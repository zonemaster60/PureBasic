Procedure StartProGUI(user.s, k1.l, k2.l, k3.l, k4.l, k5.l, k6.l, k7.l)
   Static ProGUI

   If Not ProGUI
      CompilerIf #PB_Compiler_Processor = #PB_Processor_x86
         ProGUI = OpenLibrary(#PB_Any, "ProGUI.dll")
      CompilerElse
         ProGUI = OpenLibrary(#PB_Any, "ProGUI64.dll")
      CompilerEndIf
   EndIf

   If Not ProGUI
      CompilerIf #PB_Compiler_Processor = #PB_Processor_x86
         MessageRequester("Error!", "Could Not open ProGUI.dll", #PB_MessageRequester_Ok)
      CompilerElse
         MessageRequester("Error!", "Could Not open ProGUI64.dll", #PB_MessageRequester_Ok)
      CompilerEndIf
      End
   Else
      LWord = GetFunction(ProGUI, "LWord")
      HWord = GetFunction(ProGUI, "HWord")
      MakeRGB = GetFunction(ProGUI, "MakeRGB")
      MakeColor = GetFunction(ProGUI, "MakeColor")
