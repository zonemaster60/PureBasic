Prototype SetTextControlExStyle(id.i, style.l) ; Sets the style flags for the specified TextControlEx
Prototype GetTextControlExStyle(id.i) ; Returns the style flags of the specified TextControlEx
Prototype SetTextControlExLinePadding(id.i, padding.l) ; Sets the TextControlEx spacing between lines
Prototype SetTextControlExDimensions(id.i, width.l, height.l) ; Sets the width/height of a previously created TextControlEx
Prototype TextControlExWidth(id.i) ; Returns the width in pixels of a TextControlEx
Prototype TextControlExHeight(id.i) ; Returns the height in pixels of a TextControlEx
Prototype TextControlExCalcSize(id.i, Text.p-unicode, width.i, height.i)
Prototype TextControlExID(id.l) ; Returns the Windows handle of a TextControlEx
Prototype FreeTextControlEx(id.i) ; Frees a TextControlEx from memory.
Prototype changeListiconSubIcon(listicon.i, itempos.l, subitempos.l, image.i)
Prototype SetButtonExSkin(ID.i, Skin.i, ComponentName.p-unicode, noRefresh.i) ; Sets a ButtonEx's skin
Prototype GetButtonExSkin(ID.i) ; Gets a ButtonEx's skin
Prototype ButtonEx(WindowID.i, buttonID.l, x.l, y.l, Width.l, Height.l, Text.p-unicode, normalImageID.i, hotImageID.i, pressedImageID.i, disabledImageID.i, skin.i) ; Creates an extended skinned button
Prototype ImageButtonEx(WindowID.i, buttonID.l, x.l, y.l, imageWidth.l, imageHeight.l, normalImageID.i, hotImageID.i, pressedImageID.i, disabledImageID.i) ; Creates an extended image button
Prototype ToggleButtonEx(WindowID.i, buttonID.l, x.l, y.l, Width.l, Height.l, Text.p-unicode, normalImageID.i, hotImageID.i, pressedImageID.i, selectedImageID.i, hotSelectedImageID.i, pressedSelectedImageID.i, disabledImageID.i, skin.i) ; Creates an extended skinned toggle state button
Prototype RadioButtonEx(WindowID.i, buttonID.l, x.l, y.l, Width.l, Height.l, Text.p-unicode, skin.i) ; Creates an extended skinned radio button or closes the current radio group if WindowID is null
Prototype CheckButtonEx(WindowID.i, buttonID.l, x.l, y.l, Width.l, Height.l, Text.p-unicode, skin.i) ; Creates an extended skinned check box button
Prototype ChangeButtonEx(id.i, normalImageID.i, hotImageID.i, pressedImageID.i, selectedImageID.i, hotSelectedImageID.i, pressedSelectedImageID.i, disabledImageID.i) ; Changes a ButtonEx's images
Prototype SetButtonExText(id.i, text.p-unicode) ; Sets the text of a skinned ButtonEx
Prototype GetButtonExText_(id.i) ; Gets the text of a skinned ButtonEx
Prototype ButtonExToolTip(id.i, text.p-unicode)
Prototype GetButtonExState(id.i) ; Returns the state of a ToggleButtonEx, CheckButtonEx or RadioButtonEx
Prototype SetButtonExState(id.i, state.i) ; Sets the state of a ToggleButtonEx, CheckButtonEx or RadioButtonEx
Prototype ButtonExID(id.l) ; Returns a handle to a ButtonEx's window
Prototype DisableButtonEx(id.i, disable.i) ; Disables/enables a ButtonEx, disable = True/False
Prototype FreeButtonEx(id.i) ; Frees a ButtonEx from memory
Prototype SetSplitterExSkin(ID.i, Skin.i, ComponentName.p-unicode, noRefresh.i) ; Sets a SplitterEx's skin
Prototype GetSplitterExSkin(ID.i) ; Gets a SplitterEx's skin
Prototype SplitterEx(WindowID.i, SplitterID.l, x.l, y.l, Width.l, Height.l, WindowID1.i, WindowID2.i, Skin.i, Flags.i) ; Creates a skinned splitter control
Prototype SetSplitterExAttribute(ID.i, Attribute.i, Value.i) ; Sets a SplitterEx's attributes
Prototype GetSplitterExAttribute(ID.i, Attribute.i) ; Gets a SplitterEx's attribute
Prototype SplitterExID(id.l) ; Returns a handle to a SplitterEx's window
Prototype FreeSplitterEx(id.i) ; Frees a SplitterEx from memory
Prototype SetExplorerBarSkin(ID.i, Skin.i, ComponentName.p-unicode, noRefresh.i) ; Sets an ExplorerBar's skin
Prototype GetExplorerBarSkin(ID.i) ; Gets an ExplorerBar's skin
Prototype CreateExplorerBar(WindowID.i, ExplorerBarID.l, x.l, y.l, Width.l, Height.l, Skin.i) ; Creates an empty skinned ExplorerBar control
Prototype AddExplorerBarImageGroup(Title.p-unicode, normalImageID.i, hotImageID.i, pressedImageID.i, selectedImageID.i, hotSelectedImageID.i, pressedSelectedImageID.i, disabledImageID.i, isCollapsed.i) ; Adds a new group with header icon/image to the current previously created ExplorerBar control
Prototype AddExplorerBarGroup(Title.p-unicode, isCollapsed.i) ; Adds a new group to the current previously created ExplorerBar control
Prototype SetExplorerBarGroupState(ID.i, Index.i, Collapse.i) ; Sets the ExplorerBar group's collapsed state, true/false.
Prototype GetExplorerBarGroupState(ID.i, Index.i) ; Returns true if the specified ExplorerBar group is collapsed, false otherwise.
Prototype ExplorerBarImageItem(ItemID.l, Text.p-unicode, normalImageID.i, hotImageID.i, pressedImageID.i, disabledImageID.i) ; Adds a new item with icon/image to the current previously created ExplorerBar group.
Prototype ExplorerBarItem(ItemID.l, Text.p-unicode) ; Adds a new item to the current previously created ExplorerBar group.
Prototype ExplorerBarID(id.l) ; Returns a handle to an ExplorerBar's window (HWND)
Prototype FreeExplorerBar(id.i) ; Frees an ExplorerBar from memory

