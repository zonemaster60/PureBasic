; /---------------------------------------------------------\; |         _____             _______   _     _             |; |        |  __ \           |__   __| (_)   | |            |; |        | |__) |   _ _ __ ___| |_ __ _ ___| |            |; |        |  ___/ | | | '__/ _ \ | '__| / __| |            |; |        | |   | |_| | | |  __/ | |  | \__ \_|            |; |        |_|    \__,_|_|  \___|_|_|  |_|___(_)            |; |                                                         |; |                 Code by Mindphazer                      |; |                                                         |; |                  v1.1.1 (c) 2023                        |; |                                                         |; |---------------------------------------------------------|; | Compatibilité OS :                                      |; | [x] MacOS   - Main development platform                 |; | [x] Windows - [x] DPI aware (hopefully!)                |; | [x] Linux   - Thanks NicTheQuick                        |; |---------------------------------------------------------|; |                                                         |; | Feel free to improve !                                  |; |                                                         |; \---------------------------------------------------------/ ; /---------------------------------------------------------\; |                                                         |; |  Constantes                                             |; |                                                         |; \---------------------------------------------------------/Enumeration Timer  #Timer  #TimerScroll  #TimerGradient  #TimerPlayingTimeEndEnumerationEnumeration #PB_Event_FirstCustomValue  #DummyEvent  #EventFall  #EventLeft  #EventRightEndEnumerationEnumeration MenuBar  #MainMenuEndEnumerationEnumeration MenuItems  #MainMenuAbout  #MainMenuExit  #MenuClear  #MenuNewGame  #KeyN  #KeyESCEndEnumerationEnumeration Sounds  #SoundFall  #SoundGameOver  #SoundGameStart  #SoundTouch  #SoundLineClearSingle  #SoundLineClearDouble  #SoundLineClearTriple  #SoundTouchLR  #SoundSpecialTetris  #SoundLevelUp  #SoundPieceTouchDownEndEnumerationEnumeration 2003  #MainWindow  #HighScoresWindow  #HighScoresWindowCanvas  #ButtonAide  #Grille  #Next  #Hold  #Score  #ButtonQuit  #ButtonNewGame  #Lignes  #HighScores  #Niveau  #Statistiques  #Title  #ButtonClearHS  #CheckboxSound  #CheckBoxShadow  #Font_MainWindow_0  #TimeEndEnumeration#LargeurGrille    = 10#HauteurGrille    = 22#LargeurCase      = 25#LargeurMiniature = 12#NombreDePieces   = 7#NBHighScores     = 10#CouleurFond      = $555555#AppName          = "PureTris !"#AppVersion       = "1.1.1"#HighScoresFile   = "PureTrisHi.dat"; /---------------------------------------------------------\; |                                                         |; |  Structures                                             |; |                                                         |; \---------------------------------------------------------/Structure Scores  Nom.s  Score.i  Level.i  Date.s  NBLines.i  PlayingTime.s  NBTetris.iEndStructureStructure Piece  Couleur.i  Taille.b         Array Matrice.b(3, 3)  Array MatriceOrig.b(3, 3)  Shape.iEndStructureStructure Bouton  X.i  Y.i  Length.i  Height.i  Libelle.s  BackColor.iEndStructure; /---------------------------------------------------------\; |                                                         |; |  Variables globales                                     |; |                                                         |; \---------------------------------------------------------/Global Dim StructurePiece.Piece(#NombreDePieces)Global Dim HighScores.Scores(#NBHighScores)Global Dim Grille.b(#LargeurGrille, #HauteurGrille)Global GameInProgress.b = #False, PlayingTime, PlayingSeconds, PlayingMinutesGlobal GamePaused.b = #FalseGlobal NeverPlayed = #TrueGlobal ScreenPaused, PureTrisGlobal SoundEnabled.bGlobal ImageText, YImage, TailleScroll, ImgFondGlobal Piece.b, XPiece.b, YPiece.b, NextPiece.b, CurrentIndex.bGlobal XShadow.b, YShadow.b ;, Shadow.bGlobal Dim RotateTemp.b(3, 3)Global NewList ScrollText.s()Global NewMap GadgetB.Bouton()Global NewMap Languages.s()Global YOrigine.b = 0Global XOrigine.b = 3Global ScoreGlobal LignesGlobal NBTetrisGlobal Level.a = 1Global Tempo = 1000Global HoldGlobal ImgPoints, Points, IntensitePoints.a, HauteurChute = 1Global FontScorePetit, FontScoreNormal, FontGameOver, FontPoints, FontConsolas, FontOptima, FontConsolasBigGlobal ImgGameOver, ImgGamePaused, ImgBlurred, ImgTitle, ImgPointsFondGlobal Dim CouleurPoints(4)Global Dim Panier(#NombreDePieces)Global NbAnim = 90Global Dim LogoAnime(NbAnim)Global Text_0, Text_1, Text_2, Text_3, Text_4, Text_5, Text_6, Frame_0Restore PiecesFor k = 1 To #NombreDePieces  Read.b StructurePiece(k)\Taille  Read.i StructurePiece(k)\Couleur  For i = 0 To StructurePiece(k)\Taille    For j = 0 To StructurePiece(k)\Taille      Read.b StructurePiece(k)\Matrice(j, i)      StructurePiece(k)\MatriceOrig(j, i) = StructurePiece(k)\Matrice(j, i)    Next j  Next iNext kRestore CreditsRepeat  Read.s t$  If t$ <> "_END_"    AddElement(ScrollText())    ScrollText() = t$  EndIfUntil t$ = "_END_"Procedure.s GetLanguage()  CompilerIf #PB_Compiler_OS = #PB_OS_MacOS    Protected Result.s, NSUserDefaults_defs, NSString_locale    NSUserDefaults_defs = CocoaMessage(0,0,"NSUserDefaults standardUserDefaults")    If NSUserDefaults_defs      NSString_locale  = CocoaMessage(0,NSUserDefaults_defs,"objectForKey:$",@"AppleLocale")      If NSString_locale        Result = PeekS(CocoaMessage(0, NSString_locale, "UTF8String"), -1, #PB_UTF8)        ;release(NSString_locale)      EndIf      ;release(NSUserDefaults_defs)    EndIf    ;Debug Result    Select Result      Case "fr-FR"        ProcedureReturn "FRA"      Case "en-US"        ProcedureReturn "ENG"      Case "de-DE"        ProcedureReturn "GER"    EndSelect  CompilerElseIf #PB_Compiler_OS = #PB_OS_Windows    Protected UserIntLang, *Lang    If OpenLibrary(0, "kernel32.dll")	    *Lang = GetFunction(0, "GetUserDefaultUILanguage")	    If *Lang		    UserIntLang = CallFunctionFast(*Lang)	    EndIf	    CloseLibrary(0)	  EndIf	  Select UserIntLang	    Case 1036	      ProcedureReturn "FRA"	    Case 1033	      ProcedureReturn "ENG"	    Case 1031	      ProcedureReturn "GER"	  EndSelect	CompilerElseIf #PB_Compiler_OS = #PB_OS_Linux	  Protected UserIntLang$		If ExamineEnvironmentVariables()		  While NextEnvironmentVariable()		    If Left(EnvironmentVariableName(), 4) = "LANG"					UserIntLang$ = Left(EnvironmentVariableValue(), 2)				  Break				EndIf		  Wend		EndIf		Select UserIntLang$		  Case "fr"		    ProcedureReturn "FRA"		  Case "de"		    ProcedureReturn "GER"		  Case "en"		    ProcedureReturn "ENG"		EndSelect  CompilerEndIfEndProcedureProcedure.b SoundIsOn()  If GetGadgetState(#CheckBoxSound) = #PB_Checkbox_Checked    ProcedureReturn #True  Else    ProcedureReturn #False  EndIfEndProcedureProcedure RemplirPanier()  Protected i.b, Temp.b, id.b  For i = 1 To #NombreDePieces    Panier(i) = i  Next i  For i = 1 To #NombreDePieces    id = Random(i, 1)    Temp = Panier(i)    Panier(i) = Panier(id)    Panier(id) = Temp  Next iEndProcedureProcedure.b NextPiece()  CurrentIndex + 1  If CurrentIndex > #NombreDePieces    RemplirPanier()    CurrentIndex = 1  EndIf  ProcedureReturn Panier(CurrentIndex)EndProcedureProcedure RedrawButton(Gadget, Mode = 0)  Protected Key.s, Contour, Interieur  Key = Str(Gadget)  If StartDrawing(CanvasOutput(Gadget))    If Mode = 0      Contour = $444444      Interieur = $DDDDDD    Else      Contour = GadgetB(Key)\BackColor & $AAAAAA ;$384837      Interieur = GadgetB(Key)\BackColor ;$C9FFC4    EndIf     RoundBox(0, 0, OutputWidth(), OutputHeight(), 2, 2, Contour)    RoundBox(1, 1, OutputWidth() - 2, OutputHeight() - 2, 2, 2, Interieur)    DrawingMode(#PB_2DDrawing_Transparent)    DrawingFont(FontID(FontOptima))    DrawText(DesktopScaledX(GadgetB(Key)\Length * 0.5) - (TextWidth(GadgetB(Key)\Libelle) * 0.5) + Mode, DesktopScaledY(GadgetB(Key)\Height * 0.5) - (TextHeight(GadgetB(Key)\Libelle) * 0.5) + Mode, GadgetB(Key)\Libelle, $222222)    StopDrawing()  EndIfEndProcedureProcedure MyButton(Gadget, Xb, Yb, L, H, Texte.s, Couleur = $D7ED9F)  Protected Key.s  If CanvasGadget(Gadget, Xb, Yb, L, H)    Key = Str(Gadget)    AddMapElement(GadgetB(), Str(Gadget))    GadgetB(Key)\X         = Xb    GadgetB(Key)\Y         = Yb    GadgetB(Key)\Length    = L     GadgetB(Key)\Height    = H    GadgetB(Key)\Libelle   = Texte    GadgetB(key)\BackColor = Couleur    RedrawButton(Gadget, 0)  EndIfEndProcedureProcedure EffaceCase(X, Y)  Box(DesktopScaledX(X * #LargeurCase), DesktopScaledY(Y * #LargeurCase), DesktopScaledX(#LargeurCase), DesktopScaledY(#LargeurCase), #CouleurFond)EndProcedureProcedure ClearCanvas()  DrawingMode(#PB_2DDrawing_Gradient)  BackColor(#CouleurFond)  FrontColor($999999)  LinearGradient(1, 1, 1, OutputHeight() - 2)  RoundBox(0, 0, OutputWidth(), OutputHeight(), 2, 2)EndProcedure  Procedure DessinHold()  Protected i.b, j.b, X, Y  If StartDrawing(CanvasOutput(#Hold))    ClearCanvas()    DrawingMode(#PB_2DDrawing_AlphaBlend)    X = GadgetWidth(#Hold) / 2 - ((#LargeurCase * (StructurePiece(Hold)\Taille + 1) / 2))    Y = GadgetHeight(#Hold) / 2 - ((#LargeurCase * (StructurePiece(Hold)\Taille + 1) / 2)) + 11    If Hold = 2 : Y - 10 : EndIf    For i = 0 To StructurePiece(Hold)\Taille      For j = 0 To StructurePiece(Hold)\Taille        If StructurePiece(Hold)\MatriceOrig(j, i) = 1          DrawAlphaImage(ImageID(StructurePiece(Hold)\Shape), DesktopScaledX(X + (j * #LargeurCase)), DesktopScaledY(Y + (i * #LargeurCase)), 150)        EndIf      Next j    Next i    StopDrawing()  EndIfEndProcedure  Procedure DessinPiece(Piece, X, Y, Shadow = #False)  Protected i.b, j.b  If StartDrawing(CanvasOutput(#Grille))    For i = 0 To StructurePiece(Piece)\Taille      For j = 0 To StructurePiece(Piece)\Taille        If StructurePiece(Piece)\Matrice(j, i) = 1          If Shadow And Y > YPiece            DrawingMode(#PB_2DDrawing_AlphaBlend)            DrawAlphaImage(ImageID(StructurePiece(Piece)\Shape), DesktopScaledX((X + j) * #LargeurCase), DesktopScaledY((Y + i) * #LargeurCase), 50)          Else            DrawImage(ImageID(StructurePiece(Piece)\Shape), DesktopScaledX((X + j) * #LargeurCase), DesktopScaledY((Y + i) * #LargeurCase))          EndIf        EndIf      Next j    Next i     StopDrawing()  EndIfEndProcedureProcedure DessinMiniature(Piece, X, Y, Taille)  For i = 0 To StructurePiece(Piece)\Taille    For j = 0 To StructurePiece(Piece)\Taille      If StructurePiece(Piece)\Matrice(j, i) = 1        Box(DesktopScaledX(X + (j * Taille)), DesktopScaledY((i * Taille) + Y), DesktopScaledX(Taille), DesktopScaledY(Taille), #Black)              Box(DesktopScaledX(X + (j * Taille)) + 1, DesktopScaledY((i * Taille) + Y) + 1, DesktopScaledX(Taille) - 2, DesktopScaledY(Taille) - 2, StructurePiece(Piece)\Couleur)         EndIf    Next j  Next i   EndProcedureProcedure DessinNext(Piece)  Protected i.b, j.b, X, Y, Taille = 16  If StartDrawing(CanvasOutput(#Next))    ClearCanvas()    DrawingMode(#PB_2DDrawing_Default)    X = GadgetWidth(#Next) / 2 - ((Taille * (StructurePiece(Piece)\Taille + 1) / 2))    Y = GadgetHeight(#Next) / 2 - ((Taille * (StructurePiece(Piece)\Taille + 1) / 2)) + 8    If Piece = 2 : Y - 7 : EndIf    If Piece > 0      DessinMiniature(Piece, X, Y, Taille)    EndIf     StopDrawing()  EndIfEndProcedureProcedure EffacePiece(Piece, X, Y)  Protected i.b, j.b   If StartDrawing(CanvasOutput(#Grille))    For i = 0 To StructurePiece(Piece)\Taille      For j = 0 To StructurePiece(Piece)\Taille        If StructurePiece(Piece)\Matrice(j, i) = 1           EffaceCase(X + j, Y + i)        EndIf      Next j    Next i     StopDrawing()  EndIf EndProcedure;Procedure DessineGrille();  Protected i.b, j.b;  If StartDrawing(CanvasOutput(#HighScores))    ;    Box(0, 0, OutputWidth(), OutputHeight(), $333333);    Y = 7;    X = 35;    For i = 0 To #HauteurGrille - 1;      For j = 0 To #LargeurGrille - 1;        If Grille(j, i) = 0 : C = $444444 : Else : C = #Red : EndIf ;         Box(DesktopScaledX((j * 10) + X), DesktopScaledY((i * 8) + Y), DesktopScaledX(9), DesktopScaledY(7), C);      Next j;    Next i;    StopDrawing();  EndIf;EndProcedureProcedure.b CanMoveRight(Piece, X, Y)  Protected i.b, j.b  For i = 0 To StructurePiece(Piece)\Taille    For j = 0 To StructurePiece(Piece)\Taille      If StructurePiece(Piece)\Matrice(j, i)        If X + j + 1 >= #LargeurGrille          ProcedureReturn #False        EndIf        If Y + i >= 0          If Grille(X + j + 1, Y + i) = 1             ProcedureReturn #False          EndIf        EndIf      EndIf    Next  NextProcedureReturn #TrueEndProcedureProcedure.b CanMoveLeft(Piece, X, Y)  Protected i.b, j.b  For i = 0 To StructurePiece(Piece)\Taille    For j = 0 To StructurePiece(Piece)\Taille      If StructurePiece(Piece)\Matrice(j, i)        If X + j - 1 < 0           ProcedureReturn #False        EndIf        If Y + i >= 0          If Grille(X + j - 1, Y + i) = 1            ProcedureReturn #False          EndIf        EndIf      EndIf    Next j  Next i  ProcedureReturn #TrueEndProcedureProcedure.b CanMoveDown(Piece, X, Y)  Protected i.b, j.b  For i = 0 To StructurePiece(Piece)\Taille    For j = 0 To StructurePiece(Piece)\Taille      If StructurePiece(Piece)\Matrice(j, i)        If (Y + i + 1) >= #HauteurGrille           ProcedureReturn #False        EndIf        If Grille(X + j, Y + i + 1) = 1          ProcedureReturn #False        EndIf      EndIf     Next j  Next i  ProcedureReturn #TrueEndProcedureProcedure EffaceShadow(Piece, X, Y)  Protected i.b, j.b  If GetGadgetState(#CheckBoxShadow) = #PB_Checkbox_Checked    If StartDrawing(CanvasOutput(#Grille)) ; And Shadow = #True      For i = 0 To StructurePiece(Piece)\Taille        For j = 0 To StructurePiece(Piece)\Taille          If StructurePiece(Piece)\Matrice(j, i) = 1 And Grille(X + j, Y + i) <> 1            EffaceCase(X + j, Y + i)          EndIf        Next j      Next i       StopDrawing()    EndIf   EndIfEndProcedureProcedure Shadow(Piece, XPiece, YPiece)  Protected Y.b  If GetGadgetState(#CheckBoxShadow) = #PB_Checkbox_Checked    Y = YPiece    While CanMoveDown(Piece, XPiece, Y)      Y = Y + 1    Wend      If Y > YPiece      YShadow = Y      XShadow = XPiece      DessinPiece(Piece, XShadow, YShadow, #True)    EndIf  EndIfEndProcedureProcedure EcritTexte(X, Y, T$, Couleur = #White, Gras = #False)  DrawText(X + 1, Y + 1, T$, #Black)  DrawText(X, Y, T$, Couleur)  If Gras     DrawText(X - 1, Y, T$, Couleur)  EndIfEndProcedureProcedure AfficheScore()  Protected S.s, i, DecalageY.b  CompilerIf #PB_Compiler_OS = #PB_OS_MacOS    DecalageY = 0  CompilerElse    DecalageY = -2  CompilerEndIf    S = RSet(Str(Score), 7, "0")   ; On affiche le score sur 7 chiffres  If StartDrawing(CanvasOutput(#Score))    ClearCanvas()    DrawingFont(FontID(FontScoreNormal))    DrawingMode(#PB_2DDrawing_Transparent)    EcritTexte((OutputWidth() / 2) - (TextWidth(S) / 2), DecalageY, S, $16A3FF)    StopDrawing()  EndIf    S = RSet(Str(Lignes), 3, "0")  ; On affiche le nombre de lignes sur 3 chiffres  If StartDrawing(CanvasOutput(#Lignes))    ClearCanvas()    DrawingFont(FontID(FontScoreNormal))    DrawingMode(#PB_2DDrawing_Transparent)    EcritTexte((OutputWidth() / 2) - (TextWidth(S) / 2) - 1, DecalageY - 1, S, #Green)    StopDrawing()  EndIf  S = RSet(Str(Level), 2, "0")  ; On affiche le niveau sur 2 chiffres  If StartDrawing(CanvasOutput(#Niveau))    ClearCanvas()    DrawingFont(FontID(FontScoreNormal))    DrawingMode(#PB_2DDrawing_Transparent)    EcritTexte((OutputWidth() / 2) - (TextWidth(S) / 2) - 1, DecalageY - 1, S, #Cyan)    StopDrawing()  EndIfEndProcedureProcedure AfficherTemps()  Protected T.s = RSet(Str(PlayingMinutes), 2, "0") + ":" + RSet(Str(PlayingSeconds), 2, "0")  If StartDrawing(CanvasOutput(#Time))    ClearCanvas()    DrawingFont(FontID(FontScorePetit))    DrawingMode(#PB_2DDrawing_Transparent)    EcritTexte((OutputWidth() / 2) - (TextWidth(T) / 2) - 1, (OutputHeight() / 2) - (TextHeight(T) / 2) - 1, T, $6A6AFF)    StopDrawing()  EndIfEndProcedureProcedure.b FadeLine(Transparence, Ligne, ImgLine)  If Transparence > 0    If StartDrawing(CanvasOutput(#Grille))      Box(0, DesktopScaledY(Ligne * #LargeurCase), OutputWidth(), DesktopScaledY(#LargeurCase), #CouleurFond)      DrawingMode(#PB_2DDrawing_AlphaBlend)      DrawAlphaImage(ImageID(ImgLine), 0, DesktopScaledY(Ligne * #LargeurCase), Transparence)      CompilerIf #PB_Compiler_OS = #PB_OS_MacOS        Delay(1)      CompilerEndIf      StopDrawing()      PostEvent(#DummyEvent)      ProcedureReturn #True    EndIf  EndIf  ProcedureReturn #FalseEndProcedureProcedure EffacerLigne(Ligne)  Protected i, j.b, ImgLine, Dummy  If StartDrawing(CanvasOutput(#Grille))    ImgLine = GrabDrawingImage(#PB_Any, 0, DesktopScaledY(Ligne * #LargeurCase), OutputWidth(), DesktopScaledY(#LargeurCase))    StopDrawing()  EndIf  i = 254  While FadeLine(i, Ligne, ImgLine)    CompilerIf #PB_Compiler_OS = #PB_OS_MacOS      i - 2      While WindowEvent() : Wend    CompilerElse      i - 1    CompilerEndIf  Wend    ; Décalage de l'image de la grille d'une ligne vers le bas  If StartDrawing(CanvasOutput(#Grille))    Dummy = GrabDrawingImage(#PB_Any, 0, 0, OutputWidth(), DesktopScaledY(Ligne * #LargeurCase))    DrawImage(ImageID(Dummy), 0, DesktopScaledY(#LargeurCase))    Box(0, 0, OutputWidth(), DesktopScaledX(#LargeurCase), #CouleurFond)    StopDrawing()  EndIf  For i = Ligne To 1 Step -1    For j = 0 To #LargeurGrille - 1      Grille(j, i) = Grille(j, i - 1)    Next j  Next i  FreeImage(Dummy)  FreeImage(ImgLine)EndProcedureProcedure CheckLine()  Protected i, j.b, YPoints, NBLignes.b, TP.s, PerfectClear.b, BonusShadow.b, Points  For i = #HauteurGrille - 1 To 0 Step -1      LigneComplete = #True    For j = 0 To #LargeurGrille - 1      If Grille(j, i) = 0        LigneComplete = #False        Break      EndIf    Next j    If LigneComplete = #True      EffacerLigne(i)      i = i + 1      NBLignes = NBLignes + 1      Lignes + 1      If Lignes % 10 = 0  ; Toutes les 10 lignes, on augmente le niveau et on accélère le jeu        If SoundEnabled And IsSound(#SoundLevelUp) And SoundIsOn() : PlaySound(#SoundLevelUp) : EndIf         Tempo = Tempo - (Tempo * 0.12)        If Tempo < 10 : Tempo = 10 : EndIf        Level + 1        RemoveWindowTimer(#MainWindow, #Timer)        AddWindowTimer(#MainWindow, #Timer, Tempo)      EndIf     EndIf  Next i  PerfectClear = #True                ; Perfect clear, quand la grille de jeu est vide après avoir effacé une ou plusieurs lignes  For i = 0 To #LargeurGrille - 1    For j = 0 To #HauteurGrille - 1      If Grille(i, j) = 1        PerfectClear = #False        Break      EndIf    Next j  Next i  If GetGadgetState(#CheckBoxShadow) = #PB_Checkbox_Checked    HauteurChute = 1   EndIf  Select NBLignes    Case 0      Points = Level * HauteurChute    Case 1      Points = (40 * Level)  + (Level * HauteurChute) + (PerfectClear * 800 * Level)      If SoundEnabled And IsSound(#SoundLineClearSingle) And SoundIsOn() : PlaySound(#SoundLineClearSingle) : EndIf     Case 2      Points = (100 * Level) + (Level * HauteurChute) + (PerfectClear * 1200 * Level)      If SoundEnabled And IsSound(#SoundLineClearDouble) And SoundIsOn() : PlaySound(#SoundLineClearDouble) : EndIf     Case 3      Points = (300 * Level) + (Level * HauteurChute) + (PerfectClear * 1800 * Level)      If SoundEnabled And IsSound(#SoundLineClearTriple) And SoundIsOn() : PlaySound(#SoundLineClearTriple) : EndIf     Case 4      Points = (1200 * Level) + (Level * HauteurChute) + (PerfectClear * 2000 * Level)      If SoundEnabled And IsSound(#SoundSpecialTetris) And SoundIsOn() : PlaySound(#SoundSpecialTetris) : EndIf       NBTetris + 1  EndSelect  Score + Points  IntensitePoints = 255  HauteurChute = 1  TP = "+" + Str(Points) + " pt"  If Points > 1 : TP + "s" : EndIf  Ypoints = 2  If IsImage(ImgPoints)     FreeImage(ImgPoints)  EndIf  ImgPoints = CreateImage(#PB_Any, DesktopScaledX(GadgetWidth(#Score) - 2), DesktopScaledY(28))    If StartDrawing(ImageOutput(ImgPoints))    DrawImage(ImageID(ImgPointsFond), 0, 0)    DrawingMode(#PB_2DDrawing_Transparent)    DrawingFont(FontID(FontScorePetit))    DrawText((OutputWidth() / 2) - (TextWidth(TP) / 2) + 1, DesktopScaledY(Ypoints) + 1, TP, #Black)    DrawText((OutputWidth() / 2) - (TextWidth(TP) / 2), DesktopScaledY(Ypoints), TP, CouleurPoints(NBLignes))    StopDrawing()  EndIfEndProcedureProcedure DeposePiece(Piece, X, Y)  Protected i.b, j.b  For i = 0 To StructurePiece(Piece)\Taille    For j = 0 To StructurePiece(Piece)\Taille      If StructurePiece(Piece)\Matrice(j, i) = 1        If X + j >= 0 And Y + i >= 0          Grille(X + j, Y + i) = 1        EndIf      EndIf    Next j  Next i  Checkline()  AfficheScore()  ;DessineGrille()EndProcedureProcedure.b CanRotate(Piece, X, Y, Sens = 1)  Protected i.b, j.b  For i = 0 To StructurePiece(Piece)\Taille    For j = 0 To StructurePiece(Piece)\Taille      If Sens = 1  ; rotation antihoraire        RotateTemp(i, j) = StructurePiece(Piece)\Matrice(StructurePiece(Piece)\Taille - j, i) ; on fait une rotation de la pièce vers un tableau temporaire (qu'on utilisera si la rotation peut se faire)      Else         ; rotation horaire        RotateTemp(i, j) = StructurePiece(Piece)\Matrice(j, StructurePiece(Piece)\Taille - i)       EndIf    Next j  Next i  For i = 0 To StructurePiece(Piece)\Taille    For j = 0 To StructurePiece(Piece)\Taille      If RotateTemp(j, i) = 1        If X + j < 0 Or X + j > #LargeurGrille - 1           If Piece = 1 And X + j > #LargeurGrille - 1            If j < StructurePiece(Piece)\Taille              ProcedureReturn X + j + 1            EndIf          EndIf          ProcedureReturn X + j        EndIf        If Y + i > #HauteurGrille - 1          ProcedureReturn #False        EndIf        If Y + i > 0          If Grille(X + j, Y + i) = 1            ProcedureReturn #False          EndIf        EndIf      EndIf    Next j  Next i  ProcedureReturn #TrueEndProcedureProcedure RotatePiece(Piece, X, Y)  Protected i.b, j.b  EffaceShadow(Piece, XShadow, YShadow)  EffacePiece(Piece, X, Y)  For i = 0 To StructurePiece(Piece)\Taille    For j = 0 To StructurePiece(Piece)\Taille      StructurePiece(Piece)\Matrice(i, j) = RotateTemp(i, j)  ; On copie dans StructurePiece le contenu du tableau RotateTemp qui avait été modifié lors de l'appel à CanRotate()    Next j  Next iEndProcedureProcedure.s Character(Char.s, Number.b)  Protected String.s, i.b  For i = 1 To Number    String = String + Char  Next i  ProcedureReturn StringEndProcedureProcedure AfficheHiscores()  Protected Y, i.b, T$  If StartDrawing(CanvasOutput(#HighScores))    ClearCanvas()    DrawingMode(#PB_2DDrawing_Transparent)    Y = 8    DrawingFont(FontID(FontConsolas))    For i = 1 To #NBHighScores      T$ = RSet(Str(i), 2, " ") + " - " + HighScores(i)\Nom + Character(".", 10 - Len(HighScores(i)\Nom)) + RSet(Str(HighScores(i)\Score), 7, "0")      Couleur = RGB(255 - ((i - 1) * 5), 220 - ((i - 1) * 5), 24)      DrawText(5, Y + ((i - 1) * TextHeight(T$)), T$, Couleur); $75D972)      If i = 1        DrawText(6, Y + ((i - 1) * TextHeight(T$)), T$, Couleur); $75D972)      EndIf    Next i    StopDrawing()    EndIfEndProcedureProcedure OpenWindowHiScores()  Protected Exit.b = #False, Evt, EventType, WW = 640, WH = 360, Y, T$, Gras.b  Protected Couleur, Couleur1, Couleur2, Couleur3, Couleur4, Couleur5, Couleur6  DisableWindow(#MainWindow, #True)  OpenWindow(#HighScoresWindow, 0, 0, WW, WH, "", #PB_Window_BorderLess | #PB_Window_WindowCentered, WindowID(#MainWindow))  CanvasGadget(#HighScoresWindowCanvas, 0, 0, WW, WH, #PB_Canvas_Keyboard)  AddKeyboardShortcut(#HighScoresWindow, #PB_Shortcut_Escape, #KeyESC)  If StartDrawing(CanvasOutput(#HighScoresWindowCanvas))    Box(0, 0, OutputWidth(), OutputHeight(), #Black)    Box(1, 1, OutputWidth() - 2, OutputHeight() - 2, #CouleurFond)    DrawingMode(#PB_2DDrawing_Transparent)     DrawingFont(FontID(FontScorePetit))    Couleur = $FCA28C    EcritTexte(DesktopScaledX(12),  DesktopScaledY(10), "#", Couleur)    EcritTexte(DesktopScaledX(40),  DesktopScaledY(10), "Points", Couleur)    EcritTexte(DesktopScaledX(160), DesktopScaledY(10), "Nom", Couleur)    EcritTexte(DesktopScaledX(250), DesktopScaledY(10), "Lvl", Couleur)    EcritTexte(DesktopScaledX(300), DesktopScaledY(10), "Li", Couleur)    EcritTexte(DesktopScaledX(360), DesktopScaledY(10), "Date", Couleur)    EcritTexte(DesktopScaledX(510), DesktopScaledY(10), "Time", Couleur)    EcritTexte(DesktopScaledX(580), DesktopScaledY(10), "Tetris", Couleur)    For i = 1 To #NBHighScores      Couleur  = RGB(255 - (i * 5), 220 - (i * 5), 24)      Couleur1 = RGB(155 - (i * 5), 220 - (i * 5), 224)      Couleur2 = RGB(155 - (i * 5), 220 - (i * 5), 24)      Couleur3 = RGB(255 - (i * 5), 220 - (i * 5), 124)      Couleur4 = RGB(55 -  (i * 5), 220 - (i * 5), 124)      Couleur5 = RGB(205 - (i * 5), 220 , 224 - (i * 5))      Couleur6 = RGB(255 - (i * 5), 020 , 54 - (i * 5))      T$ = RSet(Str(i), 2, " ")      Y = (TextHeight(T$) * i) + DesktopScaledY(20)      If i = 1 : Gras = #True : Else : Gras = #False : EndIf      EcritTexte(DesktopScaledX(10),  Y, T$, Couleur, Gras)      EcritTexte(DesktopScaledX(40),  Y, RSet(Str(HighScores(i)\Score), 7, "0"), Couleur1, Gras)      EcritTexte(DesktopScaledX(160), Y, HighScores(i)\Nom, Couleur2, Gras)      EcritTexte(DesktopScaledX(250), Y, RSet(Str(HighScores(i)\Level), 2, "0"), Couleur3, Gras)      EcritTexte(DesktopScaledX(300), Y, RSet(Str(HighScores(i)\NBLines), 3, "0"), Couleur4, Gras)      EcritTexte(DesktopScaledX(360), Y, HighScores(i)\Date, #White, Gras)      EcritTexte(DesktopScaledX(510), Y, HighScores(i)\PlayingTime, Couleur5, Gras)      EcritTexte(DesktopScaledX(590), Y, RSet(Str(HighScores(i)\NBTetris), 2, "0"), Couleur6, Gras)    Next i    StopDrawing()  EndIf    Repeat    Evt = WaitWindowEvent()    EventType = EventType()    EventGadget = EventGadget()    If Evt = #PB_Event_Gadget      If EventGadget = #HighScoresWindowCanvas        If EventType = #PB_EventType_LeftClick          Exit = #True          EndIf      EndIf    ElseIf Evt = #PB_Event_Menu      If EventMenu() = #KeyESC        Exit = #True      EndIf    EndIf  Until Exit = #True  CloseWindow(#HighScoresWindow)  DisableWindow(#MainWindow, #False)  SetActiveWindow(#MainWindow)EndProcedure  Procedure GameOver()  Protected i.b, Txt$, Nom$, j  GameInProgress = #False  If SoundEnabled And IsSound(#SoundGameOver) And SoundIsOn() : PlaySound(#SoundGameOver) : EndIf  If StartDrawing(CanvasOutput(#Grille))    DrawImage(ImageID(ImgGameOver), DesktopScaledX(10), DesktopScaledY(245))    StopDrawing()  EndIf  For i = 1 To #NBHighScores    If Score > HighScores(i)\Score      If i = 1        Txt$ = Languages("NewHiscore")      Else        Txt$ = Languages("ScoreNumber") + Str(i) + " !"      EndIf      Nom$ = InputRequester(Txt$, Languages("EnterName"), "")      For j = (#NBHighScores - 1) To i Step -1        HighScores(j + 1) = HighScores(j)      Next j      HighScores(i)\Nom         = Left(Nom$, 9)      HighScores(i)\Score       = Score      HighScores(i)\Level       = Level      HighScores(i)\NBLines     = Lignes      HighScores(i)\Date        = FormatDate("%dd/%mm/%yyyy", Date())      HighScores(i)\PlayingTime = Str(PlayingMinutes) + ":" + RSet(Str(PlayingSeconds), 2, "0")      HighScores(i)\NBTetris    = NBTetris      Break    EndIf  Next  AfficheHiscores()  OpenWindowHiScores()EndProcedureProcedure ClearGrille()  Protected i.b, j.b  XPiece = XOrigine  YPiece = YOrigine  If StartDrawing(CanvasOutput(#Grille))    Box(0, 0, OutputWidth(), OutputHeight(), #CouleurFond)    StopDrawing()    EndIf  If StartDrawing(CanvasOutput(#Grille))    For i = 0 To #LargeurGrille      For j = 0 To #HauteurGrille        Grille(i, j) = 0      Next j    Next i    StopDrawing()  EndIf  If StartDrawing(CanvasOutput(#Hold))    ClearCanvas()    StopDrawing()  EndIf  PlayingMinutes = 0 : PlayingSeconds = 0  AfficherTemps()  Score        = 0  NBTetris     = 0  Hold         = 0  Lignes       = 0  Level        = 1  Tempo        = 1000  HauteurChute = 1  RemoveWindowTimer(#MainWindow, #Timer)  AddWindowTimer(#MainWindow, #Timer, Tempo)  AfficheScore()  AfficheHiscores() EndProcedureProcedure.b JeuTermine()  Protected i.b  For i = 0 To #LargeurGrille - 1    If Grille(i, 0) <> 0      ProcedureReturn #True    EndIf  Next i  ProcedureReturn #FalseEndProcedureProcedure MoveDown()  Protected i.b, j.b  If GameInProgress = #True And GamePaused = #False    If CanMoveDown(Piece, XPiece, YPiece)      EffacePiece(Piece, XPiece, YPiece)      YPiece = YPiece + 1      DessinPiece(Piece, XPiece, YPiece)      ProcedureReturn #True    Else      DeposePiece(Piece, XPiece, YPiece)      If SoundEnabled And IsSound(#SoundPieceTouchDown) And SoundIsOn() : PlaySound(#SoundPieceTouchDown) : EndIf      XPiece = XOrigine      YPiece = YOrigine      Piece = NextPiece      NextPiece = NextPiece()      ; On restaure le sens de la prochaine piece grâce à la matrice d'origine, si jamais il y a eu une rotation de la pièce      For i = 0 To StructurePiece(NextPiece)\Taille        For j = 0 To StructurePiece(NextPiece)\Taille          StructurePiece(NextPiece)\Matrice(j, i) = StructurePiece(NextPiece)\MatriceOrig(j, i)        Next j      Next i      DessinNext(NextPiece)      If JeuTermine() = #True        GameOver()      Else        DessinPiece(Piece, XPiece, YPiece)        Shadow(Piece, XPiece, YPiece)        ProcedureReturn #False      EndIf    EndIf  EndIf     EndProcedureProcedure.b MoveLeft()  If CanMoveLeft(Piece, XPiece, YPiece) And GamePaused = #False    EffacePiece(Piece, XPiece, YPiece)    EffaceShadow(Piece, XShadow, YShadow)    XPiece = XPiece - 1    Shadow(Piece, XPiece, YPiece)    DessinPiece(Piece, XPiece, YPiece)      ProcedureReturn #True  EndIf  If SoundEnabled And IsSound(#SoundTouchLR) And SoundIsOn() : PlaySound(#SoundTouchLR) : EndIf   ProcedureReturn #FalseEndProcedure  Procedure.b MoveRight()  If CanMoveRight(Piece, XPiece, YPiece) And GamePaused = #False    EffacePiece(Piece, XPiece, YPiece)    EffaceShadow(Piece, XShadow, YShadow)    XPiece = XPiece + 1    Shadow(Piece, XPiece, YPiece)    DessinPiece(Piece, XPiece, YPiece)    ProcedureReturn #True  EndIf  If SoundEnabled And IsSound(#SoundTouchLR) And SoundIsOn() : PlaySound(#SoundTouchLR) : EndIf   ProcedureReturn #FalseEndProcedure Procedure PauseGame(Forced = #False)  Protected ImgH, ImgW, Pixl.b  If GamePaused = #False    GamePaused = #True    If StartDrawing(CanvasOutput(#Grille))  ; on fait une copie de l'écran de jeu      GrabDrawingImage(ScreenPaused, 0, 0, OutputWidth(), OutputHeight())      ImgBlurred = CopyImage(ScreenPaused, #PB_Any)      DrawImage(ImageID(ImgGamePaused), DesktopScaledX(10), DesktopScaledY(245))      StopDrawing()      ImgW = ImageWidth(ImgBlurred)      ImgH = ImageHeight(ImgBlurred)      Pixl = 16      ; On redimentionne 2 fois l'image, ce qui permet d'obtenir un effet flouté (NB : ne fonctionne pas en 6.00, on obtient un effet pixellisation. Il faut la 6.02 pour obtenir l'effet flouté)      ResizeImage(ImgBlurred, ImgW / Pixl , ImgH / Pixl)      ResizeImage(ImgBlurred, ImgW, ImgH, #PB_Image_Smooth)    EndIf  Else    If Forced = #False      GamePaused = #False      SetGadgetAttribute(#Grille, #PB_Canvas_Image, ImageID(ScreenPaused))      FreeImage(ScreenPaused)      FreeImage(ImgBlurred)    EndIf  EndIfEndProcedureProcedure NewGame()  If SoundEnabled And IsSound(#SoundGameStart) And SoundIsOn() : PlaySound(#SoundGameStart) : EndIf  NeverPlayed = #False  RemoveWindowTimer(#MainWindow, #TimerScroll)  SetActiveGadget(#Grille)  ClearGrille()  GameInProgress = #True  GamePaused = #False  Piece = NextPiece()  NextPiece = NextPiece()  PlayingMinutes = 0  PlayingSeconds = 0  DessinPiece(Piece, XPiece, YPiece)  Shadow(Piece, XPiece, YPiece)  DessinNext(NextPiece)EndProcedureProcedure ScrollUp()  YImage = YImage - 1  If YImage < 0 And Abs(YImage) = TailleScroll    YImage = GadgetHeight(#Grille)  EndIf  If StartDrawing(CanvasOutput(#Grille))    DrawImage(ImageID(ImageText), 0, DesktopScaledY(YImage))    StopDrawing()  EndIf    EndProcedureProcedure ClearHiScores()  Protected i.b  If MessageRequester(Languages("RequesterClearHS"), Languages("RequesterAreYouSure"), #PB_MessageRequester_YesNo | #PB_MessageRequester_Warning) = #PB_MessageRequester_Yes    For i = 1 To #NBHighScores      HighScores(i)\Nom = "XXXXX"      HighScores(i)\Score = (#NBHighScores - i) * 100    Next i    AfficheHiscores()  EndIfEndProcedureProcedure DrawTitle()  If IsImage(ImgTitle)    If StartDrawing(CanvasOutput(#Title))      ClearCanvas()      DrawingMode(#PB_2DDrawing_AlphaBlend)      DrawImage(ImageID(ImgTitle), DesktopScaledX(4), DesktopScaledY(-10))      StopDrawing()    EndIf    ProcedureReturn  EndIfEndProcedureProcedure LoadSounds()  Protected Path$  Path$ = "sounds" + #PS$  If InitSound()    SoundEnabled = #True    UseOGGSoundDecoder()    LoadSound(#SoundFall,            Path$ + "SFX_PieceFall.ogg")    LoadSound(#SoundGameOver,        Path$ + "SFX_GameOver.ogg")    LoadSound(#SoundGameStart,       Path$ + "SFX_GameStart.ogg")    LoadSound(#SoundLineClearSingle, Path$ + "SFX_SpecialLineClearSingle.ogg")    LoadSound(#SoundLineClearDouble, Path$ + "SFX_SpecialLineClearDouble.ogg")    LoadSound(#SoundLineClearTriple, Path$ + "SFX_SpecialLineClearTriple.ogg")    LoadSound(#SoundTouchLR,         Path$ + "SFX_PieceTouchLR.ogg")    LoadSound(#SoundSpecialTetris,   path$ + "SFX_SpecialTetris.ogg")    LoadSound(#SoundLevelUp,         Path$ + "SFX_LevelUp.ogg")    LoadSound(#SoundPieceTouchDown,  Path$ + "SFX_PieceTouchDown.ogg")  Else    SoundEnabled = #False  EndIfEndProcedureProcedure.i ImageTexte(Texte.s, L, W)  Protected Img  Img = CreateImage(#PB_Any, DesktopScaledX(L), DesktopScaledY(W))  If StartDrawing(ImageOutput(Img))    Box(0, 0, OutputWidth(), OutputHeight(), #Black)    DrawingMode(#PB_2DDrawing_Gradient)    FrontColor(#White)    BackColor($37B0FA)    LinearGradient(1, 1, DesktopScaledX(L), 1)    Box(1, 1, OutputWidth() - 2, OutputHeight() - 2)    DrawingMode(#PB_2DDrawing_Transparent)    DrawingFont(FontID(FontGameOver))    DrawText(DesktopScaledX(L / 2) - (TextWidth(Texte) / 2), DesktopScaledY(W / 2) - (TextHeight(Texte) / 2), Texte, #Red)    StopDrawing()    ProcedureReturn Img  Else    ProcedureReturn 0  EndIfEndProcedureProcedure OpenHiScoresFile()  Protected i.b, FicHiScores, L$   ; Lecture du fichier des Hi Scores  i = 0  FicHiScores = ReadFile(#PB_Any, #HighScoresFile)  If FicHiScores    Format = ReadStringFormat(FicHiScores)    While Eof(FicHiScores) = #False      i = i + 1      L$ = ReadString(FicHiScores) ;, Format)      HighScores(i)\Nom         = StringField(L$, 1, ";")      HighScores(i)\Score       = Val(StringField(L$, 2, ";"))      HighScores(i)\Level       = Val(StringField(L$, 3, ";"))      HighScores(i)\NBLines     = Val(StringField(L$, 4, ";"))      HighScores(i)\Date        = StringField(L$, 5, ";")      HighScores(i)\PlayingTime = StringField(L$, 6, ";")      HighScores(i)\NBTetris    = Val(StringField(L$, 7, ";"))    Wend    CloseFile(FicHiScores)  Else    For i = 1 To #NBHighScores      HighScores(i)\Nom = "XXXXX"      HighScores(i)\Score = (#NBHighScores - i) * 100      HighScores(i)\Level   = 0      HighScores(i)\NBLines = 0      HighScores(i)\Date    = ""      HighScores(i)\PlayingTime = "00:00"      HighScores(i)\NBTetris = 0    Next i  EndIfEndProcedureProcedure Initialisations()  Protected i.b, j.b, k.b, F, Img  SetWindowTitle(#MainWindow, #AppName + " © 2023 - v " + #AppVersion)  CouleurPoints(0) = $E7E7E7  CouleurPoints(1) = $35E7F0  CouleurPoints(3) = $E7E738  CouleurPoints(2) = $D96DFF  CouleurPoints(4) = $65FF37  For i = 1 To #NombreDePieces    Img = CreateImage(#PB_Any, DesktopScaledX(#LargeurCase), DesktopScaledY(#LargeurCase))    If StartDrawing(ImageOutput(Img))      Box(DesktopScaledX(0), DesktopScaledY(0), DesktopScaledX(#LargeurCase), DesktopScaledY(#LargeurCase), StructurePiece(i)\Couleur & $222222)      Plot(DesktopScaledX(0), DesktopScaledY(0), StructurePiece(i)\Couleur | $888888)      LineXY(1, 0, DesktopScaledX(#LargeurCase) - 2, 0, StructurePiece(i)\Couleur | $222222)      LineXY(0, 1, 0, DesktopScaledY(#LargeurCase) - 2, StructurePiece(i)\Couleur | $222222)      DrawingMode(#PB_2DDrawing_Gradient)      FrontColor(#Black)      BackColor(StructurePiece(i)\Couleur)      CircularGradient(DesktopScaledX(12), DesktopScaledY(12), 40)      Box(DesktopScaledX(1), DesktopScaledY(1), DesktopScaledX(#LargeurCase - 2), DesktopScaledY(#LargeurCase - 2), StructurePiece(i)\Couleur)      StructurePiece(i)\Shape = Img      StopDrawing()    EndIf  Next i    If StartDrawing(CanvasOutput(#Score))    ClearCanvas()    ImgPointsFond = GrabDrawingImage(#PB_Any, DesktopScaledX(2), DesktopScaledY(30), OutputWidth() - 2, DesktopScaledY(28))    StopDrawing()  EndIf  If StartDrawing(CanvasOutput(#Time))    ClearCanvas()    StopDrawing()  EndIf  CompilerIf #PB_Compiler_OS = #PB_OS_MacOS    FontScorePetit  = LoadFont(#PB_Any, "Tempus Sans ITC", 24, #PB_Font_HighQuality)    FontScoreNormal = LoadFont(#PB_Any, "Tempus Sans ITC", 28, #PB_Font_HighQuality)    FontGameOver    = LoadFont(#PB_Any, "Noteworthy", 40, #PB_Font_HighQuality)    FontConsolas    = LoadFont(#PB_Any, "Consolas", 13, #PB_Font_HighQuality)    FontDungeon     = LoadFont(#PB_Any, "Dungeon", 18, #PB_Font_HighQuality)    FontOptima      = LoadFont(#PB_Any, "Optima", 14, #PB_Font_HighQuality)    CreateMenu(#MainMenu, WindowID(#MainWindow))    MenuTitle(Languages("MenuFichier"))    MenuItem(#MenuNewGame, Languages("MenuNewGame"))    MenuTitle(Languages("MenuAction"))    MenuItem(#MenuClear, Languages("MenuClear"))    MenuItem(#PB_Menu_About, "")    SetGadgetFont(Text_0, FontID(FontDungeon))    SetGadgetFont(Text_1, FontID(FontDungeon))    SetGadgetFont(Text_2, FontID(FontDungeon))    SetGadgetFont(Text_3, FontID(FontDungeon))    SetGadgetFont(Text_4, FontID(FontDungeon))    SetGadgetFont(Text_5, FontID(FontDungeon))    SetGadgetFont(Text_6, FontID(FontDungeon))  CompilerElse    FontScorePetit  = LoadFont(#PB_Any, "Tempus Sans ITC", 16, #PB_Font_HighQuality)    FontScoreNormal = LoadFont(#PB_Any, "Tempus Sans ITC", 22, #PB_Font_HighQuality)    FontGameOver    = LoadFont(#PB_Any, "Showcard Gothic", 20, #PB_Font_HighQuality)    FontConsolas    = LoadFont(#PB_Any, "Consolas", 10, #PB_Font_HighQuality)    FontOptima      = LoadFont(#PB_Any, "Tahoma", 9, #PB_Font_HighQuality)  CompilerEndIf  SetGadgetFont(#CheckBoxSound, FontID(FontOptima))  SetGadgetFont(#CheckBoxShadow, FontID(FontOptima))  OpenHiScoresFile()   DessinNext(0)  ; Préparatif Texte scrolling vertical  ImageText = CreateImage(#PB_Any, DesktopScaledX(GadgetWidth(#Grille)), DesktopScaledY(GadgetHeight(#Grille)))  CompilerIf #PB_Compiler_OS = #PB_OS_MacOS    F = LoadFont(#PB_Any, "Noteworthy", 20, #PB_Font_HighQuality)  CompilerElse    F = LoadFont(#PB_Any, "Papyrus", 16, #PB_Font_HighQuality)  CompilerEndIf  Y = 0  If StartDrawing(ImageOutput(ImageText))    Box(0, 0, OutputWidth(), OutputHeight(), #CouleurFond)    DrawingMode(#PB_2DDrawing_Transparent)    DrawingFont(FontID(F))    i = 1    ForEach ScrollText()      Y + TextHeight(ScrollText())      DrawText(DesktopScaledX(GadgetWidth(#Grille) / 2 + 1) - (TextWidth(ScrollText()) / 2), DesktopScaledY(Y + 1),  ScrollText(), #Black)      DrawText(DesktopScaledX(GadgetWidth(#Grille) / 2) - (TextWidth(ScrollText()) / 2), DesktopScaledY(Y),  ScrollText(), $BFBF3F)      i + 1    Next    TailleScroll = Y    StopDrawing()  EndIf  YImage = GadgetHeight(#Grille)  UsePNGImageDecoder()  ImgTitle = CatchImage(#PB_Any, ?PureTris_png_start, ?PureTris_png_end - ?PureTris_png_start)  ResizeImage(ImgTitle, ImageWidth(ImgTitle) * DesktopResolutionX(), ImageHeight(ImgTitle) * DesktopResolutionY())  Bck = CopyImage(ImgTitle, #PB_Any)  For i = 1 To NbAnim    ResizeImage(Bck, ImageWidth(Bck) - (i * 1), ImageHeight(Bck) - (i * 1))    LogoAnime(i) = Bck    Bck = CopyImage(ImgTitle, #PB_Any)  Next i    DrawTitle()  LoadSounds()  FreeFont(F)     Mybutton(#ButtonQuit, 570, 530, 80, 25, Languages("ButtonQuit"), $BCCCFF)  Mybutton(#ButtonAide, 480, 530, 80, 25, Languages("ButtonAide"), $D7ED9F)  MyButton(#ButtonNewGame, 50, 450, 110, 25, Languages("ButtonNewGame"), $D7ED9F) ; $C9FFC4)  MyButton(#ButtonClearHS, 50, 490, 110, 25, Languages("ButtonClearHS"), $C7F9FE) ;$B3F5F9)        ImgGameOver   = ImageTexte(Languages("TexteGameOver"), 230, 70)  ImgGamePaused = ImageTexte(Languages("TexteGamePaused"), 230, 70)    RemplirPanier()EndProcedureProcedure MenuEvents()  Select EventMenu()  CompilerIf #PB_Compiler_OS = #PB_OS_MacOS       Case #PB_Menu_About      PostEvent(#PB_Event_Menu, #MainWindow, #MainMenuAbout)            Case #PB_Menu_Preferences                   Case #PB_Menu_Quit      PostEvent(#PB_Event_CloseWindow, #MainWindow, #Null)        CompilerEndIf    Case #KeyN      If GameInProgress = #False        NewGame()      EndIf    Case #MainMenuAbout      MessageRequester(#AppName, "Written by Mindphazer" + #LF$ + "v " + #AppVersion, #PB_MessageRequester_Info)     Case #MainMenuExit      PostEvent(#PB_Event_CloseWindow, #MainWindow, #Null)       Case #MenuClear      ClearHiScores()    Case #MenuNewGame      NewGame()  EndSelect  EndProcedureProcedure Aide()  If GameInProgress = #True     PauseGame()  EndIf  MessageRequester(Languages("TitleAide"), Languages("Aide"), #PB_MessageRequester_Ok | #PB_MessageRequester_Info)  If GameInProgress = #True    PauseGame()  EndIfEndProcedureProcedure OpenMainWindow(x = 0, y = 0, Width = 670, Height = 570)  LoadFont(#Font_MainWindow_0,"Dungeon", 13, #PB_Font_Bold)  OpenWindow(#MainWindow, x, y, Width, Height, "PureTris !", #PB_Window_SystemMenu | #PB_Window_MinimizeGadget | #PB_Window_ScreenCentered)  CanvasGadget(#Grille, 210, 10, 250, 550, #PB_Canvas_Keyboard)  CanvasGadget(#Title, 20, 30, 170, 80)  CanvasGadget(#Next, 480, 30, 170, 50)  CanvasGadget(#Time, 20, 240, 170, 30)  CanvasGadget(#Score, 480, 130, 170, 60)  CanvasGadget(#Lignes, 480, 220, 170, 30)  CanvasGadget(#HighScores, 480, 340, 170, 170)  CanvasGadget(#Niveau, 480, 280, 170, 30)  CanvasGadget(#Hold, 20, 140, 170, 70)    Text_0 = TextGadget(#PB_Any, 480, 110, 170, 20, Languages("TexteScore"), #PB_Text_Center)  SetGadgetFont(Text_0, FontID(#Font_MainWindow_0))  Text_1 = TextGadget(#PB_Any, 480, 200, 170, 20, Languages("TexteLignes"), #PB_Text_Center)  SetGadgetFont(Text_1, FontID(#Font_MainWindow_0))  Text_2 = TextGadget(#PB_Any, 480, 320, 170, 20, Languages("TexteHighScores"), #PB_Text_Center)  SetGadgetFont(Text_2, FontID(#Font_MainWindow_0))  Text_3 = TextGadget(#PB_Any, 480, 260, 170, 20, Languages("TexteNiveau"), #PB_Text_Center)  SetGadgetFont(Text_3, FontID(#Font_MainWindow_0))  Text_4 = TextGadget(#PB_Any, 20, 120, 170, 20, Languages("TexteHold"), #PB_Text_Center)  SetGadgetFont(Text_4, FontID(#Font_MainWindow_0))  Text_5 = TextGadget(#PB_Any, 480, 10, 170, 20, Languages("TexteNext"), #PB_Text_Center)  SetGadgetFont(Text_5, FontID(#Font_MainWindow_0))  Text_6 = TextGadget(#PB_Any, 20, 220, 170, 20, Languages("TexteTemps"), #PB_Text_Center)  SetGadgetFont(Text_6, FontID(#Font_MainWindow_0))  Frame_0 = FrameGadget(#PB_Any, 20, 430, 170, 130, "")  CheckBoxGadget(#CheckboxSound, 40, 530, 70, 20, Languages("CheckboxSound"))  GadgetToolTip(#CheckboxSound, Languages("ToolTipSound"))  CheckBoxGadget(#CheckBoxShadow, 110, 530, 70, 20, Languages("CheckBoxShadow"))  GadgetToolTip(#CheckBoxShadow, Languages("ToolTipShadows"))EndProcedure;Global Lang.s = GetLanguage();Debug LangSelect GetLanguage()  Case "FRA"    Restore TextesFRA  Case "ENG"    Restore TextesENG    Case "GER"      Restore TextesGER    Case "RUS"      Restore TextesRUS  Default    Restore TextesFRAEndSelectRepeat  Read.s Intitule.s  If Intitule <> "_End_"    Read.s Libelle.s    languages(Intitule) = Libelle    EndIfUntil Intitule = "_End_"OpenMainWindow()Initialisations()AddWindowTimer(#MainWindow, #TimerScroll, 10)AddWindowTimer(#MainWindow, #Timer, Tempo)AddWindowTimer(#MainWindow, #TimerGradient, 10)AddWindowTimer(#MainWindow, #TimerPlayingTime, 1000)AddKeyboardShortcut(#MainWindow, #PB_Shortcut_N, #KeyN)ClearGrille()BindEvent(#PB_Event_Menu, @MenuEvents(), #MainWindow)k = 0Increment.b = 1Repeat  Event = WaitWindowEvent()  EventType = EventType()  If GamePaused    If StartDrawing(CanvasOutput(#Grille))      DrawingMode(#PB_2DDrawing_Default)      DrawImage(ImageID(ImgBlurred), 0, 0)       DrawingMode(#PB_2DDrawing_AlphaBlend)      DrawAlphaImage(ImageID(ImgGamePaused), DesktopScaledX(10), DesktopScaledY(245), 128 + Sin(ElapsedMilliseconds() * 0.005) * 127 )      StopDrawing()    EndIf  EndIf    Select Event    Case #EventFall      If MoveDown() = #True        HauteurChute = HauteurChute + 1        t.q = ElapsedMilliseconds()        While WindowEvent()          CompilerIf #PB_Compiler_OS = #PB_OS_Windows            Delay(3)          CompilerElse             Repeat            Until ElapsedMilliseconds() - t > 2          CompilerEndIf         Wend        PostEvent(#EventFall)      EndIf           Case #PB_Event_Timer      Select EventTimer()        Case #Timer          If MoveDown() = #False            RemoveWindowTimer(#MainWindow,#Timer)            AddWindowTimer(#MainWindow, #Timer, Tempo)          EndIf        Case #TimerScroll           If NeverPlayed = #True            ScrollUp()          EndIf        Case #TimerPlayingTime          If GameInProgress And GamePaused = #False            PlayingSeconds + 1            If PlayingSeconds % 60 = 0              PlayingSeconds = 0              PlayingMinutes + 1            EndIf            AfficherTemps()          EndIf        Case #TimerGradient          ; Animation du titre          If StartDrawing(CanvasOutput(#Title))            k = k + Increment            If k = NbAnim : Increment = -1 : EndIf            If k = 1 : Increment = 1  : EndIf            ClearCanvas()            DrawingMode(#PB_2DDrawing_AlphaBlend)            DrawImage(ImageID(LogoAnime(k)), DesktopScaledX(4 + (k / 2)), DesktopScaledY(-10 + (k / 2)))            StopDrawing()          EndIf           ; - Fondu noir du nombre de points récoltés lorqu'une pièce se pose en bas (l'intensité part de 255 à 0)          If IntensitePoints > 0            IntensitePoints - 1            If StartDrawing(CanvasOutput(#Score))              DrawImage(ImageID(ImgPointsFond), DesktopScaledX(2), DesktopScaledY(30))              DrawingMode(#PB_2DDrawing_AlphaBlend)              DrawAlphaImage(ImageID(ImgPoints), DesktopScaledX(2), DesktopScaledY(30), IntensitePoints)              StopDrawing()            EndIf          EndIf      EndSelect    Case #PB_Event_Gadget      Select EventGadget()        Case #Grille          If EventType() = #PB_EventType_KeyDown And GameInProgress = #True            Key = GetGadgetAttribute(#Grille, #PB_Canvas_Key)             Select Key            Case #PB_Shortcut_Down               MoveDown()            Case #PB_Shortcut_Space              If GamePaused = #False                If SoundIsOn And IsSound(#SoundFall) And SoundIsOn() : PlaySound(#SoundFall) : EndIf                PostEvent(#EventFall)              EndIf            Case #PB_Shortcut_Up, #PB_Shortcut_A              If Key = #PB_Shortcut_Up                CR = CanRotate(Piece, XPiece, YPiece, 1)   ; Rotation anti-horaire              ElseIf Key = #PB_Shortcut_A                CR = CanRotate(Piece, XPiece, YPiece, -1)  ; Rotation horaire              EndIf                    If CR And GamePaused = #False                RotatePiece(Piece, XPiece, YPiece)                If CR < 0 : XPiece = XPiece + (0 - CR) : EndIf                If CR > #LargeurGrille - 1 : XPiece = XPiece - (CR - (#LargeurGrille - 1)) : EndIf                Shadow(Piece, XPiece, YPiece)                DessinPiece(Piece, XPiece, YPiece)              EndIf            Case #PB_Shortcut_Right              MoveRight()            Case #PB_Shortcut_Left              MoveLeft()            Case #PB_Shortcut_Escape              SetWindowState(#MainWindow, #PB_Window_Minimize)              PauseGame(#True)            Case #PB_Shortcut_P              PauseGame()            Case #PB_Shortcut_Q              GameInProgress = #False              GamePaused = #False              DessinNext(0)              ClearGrille()              Case #PB_Shortcut_C              If Hold = 0     ; Si aucune pièce n'est encore retenue, on place la pièce actuelle dans la zone Hold, puis on affiche la pièce suivante dans la zone de jeu                              ; et on génère une nouvelle pièce suivante                Hold = Piece                    EffacePiece(Piece, XPiece, YPiece)                Piece = NextPiece                XPiece = XOrigine                YPiece = YOrigine                NextPiece = NextPiece()                For i = 0 To StructurePiece(NextPiece)\Taille                  For j = 0 To StructurePiece(NextPiece)\Taille                    StructurePiece(NextPiece)\Matrice(j, i) = StructurePiece(NextPiece)\MatriceOrig(j, i)                  Next j                Next i                DessinNext(NextPiece)              Else                EffacePiece(Piece, XPiece, YPiece)                Temp = Hold                Hold = Piece                Piece = Temp                For i = 0 To StructurePiece(Piece)\Taille                  For j = 0 To StructurePiece(Piece)\Taille                    StructurePiece(Piece)\Matrice(j, i) = StructurePiece(Piece)\MatriceOrig(j, i)                  Next j                Next i              EndIf              DessinHold()                            DessinPiece(Piece, XPiece, YPiece)              Shadow(Piece, XPiece, YPiece)             EndSelect          EndIf       Case #ButtonQuit        Select EventType          Case #PB_EventType_LeftClick            PostEvent(#PB_Event_CloseWindow, #MainWindow, #Null)           Case #PB_EventType_MouseEnter            SetGadgetAttribute(#ButtonQuit, #PB_Canvas_Cursor, #PB_Cursor_Hand)            RedrawButton(#ButtonQuit, 1)          Case #PB_EventType_MouseLeave            SetGadgetAttribute(#ButtonQuit, #PB_Canvas_Cursor, #PB_Cursor_Default)            RedrawButton(#ButtonQuit, 0)        EndSelect      Case #ButtonAide        Select EventType          Case #PB_EventType_LeftClick            Aide()          Case #PB_EventType_MouseEnter            SetGadgetAttribute(#ButtonAide, #PB_Canvas_Cursor, #PB_Cursor_Hand)            RedrawButton(#ButtonAide, 1)          Case #PB_EventType_MouseLeave            SetGadgetAttribute(#ButtonAide, #PB_Canvas_Cursor, #PB_Cursor_Default)            RedrawButton(#ButtonAide, 0)        EndSelect      Case #ButtonNewGame        Select EventType          Case #PB_EventType_LeftClick            NewGame()          Case #PB_EventType_MouseEnter            SetGadgetAttribute(#ButtonNewGame, #PB_Canvas_Cursor, #PB_Cursor_Hand)            RedrawButton(#ButtonNewGame, 1)          Case #PB_EventType_MouseLeave            SetGadgetAttribute(#ButtonNewGame, #PB_Canvas_Cursor, #PB_Cursor_Default)            RedrawButton(#ButtonNewGame, 0)        EndSelect      Case #ButtonClearHS        Select EventType          Case #PB_EventType_LeftClick            ClearHiScores()          Case #PB_EventType_MouseEnter            SetGadgetAttribute(#ButtonClearHS, #PB_Canvas_Cursor, #PB_Cursor_Hand)            RedrawButton(#ButtonClearHS, 1)          Case #PB_EventType_MouseLeave            SetGadgetAttribute(#ButtonClearHS, #PB_Canvas_Cursor, #PB_Cursor_Default)            RedrawButton(#ButtonClearHS, 0)        EndSelect      Case #HighScores        Select EventType          Case #PB_EventType_LeftClick            OpenWindowHiScores()          Case #PB_EventType_MouseEnter            SetGadgetAttribute(#HighScores, #PB_Canvas_Cursor, #PB_Cursor_Hand)          Case #PB_EventType_MouseLeave            SetGadgetAttribute(#HighScores, #PB_Canvas_Cursor, #PB_Cursor_Default)        EndSelect      Case #CheckBoxShadow          If GameInProgress            If GetGadgetState(#CheckBoxShadow) = #PB_Checkbox_Checked              Shadow(Piece, XPiece, YPiece)            Else              If StartDrawing(CanvasOutput(#Grille)); And Shadow = #True                For i = 0 To StructurePiece(Piece)\Taille                  For j = 0 To StructurePiece(Piece)\Taille                    If StructurePiece(Piece)\Matrice(j, i) = 1 And Grille(XShadow + j, YShadow + i) <> 1                      EffaceCase(XShadow + j, YShadow + i)                    EndIf                  Next j                Next i                 StopDrawing()              EndIf             EndIf            SetActiveGadget(#Grille)          EndIf      EndSelect  EndSelect Until Event = #PB_Event_CloseWindow; Sauvegarde des HiScoresFicHiScores = CreateFile(#PB_Any, #HighScoresFile)If FicHiScores  WriteStringFormat(FicHiScores, #PB_Unicode)  For i = 1 To #NBHighScores    WriteStringN(FicHiScores, HighScores(i)\Nom + ";" +    Str(HighScores(i)\Score) + ";" +    Str(HighScores(i)\Level) + ";" +    Str(HighScores(i)\NBLines) + ";" +    HighScores(i)\Date + ";" +    HighScores(i)\PlayingTime + ";" +     Str(HighScores(i)\NBTetris))  Next i  CloseFile(FicHiScores)EndIfEndDataSection  Pieces:  ; I  Data.b 3  Data.i $3B00FF  ; rouge  Data.b 0,0,0,0  Data.b 1,1,1,1  Data.b 0,0,0,0  Data.b 0,0,0,0  ; O  Data.b 1  Data.i $EA7361  ; Bleu  Data.b 1,1  Data.b 1,1  ; T  Data.b 2  Data.i $4EAFFE  ; Orange  Data.b 0,1,0  Data.b 1,1,1  Data.b 0,0,0    ; L  Data.b 2  Data.i #Magenta  Data.b 0,0,1  Data.b 1,1,1  Data.b 0,0,0    ; J  Data.b 2  Data.i #White  Data.b 1,0,0  Data.b 1,1,1  Data.b 0,0,0    ; Z  Data.b 2  Data.i  #Cyan  Data.b 1,1,0  Data.b 0,1,1  Data.b 0,0,0    ; S  Data.b 2  Data.i #Green  Data.b 0,1,1  Data.b 1,1,0  Data.b 0,0,0    Credits:  Data.s "Puretris !"   Data.s ""  Data.s "Code by Mindphazer"  Data.s "(c) 2023"  Data.s ""  Data.s "Made with Purebasic"  Data.s " "  Data.s "Thanks to"  Data.s "Fred (PB is great !)"  Data.s "Infratec"  Data.s "fjmangas"  Data.s "All members of"  Data.s "Purebasic forums"  Data.s " "  Data.s "Press N to start"  Data.s " "  Data.s "_END_"  Puretris_png_start:    ; size : 8926 bytes    Data.q $0A1A0A0D474E5089,$524448490D000000,$64000000AA000000,$AB94160000000608,$474B620600000046,$A0FF00FF00FF0044,$700900