a.s "CheckboxSound",       "Sons"    Data.s "ToolTipSound",        "Activer les sons"    Data.s "CheckBoxShadow",      "Ombres"    Data.s "ToolTipShadows",      "Activer la silhouette indiquant l'endoit où la pièce se posera"    Data.s "NewHiScore",          "Vous avez le meilleur score !"    Data.s "ScoreNumber",         "Vous avez le score n° "    Data.s "EnterName",           "Entrez votre nom"    Data.s "RequesterAreYouSure", "Etes-vous sûr de vouloir effacer le tableau des meilleurs scores ?"    Data.s "RequesterClearHS",    "Effacer les Hi-Scores"    Data.s "MenuFichier",         "&Fichier"    Data.s "MenuAction",          "&Action"    Data.s "MenuNewGame",         "Nouveau jeu" + Chr(9) + "N"    Data.s "MenuClear",           "Effacer Hiscores"    Data.s "TitleAide",           "Aide"    Data.s "TexteGameOver",       "Jeu terminé !"    Data.s "TexteGamePaused",     "Jeu en pause"    Data.s "TexteTemps",          "Temps de jeu"    Data.s "TexteHold",           "Retenu"    Data.s "Aide",                "Flèches droite et gauche = Déplacement de la pièce" + #CRLF$ + "Flèche haut = Rotation de la pièce (sens antihoraire)" + #CRLF$ + "Touche A = Rotation de la pièce (sens horaire)" + #CRLF$ + "Flèche bas = Descend la pièce" + #CRLF$ + "Espace = Lâcher la pièce" + #CRLF$ + "Touche C = Retient la pièce" + #CRLF$ + "Touche P = Met la partie en pause" + #CRLF$ + "Touche Q = Quitte la partie"    Data.s "_End_"    ;-TextesENG    TextesENG:    Data.s "ButtonQuit",          "Quit"    Data.s "ButtonAide",          "Help"    Data.s "ButtonNewGame",       "New Game"    Data.s "ButtonClearHS",       "Clear Hi-scores"    Data.s "TexteScore",          "Score"    Data.s "TexteLignes",         "Lines"    Data.s "TexteHighScores",     "Best scores"    Data.s "TexteNiveau",         "Level"    Data.s "TexteNext",           "Next piece"    Data.s "CheckboxSound",       "Sounds"    Data.s "ToolTipSound",        "Actives the sounds"    Data.s "CheckBoxShadow",      "Shadows"    Data.s "ToolTipShadows",      "Actives the shape showing where the piece will be dropped"    Data.s "NewHiScore",          "You have the high score !"    Data.s "ScoreNumber",         "You have score n° "    Data.s "EnterName",           "Enter your name"    Data.s "RequesterAreYouSure", "Are you sure you want to clear high scores ?"    Data.s "RequesterClearHS",    "Clear High-Scores"    Data.s "MenuFichier",         "&File"    Data.s "MenuAction",          "&Action"    Data.s "MenuNewGame",         "New game" + Chr(9) + "N"    Data.s "MenuClear",           "Clear Hiscores"    Data.s "TitleAide",           "Help"    Data.s "TexteGameOver",       "Game Over !"    Data.s "TexteGamePaused",     "Game Paused"    Data.s "TexteTemps",          "Playing Time"    Data.s "TexteHold",           "Hold"    Data.s "Aide",                "Left and right arrows = move the piece" + #CRLF$ + "Up arrow = Rotate the piece (counterclockwise)" + #CRLF$ + "A key = Rotate the piece (clockwise)" + #CRLF$ + "Down arrow = move the piece down" + #CRLF$ + "Space = Drop the piece" + #CRLF$ + "C key = Hold piece"  + #CRLF$ + "P Key = Pause the game" + #CRLF$ + "Q Key = Exit the game"    Data.s "_End_"    ;-TextesGER  TextesGER:    Data.s "ButtonQuit",          "Ende"    Data.s "ButtonAide",          "Hilfe"    Data.s "ButtonNewGame",       "Neues Spiel"    Data.s "ButtonClearHS",       "Rangliste löschen"    Data.s "TexteScore",          "Spielstand"    Data.s "TexteLignes",         "Zeilen"    Data.s "TexteHighScores",     "Rangliste"    Data.s "TexteNiveau",         "Niveau"    Data.s "TexteNext",           "Nächstes Teil"    Data.s "CheckboxSound",       "Töne"    Data.s "ToolTipSound",        "Töne Einschalten"    Data.s "CheckBoxShadow",      "Schatten"    Data.s "ToolTipShadows",      "Aktiviert die Form, die zeigt, wo das Stück abgelegt wird"    Data.s "NewHiScore",          "Du liegst in Führung !"    Data.s "ScoreNumber",         "Du liegst auf Rang Nr. "    Data.s "EnterName",           "Gib Deinen Namen ein"    Data.s "RequesterAreYouSure", "Willst Du wirklich die Rangliste löschen ?"    Data.s "RequesterClearHS",    "Lösche Rangliste"    Data.s "MenuFichier",         "&Datei"    Data.s "MenuAction",          "&Aktionen"    Data.s "MenuNewGame",         "Neues Spiel" + #TAB$ + "N"    Data.s "MenuClear",           "Lösche Rangliste"    Data.s "TitleAide",           "Hilfe"    Data.s "TexteGameOver",       "Spiel beendet !"    Data.s "TexteGamePaused",     "Spiel pausiert"    Data.s "TexteTemps",          "Spielzeit"    Data.s "TexteHold",           "Hold"    Data.s "Aide",                "Linker und rechter Pfeil = bewegt das Teil" + #CRLF$ + "Pfeil hoch = dreht das Teil (gegen den Uhrzeigersinn)" + #CRLF$ + "A Taste = dreht das Teil (im Uhrzeigersinn)" + #CRLF$ + "Pfeil runter = bewegt das Teil abwärts" + #CRLF$ + "Leertaste = lässt das Teil fallen" + #CRLF$ + "P Taste = pausiert das Spiel" + #CRLF$ + "Q Taste = beendet das Spiel" + #CRLF$ + "C Taste = Hold"    Data.s "_End_"      TextesRUS:    Data.s "ButtonQuit",          "Выход"    Data.s "ButtonAide",          "Справка"    Data.s "ButtonNewGame",       "Новая игра"    Data.s "ButtonClearHS",       "Очистить рекорды"    Data.s "TexteScore",          "Счет"    Data.s "TexteLignes",         "Линии"    Data.s "TexteHighScores",     "Рекорды"    Data.s "TexteNiveau",         "Уровень"    Data.s "TexteNext",           "Следующая фигура"    Data.s "CheckboxSound",       "Звуки"    Data.s "CheckBoxShadow",       "Тень"    Data.s "NewHiScore",          "У вас высокий балл !"    Data.s "ScoreNumber",         "У вас есть счет n° "    Data.s "EnterName",           "Введите ваше имя"    Data.s "RequesterAreYouSure", "Вы уверены, что хотите очистить рекорды?"    Data.s "RequesterClearHS",    "Очистить рекорды"    Data.s "MenuFichier",         "&Файл"    Data.s "MenuAction",          "&Действие"    Data.s "MenuNewGame",         "Новая игра" + Chr(9) + "N"    Data.s "MenuClear",           "Очистить рекорды"    Data.s "TitleAide",           "Справка"    Data.s "TexteGameOver",       "Игра окончена!"    Data.s "TexteGamePaused",     "Пауза"    Data.s "TexteTemps",          "Время игры"    Data.s "TexteHold",           "Держать"    Data.s "Aide",                "Стрелки влево и вправо = переместить фигуру" + #CRLF$ + "Стрелка вверх = повернуть фигуру (против часовой стрелки)" + #CRLF$ + "Клавиша A = повернуть (по часовой стрелке)" + #CRLF$ + "Стрелка вниз = переместить фигуру вниз" + #CRLF$ + "Пробел = бросить фигуру" + #CRLF$ + "Ударать по C = Hold"  + #CRLF$ + "Клавиша P = пауза в игре" + #CRLF$ + "Клавиша Q = выйти из игры"    Data.s "_End_"    EndDataSection; PLIST <key>CFBundleInfoDictionaryVersion</key>; PLIST <string>6.0</string>; PLIST <key>CFBundlePackageType</key>; PLIST <string>APPL</string>; PLIST <key>CFBundleVersion</key>; PLIST <string>0.1</string>; PLIST <key>CFBundleSignature</key>; PLIST <string>PBAPP</string>; PLIST <key>CFBundleShortVersionString</key>; PLIST <string>1.0.6</string>; PLIST <key>NSHumanReadableCopyright</key>; PLIST <string>Copyright (c) 2023 Mindphazer. All rights reserved.</string>*; IDE Options = PureBasic 6.03 beta 4 LTS (Windows - x64); CursorPosition = 1860; FirstLine = 1843; Folding = ----------; Optimizer; EnableThread; EnableXP; EnableUser; DPIAware; UseIcon = PureTrisIco.ico; Executable = PureTris.exe