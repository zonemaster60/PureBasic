    #ThreadCSwitchMon                ;private
EndEnumeration

Procedure GetThreadIDFromHandle(Handle.i)
    
    Protected Info.THREAD_BASIC_INFORMATION
    
    If NtQueryInformationThread_(Handle, #ThreadBasicInformation, @Info, SizeOf(Info),0) = 0
        ProcedureReturn Info\ClientId\UniqueThread
    EndIf
    
EndProcedure

; converts all white pixels to be transparent alpha and full alpha otherwise
Procedure filterWhiteToAlpha(x, y, s, t)
    r = Red(s)
    g = Green(s)
    b = Blue(s)
    If r = 255 And g = 255 And b = 255
        alpha = 0
    Else
        alpha = 255
    EndIf
    ProcedureReturn RGBA(r, g, b, alpha)
EndProcedure
Macro addAlphaToXpTheme(image)
    ; hack to add an alpha channel on XP theme
    If ThemesEnabled And OSVersion <= #PB_OS_Windows_XP
        timage = CreateImage(#PB_Any, w, h, 32)
        StartDrawing(ImageOutput(timage))
        DrawingMode(#PB_2DDrawing_CustomFilter)
        CustomFilterCallback(@filterWhiteToAlpha())
        DrawImage(ImageID(image), 0, 0)
        StopDrawing()
        FreeImage(image)
        image = timage
    EndIf
EndMacro

;--===================
;- init/create default skins
;--===================
Procedure initDefaultSkin(name.s)
    Static loadedBinaries
    
    If loadedBinaries = #False
        
        DataSection
            
            ; explorer bar office 2007 blue skin images
            xbar_office2007_blue_border:
            IncludeBinary "ExplorerBar_Office2007_blue_border.png"
            xbar_office2007_blue_hborder:
            IncludeBinary "ExplorerBar_Office2007_blue_hborder.png"
            xbar_office2007_blue_glyph_down:
            IncludeBinary "ExplorerBar_Office2007_blue_glyph_down.png"
            xbar_office2007_blue_glyph_up:
            IncludeBinary "ExplorerBar_Office2007_blue_glyph_up.png"
            ; explorer bar office 2007 silver skin images
            xbar_office2007_silver_border:
            IncludeBinary "ExplorerBar_Office2007_silver_border.png"
            xbar_office2007_silver_hborder:
            IncludeBinary "ExplorerBar_Office2007_silver_hborder.png"
            xbar_office2007_silver_glyph_down:
            IncludeBinary "ExplorerBar_Office2007_silver_glyph_down.png"
            xbar_office2007_silver_glyph_up:
            IncludeBinary "ExplorerBar_Office2007_silver_glyph_up.png"
            ; explorer bar office 2007 black skin images
            xbar_office2007_black_border:
            IncludeBinary "ExplorerBar_Office2007_black_border.png"
            xbar_office2007_black_hborder:
            IncludeBinary "ExplorerBar_Office2007_black_hborder.png"
            xbar_office2007_black_glyph_down:
            IncludeBinary "ExplorerBar_Office2007_black_glyph_down.png"
            xbar_office2007_black_glyph_up:
            IncludeBinary "ExplorerBar_Office2007_black_glyph_up.png"
            
        EndDataSection
        
        ; explorer bar office 2007 blue skin images
        Global xbar_office2007_blue_border = CatchImage(#PB_Any, ?xbar_office2007_blue_border)
        Global xbar_office2007_blue_hborder = CatchImage(#PB_Any, ?xbar_office2007_blue_hborder)
        Global xbar_office2007_blue_glyph_down = CatchImage(#PB_Any, ?xbar_office2007_blue_glyph_down)
        Global xbar_office2007_blue_glyph_up = CatchImage(#PB_Any, ?xbar_office2007_blue_glyph_up)
        ; explorer bar office 2007 silver skin images
        Global xbar_office2007_silver_border = CatchImage(#PB_Any, ?xbar_office2007_silver_border)
        Global xbar_office2007_silver_hborder = CatchImage(#PB_Any, ?xbar_office2007_silver_hborder)
        Global xbar_office2007_silver_glyph_down = CatchImage(#PB_Any, ?xbar_office2007_silver_glyph_down)
        Global xbar_office2007_silver_glyph_up = CatchImage(#PB_Any, ?xbar_office2007_silver_glyph_up)
        ; explorer bar office 2007 black skin images
        Global xbar_office2007_black_border = CatchImage(#PB_Any, ?xbar_office2007_black_border)
        Global xbar_office2007_black_hborder = CatchImage(#PB_Any, ?xbar_office2007_black_hborder)
        Global xbar_office2007_black_glyph_down = CatchImage(#PB_Any, ?xbar_office2007_black_glyph_down)
        Global xbar_office2007_black_glyph_up = CatchImage(#PB_Any, ?xbar_office2007_black_glyph_up)
        
        loadedBinaries = #True
        
    EndIf
    
    name = LCase(name)
    
    If GetSkinHandle(name) = 0
        
        SkinAutoUpdateRepress = #True
        
        Select name
                
                ;- **** image button
            Case "imagebuttonskin"  
                
                ; create image button skin
                Global imageButtonSkin = CreateSkin("imageButtonSkin")
                ; normal
                SetSkinProperty(imageButtonSkin, "imagebuttonex", "normal", "background", "-1;")
                SetSkinProperty(imageButtonSkin, "imagebuttonex", "normal", "image position", "x: 50%; y: 50%;")
                ; hot
                SetSkinProperty(imageButtonSkin, "imagebuttonex", "hot", "background", "-1;")
                SetSkinProperty(imageButtonSkin, "imagebuttonex", "hot", "image position", "x: 50%; y: 50%;")
                ; pressed
                SetSkinProperty(imageButtonSkin, "imagebuttonex", "pressed", "background", "-1;")
                SetSkinProperty(imageButtonSkin, "imagebuttonex", "pressed", "image position", "x: 50%; y: 50%;")
                ; disabled
                SetSkinProperty(imageButtonSkin, "imagebuttonex", "disabled", "background", "-1;")
                SetSkinProperty(imageButtonSkin, "imagebuttonex", "disabled", "image position", "x: 50%; y: 50%;")
                
                ;- **** button
            Case "sysbuttonskin"
                
                ; create system button skin
                Global sysButtonSkin = CreateSkin("sysButtonSkin")
                ; normal
                SetSkinProperty(sysButtonSkin, "buttonex", "normal", "background", "8;")
                SetSkinProperty(sysButtonSkin, "buttonex", "normal", "image position", "x: 50%; y: 50%;")
                SetSkinProperty(sysButtonSkin, "buttonex", "normal", "image padding", "top: 2; left: 6; bottom: 2; right: 4;")
                SetSkinProperty(sysButtonSkin, "buttonex", "normal", "text position", "x: 50%; y: 50%;")
                SetSkinProperty(sysButtonSkin, "buttonex", "normal", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
                ; hot
                SetSkinProperty(sysButtonSkin, "buttonex", "hot", "background", "9;")
                SetSkinProperty(sysButtonSkin, "buttonex", "hot", "image position", "x: 50%; y: 50%;")
                SetSkinProperty(sysButtonSkin, "buttonex", "hot", "image padding", "top: 2; left: 6; bottom: 2; right: 4;")
                SetSkinProperty(sysButtonSkin, "buttonex", "hot", "text position", "x: 50%; y: 50%;")
