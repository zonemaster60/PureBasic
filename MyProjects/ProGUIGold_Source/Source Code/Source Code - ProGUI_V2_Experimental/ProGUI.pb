;--=========
;- initProGUI
;--=========
ProcedureDLL ProGUI_Init()
    
    ; Setup the error handler
    ;OnErrorCall(@ErrorHandler())
    
    CompilerIf #DEBUGENABLED = -1
        Global NewMap previousMutexLine.s()
    CompilerEndIf
    Global NewList lsicon.listiconsubicons()
    Global NewList rebarBand.rebarbands()
    Global NewList rebarGadget.rebarGadgets()
    Global NewList toolbarEx.toolbarExs()
    Global NewList toolbarExButton.toolbarExButtons()
    Global NewList toolbartip.toolbarTooltips()
    Global NewList itemex.itemexs()
    Global NewList menuex.menuexs()
    Global NewList popupUserData.popupUserDatas()
    Global NewList menuScrollHotKey.menuScrollHotKeys()
    Global NewList menuCallback.menuCallbacks()
    Global NewList cmdbar.CommandBars()
    Global NewList drpShadow.dropShadows() ; used for keeping track of a drop shadow's hdc and bitmap data
    Global NewList shadow.shadows()        ; used for keeping tack of active menu drop shadows
    Global NewList titleShadow.shadows()   ; used for keeping track of menu title drop shadows
    Global NewList skin.skins()
    Global NewList skinHwndRedraw() ; keeps track of top level child windows that have had the #WM_UPDATESKIN message sent and need redrawing
    Global NewMap colour()          ; map of colour names to rgb value
    Global NewList border.borders()
    Global NewMap borderHandleCount() ; used to check how many copies of the handle there are, if handlecount = 1 then can free resources 
    Global NewMap img.imgs()          ; used for image memory management, stores hash of HBITMAP or HICON
    Global NewMap imgp()              ; used for image memory management, stores hash of file path to image
    Global NewMap hotkeyTable.hotkeytables()  ; used for tracking keyboard shortcuts/accelerators associated with each window
    Global NewMap IDHwndLookup.IDHwndLookup(10000) ; used for quickly returning Hwnd associated with and ID
    Global Dim IDHwndLookupArray(1) ; used for quickly returning Hwnd associated with and ID
    
    ; mutexes
    Global trialMutex = CreateMutex() ; trial thread mutex
    Global menuMutex = CreateMutex()            ; used to make sure no thread collisions when handling menuex lists
    Global toolbarMutex = CreateMutex()         ; used to make sure no thread collisions when handling toolbarex lists
    Global panelExMutex = CreateMutex()         ; used to make sure no thread collisions when handling panelex/panelexpage lists
    Global updateMutex = CreateMutex()
    Global hotkeyMutex = CreateMutex()          ; used to make sure no thread collision when handling window accelerator
    Global animationMutex = CreateMutex()       ; used to make sure no thread collisions when handling animation
    Global uniqueIDMutex = CreateMutex()        ; used to make sure no thread collisions when allocating unique ID
    
    ; global atoms
    Global panelexAtom = GlobalAddAtom_("ProGUI_PanelEx") ; for use with setprop / getprop for quick retrieval of structure pointers from hwnd
    Global panelexpageAtom = GlobalAddAtom_("ProGUI_PanelExPage")
    Global trackwinAtom = GlobalAddAtom_("ProGUI_trackWin") ; used for keeping track of windows in ProGUI, e.g. PanelExPage autoscroll
    Global txtcontrolAtom = GlobalAddAtom_("ProGUI_TextControl") ; for use with setprop / getprop for quick retrieval of structure pointers from hwnd
    Global buttonexAtom = GlobalAddAtom_("ProGUI_ButtonEx") ; for use with setprop / getprop for quick retrieval of structure pointers from hwnd
    Global splitterexAtom = GlobalAddAtom_("ProGUI_SplitterEx") ; for use with setprop / getprop for quick retrieval of structure pointers from hwnd
    Global explorerbarAtom = GlobalAddAtom_("ProGUI_ExplorerBar") ; for use with setprop / getprop for quick retrieval of structure pointers from hwnd
    Global graphAtom = GlobalAddAtom_("ProGUI_Graph") ; for use with setprop / getprop for quick retrieval of structure pointers from hwnd
    
    ; animation threads
    Global animationThreadID     ; system ID of the thread
    Global animationThreadHandle ; system hThread handle
    Global animationThreadHwnd   ; hwnd of the thread
    Global renderThreadID        ; system ID of the thread
    Global renderThreadHandle    ; system hThread handle
    Global renderThreadHwnd      ; hwnd of the thread
    
    ; animation control events for communication between main animation thread, render thread and calling commands
    Global animationRenderEvent = CreateEvent_(0, 0, 0, 0) ; signaled to render thread from main animation thread
    Global animationTrueEvent = CreateEvent_(0, 0, 0, 0)   ; signaled from main animation thread back to a calling command
    Global animationFalseEvent = CreateEvent_(0, 0, 0, 0)  ; signaled from main animation thread back to a calling command
    Global updateSemaphore = #Null
    
    ; set up UI colours
    Global UIColourMode ; used for storing current UI colour mode
    Global Dim UIWhidbeyColours.UIColours(#MaxUIComponents)
    Global Dim UIOffice2003Colours.UIColours(#MaxUIComponents)
    Global Dim UIOffice2007Colours.UIColours(#MaxUIComponents)
    Global Dim brushHandle.brushHandles(#MaxUIComponents)
    setDefaultUIColours()
    
    ; image codecs
    UsePNGImageDecoder()
    UseJPEGImageDecoder()
    
    ; packer compression
    UseZipPacker()
    
    DataSection
        nullicon:
        IncludeBinary "null.ico"
        toolstripDropdownGlyph:
        IncludeBinary "toolstripDropdownGlyph.ico"
        dropdownGlyph:
        IncludeBinary "dropdownGlyph.ico"
        tickicon:
        IncludeBinary "tick.ico"
        bulleticon:
        IncludeBinary "bullet.ico"
        arrowicon:
        Data.b 135, 140, 46, 98, 2, 54, 78, 239, 82, 38, 57, 181, 56
    EndDataSection
    
    Global nullicon
    nullicon = ImageID(CatchImage(#PB_Any, ?nullicon))
    Global toolstripDropdownGlyph
    toolstripDropdownGlyph = ImageList_Create_(7, 17, #ILC_MASK | #ILC_COLOR32, 0, 0)
    error = ImageList_ReplaceIcon_(toolstripDropdownGlyph, -1, ImageID(CatchImage(#PB_Any, ?toolstripDropdownGlyph)))
    Global dropdownGlyph
    dropdownGlyph = ImageList_Create_(5, 3, #ILC_MASK | #ILC_COLOR32, 0, 0)
    error = ImageList_ReplaceIcon_(dropdownGlyph, -1, ImageID(CatchImage(#PB_Any, ?dropdownGlyph)))
    Global tickicon
    tickicon = ImageList_Create_(7, 7, #ILC_MASK | #ILC_COLOR32, 0, 0)
    error = ImageList_ReplaceIcon_(tickicon, -1, ImageID(CatchImage(#PB_Any, ?tickicon)))
    Global bulleticon
    bulleticon = ImageList_Create_(7, 7, #ILC_MASK | #ILC_COLOR32, 0, 0)
    error = ImageList_ReplaceIcon_(bulleticon, -1, ImageID(CatchImage(#PB_Any, ?bulleticon)))
    
    Global seed.l = 259173849
    
    ;- load mouse pointers
    Global normalMousePointer = LoadCursor_(0, #IDC_ARROW)
    Global verticalResizeMousePointer = LoadCursor_(0, #IDC_SIZENS)
    Global verticalDragMousePointer = LoadCursor_(0, #IDC_SIZENS)
    Global linkMousePointer = LoadCursor_(0, #IDC_HAND)
    Global dragMousePointer = LoadCursor_(0, #IDC_SIZEALL)
    Global hResizeMousePointer = LoadCursor_(0, #IDC_SIZEWE)
    
    Global rebarResizableMousepointer
    Global mousePointerHook
    Global rebarMouseMoveHook
    Global rebarVerticalResizeDrag
    rebarVerticalResizeDrag = -1
    Global lastRebarVertResizePos
    
    Global rebarGadgetInsert
    rebarGadgetInsert = -2  ; de-activate rebaraddgadget insert mode
    
    Global seed3.l = 478734210
    
    Global lastResizeRect.RECT
    Global resizeRECT.RECT
    Global resizing
    Global resizeMaximized
    Global LargestDesktopWidth  ; used for storing the largest desktop width on the system, for rebar UI Style formating
    
    currentMenuEx = -1
    currentMenuTitleEX = -1
    currentRebarGadget = -1
    currentToolbarEX = -1
    
    Global seed2.l = 924751372
    
    menuItemOver = -1
    menuOriginItem = -1
    menuHotItemNext = -1
    menuExItemIconWidth = 16
    menuExItemIconHeight = 16
    
    trialCounter = (200+800)*18
    
    ; set DefualtFont
    Global DefaultFont
    metrics.NONCLIENTMETRICS
    metrics\cbSize = SizeOf(NONCLIENTMETRICS)
    SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
    DefaultFont = CreateFontIndirect_(metrics\lfMenuFont)
    
    Global testFont = LoadFontEx("Verdana", 10, 0)
    
    ; get system menu drop shadow status
    SystemParametersInfo_(#SPI_GETDROPSHADOW, 0, @systemDropShadowsEnabled, 0)
    
    ; system horizontal / vertical scrollbar thumb size
    Global iHThumb = GetSystemMetrics_(#SM_CXHTHUMB)
    Global iVThumb = GetSystemMetrics_(#SM_CYVTHUMB)
    
    ; system maximum width / height of a window that has a caption and sizing borders
    Global iCXMaxTrack =  GetSystemMetrics_(#SM_CXMAXTRACK)
    Global iCYMaxTrack =  GetSystemMetrics_(#SM_CYMAXTRACK)
    
    ; stores current caret info
    Global caret.caret
    
    ; display ProGUI version
    Global Version.f = #Version
    CompilerIf #DEBUGENABLED <> 0
        debuglog(#AppName+" Version: "+StrF(Version,2))
    CompilerEndIf
    
    ; get os version
    Global osVersion = OSVersion()
    CompilerIf #DEBUGENABLED <> 0
        debuglog("Operating System Version: "+Str(osVersion))
    CompilerEndIf
    
    ; get Comctl32.dll version
    Global Comctl32MajorVersion
    Global Comctl32MinorVersion
    Global Comctl32BuildNumber
    
    lib = OpenLibrary(#PB_Any,"Comctl32.dll")
    If lib <> 0
        dllinfo.DLLVERSIONINFO
        dllinfo\cbSize = SizeOf(DLLVERSIONINFO)
        CallFunction(lib,"DllGetVersion",@dllinfo)
        Comctl32MajorVersion = dllinfo\dwMajorVersion
        Comctl32MinorVersion = dllinfo\dwMinorVersion
        Comctl32BuildNumber = dllinfo\dwBuildNumber
        CompilerIf #DEBUGENABLED <> 0
            debuglog("Comctl32.dll Version: "+Str(Comctl32MajorVersion)+"."+Str(Comctl32MinorVersion)+"."+Str(Comctl32BuildNumber))
        CompilerEndIf
        CloseLibrary(lib)
    EndIf
    
    Gdi32 = OpenLibrary(#PB_Any, "Gdi32.dll") 
    If Gdi32
        Global GdiAlphaBlend_.GdiAlphaBlend_ = GetFunction(Gdi32, "GdiAlphaBlend")
        Debuglog("GdiAlphaBlend: "+Str(GdiAlphaBlend_))
        Global GdiGradientFill_.GdiGradientFill_ = GetFunction(Gdi32, "GdiGradientFill")
        Debuglog("GdiGradientFill: "+Str(GdiGradientFill_))
    Else 
       MessageRequester("Error!","Can't open Gdi32.dll",#MB_ICONERROR)
    EndIf
    
    InitXPtheme()
    InitDwmapi()
    InitMMCSS()
    CompilerIf #DEBUGENABLED = -1
        debuglog("initialising GDI+...")
    CompilerEndIf
    InitGDIPlus()
    CompilerIf #DEBUGENABLED = -1
        debuglog("GDI+ initialised.")
    CompilerEndIf
    
    Init_GraphLibrary()
    
    ; Initialise API Hooks for diverted rendering
    hook_Init()
    
    CompilerIf #DISABLEPROTECTION = 0
        macro_loadHash()
        macro_verifyHash()
    CompilerEndIf
    
EndProcedure

;- !!!!!!!********** Includes
XIncludeFile "ProGUI_PanelEx.pbi"

;-
Procedure getDivertedBuffer_(*trackWin.trackWindows, dc = #Null, isClient = #False, fromGet = #False)
    
    If *trackWin\divertedDummyDC = #Null
        *trackWin\divertedDummyDC = CreateCompatibleDC_(0)
        *trackWin\divertedDummyRgn = CreateRectRgn_(0, 0, 0, 0)
        SelectClipRgn_(*trackWin\divertedDummyDC, *trackWin\divertedDummyRgn)
    EndIf
    
    If dc <> #Null
        
        *trackWin\divertedOriginalDC = dc
        If fromGet = #True
            *trackWin\divertedGetDC[*trackWin\divertedGetIndex] = dc
            *trackWin\divertedGetIndex + 1
            If *trackWin\divertedGetIndex > #MAXGETS-1
                *trackWin\divertedGetIndex = #MAXGETS-1
            EndIf
        EndIf
         
        ; calculate window frame offsets
        GetWindowRect_(*trackWin\hwnd, wrc.RECT)
        MapWindowPoints_(0, *trackWin\hwnd, wrc, 2)
        
        If wrc\left < 0
            frameXOffset = -wrc\left
        EndIf
        If wrc\top < 0
            frameYOffset = -wrc\top
        EndIf
        
        If *trackWin\divertedClipRgn <> #Null
            SelectObject_(*trackWin\divertedDC, *trackWin\divertedOrgClipRgn)
            DeleteObject_(*trackWin\divertedClipRgn)
        EndIf
        
        ;*trackWin\divertedClipRgn = CreateRectRgn_(0, 0, *trackWin\divertedWidth, *trackWin\divertedHeight)
        
        *trackWin\divertedClipRgn = CreateRectRgn_(0, 0, 0, 0)
        GetRandomRgn_(dc, *trackWin\divertedClipRgn, 4)
        MapWindowPoints_(0, *trackWin\hwnd, pt.POINT, 1)
        OffsetRgn_(*trackWin\divertedClipRgn, pt\x+frameXOffset, pt\y+frameYOffset)
        
    Else
        
        *rpanelex.panelexs = *trackWin\rootPanelex
        dc = *rpanelex\backgroundDC
        
    EndIf
    
    GetWindowRect_(*trackWin\hwnd, rec.RECT)
    
    If *trackWin\divertedBuffer = #Null Or (rec\right-rec\left) > *trackWin\divertedWidth Or (rec\bottom-rec\top) > *trackwin\divertedHeight
        
        If *trackWin\divertedDC = #Null
            *trackWin\divertedDC = CreateCompatibleDC_(dc)
        EndIf
        
        oldWidth = *trackWin\divertedWidth
        oldHeight = *trackWin\divertedHeight
        
        If (rec\right-rec\left) > *trackWin\divertedWidth
            *trackWin\divertedWidth = rec\right-rec\left
        EndIf
        
        If (rec\bottom-rec\top) > *trackWin\divertedHeight
            *trackWin\divertedHeight = rec\bottom-rec\top
        EndIf
        
        If *trackWin\divertedWidth <= 0
            *trackWin\divertedWidth = 1
        EndIf
        If *trackWin\divertedHeight <= 0
            *trackWin\divertedHeight = 1
        EndIf
        
        ;*trackWin\divertedBuffer = CreateImage(#PB_Any, *trackWin\divertedWidth, *trackWin\divertedHeight, 32);, RGB(255,0,0))
        ;*trackWin\divertedDC = CreateCompatibleDC_(dc)
        ;SelectObject_(*trackWin\divertedDC, ImageID(*trackWin\divertedBuffer))
        
        newDivertedBuffer = CreateImage(#PB_Any, *trackWin\divertedWidth, *trackWin\divertedHeight, 32);, RGB(255,0,0))
        
        If *trackWin\divertedBuffer <> #Null
            
            SetWindowOrgEx_(*trackWin\divertedDC, 0, 0, 0)
            
            ndc = StartDrawing(ImageOutput(newDivertedBuffer))
            BitBlt_(ndc, 0, 0, oldWidth, oldHeight, *trackWin\divertedDC, 0, 0, #SRCCOPY)
            StopDrawing()
            
            SelectObject_(*trackWin\divertedDC, ImageID(newDivertedBuffer))
            FreeImage(*trackWin\divertedBuffer)
            *trackWin\divertedBuffer = newDivertedBuffer
            
        Else
            SelectObject_(*trackWin\divertedDC, ImageID(newDivertedBuffer))
            *trackWin\divertedBuffer = newDivertedBuffer
        EndIf
        
    Else
        ;If isClient = #True And fromGet = #False
        ;StartDrawing(ImageOutput(*trackWin\divertedBuffer))
        ;DrawingMode(#PB_2DDrawing_AllChannels)
        ;Box(0, 0, *trackWin\divertedWidth, *trackWin\divertedHeight, RGBA(255, 0, 0, 255))
        ;StopDrawing()
        ;EndIf
        
        ;*rpanelex.panelexs = *trackWin\rootPanelex
        ;GetClientRect_(*trackWin\hwnd, rc.RECT)
        ;width = rc\right-rc\left
        ;height = rc\bottom-rc\top
        ;MapWindowPoints_(*trackWin\hwnd, *trackWin\rootPanelexPageHwnd, rc, 2)
        ;BitBlt_(*trackWin\divertedDC, 0, 0, width, height, *rpanelex\backgroundDC, rc\left, rc\top, #SRCCOPY)
        
    EndIf
    
    If *trackWin\divertedClipRgn <> #Null
        old = SelectClipRgn_(*trackWin\divertedDC, *trackWin\divertedClipRgn)
        If *trackWin\divertedOrgClipRgn = #Null
            *trackWin\divertedOrgClipRgn = old
        EndIf
    EndIf
    
    If isClient = #True
        ; calculate window frame offsets
        GetWindowRect_(*trackWin\hwnd, wrc.RECT)
        MapWindowPoints_(0, *trackWin\hwnd, wrc, 2)
        If wrc\left < 0
            frameXOffset = -wrc\left
        EndIf
        If wrc\top < 0
            frameYOffset = -wrc\top
        EndIf
        SetWindowOrgEx_(*trackWin\divertedDC, -frameXOffset, -frameYOffset, 0)
        OffsetRgn_(*trackWin\divertedClipRgn, -frameXOffset, -frameYOffset)
    Else
        SetWindowOrgEx_(*trackWin\divertedDC, 0, 0, 0)
        ProcedureReturn *trackWin\divertedDummyDC
    EndIf
    
    If *trackWin\divertedSetNoRedraw <> #False
        ProcedureReturn *trackWin\divertedDummyDC
    EndIf
    
    ProcedureReturn *trackWin\divertedDC
    
EndProcedure

Global *currentTrackwin
Procedure getDivertedBuffer(*trackWin.trackWindows, dc = #Null, isClient = #False, fromGet = #False, registerGetOnly = #False)
    
    If *trackWin\divertedDummyDC = #Null
        *trackWin\divertedDummyDC = CreateCompatibleDC_(0)
        *trackWin\divertedDummyRgn = CreateRectRgn_(0, 0, 0, 0)
        SelectClipRgn_(*trackWin\divertedDummyDC, *trackWin\divertedDummyRgn)
    EndIf
    
    If dc <> #Null
        
;         If GetObjectType_(*trackWin\divertedOriginalDC) <> #OBJ_DC
;             ReleaseDC_(*trackWin\hwnd, *trackWin\divertedOriginalDC)
;             DeleteDC_(*trackWin\divertedOriginalDC)
;             *trackWin\divertedOriginalDC = #Null
;         EndIf
        
        *trackWin\divertedOriginalDC = dc
        If fromGet = #True
            *trackWin\divertedGetDC[*trackWin\divertedGetIndex] = dc
            *trackWin\divertedGetType[*trackWin\divertedGetIndex] = isClient
            *trackWin\divertedGetIndex + 1
            If *trackWin\divertedGetIndex > #MAXGETS-1
                *trackWin\divertedGetIndex = #MAXGETS-1
            EndIf
            If registerGetOnly = #True
                ProcedureReturn dc
            EndIf
        EndIf
        
        If isClient = #True
        
            If *trackWin\divertedClipRgn <> #Null
                SelectObject_(*trackWin\divertedDC, *trackWin\divertedOrgClipRgn)
                DeleteObject_(*trackWin\divertedClipRgn)
            EndIf
            
            ;If *trackWin\divertedBuffer = #Null
            ;    GetClientRect_(*trackWin\hwnd, rc.RECT)
            ;    *trackWin\divertedClipRgn = CreateRectRgnIndirect_(rc)
            ;Else
            
            *trackWin\divertedClipRgn = CreateRectRgn_(0, 0, 0, 0)
            GetRandomRgn_(dc, *trackWin\divertedClipRgn, 4)
            MapWindowPoints_(0, *trackWin\hwnd, pt.POINT, 1)
            OffsetRgn_(*trackWin\divertedClipRgn, pt\x, pt\y)
            
            ;EndIf
            
        Else
            
            ; calculate window frame offsets
            GetWindowRect_(*trackWin\hwnd, wrc.RECT)
            MapWindowPoints_(0, *trackWin\hwnd, wrc, 2)
            
            If wrc\left < 0
                frameXOffset = -wrc\left
            EndIf
            If wrc\top < 0
                frameYOffset = -wrc\top
            EndIf
            
            If frameXOffset <> 0 Or frameYOffset <> 0
            
                If *trackWin\divertedWinClipRgn <> #Null
                    SelectObject_(*trackWin\divertedWinDC, *trackWin\divertedWinOrgClipRgn)
                    DeleteObject_(*trackWin\divertedWinClipRgn)
                EndIf
                
                ;If *trackWin\divertedWinBuffer = #Null
                ;    *trackWin\divertedWinClipRgn = CreateRectRgn_(0, 0, wrc\right-wrc\left, wrc\bottom-wrc\top)
                ;Else
                    *trackWin\divertedWinClipRgn = CreateRectRgn_(0, 0, 0, 0)
                    GetRandomRgn_(dc, *trackWin\divertedWinClipRgn, 4)
                    MapWindowPoints_(0, *trackWin\hwnd, pt.POINT, 1)
                    OffsetRgn_(*trackWin\divertedWinClipRgn, pt\x+frameXOffset, pt\y+frameYOffset)
                ;EndIf
                
            Else
                
                If *trackWin\divertedClipRgn <> #Null
                    SelectObject_(*trackWin\divertedDC, *trackWin\divertedOrgClipRgn)
                    DeleteObject_(*trackWin\divertedClipRgn)
                EndIf
                
                *trackWin\divertedClipRgn = CreateRectRgn_(0, 0, 0, 0)
                GetRandomRgn_(dc, *trackWin\divertedClipRgn, 4)
                MapWindowPoints_(0, *trackWin\hwnd, pt.POINT, 1)
                OffsetRgn_(*trackWin\divertedClipRgn, pt\x, pt\y)
                
            EndIf
            
        EndIf
            
    Else
        
        *rpanelex.panelexs = *trackWin\rootPanelex
        dc = *rpanelex\backgroundDC
        
    EndIf
    
    ; calculate window frame offsets
    GetWindowRect_(*trackWin\hwnd, wrc.RECT)
    MapWindowPoints_(0, *trackWin\hwnd, wrc, 2)
    
    If wrc\left < 0
        frameXOffset = -wrc\left
    EndIf
    If wrc\top < 0
        frameYOffset = -wrc\top
    EndIf
    
    If isClient = #True Or (isClient = #False And frameXOffset = 0 And frameYOffset = 0)
    
        GetClientRect_(*trackWin\hwnd, rec.RECT)
        
        If *trackWin\divertedBuffer = #Null Or (rec\right-rec\left) > *trackWin\divertedWidth Or (rec\bottom-rec\top) > *trackwin\divertedHeight
            
            If *trackWin\divertedDC = #Null
                *trackWin\divertedDC = CreateCompatibleDC_(dc)
                class.s = Space(255)
                GetClassName_(*trackWin\hwnd, @class, 255)
                debuglog("Creating diverted client DC class: " + class)
            EndIf
            
            oldWidth = *trackWin\divertedWidth
            oldHeight = *trackWin\divertedHeight
            
            If (rec\right-rec\left) > *trackWin\divertedWidth
                *trackWin\divertedWidth = rec\right-rec\left
            EndIf
            
            If (rec\bottom-rec\top) > *trackWin\divertedHeight
                *trackWin\divertedHeight = rec\bottom-rec\top
            EndIf
            
            If *trackWin\divertedWidth <= 0
                *trackWin\divertedWidth = 1
            EndIf
            If *trackWin\divertedHeight <= 0
                *trackWin\divertedHeight = 1
            EndIf
            
            newDivertedBuffer = CreateImage(#PB_Any, *trackWin\divertedWidth, *trackWin\divertedHeight, 32, GetSysColor_(#COLOR_WINDOW))
            
            If *trackWin\divertedBuffer <> #Null
                
                ndc = StartDrawing(ImageOutput(newDivertedBuffer))
                BitBlt_(ndc, 0, 0, oldWidth, oldHeight, *trackWin\divertedDC, 0, 0, #SRCCOPY)
                StopDrawing()
                
                SelectObject_(*trackWin\divertedDC, ImageID(newDivertedBuffer))
                FreeImage(*trackWin\divertedBuffer)
                *trackWin\divertedBuffer = newDivertedBuffer
                
            Else
                SelectObject_(*trackWin\divertedDC, ImageID(newDivertedBuffer))
                *trackWin\divertedBuffer = newDivertedBuffer
            EndIf
            
        Else
            ;If isClient = #True And fromGet = #False
            ;StartDrawing(ImageOutput(*trackWin\divertedBuffer))
            ;DrawingMode(#PB_2DDrawing_AllChannels)
            ;Box(0, 0, *trackWin\divertedWidth, *trackWin\divertedHeight, RGBA(255, 0, 0, 255))
            ;StopDrawing()
            ;EndIf
            
            ;*rpanelex.panelexs = *trackWin\rootPanelex
            ;GetClientRect_(*trackWin\hwnd, rc.RECT)
            ;width = rc\right-rc\left
            ;height = rc\bottom-rc\top
            ;MapWindowPoints_(*trackWin\hwnd, *trackWin\rootPanelexPageHwnd, rc, 2)
            ;BitBlt_(*trackWin\divertedDC, 0, 0, width, height, *rpanelex\backgroundDC, rc\left, rc\top, #SRCCOPY)
            
        EndIf
        
        If *trackWin\divertedClipRgn <> #Null
            old = SelectClipRgn_(*trackWin\divertedDC, *trackWin\divertedClipRgn)
            If *trackWin\divertedOrgClipRgn = #Null
                *trackWin\divertedOrgClipRgn = old
            EndIf
        EndIf
        
;         root = *trackWin\rootPanelexPageHwnd
;         *rootpanelexpage.panelexpages = *trackWin\rootPanelexPage
;         If *rootpanelexpage <> #Null
;             
;             *rootpanelex.panelexs = *rootpanelexpage\panelex
;             
;             dc = *rootpanelex\backgroundDC
;             
;             GetClientRect_(*trackWin\hwnd, @rc.RECT)
;             
;             width = rc\right-rc\left
;             height = rc\bottom-rc\top
;             MapWindowPoints_(*trackWin\hwnd, root, @rc, 2)
;             
;             BitBlt_(*trackWin\divertedDC, 0 , 0, width, height, dc, rc\left, rc\top, #SRCCOPY)
;             
;         EndIf
        
        result = *trackWin\divertedDC
        
    ElseIf isClient = #False Or isClient = -1 ; -1 = force setup of dc and buffer for window frame, and return
        
        GetWindowRect_(*trackWin\hwnd, rec.RECT)
        
        If *trackWin\divertedWinBuffer = #Null Or (rec\right-rec\left) > *trackWin\divertedWinWidth Or (rec\bottom-rec\top) > *trackwin\divertedWinHeight
            
            If *trackWin\divertedWinDC = #Null
                *trackWin\divertedWinDC = CreateCompatibleDC_(dc)
                class.s = Space(255)
                GetClassName_(*trackWin\hwnd, @class, 255)
                debuglog("Creating diverted window DC class: " + class)
            EndIf
            
            oldWidth = *trackWin\divertedWinWidth
            oldHeight = *trackWin\divertedWinHeight
            
            If (rec\right-rec\left) > *trackWin\divertedWinWidth
                *trackWin\divertedWinWidth = rec\right-rec\left
            EndIf
            
            If (rec\bottom-rec\top) > *trackWin\divertedWinHeight
                *trackWin\divertedWinHeight = rec\bottom-rec\top
            EndIf
            
            If *trackWin\divertedWinWidth <= 0
                *trackWin\divertedWinWidth = 1
            EndIf
            If *trackWin\divertedWinHeight <= 0
                *trackWin\divertedWinHeight = 1
            EndIf
            
            newDivertedBuffer = CreateImage(#PB_Any, *trackWin\divertedWinWidth, *trackWin\divertedWinHeight, 32, GetSysColor_(#COLOR_WINDOW))
            
            If *trackWin\divertedWinBuffer <> #Null
                
                ndc = StartDrawing(ImageOutput(newDivertedBuffer))
                BitBlt_(ndc, 0, 0, oldWidth, oldHeight, *trackWin\divertedWinDC, 0, 0, #SRCCOPY)
                StopDrawing()
                
                SelectObject_(*trackWin\divertedWinDC, ImageID(newDivertedBuffer))
                FreeImage(*trackWin\divertedWinBuffer)
                *trackWin\divertedWinBuffer = newDivertedBuffer
                
            Else
                SelectObject_(*trackWin\divertedWinDC, ImageID(newDivertedBuffer))
                *trackWin\divertedWinBuffer = newDivertedBuffer
            EndIf
            
        Else
            ;If isClient = #True And fromGet = #False
            ;StartDrawing(ImageOutput(*trackWin\divertedBuffer))
            ;DrawingMode(#PB_2DDrawing_AllChannels)
            ;Box(0, 0, *trackWin\divertedWidth, *trackWin\divertedHeight, RGBA(255, 0, 0, 255))
            ;StopDrawing()
            ;EndIf
            
            ;*rpanelex.panelexs = *trackWin\rootPanelex
            ;GetClientRect_(*trackWin\hwnd, rc.RECT)
            ;width = rc\right-rc\left
            ;height = rc\bottom-rc\top
            ;MapWindowPoints_(*trackWin\hwnd, *trackWin\rootPanelexPageHwnd, rc, 2)
            ;BitBlt_(*trackWin\divertedDC, 0, 0, width, height, *rpanelex\backgroundDC, rc\left, rc\top, #SRCCOPY)
            
        EndIf
        
        If *trackWin\divertedWinClipRgn <> #Null
            old = SelectClipRgn_(*trackWin\divertedWinDC, *trackWin\divertedWinClipRgn)
            If *trackWin\divertedWinOrgClipRgn = #Null
                *trackWin\divertedWinOrgClipRgn = old
            EndIf
        EndIf
        
        result = *trackWin\divertedWinDC
        
    EndIf
    
    If *trackWin\divertedSetNoRedraw <> #False
        ProcedureReturn *trackWin\divertedDummyDC
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newSetParent(hWndChild, hWndNewParent)
    
    class.s = Space(255)
    GetClassName_(hWndChild, @class, 255)
    class2.s = Space(255)
    GetClassName_(hWndNewParent, @class2, 255)
    debuglog("Set parent " + class + " to " + class2)
    
    *trackWin.trackWindows = GetProp_(hWndChild, trackwinAtom)
    If *trackWin <> #Null
        
        *oldParentTrackWin.trackWindows = *trackWin\parentTrackWin
        
        result = SetParent(hWndChild, hWndNewParent)
        
        *trackWin\parent = hWndNewParent
        *trackWin\parentTrackWin = GetProp_(*trackWin\parent, trackwinAtom)
        updateTrackWinRootPanelEx(*oldParentTrackWin)
        updateTrackWinRootPanelEx(*trackWin)
        
        ; delete cached static control backbrush if set
        If *trackWin\hBrush <> #Null
            DeleteObject_(*trackWin\hBrush)
            *trackWin\hBrush = #Null
        EndIf
        
    Else
        result = SetParent(hWndChild, hWndNewParent)  
    EndIf
  
    ProcedureReturn result
    
EndProcedure

