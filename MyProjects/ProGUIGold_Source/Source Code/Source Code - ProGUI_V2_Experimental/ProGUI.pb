Procedure CRC32Fingerprint(*bits, size)
    
    UseCRC32Fingerprint()
    ProcedureReturn Val("$"+Fingerprint(*bits, size, #PB_Cipher_CRC32))
    
EndProcedure

ProcedureDLL OpenWindowEx(Title.s, x, y, InnerWidth, InnerHeight, Flags.i, Skin.i, ParentHwnd.i) ; Creates a new window
    
    macro_protectCommand()
    
    window = OpenWindow(#PB_Any, x, y, InnerWidth, InnerHeight, Title, Flags, ParentHwnd)
    If window <> 0 And IsWindow(window)
        ProcedureReturn WindowID(window)
    EndIf
    
    ProcedureReturn #False
    
EndProcedure

ProcedureDLL LimitWindowSize(WindowID.i, MinWidth.l, MinHeight.l, MaxWidth.l, MaxHeight.l) ; sets the minimum and maximum dimensions that a window (HWND) can be resized to.
    
    macro_protectCommand()
    
    If IsWindow_(WindowID)
        
        *trackWin.trackWindows = GetProp_(WindowID, trackwinAtom)
        If *trackWin <> #Null
        
            GetWindowRect_(WindowID, rc.RECT)
            If rc\right-rc\left < MinWidth And MinWidth <> 0
                width = MinWidth
            ElseIf rc\right-rc\left > MaxWidth And MaxWidth <> 0
                width = MaxWidth
            EndIf
            If rc\bottom-rc\top < MinHeight And MinHeight <> 0
                height = MinHeight
            ElseIf rc\bottom-rc\top > MaxHeight And MaxHeight <> 0
                height = MaxHeight
            EndIf
            
            *trackWin\limitSize\left = MinWidth
            *trackWin\limitSize\top = MinHeight
            *trackWin\limitSize\right = MaxWidth
            *trackWin\limitSize\bottom = MaxHeight
            *trackWin\limitSizeSet = #True
            
            If width > 0 Or height > 0
                SetWindowPos_(WindowID, 0, 0, 0, width, height, #SWP_NOMOVE)
            EndIf
            
        EndIf
        
    EndIf
    
    ProcedureReturn #True
    
EndProcedure

Procedure HotKeyHook(nCode, wParam, lParam)
    Static ctrl, shift, alt
    
    If HaltProGUI = #True
        ProcedureReturn 0
    EndIf
    
    If nCode = #HC_ACTION
        
        *msg.MSG = lParam
        Select *msg\message
                
            Case #WM_KEYDOWN
                
                If *msg\wParam = #VK_CONTROL
                    ctrl = #FCONTROL
                ElseIf *msg\wParam = #VK_SHIFT
                    shift = #FSHIFT
                ElseIf *msg\wParam = #VK_MENU
                    alt = #FALT
                Else
                    ; check hotkey table for the window
                    
                    WindowID = GetAncestor_(*msg\hwnd, #GA_ROOT)
                    
                    LockMutex(hotkeyMutex)
                    If FindMapElement(hotkeyTable(), Str(WindowID)) <> 0
                        
                        ForEach hotkeyTable()\k()
                            If hotkeyTable()\k()\fvirt & #FVIRTKEY
                                fvirt = ctrl|shift|alt|#FVIRTKEY
                                key = *msg\wParam
                            Else
                                fvirt = ctrl|shift|alt
                                key = MapVirtualKey_(*msg\wParam, 2)
                            EndIf
                            If hotkeyTable()\k()\fvirt = fvirt And hotkeyTable()\k()\key = key
                                found = #True
                                ID = hotkeyTable()\k()\cmd
                                Break
                            EndIf
                        Next
                        
                    EndIf
                    ; nothing found check global hot keys
                    If found = 0
                        If FindMapElement(hotkeyTable(), "0") <> 0
                            
                            ForEach hotkeyTable()\k()
                                If hotkeyTable()\k()\fvirt & #FVIRTKEY
                                    fvirt = ctrl|shift|alt|#FVIRTKEY
                                    key = *msg\wParam
                                Else
                                    fvirt = ctrl|shift|alt
                                    key = MapVirtualKey_(*msg\wParam, 2)
                                EndIf
                                If hotkeyTable()\k()\fvirt = fvirt And hotkeyTable()\k()\key = key
                                    found = #True
                                    ID = hotkeyTable()\k()\cmd
                                    gui.GUITHREADINFO
                                    gui\cbSize = SizeOf(GUITHREADINFO)
                                    If GetGUIThreadInfo_(GetCurrentThreadId_(), @gui) <> 0
                                        WindowID = GetAncestor_(gui\hwndActive, #GA_ROOT)
                                    EndIf
                                    Break
                                EndIf
                            Next
                            
                        EndIf
                    EndIf
                    UnlockMutex(hotkeyMutex)
                    
                    If found = #True
                        SendMessage_(WindowID, #WM_COMMAND, MakeLong(ID, 0), 0)
                        *msg\message = 0 ; stop other hooks from processing this message
                    EndIf
                    
                EndIf
                
            Case #WM_KEYUP
                
                If *msg\wParam = #VK_CONTROL
                    ctrl = #False
                ElseIf *msg\wParam = #VK_SHIFT
                    shift = #False
                ElseIf *msg\wParam = #VK_MENU
                    alt = #False
                EndIf
                
            Case #WM_SYSKEYDOWN
                
                If *msg\wParam <> #VK_MENU
                    If HIWORD(*msg\lParam) & #KF_ALTDOWN
                        
                        If *msg\wParam = #VK_CONTROL
                            ctrl = #FCONTROL
                        ElseIf *msg\wParam = #VK_SHIFT
                            shift = #FSHIFT
                        Else
                            
                            WindowID = GetAncestor_(*msg\hwnd, #GA_ROOT)
                            
                            LockMutex(hotkeyMutex)
                            If FindMapElement(hotkeyTable(), Str(WindowID)) <> 0
                                
                                ForEach hotkeyTable()\k()
                                    If hotkeyTable()\k()\fvirt & #FVIRTKEY
                                        fvirt = ctrl|shift|#FALT|#FVIRTKEY
                                        key = *msg\wParam
                                    Else
                                        fvirt = ctrl|shift|#FALT
                                        key = MapVirtualKey_(*msg\wParam, 2)
                                    EndIf
                                    If hotkeyTable()\k()\fvirt = fvirt And hotkeyTable()\k()\key = key
                                        found = #True
                                        ID = hotkeyTable()\k()\cmd
                                        Break
                                    EndIf
                                Next
                                
                            EndIf
                            ; nothing found check global hot keys
                            If found = 0
                                If FindMapElement(hotkeyTable(), "0") <> 0
                                    
                                    ForEach hotkeyTable()\k()
                                        If hotkeyTable()\k()\fvirt & #FVIRTKEY
                                            fvirt = ctrl|shift|#FALT|#FVIRTKEY
                                            key = *msg\wParam
                                        Else
                                            fvirt = ctrl|shift|#FALT
                                            key = MapVirtualKey_(*msg\wParam, 2)
                                        EndIf
                                        If hotkeyTable()\k()\fvirt = fvirt And hotkeyTable()\k()\key = key
                                            found = #True
                                            ID = hotkeyTable()\k()\cmd
                                            gui.GUITHREADINFO
                                            gui\cbSize = SizeOf(GUITHREADINFO)
                                            If GetGUIThreadInfo_(GetCurrentThreadId_(), @gui) <> 0
                                                WindowID = GetAncestor_(gui\hwndActive, #GA_ROOT)
                                            EndIf
                                            Break
                                        EndIf
                                    Next
                                    
                                EndIf
                            EndIf
                            UnlockMutex(hotkeyMutex)
                            
                            If found = #True
                                SendMessage_(WindowID, #WM_COMMAND, MakeLong(ID, 0), 0)
                                *msg\message = 0 ; stop other hooks from processing this message
                            EndIf
                            
                        EndIf
                        
                        alt = #FALT
                        
                    EndIf
                ElseIf *msg\wParam = #VK_MENU
                    alt = #FALT
                EndIf
                
            Case #WM_SYSKEYUP
                
                If *msg\wParam = #VK_CONTROL
                    ctrl = #False
                ElseIf *msg\wParam = #VK_SHIFT
                    shift = #False
                ElseIf *msg\wParam = #VK_MENU
                    alt = #False
                EndIf
                
        EndSelect
        
        Result = CallNextHookEx_(0, nCode, wParam, lParam)
    ElseIf nCode < 0
        Result = CallNextHookEx_(0, nCode, wParam, lParam)
    EndIf
    
    ProcedureReturn Result
    
EndProcedure

ProcedureDLL HotKey(WindowID.i, ID.w, key$) ; sets a keyboard accelerator/shortcut combination specified by key$ to a window. ID = -1 to remove shortcut, Key$ = "" to clear all.
    
    macro_protectCommand()
    
    If key$ <> "" And (IsWindow_(WindowID) Or WindowID = 0)
        
        key$ = LCase(key$)
        
        ; extract key combinations
        fVirt = 0 : key = 0 : cmd = 0
        
        ; strip any effect escape codes that might be in there
        key$ = ReplaceString(key$, "\b", "")
        key$ = ReplaceString(key$, "\i", "")
        key$ = ReplaceString(key$, "\u", "")
        key$ = ReplaceString(key$, "\s", "")
        key$ = ReplaceString(key$, "\c", "")
        key$ = ReplaceString(key$, "\n", "")
        
        ; replace any unusual delimeters with +
        key$ = ReplaceString(key$, "|", "+")
        key$ = ReplaceString(key$, " ", "+")
        key$ = ReplaceString(key$, "-", "+")
        key$ = ReplaceString(key$, ",", "+")
        key$ = ReplaceString(key$, ".", "+")
        key$ = ReplaceString(key$, "~", "+")
        key$ = ReplaceString(key$, "^", "+")
        key$ = ReplaceString(key$, "/", "+")
        key$ = ReplaceString(key$, "\", "+")
        key$ = ReplaceString(key$, ":", "+")
        key$ = ReplaceString(key$, ";", "+")
        
        n = 1
        Repeat
            
            k$ = StringField(key$, n, "+")
            Select k$
                Case ""
                    ; do nothing
                Case "alt"
                    alt = #True
                Case "ctrl"
                    ctrl = #True
                Case "control"
                    ctrl = #True
                Case "shift"
                    shift = #True
                Case "back"
                    key = #VK_BACK
                Case "tab"
                    key = #VK_TAB
                Case "clear"
                    key = #VK_CLEAR
                Case "return"
                    key = #VK_RETURN
                Case "ret"
                    key = #VK_RETURN
                Case "enter"
                    key = #VK_RETURN
                Case "ent"
                    key = #VK_RETURN
                Case "pause"
                    key = #VK_PAUSE
                Case "capital"
                    key = #VK_CAPITAL
                Case "caps"
                    key = #VK_CAPITAL
                Case "capslock"
                    key = #VK_CAPITAL
                Case "escape"
                    key = #VK_ESCAPE
                Case "esc"
                    key = #VK_ESCAPE
                Case "space"
                    key = #VK_SPACE
                Case "prior"
                    key = #VK_PRIOR
                Case "next"
                    key = #VK_NEXT
                Case "pgdn"
                    key = #VK_PRIOR
                Case "pgup"
                    key = #VK_NEXT
                Case "pageup"
                    key = #VK_PRIOR
                Case "pagedown"
                    key = #VK_NEXT
                Case "end"
                    key = #VK_END
                Case "home"
                    key = #VK_HOME
                Case "left"
                    key = #VK_LEFT
                Case "up"
                    key = #VK_UP
                Case "right"
                    key = #VK_RIGHT
                Case "down"
                    key = #VK_DOWN
                Case "select"
                    key = #VK_SELECT
                Case "print"
                    key = #VK_PRINT
                Case "execute"
                    key = #VK_EXECUTE
                Case "snapshot"
                    key = #VK_SNAPSHOT
                Case "prtsc"
                    key = #VK_SNAPSHOT
                Case "insert"
                    key = #VK_INSERT
                Case "ins"
                    key = #VK_INSERT
                Case "delete"
                    key = #VK_DELETE
                Case "del"
                    key = #VK_DELETE
                Case "help"
                    key = #VK_HELP
                Case "lwin"
                    key = #VK_LWIN
                Case "rwin"
                    key = #VK_RWIN
                Case "leftwin"
                    key = #VK_LWIN
                Case "rightwin"
                    key = #VK_RWIN
                Case "leftwindows"
                    key = #VK_LWIN
                Case "rightwindows"
                    key = #VK_RWIN
                Case "apps"
                    key = #VK_APPS
                Case "numpad0"
                    key = #VK_NUMPAD0
                Case "numpad1"
                    key = #VK_NUMPAD1
                Case "numpad2"
                    key = #VK_NUMPAD2
                Case "numpad3"
                    key = #VK_NUMPAD3
                Case "numpad4"
                    key = #VK_NUMPAD4
                Case "numpad5"
                    key = #VK_NUMPAD5
                Case "numpad6"
                    key = #VK_NUMPAD6
                Case "numpad7"
                    key = #VK_NUMPAD7
                Case "numpad8"
                    key = #VK_NUMPAD8
                Case "numpad9"
                    key = #VK_NUMPAD9
                Case "num0"
                    key = #VK_NUMPAD0
                Case "num1"
                    key = #VK_NUMPAD1
                Case "num2"
                    key = #VK_NUMPAD2
                Case "num3"
                    key = #VK_NUMPAD3
                Case "num4"
                    key = #VK_NUMPAD4
                Case "num5"
                    key = #VK_NUMPAD5
                Case "num6"
                    key = #VK_NUMPAD6
                Case "num7"
                    key = #VK_NUMPAD7
                Case "num8"
                    key = #VK_NUMPAD8
                Case "num9"
                    key = #VK_NUMPAD9
                Case "pad0"
                    key = #VK_NUMPAD0
                Case "pad1"
                    key = #VK_NUMPAD1
                Case "pad2"
                    key = #VK_NUMPAD2
                Case "pad3"
                    key = #VK_NUMPAD3
                Case "pad4"
                    key = #VK_NUMPAD4
                Case "pad5"
                    key = #VK_NUMPAD5
                Case "pad6"
                    key = #VK_NUMPAD6
                Case "pad7"
                    key = #VK_NUMPAD7
                Case "pad8"
                    key = #VK_NUMPAD8
                Case "pad9"
                    key = #VK_NUMPAD9
                Case "multiply"
                    key = #VK_MULTIPLY
                Case "add"
                    key = #VK_ADD
                Case "separator"
                    key = #VK_SEPARATOR
                Case "subtract"
                    key = #VK_SUBTRACT
                Case "decimal"
                    key = #VK_DECIMAL
                Case "divide"
                    key = #VK_DIVIDE
                Case "f1"
                    key = #VK_F1
                Case "f2"
                    key = #VK_F2
                Case "f3"
                    key = #VK_F3
                Case "f4"
                    key = #VK_F4
                Case "f5"
                    key = #VK_F5
                Case "f6"
                    key = #VK_F6
                Case "f7"
                    key = #VK_F7
                Case "f8"
                    key = #VK_F8
                Case "f9"
                    key = #VK_F9
                Case "f10"
                    key = #VK_F10
                Case "f11"
                    key = #VK_F11
                Case "f12"
                    key = #VK_F12
                Case "f13"
                    key = #VK_F13
                Case "f14"
                    key = #VK_F14
                Case "f15"
                    key = #VK_F15
                Case "f16"
                    key = #VK_F16
                Case "f17"
                    key = #VK_F17
                Case "f18"
                    key = #VK_F18
                Case "f19"
                    key = #VK_F19
                Case "f20"
                    key = #VK_F20
                Case "f21"
                    key = #VK_F21
                Case "f22"
                    key = #VK_F22
                Case "f23"
                    key = #VK_F23
                Case "f24"
                    key = #VK_F24
                Case "numlock"
                    key = #VK_NUMLOCK
                Case "scroll"
                    key = #VK_SCROLL
                Case "plus"
                    key = #VK_OEM_PLUS
                Case "minus"
                    key = #VK_OEM_MINUS
                Case "comma"
                    key = #VK_OEM_COMMA
                Case "period"
                    key = #VK_OEM_PERIOD
                Default
                    
                    If Len(k$) = 1
                        asciimode = #True
                        key = Asc(UCase(k$))
                    Else
                        ProcedureReturn 0
                    EndIf
                    
            EndSelect
            
            n + 1
        Until k$ = ""
        
        If alt = #True
            fVirt = fVirt | #FALT
        EndIf
        If ctrl = #True
            fVirt = fVirt | #FCONTROL
        EndIf
        If shift = #True
            fVirt = fVirt | #FSHIFT
        EndIf
        
        If asciimode = #False
            fVirt = fVirt | #FVIRTKEY
        EndIf
        
        WindowID = GetAncestor_(WindowID, #GA_ROOT)
        
        LockMutex(hotkeyMutex)
        ForEach hotkeyTable(Str(WindowID))\k()
            If hotkeyTable()\k()\fVirt = fVirt And hotkeyTable()\k()\key = key
                ; remove key
                If ID = -1
                    DeleteElement(hotkeyTable()\k())
                    del = #True
                EndIf
                found = #True
                Break
            EndIf
        Next
        
        If del = #False
            If found = #False
                AddElement(hotkeyTable()\k())
            EndIf
            hotkeyTable()\k()\cmd = ID
            hotkeyTable()\k()\fVirt = fVirt
            hotkeyTable()\k()\key = key
        EndIf
        UnlockMutex(hotkeyMutex)
        
        ; create hook to handle keyboard hotkeys
        If HotKeyHook = 0
            HotKeyHook = SetWindowsHookEx_(#WH_GETMESSAGE, @HotKeyHook(), 0, GetCurrentThreadId_())
        EndIf
        
        retval = #True
        
        ; clear/free hotkey table for this window
    ElseIf key$ = "" And (IsWindow_(WindowID) Or WindowID = 0)
        
        WindowID = GetAncestor_(WindowID, #GA_ROOT)
        LockMutex(hotkeyMutex)
        DeleteMapElement(hotkeyTable(), Str(WindowID))
        UnlockMutex(hotkeyMutex)
        
        retval = #True
        
    EndIf
    
    ProcedureReturn retval
    
EndProcedure

Procedure autoHotKey(WindowID.i, ID.w, Text.s)
    
    If menuExAutoHotKeyDisable = #False
        p = FindString(text, #ShortcutCode, 1)
        If p <> 0
            Repeat
                If Mid(text, n, 1) = #ShortcutCode And Mid(text, n+1, 1) = #ShortcutCode
                    text = Mid(text, 1, n)+Mid(text, n+2, Len(text))
                ElseIf Mid(text, n, 1) = #ShortcutCode And Mid(text, n+1, 1) <> #ShortcutCode
                    foundShortcut = #True
                    p = n
                    Break
                EndIf
                n = n + 1
            Until n >= Len(text)
        EndIf
        
        If foundShortcut = #True
            txt.s = Mid(text, 1, p-1)
            shortcut.s = Mid(text, p+1)
            ProcedureReturn HotKey(WindowID, ID, shortcut)
        EndIf
    EndIf
    
    ProcedureReturn 0
    
EndProcedure

Procedure Hbitmap2PBImage(hBitmap.i, Depth)
    
    GetObject_(hBitmap, SizeOf(BITMAP), @BM.BITMAP)
    If BM\bmBits
        
        If Depth = 0
            Depth = BM\bmBitsPixel
        EndIf

        id = CreateImage(#PB_Any, BM\bmWidth, BM\bmHeight, Depth)
        If id <> #Null
            ddc = StartDrawing(ImageOutput(id))
            sdc = CreateCompatibleDC_(ddc)
            old = SelectObject_(sdc, hBitmap)
            BitBlt_(ddc, 0, 0, BM\bmWidth, BM\bmHeight, sdc, 0, 0, #SRCCOPY)
            SelectObject_(sdc, old)
            DeleteDC_(sdc)
            StopDrawing()
        EndIf
        
    EndIf
    ProcedureReturn id
EndProcedure


; transCol is colour to mask, returns handle to region (free with deleteobject)
Procedure CreateRGNMask(image, transCol)
    Define bmpInfo.BITMAPINFOHEADER
    
    wide = ImageWidth(image)                     ; Get width and height
    high = ImageHeight(image)
    *mem = AllocateMemory(wide*high*4)              ; Allocate some space
    
    hdc = StartDrawing(ImageOutput(image))       ; Need a DC, get via StartDrawing
    
    hMask  = CreateRectRgn_(0,0,0,0)               ; Create an empty mask
    
    bmpInfo\biSize = SizeOf(BITMAPINFOHEADER)      ; Set up the bmp header info
    bmpInfo\biWidth  = wide 
    bmpInfo\biHeight = high 
    bmpInfo\biPlanes = 1 
    bmpInfo\biBitCount = 32 
    bmpInfo\biCompression = #BI_RGB
    ; Make a DIB from the bitmap
    GetDIBits_(hdc,ImageID(image), 1, high-1, *mem, bmpInfo, #DIB_RGB_COLORS)
    
    *ptr=*mem                                        ; Scan through the image ignoring the
    For vert = 0 To high-1                           ;   transCol pixels and create tiny
        For horz = 0 To wide-1                       ;   regions then ORing these with the
            If PeekL(*ptr) <> transCol               ;   initial mask region
                tmpRgn = CreateRectRgn_(horz, high-vert-1, horz+1, high-vert-2)
                CombineRgn_(hMask, hMask, tmpRgn, #RGN_OR)
                DeleteObject_(tmpRgn)                    ; Get rid of the temporary region
            EndIf 
            *ptr+4                                      ; Next pixel, please.
        Next
    Next 
    StopDrawing()                                  ; Done.
    
    FreeMemory(*mem)
    
    ;skin\maskSize = GetRegionData_(hMask,0,0)
    ;skn=AllocateMemory(skin\maskSize)              ; Copy the mask information
    ;GetRegionData_(hMask, skin\maskSize, skn)
    
    ProcedureReturn hMask
    
EndProcedure

Procedure convertImageFormat(Image.i, Mode.b) ; Mode = #True: PreMultiplyAlpha, Mode = -1: UnPreMultiplyAlpha
    
    If GetIconInfo_(Image, @iInfo.ICONINFO) <> 0
        Image = iInfo\hbmColor
        Mask = iInfo\hbmMask
    EndIf
    
    If Mask <> 0
        
        GetObject_(Mask, SizeOf(BITMAP), @BM.BITMAP)
        width = BM\bmWidth
        height = BM\bmHeight
        
        If width > 0 And height > 0
            
            maskbitcount = 32
            maskextrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
            sizeheaders = SizeOf(BITMAPFILEHEADER) + SizeOf(BITMAPINFOHEADER)
            sizeimage = (width * maskbitcount / 8 + maskextrabytesperrow) * height
            *mask = AllocateMemory(sizeheaders + sizeimage)
            
            *bitmapfile.BITMAPFILEHEADER = *mask
            *bitmapfile\bfType = Asc("B") + Asc("M") << 8
            *bitmapfile\bfSize = sizeheaders +sizeimage
            *bitmapfile\bfOffBits = sizeheaders
            *bitmapinfo.BITMAPINFOHEADER = *mask + SizeOf(BITMAPFILEHEADER)
            *bitmapinfo\biSize = SizeOf(BITMAPINFOHEADER)
            *bitmapinfo\biWidth = width
            *bitmapinfo\biHeight = height
            *bitmapinfo\biPlanes = 1
            *bitmapinfo\biBitCount = maskbitcount
            *bitmapinfo\biCompression = 0
            *bitmapinfo\biSizeImage = sizeimage
            
            *maskdata = *mask + sizeheaders
            
            *maskdatapos = *maskdata
            
            newImage = CreateImage(#PB_Any, width, height, 32)
            
            hdc = StartDrawing(ImageOutput(newImage))
            GetDIBits_(hdc, Mask, 0, height, *mask+sizeheaders, *bitmapinfo, #DIB_RGB_COLORS)
            StopDrawing()
            FreeImage(newImage)
        EndIf
        
    EndIf
    
    GetObject_(Image, SizeOf(BITMAP), @BM.BITMAP)
    width = BM\bmWidth
    height = BM\bmHeight
    
    If width > 0 And height > 0
        
        bitcount = BM\bmBitsPixel
        extrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
        sizeheaders = SizeOf(BITMAPFILEHEADER) + SizeOf(BITMAPINFOHEADER)
        sizeimage = (width * bitcount / 8 + extrabytesperrow) * height
        *bitmap = AllocateMemory(sizeheaders + sizeimage)
        
        *bitmapfile.BITMAPFILEHEADER = *bitmap
        *bitmapfile\bfType = Asc("B") + Asc("M") << 8
        *bitmapfile\bfSize = sizeheaders +sizeimage
        *bitmapfile\bfOffBits = sizeheaders
        *bitmapinfo.BITMAPINFOHEADER = *bitmap + SizeOf(BITMAPFILEHEADER)
        *bitmapinfo\biSize = SizeOf(BITMAPINFOHEADER)
        *bitmapinfo\biWidth = width
        *bitmapinfo\biHeight = height
        *bitmapinfo\biPlanes = 1
        *bitmapinfo\biBitCount = bitcount
        *bitmapinfo\biCompression = 0
        *bitmapinfo\biSizeImage = sizeimage
        
        *bitmapdata = *bitmap + sizeheaders
        
        *bitmapdatapos = *bitmapdata
        
        newImage = CreateImage(#PB_Any, width, height, 32)
        
        hdc = StartDrawing(ImageOutput(newImage))
        GetDIBits_(hdc, image, 0, height, *bitmap+sizeheaders, *bitmapinfo, #DIB_RGB_COLORS)
        DrawingMode(#PB_2DDrawing_AllChannels)
        
        For y = 0 To height - 1
            For x = 0 To width - 1
                
                bbyte.a = PeekB(*bitmapdatapos) ; Blue
                gbyte.a = PeekB(*bitmapdatapos + 1) ; Green
                rbyte.a = PeekB(*bitmapdatapos + 2) ; Red
                r = rbyte : g = gbyte : b = bbyte
                a.a = PeekB(*bitmapdatapos + 3)
                
                ; if 24bit image and no mask then set alpha to full
                If BM\bmBitsPixel = 24 And *mask = 0
                    a = 255
                EndIf
                
                If a = 0 And *mask <> 0
                    a = PeekB(*maskdatapos)
                    If a = 0
                        a = 255
                    Else
                        a = 0
                    EndIf
                EndIf
                
                ; PreMultiplyAlpha
                If Mode = #True
                    r = r & $FF * a &$FF / $FF
                    g = g & $FF * a &$FF / $FF
                    b = b & $FF * a &$FF / $FF
                    ; UnPreMultiplyAlpha
                ElseIf mode = -1
                    If a > 0
                        r = (r * 255 + a / 2) / a
                        g = (g * 255 + a / 2) / a
                        b = (b * 255 + a / 2) / a
                    Else
                        r = 255
                        g = 255
                        b = 255
                    EndIf
                EndIf
                
                Plot(x,(height-1)-y, RGBA(r, g, b, a))
                
                *bitmapdatapos + bitcount / 8
                If *mask <> 0
                    *maskdatapos + maskbitcount / 8
                EndIf
            Next
            *bitmapdatapos + extrabytesperrow
            If *mask <> 0
                *maskdatapos + maskextrabytesperrow
            EndIf
        Next
        
        StopDrawing()
        
        FreeMemory(*bitmap)
        If *mask <> 0
            FreeMemory(*mask)
        EndIf
        
        sdc = StartDrawing(ImageOutput(newImage))
        ddc = CreateCompatibleDC_(sdc)
        retval = CreateCompatibleBitmap_(sdc, ImageWidth(newImage), ImageHeight(newImage))
        old = SelectObject_(ddc, retval)
        BitBlt_(ddc, 0, 0, ImageWidth(newImage), ImageHeight(newImage), sdc, 0, 0, #SRCCOPY)
        SelectObject_(ddc, old)
        DeleteDC_(ddc)
        StopDrawing()
        
        FreeImage(newImage)
        
    EndIf
    
    If iInfo\hbmColor <> 0
        DeleteObject_(iInfo\hbmColor)
    EndIf
    
    If iInfo\hbmMask <> 0
        DeleteObject_(iInfo\hbmMask)
    EndIf
    
    ProcedureReturn retval
    
EndProcedure

Procedure autoBorder(Image, *rc.RECT)
    
    tol = 20 ; border pixel detection tolerance %
    
    If GetIconInfo_(Image, @iInfo.ICONINFO) <> 0
        Image = iInfo\hbmColor
        Mask = iInfo\hbmMask
    EndIf
    
    GetObject_(Image, SizeOf(BITMAP), @BM.BITMAP)
    width = BM\bmWidth
    height = BM\bmHeight
    
    If width > 0 And height > 0
        
        bitcount = BM\bmBitsPixel
        extrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
        sizeheaders = SizeOf(BITMAPFILEHEADER) + SizeOf(BITMAPINFOHEADER)
        sizeimage = (width * bitcount / 8 + extrabytesperrow) * height
        *bitmap = AllocateMemory(sizeheaders + sizeimage)
        
        *bitmapfile.BITMAPFILEHEADER = *bitmap
        *bitmapfile\bfType = Asc("B") + Asc("M") << 8
        *bitmapfile\bfSize = sizeheaders +sizeimage
        *bitmapfile\bfOffBits = sizeheaders
        *bitmapinfo.BITMAPINFOHEADER = *bitmap + SizeOf(BITMAPFILEHEADER)
        *bitmapinfo\biSize = SizeOf(BITMAPINFOHEADER)
        *bitmapinfo\biWidth = width
        *bitmapinfo\biHeight = height
        *bitmapinfo\biPlanes = 1
        *bitmapinfo\biBitCount = bitcount
        *bitmapinfo\biCompression = 0
        *bitmapinfo\biSizeImage = sizeimage
        
        *bitmapdata = *bitmap + sizeheaders
        
        *bitmapdatapos = *bitmapdata
        
        newImage = CreateImage(#PB_Any, width, height, 32)
        
        hdc = StartDrawing(ImageOutput(newImage))
        GetDIBits_(hdc, image, 0, height, *bitmap+sizeheaders, *bitmapinfo, #DIB_RGB_COLORS)
        DrawingMode(#PB_2DDrawing_AllChannels)
        
        top.side
        top\x = width/2
        top\y = 0
        top\lc = 255
        left.side
        left\x = 0
        left\y = height/2
        left\lc = 255
        bottom.side
        bottom\x = width/2
        bottom\y = height-1
        bottom\lc = 255
        right.side
        right\x = width-1
        right\y = height/2
        right\lc = 255
        
        alpha.f = AlphaChannel
        a.a = 0
        Repeat
            
            *offset = *bitmapdatapos+((top\x*4)+(((height-1)-top\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            top\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            top\c = grey
            top\a = a
            
            *offset = *bitmapdatapos+((left\x*4)+(((height-1)-left\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            left\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            left\c = grey
            left\a = a
            ;Debug "left\c "+Str(left\c)+" left\a "+Str(left\a)
            
            *offset = *bitmapdatapos+((bottom\x*4)+(((height-1)-bottom\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            bottom\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            bottom\c = grey
            bottom\a = a
            
            *offset = *bitmapdatapos+((right\x*4)+(((height-1)-right\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            right\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            right\c = grey
            right\a = a
            
            ;Debug Str(left\c)+" "+Str(left\a)
            
            If top\c <= top\lc And top\a >= top\la
                top\lc = top\c
                top\la = top\a
                top\lx = top\x
                top\ly = top\y+1
            EndIf
            
            If left\c <= left\lc And left\a >= left\la
                left\lc = left\c
                left\la = left\a
                left\lx = left\x+1
                left\ly = left\y
                ;Debug "left\c "+Str(left\c)+" left\a "+Str(left\a)
            EndIf
            
            If bottom\c <= bottom\lc And bottom\a >= bottom\la
                bottom\lc = bottom\c
                bottom\la = bottom\a
                bottom\lx = bottom\x
                bottom\ly = bottom\y-1
            EndIf
            
            If right\c <= right\lc And right\a >= right\la
                right\lc = right\c
                right\la = right\a
                right\lx = right\x-1
                right\ly = right\y
            EndIf
            
            If top\y < height/2
                top\y = top\y + 1
                stop = #False
            Else
                stop = #True
            EndIf
            If left\x < width/2
                left\x = left\x + 1
                stop = #False
            Else
                stop = #True
            EndIf
            If bottom\y > height/2
                bottom\y = bottom\y - 1
                stop = #False
            Else
                stop = #True
            EndIf
            If right\x > width/2
                right\x = right\x - 1
                stop = #False
            Else
                stop = #True
            EndIf
            
            n = n + 1
        Until stop = #True
        
        
        rc.RECT
        rc\left = left\lx
        rc\top = top\ly
        rc\right = right\lx
        rc\bottom = bottom\ly
        ;Debug "border mask rect:  L: "+Str(rc\left)+"  T: "+Str(rc\top)+"  R: "+Str(rc\right)+"  B: "+Str(rc\bottom)
        ;t = (255/100)*10
        ;Debug "tol: "+Str(t)
        
        a.a = 255
        
        *offset = *bitmapdatapos+(((width/2)*4)+(((height-1)-(height/2))*width*4))
        bbyte.a = PeekB(*offset) ; Blue
        gbyte.a = PeekB(*offset + 1) ; Green
        rbyte.a = PeekB(*offset + 2) ; Red
        If bitcount = 32             ; Alpha channel
            a.a = PeekB(*offset + 3)
        EndIf
        r = rbyte : g = gbyte : b = bbyte
        grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
        c = grey
        ca = a
        
        top\x = top\lx
        top\y = top\ly
        left\x = left\lx
        left\y = left\ly
        bottom\x = bottom\lx
        bottom\y = bottom\ly
        right\x = right\lx
        right\y = right\ly
        
        stop = 0
        Repeat
            
            *offset = *bitmapdatapos+((top\x*4)+(((height-1)-top\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            top\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            top\c = grey
            top\a = a
            
            *offset = *bitmapdatapos+((left\x*4)+(((height-1)-left\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            left\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            left\c = grey
            left\a = a
            
            *offset = *bitmapdatapos+((bottom\x*4)+(((height-1)-bottom\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            bottom\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            bottom\c = grey
            bottom\a = a
            
            *offset = *bitmapdatapos+((right\x*4)+(((height-1)-right\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            right\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            right\c = grey
            right\a = a
            
            ;Debug Str(left\c)+" "+Str(left\a)+"    x:"+Str(left\x)+"  y:"+Str(left\y)
            
            If ((c >= top\c-t And c <= top\c+t And ca = 255) Or ca = top\a) And topfound = #False
                top\lx = top\x
                top\ly = top\y
                topfound = #True
            EndIf
            
            If ((c >= left\c-t And c <= left\c+t And ca = 255) Or ca = left\a) And leftfound = #False
                left\lx = left\x
                left\ly = left\y
                leftfound = #True
            EndIf
            
            If ((c >= bottom\c-t And c <= bottom\c+t And ca = 255) Or ca = bottom\a) And bottomfound = #False
                bottom\lx = bottom\x
                bottom\ly = bottom\y
                bottomfound = #True
            EndIf
            
            If ((c >= right\c-t And c <= right\c+t And ca = 255) Or ca = right\a) And rightfound = #False
                right\lx = right\x
                right\ly = right\y
                rightfound = #True
            EndIf
            
            
            If top\y < height/2
                top\y = top\y + 1
                stop = #False
            Else
                stop = #True
            EndIf
            If left\x < width/2
                left\x = left\x + 1
                stop = #False
            Else
                stop = #True
            EndIf
            If bottom\y > height/2
                bottom\y = bottom\y - 1
                stop = #False
            Else
                stop = #True
            EndIf
            If right\x > width/2
                right\x = right\x - 1
                stop = #False
            Else
                stop = #True
            EndIf
            
        Until stop = #True
        
        *rc\left = left\lx+1
        *rc\top = top\ly+1
        *rc\right = right\lx-1
        *rc\bottom = bottom\ly-1
        Debug "auto border rect:  L: "+Str(*rc\left)+"  T: "+Str(*rc\top)+"  R: "+Str(*rc\right)+"  B: "+Str(*rc\bottom)
        
        StopDrawing()
        
        FreeMemory(*bitmap)
        FreeImage(newImage)
        
        retval = #True
        
    EndIf
    
    If iInfo\hbmColor <> 0
        DeleteObject_(iInfo\hbmColor)
    EndIf
    
    If iInfo\hbmMask <> 0
        DeleteObject_(iInfo\hbmMask)
    EndIf
    
    
    ProcedureReturn retval
    
EndProcedure

Procedure autoMask(Image)
    
    tol = 40 ; border pixel detection tolerance %
    
    
    If GetIconInfo_(Image, @iInfo.ICONINFO) <> 0
        Image = iInfo\hbmColor
        Mask = iInfo\hbmMask
    EndIf
    
    GetObject_(Image, SizeOf(BITMAP), @BM.BITMAP)
    width = BM\bmWidth
    height = BM\bmHeight
    
    If width > 0 And height > 0
        
        bitcount = BM\bmBitsPixel
        extrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
        sizeheaders = SizeOf(BITMAPFILEHEADER) + SizeOf(BITMAPINFOHEADER)
        sizeimage = (width * bitcount / 8 + extrabytesperrow) * height
        *bitmap = AllocateMemory(sizeheaders + sizeimage)
        
        *bitmapfile.BITMAPFILEHEADER = *bitmap
        *bitmapfile\bfType = Asc("B") + Asc("M") << 8
        *bitmapfile\bfSize = sizeheaders +sizeimage
        *bitmapfile\bfOffBits = sizeheaders
        *bitmapinfo.BITMAPINFOHEADER = *bitmap + SizeOf(BITMAPFILEHEADER)
        *bitmapinfo\biSize = SizeOf(BITMAPINFOHEADER)
        *bitmapinfo\biWidth = width
        *bitmapinfo\biHeight = height
        *bitmapinfo\biPlanes = 1
        *bitmapinfo\biBitCount = bitcount
        *bitmapinfo\biCompression = 0
        *bitmapinfo\biSizeImage = sizeimage
        
        *bitmapdata = *bitmap + sizeheaders
        
        *bitmapdatapos = *bitmapdata
        
        newImage = CreateImage(#PB_Any, width, height, 32)
        
        hdc = StartDrawing(ImageOutput(newImage))
        GetDIBits_(hdc, image, 0, height, *bitmap+sizeheaders, *bitmapinfo, #DIB_RGB_COLORS)
        DrawingMode(#PB_2DDrawing_AllChannels)
        
        top.side
        top\x = width/2
        top\y = 0
        top\lc = 255
        left.side
        left\x = 0
        left\y = height/2
        left\lc = 255
        bottom.side
        bottom\x = width/2
        bottom\y = height-1
        bottom\lc = 255
        right.side
        right\x = width-1
        right\y = height/2
        right\lc = 255
        
        alpha.f = AlphaChannel
        a.a = 0
        Repeat
            
            *offset = *bitmapdatapos+((top\x*4)+(((height-1)-top\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            top\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            top\c = grey
            top\a = a
            
            *offset = *bitmapdatapos+((left\x*4)+(((height-1)-left\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            left\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            left\c = grey
            left\a = a
            
            *offset = *bitmapdatapos+((bottom\x*4)+(((height-1)-bottom\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            bottom\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            bottom\c = grey
            bottom\a = a
            
            *offset = *bitmapdatapos+((right\x*4)+(((height-1)-right\y)*width*4))
            bbyte.a = PeekB(*offset) ; Blue
            gbyte.a = PeekB(*offset + 1) ; Green
            rbyte.a = PeekB(*offset + 2) ; Red
            If bitcount = 32             ; Alpha channel
                a.a = PeekB(*offset + 3)
            EndIf
            right\c = RGB(rbyte, gbyte, bbyte)
            r = rbyte : g = gbyte : b = bbyte
            grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
            right\c = grey
            right\a = a
            
            ;Debug Str(left\c)+" "+Str(left\a)
            
            If top\c <= top\lc Or top\a > top\la
                top\lc = top\c
                top\la = top\a
                top\lx = top\x
                top\ly = top\y+1
            EndIf
            
            If left\c <= left\lc Or left\a > left\la
                left\lc = left\c
                left\la = left\a
                left\lx = left\x+1
                left\ly = left\y
                ;Debug Str(left\c)+" "+Str(left\a)
            EndIf
            
            If bottom\c <= bottom\lc Or bottom\a > bottom\la
                bottom\lc = bottom\c
                bottom\la = bottom\a
                bottom\lx = bottom\x
                bottom\ly = bottom\y-1
            EndIf
            
            If right\c <= right\lc Or right\a > right\la
                right\lc = right\c
                right\la = right\a
                right\lx = right\x-1
                right\ly = right\y
            EndIf
            
            If top\y < height/2
                top\y = top\y + 1
                stop = #False
            Else
                stop = #True
            EndIf
            If left\x < width/2
                left\x = left\x + 1
                stop = #False
            Else
                stop = #True
            EndIf
            If bottom\y > height/2
                bottom\y = bottom\y - 1
                stop = #False
            Else
                stop = #True
            EndIf
            If right\x > width/2
                right\x = right\x - 1
                stop = #False
            Else
                stop = #True
            EndIf
            
            n = n + 1
        Until stop = #True
        
        rc.RECT
        rc\left = left\lx
        rc\top = top\ly
        rc\right = right\lx
        rc\bottom = bottom\ly
        
        Debug "border mask rect:  L: "+Str(rc\left)+"  T: "+Str(rc\top)+"  R: "+Str(rc\right)+"  B: "+Str(rc\bottom)
        t = (255/100)*tol
        Debug "tol: "+Str(t)
        
        For yi = 0 To height - 1
            For x = 0 To width - 1
                bbyte.a = PeekB(*bitmapdatapos) ; Blue
                gbyte.a = PeekB(*bitmapdatapos + 1) ; Green
                rbyte.a = PeekB(*bitmapdatapos + 2) ; Red
                r = rbyte : g = gbyte : b = bbyte
                grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
                c = grey
                If bitcount = 32 ; Alpha channel
                    a.a = PeekB(*bitmapdatapos + 3)
                EndIf
                y = (height-1)-yi
                
                
                ; if pixel is inside detected mask border
                If x >= left\lx And x <= right\lx And y >= top\ly And y <= bottom\ly
                    
                    found = #False
                    If (c >= top\lc-t And c <= top\lc+t) And (a >= top\la-t And a <= top\la+t)
                        found = #True
                    EndIf
                    If (c >= left\lc-t And c <= left\lc+t) And (a >= left\la-t And a <= left\la+t)
                        found = #True
                    EndIf
                    If (c >= bottom\lc-t And c <= bottom\lc+t) And (a >= bottom\la-t And a <= bottom\la+t)
                        found = #True
                    EndIf
                    If (c >= right\lc-t And c <= right\lc+t) And (a >= right\la-t And a <= right\la+t)
                        found = #True
                    EndIf
                    
                    ;Debug "x: "+Str(x)+" Y: "+Str(yi)
                    If found = #True
                        ;Debug "found x: "+Str(x)+" Y: "+Str(yi)
                        Plot(x, y, RGBA(255,255,255,255))
                    Else
                        Plot(x, y, RGBA(0,0,0,0))
                    EndIf
                    
                Else
                    Plot(x, y, RGBA(255,255,255,255))
                EndIf
                
                
                *bitmapdatapos + bitcount / 8
                If *mask <> 0
                    *maskdatapos + maskbitcount / 8
                EndIf
            Next
            *bitmapdatapos + extrabytesperrow
            If *mask <> 0
                *maskdatapos + maskextrabytesperrow
            EndIf
        Next
        
        FillArea(left\lx, top\ly, -1, RGBA(255,255,255,255))
        FillArea(right\lx, top\ly, -1, RGBA(255,255,255,255))
        FillArea(left\lx, bottom\ly, -1, RGBA(255,255,255,255))
        FillArea(right\lx, bottom\ly, -1, RGBA(255,255,255,255))
        
        StopDrawing()
        
        FreeMemory(*bitmap)
        
        ;     If flags & #ImgBlend_ReturnIcon
        ;       
        ;       tlist = ImageList_Create_(width, height, #ILC_MASK | #ILC_COLOR32, 0, 0)
        ;       ImageList_Add_(tlist, ImageID(newImage), 0)
        ;       hIcon = ImageList_GetIcon_(tlist, 0, 0)
        ;       ImageList_Destroy_(tlist)
        ;       FreeImage(newImage)
        ;       
        ;       retval = hIcon
        ;     Else
        ;       retval = ImageID(newImage)
        ;     EndIf
        
    EndIf
    
    If iInfo\hbmColor <> 0
        DeleteObject_(iInfo\hbmColor)
    EndIf
    
    If iInfo\hbmMask <> 0
        DeleteObject_(iInfo\hbmMask)
    EndIf
    
    
    ProcedureReturn newImage
    
EndProcedure

Procedure createBorder()
    retval = AddElement(border())
    If retval <> 0
        borderHandleCount(Str(retval)) = 1
    EndIf
    ProcedureReturn retval
EndProcedure

Procedure flushBorder(*border)
    
    If *border <> 0
        ChangeCurrentElement(border(), *Border)
    Else
        ProcedureReturn 0
    EndIf
    
    If border()\srcHandle <> 0
        handleCount = borderHandleCount(Str(border()\srcHandle))
        *srcHandle = border()\srcHandle
    Else
        handleCount = borderHandleCount(Str(*border))
        *srcHandle = *border
    EndIf
    
    If handleCount > 1
        borderHandleCount(Str(*srcHandle)) = borderHandleCount(Str(*srcHandle)) - 1
    Else
        ; free resources when handle count gets to 1 (this one)
        
        ForEach border()\image()
            ImageList_Destroy_(border()\image()\top\dat)
            ImageList_Destroy_(border()\image()\left\dat)
            ImageList_Destroy_(border()\image()\right\dat)
            ImageList_Destroy_(border()\image()\bottom\dat)
            ImageList_Destroy_(border()\image()\topLeft\dat)
            ImageList_Destroy_(border()\image()\topRight\dat)
            ImageList_Destroy_(border()\image()\bottomLeft\dat)
            ImageList_Destroy_(border()\image()\bottomRight\dat)
            n = n + 1
        Next
        
        ForEach border()\mask()
            DeleteObject_(border()\mask()\topleft\dat)
            DeleteObject_(border()\mask()\top\dat)
            DeleteObject_(border()\mask()\topright\dat)
            DeleteObject_(border()\mask()\left\dat)
            DeleteObject_(border()\mask()\right\dat)
            DeleteObject_(border()\mask()\bottomleft\dat)
            DeleteObject_(border()\mask()\bottom\dat)
            DeleteObject_(border()\mask()\bottomright\dat)
            n = n + 1
        Next
        
        ClearMap(border()\image())
        ClearMap(border()\mask())
        
        DeleteObject_(border()\mask()\maskrgn)
        
        DeleteMapElement(borderHandleCount(), Str(*srcHandle))
        
    EndIf
    
    ProcedureReturn n
    
EndProcedure

Procedure freeBorder(*border)
    
    If *border <> 0
        ChangeCurrentElement(border(), *Border)
    Else
        ProcedureReturn 0
    EndIf
    
    If border()\srcHandle <> 0
        handleCount = borderHandleCount(Str(border()\srcHandle))
        *srcHandle = border()\srcHandle
    Else
        handleCount = borderHandleCount(Str(*border))
        *srcHandle = *border
    EndIf
    
    If handleCount > 1
        borderHandleCount(Str(*srcHandle)) = borderHandleCount(Str(*srcHandle)) - 1
    Else
        ; free resources when handle count gets to 1 (this one)
        
        ForEach border()\image()
            ImageList_Destroy_(border()\image()\top\dat)
            ImageList_Destroy_(border()\image()\left\dat)
            ImageList_Destroy_(border()\image()\right\dat)
            ImageList_Destroy_(border()\image()\bottom\dat)
            ImageList_Destroy_(border()\image()\topLeft\dat)
            ImageList_Destroy_(border()\image()\topRight\dat)
            ImageList_Destroy_(border()\image()\bottomLeft\dat)
            ImageList_Destroy_(border()\image()\bottomRight\dat)
        Next
        
        ForEach border()\mask()
            DeleteObject_(border()\mask()\topleft\dat)
            DeleteObject_(border()\mask()\top\dat)
            DeleteObject_(border()\mask()\topright\dat)
            DeleteObject_(border()\mask()\left\dat)
            DeleteObject_(border()\mask()\right\dat)
            DeleteObject_(border()\mask()\bottomleft\dat)
            DeleteObject_(border()\mask()\bottom\dat)
            DeleteObject_(border()\mask()\bottomright\dat)
            DeleteObject_(border()\mask()\maskrgn)
        Next
        
        DeleteMapElement(borderHandleCount(), Str(*srcHandle))
        
    EndIf
    
    DeleteElement(border())
    
EndProcedure

Procedure copyBorder(*src, *dst)
    If *src <> 0 And *dst <> 0
        flushBorder(*dst)
        CopyStructure(*src, *dst, Borders)
        ChangeCurrentElement(border(), *src)
        If border()\srcHandle = 0
            ChangeCurrentElement(border(), *dst)
            border()\srcHandle = *src
            borderHandleCount(Str(*src)) = borderHandleCount(Str(*src)) + 1
        Else
            *srcHandle = border()\srcHandle
            ChangeCurrentElement(border(), *dst)
            border()\srcHandle = *srcHandle
            borderHandleCount(Str(*srcHandle)) = borderHandleCount(Str(*srcHandle)) + 1
        EndIf
    EndIf
    ProcedureReturn 0
EndProcedure


Procedure setBorder(*Border, BorderImage.i, BorderMask.i, *BorderRect.RECT, *BorderAutoStretch.RECT)
    
    If *border <> 0
        ChangeCurrentElement(border(), *Border)
    Else
        ProcedureReturn 0
    EndIf
    
    If *BorderAutoStretch <> #Null
        
        CopyStructure(*BorderAutoStretch, border()\autoStretchSides, RECT)
        
    EndIf
    
    If BorderImage <> 0
        
        GetObject_(BorderImage, SizeOf(BITMAP), @BM.BITMAP)
        If bm\bmWidth <= 0 Or bm\bmHeight <= 0 Or bm\bmBits = 0
            ProcedureReturn 0
        EndIf
        width = bm\bmWidth
        height = bm\bmHeight
        bitcount = BM\bmBitsPixel
        extrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
        sizeimage = (width * bitcount / 8 + extrabytesperrow) * height
        
        ; make sure border rect if exists, fits inside border image dimensions
        If *BorderRect <> 0 And (*BorderRect\left < 0 Or *BorderRect\right < 0 Or *BorderRect\right > width Or *BorderRect\top < 0 Or *BorderRect\bottom < 0 Or *BorderRect\bottom > height Or *BorderRect\right < *BorderRect\left Or *BorderRect\bottom < *BorderRect\top)
            ProcedureReturn 0
        EndIf
        
        If FindMapElement(border()\image(), Str(BorderImage)) <> 0
            
            ; check if rect has changed
            If *BorderRect <> 0 And (*BorderRect\left <> border()\image()\rc\left Or *BorderRect\top <> border()\image()\rc\top Or *BorderRect\right <> border()\image()\rc\right Or *BorderRect\bottom <> border()\image()\rc\bottom)
                createImage = #True
            Else
                ; check if image data changed
                If CRC32Fingerprint(bm\bmBits, sizeimage) <> border()\image()\crc32
                    createImage = #True
                Else
                    border()\thisimage = Str(BorderImage)
                EndIf
            EndIf
            
        Else
            createImage = #True
        EndIf
    EndIf
    
    If createImage = #True
        Debug "createimage"
        BImage = Hbitmap2PBImage(BorderImage, 0)
        If BImage <> 0
            
            ; free revious image parts if found
            If FindMapElement(border()\image(), Str(BorderImage)) <> 0
                ImageList_Destroy_(border()\image()\top\dat)
                ImageList_Destroy_(border()\image()\left\dat)
                ImageList_Destroy_(border()\image()\right\dat)
                ImageList_Destroy_(border()\image()\bottom\dat)
                ImageList_Destroy_(border()\image()\topLeft\dat)
                ImageList_Destroy_(border()\image()\topRight\dat)
                ImageList_Destroy_(border()\image()\bottomLeft\dat)
                ImageList_Destroy_(border()\image()\bottomRight\dat)
            EndIf
            
            If *BorderRect = 0
                BorderRc.RECT
                *BorderRect = BorderRc
                autoBorder(BorderImage, *BorderRect)
            EndIf
            
            ; error check incase of negative
            If *BorderRect\right-*BorderRect\left < 0
                *BorderRect\left = 1
                *BorderRect\right = 2
            EndIf
            If *BorderRect\bottom-*BorderRect\top < 0
                *BorderRect\top = 1
                *BorderRect\bottom = 2
            EndIf
            
            BorderImage$ = Str(BorderImage)
            
            CopyStructure(*BorderRect, border()\image(BorderImage$)\rc, RECT)
            
            border()\thisimage = BorderImage$
            border()\image(BorderImage$)\crc32 = CRC32Fingerprint(bm\bmBits, sizeimage)
            
            topleft = GrabImage(BImage, #PB_Any, 0, 0, *BorderRect\left, *BorderRect\top)
            top = GrabImage(BImage, #PB_Any, *BorderRect\left, 0, *BorderRect\right-*BorderRect\left, *BorderRect\top)
            topright = GrabImage(BImage, #PB_Any, *BorderRect\right, 0, width-*BorderRect\right, *BorderRect\top)
            left = GrabImage(BImage, #PB_Any, 0, *BorderRect\top, *BorderRect\left, *BorderRect\bottom-*BorderRect\top)
            right = GrabImage(BImage, #PB_Any, *BorderRect\right, *BorderRect\top, width-*BorderRect\right, *BorderRect\bottom-*BorderRect\top)
            bottomleft = GrabImage(BImage, #PB_Any, 0, *BorderRect\bottom, *BorderRect\left, height-*BorderRect\bottom)
            bottom = GrabImage(BImage, #PB_Any, *BorderRect\left, *BorderRect\bottom, *BorderRect\right-*BorderRect\left, height-*BorderRect\bottom)
            bottomright = GrabImage(BImage, #PB_Any, *BorderRect\right, *BorderRect\bottom, width-*BorderRect\right, height-*BorderRect\bottom)
            
            border()\image()\topleft\width = ImageWidth(topleft)
            border()\image()\topleft\height = ImageHeight(topleft)
            border()\image()\top\width = ImageWidth(top)
            border()\image()\top\height = ImageHeight(top)
            border()\image()\topright\width = ImageWidth(topright)
            border()\image()\topright\height = ImageHeight(topright)
            border()\image()\left\width = ImageWidth(left)
            border()\image()\left\height = ImageHeight(left)
            border()\image()\right\width = ImageWidth(right)
            border()\image()\right\height = ImageHeight(right)
            border()\image()\bottomleft\width = ImageWidth(bottomleft)
            border()\image()\bottomleft\height = ImageHeight(bottomleft)
            border()\image()\bottom\width = ImageWidth(bottom)
            border()\image()\bottom\height = ImageHeight(bottom)
            border()\image()\bottomright\width = ImageWidth(bottomright)
            border()\image()\bottomright\height = ImageHeight(bottomright)
            
            border()\image()\topleft\dat = ImageList_Create_(border()\image()\topleft\width, border()\image()\topleft\height, #ILC_MASK | #ILC_COLOR32, 0, 0)
            ImageList_Add_(border()\image()\topleft\dat, ImageID(topleft), 0)
            border()\image()\top\dat = ImageList_Create_(border()\image()\top\width, border()\image()\top\height, #ILC_MASK | #ILC_COLOR32, 0, 0)
            ImageList_Add_(border()\image()\top\dat, ImageID(top), 0)
            border()\image()\topright\dat = ImageList_Create_(border()\image()\topright\width, border()\image()\topright\height, #ILC_MASK | #ILC_COLOR32, 0, 0)
            ImageList_Add_(border()\image()\topright\dat, ImageID(topright), 0)
            border()\image()\left\dat = ImageList_Create_(border()\image()\left\width, border()\image()\left\height, #ILC_MASK | #ILC_COLOR32, 0, 0)
            ImageList_Add_(border()\image()\left\dat, ImageID(left), 0)
            border()\image()\right\dat = ImageList_Create_(border()\image()\right\width, border()\image()\right\height, #ILC_MASK | #ILC_COLOR32, 0, 0)
            ImageList_Add_(border()\image()\right\dat, ImageID(right), 0)
            border()\image()\bottomleft\dat = ImageList_Create_(border()\image()\bottomleft\width, border()\image()\bottomleft\height, #ILC_MASK | #ILC_COLOR32, 0, 0)
            ImageList_Add_(border()\image()\bottomleft\dat, ImageID(bottomleft), 0)
            border()\image()\bottom\dat = ImageList_Create_(border()\image()\bottom\width, border()\image()\bottom\height, #ILC_MASK | #ILC_COLOR32, 0, 0)
            ImageList_Add_(border()\image()\bottom\dat, ImageID(bottom), 0)
            border()\image()\bottomright\dat = ImageList_Create_(border()\image()\bottomright\width, border()\image()\bottomright\height, #ILC_MASK | #ILC_COLOR32, 0, 0)
            ImageList_Add_(border()\image()\bottomright\dat, ImageID(bottomright), 0)
            
            ; create and replace premultiplied copies if auto stretch is on
            If border()\autoStretchSides\top <> #False
                If border()\image()\top\datPremultiplied <> #Null
                    DeleteObject_(border()\image()\top\datPremultiplied)
                EndIf
                border()\image()\top\datPremultiplied = convertImageFormat(ImageID(top), #True)
            EndIf
            If border()\autoStretchSides\left <> #False
                If border()\image()\left\datPremultiplied <> #Null
                    DeleteObject_(border()\image()\left\datPremultiplied)
                EndIf
                border()\image()\left\datPremultiplied = convertImageFormat(ImageID(left), #True)
            EndIf
            If border()\autoStretchSides\bottom <> #False
                If border()\image()\bottom\datPremultiplied <> #Null
                    DeleteObject_(border()\image()\bottom\datPremultiplied)
                EndIf
                border()\image()\bottom\datPremultiplied = convertImageFormat(ImageID(bottom), #True)
            EndIf
            If border()\autoStretchSides\right <> #False
                If border()\image()\right\datPremultiplied <> #Null
                    DeleteObject_(border()\image()\right\datPremultiplied)
                EndIf
                border()\image()\right\datPremultiplied = convertImageFormat(ImageID(right), #True)
            EndIf
            
            FreeImage(topleft)
            FreeImage(top)
            FreeImage(topright)
            FreeImage(left)
            FreeImage(right)
            FreeImage(bottomleft)
            FreeImage(bottom)
            FreeImage(bottomright)
            
            FreeImage(BImage)
            
            If BorderMask = 0 Or BorderMask = -2
                createMask = #True
            EndIf
            
            border()\thisimage = BorderImage$
            
        Else  
            ProcedureReturn 0
        EndIf  
        
    EndIf
    
    If BorderMask <> 0 And BorderMask <> -2 And BorderMask <> -1
        
        GetObject_(BorderMask, SizeOf(BITMAP), @BM.BITMAP)
        If bm\bmWidth <= 0 Or bm\bmHeight <= 0 Or bm\bmBits = 0
            ProcedureReturn 0
        EndIf
        width = bm\bmWidth
        height = bm\bmHeight
        bitcount = BM\bmBitsPixel
        extrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
        sizeimage = (width * bitcount / 8 + extrabytesperrow) * height
        
        ; make sure border rect if exists, fits inside border image dimensions
        If *BorderRect <> 0 And (*BorderRect\left < 0 Or *BorderRect\right < 0 Or *BorderRect\right > width Or *BorderRect\top < 0 Or *BorderRect\bottom < 0 Or *BorderRect\bottom > height Or *BorderRect\right < *BorderRect\left Or *BorderRect\bottom < *BorderRect\top)
            ProcedureReturn 0
        EndIf
        
        If FindMapElement(border()\mask(), Str(BorderMask)) <> 0
            
            ; check if rect has changed
            If *BorderRect <> 0 And (*BorderRect\left <> border()\mask()\rc\left Or *BorderRect\top <> border()\mask()\rc\top Or *BorderRect\right <> border()\mask()\rc\right Or *BorderRect\bottom <> border()\mask()\rc\bottom)
                createMask = #True
            Else
                ; check if image data changed
                If CRC32Fingerprint(bm\bmBits, sizeimage) <> border()\mask()\crc32
                    createMask = #True
                Else
                    border()\thismask = Str(BorderMask)
                EndIf
            EndIf
            
        Else
            createMask = #True
        EndIf
    EndIf
    
    If createMask = #True
        Debug "createmask"
        If BorderMask = 0
            maskImage = autoMask(BorderImage)
            BorderMask = ImageID(maskImage)
            BorderMask$ = Str(BorderImage)
        ElseIf BorderMask = -2
            maskImage = autoMask(BorderImage)
            BorderMask = ImageID(maskImage)
            BorderMask$ = Str(BorderImage)
            border()\thisimage = ""
        Else
            BorderMask$ = Str(BorderMask)
        EndIf
        
        BMask = Hbitmap2PBImage(BorderMask, 0)
        If BMask <> 0
            ;destroy previous region parts if any exist
            If FindMapElement(border()\mask(), BorderMask$) <> 0
                DeleteObject_(border()\mask()\topleft\dat)
                DeleteObject_(border()\mask()\top\dat)
                DeleteObject_(border()\mask()\topright\dat)
                DeleteObject_(border()\mask()\left\dat)
                DeleteObject_(border()\mask()\right\dat)
                DeleteObject_(border()\mask()\bottomleft\dat)
                DeleteObject_(border()\mask()\bottom\dat)
                DeleteObject_(border()\mask()\bottomright\dat)
            EndIf
            
            If *BorderRect = 0
                BorderRc.RECT
                *BorderRect = BorderRc
                autoBorder(BorderMask, *BorderRect)
            EndIf
            
            GetObject_(BorderMask, SizeOf(BITMAP), @BM.BITMAP)
            If bm\bmWidth <= 0 Or bm\bmHeight <= 0 Or bm\bmBits = 0
                ProcedureReturn 0
            EndIf
            width = bm\bmWidth
            height = bm\bmHeight
            bitcount = BM\bmBitsPixel
            extrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
            sizeimage = (width * bitcount / 8 + extrabytesperrow) * height
            
            ; make sure border rect if exists, fits inside border image dimensions
            If *BorderRect <> 0 And (*BorderRect\left < 0 Or *BorderRect\right < 0 Or *BorderRect\right > width Or *BorderRect\top < 0 Or *BorderRect\bottom < 0 Or *BorderRect\bottom > height Or *BorderRect\right < *BorderRect\left Or *BorderRect\bottom < *BorderRect\top)
                ProcedureReturn 0
            EndIf
            
            CopyStructure(*BorderRect, border()\mask(BorderMask$)\rc, RECT)
            
            border()\thismask = BorderMask$
            border()\mask(BorderMask$)\crc32 = CRC32Fingerprint(bm\bmBits, sizeimage)
            
            topleft = GrabImage(BMask, #PB_Any, 0, 0, *BorderRect\left, *BorderRect\top+1)
            top = GrabImage(BMask, #PB_Any, *BorderRect\left, 0, *BorderRect\right-*BorderRect\left, *BorderRect\top+1)
            topright = GrabImage(BMask, #PB_Any, *BorderRect\right, 0, width-*BorderRect\right, *BorderRect\top+1)
            left = GrabImage(BMask, #PB_Any, 0, *BorderRect\top, *BorderRect\left, *BorderRect\bottom-*BorderRect\top+1)
            right = GrabImage(BMask, #PB_Any, *BorderRect\right, *BorderRect\top, width-*BorderRect\right, *BorderRect\bottom-*BorderRect\top+1)
            bottomleft = GrabImage(BMask, #PB_Any, 0, *BorderRect\bottom, *BorderRect\left, height-*BorderRect\bottom+1)
            bottom = GrabImage(BMask, #PB_Any, *BorderRect\left, *BorderRect\bottom, *BorderRect\right-*BorderRect\left, height-*BorderRect\bottom+1)
            bottomright = GrabImage(BMask, #PB_Any, *BorderRect\right, *BorderRect\bottom, width-*BorderRect\right, height-*BorderRect\bottom+1)
            
            border()\mask()\topleft\width = ImageWidth(topleft)
            border()\mask()\topleft\height = ImageHeight(topleft)-1
            border()\mask()\top\width = ImageWidth(top)
            border()\mask()\top\height = ImageHeight(top)-1
            border()\mask()\topright\width = ImageWidth(topright)
            border()\mask()\topright\height = ImageHeight(topright)-1
            border()\mask()\left\width = ImageWidth(left)
            border()\mask()\left\height = ImageHeight(left)-1
            border()\mask()\right\width = ImageWidth(right)
            border()\mask()\right\height = ImageHeight(right)-1
            border()\mask()\bottomleft\width = ImageWidth(bottomleft)
            border()\mask()\bottomleft\height = ImageHeight(bottomleft)-1
            border()\mask()\bottom\width = ImageWidth(bottom)
            border()\mask()\bottom\height = ImageHeight(bottom)-1
            border()\mask()\bottomright\width = ImageWidth(bottomright)
            border()\mask()\bottomright\height = ImageHeight(bottomright)-1
            
            ; create region masks for border parts
            border()\mask()\topleft\dat = CreateRGNMask(topleft, 0)
            border()\mask()\top\dat = CreateRGNMask(top, 0)
            border()\mask()\topright\dat = CreateRGNMask(topright, 0)
            border()\mask()\left\dat = CreateRGNMask(left, 0)
            border()\mask()\right\dat = CreateRGNMask(right, 0)
            border()\mask()\bottomleft\dat = CreateRGNMask(bottomleft, 0)
            border()\mask()\bottom\dat = CreateRGNMask(bottom, 0)
            border()\mask()\bottomright\dat = CreateRGNMask(bottomright, 0)
            
            FreeImage(topleft)
            FreeImage(top)
            FreeImage(topright)
            FreeImage(left)
            FreeImage(right)
            FreeImage(bottomleft)
            FreeImage(bottom)
            FreeImage(bottomright)
            
            FreeImage(BMask)
            
            If maskImage <> 0
                FreeImage(maskImage)
            EndIf
            
            border()\thismask = BorderMask$
            
        Else
            ProcedureReturn 0
        EndIf
        
        
    EndIf
    
    If BorderImage = 0
        border()\thisimage = ""
    EndIf
    
    If BorderMask = 0
        border()\thismask = border()\thisimage
    ElseIf BorderMask = -2 And BorderImage <> 0
        border()\thismask = Str(BorderImage)
        border()\thisimage = ""
    ElseIf BorderMask = -1
        border()\thismask = ""
    EndIf
    
    
    ProcedureReturn #True
    
EndProcedure

Procedure drawBorder(hdc.i, *border.Borders, *rc.RECT)
    
    If *border = #Null
        ProcedureReturn #False
    EndIf
    
    *image.BorderImage = FindMapElement(*border\image(), *border\thisimage)
    
    If *image <> #Null
        
        width = *rc\right - *rc\left
        height = *rc\bottom - *rc\top
        
        ; draw border
        ImageList_Draw_(*image\topleft\dat, 0, hdc, *rc\left, *rc\top, #ILD_NORMAL)
        
        x = *image\topleft\width
        If border()\autoStretchSides\top = #True
            
            srcdc = CreateCompatibleDC_(0)
            SelectObject_(srcdc, *image\top\datPremultiplied)
            GdiAlphaBlend_(hdc, *rc\left+x, *rc\top, width-(x+*image\topright\width), *image\top\height, srcdc, 0, 0, *image\top\width, *image\top\height, $1000000 | 255<<16)
            DeleteDC_(srcdc)
            
        Else
            
            Repeat
                If x+*image\top\width > width-*image\topright\width
                    d = (width-*image\topright\width)-x
                    ImageList_DrawEx_(*image\top\dat, 0, hdc, *rc\left+x, *rc\top, d, *image\top\height, #CLR_NONE, #CLR_NONE, #ILD_NORMAL) 
                    Break
                Else
                    ImageList_Draw_(*image\top\dat, 0, hdc, *rc\left+x, *rc\top, #ILD_NORMAL) 
                EndIf
                x = x + *image\top\width
            Until x >= width-*image\topright\width
            
        EndIf
        
        ImageList_Draw_(*image\topright\dat, 0, hdc, *rc\left+width-*image\topright\width, *rc\top, #ILD_NORMAL) 
        
        y = *image\topleft\height
        If border()\autoStretchSides\left = #True
            
            srcdc = CreateCompatibleDC_(0)
            SelectObject_(srcdc, *image\left\datPremultiplied)
            GdiAlphaBlend_(hdc, *rc\left, *rc\top+y, *image\left\width, height-(y+*image\bottomleft\height), srcdc, 0, 0, *image\left\width, *image\left\height, $1000000 | 255<<16)
            DeleteDC_(srcdc)
            
        Else
            
            Repeat
                If y+*image\left\height > height-*image\bottomleft\height
                    d = (height-*image\bottomleft\height)-y
                    ImageList_DrawEx_(*image\left\dat, 0, hdc, *rc\left, *rc\top+y, *image\left\width, d, #CLR_NONE, #CLR_NONE, #ILD_NORMAL) 
                    Break
                Else
                    ImageList_Draw_(*image\left\dat, 0, hdc, *rc\left, *rc\top+y, #ILD_NORMAL)
                EndIf
                y = y + *image\left\height
            Until y >= height-*image\bottomleft\height
            
        EndIf
        
        y = *image\topright\Height
        If border()\autoStretchSides\right = #True
            
            srcdc = CreateCompatibleDC_(0)
            SelectObject_(srcdc, *image\right\datPremultiplied)
            GdiAlphaBlend_(hdc, *rc\left+width-*image\right\Width, *rc\top+y, *image\right\width, height-(y+*image\bottomright\height), srcdc, 0, 0, *image\right\width, *image\right\height, $1000000 | 255<<16)
            DeleteDC_(srcdc)
            
        Else
            
            Repeat
                If y+*image\right\height > height-*image\bottomright\height
                    d = (height-*image\bottomright\height)-y
                    ImageList_DrawEx_(*image\right\dat, 0, hdc, *rc\left+width-*image\right\width, *rc\top+y, *image\right\width, d, #CLR_NONE, #CLR_NONE, #ILD_NORMAL) 
                    Break
                Else
                    ImageList_Draw_(*image\right\dat, 0, hdc, *rc\left+width-*image\right\Width, *rc\top+y, #ILD_NORMAL)
                EndIf
                y = y + *image\right\height
            Until y >= height-*image\bottomright\height
            
        EndIf
        
        ImageList_Draw_(*image\bottomleft\dat, 0, hdc, *rc\left, *rc\top+height-*image\bottomleft\height, #ILD_NORMAL) 
        
        x = *image\bottomleft\width
        If border()\autoStretchSides\bottom = #True
            
            srcdc = CreateCompatibleDC_(0)
            SelectObject_(srcdc, *image\bottom\datPremultiplied)
            GdiAlphaBlend_(hdc, *rc\left+x, *rc\top+height-*image\bottom\height, width-(x+*image\bottomright\width), *image\bottom\height, srcdc, 0, 0, *image\bottom\width, *image\bottom\height, $1000000 | 255<<16)
            DeleteDC_(srcdc)
            
        Else
            
            Repeat
                If x+*image\bottom\width > width-*image\bottomright\width
                    d = (width-*image\bottomright\width)-x
                    ImageList_DrawEx_(*image\bottom\dat, 0, hdc, *rc\left+x, *rc\top+height-*image\bottom\height, d, *image\bottom\height, #CLR_NONE, #CLR_NONE, #ILD_NORMAL) 
                    Break
                Else
                    ImageList_Draw_(*image\bottom\dat, 0, hdc, *rc\left+x, *rc\top+height-*image\bottom\height, #ILD_NORMAL) 
                EndIf
                x = x + *image\bottom\width
            Until x >= width-*image\bottomright\width
            
        EndIf
        
        ImageList_Draw_(*image\bottomright\dat, 0, hdc, *rc\left+width-*image\bottomright\width, *rc\top+height-*image\bottomright\height, #ILD_NORMAL) 
        
        
        ProcedureReturn #True
        
    EndIf
    
    ProcedureReturn 0
    
EndProcedure

Procedure getBorderRgn(*border.Borders, *rc.RECT)
    
    If *border = #Null
        ProcedureReturn 0
    EndIf
    
    *mask.BorderMasks = FindMapElement(*border\mask(), *border\thismask)
    
    If *mask <> #Null
        
        width = (*rc\right-*rc\left)
        height = (*rc\bottom-*rc\top)
        
        ; make region border mask
        If *mask\maskrgn = 0 Or (*mask\maskwidth <> width Or *mask\maskheight <> height)
            If *mask\maskrgn <> 0
                DeleteObject_(*mask\maskrgn)
            EndIf
            *mask\maskrgn  = CreateRectRgn_(0,0,width,height)
            
            CombineRgn_(*mask\maskrgn, *mask\maskrgn, *mask\topleft\dat, #RGN_DIFF)
            x = *mask\topleft\width
            Repeat
                OffsetRgn_(*mask\top\dat, x, 0)
                CombineRgn_(*mask\maskrgn, *mask\maskrgn, *mask\top\dat, #RGN_DIFF)
                OffsetRgn_(*mask\top\dat, -x, 0)
                x = x + *mask\top\width
            Until x >= width-*mask\topright\width
            
            OffsetRgn_(*mask\topright\dat, width-*mask\topright\width, 0)
            CombineRgn_(*mask\maskrgn, *mask\maskrgn, *mask\topright\dat, #RGN_DIFF)
            OffsetRgn_(*mask\topright\dat, -(width-*mask\topright\width), 0)
            
            y = *mask\topleft\height
            Repeat
                OffsetRgn_(*mask\left\dat, 0, y)
                CombineRgn_(*mask\maskrgn, *mask\maskrgn, *mask\left\dat, #RGN_DIFF)
                OffsetRgn_(*mask\left\dat, 0, -y)
                y = y + *mask\left\height
            Until y >= height-*mask\bottomleft\height
            
            y = *mask\topright\height
            Repeat
                OffsetRgn_(*mask\right\dat, width-*mask\right\width, y)
                CombineRgn_(*mask\maskrgn, *mask\maskrgn, *mask\right\dat, #RGN_DIFF)
                OffsetRgn_(*mask\right\dat, -(width-*mask\right\width), -y)
                y = y + *mask\right\height
            Until y >= height-*mask\bottomright\height
            
            OffsetRgn_(*mask\bottomleft\dat, 0, height-*mask\bottomleft\height)
            CombineRgn_(*mask\maskrgn, *mask\maskrgn, *mask\bottomleft\dat, #RGN_DIFF)
            OffsetRgn_(*mask\bottomleft\dat, 0, -(height-*mask\bottomleft\height))
            
            x = *mask\bottomleft\width
            Repeat
                OffsetRgn_(*mask\bottom\dat, x, height-*mask\bottom\height)
                CombineRgn_(*mask\maskrgn, *mask\maskrgn, *mask\bottom\dat, #RGN_DIFF)
                OffsetRgn_(*mask\bottom\dat, -x, -(height-*mask\bottom\height))
                x = x + *mask\bottom\width
            Until x >= width-*mask\bottomright\width
            
            OffsetRgn_(*mask\bottomright\dat, width-*mask\bottomright\width, height-*mask\bottomright\height)
            CombineRgn_(*mask\maskrgn, *mask\maskrgn, *mask\bottomright\dat, #RGN_DIFF)
            OffsetRgn_(*mask\bottomright\dat, -(width-*mask\bottomright\Width), -(height-*mask\bottomright\height))
            
            *mask\maskwidth = width
            *mask\maskheight = height
            
        EndIf
        
        ProcedureReturn *mask\maskrgn
        
    EndIf
    
    ProcedureReturn 0
    
EndProcedure



Macro NormalizeRGB(r, g, b)
    
    If r > 255
        r = 255
    ElseIf r < 0
        r = 0
    EndIf 
    
    If g > 255 
        g = 255
    ElseIf g < 0
        g = 0
    EndIf 
    
    If b > 255 
        b = 255
    ElseIf b < 0
        b = 0
    EndIf 
    
EndMacro

ProcedureDLL CreateGradient(style.l, colour1.l, colour2.l) ; Creates a gradient
    
    macro_protectCommand()
    
    *gradient.gradients = AllocateStructure(gradients)
    
    If *gradient <> #Null
        
        *gradient\style = style
        *gradient\col(0) = colour1
        *gradient\col(1) = colour2
        *gradient\cpos(1) = 1
        *gradient\numCols = 2
        
        ; check if the gradient is alpha transparent and flag if so
        *alpha.ascii = @*gradient\col(0)+3
        If *alpha\a <> 255
            *gradient\isAlpha = #True
        EndIf
        *alpha.ascii = @*gradient\col(1)+3
        If *alpha\a <> 255
            *gradient\isAlpha = #True
        EndIf
        
    EndIf
    
    ProcedureReturn *gradient
    
EndProcedure

ProcedureDLL SetGradient(Gradient.i, style.l) ; Sets a previously created gradient's style
    
    macro_protectCommand()
    
    *gradient.gradients = Gradient
    If *gradient <> #Null
        
        *gradient\style = style
        ProcedureReturn #True
        
    EndIf
    
    ProcedureReturn #False
    
EndProcedure

ProcedureDLL SetGradientColour(Gradient.i, Position.f, Colour.l) ; Sets a gradient's colour at blend position
    
    macro_protectCommand()
    
    *gradient.gradients = Gradient
    If *gradient <> #Null And Position >= 0 And Position <= 1
        
        If Position = 0
            *gradient\col(0) = Colour
        ElseIf Position = 1
            *gradient\col(*gradient\numCols-1) = Colour
        Else
            
            ; check if position already set
            For n = 0 To *gradient\numCols-1
                If *gradient\cpos(n) = Position
                    *gradient\col(n) = Colour
                    found = #True
                    Break
                EndIf
            Next
            
            If found = #False ; not set add new
                
                ReDim *gradient\col(*gradient\numCols)
                ReDim *gradient\cpos(*gradient\numCols)
                
                *gradient\cpos(*gradient\numCols) = Position
                *gradient\col(*gradient\numCols) = Colour
                *gradient\numCols + 1
                
                NewList cols.GradientCol()
                For n = 0 To *gradient\numCols-1
                    AddElement(cols())
                    cols()\colour = *gradient\col(n)
                    cols()\pos = *gradient\cpos(n)
                Next
                SortStructuredList(cols(), #PB_Sort_Ascending, OffsetOf(GradientCol\pos), TypeOf(GradientCol\pos))
                
                n = 0
                ForEach cols()
                    *gradient\col(n) = cols()\colour
                    *gradient\cpos(n) = cols()\pos
                    n + 1
                Next
                    
            EndIf
            
        EndIf
        
        ; check if alpha
        isAlpha = #False
        For n = 0 To *gradient\numCols-1
            *alpha.ascii = @*gradient\col(n)+3
            If *alpha\a <> 255
                isAlpha = #True
                Break
            EndIf
        Next
        
        *gradient\isAlpha = isAlpha
        
        ProcedureReturn #True
        
    EndIf
    
    ProcedureReturn #False
    
EndProcedure

ProcedureDLL GetGradientColour(Gradient.i, Position.f) ; Gets a gradient's colour at blend position
    
    macro_protectCommand()
    
    *gradient.gradients = Gradient
    If *gradient <> #Null
        
        If Position = 0
            ProcedureReturn *gradient\col(0)
        ElseIf Position = 1
            ProcedureReturn *gradient\col(*gradient\numCols-1)
        EndIf
        
        ; find position
        For n = 0 To *gradient\numCols-1
            If *gradient\cpos(n) = Position
                ProcedureReturn *gradient\col(n)
            EndIf
        Next
        
        ProcedureReturn -1
        
    EndIf
    
    ProcedureReturn -2
    
EndProcedure

ProcedureDLL RemoveGradientColour(Gradient.i, Position.f) ; Removes a gradient's colour at blend position
    
    macro_protectCommand()
    
    If position = 0 Or position < -1 Or Position >= 1
        ProcedureReturn #False
    EndIf
    
    *gradient.gradients = Gradient
    If *gradient <> #Null
        
        If Position = -1
            
            endcol = *gradient\col(*gradient\numCols-1)
            ReDim *gradient\col(1)
            ReDim *gradient\cpos(1)
            *gradient\col(1) = endcol
            *gradient\cpos(1) = 1
            *gradient\numCols = 2
            found = #True
            
        Else
            
            ; find matching position
            NewList cols.GradientCol()
            For n = 0 To *gradient\numCols-1
                If *gradient\cpos(n) = Position
                    found = #True
                Else
                    AddElement(cols())
                    cols()\colour = *gradient\col(n)
                    cols()\pos = *gradient\cpos(n)
                EndIf
            Next
            
            If found = #True
                newSize = ListSize(cols())-1
                ReDim *gradient\col(newSize)
                ReDim *gradient\cpos(newSize)
                *gradient\numCols = newSize+1
                n = 0
                ForEach cols()
                    *gradient\col(n) = cols()\colour
                    *gradient\cpos(n) = cols()\pos
                    n + 1
                Next
            EndIf
            
        EndIf
        
        If found = #True
            
            ; check if alpha
            isAlpha = #False
            For n = 0 To *gradient\numCols-1
                *alpha.ascii = @*gradient\col(n)+3
                If *alpha\a <> 255
                    isAlpha = #True
                    Break
                EndIf
            Next
            
            *gradient\isAlpha = isAlpha
            
        EndIf
        
    EndIf
    
    ProcedureReturn found
    
EndProcedure

ProcedureDLL DrawGradient(dc, Gradient.i, *rec.RECT)
    
    *gradient.gradients = Gradient
    If *gradient <> #Null And dc <> #Null
        
        If *gradient\numCols = 2 And *gradient\col(0) = *gradient\col(1)
            GdipCreateFromHDC(dc, @GraphicObject)
            GdipSetCompositingQuality(GraphicObject, #CompositingQualityHighSpeed)
            GdipSetPixelOffsetMode(GraphicObject, #PixelOffsetModeNone)
            GdipSetSmoothingMode(GraphicObject, #SmoothingModeNone)
            GdipSetInterpolationMode(GraphicObject, #InterpolationModeDefault)
            GdipCreateSolidFill(*gradient\col(0), @BrushObject)
            If *gradient\isAlpha = #False
                GdipSetCompositingMode(GraphicObject, #CompositingModeSourceCopy)
            Else
                GdipSetCompositingMode(GraphicObject, #CompositingModeSourceOver)  
            EndIf
            GdipFillRectangleI(GraphicObject, BrushObject, *rec\left, *rec\top, *rec\right-*rec\left, *rec\bottom-*rec\top)
            GdipDeleteGraphics(GraphicObject)
            GdipDeleteBrush(BrushObject)
            ProcedureReturn #True
        EndIf
        
        p1.POINT
        p1\x = *rec\left
        p1\y = *rec\top
        p2.POINT
        If *gradient\style = 0
            p2\x = *rec\right
            p2\y = *rec\top
        ElseIf *gradient\style = #VerticalGRADIENT
            p2\x = *rec\left
            p2\y = *rec\bottom
        EndIf
        
        GdipCreateFromHDC(dc, @GraphicObject)
        If *gradient\isAlpha = #True
            GdipSetCompositingMode(GraphicObject, #CompositingModeSourceOver)
        Else
            GdipSetCompositingMode(GraphicObject, #CompositingModeSourceCopy)
        EndIf
        GdipSetCompositingQuality(GraphicObject, #CompositingQualityHighSpeed)
        GdipSetPixelOffsetMode(GraphicObject, #PixelOffsetModeNone)
        GdipSetSmoothingMode(GraphicObject, #SmoothingModeNone)
        GdipSetInterpolationMode(GraphicObject, #InterpolationModeDefault)
        
        If *gradient\style <= #VerticalGRADIENT
            
            GdipCreateLineBrushI(p1, p2, *gradient\col(0), *gradient\col(*gradient\numCols-1), 1, @BrushObject)
            
            If *gradient\numCols > 2
                GdipSetLinePresetBlend(BrushObject, *gradient\col(), *gradient\cpos(), *gradient\numCols)
            EndIf
            
            GdipFillRectangleI(GraphicObject, BrushObject, *rec\left, *rec\top, *rec\right-*rec\left, *rec\bottom-*rec\top) ; x,y width,height
            
        ElseIf *gradient\style = #RectangleGRADIENT
            
            Dim p.POINT(3)
            p(0)\x = *rec\left : p(0)\y = *rec\top
            p(1)\x = *rec\right : p(1)\y = *rec\top
            p(2)\x = *rec\right : p(2)\y = *rec\bottom
            p(3)\x = *rec\left : p(3)\y = *rec\bottom
            
            GdipCreatePathGradientI(p(), 4, 0, @BrushObject)
            
            pt.POINT
            pt\x = *rec\left+((*rec\right-*rec\left)/2)
            pt\y = *rec\top+((*rec\bottom-*rec\top)/2)
            GdipSetPathGradientCenterPointI(BrushObject, pt)
            
            GdipSetLinePresetBlend(BrushObject, *gradient\col(), *gradient\cpos(), *gradient\numCols)
            GdipFillRectangleI(GraphicObject, BrushObject, *rec\left, *rec\top, *rec\right-*rec\left, *rec\bottom-*rec\top) ; x,y width,height
            
        ElseIf *Gradient\style = #EllipseGRADIENT
            
            GdipCreatePath(0, @PathObject)
            GdipAddPathEllipseI(PathObject, *rec\left, *rec\top, *rec\right-*rec\left, *rec\bottom-*rec\top)
            GdipCreatePathGradientFromPath(PathObject, @BrushObject)
            
            p.POINT
            p\x = *rec\left+((*rec\right-*rec\left)/2)
            p\y = *rec\top+((*rec\bottom-*rec\top)/2)
            GdipSetPathGradientCenterPointI(BrushObject, pt)
            
            GdipSetLinePresetBlend(BrushObject, *gradient\col(), *gradient\cpos(), *gradient\numCols)
            GdipFillRectangleI(GraphicObject, BrushObject, *rec\left, *rec\top, *rec\right-*rec\left, *rec\bottom-*rec\top) ; x,y width,height
            GdipDeletePath(PathObject)
            
        EndIf
        
        GdipDeleteGraphics(GraphicObject)
        GdipDeleteBrush(BrushObject)
        
        ProcedureReturn #True
        
    EndIf
    
    ProcedureReturn #False
    
EndProcedure

ProcedureDLL FreeGradient(Gradient.i) ; Frees a gradient from memory.
    
    *gradient.gradients = Gradient
    If *gradient <> #Null
        FreeStructure(*gradient)
        ProcedureReturn #True
    EndIf
    
    ProcedureReturn #False
    
EndProcedure

ProcedureDLL ImgPath(Path.s)
    
    macro_protectCommand()
    
    If Mid(path, Len(path), 1) <> "\"
        path = path + "\"
    EndIf
    LoadImg_DefaultPath = Path.s
    
    ProcedureReturn #True
    
EndProcedure

ProcedureDLL LoadImg(Path.s, Width.l, Height.l, Flags.i) ; Loads a PNG, JPG, BMP or Icon, returns the new HBITMAP/HICON handle or zero for failure.
    
    macro_protectCommand()
    
    If Flags & #Img_Shared
        If FindMapElement(imgp(), Path) <> 0
            img(Str(imgp()))\count + 1
            ProcedureReturn imgp()
        EndIf
    EndIf
    
    ; check that file exists and is not empty
    If FileSize(LoadImg_DefaultPath+Path) <= 0
        ProcedureReturn 0
    EndIf
    
    Image = LoadImage_(GetModuleHandle_(0), LoadImg_DefaultPath+Path, #IMAGE_ICON, Width, Height, #LR_LOADFROMFILE)
    If Image = #Null
        
        id = LoadImage(#PB_Any, LoadImg_DefaultPath+path)
        If id <> #Null

            aWidth = ImageWidth(id)
            aHeight = ImageHeight(id)
            If (width <> 0 Or height <> 0)
                If width = 0
                    width = aWidth
                EndIf  
                If height = 0
                    height = aHeight
                EndIf
                
                If width <> aWidth Or height <> aHeight
                    ResizeImage(id, width, height)
                EndIf
            EndIf
            
            If Flags & #Img_ReturnIcon
                
                tlist = ImageList_Create_(ImageWidth(id), ImageHeight(id), #ILC_MASK | #ILC_COLOR32, 0, 0)
                ImageList_Add_(tlist, ImageID(id), 0)
                hIcon = ImageList_GetIcon_(tlist, 0, 0)
                ImageList_Destroy_(tlist)
                
                Image = hIcon
                
            Else
                
                sdc = StartDrawing(ImageOutput(id))
                ddc = CreateCompatibleDC_(sdc)
                image = CreateCompatibleBitmap_(sdc, ImageWidth(id), ImageHeight(id))
                old = SelectObject_(ddc, image)
                BitBlt_(ddc, 0, 0, ImageWidth(id), ImageHeight(id), sdc, 0, 0, #SRCCOPY)
                SelectObject_(ddc, old)
                DeleteDC_(ddc)
                StopDrawing()
                
            EndIf
            
            FreeImage(id)
            
        EndIf
    EndIf
    
    ; memory management, if new image
    If Image <> 0 And Flags & #Img_Shared
        If FindMapElement(imgp(), Path) = 0
            img(Str(Image))\count = 0
            img()\imgpath = Path
            imgp(Path) = Image
        EndIf
    EndIf
    
    ProcedureReturn Image
    
EndProcedure

ProcedureDLL ImgWidth(Image.i)
    
    If GetIconInfo_(Image, @iInfo.ICONINFO) <> 0
        Bitmap = iInfo\hbmColor
        Mask = iInfo\hbmMask
        GetObject_(Bitmap, SizeOf(BITMAP), @BM.BITMAP)
        width = BM\bmWidth
        DeleteObject_(Bitmap)
        DeleteObject_(Mask)
    Else
        GetObject_(Image, SizeOf(BITMAP), @BM.BITMAP)
        width = BM\bmWidth
    EndIf
    
    ProcedureReturn width
    
EndProcedure

ProcedureDLL ImgHeight(Image.i)
    
    If GetIconInfo_(Image, @iInfo.ICONINFO) <> 0
        Bitmap = iInfo\hbmColor
        Mask = iInfo\hbmMask
        GetObject_(Bitmap, SizeOf(BITMAP), @BM.BITMAP)
        height = BM\bmHeight
        DeleteObject_(Bitmap)
        DeleteObject_(Mask)
    Else
        GetObject_(Image, SizeOf(BITMAP), @BM.BITMAP)
        height = BM\bmHeight
    EndIf
    
    ProcedureReturn height
    
EndProcedure

ProcedureDLL FreeImg(Image.i) ; Removes an image or icon from memory.
    
    ; does image handle exist in our hashmap
    If FindMapElement(img(), Str(Image)) <> 0
        ; if the handle count is less than or equal to 1 then safe to free resources
        If img()\count <= 1
            If img()\himl <> 0
                ImageList_Destroy_(img()\himl)
            EndIf
            DeleteMapElement(imgp(), img()\imgpath)
            DeleteMapElement(img(), Str(Image))
        Else
            img()\count - 1
        EndIf
    EndIf
    
    retval = DestroyIcon_(Image)
    If retval = 0
        retval = DeleteObject_(Image)
    EndIf
    
    ProcedureReturn retval
    
EndProcedure

ProcedureDLL ImgBlend(Image.i, AlphaChannel.f, Contrast.f, Brightness.f, Color.l, BlendAmount.f, Flags) ; Alters an icon/image's alpha/contrast/brightness and/or blends with a color, returns new bitmap or icon
    
    macro_protectCommand()
    
    If GetIconInfo_(Image, @iInfo.ICONINFO) <> 0
        Image = iInfo\hbmColor
        Mask = iInfo\hbmMask
    EndIf
    
    If Mask <> 0
        
        GetObject_(Mask, SizeOf(BITMAP), @BM.BITMAP)
        width = BM\bmWidth
        height = BM\bmHeight
        
        If width > 0 And height > 0
            ;debuglog("ImgBlend: "+Str(width)+" "+Str(height))
            
            maskbitcount = 32
            ;debuglog("bitcount: "+Str(bitcount))
            maskextrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
            sizeheaders = SizeOf(BITMAPFILEHEADER) + SizeOf(BITMAPINFOHEADER)
            sizeimage = (width * maskbitcount / 8 + maskextrabytesperrow) * height
            *mask = AllocateMemory(sizeheaders + sizeimage)
            
            *bitmapfile.BITMAPFILEHEADER = *mask
            *bitmapfile\bfType = Asc("B") + Asc("M") << 8
            *bitmapfile\bfSize = sizeheaders +sizeimage
            *bitmapfile\bfOffBits = sizeheaders
            *bitmapinfo.BITMAPINFOHEADER = *mask + SizeOf(BITMAPFILEHEADER)
            *bitmapinfo\biSize = SizeOf(BITMAPINFOHEADER)
            *bitmapinfo\biWidth = width
            *bitmapinfo\biHeight = height
            *bitmapinfo\biPlanes = 1
            *bitmapinfo\biBitCount = maskbitcount
            *bitmapinfo\biCompression = 0
            *bitmapinfo\biSizeImage = sizeimage
            
            *maskdata = *mask + sizeheaders
            
            *maskdatapos = *maskdata
            
            newImage = CreateImage(#PB_Any, width, height, 32)
            
            hdc = StartDrawing(ImageOutput(newImage))
            GetDIBits_(hdc, Mask, 0, height, *mask+sizeheaders, *bitmapinfo, #DIB_RGB_COLORS)
            StopDrawing()
            FreeImage(newImage)
        EndIf
        
    EndIf
    
    GetObject_(Image, SizeOf(BITMAP), @BM.BITMAP)
    width = BM\bmWidth
    height = BM\bmHeight
    
    If width > 0 And height > 0
        ;debuglog("ImgBlend: "+Str(width)+" "+Str(height))
        
        If AlphaChannel < 1
            AlphaChannel = 1
        ElseIf AlphaChannel > 255
            AlphaChannel = 255
        EndIf
        
        bitcount = BM\bmBitsPixel
        extrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
        sizeheaders = SizeOf(BITMAPFILEHEADER) + SizeOf(BITMAPINFOHEADER)
        sizeimage = (width * bitcount / 8 + extrabytesperrow) * height
        *bitmap = AllocateMemory(sizeheaders + sizeimage)
        
        *bitmapfile.BITMAPFILEHEADER = *bitmap
        *bitmapfile\bfType = Asc("B") + Asc("M") << 8
        *bitmapfile\bfSize = sizeheaders +sizeimage
        *bitmapfile\bfOffBits = sizeheaders
        *bitmapinfo.BITMAPINFOHEADER = *bitmap + SizeOf(BITMAPFILEHEADER)
        *bitmapinfo\biSize = SizeOf(BITMAPINFOHEADER)
        *bitmapinfo\biWidth = width
        *bitmapinfo\biHeight = height
        *bitmapinfo\biPlanes = 1
        *bitmapinfo\biBitCount = bitcount
        *bitmapinfo\biCompression = 0
        *bitmapinfo\biSizeImage = sizeimage
        
        *bitmapdata = *bitmap + sizeheaders
        
        *bitmapdatapos = *bitmapdata
        
        newImage = CreateImage(#PB_Any, width, height, 32)
        
        hdc = StartDrawing(ImageOutput(newImage))
        GetDIBits_(hdc, image, 0, height, *bitmap+sizeheaders, *bitmapinfo, #DIB_RGB_COLORS)
        DrawingMode(#PB_2DDrawing_AllChannels)
        
        alpha.f = AlphaChannel
        
        For y = 0 To height - 1
            For x = 0 To width - 1
                bbyte.a = PeekB(*bitmapdatapos) ; Blue
                gbyte.a = PeekB(*bitmapdatapos + 1) ; Green
                rbyte.a = PeekB(*bitmapdatapos + 2) ; Red
                r = rbyte : g = gbyte : b = bbyte
                
                If flags & #ImgBlend_Greyscale
                    grey.f = (0.2989*r)+(0.5870*g)+(0.1140*b)
                    r = grey:g = grey:b = grey
                EndIf
                
                newColor = AlphaBlend(RGB(r,g,b), Color, BlendAmount)
                
                r=Red(newColor):g=Green(newColor):b=Blue(newColor)
                
                contrast_correction.f = (Contrast + 255) * 259 / (255 * (259 - Contrast))
                r = (r - 128) * contrast_correction + 128
                g = (g - 128) * contrast_correction + 128
                b = (b - 128) * contrast_correction + 128
                NormalizeRGB(r, g, b) 
                
                r = r + Brightness
                g = g + Brightness
                b = b + Brightness
                NormalizeRGB(r, g, b) 
                
                newColor = RGB(r,g,b)
                
                If bitcount = 32 ; Alpha channel
                    
                    a.a = PeekB(*bitmapdatapos + 3)
                    If a = 0 And *mask <> 0
                        a.a = PeekB(*maskdatapos)
                        If a = 0
                            a = 255
                        Else
                            a = 0
                        EndIf
                    EndIf
                    alpha.f = a
                    alpha = (alpha/255)*AlphaChannel
                    
                EndIf
                
                Plot(x,(height-1)-y, RGBA(Red(newColor),Green(newColor),Blue(newColor),alpha))
                
                *bitmapdatapos + bitcount / 8
                If *mask <> 0
                    *maskdatapos + maskbitcount / 8
                EndIf
            Next
            *bitmapdatapos + extrabytesperrow
            If *mask <> 0
                *maskdatapos + maskextrabytesperrow
            EndIf
        Next
        
        StopDrawing()
        
        FreeMemory(*bitmap)
        If *mask <> 0
            FreeMemory(*mask)
        EndIf
        
        If flags & #ImgBlend_ReturnIcon
            
            tlist = ImageList_Create_(width, height, #ILC_MASK | #ILC_COLOR32, 0, 0)
            ImageList_Add_(tlist, ImageID(newImage), 0)
            hIcon = ImageList_GetIcon_(tlist, 0, 0)
            ImageList_Destroy_(tlist)
            FreeImage(newImage)
            
            retval = hIcon
        Else
            
            sdc = StartDrawing(ImageOutput(newImage))
            ddc = CreateCompatibleDC_(sdc)
            retval = CreateCompatibleBitmap_(sdc, ImageWidth(newImage), ImageHeight(newImage))
            old = SelectObject_(ddc, retval)
            BitBlt_(ddc, 0, 0, ImageWidth(newImage), ImageHeight(newImage), sdc, 0, 0, #SRCCOPY)
            SelectObject_(ddc, old)
            DeleteDC_(ddc)
            StopDrawing()
            
            FreeImage(newImage)
            
        EndIf
        
        If flags & #ImgBlend_DestroyOriginal
            DestroyIcon_(Image)
            DeleteObject_(Image)
        EndIf
        
    EndIf
    
    If iInfo\hbmColor <> 0
        DeleteObject_(iInfo\hbmColor)
    EndIf
    
    If iInfo\hbmMask <> 0
        DeleteObject_(iInfo\hbmMask)
    EndIf
    
    ProcedureReturn retval
    
EndProcedure

Structure hsl
    h.f
    s.f
    l.f
EndStructure

Structure hsv
    h.f
    s.f
    v.f
EndStructure
Procedure.l HSLToRGB(*colorspace.hsl)
    
    ; ***************************************************************************
    ;
    ; Function: Converts HSL color space to RGB
    ;
    ; Returns:  The value of RGB
    ;
    ; ***************************************************************************
    
    Protected r.f, g.f, b.f
    Protected temp1.f, temp2.f
    Protected r_temp.f, g_temp.f, b_temp.f
    Protected h_temp.f
    
    If *colorspace\s = 0
        r = *colorspace\l
        g = *colorspace\l
        b = *colorspace\l
    Else
        If *colorspace\l < 0.5
            temp2 = *colorspace\l * (1 + *colorspace\s)
        Else
            temp2 = *colorspace\l + *colorspace\s - *colorspace\l * *colorspace\s
        EndIf
        
        temp1 = 2 * *colorspace\l - temp2
        
        h_temp = *colorspace\h / 360
        
        r_temp = h_temp + 1 / 3
        g_temp = h_temp
        b_temp = h_temp - 1 / 3
        
        If r_temp < 0
            r_temp + 1
        ElseIf r_temp > 1
            r_temp - 1
        EndIf
        
        If g_temp < 0
            g_temp + 1
        ElseIf g_temp > 1
            g_temp - 1
        EndIf
        
        If b_temp < 0
            b_temp + 1
        ElseIf b_temp > 1
            b_temp - 1
        EndIf
        
        If 6 * r_temp < 1
            r = temp1 + (temp2 - temp1) * 6 * r_temp
        ElseIf 2 * r_temp < 1
            r = temp2
        ElseIf 3 * r_temp < 2
            r = temp1 + (temp2 - temp1) * ((2 / 3) - r_temp) * 6
        Else
            r = temp1
        EndIf
        
        If 6 * g_temp < 1
            g = temp1 + (temp2 - temp1) * 6 * g_temp
        ElseIf 2 * g_temp < 1
            g = temp2
        ElseIf 3 * g_temp < 2
            g = temp1 + (temp2 - temp1) * ((2 / 3) - g_temp) * 6
        Else
            g = temp1
        EndIf
        
        If 6 * b_temp < 1
            b = temp1 + (temp2 - temp1) * 6 * b_temp
        ElseIf 2 * b_temp < 1
            b = temp2
        ElseIf 3 * b_temp < 2
            b = temp1 + (temp2 - temp1) * ((2 / 3) - b_temp) * 6
        Else
            b = temp1
        EndIf
    EndIf
    
    ProcedureReturn RGB(Int(r * 255), Int(g * 255), Int(b * 255))
    
EndProcedure
Procedure RGBToHSV(color, *colorspace.hsv)
    
    ; ***************************************************************************
    ;
    ; Function: Converts an RGB color space to HSV
    ;
    ; Returns:  A structure containing the HSV values
    ;
    ; ***************************************************************************
    
    Protected r.f, g.f, b.f
    Protected r_temp.l, g_temp.l, b_temp.l
    Protected delta.f, min.f
    
    r_temp = Red(color)
    g_temp = Green(color)
    b_temp = Blue(color)
    
    r = r_temp / 255
    g = g_temp / 255
    b = b_temp / 255
    
    If r < g
        min = r
    Else
        min = g
    EndIf
    If b < min
        b = min
    EndIf
    
    If r > g
        *colorspace\v = r
    Else
        *colorspace\v = g
    EndIf
    If b > *colorspace\v
        *colorspace\v = b
    EndIf
    
    delta = *colorspace\v - min
    
    If *colorspace\v = 0
        *colorspace\s = 0
    Else
        *colorspace\s = delta / *colorspace\v
    EndIf
    
    If *colorspace\s = 0
        *colorspace\h = 0
    Else
        If r = *colorspace\v
            *colorspace\h = 60 * (g - b) / delta
        ElseIf g = *colorspace\v
            *colorspace\h = 120 + 60 * (b - r) / delta
        ElseIf b = *colorspace\v
            *colorspace\h = 240 + 60 * (r - g) / delta
        EndIf
        If *colorspace\h < 0
            *colorspace\h + 360
        EndIf
    EndIf
    
EndProcedure

ProcedureDLL ImgHueBlend(Image.i, AlphaChannel.f, HueColor.l, Saturation.f, Lightness.f, BlendColor.l, BlendAmount.f, Flags) ; Alters an icon/image's alpha/color hue and/or blends with a color, returns new bitmap or icon
    
    macro_protectCommand()
    
    hsl.hsl
    hsv.hsv
    RGBToHSV(HueColor, hsv)
    hsl\h = hsv\h
    hsl\s = hsv\s+Saturation
    
    If hsl\s < 0
        hsl\s = 0
    ElseIf hsl\s > 1
        hsl\s = 1
    EndIf
    
    If GetIconInfo_(Image, @iInfo.ICONINFO) <> 0
        Image = iInfo\hbmColor
        Mask = iInfo\hbmMask
    EndIf
    
    If Mask <> 0
        
        GetObject_(Mask, SizeOf(BITMAP), @BM.BITMAP)
        width = BM\bmWidth
        height = BM\bmHeight
        
        If width > 0 And height > 0
            ;debuglog("ImgBlend: "+Str(width)+" "+Str(height))
            
            maskbitcount = 32
            ;debuglog("bitcount: "+Str(bitcount))
            maskextrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
            sizeheaders = SizeOf(BITMAPFILEHEADER) + SizeOf(BITMAPINFOHEADER)
            sizeimage = (width * maskbitcount / 8 + maskextrabytesperrow) * height
            *mask = AllocateMemory(sizeheaders + sizeimage)
            
            *bitmapfile.BITMAPFILEHEADER = *mask
            *bitmapfile\bfType = Asc("B") + Asc("M") << 8
            *bitmapfile\bfSize = sizeheaders +sizeimage
            *bitmapfile\bfOffBits = sizeheaders
            *bitmapinfo.BITMAPINFOHEADER = *mask + SizeOf(BITMAPFILEHEADER)
            *bitmapinfo\biSize = SizeOf(BITMAPINFOHEADER)
            *bitmapinfo\biWidth = width
            *bitmapinfo\biHeight = height
            *bitmapinfo\biPlanes = 1
            *bitmapinfo\biBitCount = maskbitcount
            *bitmapinfo\biCompression = 0
            *bitmapinfo\biSizeImage = sizeimage
            
            *maskdata = *mask + sizeheaders
            
            *maskdatapos = *maskdata
            
            newImage = CreateImage(#PB_Any, width, height, 32)
            
            hdc = StartDrawing(ImageOutput(newImage))
            GetDIBits_(hdc, Mask, 0, height, *mask+sizeheaders, *bitmapinfo, #DIB_RGB_COLORS)
            StopDrawing()
            FreeImage(newImage)
        EndIf
        
    EndIf
    
    GetObject_(Image, SizeOf(BITMAP), @BM.BITMAP)
    width = BM\bmWidth
    height = BM\bmHeight
    
    If width > 0 And height > 0
        ;debuglog("ImgHueBlend: "+Str(width)+" "+Str(height))
        
        If AlphaChannel < 1
            AlphaChannel = 1
        ElseIf AlphaChannel > 255
            AlphaChannel = 255
        EndIf
        
        bitcount = BM\bmBitsPixel
        extrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
        sizeheaders = SizeOf(BITMAPFILEHEADER) + SizeOf(BITMAPINFOHEADER)
        sizeimage = (width * bitcount / 8 + extrabytesperrow) * height
        *bitmap = AllocateMemory(sizeheaders + sizeimage)
        
        *bitmapfile.BITMAPFILEHEADER = *bitmap
        *bitmapfile\bfType = Asc("B") + Asc("M") << 8
        *bitmapfile\bfSize = sizeheaders +sizeimage
        *bitmapfile\bfOffBits = sizeheaders
        *bitmapinfo.BITMAPINFOHEADER = *bitmap + SizeOf(BITMAPFILEHEADER)
        *bitmapinfo\biSize = SizeOf(BITMAPINFOHEADER)
        *bitmapinfo\biWidth = width
        *bitmapinfo\biHeight = height
        *bitmapinfo\biPlanes = 1
        *bitmapinfo\biBitCount = bitcount
        *bitmapinfo\biCompression = 0
        *bitmapinfo\biSizeImage = sizeimage
        
        *bitmapdata = *bitmap + sizeheaders
        
        *bitmapdatapos = *bitmapdata
        
        newImage = CreateImage(#PB_Any, width, height, 32)
        
        hdc = StartDrawing(ImageOutput(newImage))
        GetDIBits_(hdc, image, 0, height, *bitmap+sizeheaders, *bitmapinfo, #DIB_RGB_COLORS)
        DrawingMode(#PB_2DDrawing_AllChannels)
        
        alpha.f = AlphaChannel
        
        For y = 0 To height - 1
            For x = 0 To width - 1
                bbyte.a = PeekB(*bitmapdatapos) ; Blue
                gbyte.a = PeekB(*bitmapdatapos + 1) ; Green
                rbyte.a = PeekB(*bitmapdatapos + 2) ; Red
                r = rbyte : g = gbyte : b = bbyte
                
                color = 0.299 * r + 0.587 * g + 0.114 * b
                
                hsl\l = Lightness * 2 - 1
                If hsl\l < 0
                    hsl\l = color / 255 * (hsl\l + 1)
                Else
                    hsl\l = color / 255 * (1 - hsl\l) + hsl\l
                EndIf
                newColor = HSLToRGB(hsl)
                
                r=Red(newColor):g=Green(newColor):b=Blue(newColor)
                
                newColor = AlphaBlend(RGB(r,g,b), BlendColor, BlendAmount)
                
                If bitcount = 32 ; Alpha channel
                    
                    a.a = PeekB(*bitmapdatapos + 3)
                    If a = 0 And *mask <> 0
                        a.a = PeekB(*maskdatapos)
                        If a = 0
                            a = 255
                        Else
                            a = 0
                        EndIf
                    EndIf
                    alpha.f = a
                    alpha = (alpha/255)*AlphaChannel
                    
                EndIf
                
                Plot(x,(height-1)-y, RGBA(Red(newColor),Green(newColor),Blue(newColor),alpha))
                
                *bitmapdatapos + bitcount / 8
                If *mask <> 0
                    *maskdatapos + maskbitcount / 8
                EndIf
            Next
            *bitmapdatapos + extrabytesperrow
            If *mask <> 0
                *maskdatapos + maskextrabytesperrow
            EndIf
        Next
        
        StopDrawing()
        
        FreeMemory(*bitmap)
        If *mask <> 0
            FreeMemory(*mask)
        EndIf
        
        If flags & #ImgBlend_ReturnIcon
            
            tlist = ImageList_Create_(width, height, #ILC_MASK | #ILC_COLOR32, 0, 0)
            ImageList_Add_(tlist, ImageID(newImage), 0)
            hIcon = ImageList_GetIcon_(tlist, 0, 0)
            ImageList_Destroy_(tlist)
            FreeImage(newImage)
            
            retval = hIcon
            
        Else
            
            sdc = StartDrawing(ImageOutput(newImage))
            ddc = CreateCompatibleDC_(sdc)
            retval = CreateCompatibleBitmap_(sdc, ImageWidth(newImage), ImageHeight(newImage))
            old = SelectObject_(ddc, retval)
            BitBlt_(ddc, 0, 0, ImageWidth(newImage), ImageHeight(newImage), sdc, 0, 0, #SRCCOPY)
            SelectObject_(ddc, old)
            DeleteDC_(ddc)
            StopDrawing()
            
            FreeImage(newImage)
            
        EndIf
        
        If flags & #ImgBlend_DestroyOriginal
            DestroyIcon_(Image)
            DeleteObject_(Image)
        EndIf
        
    EndIf
    
    If iInfo\hbmColor <> 0
        DeleteObject_(iInfo\hbmColor)
    EndIf
    
    If iInfo\hbmMask <> 0
        DeleteObject_(iInfo\hbmMask)
    EndIf
    
    ProcedureReturn retval
    
EndProcedure


Procedure hBitmap_to_hIcon(hBitmap)
    
    GetObject_(hBitmap, SizeOf(BITMAP), @BM.BITMAP)
    width = BM\bmWidth
    height = BM\bmHeight
    tlist = ImageList_Create_(width, height, #ILC_MASK | #ILC_COLOR32, 0, 0)
    ImageList_Add_(tlist, hBitmap, 0)
    hIcon = ImageList_GetIcon_(tlist, 0, 0)
    ImageList_Destroy_(tlist)
    
    ProcedureReturn hIcon
    
EndProcedure


ProcedureDLL.f ProGUIVersion()
    ProcedureReturn #Version
EndProcedure

Procedure measureMenuItemHeight(hdc.i, MenuItemEx.i)
    
    *thisItemEx = @itemex()
    ChangeCurrentElement(itemex(), MenuItemEx)
    oldFont = SelectObject_(hdc, currentMenuEXFont)
    
    If itemex()\scroll < 0 ; special scroll item button
        
        If itemex()\scroll <> -3 ; not filler
            height = menuScrollButtonHeight
        Else
            height = menuScrollFillerHeight
        EndIf
        
    ElseIf itemex()\text = "" ; separator
        
        ; get associated menuex
        ForEach menuex()
            If menuex()\popupid = itemex()\popupid
                Break
            EndIf
        Next
        
        If menuex()\style < 5
            height = 7
        Else
            height = 2
        EndIf
        
    Else
        
        rec.RECT
        rec\left = 0
        rec\right = 0
        rec\top = 0
        rec\bottom = 0
        renderText(hdc, itemex()\text, rec, 0, #DT_CALCRECT)
        
        height = rec\bottom+(#MENUEXITEMPADY*2)+(#MENUITEMIMAGEPADY*2)
        
        If height < itemex()\imageHeight+(#MENUEXITEMPADY*2)+(#MENUITEMIMAGEPADY*2)
            height = itemex()\imageHeight+(#MENUEXITEMPADY*2)+(#MENUITEMIMAGEPADX*2)
        EndIf
        
        height = height + 3
        
    EndIf
    
    SelectObject_(hdc, oldFont)
    
    ChangeCurrentElement(itemex(), *thisItemEx)
    
    ProcedureReturn height
    
EndProcedure

Procedure measureMenuWidth(MenuItemEx.i)
    
    hdc = CreateCompatibleDC_(0)
    oldFont = SelectObject_(hdc, currentMenuEXFont)
    
    ChangeCurrentElement(itemex(), MenuItemEx)
    
    p = FindString(itemex()\text, #ShortcutCode, 1)
    If p > 0
        txt.s = Mid(itemex()\text, 1, p-1)
        shortcut.s = Mid(itemex()\text, p+1)
        renderText(hdc, txt, @rec.RECT, currentMenuEXFont, #DT_CALCRECT)
        renderText(hdc, shortcut, @rc.RECT, currentMenuEXFont, #DT_CALCRECT)
        width = rec\right+rc\right
    Else 
        renderText(hdc, itemex()\text, @rec.RECT, currentMenuEXFont, #DT_CALCRECT)
        width = rec\right
    EndIf
    
    GetObject_(currentMenuEXFont, SizeOf(LOGFONT), @fontnfo.LOGFONT)
    fheight = fontnfo\lfHeight
    fheight = fontnfo\lfHeight: If fheight<0: fheight = -fheight: EndIf
    fheight*72.0/GetScreenDPI()
    padding = calcSidebarPadding(fheight)
    
    If fheight <= 9
        padding = padding - 2
    EndIf
    
    width = width + (itemex()\imageWidth*2)+padding+GetSystemMetrics_(#SM_CXMENUCHECK)
    
    SelectObject_(hdc, oldFont)
    DeleteDC_(hdc)
    
    ProcedureReturn width
    
EndProcedure


