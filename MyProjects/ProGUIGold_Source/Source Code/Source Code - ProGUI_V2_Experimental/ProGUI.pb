;                         py.d = grheight/2
;                         ratio.d = Abs(*graph\xAxisMax-*graph\xAxisMin)/grwidth
;                         pointx.d = (((px-*graph\xOffset)*ratio)+*graph\xAxisMin)
;                         ratio.d = Abs(*graph\yAxisMax-*graph\yAxisMin)/grheight
;                         pointy.d = ((((grheight-py)+*graph\yOffset)*ratio)+*graph\yAxisMin)
;                         
;                         txMin.d = *graph\xAxisMin
;                         txMax.d = *graph\xAxisMax
;                         tyMin.d = *graph\yAxisMin
;                         tyMax.d = *graph\yAxisMax
;                         
;                         *graph\xAxisMin = ((*graph\xAxisMin-pointx)/glzoom)+pointx
;                         *graph\xAxisMax = ((*graph\xAxisMax-pointx)/glzoom)+pointx
;                         
;                         *graph\yAxisMin = ((*graph\yAxisMin-pointy)/glzoom)+pointy
;                         *graph\yAxisMax = ((*graph\yAxisMax-pointy)/glzoom)+pointy
;                         
;                         ; calc axis ticks
;                         tickSpacing.d = GL_metric(GL_DPI)\DPI_Ratio**graph\tickSpacing
;                         xticks.d = grwidth/tickSpacing;Round(grwidth/tickSpacing, #PB_Round_Down)
;                         yticks.d = grheight/tickSpacing;Round(grheight/tickSpacing, #PB_Round_Down)
;                         oxticks.d = xticks
;                         oyticks.d = yticks
