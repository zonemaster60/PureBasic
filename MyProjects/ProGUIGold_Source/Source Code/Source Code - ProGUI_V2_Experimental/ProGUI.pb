;             StopDrawing()
;             FreeImage(found)
;             
;         ;EndIf
        
    EndIf
    
EndProcedure



Procedure.s renderText(hdc.i, txt.s, *rc.RECT, thisFont.i, style.l, hwnd.i = -1)
    
    ; used to limit text within window
    maxRight = *rc\right
    maxBottom = *rc\bottom
    
    If style & #RTXT_PROCESS_LINKS And hwnd <> #Null
        
        *txtcontrol.txtcontrols = GetProp_(hwnd, txtcontrolAtom)
        If *txtcontrol = #Null
            ProcedureReturn ""
        EndIf
        
        ; clear hyperlink list
        ClearList(*txtcontrol\link())
        
    EndIf
    
    If style & #DT_CALCRECT
        calcRect = #True
    ElseIf style & #DT_OVERRIDECOLOUR
        overrideColour = #True
    EndIf
    
    
    If style & #TCX_TOP
        flags = #DT_TOP | #DT_SINGLELINE | #DT_LEFT | #DT_EXPANDTABS | #DT_NOCLIP
    ElseIf style & #TCX_CENTRE And style & #TCX_VCENTRE
        singleLineVCentre = #True
        singleLineCentre = #True
        flags = #DT_VCENTER | #DT_CENTER | #DT_SINGLELINE | #DT_LEFT | #DT_EXPANDTABS | #DT_NOCLIP
    Else
        singleLineVCentre = #True
        flags = #DT_VCENTER | #DT_SINGLELINE | #DT_LEFT | #DT_EXPANDTABS | #DT_NOCLIP
    EndIf
    
    If style & #TCX_END_ELLIPSIS
        flags = flags | #DT_END_ELLIPSIS
    EndIf
    
    If style & #TCX_PATH_ELLIPSIS
        flags = flags | #DT_PATH_ELLIPSIS
    EndIf
    
    If style & #TCX_DISABLE_ESCAPECODES
        disableEscapeCodes = #True
    EndIf
    
    If style & #RTXT_RETURNSTRING
        returnString = #True
        retstr.s = ""
    EndIf
    
    If thisFont = 0
        thisFont = GetCurrentObject_(hdc, #OBJ_FONT)
        oldFont = thisFont
    Else
        oldFont = SelectObject_(hdc, thisFont)
    EndIf
    
    GetObject_(thisFont, SizeOf(LOGFONT), @fontnfo.LOGFONT)
    
    thisColour = GetTextColor_(hdc)
    
    SetBkMode_(hdc, #TRANSPARENT)
    
    ; are there any escape codes in this txt
    If disableEscapeCodes = #False And FindString(txt, "\", 1) > 0
        
        l = GetTextFace_(hdc, 0, 0)
        CompilerIf #PB_Compiler_Unicode
            l = l*2
        CompilerEndIf
        *mem = AllocateMemory(l+2)
        GetTextFace_(hdc, l, *mem)
        fontName.s = PeekS(*mem)
        ;Debug fontName
        FreeMemory(*mem)
        
        met.TEXTMETRIC
        GetTextMetrics_(hdc, @met)
        
        ; check if multiple lines
        If FindString(txt, "\|", 1) > 0
            linePadding = renderTextLinePadding
        EndIf
        
        ; scan txt for control codes
        p = 1
        lp = 1
        Repeat
            p = FindString(txt, "\", p)
            
            ; find block of backspace escape codes first, e.g. a file path
            If p <> 0 And Mid(txt, p, 2) = "\\"
                p = p + 2
                blockFound = #True
                Continue
            EndIf
            
            ; other escape code found
            If p <> 0
                
                c.s = LCase(Mid(txt, p+1, 1))
                
                thisTxt.s = Mid(txt, lp, (p-lp))
                
                If blockFound = #True
                    thisTxt = ReplaceString(thisTxt, "\\", "\") ; if block of backspace escape codes then make single
                    blockFound = #False
                EndIf
                rec.RECT
                rec\left = 0
                rec\right = 0
                rec\top = 0
                rec\bottom = 0
                DrawText_(hdc, thisTxt, Len(thisTxt), @rec, #DT_EXPANDTABS|#DT_CALCRECT)
                thisWidth = rec\right
                If thisTxt = ""
                    DrawText_(hdc, " ", 1, @rec, #DT_EXPANDTABS|#DT_CALCRECT)
                EndIf
                thisHeight = rec\bottom+linePadding
                
                ; not calculating rect then render
                If calcRect = 0
                    rec\top = *rc\top+ypos
                    rec\left = *rc\left+xpos
                    rec\right = *rc\left+xpos+thisWidth
                    If rec\right > maxRight ; limit inside width of window
                        flags = flags &~ #DT_NOCLIP
                        rec\right = maxRight
                        If flags & #DT_END_ELLIPSIS And Len(thistxt) = 1
                            thistxt = "..."
                        EndIf
                    EndIf
                    If singleLineVCentre = #True
                        rec\bottom = *rc\bottom
                    Else
                        rec\bottom = rec\top+rec\bottom
                    EndIf
                    If rec\bottom > maxBottom ; limit inside height of window
                        flags = flags &~ #DT_NOCLIP
                        rec\bottom = maxBottom
                    EndIf
                    
                    DrawText_(hdc, thisTxt, Len(thisTxt), @rec, flags)
                EndIf
                
                If returnString = #True
                    retstr.s = retstr + thisTxt
                EndIf
                
                If xpos+thisWidth > totalWidth
                    totalWidth = xpos+thisWidth
                EndIf
                If ypos+thisHeight > totalHeight
                    totalHeight = ypos+thisHeight
                EndIf
                xpos = xpos + thisWidth
                
                If c = "b"  ; bold
                    
                    SelectObject_(hdc, thisFont)
                    DeleteObject_(font)
                    If met\tmWeight = 700
                        met\tmWeight = 400
                    Else
                        met\tmWeight = 700
                    EndIf
                    font = CreateFont_(met\tmHeight, met\tmAveCharWidth, 0, 0, met\tmWeight, met\tmItalic, met\tmUnderlined, met\tmStruckOut, met\tmCharSet, 0, 0, fontnfo\lfQuality, met\tmPitchAndFamily, @fontName)
                    SelectObject_(hdc, font)
                    lp = p+2
                    
                ElseIf c = "u"  ; underline
                    
                    SelectObject_(hdc, thisFont)
                    DeleteObject_(font)
                    If met\tmUnderlined = #True
                        met\tmUnderlined = #False
                    Else
                        met\tmUnderlined = #True
                    EndIf
                    font = CreateFont_(met\tmHeight, met\tmAveCharWidth, 0, 0, met\tmWeight, met\tmItalic, met\tmUnderlined, met\tmStruckOut, met\tmCharSet, 0, 0, fontnfo\lfQuality, met\tmPitchAndFamily, @fontName)
                    SelectObject_(hdc, font)
                    lp = p+2
                    
                ElseIf c = "s"  ; strike out
                    
                    SelectObject_(hdc, thisFont)
                    DeleteObject_(font)
                    If met\tmStruckOut = #True
                        met\tmStruckOut = #False
                    Else
                        met\tmStruckOut = #True
                    EndIf
                    font = CreateFont_(met\tmHeight, met\tmAveCharWidth, 0, 0, met\tmWeight, met\tmItalic, met\tmUnderlined, met\tmStruckOut, met\tmCharSet, 0, 0, fontnfo\lfQuality, met\tmPitchAndFamily, @fontName)
                    SelectObject_(hdc, font)
                    lp = p+2
                    
                ElseIf c = "i"  ; italic
                    
                    SelectObject_(hdc, thisFont)
                    DeleteObject_(font)
                    If met\tmItalic = #True
                        met\tmItalic = #False
                    Else
                        met\tmItalic = #True
                    EndIf
                    font = CreateFont_(met\tmHeight, met\tmAveCharWidth, 0, 0, met\tmWeight, met\tmItalic, met\tmUnderlined, met\tmStruckOut, met\tmCharSet, 0, 0, fontnfo\lfQuality, met\tmPitchAndFamily, @fontName)
                    SelectObject_(hdc, font)
                    lp = p+2
                    
                ElseIf c = "n"
                    
                    SelectObject_(hdc, thisFont)
                    DeleteObject_(font)
                    met.TEXTMETRIC
                    GetTextMetrics_(hdc, @met)
                    SetTextColor_(hdc, thisColour)
                    lp = p+2
                    
                ElseIf c = "c"  ; colour
                    
                    hx.s = Mid(txt, p+2, 6)
                    r = Val("$"+Mid(hx, 1, 2))
                    g = Val("$"+Mid(hx, 3, 2))
                    b = Val("$"+Mid(hx, 5, 2))
                    If overrideColour = #False
                        SetTextColor_(hdc, RGB(r,g,b))
                    EndIf
                    lp = p+8
                    
                ElseIf c = "l"  ; hyperlink
                    
                    lp = p+2
                    
                    ; see if beggining of link
                    If Asc(Mid(txt, lp, 1)) >= 48 And Asc(Mid(txt, lp, 1)) <= 57
                        ; get id
                        n = lp-1
                        Repeat
                            n = n + 1
                        Until n > Len(txt) Or (Asc(Mid(txt, n, 1)) < 48 Or Asc(Mid(txt, n, 1)) > 57)
                        linkID = Val(Mid(txt, lp, n-lp))
                        lp = n
                        
                        linkpos = lp
                        linkX = *rc\left+xpos
                        linkY = *rc\top+ypos
                        
                        ; end of link
                    Else
                        
                        thisTxt.s = Mid(txt, linkpos, (lp-2)-linkpos)
                        rec.RECT
                        rec\left = 0
                        rec\right = 0
                        rec\top = 0
                        rec\bottom = 0
                        
                        ; remove any control codes from thisTxt
                        thisTxt = RemoveString(thisTxt, "\u")
                        thisTxt = RemoveString(thisTxt, "\b")
                        thisTxt = RemoveString(thisTxt, "\i")
                        thisTxt = RemoveString(thisTxt, "\s")
                        thisTxt = RemoveString(thisTxt, "\n")
                        thisTxt = ReplaceString(thisTxt, "\\", "\")
                        Repeat
                            tp = FindString(LCase(thisTxt), "\c", 1)
                            If tp <> 0
                                thisTxt = Mid(thisTxt, tp+8)
                            EndIf
                        Until tp = 0
                        
                        DrawText_(hdc, thisTxt, Len(thisTxt), @rec, #DT_EXPANDTABS|#DT_CALCRECT)
                        
                        If *txtcontrol <> #Null ; only store the link location if processLinks is set to true
                            *link.txtControlLinks = AddElement(*txtcontrol\link())
                            *link\id = linkID
                            *link\rc\left = linkX
                            *link\rc\top = linkY
                            *link\rc\right = linkX+rec\right
                            *link\rc\bottom = linkY+rec\bottom
                        EndIf
                        
                        lp = p+2
                    EndIf
                    
                    
                ElseIf c = "|"  ; new line
                    
                    lp = p+2
                    
                    xpos = 0
                    ypos = ypos+thisHeight
                    
                ElseIf c = "\"  ; detected double backslash escape code, display single backslash
                    lp = p+1
                    p = p + 1
                Else  ; no recognisable escape code, ignore backslash
                    lp = p+1
                EndIf
                p = p + 1
            EndIf
        Until p = 0
        
        If lp > 0 And lp <= Len(txt)
            thisTxt.s = Trim(Mid(txt, lp))
            
            If blockFound = #True
                thisTxt = ReplaceString(thisTxt, "\\", "\") ; if block of backspace escape codes then make single
                blockFound = #False
            EndIf
            
            rec.RECT
            rec\left = 0
            rec\right = 0
            rec\top = 0
            rec\bottom = 0
            DrawText_(hdc, thisTxt, Len(thisTxt), @rec, #DT_EXPANDTABS|#DT_CALCRECT)
            thisWidth = rec\right
            If thisTxt = ""
                DrawText_(hdc, " ", 1, @rec, #DT_EXPANDTABS|#DT_CALCRECT)
            EndIf
            thisHeight = rec\bottom
            
            ; not calculating rect then render
            If calcRect = 0
                rec\top = *rc\top+ypos
                rec\left = *rc\left+xpos
                rec\right = *rc\left+xpos+thisWidth
                If rec\right > maxRight ; limit inside width of window
                    flags = flags &~ #DT_NOCLIP
                    rec\right = maxRight
                    If flags & #DT_END_ELLIPSIS And Len(thistxt) = 1
                        thistxt = "..."
                    EndIf
                EndIf
                If singleLineVCentre = #True
                    rec\bottom = *rc\bottom
                Else
                    rec\bottom = rec\top+rec\bottom
                EndIf
                If rec\bottom > maxBottom ; limit inside height of window
                    flags = flags &~ #DT_NOCLIP
                    rec\bottom = maxBottom
                EndIf
                DrawText_(hdc, thisTxt, Len(thisTxt), @rec, flags)
            EndIf
            
            If returnString = #True
                retstr.s = retstr + thisTxt
            EndIf
            
        EndIf
        
        ; draw complete txt string without formating
    Else
        If calcRect = 0
            DrawText_(hdc, txt, Len(txt), *rc, flags)
            If returnString = #True
                retstr.s = txt
            EndIf
        Else
            DrawText_(hdc, txt, Len(txt), *rc, #DT_EXPANDTABS|#DT_CALCRECT)
            If returnString = #True
                retstr.s = txt
                ProcedureReturn retstr
            EndIf
            ProcedureReturn ""
        EndIf
    EndIf
    
    SelectObject_(hdc, oldFont)
    DeleteObject_(font)
    
    If lp <= Len(txt) ; don't add totalwidth if escape code on end of txt
        If xpos+thisWidth > totalWidth
            totalWidth = xpos+thisWidth
        EndIf
        If ypos+thisHeight > totalHeight
            totalHeight = ypos+thisHeight
        EndIf
    EndIf
    
    If calcRect = #True
        *rc\top = 0
        *rc\left = 0
        *rc\right = totalWidth
        *rc\bottom = totalHeight
    Else
        If hwnd <> -1
            alphaText(hdc, txt, *rc, thisFont, style, hwnd) ; if in alpha panelex page then adds alpha channel data
        EndIf
    EndIf
    
    If returnString = #True
        ProcedureReturn retstr.s
    EndIf
    
    ProcedureReturn ""
    
EndProcedure


Procedure resizeToolbar(toolbarID)
    
    ; loop through menuex items and resize accordingly
    ForEach menuex()
        If menuex()\singleMenu = 0 And menuex()\toolbarID = toolbarID
            
            ; change our current menuex font to the new menu font
            hdc = CreateCompatibleDC_(0)
            SelectObject_(hdc, currentMenuEXFont)
            
            ; get old height of toolbar
            oldheight = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)
            oldheight = (oldheight>>16)
            
            ; re-calc the toolbar button dimensions with the new font
            buttontxt.s = ""
            bufflen = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, 0)
            If bufflen > 0
                CompilerIf #PB_Compiler_Unicode
                    bufflen = bufflen * 2
                CompilerEndIf
                *mem = AllocateMemory(bufflen+2)
                SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, *mem)
                buttontxt = PeekS(*mem, bufflen)
                FreeMemory(*mem)
            EndIf
            
            DrawText_(hdc, buttontxt, Len(buttontxt), @rec.RECT, #DT_SINGLELINE | #DT_CALCRECT)
            
            DeleteDC_(hdc)
            
            buttoni.TBBUTTONINFO
            buttoni\cbSize = SizeOf(TBBUTTONINFO)
            buttoni\dwMask = #TBIF_SIZE
            buttoni\cx = rec\right+#MENUEXPADX
            
            ; reset menu bar height if font too small
            If rec\bottom+#MENUEXPADY < #MENUEXMINHEIGHT
                rec\bottom = #MENUEXMINHEIGHT - #MENUEXPADY
            EndIf
            
            ; 2003 style
            If menuex()\style = 6
                buttoni\cx = buttoni\cx - 2
                rec\bottom = rec\bottom - 3
                ; 2007 style
            ElseIf menuex()\style = #UISTYLE_OFFICE2007
                buttoni\cx = buttoni\cx - 2
                rec\bottom = rec\bottom - 2
            EndIf
            
            SendMessage_(menuex()\toolbarID, #TB_SETBUTTONSIZE, 0, MakeLong(0, rec\bottom+#MENUEXPADY))
            SendMessage_(menuex()\toolbarID, #TB_SETBUTTONINFO, menuex()\buttonID, @buttoni)
            
            ; check if the toolbar is in a rebar
            ForEach rebarGadget()
                If GetParent_(menuex()\toolbarID) = rebarGadget()\Handle
                    
                    ; find bar that our toolbar is contained in
                    max = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0,0)
                    For n = 0 To max
                        band.REBARBANDINFO
                        band\cbSize = SizeOf(REBARBANDINFO)
                        band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
                        SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, n, @band)
                        
                        dwBtnSize = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)>>16
                        If band\hwndChild = menuex()\toolbarID
                            
                            ; calc old height delta between toolbar and band
                            hdelta = band\cyMinChild-oldheight
                            
                            ; set rebar band's new height
                            band\fMask = #RBBIM_CHILDSIZE
                            band\cyMinChild = dwBtnSize+hdelta
                            SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, n, @band)
                            
                            Break
                        EndIf
                    Next
                    
                    Break
                EndIf
            Next
            
        EndIf
    Next
    
EndProcedure

Procedure GetScreenDPI(horiz.b=#False)
    ; Get screen dots per inch vertically (default) or horizontally
    Protected hdc, dpi
    hdc = CreateCompatibleDC_(0) ; Desktop device context
    If horiz
        dpi = GetDeviceCaps_(hdc, #LOGPIXELSX)
    Else
        dpi = GetDeviceCaps_(hdc, #LOGPIXELSY)
    EndIf
    DeleteDC_(hdc)
    ProcedureReturn dpi
EndProcedure 

Procedure calcSidebarPadding(pntSize)
    
    If pntSize >= 10
        
        t.f = Round(pntSize/5, #PB_Round_Down)
        i = t-2
        t = t*5
        z = 10
        For n = t To pntSize-1
            z = z + 2
        Next
        
        ProcedureReturn (z+(i*8))
        
    EndIf
    
    ProcedureReturn 8
EndProcedure

ProcedureDLL LoadFontEx(Name.s, PointSize.l, Flags.i) ; loads a font and returns a handle to it
    
    macro_protectCommand()
    
    PointSize = -MulDiv_(PointSize, GetScreenDPI(), 72)
    
    If flags & #Font_Antialiased
        quality = #ANTIALIASED_QUALITY
        flags = flags &~ #ANTIALIASED_QUALITY
    ElseIf flags & #Font_NonAntialiased
        quality = #NONANTIALIASED_QUALITY
        flags = flags &~ #NONANTIALIASED_QUALITY
    ElseIf flags & #Font_Cleartype
        quality = #CLEARTYPE_QUALITY
        flags = flags &~ #CLEARTYPE_QUALITY
    ElseIf flags & #Font_Draft
        qaulity = #DRAFT_QUALITY
        flags = flags &~ #DRAFT_QUALITY
    EndIf
    
    If flags >= #FW_BOLD And flags <= #FW_BOLD+#Font_StrikeOut
        weight = #FW_BOLD
        flags = flags &~ #FW_BOLD
    EndIf
    
    If flags & #Font_Bold
        weight = #FW_BOLD
        flags = flags &~ #Font_Bold
    EndIf
    
    If flags & #Font_Italic
        italic = #True
        flags = flags &~ #Font_Italic
    EndIf
    
    If flags & #Font_Underline
        underline = #True
        flags = flags &~ #Font_Underline
    EndIf
    
    If flags & #Font_StrikeOut
        strikeout = #True
        flags = flags &~ #Font_StrikeOut
    EndIf
    
    If flags = 400
        flags = 0
    EndIf
    
    If flags & #PB_Font_Bold
        weight = #FW_BOLD
    EndIf
    If flags & #PB_Font_Italic
        italic = #True
    EndIf
    
    ProcedureReturn CreateFont_(PointSize, 0, 0, 0, weight, italic, underline, strikeout, #DEFAULT_CHARSET, #OUT_DEFAULT_PRECIS, #CLIP_DEFAULT_PRECIS, quality, #VARIABLE_PITCH, Name)
    
EndProcedure

ProcedureDLL FreeFontEx(Font.i) ; Removes a font from memory
    ProcedureReturn DeleteObject_(Font)
EndProcedure

ProcedureDLL SetWindowFont(Hwnd.i, Font.i)
    ProcedureReturn SendMessage_(Hwnd, #WM_SETFONT, Font, #True)
EndProcedure

ProcedureDLL GetFontSize(fontID.i)  ; returns the point size of a font
    
    macro_protectCommand()
    
    CompilerIf #LIBRARY = 1
        If IsFont(fontID)
            fontID = FontID(fontID)
        EndIf
    CompilerEndIf
    
    If GetObject_(fontID, SizeOf(LOGFONT), @fontnfo.LOGFONT) <> 0
        fheight = fontnfo\lfHeight
        fheight = fontnfo\lfHeight: If fheight<0: fheight = -fheight: EndIf
        fheight*72.0/GetScreenDPI()
        ProcedureReturn fheight
    EndIf
    
    ProcedureReturn #False
    
EndProcedure

ProcedureDLL.s GetFontName(fontID.i)  ; returns the face name of a font
    
    macro_protectCommand()
    
    ReturnString$ = GetFontNamep(fontID.i)
    
    ProcedureReturn ReturnString$
    
EndProcedure

Procedure.s GetFontNamep(fontID.i)  ; private returns the face name of a font
    
    CompilerIf #LIBRARY = 1
        If IsFont(fontID)
            fontID = FontID(fontID)
        EndIf
    CompilerEndIf
    
    If GetObject_(fontID, SizeOf(LOGFONT), @fontnfo.LOGFONT) <> 0
        ReturnString$ = PeekS(@fontnfo\lfFaceName)
        ProcedureReturn ReturnString$
    EndIf
    
    ReturnString$ = ""
    
    ProcedureReturn ReturnString$
    
EndProcedure

;--
;- Processing/Custom Draw of
;- MenuEx, ToolBarEx and Rebar
;--
Procedure menuExScroll(direction.i) ; 0 = down | 1 = up | 2 = bottom | 3 = top
    
    mnfo.MENUITEMINFO_Fixed
    mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    
    WindowID = menuScrollWindow
    
    speed = 3
    
    ; flick to top
    If direction = 3
        
        menuScrolling = #True
        
        SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
        
        count = GetMenuItemCount_(menuScrollHandle)-1
        
        ; clear all current items
        For n = 0 To count
            RemoveMenuItemEx(menuScrollHandle, 0, #True)
        Next
        
        ; populate menu with items from original
        menuScrollFillerHeight = 7
        InsertMenuItemEx(menuScrollHandle, 0, #MENUSCROLLDOWNID, "", 0, 0, 0, -1)
        InsertMenuItemEx(menuScrollHandle, 0, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
        menuScrollPos = 0
        Repeat
            mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
            If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            ImageList = itemex()\ImageList
            normal = itemex()\normal
            hot = itemex()\hot
            disabled = itemex()\disabled
            InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
            mnfo\fMask = #MIIM_STATE
            SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
            If normal <> 0
                itemex()\ImageList = ImageList_Duplicate_(ImageList)
                itemex()\normal = normal
                itemex()\hot = hot
                itemex()\disabled = disabled
            EndIf
            menuScrollPos = menuScrollPos + 1
        Until CalcMenuItemHeight(menuScrollHandle) > menuScrollHeight
        RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True)
        
        ; check if we need to increase filler
        height = CalcMenuItemHeight(menuScrollHandle)
        If height < menuScrollHeight
            
            menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
            RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
            InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
            
        ElseIf height > menuScrollHeight
            
            menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
            RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
            InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
        EndIf
        
        menuScrolling = #False
        
        SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
        RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_UPDATENOW)
        
        ProcedureReturn 0
        
        ; flick to bottom
    ElseIf direction = 2
        
        menuScrolling = #True
        
        SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
        
        count = GetMenuItemCount_(menuScrollHandle)-1
        
        ; clear all current items
        For n = 0 To count
            RemoveMenuItemEx(menuScrollHandle, 0, #True)
        Next
        
        ; populate menu with items from original
        menuScrollFillerHeight = 7
        InsertMenuItemEx(menuScrollHandle, 0, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
        InsertMenuItemEx(menuScrollHandle, 0, #MENUSCROLLUPID, "", 0, 0, 0, -2)
        menuScrollPos = GetMenuItemCount_(originalScrollMenu)-1
        pos = 0
        Repeat
            mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
            If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            ImageList = itemex()\ImageList
            normal = itemex()\normal
            hot = itemex()\hot
            disabled = itemex()\disabled
            InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-pos, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
            mnfo\fMask = #MIIM_STATE
            SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
            If normal <> 0
                itemex()\ImageList = ImageList_Duplicate_(ImageList)
                itemex()\normal = normal
                itemex()\hot = hot
                itemex()\disabled = disabled
            EndIf
            menuScrollPos = menuScrollPos - 1
            pos = pos + 1
        Until CalcMenuItemHeight(menuScrollHandle) > menuScrollHeight
        RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-(pos), #True)
        
        ; check if we need to increase or decrease filler
        height = CalcMenuItemHeight(menuScrollHandle)
        If height < menuScrollHeight
            
            menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
            RemoveMenuItemEx(menuScrollHandle, 1, #True)
            InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
            
        ElseIf height > menuScrollHeight
            
            menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
            RemoveMenuItemEx(menuScrollHandle, 1, #True)
            InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
        EndIf
        
        menuScrolling = #False
        
        SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
        RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_UPDATENOW)
        
        ProcedureReturn 0
        
    EndIf
    
    
    Repeat
        
        SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
        RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_UPDATENOW)
        
        
        SetCapture_(WindowID)
        
        menuScrolling = #True
        
        ;Delay(500)
        
        mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
        
        ;-/ scroll down
        If direction = 0
            
            ; have we just started scrolling down
            If GetMenuItemInfo_(menuScrollHandle, 0, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            hdc = GetWindowDC_(WindowID)
            If itemex()\scroll = 0
                
                menuScrollPos = GetMenuItemCount_(menuScrollHandle)-2
                menuScrollEndPos = 1
                If GetMenuItemInfo_(menuScrollHandle, 0, #True, @mnfo) <> 0
                    ChangeCurrentElement(itemex(), mnfo\dwItemData)
                EndIf
                
                height = measureMenuItemHeight(hdc, @itemex())-menuScrollFillerHeight
                
                SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
                
                ; add to top up button
                InsertMenuItemEx(menuScrollHandle, 0, #MENUSCROLLUPID, "", 0, 0, 0, -2)
                RemoveMenuItemEx(menuScrollHandle, 1, #True)
                
                menuScrolling = #False
                SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
                RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_NOERASE|#RDW_UPDATENOW)
                menuScrolling = #True
                
                s = -speed
                GetClientRect_(WindowID, @rc.RECT)
                rc\top = menuScrollButtonHeight+menuScrollFillerHeight-5
                rc\bottom = (rc\bottom - menuScrollButtonHeight)+5
                
                frames = height/speed
                For n = 0 To frames-1
                    ScrollWindow_(WindowID, 0, s, rc, 0)
                    Delay(10)
                Next
                
                SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
                
                ; remove filler from bottom and add to top
                RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
                InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                
                ; if 2nd item to remove is separator then remove
                If GetMenuItemInfo_(menuScrollHandle, 2, #True, @mnfo) <> 0
                    ChangeCurrentElement(itemex(), mnfo\dwItemData)
                EndIf
                If itemex()\text = ""
                    separator = #True
                    RemoveMenuItemEx(menuScrollHandle, 2, #True)
                    menuScrollEndPos = menuScrollEndPos + 1
                EndIf
                
            Else
                
                If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True, @mnfo) <> 0
                    ChangeCurrentElement(itemex(), mnfo\dwItemData)
                EndIf
                If itemex()\scroll = -3
                    height = menuScrollButtonHeight-menuScrollFillerHeight
                Else
                    height = menuScrollButtonHeight
                EndIf
                
                s = -speed
                GetClientRect_(WindowID, @rc.RECT)
                rc\top = menuScrollButtonHeight+menuScrollFillerHeight+1
                rc\bottom = (rc\bottom - menuScrollButtonHeight)+5
                ;frames.f = Round(height/speed, #PB_ROUND_DOWN)
                frames = height/speed
                For n = 0 To frames-1
                    ScrollWindow_(WindowID, 0, s, rc, 0)
                    Delay(10)
                Next
                
                menuScrollPos = menuScrollPos + 1
                
            EndIf
            ReleaseDC_(WindowID, hdc) 
            
            SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
            
            ; check if filler is at bottom and if so prepare for scroll down
            If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            If itemex()\scroll = -3
                
                RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
                menuScrollFillerHeight = 7
                InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                t = menuScrollPos
                menuScrollPos = menuScrollEndPos+1
                menuScrollEndPos = t-1
                
            Else
                ; remove filler
                If GetMenuItemInfo_(menuScrollHandle, 1, #True, @mnfo) <> 0
                    ChangeCurrentElement(itemex(), mnfo\dwItemData)
                EndIf
                If itemex()\scroll = -3
                    RemoveMenuItemEx(menuScrollHandle, 1, #True)
                    menuScrollFillerHeight = 7
                    InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                EndIf
            EndIf
            
            
            ; if 1st item to remove is separator then remove
            If GetMenuItemInfo_(menuScrollHandle, 2, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            If itemex()\text = ""
                separator = #True
                RemoveMenuItemEx(menuScrollHandle, 2, #True)
                menuScrollEndPos = menuScrollEndPos + 1
            EndIf
            
            RemoveMenuItemEx(menuScrollHandle, 2, #True)
            menuScrollEndPos = menuScrollEndPos + 1
            
            ; if 2nd item to remove is separator then remove
            If GetMenuItemInfo_(menuScrollHandle, 2, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            If itemex()\text = ""
                separator = #True
                RemoveMenuItemEx(menuScrollHandle, 2, #True)
                menuScrollEndPos = menuScrollEndPos + 1
            EndIf
            
            If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            ImageList = itemex()\ImageList
            normal = itemex()\normal
            hot = itemex()\hot
            disabled = itemex()\disabled
            InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
            mnfo\fMask = #MIIM_STATE
            SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
            If normal <> 0
                itemex()\ImageList = ImageList_Duplicate_(ImageList)
                itemex()\normal = normal
                itemex()\hot = hot
                itemex()\disabled = disabled
            EndIf
            
            
            height = CalcMenuItemHeight(menuScrollHandle)
            If height < menuScrollHeight
                menuScrollPos = menuScrollPos + 1
                mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
                If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
                    ChangeCurrentElement(itemex(), mnfo\dwItemData)
                EndIf
                ImageList = itemex()\ImageList
                normal = itemex()\normal
                hot = itemex()\hot
                disabled = itemex()\disabled
                InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
                mnfo\fMask = #MIIM_STATE
                SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
                If normal <> 0
                    itemex()\ImageList = ImageList_Duplicate_(ImageList)
                    itemex()\normal = normal
                    itemex()\hot = hot
                    itemex()\disabled = disabled
                EndIf
                
                ; check if we need to increase filler
                height = CalcMenuItemHeight(menuScrollHandle)
                If height < menuScrollHeight
                    menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
                    RemoveMenuItemEx(menuScrollHandle, 1, #True)
                    InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                EndIf
            EndIf
            
            
            ; check if we need to decrease filler
            height = CalcMenuItemHeight(menuScrollHandle)
            If height > menuScrollHeight
                
                menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
                
                ; check height again and if still too big then remove previous item and increase filler
                ;height = CalcMenuItemHeight(menuScrollHandle)
                If menuScrollFillerHeight < 0
                    menuScrollPos = menuScrollPos - 1
                    RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
                    menuScrollFillerHeight = 0
                    height = CalcMenuItemHeight(menuScrollHandle)
                    menuScrollFillerHeight = menuScrollHeight-height
                EndIf
                
                RemoveMenuItemEx(menuScrollHandle, 1, #True)
                InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
            EndIf
            
            
            ; check if we're near the end and if the last few items will fit in the filler+button space
            If menuScrollPos >= GetMenuItemCount_(originalScrollMenu)-4
                height = 0
                hdc = GetWindowDC_(WindowID)
                pos = menuScrollPos+1
                For n = pos To GetMenuItemCount_(originalScrollMenu)-1
                    mnfo\fMask = #MIIM_DATA
                    If GetMenuItemInfo_(originalScrollMenu, n, #True, @mnfo) <> 0
                        ChangeCurrentElement(itemex(), mnfo\dwItemData)
                        height = height + measureMenuItemHeight(hdc, @itemex())
                    EndIf
                Next
                
                ; the end will fit
                If height <= menuScrollButtonHeight+menuScrollFillerHeight
                    ; remove bottom button
                    RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #True)
                    For n = pos To GetMenuItemCount_(originalScrollMenu)-1
                        mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
                        If GetMenuItemInfo_(originalScrollMenu, n, #True, @mnfo) <> 0
                            ChangeCurrentElement(itemex(), mnfo\dwItemData)
                            ImageList = itemex()\ImageList
                            normal = itemex()\normal
                            hot = itemex()\hot
                            disabled = itemex()\disabled
                            InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle), mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
                            mnfo\fMask = #MIIM_STATE
                            SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
                            If normal <> 0
                                itemex()\ImageList = ImageList_Duplicate_(ImageList)
                                itemex()\normal = normal
                                itemex()\hot = hot
                                itemex()\disabled = disabled
                            EndIf
                            
                        EndIf
                    Next
                    
                    ; check if we need to increase or decrease filler
                    height = CalcMenuItemHeight(menuScrollHandle)
                    If height < menuScrollHeight
                        
                        menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
                        RemoveMenuItemEx(menuScrollHandle, 1, #True)
                        InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                        
                    ElseIf height > menuScrollHeight
                        
                        menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
                        RemoveMenuItemEx(menuScrollHandle, 1, #True)
                        InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                    EndIf
                    
                    menuScrollEnd = #True
                EndIf
                ReleaseDC_(WindowID, hdc)
            EndIf
            
            menuScrolling = #False
            SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
            RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_UPDATENOW);|#RDW_ERASE)
            
            ;-/ scroll up  
        Else
            
            ; have we just started scrolling up and bottom button is missing
            If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            hdc = GetWindowDC_(WindowID)
            If itemex()\scroll = 0
                
                menuScrollPos = (GetMenuItemCount_(originalScrollMenu)-1) - (GetMenuItemCount_(menuScrollHandle)-2)
                menuScrollEndPos = GetMenuItemCount_(originalScrollMenu)-2
                If GetMenuItemInfo_(menuScrollHandle, 0, #True, @mnfo) <> 0
                    ChangeCurrentElement(itemex(), mnfo\dwItemData)
                EndIf
                
                height = measureMenuItemHeight(hdc, @itemex())-menuScrollFillerHeight
                
                SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
                
                ; add to bottom down button
                InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle), #MENUSCROLLDOWNID, "", 0, 0, 0, -1)
                RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
                
                menuScrolling = #False
                SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
                RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_NOERASE|#RDW_UPDATENOW)
                menuScrolling = #True
                
                s = speed
                GetClientRect_(WindowID, @rc.RECT)
                rc\top = menuScrollButtonHeight-5
                rc\bottom = (rc\bottom - menuScrollButtonHeight)-1
                
                frames = height/speed
                For n = 0 To frames-1
                    ScrollWindow_(WindowID, 0, s, rc, 0)
                    Delay(10)
                Next
                
                SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
                
                ; remove filler from top and add to bottom
                RemoveMenuItemEx(menuScrollHandle, 1, #True)
                menuScrollFillerHeight = 7
                InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                
                ; if 2nd item to remove is separator then remove
                If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True, @mnfo) <> 0
                    ChangeCurrentElement(itemex(), mnfo\dwItemData)
                EndIf
                If itemex()\text = ""
                    separator = #True
                    RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True)
                    menuScrollEndPos = menuScrollEndPos - 1
                EndIf
                
            Else
                
                If GetMenuItemInfo_(menuScrollHandle, 1, #True, @mnfo) <> 0
                    ChangeCurrentElement(itemex(), mnfo\dwItemData)
                EndIf
                If itemex()\scroll = -3
                    height = menuScrollButtonHeight-menuScrollFillerHeight
                Else
                    height = menuScrollButtonHeight
                EndIf
                
                s = speed
                GetClientRect_(WindowID, @rc.RECT)
                rc\top = menuScrollButtonHeight-5
                rc\bottom = (rc\bottom - menuScrollButtonHeight)-1
                frames = height/speed
                For n = 0 To frames-1
                    ScrollWindow_(WindowID, 0, s, rc, 0)
                    Delay(10)
                Next
                
                menuScrollPos = menuScrollPos - 1
                
            EndIf
            ReleaseDC_(WindowID, hdc) 
            
            SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
            
            ; check if filler is at top and if so prepare for scroll up
            If GetMenuItemInfo_(menuScrollHandle, 1, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            If itemex()\scroll = -3
                
                RemoveMenuItemEx(menuScrollHandle, 1, #True)
                menuScrollFillerHeight = 7
                InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                t = menuScrollPos
                menuScrollPos = menuScrollEndPos-1
                menuScrollEndPos = t+1
                
            Else
                ; remove filler
                If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True, @mnfo) <> 0
                    ChangeCurrentElement(itemex(), mnfo\dwItemData)
                EndIf
                If itemex()\scroll = -3
                    RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
                    menuScrollFillerHeight = 7
                    InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                EndIf
            EndIf
            
            ; if 1st item to remove is separator then remove
            If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            If itemex()\text = ""
                separator = #True
                RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True)
                menuScrollEndPos = menuScrollEndPos - 1
            EndIf
            
            RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True)
            menuScrollEndPos = menuScrollEndPos - 1
            
            ; if 2nd item to remove is separator then remove
            If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            If itemex()\text = ""
                separator = #True
                RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True)
                menuScrollEndPos = menuScrollEndPos - 1
            EndIf
            
            If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
                ChangeCurrentElement(itemex(), mnfo\dwItemData)
            EndIf
            ImageList = itemex()\ImageList
            normal = itemex()\normal
            hot = itemex()\hot
            disabled = itemex()\disabled
            InsertMenuItemEx(menuScrollHandle, 1, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
            mnfo\fMask = #MIIM_STATE
            SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
            If normal <> 0
                itemex()\ImageList = ImageList_Duplicate_(ImageList)
                itemex()\normal = normal
                itemex()\hot = hot
                itemex()\disabled = disabled
            EndIf
            
            
            height = CalcMenuItemHeight(menuScrollHandle)
            If height < menuScrollHeight
                menuScrollPos = menuScrollPos - 1
                mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
                If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
                    ChangeCurrentElement(itemex(), mnfo\dwItemData)
                EndIf
                ImageList = itemex()\ImageList
                normal = itemex()\normal
                hot = itemex()\hot
                disabled = itemex()\disabled
                InsertMenuItemEx(menuScrollHandle, 1, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
                mnfo\fMask = #MIIM_STATE
                SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
                If normal <> 0
                    itemex()\ImageList = ImageList_Duplicate_(ImageList)
                    itemex()\normal = normal
                    itemex()\hot = hot
                    itemex()\disabled = disabled
                EndIf
                
                ; check if we need to increase filler
                height = CalcMenuItemHeight(menuScrollHandle)
                If height < menuScrollHeight
                    menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
                    RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
                    InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                EndIf
            EndIf
            
            
            ; check if we need to decrease filler
            height = CalcMenuItemHeight(menuScrollHandle)
            If height > menuScrollHeight
                
                menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
                
                ; check height again and if still too big then remove previous item and increase filler
                ;height = CalcMenuItemHeight(menuScrollHandle)
                If menuScrollFillerHeight < 0
                    menuScrollPos = menuScrollPos + 1
                    RemoveMenuItemEx(menuScrollHandle, 1, #True)
                    menuScrollFillerHeight = 0
                    height = CalcMenuItemHeight(menuScrollHandle)
                    menuScrollFillerHeight = menuScrollHeight-height
                EndIf
                
                RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
                InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
            EndIf
            
            
            ; check if we're near the top and if the last few items will fit in the filler+button space
            If menuScrollPos <= 3
                height = 0
                hdc = GetWindowDC_(WindowID)
                pos = menuScrollPos-1
                For n = pos To 0 Step -1
                    mnfo\fMask = #MIIM_DATA
                    If GetMenuItemInfo_(originalScrollMenu, n, #True, @mnfo) <> 0
                        ChangeCurrentElement(itemex(), mnfo\dwItemData)
                        height = height + measureMenuItemHeight(hdc, @itemex())
                    EndIf
                Next
                
                ; top will fit
                If height <= menuScrollButtonHeight+menuScrollFillerHeight
                    
                    ; remove top button
                    RemoveMenuItemEx(menuScrollHandle, 0, #True)
                    For n = pos To 0 Step -1
                        mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
                        If GetMenuItemInfo_(originalScrollMenu, n, #True, @mnfo) <> 0
                            ChangeCurrentElement(itemex(), mnfo\dwItemData)
                            ImageList = itemex()\ImageList
                            normal = itemex()\normal
                            hot = itemex()\hot
                            disabled = itemex()\disabled
                            InsertMenuItemEx(menuScrollHandle, 0, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
                            mnfo\fMask = #MIIM_STATE
                            SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
                            If normal <> 0
                                itemex()\ImageList = ImageList_Duplicate_(ImageList)
                                itemex()\normal = normal
                                itemex()\hot = hot
                                itemex()\disabled = disabled
                            EndIf
                            
                        EndIf
                    Next
                    
                    ; check if we need to increase filler
                    height = CalcMenuItemHeight(menuScrollHandle)
                    If height < menuScrollHeight
                        
                        menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
                        RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
                        InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                        
                    ElseIf height > menuScrollHeight
                        
                        menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
                        RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
                        InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
                    EndIf
                    
                    menuScrollEnd = #True
                EndIf
                ReleaseDC_(WindowID, hdc)
            EndIf
            
            menuScrolling = #False
            SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
            RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_UPDATENOW);|#RDW_ERASE)
            
        EndIf
        
        menuScrolling = #False
        
        ReleaseCapture_()
        
        
        ;- scroll end
    Until menuScrollActive = #False Or menuScrollEnd = #True
    
    menuScrollThread = 0
    menuScrollEnd = #False
    
EndProcedure

;- createScrollMenu macro
Macro createScrollMenu()
    
    menuex()\active = -1
    *realMenuEx = @menuex()
    
    originalScrollMenu = menuex()\popupid
    style = menuex()\style
    toolbarID = menuex()\toolbarID
    buttonID = menuex()\buttonID
    win = menuex()\WindowID
    
    menuScrollHandle = CreatePopupMenuEx(#ProGUI_Any, style)
    menuex()\toolbarID = toolbarID
    menuex()\buttonID = buttonID
    menuex()\WindowID = win
    
    count = GetMenuItemCount_(originalScrollMenu)
    mnfo.MENUITEMINFO_Fixed
    mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    For n = 0 To count-1
        mnfo\fMask = #MIIM_DATA|#MIIM_ID|#MIIM_SUBMENU|#MIIM_STATE
        If GetMenuItemInfo_(originalScrollMenu, n, #True, @mnfo) <> 0
            ChangeCurrentElement(itemex(), mnfo\dwItemData)
            
            ; grab item height into menuScrollButtonHeight and set menusidebarpadding
            If itemHeight = 0 And itemex()\text <> ""
                hdc = CreateCompatibleDC_(0)
                menuScrollButtonHeight = measureMenuItemHeight(hdc, mnfo\dwItemData)
                GetObject_(currentMenuEXFont, SizeOf(LOGFONT), @fontnfo.LOGFONT)
                fheight = fontnfo\lfHeight
                fheight = fontnfo\lfHeight: If fheight<0: fheight = -fheight: EndIf
                fheight*72.0/GetScreenDPI()
                menuSideBarPadding = calcSidebarPadding(fheight)-2
                DeleteDC_(hdc)
            EndIf
            
            ImageList = itemex()\ImageList
            normal = itemex()\normal
            hot = itemex()\hot
            disabled = itemex()\disabled
            text.s = itemex()\text
            
            ; add hotkey
            p = FindString(itemex()\text, "&", 1)
            If p > 0
                h.s = Mid(itemex()\text, p+1, 1)
                AddElement(menuScrollHotKey())
                menuScrollHotKey()\hotkey = UCase(h)
                menuScrollHotKey()\id = mnfo\wID
            EndIf
            
            MenuItemEx(mnfo\wID, text, 0, 0, 0, mnfo\hSubMenu)
            mnfo\fMask = #MIIM_STATE
            SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
            If normal <> 0
                itemex()\ImageList = ImageList_Duplicate_(ImageList)
                itemex()\normal = normal
                itemex()\hot = hot
                itemex()\disabled = disabled
            EndIf
        Else
            Break
        EndIf
    Next
    
    ; remove items from menu until fits
    count = n
    Repeat
        n = GetMenuItemCount_(menuex()\popupid)-1
        RemoveMenuItemEx(menuScrollHandle, n, #True)
        height = CalcMenuItemHeight(menuex()\popupid)
        If rect\bottom+height+7+menuScrollButtonHeight < minfo\rcWork\bottom-2
            menuTitleVOffset = 0
            Break
        ElseIf (rect\top+vertoffset)-(height+7+menuScrollButtonHeight) > minfo\rcWork\top
            menuTitleVOffset = -1
            Break
        EndIf
    ForEver
    
    menuScrollFillerHeight = 7
    MenuItemEx(#MENUSCROLLFILLERID, "", 0, 0, 0, 0)
    itemex()\scroll = -3 ; filler
    MenuItemEx(#MENUSCROLLDOWNID, "", 0, 0, 0, 0)
    itemex()\scroll = -1 ; scroll down button
    
    
    menuScrollWidth = width-GetSystemMetrics_(#SM_CXMENUCHECK)
    menuScrollHeight = CalcMenuItemHeight(menuScrollHandle)
    height = menuScrollHeight
    
EndMacro

Structure menuErase
    Buffer.i
    hdc.i
    rc.RECT
    vrc.RECT
EndStructure

Procedure doMenuTrackBufferedErase(toolbar.i, *brc.RECT)
    Static menuErase.menuErase
    
    ; copy menu tracked area into buffer
    If toolbar > 0 Or toolbar < -2
        
        thisMenuEx = @menuex()
        thisItemEx = @itemex()
        
        ; calculate required buffer size to fit entire possible menu track area
        count = SendMessage_(toolbar, #TB_BUTTONCOUNT, 0, 0)-1
        For p = 0 To count
            SendMessage_(toolbar, #TB_GETITEMRECT, p, @rc.RECT)
            MapWindowPoints_(toolbar, 0, @rc, 2)
            SendMessage_(toolbar, #TB_GETBUTTON, p, @bnfo.TBBUTTON)
            If p = 0
                left = rc\left
                right = rc\right
                top = rc\top
                bottom = rc\bottom
            EndIf
            
            ForEach menuex()
                If menuex()\toolbarID = toolbar And menuex()\buttonID = bnfo\idCommand
                    height = CalcMenuItemHeight(menuex()\popupid)
                    width = CalcMenuItemWidth(menuex()\popupid)
                    If rc\top-height < top
                        top = rc\top-height
                    EndIf
                    If rc\bottom+height > bottom
                        bottom = rc\bottom+height
                    EndIf
                    If rc\left+width > right
                        right = rc\left+width
                    EndIf
                    Break
                EndIf
            Next
            
        Next
        
        width = right-left
        debuglog("width:"+Str(width))
        height = bottom-top
        
        dhwnd = GetDesktopWindow_()
        dhdc = GetDC_(dhwnd)
        ;dhdc = GetDC_(0)
        
        ; setup buffer if not already created
        If menuErase\hdc = 0
            menuErase\hdc = CreateCompatibleDC_(dhdc)
            menuErase\Buffer = CreateCompatibleBitmap_(dhdc, width, height)
            SelectObject_(menuErase\hdc, menuErase\Buffer)
            debuglog("create")
        Else
            ; check if the buffer needs to grow
            If width > menuErase\rc\right-menuErase\rc\left Or height > menuErase\rc\bottom-menuErase\rc\top
                DeleteObject_(menuErase\Buffer)
                menuErase\Buffer = CreateCompatibleBitmap_(dhdc, width, height)
                SelectObject_(menuErase\hdc, menuErase\Buffer)
                debuglog("bigger")
            EndIf
        EndIf
        
        ; copy menu tracked area of screen into buffer
        ;debuglog("copying screen area")
        menuEraseBufferInvalid = 0
        menuErase\rc\top = top
        menuErase\rc\bottom = bottom
        menuErase\rc\left = left
        menuErase\rc\right = right
        
        menuErase\vrc\top = 0
        menuErase\vrc\left = 0
        menuErase\vrc\bottom = 0
        menuErase\vrc\right = 0
        ;BitBlt_(menuErase\hdc, 0, 0, width, height, dhdc, left, top, #SRCCOPY)
        
        ReleaseDC_(dhwnd, dhdc)
        
        ChangeCurrentElement(itemex(), thisItemEx)
        ChangeCurrentElement(menuex(), thisMenuEx)
        
        ; do blit of buffer to screen using *brc coords
    ElseIf toolbar = 0
        If *brc <> 0
            
            ;*brc\top = *brc\top+1
            ;*brc\bottom = *brc\bottom+1
            dhdc = GetDC_(0)
            BitBlt_(dhdc, *brc\left, *brc\top, *brc\right-*brc\left, *brc\bottom-*brc\top, menuErase\hdc, *brc\left-menuErase\rc\left, *brc\top-menuErase\rc\top, #SRCCOPY)
            ReleaseDC_(0, dhdc)
            
        EndIf
        ; update buffer with area in *brc
    ElseIf toolbar = -1
        If *brc <> 0
            
            dhdc = GetDC_(0)
            
            If IntersectRect(*brc, menuErase\vrc)
                
                If *brc\left < menuErase\vrc\left Or *brc\right > menuErase\vrc\right Or *brc\top < menuErase\vrc\top Or *brc\bottom > menuErase\vrc\bottom ;EqualRect_(nrec, *brc) = 0
                    
                    If *brc\right > menuErase\vrc\right
                        CopyRect_(@rc.RECT, *brc)
                        rc\left = menuErase\vrc\right
                        BitBlt_(menuErase\hdc, rc\left-menuErase\rc\left, rc\top-menuErase\rc\top, rc\right-rc\left, rc\bottom-rc\top, dhdc, rc\left, rc\top, #SRCCOPY)
                    EndIf
                    
                    If *brc\left < menuErase\vrc\left
                        CopyRect_(@rc.RECT, *brc)
                        rc\right = menuErase\vrc\left
                        BitBlt_(menuErase\hdc, rc\left-menuErase\rc\left, rc\top-menuErase\rc\top, rc\right-rc\left, rc\bottom-rc\top, dhdc, rc\left, rc\top, #SRCCOPY)
                    EndIf
                    
                    If *brc\top < menuErase\vrc\top
                        CopyRect_(@rc.RECT, *brc)
                        rc\bottom = menuErase\vrc\top
                        ;rc\left = menuErase\vrc\left
                        ;rc\right = menuErase\vrc\right
                        BitBlt_(menuErase\hdc, rc\left-menuErase\rc\left, rc\top-menuErase\rc\top, rc\right-rc\left, rc\bottom-rc\top, dhdc, rc\left, rc\top, #SRCCOPY)
                    EndIf
                    
                    If *brc\bottom > menuErase\vrc\bottom
                        CopyRect_(@rc.RECT, *brc)
                        rc\top = menuErase\vrc\bottom
                        ;rc\left = menuErase\vrc\left
                        ;rc\right = menuErase\vrc\right
                        BitBlt_(menuErase\hdc, rc\left-menuErase\rc\left, rc\top-menuErase\rc\top, rc\right-rc\left, rc\bottom-rc\top, dhdc, rc\left, rc\top, #SRCCOPY)
                    EndIf
                    
                    CopyRect_(menuErase\vrc, *brc)
                    
                EndIf
                
            Else
                CopyRect_(menuErase\vrc, *brc)
                BitBlt_(menuErase\hdc, *brc\left-menuErase\rc\left, *brc\top-menuErase\rc\top, *brc\right-*brc\left, *brc\bottom-*brc\top, dhdc, *brc\left, *brc\top, #SRCCOPY)
            EndIf
            
            
            ;BitBlt_(menuErase\hdc, *brc\left-menuErase\rc\left, *brc\top-menuErase\rc\top, *brc\right-*brc\left, *brc\bottom-*brc\top, dhdc, *brc\left, *brc\top, #SRCCOPY)
            
            ;BitBlt_(menuErase\hdc, 0, 0, *brc\left-menuErase\rc\left, menuErase\rc\bottom-menuErase\rc\top, dhdc, menuErase\rc\left, menuErase\rc\top, #SRCCOPY)
            ;debuglog(Str(*brc\right-menuErase\rc\left))
            ;BitBlt_(menuErase\hdc, *brc\right-menuErase\rc\left, 0, menuErase\rc\right-*brc\right, menuErase\rc\bottom-menuErase\rc\top, dhdc, *brc\right, menuErase\rc\top, #SRCCOPY)
            ;trc.RECT
            ;trc\left = *brc\right
            ;trc\right = menuErase\rc\right
            ;trc\top = 0
            ;trc\bottom = menuErase\rc\bottom
            ;FillRect_(dhdc, trc, CreateSolidBrush_(RGB(255,0,0)))
            ReleaseDC_(0, dhdc)
            
        EndIf
        
    ElseIf toolbar = -2
        If *brc <> 0
            dhdc = GetDC_(0)
            BitBlt_(menuErase\hdc, *brc\left-menuErase\rc\left, *brc\top-menuErase\rc\top, *brc\right-*brc\left, *brc\bottom-*brc\top, dhdc, *brc\left, *brc\top, #SRCCOPY)
            ReleaseDC_(0, dhdc)
        EndIf
    EndIf
    
    
EndProcedure

Structure enumInvalidate
    excludeHwnd.i
    found.l
    rec.RECT
EndStructure

Procedure enumInvalidateWinProc(hwnd, lParam)
    
    *enum.enumInvalidate = lParam
    
    If *enum\excludeHwnd = hwnd Or *enum\excludeHwnd = 0
        *enum\found = #True
    EndIf
    
    If *enum\excludeHwnd <> hwnd And *enum\found = #True And IsWindowVisible_(hwnd) <> 0
        GetWindowRect_(hwnd, @rc.RECT)
        If IntersectRect_(@urec.RECT, *enum\rec, rc) <> 0
            
            CopyRect_(@mrec.RECT, urec)
            MapWindowPoints_(0, hwnd, @mrec, 2)
            
            
            ; little hack to get rid of none erasure of edge of desktop when app maximised on next monitor
            ;       prc.RECT
            ;       prc\left = urec\right-4
            ;       prc\top = urec\top
            ;       prc\right = prc\left
            ;       prc\bottom = prc\top
            ;       hmonitor = MonitorFromRect_(@prc, #MONITOR_DEFAULTTONEAREST)
            ;       minfo.MONITORINFO
            ;       minfo\cbSize = SizeOf(MONITORINFO)
            ;       GetMonitorInfo_(hmonitor, @minfo)
            ;       If urec\right >= minfo\rcMonitor\right-4
            ;         mrec\right = mrec\right + 4
            ;       EndIf
            
            RedrawWindow_(hwnd, mrec, 0, #RDW_INVALIDATE|#RDW_FRAME|#RDW_ERASE|#RDW_ALLCHILDREN|#RDW_ERASENOW|#RDW_INTERNALPAINT|#RDW_UPDATENOW)
            
            If *enum\rec\left = urec\left And *enum\rec\right = urec\right And *enum\rec\top = urec\top And *enum\rec\bottom = urec\bottom
                ProcedureReturn 0
            EndIf
            
            SubtractRect_(@nrec.RECT, *enum\rec, urec)
            CopyRect_(*enum\rec, nrec)
            
        EndIf
    EndIf
    
    ProcedureReturn #True
EndProcedure

Procedure invalidateScrnRec(*rec.RECT, excludeHwnd)
    
    enum.enumInvalidate
    enum\excludeHwnd = excludeHwnd
    CopyRect_(@enum\rec, *rec)
    EnumWindows_(@enumInvalidateWinProc(), @enum)
    
EndProcedure

Procedure doMenuTrackErase(WindowID)
    
    If menuex()\active <> 0 And menuScrolling = #False And menuScrollActive = #False And lastMenuWidth <> 0
        GetWindowRect_(WindowID, @rec.RECT)
        
        If lastMenuX = rec\left And lastMenuY = rec\top
            ProcedureReturn 0
        EndIf
        
        rc.RECT
        rc\left = lastMenuX
        rc\right = lastMenuX+lastMenuWidth
        rc\top = lastMenuY
        rc\bottom = lastMenuY+lastMenuHeight
        If IntersectRect(rc, rec) = 0
            
            If lastMenuY < rec\top And lastMenuX < rec\left
                rc\bottom = rc\bottom-1
            ElseIf lastMenuY > rec\top And lastMenuX < rec\left
                rc\top = rc\top+1
            EndIf
            
            invalidateScrnRec(@rc, WindowID)
            lastMenuX = 0
            lastMenuY = 0
            lastMenuWidth = 0
            lastMenuHeight = 0
            ProcedureReturn 0
        EndIf
        
        
        If lastMenuX < rec\left
            
            rc.RECT
            rc\left = lastMenuX
            rc\right = rec\left
            rc\top = lastMenuY
            rc\bottom = lastMenuY+lastMenuHeight
            
            If menuEraseBufferInvalid = #True Or menuEraseBuffered = #False
                invalidateScrnRec(@rc, WindowID)
                If menuEraseBuffered = #True
                    doMenuTrackBufferedErase(-2, @rc)
                EndIf
            Else
                doMenuTrackBufferedErase(0, @rc)
            EndIf
            
        EndIf
        
        If lastMenuX+lastMenuWidth > rec\right
            
            rc.RECT
            rc\left = rec\right
            rc\right = lastMenuX+lastMenuWidth
            rc\top = lastMenuY
            rc\bottom = lastMenuY+lastMenuHeight
            
            If menuEraseBufferInvalid = #True Or menuEraseBuffered = #False
                invalidateScrnRec(@rc, WindowID)
                If menuEraseBuffered = #True
                    doMenuTrackBufferedErase(-2, @rc)
                EndIf
            Else
                doMenuTrackBufferedErase(0, @rc)
            EndIf
            
        EndIf
        
        If lastMenuY+lastMenuHeight > rec\bottom
            
            rc.RECT
            rc\left = lastMenuX
            rc\right = lastMenuX+lastMenuWidth
            rc\top = rec\bottom
            rc\bottom = lastMenuY+lastMenuHeight
            
            If menuEraseBufferInvalid = #True Or menuEraseBuffered = #False
                invalidateScrnRec(@rc, WindowID)
                If menuEraseBuffered = #True
                    doMenuTrackBufferedErase(-2, @rc)
                EndIf
            Else
                doMenuTrackBufferedErase(0, @rc)
            EndIf
            
        EndIf
        
        If lastMenuY < rec\top
            
            rc.RECT
            rc\left = lastMenuX
            rc\right = lastMenuX+lastMenuWidth
            rc\top = lastMenuY
            rc\bottom = rec\top
            
            If menuEraseBufferInvalid = #True Or menuEraseBuffered = #False
                invalidateScrnRec(@rc, WindowID)
                If menuEraseBuffered = #True
                    doMenuTrackBufferedErase(-2, @rc)
                EndIf
            Else
                doMenuTrackBufferedErase(0, @rc)
            EndIf
            
        EndIf
        
        lastMenuX = 0
        lastMenuY = 0
        lastMenuWidth = 0
        lastMenuHeight = 0
        
    EndIf
    
EndProcedure

Procedure eraseLastMenu()
    
    rc.RECT
    rc\left = lastMenuX
    rc\right = lastMenuX+lastMenuWidth
    rc\top = lastMenuY
    rc\bottom = lastMenuY+lastMenuHeight
    invalidateScrnRec(@rc, 0)
    
    lastMenuX = 0
    lastMenuY = 0
    lastMenuWidth = 0
    lastMenuHeight = 0
    
EndProcedure



Global redrawWait = 0
Procedure MyWindowCallback(WindowID,message,wParam,lParam)
    Static mouseCaptured
    ;/ *** stealth protection make the process become slowly unstable if HaltProGUI detected
    Static HaltElapsed
    If HaltProGUI = #True And HaltElapsed = 0
        HaltElapsed = ElapsedMilliseconds()
    EndIf
    If HaltElapsed > 0 And ElapsedMilliseconds() > HaltElapsed+60000 ; after minute
        If Random(500) = 0
            *mem = AllocateMemory(100)
            For n = 0 To Random(1000)
                PokeB(*mem+n, Random(255))
            Next
        EndIf
    EndIf
    ;/^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
    
    ; find old callback for window id
    ForEach menuCallback()
        If menuCallback()\WindowID = WindowID
            ProGUIOldCallBack = menuCallback()\oldCallback
            Result = CallWindowProc_(ProGUIOldCallBack,WindowID,message,wParam,lParam)
            Break
        EndIf
    Next
    
    
    ;debuglog("message: "+Hex(message))
    Select message
            
            
            ;Case #WM_PAINT
            
            ;ProcedureReturn 0
            
            ;Case #WM_ERASEBKGND
            
            ;  ProcedureReturn result
            ;  Result = 1
            
            
            ;/ handle styled combobox gadget in toolbarex states, i.e dropdown etc...
        Case #WM_COMMAND
            
            If HIWORD(wParam) = #CBN_DROPDOWN
                
                ; makesure combobox is in a toolbarEx
                If ListSize(toolbarExButton()) > 0
                    *thistoolbarExButton = @toolbarExButton()
                    found = 0
                    ForEach toolbarExButton()
                        If toolbarExButton()\gadget = lParam And toolbarExButton()\gadgetStyled <> 0
                            
                            toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState | #TOOLBAREXGADGET_DROPDOWN
                            
                            GetClientRect_(toolbarExButton()\gadget, @trc.RECT)
                            MapWindowPoints_(toolbarExButton()\gadget, toolbarExButton()\toolbarExHandle, @trc, 2)
                            RedrawWindow_(toolbarExButton()\toolbarExHandle, trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ALLCHILDREN)
                            
                            Break
                        EndIf
                    Next
                    ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
                EndIf
                
            ElseIf HIWORD(wParam) = #CBN_CLOSEUP
                
                ; makesure combobox is in a toolbarEx
                If ListSize(toolbarExButton()) > 0
                    *thistoolbarExButton = @toolbarExButton()
                    found = 0
                    ForEach toolbarExButton()
                        If toolbarExButton()\gadget = lParam And toolbarExButton()\gadgetStyled <> 0
                            
                            toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState &~ #TOOLBAREXGADGET_DROPDOWN
                            
                            pt.POINT
                            GetCursorPos_(@pt)
                            hwnd = WindowFromPoint_(PeekQ(pt))
                            If hwnd <> toolbarExButton()\gadget And GetParent_(hwnd) <> toolbarExButton()\gadget
                                toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState &~ #TOOLBAREXGADGET_HOVER
                            EndIf
                            
                            GetClientRect_(toolbarExButton()\gadget, @trc.RECT)
                            MapWindowPoints_(toolbarExButton()\gadget, toolbarExButton()\toolbarExHandle, @trc, 2)
                            RedrawWindow_(toolbarExButton()\toolbarExHandle, trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ALLCHILDREN)
                            
                            Break
                        EndIf
                    Next
                    ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
                EndIf
                
                ;       ElseIf HIWORD(wParam) = #CBN_SETFOCUS
                ;         
                ;         ; makesure combobox is in a toolbarEx
                ;         If ListSize(toolbarExButton()) > 0
                ;           *thistoolbarExButton = @toolbarExButton()
                ;           found = 0
                ;           ForEach toolbarExButton()
                ;             If toolbarExButton()\gadget = lParam And toolbarExButton()\gadgetStyled <> 0
                ;               
                ;               toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState | #TOOLBAREXGADGET_FOCUS
                ;               
                ;               GetClientRect_(toolbarExButton()\gadget, @trc.RECT)
                ;               MapWindowPoints_(toolbarExButton()\gadget, toolbarExButton()\toolbarExHandle, @trc, 2)
                ;               RedrawWindow_(toolbarExButton()\toolbarExHandle, trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ALLCHILDREN)
                ;               
                ;               Break
                ;             EndIf
                ;           Next
                ;           ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
                ;         EndIf
                ;         
                ;       ElseIf HIWORD(wParam) = #CBN_KILLFOCUS
                ;         
                ;         ; makesure combobox is in a toolbarEx
                ;         If ListSize(toolbarExButton()) > 0
                ;           *thistoolbarExButton = @toolbarExButton()
                ;           found = 0
                ;           ForEach toolbarExButton()
                ;             If toolbarExButton()\gadget = lParam And toolbarExButton()\gadgetStyled <> 0
                ;               
                ;               toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState &~ #TOOLBAREXGADGET_FOCUS
                ;               
                ;               GetClientRect_(toolbarExButton()\gadget, @trc.RECT)
                ;               MapWindowPoints_(toolbarExButton()\gadget, toolbarExButton()\toolbarExHandle, @trc, 2)
                ;               RedrawWindow_(toolbarExButton()\toolbarExHandle, trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ALLCHILDREN)
                ;               
                ;               Break
                ;             EndIf
                ;           Next
                ;           ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
                ;         EndIf
                
            EndIf
            
            ;/ detect if windows theme has changed
        Case #WM_THEMECHANGED
            
            If XPthemeActive <> 0
                
                CallFunctionFast(*CloseThemeData, hTheme)
                Window = GetForegroundWindow_()
                hTheme = OpenThemeData(Window, "scrollbar")
                If hTheme <> 0
                    XPthemeColour = CallFunctionFast(*GetThemeSysColor, hTheme, 2)
                    SetDefaultGlobalSkinColourTheme(XPthemeColour)
                EndIf
                *tmem = AllocateMemory(255)
                CallFunction(XPthemeActive, "GetCurrentThemeName", *tmem, 100, 0, 0, 0, 0)
                name.s = PeekS(*tmem, -1, #PB_Unicode)
                FreeMemory(*tmem)
                If name <> ""
                    ThemesEnabled = #True
                Else
                    ThemesEnabled = 0
                EndIf
                
                If hTheme <> 0
                    CallFunctionFast(*CloseThemeData, hThemeExplorerbar)
                    CallFunctionFast(*CloseThemeData, hThemeRebar)
                    CallFunctionFast(*CloseThemeData, hThemeTab)
                    CallFunctionFast(*CloseThemeData, hThemeToolbar)
                    CallFunctionFast(*CloseThemeData, hThemeMenu)
                    CallFunctionFast(*CloseThemeData, hThemeButton)
                EndIf
                
                hThemeExplorerbar = OpenThemeData(Window, "explorerbar")
                hThemeRebar = OpenThemeData(Window, "rebar")
                hThemeTab = OpenThemeData(Window, "tab")
                hThemeToolbar = OpenThemeData(Window, "toolbar")
                hThemeMenu = OpenThemeData(Window, "menu")
                hThemeButton = OpenThemeData(Window, "button")
                
            Else
                ThemesEnabled = 0
                hTheme = 0
            EndIf
            
            If Dwmapi <> 0
                CallFunctionFast(*DwmIsCompositionEnabled, @CompositionEnabled)
            EndIf
            
            ; flush blitEx cache
            blitExFlush()
            
            ; flag cached menu buffer for re-draw
            LockMutex(menuMutex)
            ForEach menuex()
                menuex()\bufferWidth = 0
                menuex()\bufferHeight = 0
            Next
            UnlockMutex(menuMutex)
            
            ; re-render any styled rebar backgrounds with new theme
            RenderRebarBackgrounds(#True)
            
            ;/ detect desktop composition (Aero) state changed
        Case #WM_DWMCOMPOSITIONCHANGED
            
            If Dwmapi <> 0
                CallFunctionFast(*DwmIsCompositionEnabled, @CompositionEnabled)
            EndIf
            
            ;/ detect if menu window gains/looses focus
        Case #WM_ACTIVATE
            
            LockMutex(menuMutex)
            
            ;scan menues for window that matches this event
            temptoolbarid = -1
            ForEach menuex()
                
                If menuex()\WindowID = WindowID
                    
                    ; grey out menu title
                    If PeekB(@wParam) = #WA_INACTIVE
                        menuex()\greyed = -1
                        
                        ; destroy all title dropshadows if exists
                        If ListSize(titleShadow()) > 0
                            ForEach titleShadow()
                                DestroyWindow_(titleShadow()\rightShadow)
                                DestroyWindow_(titleShadow()\bottomShadow)
                                DeleteElement(titleShadow())
                            Next
                        EndIf
                        
                    Else
                        menuex()\greyed = 0
                    EndIf
                    
                    If temptoolbarid <> menuex()\toolbarID
                        RedrawWindow_(menuex()\toolbarID, 0, 0, 7)
                        temptoolbarid = menuex()\toolbarID
                    EndIf
                    
                EndIf
                
            Next
            
            UnlockMutex(menuMutex)
            
            Result = 0
            
        Case #WM_SIZING
            
            resizing = -1
            
            ; hack to change toolbar to clip children while dragging, removes flickering of child gadgets
            If ListSize(toolbarEx()) > 0
                *thistoolbarEx = @toolbarEx()
                ForEach toolbarEx()
                    If GetParent_(GetParent_(toolbarEx()\Handle)) = WindowID
                        
                        SetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE, GetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE) | #WS_CLIPCHILDREN)
                        
                    EndIf
                Next
                ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
            EndIf
            
        Case #WM_EXITSIZEMOVE
            
            ; hack to change toolbar to clip children while dragging, removes flickering of child gadgets
            If ListSize(toolbarEx()) > 0
                *thistoolbarEx = @toolbarEx()
                ForEach toolbarEx()
                    If GetParent_(GetParent_(toolbarEx()\Handle)) = WindowID
                        
                        SetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE, GetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE) &~ #WS_CLIPCHILDREN)
                        RedrawWindow_(toolbarEx()\Handle, 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
                        
                    EndIf
                Next
                ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
            EndIf
            
            resizing = 0
            
        Case #WM_SIZE
            
            If wParam = #SIZE_MAXIMIZED And resizeMaximized = 0
                resizeMaximized = -1
            ElseIf wParam <> #SIZE_MAXIMIZED And resizeMaximized <> 0
                resizeMaximized = 0
            EndIf
            
            ;/ resize any rebars
            ForEach rebarGadget()
                
                If rebarGadget()\WindowID = WindowID
                    If rebarGadget()\dbtoggle = 0
                        If rebarGadget()\doublebuffer = -1
                            SetWindowLongPtr_(rebarGadget()\Handle, #GWL_EXSTYLE, #WS_EX_TOOLWINDOW|#WS_EX_COMPOSITED)
                        EndIf
                        rebarGadget()\dbtoggle = -1
                    EndIf
                    
                    height = SendMessage_(rebarGadget()\Handle, #RB_GETBARHEIGHT, 0,0)
                    
                    SendMessage_(rebarGadget()\Handle, #WM_SETREDRAW, #False, 0)
                    ;SetWindowPos_(rebarGadget()\Handle, 0, 0, 0, LOWORD(lParam), height, #SWP_NOMOVE|#SWP_NOOWNERZORDER|#SWP_NOACTIVATE|#SWP_NOREDRAW|#SWP_NOZORDER)
                    MoveWindow_(rebargadget()\Handle, 0, 0, LOWORD(lParam), height, #False)
                    updateRebar(WindowID)
                    SendMessage_(rebarGadget()\Handle, #WM_SETREDRAW, #True, 0)
                    
                    *thisRebarGadget = @rebarGadget()
                    ;GetUpdateRect_(rebarGadget()\Handle, @rc.RECT, 0)
                    ;RedrawWindow_(rebarGadget()\Handle,rc,0,#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_ERASE|#RDW_ERASENOW|#RDW_UPDATENOW|#RDW_ALLCHILDREN)
                    
                    
                    GetUpdateRect_(rebarGadget()\Handle, @rc.RECT, 0)
                    ;GetClientRect_(rebarGadget()\Handle, @rc.RECT)
                    rc\top = rc\top - 2       ; windows 7 rendering glitch fix
                    rc\bottom = rc\bottom + 2 ; ^
                    rgn = CreateRectRgnIndirect_(rc)
                    rtype = GetUpdateRgn_(rebarGadget()\Handle, @rgn, 0)
                    
                    If resizing = -1
                        RedrawWindow_(rebarGadget()\Handle,0,rgn,#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_ERASE|#RDW_ERASENOW|#RDW_UPDATENOW|#RDW_ALLCHILDREN)
                    Else
                        RedrawWindow_(rebarGadget()\Handle,0,0,#RDW_FRAME|#RDW_INVALIDATE|#RDW_ERASE|#RDW_ERASENOW|#RDW_UPDATENOW|#RDW_ALLCHILDREN)
                    EndIf
                    DeleteObject_(rgn)
                    
                    
                    ;RedrawWindow_(rebarGadget()\Handle, 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_NOERASE|#RDW_UPDATENOW)
                    ChangeCurrentElement(rebarGadget(), *thisRebarGadget)
                    
                    If rebarGadget()\doublebuffer = 0
                        ForEach toolbarEx()
                            
                            ; handle #TBSTYLE_WRAPABLE toolbars in rebar when rebar resized and no SIZE_MINIMIZED/maximized etc
                            If wParam = 0 And rebarGadget()\handle = GetParent_(toolbarEx()\handle)
                                
                                rows = SendMessage_(toolbarEx()\handle, #TB_GETROWS, 0, 0)
                                If rows <> toolbarEx()\lastRowCount
                                    
                                    ; find band that our toolbar is contained in
                                    max = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0,0)
                                    For n = 0 To max
                                        
                                        band.REBARBANDINFO
                                        band\cbSize = SizeOf(REBARBANDINFO)
                                        band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
                                        SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, n, @band)
                                        If band\hwndChild = toolbarEx()\handle
                                            
                                            dwBtnSize = SendMessage_(toolbarEx()\handle, #TB_GETBUTTONSIZE, 0,0)>>16
                                            pad = toolbarEx()\lastRowCount * dwBtnSize
                                            
                                            toolbarEx()\lastRowCount = rows
                                            
                                            pad = band\cyMinChild-pad
                                            
                                            dwBtnSize = (dwBtnSize * rows)+pad
                                            
                                            ; set rebar band's new height
                                            band\fMask = #RBBIM_CHILDSIZE
                                            band\cyMinChild = dwBtnSize;+hdelta
                                            SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, n, @band)
                                            
                                            
                                            handle = rebarGadget()\Handle
                                            *this = @rebarGadget()
                                            height = RebarHeight(handle)
                                            ChangeCurrentElement(rebarGadget(), *this)
                                            
                                            Break
                                        EndIf
                                        
                                    Next
                                    
                                EndIf
                                
                            EndIf
                            
                            
                            If GetParent_(GetParent_(toolbarEx()\Handle)) = WindowID
                                RedrawWindow_(toolbarEx()\Handle, 0, 0, #RDW_NOERASE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
                            EndIf
                            
                        Next
                    EndIf
                    
                EndIf
                
            Next
            
            ;-/ resize any commandbars
            ForEach cmdbar()
                GetClientRect_(cmdbar()\Handle, @rc.RECT)
                
                If cmdbar()\style & #CMDBAR_LEFT
                    SetWindowPos_(cmdbar()\Handle, 0, 0, 0, rc\right, HIWORD(lParam), #SWP_NOOWNERZORDER|#SWP_NOACTIVATE|#SWP_NOZORDER)
                ElseIf cmdbar()\style & #CMDBAR_RIGHT
                    SetWindowPos_(cmdbar()\Handle, 0, LOWORD(lParam)-rc\right, 0, rc\right, HIWORD(lParam), #SWP_NOOWNERZORDER|#SWP_NOACTIVATE|#SWP_NOZORDER)
                ElseIf cmdbar()\style & #CMDBAR_BOTTOM
                    SetWindowPos_(cmdbar()\Handle, 0, 0, HIWORD(lParam)-rc\bottom, LOWORD(lParam), rc\bottom, #SWP_NOOWNERZORDER|#SWP_NOACTIVATE|#SWP_NOZORDER)
                Else ; default top behaviour
                    SetWindowPos_(cmdbar()\Handle, 0, 0, 0, LOWORD(lParam), rc\bottom, #SWP_NOOWNERZORDER|#SWP_NOACTIVATE|#SWP_NOZORDER)
                EndIf
            Next
            
            
            Result = 0
            
            ;Case #WM_EXITSIZEMOVE
            
            ; ForEach rebarGadget()
            ; If rebarGadget()\WindowID = WindowID
            ; If rebarGadget()\dbtoggle = -1
            ; If rebarGadget()\doublebuffer = -1
            ; SetWindowLongPtr_(rebarGadget()\Handle, #GWL_EXSTYLE, #WS_EX_TOOLWINDOW)
            ; EndIf
            ; rebarGadget()\dbtoggle = 0
            ; EndIf
            ; 
            ; ;RedrawWindow_(rebarGadget()\WindowID,0,0,#RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
            ; ;RedrawWindow_(rebarGadget()\Handle,0,0,#RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_NOERASE|#RDW_UPDATENOW)
            ; 
            ; debuglog("cool")
            ; GetUpdateRect_(rebarGadget()\Handle, @rc.RECT, #False)
            ; RedrawWindow_(rebarGadget()\Handle,0,0,#RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_FRAME|#RDW_UPDATENOW)
            ; 
            ; ;If resizing = -1
            ; ;SendMessage_(rebarGadget()\WindowID, #WM_SETREDRAW, #True, 0)
            ; ;MoveWindow_(rebarGadget()\WindowID, lastResizeRect\left, lastResizeRect\top, lastResizeRect\right-lastResizeRect\left, lastResizeRect\bottom-lastResizeRect\top, #True)
            ; resizing = 0
            ; ;lastResizeRect\top = 0
            ; ;lastResizeRect\left = 0
            ; ;lastResizeRect\right = 0
            ; ;lastResizeRect\bottom = 0
            ; ;EndIf
            ; EndIf
            ; Next
            
            ;/ detect if windows system settings changed
        Case #WM_SETTINGCHANGE
            
            ; detect if windows changes system menu font
            If wParam = #SPI_SETNONCLIENTMETRICS
                
                ; flush blitEx cache
                blitExFlush()
                
                LockMutex(menuMutex)
                
                ; flag cached menu buffer for re-draw
                ForEach menuex()
                    menuex()\bufferWidth = 0
                    menuex()\bufferHeight = 0
                Next
                
                ; loop through menuex items and resize accordingly
                ForEach menuex()
                    If menuex()\singleMenu = 0
                        
                        ; change our current menuex font to the new menu font
                        hdc = CreateCompatibleDC_(0)
                        
                        metrics.NONCLIENTMETRICS
                        metrics\cbSize = SizeOf(NONCLIENTMETRICS)
                        
                        SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
                        DeleteObject_(currentMenuEXFont)
                        currentMenuEXFont = CreateFontIndirect_(metrics\lfMenuFont)
                        SelectObject_(hdc, currentMenuEXFont)
                        
                        ; get old height of toolbar
                        oldheight.l = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)
                        oldheight = (oldheight>>16)
                        
                        ; re-calc the toolbar button dimensions with the new font
                        buttontxt.s = ""
                        bufflen = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, 0)
                        If bufflen > 0
                            CompilerIf #PB_Compiler_Unicode
                                bufflen = bufflen * 2
                            CompilerEndIf
                            *mem = AllocateMemory(bufflen+2)
                            SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, *mem)
                            buttontxt = PeekS(*mem, bufflen)
                            FreeMemory(*mem)
                        EndIf
                        
                        DrawText_(hdc, buttontxt, Len(buttontxt), @rec.RECT, #DT_SINGLELINE | #DT_CALCRECT)
                        
                        DeleteDC_(hdc)
                        
                        buttoni.TBBUTTONINFO
                        buttoni\cbSize = SizeOf(TBBUTTONINFO)
                        buttoni\dwMask = #TBIF_SIZE
                        buttoni\cx = rec\right+#MENUEXPADX
                        
                        ; reset menu bar height if font too small
                        If rec\bottom+#MENUEXPADY < #MENUEXMINHEIGHT
                            rec\bottom = #MENUEXMINHEIGHT - #MENUEXPADY
                        EndIf
                        
                        ; 2003 style
                        If menuex()\style = 6
                            buttoni\cx = buttoni\cx - 2
                            rec\bottom = rec\bottom - 3
                            ; 2007 style
                        ElseIf menuex()\style = #UISTYLE_OFFICE2007
                            buttoni\cx = buttoni\cx - 2
                            rec\bottom = rec\bottom - 2
                        EndIf
                        
                        SendMessage_(menuex()\toolbarID, #TB_SETBUTTONSIZE, 0, MakeLong(0, rec\bottom+#MENUEXPADY))
                        SendMessage_(menuex()\toolbarID, #TB_SETBUTTONINFO, menuex()\buttonID, @buttoni)
                        
                        ; check if the toolbar is in a rebar
                        ForEach rebarGadget()
                            If GetParent_(menuex()\toolbarID) = rebarGadget()\Handle
                                
                                ; find bar that our toolbar is contained in
                                max = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0,0)
                                For n = 0 To max
                                    band.REBARBANDINFO
                                    band\cbSize = SizeOf(REBARBANDINFO)
                                    band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
                                    SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, n, @band)
                                    
                                    dwBtnSize = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)>>16
                                    If band\hwndChild = menuex()\toolbarID
                                        
                                        ; calc old height delta between toolbar and band
                                        hdelta = band\cyMinChild-oldheight
                                        
                                        ; set rebar band's new height
                                        band\fMask = #RBBIM_CHILDSIZE
                                        band\cyMinChild = dwBtnSize+hdelta
                                        SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, n, @band)
                                        
                                        Break
                                    EndIf
                                Next
                                
                                Break
                            EndIf
                        Next
                        
                    EndIf
                Next
                
                UnlockMutex(menuMutex)
                
                Result = 0
            EndIf
            
            ; detect if system drop-shadows enabled status has been changed
            If wParam = #SPI_SETDROPSHADOW
                SystemParametersInfo_(#SPI_GETDROPSHADOW, 0, @systemDropShadowsEnabled, 0)  ; get system menu drop shadow status
            EndIf
            
        Case #WM_NOTIFY
            *nmhdr.NMHDR = lParam
            
            ;- toolbar tooltips
            If *nmhdr\code = #TTN_GETDISPINFOW Or *nmhdr\code = #TTN_GETDISPINFOA
                
                *tip.NMTTDISPINFO = lParam
                
                ForEach toolbartip()
                    If toolbartip()\id = *tip\hdr\idFrom
                        If #LIBRARY = 1 Or *nmhdr\code = #TTN_GETDISPINFOW
                            *tip\lpszText = @toolbartip()\text
                        ElseIf *nmhdr\code = #TTN_GETDISPINFOA
                            If toolbartip()\asciiBuff <> 0
                                FreeMemory(toolbartip()\asciiBuff)
                            EndIf
                            toolbartip()\asciiBuff = AllocateMemory(Len(toolbartip()\text)+1)
                            PokeS(toolbartip()\asciiBuff, toolbartip()\text, Len(toolbartip()\text), #PB_Ascii)
                            *tip\lpszText = toolbartip()\asciiBuff
                        EndIf
                        Break
                    EndIf
                Next
                
            EndIf
            
            ;/ rebar child size
            ;       If *nmhdr\code = #RBN_CHILDSIZE
            ;         
            ;         *cs.NMREBARCHILDSIZE = lParam
            ;         
            ;         band.REBARBANDINFO
            ;         band\cbSize = SizeOf(REBARBANDINFO)
            ;         band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
            ;         SendMessage_(*cs\hdr\hwndFrom, #RB_GETBANDINFO, *cs\uBand, @band)
            ;         
            ;         ForEach toolbarEx()
            ;           If toolbarEx()\handle = band\hwndChild
            ;             
            ;             rows = SendMessage_(toolbarEx()\handle, #TB_GETROWS, 0, 0)
            ;             debuglog(Str(rows)+"  : "+Str(toolbarEx()\handle))
            ;             If rows <> toolbarEx()\lastRowCount
            ;               
            ;               dwBtnSize = SendMessage_(toolbarEx()\handle, #TB_GETBUTTONSIZE, 0,0)>>16
            ;               pad = toolbarEx()\lastRowCount * dwBtnSize
            ;               
            ;               toolbarEx()\lastRowCount = rows
            ;             
            ;               pad = band\cyMinChild-pad
            ;               ;debuglog(Str(pad))
            ;               
            ;               dwBtnSize = (dwBtnSize * rows)+pad
            ;               
            ;               ; set rebar band's new height
            ;               band\fMask = #RBBIM_CHILDSIZE
            ;               band\cyMinChild = dwBtnSize;+hdelta
            ;               SendMessage_(*cs\hdr\hwndFrom, #RB_SETBANDINFO, *cs\uBand, @band)
            ;               
            ;               ; send rebar update message to apps main window
            ;               root = GetAncestor_(*cs\hdr\hwndFrom, #GA_ROOT)
            ;               PostMessage_(root, #REBAR_UPDATED, RebarHeight(*cs\hdr\hwndFrom), *cs\hdr\hwndFrom)
            ;               root = GetAncestor_(*cs\hdr\hwndFrom, #GA_PARENT)
            ;               PostMessage_(root, #REBAR_UPDATED, RebarHeight(*cs\hdr\hwndFrom), *cs\hdr\hwndFrom)
            ;                   
            ;             EndIf
            ;             
            ;             Break
            ;           EndIf
            ;         Next
            ;         
            ;       EndIf
            
            ;-/ handle rebar layout change
            If *nmhdr\code = #RBN_LAYOUTCHANGED
                
                SendMessage_(*nmhdr\hwndFrom, #WM_SETREDRAW, #False, 0)
                updateRebar(WindowID)
                SendMessage_(*nmhdr\hwndFrom, #WM_SETREDRAW, #True, 0)
                
                ForEach rebarGadget()
                    If rebarGadget()\WindowID = WindowID
                        
                        GetUpdateRect_(rebarGadget()\Handle, @rc.RECT, #False)
                        RedrawWindow_(rebarGadget()\Handle,rc,0,#RDW_NOERASE|#RDW_UPDATENOW)
                        
                    EndIf
                Next
                
            EndIf
            
            
            
            ;-rebar drag
            If *nmhdr\code = #RBN_BEGINDRAG
                currentDragRebar = *nmhdr\hwndFrom
                *nmrebar.NMREBAR = lParam
                currentDragBandID = *nmrebar\wID
                currentDragBand = *nmrebar\uBand
                currentDragRebarParent = WindowID
                
                ForEach rebarGadget()
                    If rebarGadget()\Handle = *nmhdr\hwndFrom
                        currentDragRebarBuffered = rebarGadget()\doublebuffer
                        Break
                    EndIf
                Next
                
                threadId = GetWindowThreadProcessId_(*nmhdr\hwndFrom, 0)
                rebarHook = SetWindowsHookEx_(#WH_MOUSE, @rebarHook(), 0, threadId)
                
                ; hack to change toolbar to clip children while dragging, removes flickering of child gadgets
                If ListSize(toolbarEx()) > 0
                    *thistoolbarEx = @toolbarEx()
                    ForEach toolbarEx()
                        If GetParent_(toolbarEx()\Handle) = *nmhdr\hwndFrom
                            
                            SetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE, GetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE) | #WS_CLIPCHILDREN)
                            
                        EndIf
                    Next
                    ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
                EndIf
                
                
            EndIf
            
            If *nmhdr\code = #RBN_ENDDRAG
                UnhookWindowsHookEx_(rebarHook)
                currentDragRebar = 0
                SetCursor_(normalMousePointer)
                
                ; hack to change toolbar back from clip children, stops fucked up windows7/vista button fade (fucking useless microsoft engineers)
                If ListSize(toolbarEx()) > 0
                    *thistoolbarEx = @toolbarEx()
                    ForEach toolbarEx()
                        If GetParent_(toolbarEx()\Handle) = *nmhdr\hwndFrom
                            
                            SetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE, GetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE) &~ #WS_CLIPCHILDREN)
                            RedrawWindow_(toolbarEx()\Handle, 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
                            
                        EndIf
                    Next
                    ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
                EndIf
                
            EndIf
            
            ;/ handle chevrons in the rebar
            If *nmhdr\code = #RBN_CHEVRONPUSHED
                
                If chevronState = 0
                    *rebar.NMREBARCHEVRON = lParam
                    
                    binfo.REBARBANDINFO
                    binfo\cbSize = SizeOf(REBARBANDINFO)
                    binfo\fMask = #RBBIM_CHILD
                    SendMessage_(*nmhdr\hwndFrom, #RB_GETRECT, *rebar\uBand,@rec.RECT)
                    MapWindowPoints_(*nmhdr\hwndFrom, 0, @rec, 2)
                    MapWindowPoints_(*nmhdr\hwndFrom, 0, @*rebar\rc, 2)
                    
                    chevronRECT\left = *rebar\rc\left
                    chevronRECT\right = *rebar\rc\right
                    chevronRECT\top = *rebar\rc\top
                    chevronRECT\bottom = *rebar\rc\bottom
                    
                    SendMessage_(*nmhdr\hwndFrom, #RB_GETBANDINFO, *rebar\uBand, @binfo)
                    buttoncount = SendMessage_(binfo\hwndChild, #TB_BUTTONCOUNT, 0, 0)
                    ImageList = SendMessage_(binfo\hwndChild, #TB_GETIMAGELIST, 0, 0)
                    
                    menuToolbar = binfo\hwndChild
                    
                    LockMutex(menuMutex)
                    
                    ; see if this toolbar belongs to menuex
                    found = 0
                    ForEach menuex()
                        If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\singleMenu = 0
                            found = #True
                            Break
                        EndIf
                    Next
                    
                    UnlockMutex(menuMutex)
                    
                    chevronPopup = CreatePopupMenuEx(#ProGUI_Any, 0)
                    If chevronPopup <> 0
                        
                        ; scan through all buttons on toolbar
                        For n = 0 To buttoncount-1
                            SendMessage_(binfo\hwndChild, #TB_GETITEMRECT, n, @rec2.RECT)
                            rec2\right = rec2\right + 21
                            MapWindowPoints_(binfo\hwndChild, 0, @rec2, 2)
                            ;IntersectRect_(@irec.RECT, @rec, @rec2)
                            
                            ;Debug EqualRect_(@rec2, @irec)
                            If rec2\right > rec\right
                                ;If EqualRect_(@rec2, @irec) = #False
                                ;Debug "button "+Str(n)+" is hidden!"
                                
                                SendMessage_(binfo\hwndChild, #TB_GETBUTTON, n, @button.TBBUTTON)
                                If button\fsStyle <> #BTNS_SEP
                                    
                                    buttontxt.s = ""
                                    ;SendMessage_(binfo\hwndChild, #TB_GETBUTTONTEXT, button\idCommand, @buttontxt)
                                    bufflen = SendMessage_(binfo\hwndChild, #TB_GETBUTTONTEXT, button\idCommand, 0)
                                    If bufflen > 0
                                        CompilerIf #PB_Compiler_Unicode
                                            bufflen = bufflen * 2
                                        CompilerEndIf
                                        *mem = AllocateMemory(bufflen+2)
                                        SendMessage_(binfo\hwndChild, #TB_GETBUTTONTEXT, button\idCommand, *mem)
                                        buttontxt = PeekS(*mem, bufflen)
                                        FreeMemory(*mem)
                                    EndIf
                                    
                                    If button\iBitmap = #I_IMAGENONE
                                        icon = 0
                                        SetMenuExImageSize(16, 16)
                                        If found = #True
                                            ;icon = menuex()
                                            info.MENUITEMINFO_Fixed
                                            info\cbSize = SizeOf(MENUITEMINFO_Fixed)
                                            info\fMask = #MIIM_DATA|#MIIM_STATE
                                            If GetMenuItemInfo_(chevronPopup, n, #True, @info) = 0
                                                ProcedureReturn #False
                                            EndIf
                                            LockMutex(menuMutex)
                                            ChangeCurrentElement(itemex(), info\dwItemData)
                                            icon = itemex()\normal
                                            hot = itemex()\hot
                                            disabled = itemex()\disabled
                                            UnlockMutex(menuMutex)
                                        EndIf
                                    Else
                                        If buttontxt = ""
                                            buttontxt = " "
                                        EndIf
                                        icon = ImageList_GetIcon_(ImageList, n, #ILD_TRANSPARENT)
                                        ImageList_GetIconSize_(ImageList, @width, @height)
                                        SetMenuExImageSize(width, height)
                                    EndIf
                                    
                                    ; if button is a dropdown then add its menu as submenu
                                    If button\fsStyle & #BTNS_DROPDOWN Or button\fsStyle & #BTNS_WHOLEDROPDOWN
                                        ;find menu for button
                                        LockMutex(menuMutex)
                                        ForEach menuex()
                                            If menuex()\buttonID = button\idCommand
                                                
                                                submenu = menuex()\popupid
                                                
                                                Break
                                            EndIf
                                        Next
                                        UnlockMutex(menuMutex)
                                    EndIf
                                    
                                    MenuItemEx(button\idCommand, buttontxt, icon, hot, disabled, submenu)
                                    If icon <> 0
                                        DestroyIcon_(icon)
                                    EndIf
                                    submenu = 0
                                    
                                    ; if button is disabled then disable menu item
                                    If button\fsState & #TBSTATE_ENABLED = #False
                                        DisableMenuItemEx(chevronPopup, button\idCommand, 1)
                                    EndIf
                                    
                                Else
                                    MenuBarEx()
                                EndIf
                                
                            EndIf
                            
                        Next
                        
                        threadId = GetWindowThreadProcessId_(binfo\hwndChild, 0)
                        chevHook = SetWindowsHookEx_(#WH_MSGFILTER, @ChevronMsgHook(), 0, threadId)
                        
                        tpm.TPMPARAMS
                        tpm\cbSize = SizeOf(TPMPARAMS)
                        tpm\rcExclude\left = *rebar\rc\left
                        tpm\rcExclude\right = *rebar\rc\right
                        tpm\rcExclude\top = *rebar\rc\top
                        tpm\rcExclude\bottom = *rebar\rc\bottom
                        chevronState = 0
                        
                        ; find nearest display monitor to window
                        hmonitor = MonitorFromRect_(*rebar\rc, #MONITOR_DEFAULTTONEAREST)
                        minfo.MONITORINFO
                        minfo\cbSize = SizeOf(MONITORINFO)
                        GetMonitorInfo_(hmonitor, @minfo)
                        
                        If *rebar\rc\left < minfo\rcWork\left
                            *rebar\rc\left = minfo\rcWork\left
                        EndIf
                        
                        ; get menu dimensions
                        width = CalcMenuItemWidth(chevronPopup)
                        If *rebar\rc\left+width > minfo\rcWork\right
                            *rebar\rc\left = minfo\rcWork\right
                        EndIf
                        
                        ;TrackPopupMenuEx_(chevronPopup, #TPM_VERTICAL, *rebar\rc\left, *rebar\rc\bottom, *nmhdr\hwndFrom, @tpm)
                        DisplayPopupMenuEx(chevronPopup, *nmhdr\hwndFrom, *rebar\rc\left, *rebar\rc\bottom)
                        UnhookWindowsHookEx_(chevHook)
                        
                        ; detach any submenus we attached earlier
                        items = GetMenuItemCount_(chevronPopup)
                        If items <> -1
                            For n = 0 To items-1
                                submenu = GetSubMenu_(chevronPopup, n)
                                If submenu <> 0
                                    RemoveMenu_(chevronPopup, n, #MF_BYPOSITION)
                                    n = n - 1
                                EndIf
                            Next
                        EndIf
                        
                        FreeMenuEx(chevronPopup)
                        
                    EndIf
                    
                    
                Else
                    chevronState = 0
                EndIf
            EndIf
            
            ;- menu code
            ;/ handle toolbar menu logic
            If *nmhdr\code = #TBN_DROPDOWN
                *nmTB.NMTOOLBAR = lParam
                menuToolbar = *nmhdr\hwndFrom
                
                LockMutex(menuMutex)
                
                ; search for a menu match and correct button
                found = 0
                ForEach menuex()
                    If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\buttonID = *nmTB\iItem
                        If menuex()\dropdownMenuex > 0
                            
                            dropdownMenuex = menuex()\dropdownMenuex
                            ChangeCurrentElement(menuex(), dropdownMenuex)
                            
                        ElseIf menuex()\dropdownMenuex = -1 ; dropdown menu not initialised then exit
                            Break
                        EndIf
                        
                        found = -1
                        Break
                    EndIf
                Next
                
                
                ; a menu toolbar item has been selected
                If found = -1
                    
                    If menuItemOver <> -1
                        menuItemOver = -1
                        If menuOldFocus <> 0
                            SetFocus_(menuOldFocus)
                            menuOldFocus = 0
                        EndIf
                        menuActive = 0
                        eraseLastMenu()
                        SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
                        GetUpdateRect_(menuToolbar, @rc.RECT, #False)
                        UnlockMutex(menuMutex)
                        RedrawWindow_(menuToolbar,rc,0,#RDW_ERASENOW|#RDW_UPDATENOW)
                        ProcedureReturn #TBDDRET_DEFAULT
                    EndIf
                    
                    If menuKeyboardActive <> #True And menuHotItemNext = -1
                        menuOldFocus = GetFocus_()
                    EndIf
                    
                    menuHotItem = SendMessage_(*nmhdr\hwndFrom, #TB_GETHOTITEM, 0, 0)
                    
                    menuWindow = 0
                    menuHotItemNext = -1
                    
                    menuOriginItem = menuHotItem
                    
                    menuTitleOffset = 0
                    menuTitleVOffset = 0
                    
                    subMenuActive = 0
                    lastSubMenu = 0
                    
                    SendMessage_(*nmhdr\hwndFrom, #TB_GETRECT, *nmTB\iItem, @rect.RECT)
                    If menuex()\singleMenu = 0
                        menuTitleWidth = rect\right-rect\left ; set menuTitleWidth to width of toolbar button
                        menuActive = -1                       ; let our callwndproc know that this is a menubar
                    Else                                      ; for drop down buttons
                        
                        If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2007
                            menuTitleWidth = rect\right-rect\left
                            rect\bottom = rect\bottom - 2
                        EndIf
                        If menuex()\style = 5
                            menuTitleWidth = rect\right-rect\left+4
                            rect\bottom = rect\bottom-1
                        EndIf
                        
                        dropdownActive = #True
                        
                    EndIf
                    menuTitleHeight = rect\bottom-rect\top
                    
                    MapWindowPoints_(*nmhdr\hwndFrom, 0, @rect, 2)
                    menuTitleXpos = rect\left
                    menuTitleYpos = rect\bottom
                    
                    If menuex()\singleMenu = 0
                        threadId = GetWindowThreadProcessId_(*nmhdr\hwndFrom, 0)
                        menuHook = SetWindowsHookEx_(#WH_MSGFILTER, @MsgHook(), 0, threadId)
                    EndIf
                    
                    ; find nearest display monitor to window
                    hmonitor = MonitorFromRect_(rect, #MONITOR_DEFAULTTONEAREST)
                    minfo.MONITORINFO
                    minfo\cbSize = SizeOf(MONITORINFO)
                    GetMonitorInfo_(hmonitor, @minfo)
                    
                    If rect\left < minfo\rcWork\left
                        menuTitleOffset = -(minfo\rcWork\left-rect\left)
                        rect\left = minfo\rcWork\left
                    EndIf
                    
                    
                    ; position popupmenu further up if office style
                    If menuex()\style = 5
                        vertoffset = 1
                    Else
                        vertoffset = 0
                    EndIf
                    
                    ; upsidedown offset for office2003 style
                    If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003
                        upsideDownOffset = 4
                    ElseIf menuex()\style = #UISTYLE_WHIDBEY
                        upsideDownOffset = 3
                    Else
                        upsideDownOffset = 0
                    EndIf
                    
                    menuTitleVOffset = rect\bottom-(1+vertoffset)
                    
                    ;- get menu dimensions
                    width = CalcMenuItemWidth(menuex()\popupid)
                    menuWindowXpos = rect\left  ; store the predicted x pos of menu window for use with title dropshadow 
                    If rect\left+width > minfo\rcWork\right
                        If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003 Or menuex()\style = #UISTYLE_OFFICE2007
                            menuTitleOffset = (rect\left+width)-minfo\rcWork\right+4
                        Else
                            menuTitleOffset = (rect\left+width)-minfo\rcWork\right+2
                        EndIf
                        menuWindowXpos = (minfo\rcWork\right-width)  ; store the predicted x pos of menu window for use with title dropshadow
                    EndIf
                    menuPositionOffset = 0
                    If rect\left+width+5 > minfo\rcWork\right
                        menuPositionOffset = (rect\left+width)-minfo\rcWork\right+6
                        rect\left = (minfo\rcWork\right-width)-5
                    EndIf
                    height = CalcMenuItemHeight(menuex()\popupid)
                    If rect\bottom+height >= minfo\rcWork\bottom+vertoffset-1
                        menuTitleVOffset = -1
                    EndIf
                    
                    ; detect if menu too large to fit on screen, create scroll menu if so
                    If menuTitleVOffset = -1 And (rect\top+1+vertoffset)-height < minfo\rcWork\top
                        createScrollMenu()
                    EndIf
                    
                    ; menu won't fit bellow but will fit above then make sure track popup displays above title
                    If menuTitleVOffset = -1
                        rect\bottom = (rect\top-height)+2+vertoffset
                        If menuex()\style < 5
                            rect\bottom = rect\bottom - 1
                        EndIf
                        
                        ; drop-down and 2003/2007 style move down extra pixels so aligns properly
                        If menuex()\singleMenu <> 0
                            If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003
                                rect\bottom = rect\bottom + 2
                            ElseIf menuex()\style = #UISTYLE_OFFICE2007
                                rect\bottom = rect\bottom + 2
                            EndIf
                        EndIf
                        
                    EndIf
                    
                    menuWindowWidth = width
                    menuex()\measuredWidth = width
                    menuex()\measuredHeight = height
                    
                    menuex()\active = -1
                    menuex()\root = #True
                    
                    thisMenuEx = @menuex()
                    SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
                    SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
                    GetUpdateRect_(menuToolbar, @rc.RECT, #False)
                    UnlockMutex(menuMutex)
                    RedrawWindow_(menuToolbar,rc,0,#RDW_ERASENOW|#RDW_UPDATENOW)
                    
                    ; need this with scroll menu due to TB_SETHOTITEM changing menuex
                    LockMutex(menuMutex)
                    ChangeCurrentElement(menuex(), thisMenuEx)
                    
                    menuHandle = menuex()\popupid
                    menuExHandle = @menuex()
                    
                    If menuKeyboardActive = #True
                        keybd_event_(#VK_DOWN, 0, 0, 0)
                    EndIf
                    
                    ; detect whether slide animation effect is enabled on system and disable animation if so
                    SystemParametersInfo_(#SPI_GETMENUFADE, 0, @fade.l, 0)
                    If fade = #False
                        noAnimation = #TPM_NOANIMATION
                    EndIf
                    
                    If CompositionEnabled = #False And menuEraseBuffered = #True
                        doMenuTrackBufferedErase(menuToolbar, 0)
                    EndIf
                    
                    ; save toolbarex's menu held colour
                    If dropdownActive = #True
                        ForEach toolbarEx()
                            If toolbarEx()\handle = menuToolbar
                                Break
                            EndIf
                        Next
                        
                        dropdownHeldColour = getMenuColourEx(toolbarEx()\UIStyle, #menuHeldBorder, 0)
                        
                    EndIf
                    
                    popupid = menuex()\popupid
                    
                    UnlockMutex(menuMutex)
                    TrackPopupMenuEx_(popupid, #TPM_VERTICAL|noAnimation, rect\left, rect\bottom-(1+vertoffset), *nmhdr\hwndFrom, 0)
                    LockMutex(menuMutex)
                    ChangeCurrentElement(menuex(), thisMenuEx)
                    
                    menuHandle = 0
                    menuex()\active = 0
                    menuActive = 0
                    dropdownActive = 0
                    menuDraw = 0
                    menuex()\root = #False
                    
                    
                    ; if the tracked menu was a scroll menu then free up
                    If menuScrollHandle <> 0
                        ; If menuScrollThread <> 0
                        ; SendMessage_(menuScrollHandle, #WM_SETREDRAW, #True, 0)
                        ; KillThread(menuScrollThread)
                        ; menuScrollThread = 0
                        ; EndIf
                        menuex()\toolbarID = -1
                        FreeMenuEx(menuScrollHandle)
                        menuDraw = 0
                        ChangeCurrentElement(menuex(), *realMenuEx)
                        menuex()\active = 0
                        menuScrollHandle = 0
                        menuScrollWindow = 0
                        menuScrolling = 0
                        menuScrollActive = 0
                        ClearList(menuScrollHotKey())
                    EndIf
                    
                    If menuex()\singleMenu = 0
                        UnhookWindowsHookEx_(menuHook)
                        
                        ; deselect the menu toolbar button
                        If menuHotItemNext = -1 And menuKeyboardActive <> -2
                            
                            SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
                            menuItemOver = -1
                            menuKeyboardActive = #False
                            If menuOldFocus <> 0
                                SetFocus_(menuOldFocus)
                                menuOldFocus = 0
                            EndIf
                            eraseLastMenu()
                            SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
                            GetUpdateRect_(menuToolbar, @rc.RECT, #False)
                            UnlockMutex(menuMutex)
                            RedrawWindow_(menuToolbar,rc,0,#RDW_NOERASE|#RDW_UPDATENOW)
                            LockMutex(menuMutex)
                            ChangeCurrentElement(menuex(), thisMenuEx)
                            
                        EndIf
                        
                        ; this code solves bug with clicking on same selected menu title when key nav by alt or f10, disables re-activation of dropdown next time round
                        If altActivated = -2
                            menuItemOver = -2
                            altActivated = #False
                        EndIf
                        
                    Else
                        
                        eraseLastMenu()
                        
                    EndIf
                    
                    If menuKeyboardActive = -2
                        menuKeyboardActive = #True
                    EndIf
                    
                    Result = #TBDDRET_DEFAULT
                EndIf
                
                UnlockMutex(menuMutex)
            EndIf
            
            If *nmhdr\code = #TBN_HOTITEMCHANGE
                *nmTB.NMTOOLBAR = lParam
                *nmTBHot.NMTBHOTITEM = lParam
                
                
                If menuHotItemNext <> -1
                    
                    ;debuglog(Str(*nmTBHot\idNew))
                    
                    LockMutex(menuMutex)
                    
                    found = 0
                    ForEach menuex()
                        If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\singleMenu = 0
                            found2 = -1
                        EndIf
                        
                        If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\singleMenu = 0 And menuex()\buttonID = *nmTBHot\idNew
                            menuHotItem = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBHot\idNew, 0)
                            menuHotItemNext = -1
                            found = -1
                            Break
                        EndIf
                    Next
                    
                    ; if goes off button before it registers
                    If *nmTBHot\idNew = 0 Or found2 = 0
                        ;debuglog("ok")
                        SendMessage_(menuToolbar, #TB_SETHOTITEM, menuHotItemNext, 0)
                        UnlockMutex(menuMutex)
                        ProcedureReturn #TBDDRET_DEFAULT
                    EndIf
                    
                    
                    If found = -1
                        
                        menuWindow = 0
                        menuTitleOffset = 0
                        menuTitleVOffset = 0
                        
                        subMenuActive = 0
                        lastSubMenu = 0
                        
                        SendMessage_(*nmhdr\hwndFrom, #TB_GETRECT, menuex()\buttonID, @rect.RECT)
                        menuTitleWidth = rect\right-rect\left
                        menuTitleHeight = rect\bottom-rect\top
                        
                        MapWindowPoints_(*nmhdr\hwndFrom, 0, @rect, 2)
                        menuTitleXpos = rect\left
                        
                        threadId = GetWindowThreadProcessId_(*nmhdr\hwndFrom, 0)
                        menuHook = SetWindowsHookEx_(#WH_MSGFILTER, @MsgHook(), 0, threadId)
                        
                        ; find nearest display monitor to window
                        hmonitor = MonitorFromRect_(rect, #MONITOR_DEFAULTTONEAREST)
                        minfo.MONITORINFO
                        minfo\cbSize = SizeOf(MONITORINFO)
                        GetMonitorInfo_(hmonitor, @minfo)
                        
                        If rect\left < minfo\rcWork\left
                            menuTitleOffset = -(minfo\rcWork\left-rect\left)
                            rect\left = minfo\rcWork\left
                        EndIf
                        
                        ; position popupmenu further up if office style
                        If menuex()\style = 5
                            vertoffset = 1
                        Else
                            vertoffset = 0
                        EndIf
                        
                        ; upsidedown offset for office2003 style
                        If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003
                            upsideDownOffset = 4
                        ElseIf menuex()\style = #UISTYLE_WHIDBEY
                            upsideDownOffset = 3
                        Else
                            upsideDownOffset = 0
                        EndIf
                        
                        
                        ; get menu dimensions
                        width = CalcMenuItemWidth(menuex()\popupid)
                        menuWindowXpos = rect\left  ; store the predicted x pos of menu window for use with title dropshadow 
                        If rect\left+width > minfo\rcWork\right
                            If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003 Or menuex()\style = #UISTYLE_OFFICE2007
                                menuTitleOffset = (rect\left+width)-minfo\rcWork\right+4
                            Else
                                menuTitleOffset = (rect\left+width)-minfo\rcWork\right+2
                            EndIf
                            menuWindowXpos = (minfo\rcWork\right-width)  ; store the predicted x pos of menu window for use with title dropshadow
                        EndIf
                        menuPositionOffset = 0
                        If rect\left+width+5 > minfo\rcWork\right
                            menuPositionOffset = (rect\left+width)-minfo\rcWork\right+6
                            rect\left = (minfo\rcWork\right-width)-5
                        EndIf
                        
                        height = CalcMenuItemHeight(menuex()\popupid)
                        If rect\bottom+height >= minfo\rcWork\bottom+vertoffset-1
                            menuTitleVOffset = -1
                        EndIf
                        
                        ; detect if menu too large to fit on screen, create scroll menu if so
                        If menuTitleVOffset = -1 And (rect\top+1+vertoffset)-height < minfo\rcWork\top
                            createScrollMenu()
                        EndIf
                        
                        ; menu won't fit bellow but will fit above then make sure track popup displays above title
                        If menuTitleVOffset = -1
                            rect\bottom = (rect\top-height)+2+vertoffset
                            If menuex()\style < 5
                                rect\bottom = rect\bottom - 1
                            EndIf
                        EndIf
                        
                        
                        menuWindowWidth = width
                        menuex()\measuredWidth = width
                        menuex()\measuredHeight = height
                        
                        menuex()\active = -1
                        menuex()\root = #True
                        menuActive = -1
                        menuHandle = menuex()\popupid
                        menuExHandle = @menuex()
                        tbButtonChange = #True
                        
                        
                        *thisMenuEx = @menuex()
                        popupid = menuex()\popupid
                        UnlockMutex(menuMutex)
                        TrackPopupMenuEx_(popupid, #TPM_VERTICAL|#TPM_NOANIMATION, rect\left, rect\bottom-(1+vertoffset), *nmhdr\hwndFrom, 0)
                        LockMutex(menuMutex)
                        ChangeCurrentElement(menuex(), *thisMenuEx)
                        menuHandle = 0
                        menuex()\active = 0
                        menuActive = 0
                        menuDraw = 0
                        UnhookWindowsHookEx_(menuHook)
                        
                        menuex()\root = #False
                        
                        tbButtonChange = #False
                        
                        ; if the tracked menu was a scroll menu then free up
                        If menuScrollHandle <> 0
                            ; If menuScrollThread <> 0
                            ; SendMessage_(menuScrollHandle, #WM_SETREDRAW, #True, 0)
                            ; KillThread(menuScrollThread)
                            ; menuScrollThread = 0
                            ; EndIf
                            menuex()\toolbarID = -1
                            FreeMenuEx(menuScrollHandle)
                            menuDraw = 0
                            ChangeCurrentElement(menuex(), *realMenuEx)
                            menuex()\active = 0
                            menuScrollHandle = 0
                            menuScrollWindow = 0
                            menuScrolling = 0
                            menuScrollActive = 0
                            ClearList(menuScrollHotKey())
                        EndIf
                        
                        ; menu hot tracking finnished
                        If menuItemOver = -1 And menuHotItemNext = -1
                            
                            eraseLastMenu()
                            SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
                            SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
                            UnlockMutex(menuMutex)
                            RedrawWindow_(menuToolbar,0,0,#RDW_INVALIDATE|#RDW_NOERASE|#RDW_UPDATENOW)
                            ProcedureReturn #TBDDRET_TREATPRESSED
                            
                        EndIf
                        
                    EndIf
                    
                    UnlockMutex(menuMutex)
                    
                EndIf
                
                Result = #TBDDRET_DEFAULT
            EndIf  
            
            
            ;-/handle custom draw of menu titles, rebars and toolbars
            If *nmhdr\code = #NM_CUSTOMDRAW
                
                *custTB.NMTBCUSTOMDRAW = lParam
                *nmTBCust.NMCUSTOMDRAW = *custTB\nmcd
                
                
                ;/ handle custom draw of rebar and toolbar UI styles
                ; check if ownerdraw msg is for rebar or toolbar and if rebar/containing rebar has extended UI style
                foundbar = 0
                foundToolBarEx = 0
                ForEach toolbarEx()
                    If toolbarEx()\Handle = *nmhdr\hwndFrom
                        parent = GetParent_(*nmhdr\hwndFrom)
                        ForEach rebarGadget()
                            If rebarGadget()\Handle = parent And rebarGadget()\UIStyle <> 0
                                foundbar = rebarGadget()\UIStyle
                                Break
                            EndIf
                        Next
                        Result = #CDRF_NOTIFYITEMDRAW
                        foundToolBarEx = #True
                        Break
                    EndIf
                Next
                
                If foundbar = 0
                    ForEach rebarGadget()
                        If rebarGadget()\Handle = *nmhdr\hwndFrom And rebarGadget()\UIStyle <> 0
                            foundbar = rebarGadget()\UIStyle
                            Result = #CDRF_NOTIFYITEMDRAW
                            Break
                        EndIf
                    Next
                EndIf
                
                ; handle rendering of panelex background if inside
                If *nmTBCust\dwDrawStage = #CDDS_PREERASE
                    ;is this a toolbar and not inside rebar
                    If foundToolBarEx = #True; And foundbar = 0
                        *trackWin.trackWindows = GetProp_(*nmhdr\hwndFrom, trackwinAtom)
                        If *trackWin <> #Null
                            If *trackWin\rootPanelex <> #Null
                                
                                *rpanelex.PanelExs = *trackWin\rootPanelex
                                
                                GetClientRect_(*nmhdr\hwndFrom, rc.RECT)
                                MapWindowPoints_(*nmhdr\hwndFrom, *trackWin\rootPanelexPageHwnd, rc, 2)
                                ;*trackWin\noblit = #True
                                ;RefreshPanelEx(*rpanelex\Handle, rc)
                                ;*trackWin\noblit = #False
                                
                                BitBlt_(*nmTBCust\hdc, *nmTBCust\rc\left, *nmTBCust\rc\top, *nmTBCust\rc\right-*nmTBCust\rc\left, *nmTBCust\rc\bottom-*nmTBCust\rc\top, *trackWin\divertedWinDC, *nmTBCust\rc\left, *nmTBCust\rc\top, #SRCCOPY)
                                ;BitBlt_(*nmTBCust\hdc, rc\left, rc\top, rc\right-rc\left, rc\bottom-rc\top, *trackWin\divertedWinDC, rc\left, rc\top, #SRCCOPY)
                                
                                ;- draw toolstrip background
                                ;If toolbarEx()\UIStyle = #UISTYLE_OFFICE2003 Or toolbarEx()\UIStyle = #UISTYLE_OFFICE2007
                                    
                                    ; get width of toolbar
                                    SendMessage_(toolbarEx()\Handle, #TB_GETMAXSIZE, 0, @sz.SIZE)
                                    right = sz\cx
                                    height = sz\cy
                                    
                                    ; add 2 pixels on to width of toolstrip for default rounded end
                                    right = right + 2
                                    
                                    ; if band width is less than right then set right to band width
                                    If *nmTBCust\rc\right < right
                                        ;right = *nmTBCust\rc\right
                                    EndIf
                                    
                                    ;/ draw toolstrip
                                    ; get top round corner pixels
                                    topleftPixelSrc = GetPixel_(*nmTBCust\hdc, right-1,0)
                                    
                                    ; get bottom round corner pixels
                                    bPixelSrc = GetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\bottom-1)
                                    
                                    ; draw toolstrip background
                                    rc.RECT
                                    rc\left = 0;*nmTBCust\rc\left
                                    If rc\left > right
                                        ;rc\left = right
                                    EndIf
                                    rc\right = rc\left + right
                                    If rc\right > right
                                        ;rc\right = right
                                    EndIf
                                    rc\top = 0;*nmTBCust\rc\top
                                    rc\bottom = height;rc\top + height
                                                      ;debuglog(Str(rc\left)+" "+Str(rc\right)+" "+Str(rc\top)+" "+Str(rc\bottom))
                                    blitEx(*nmTBCust\hdc, toolbarEx()\UIStyle, #toolstripBackground1, @rc, #ForceVerticalRedraw|#DynamicBlitEx)
                                    
                                    Debug "yo"
                                    ;br = CreateSolidBrush_(RGB(255,0,0))
                                    ;FillRect_(*nmTBCust\hdc, rc, br)
                                    ;DeleteObject_(br)
                                    
                                    index = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBCust\dwItemSpec, 0)
                                    btncount = SendMessage_(*nmhdr\hwndFrom, #TB_BUTTONCOUNT, 0, 0)
                                    GetClientRect_(*nmhdr\hwndFrom, clrc.RECT)
                                    pt.POINT
                                    pt\x = clrc\right-1
                                    pt\y = *nmTBCust\rc\top
                                    lindex = Abs(SendMessage_(*nmhdr\hwndFrom, #TB_HITTEST, 0, @pt))
                                    Debug lindex
                                    
                                    pt.POINT
                                    pt\x = *nmTBCust\rc\right-1
                                    pt\y = *nmTBCust\rc\top
                                    ;If index = lindex-2
                                    ;If SendMessage_(*nmhdr\hwndFrom, #TB_HITTEST, 0, @pt) < 0 ; make sure not drawing button background
                                                                                              ; draw top end rounded corner
                                        topleftPixel = GetPixel_(*nmTBCust\hdc, right-1,0)
                                        topleftPixel = AlphaBlend (topleftPixelSrc , topleftPixel , 135)
                                        SetPixel_(*nmTBCust\hdc, right-1,0, topleftPixelSrc)
                                        SetPixel_(*nmTBCust\hdc, right-2,0, topleftPixel)
                                        SetPixel_(*nmTBCust\hdc, right-1,1, topleftPixel)
                                        Debug "poo"
                                        ; draw bottom end rounded corner
                                        bpixel = GetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\bottom-1)
                                        bpixel = AlphaBlend (bPixelSrc , bpixel , 135)
                                        SetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\bottom-1, bPixelSrc)
                                        SetPixel_(*nmTBCust\hdc, right-2,*nmTBCust\rc\bottom-1, bpixel)
                                        SetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\bottom-2, bpixel)
                                    ;EndIf
                                    
                                 ;EndIf
                                
                            EndIf
                        EndIf
                    EndIf
                    
                ElseIf *nmTBCust\dwDrawStage = #CDDS_ITEMPREPAINT
                    ;is this a toolbar and not inside rebar
                    If foundToolBarEx = #True; And foundbar = 0
                        *trackWin.trackWindows = GetProp_(*nmhdr\hwndFrom, trackwinAtom)
                        If *trackWin <> #Null
                            If *trackWin\rootPanelex <> #Null
                                
                                *rpanelex.PanelExs = *trackWin\rootPanelex
                                ;Debug *nmTBCust\uItemState
                                ;If *nmTBCust\uItemState <> 0;*nmTBCust\uItemState = 64 Or *nmTBCust\uItemState = 65 Or *nmTBCust\uItemState = 4
                                    GetClientRect_(*nmhdr\hwndFrom, rc.RECT)
                                    MapWindowPoints_(*nmhdr\hwndFrom, *trackWin\rootPanelexPageHwnd, rc, 2)
                                    *trackWin\noblit = #True
                                    RefreshPanelEx(*rpanelex\Handle, rc)
                                    *trackWin\noblit = #False
                                    BitBlt_(*nmTBCust\hdc, *nmTBCust\rc\left, *nmTBCust\rc\top, *nmTBCust\rc\right-*nmTBCust\rc\left, *nmTBCust\rc\bottom-*nmTBCust\rc\top, *trackWin\divertedWinDC, *nmTBCust\rc\left, *nmTBCust\rc\top, #SRCCOPY)
                                ;EndIf
                                
                            EndIf
                        EndIf
                    EndIf
                EndIf
                
                ;FillRect_(*nmTBCust\hdc, *nmTBCust\rc, CreateSolidBrush_(RGB(Random(255),0,0)))
                If *nmTBCust\dwDrawStage = #CDDS_ITEMPREPAINT
                    
                    If foundbar = #UISTYLE_OFFICE2003 Or foundbar = #UISTYLE_OFFICE2007
                        
                        
                        
                        ; is this a menu toolbar item
                        LockMutex(menuMutex)
                        found = 0
                        ForEach menuex()
                            If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\singleMenu = 0
                                found = -1
                                Break
                            EndIf
                        Next
                        UnlockMutex(menuMutex)
                        
                        ; find largest desktop width if not already found
                        If LargestDesktopWidth = 0
                            desktops = ExamineDesktops()
                            For n = 0 To desktops
                                width = DesktopWidth(n)
                                If LargestDesktopWidth < width
                                    LargestDesktopWidth = width
                                EndIf
                            Next
                        EndIf
                        
                        If InitGDIPlus() <> 0
                            
                            If foundToolBarEx = #True And toolbarEx()\Handle = *nmhdr\hwndFrom And found = 0
                                ;- draw toolstrip background
                                If toolbarEx()\UIStyle = #UISTYLE_OFFICE2003 Or toolbarEx()\UIStyle = #UISTYLE_OFFICE2007
                                    
;                                     ; get width of toolbar
;                                     SendMessage_(toolbarEx()\Handle, #TB_GETMAXSIZE, 0, @sz.SIZE)
;                                     right = sz\cx
;                                     height = sz\cy
;                                     
;                                     ; add 2 pixels on to width of toolstrip for default rounded end
;                                     right = right + 2
;                                     
;                                     ; if band width is less than right then set right to band width
;                                     If *nmTBCust\rc\right < right
;                                         right = *nmTBCust\rc\right
;                                     EndIf
;                                     
;                                     ;/ draw toolstrip
;                                     ; get top round corner pixels
;                                     topleftPixelSrc = GetPixel_(*nmTBCust\hdc, right-1,0)
;                                     
;                                     ; get bottom round corner pixels
;                                     bPixelSrc = GetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\bottom-1)
;                                     
;                                     ; draw toolstrip background
;                                     rc.RECT
;                                     rc\left = *nmTBCust\rc\left
;                                     If rc\left > right
;                                         rc\left = right
;                                     EndIf
;                                     rc\right = rc\left + right
;                                     If rc\right > right
;                                         rc\right = right
;                                     EndIf
;                                     rc\top = 0;*nmTBCust\rc\top
;                                     rc\bottom = height;rc\top + height
;                                                       ;debuglog(Str(rc\left)+" "+Str(rc\right)+" "+Str(rc\top)+" "+Str(rc\bottom))
;                                     blitEx(*nmTBCust\hdc, toolbarEx()\UIStyle, #toolstripBackground1, @rc, #ForceVerticalRedraw|#DynamicBlitEx)
;                                     
;                                     
;                                     ;br = CreateSolidBrush_(RGB(255,0,0))
;                                     ;FillRect_(*nmTBCust\hdc, rc, br)
;                                     ;deleteobject_(br)
;                                     
;                                     index = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBCust\dwItemSpec, 0)
