            EndIf
            
        EndIf
        
        ProcedureReturn #True
        
    EndIf
    
    ProcedureReturn #False
    
EndProcedure

ProcedureDLL GetExplorerBarGroupState(ID.i, Index.i) ; Returns true if the specified ExplorerBar group is collapsed, false otherwise. 
    
    hwnd = getHwndFromUniqueID(ID)
    If hwnd <> #Null
        ID = hwnd
    EndIf
    *xbar.ExplorerBars = GetProp_(ID, explorerbarAtom)
    If *xbar = #Null
        ProcedureReturn #False
    EndIf
    
    *group.ExplorerBarGroups = SelectElement(*xbar\group(), Index)
    
    If *group <> #Null
        
        ProcedureReturn *group\collapsed
        
    EndIf
    
    ProcedureReturn #False
    
EndProcedure

ProcedureDLL ExplorerBarImageItem(ExplorerBarID.l, GroupIndex.i, ItemID.l, Text.s, normalImageID.i, hotImageID.i, pressedImageID.i, disabledImageID.i) ; Adds a new item with icon/image to a previously created ExplorerBar group.
    
    macro_protectCommand()
    
    hwnd = getHwndFromUniqueID(ExplorerBarID)
    If hwnd <> #Null
        ExplorerBarID = hwnd
    EndIf
    *xbar.ExplorerBars = GetProp_(ExplorerBarID, explorerbarAtom)
    If *xbar = #Null
        ProcedureReturn #False
    EndIf
    
    If GroupIndex = -1
        *group.ExplorerBarGroups = LastElement(*xbar\group())
    Else
        *group.ExplorerBarGroups = SelectElement(*xbar\group(), GroupIndex)
    EndIf
    
    ; make sure explorerbar item doesn't already exist
    If ItemID = #ProGUI_Any
        Repeat
            ; generate unique item id
            ItemID = generateUniqueCommandID_wordUnsigned()
            ; check that same id doesnt already exist
            found = 0
            ForEach *group\item()
                If *group\item()\id = ItemID
                    found = -1
                    Break
                EndIf
            Next
        Until found = 0
        ProGUI_Any = #True
    Else
        ; make sure explorerbar item id doesnt exist
        ForEach *group\item()
            If *group\item()\id = ItemID
                ProcedureReturn #False
            EndIf
        Next
    EndIf
    
    ; create item toggle button
    realid = ButtonEx(*group\groupPage, #ProGUI_Any, 0, 0, 0, 0, Text, normalImageID, hotImageID, pressedImageID, disabledImageID, -1)
    item = ButtonExID(realid)
    If item <> #Null
        
        LastElement(*group\item())
        *item.ExplorerBarItems = AddElement(*group\item())
        *item\hwnd = item
        *item\realid = realid
        *item\id = ItemID
        
        groupHeight = calcXbarGroupHeight()
        If groupHeight < *xbar\headerHeight
            groupHeight = *xbar\headerHeight
        EndIf
        
        If *group\collapsed = #True
            *group\storedheight = groupHeight
            groupHeight = 0
        EndIf
        
        SetButtonExSkin(item, *xbar\skin, "explorerbar group item", 0)
        
        GetClientRect_(*group\group, rc.RECT)
        MapWindowPoints_(*group\group, *xbar\Handle, rc, 2)
        MoveWindow_(*group\group, 0, rc\top, 0, groupHeight, #False)
        SendMessage_(*xbar\Handle, #WM_SIZE, 0, 0)
        
        RefreshPanelEx(*xbar\Handle)
        
        If ProGUI_Any = #True
            ProcedureReturn ItemID
        Else
            ProcedureReturn item
        EndIf
        
    EndIf
     
    ProcedureReturn #False
    
EndProcedure

ProcedureDLL ExplorerBarItem(ExplorerBarID.l, GroupIndex.i, ItemID.l, Text.s) ; Adds a new item to a previously created ExplorerBar group.
    ProcedureReturn ExplorerBarImageItem(ExplorerBarID.l, GroupIndex.i, ItemID.l, Text.s, 0, 0, 0, 0)
EndProcedure

ProcedureDLL ExplorerBarID(ID.l) ; Returns a handle to an ExplorerBar's window (HWND)
    
    hwnd = getHwndFromUniqueID(ID)
    If hwnd <> #Null
        ID = hwnd
    EndIf
    *xbar.ExplorerBars = GetProp_(ID, explorerbarAtom)
    If *xbar = #Null
        ProcedureReturn #False
    EndIf
    
    ProcedureReturn *xbar\Handle
    
EndProcedure

ProcedureDLL FreeExplorerBar(ID.i) ; Frees an ExplorerBar from memory
    
    hwnd = getHwndFromUniqueID(ID)
    If hwnd <> #Null
        ID = hwnd
    EndIf
    *xbar.ExplorerBars = GetProp_(ID, explorerbarAtom)
    If *xbar = #Null
        ProcedureReturn #False
    EndIf
    
    DestroyWindow_(*xbar\Handle)
    
    ProcedureReturn #True
    
EndProcedure

