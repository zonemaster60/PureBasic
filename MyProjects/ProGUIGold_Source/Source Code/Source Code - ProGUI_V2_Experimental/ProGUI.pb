                    tfcolour = AlphaBlendColour(tfcolour, RGB(255,255,255), 50)
                    SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "text", "font: "+fname+", "+Str(fheight)+", bold; colour: rgb("+Str(Red(tfcolour))+","+Str(Green(tfcolour))+","+Str(Blue(tfcolour))+")")
                EndIf
                ; explorerbar group item toggle button skin
                ; normal
                SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "background", "-1;");"RGBA(255, 255, 0, 255);")
                SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "image position", "x: 0; y: centre;")
                SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
                SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "text position", "x: 0; y: centre;")
                SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
                If ThemesEnabled = #True
                    tempimg = CreateImage(#PB_Any, 1, 1, 32)
                    hdc = StartDrawing(ImageOutput(tempimg))
                    retval = CallFunctionFast(*GetThemeFont, hThemeExplorerbar, hdc, 1, 1, 210, font.LOGFONTW); 210 = #TMT_FONT
                    StopDrawing()
                    FreeImage(tempimg)
                    If retval = 0
                        CallFunctionFast(*GetThemeColor, hThemeExplorerbar, 5, 1, 3803, @fcolour) ; 3803 = #TMT_TEXTCOLOR
                        fname.s = PeekS(@font\lfFaceName, -1, #PB_Unicode)
                        fheight = font\lfHeight
                        fheight = font\lfHeight: If fheight<0: fheight = -fheight: EndIf
                        fheight*72.0/GetScreenDPI()
                        Debug "xbar skin item font:"+fname+" size: "+Str(fheight)+" colour: "+Str(Red(fcolour))+" "+Str(Green(fcolour))+" "+Str(Blue(fcolour))
                        SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "text", "font: "+fname+", "+Str(fheight)+"; colour: rgb("+Str(Red(fcolour))+","+Str(Green(fcolour))+","+Str(Blue(fcolour))+")")
                    EndIf
                Else
                    fname.s = GetFontNamep(DefaultFont)
                    fheight = GetFontSize(DefaultFont)
                    SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "text", "font: "+fname+", "+Str(fheight)+"; colour: rgb("+Str(Red(fcolour))+","+Str(Green(fcolour))+","+Str(Blue(fcolour))+")")
                EndIf
                ; hot
