Procedure newSetScrollInfo(hwnd, fnBar, *lpsi, fRedraw)
   
    ;class.s = Space(255)
    ;GetClassName_(hwnd, @class, 255)
    ;debuglog("SetScrollInfo " + class + " " + Str(Random(255)))
   
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null
        
        ;class.s = Space(255)
        ;GetClassName_(hwnd, @class, 255)
        ;debuglog("SetScrollInfo " + class + " " + Str(Random(255)))
        
        If *trackWin\rootPanelex <> #Null And (fnBar = #SB_HORZ Or fnBar = #SB_VERT)
            
            If ThemesEnabled = #False
                fRedraw = 0
                result = SetScrollInfo(hwnd, fnBar, *lpsi, fRedraw)
                If scrollbarsHook = #Null And *trackWin\divertedScrollTrack = #Null
                    drawClassicScrollbars(*trackWin, 0, #True)
                EndIf
            Else
                result = SetScrollInfo(hwnd, fnBar, *lpsi, fRedraw)
            EndIf
            
        Else
            result = SetScrollInfo(hwnd, fnBar, *lpsi, fRedraw)
        EndIf
            
    Else
        result = SetScrollInfo(hwnd, fnBar, *lpsi, fRedraw)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

