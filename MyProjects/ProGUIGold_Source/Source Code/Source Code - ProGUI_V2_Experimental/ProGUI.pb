Procedure newEndPaint(hwnd, *lpPaint.PAINTSTRUCT)
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null
        
        If *trackWin\divertedBuffer <> #Null
            
            If *trackWin\windowType = #WINDOWTYPE_REBAR
                ;debuglog("-------------- endpaint")
            EndIf
            
            If *trackWin\noPaint = #True
                ProcedureReturn EndPaint(hwnd, *lpPaint)
            EndIf
            
            *trackWin\divertedRefreshCount - 1
            If *trackWin\divertedRefreshCount < 0
                *trackWin\divertedRefreshCount = 0
            EndIf
            
            *trackWin\divertedRefreshCount = 0
            
            If *trackWin\divertedRedraw = #False And *trackWin\divertedSetNoRedraw = #False And *trackWin\divertedRefreshCount = 0
                
;                 class.s = Space(255)
;                 GetClassName_(hwnd, @class, 255)
;                 debuglog("EndPaint " + class + " " + Str(hwnd))
;                 debuglog("!!! Refresh triggered from EndPaint !!! " + Str(Random(255)))
                
                If *trackWin\windowType = #WINDOWTYPE_RICHEDIT
                    ;debuglog("refresh")
                EndIf
                
                *panelex.panelexs = *trackWin\parentPanelex
                *panelexpage.panelexpages = *panelex\displayedPage
                
                ;GetRgnBox_(*trackWin\divertedClipRgn, updateRect.RECT)
                ;GetClipBox_(*trackWin\divertedDC, updateRect.RECT)
                ;MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
                
                ;rgn = CreateRectRgn_(0, 0, 0, 0)
                ;CombineRgn_(rgn, rgn, *trackWin\divertedClipRgn, #RGN_OR)
                
                If *trackWin\divertedWinClipRgn <> #Null
                    
                    ; calculate window frame offsets
                    GetWindowRect_(*trackWin\hwnd, wrc.RECT)
                    MapWindowPoints_(0, *trackWin\hwnd, wrc, 2)
                    
                    If wrc\left < 0
                        frameXOffset = -wrc\left
                    EndIf
                    If wrc\top < 0
                        frameYOffset = -wrc\top
                    EndIf
                    
                    rgn = CreateRectRgn_(0, 0, 0, 0)
                    OffsetRgn_(*trackWin\divertedClipRgn, frameXOffset, frameYOffset)
                    CombineRgn_(rgn, rgn, *trackWin\divertedClipRgn, #RGN_OR)
                    OffsetRgn_(*trackWin\divertedClipRgn, -frameXOffset, -frameYOffset)
                    CombineRgn_(rgn, rgn, *trackWin\divertedWinClipRgn, #RGN_OR)
                    GetRgnBox_(rgn, updateRect.RECT)
                    updateRect\left = -frameXOffset
                    updateRect\top = -frameYOffset
                    MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
                    DeleteObject_(rgn)
                    
;                     rgn = CreateRectRgn_(0, 0, 0, 0)
;                     crgn = CreateRectRgn_(0, 0, 0, 0)
;                     GetClipRgn_(*trackWin\divertedDC, crgn)
;                     OffsetRgn_(crg, frameXOffset, frameYOffset)
;                     CombineRgn_(rgn, rgn, crgn, #RGN_OR)
;                     CombineRgn_(rgn, rgn, *trackWin\divertedWinClipRgn, #RGN_OR)
;                     GetRgnBox_(rgn, updateRect.RECT)
;                     updateRect\left = -frameXOffset
;                     updateRect\top = -frameYOffset
;                     MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
;                     DeleteObject_(rgn)
;                     DeleteObject_(crgn)
                    
                Else
                    
                    ;class.s = Space(255)
                    ;GetClassName_(hwnd, @class, 255)
                    ;debuglog("no frame: " + class)
                    
                    GetRgnBox_(*trackWin\divertedClipRgn, updateRect.RECT)
                    ;GetClipBox_(*trackWin\divertedDC, updateRect.RECT)
                    MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
                    
                EndIf
                
                *trackWin\divertedRefresh = #True
                RefreshPanelEx(*panelex\Handle, updateRect)
                
            EndIf
            
            *trackWin\divertedlpPaintDCIndex - 1
            If *trackWin\divertedlpPaintDCIndex < 0
                *trackWin\divertedlpPaintDCIndex = 0
            EndIf
            If *trackWin\divertedlpPaintDCs[*trackWin\divertedlpPaintDCIndex] <> #Null
                *lpPaint\hdc = *trackWin\divertedlpPaintDCs[*trackWin\divertedlpPaintDCIndex]
                *trackWin\divertedlpPaintDCs[*trackWin\divertedlpPaintDCIndex] = #Null
            EndIf
            
        EndIf
        
        result = EndPaint(hwnd, *lpPaint)
        
    Else
        result = EndPaint(hwnd, *lpPaint)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newBeginPaint(hwnd, *lpPaint.PAINTSTRUCT)
    
;     class.s = Space(255)
;     GetClassName_(hwnd, @class, 255)
;     debuglog("BeginPaint " + class + " " + Str(hwnd))
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null
        
        If *trackWin\rootPanelex <> #Null
            
            If *trackWin\windowType = #WINDOWTYPE_REBAR
                ;debuglog("")
                ;debuglog("-------------- paint")
            EndIf
            
            result = BeginPaint(hwnd, *lpPaint)
            
            class.s = Space(255)
            GetClassName_(hwnd, @class, 255)
            debuglog("BeginPaint " + class + " " + Str(hwnd))
            
            If *trackWin\noPaint = #True
                ProcedureReturn result
            EndIf
            
            Select *trackWin\windowType
                    
                Case #WINDOWTYPE_PANELEX, #WINDOWTYPE_PANELEXPAGE, #WINDOWTYPE_PBFRAME;, #WINDOWTYPE_WEBDocObject, #WINDOWTYPE_WEBExplorer
                    
                    ; do nothing
                    
                Default
                ;Case #WINDOWTYPE_STATIC, #WINDOWTYPE_SYSSCROLLBAR, #WINDOWTYPE_SYSPROGRESSBAR, #WINDOWTYPE_SYSBUTTON, #WINDOWTYPE_EDIT, #WINDOWTYPE_RICHEDIT, #WINDOWTYPE_LISTBOX, #WINDOWTYPE_LISTVIEW
                    
                    *trackWin\divertedRefreshCount + 1
                    
                    result = getDivertedBuffer(*trackWin, result, #True)
                    
                    *trackWin\divertedlpPaintDCs[*trackWin\divertedlpPaintDCIndex] = *lpPaint\hdc
                    *trackWin\divertedlpPaintDCIndex + 1
                    If *trackWin\divertedlpPaintDCIndex > #MAXGETS-1
                        *trackWin\divertedlpPaintDCIndex = #MAXGETS-1
                    EndIf
                    
                    *lpPaint\hdc = result
                    
                    brush = GetClassLongPtr_(hwnd, #GCL_HBRBACKGROUND)
                    If brush <> #Null; And (*trackWin\windowType = #WINDOWTYPE_RICHEDIT Or *trackWin\windowType = #WINDOWTYPE_LISTBOX)
                        ;class.s = Space(255)
                        ;GetClassName_(hwnd, @class, 255)
                        ;debuglog("BeginPaint " + class + " " + Str(hwnd))
                        If *trackWin\windowType = #WINDOWTYPE_RICHEDIT
                            sysbrush = GetSysColorBrush_(brush-1)
                            If sysbrush <> #Null
                                brush = sysbrush
                            EndIf
                            GetClientRect_(hwnd, rc.RECT)
                            FillRect_(result, rc, brush)
                        EndIf
                        
                    Else
                        If *trackWin\noErase = #False
                            CallWindowProc_(*trackWin\callbackProc, hwnd, #WM_ERASEBKGND, result, 0)
                        EndIf
                    EndIf
                    
                    ;debuglog("BeginPaint result: " + Str(result))
                    ;debuglog("+" + Str(*lpPaint\rcPaint\left) + " " + Str(*lpPaint\rcPaint\top) + " " + Str(*lpPaint\rcPaint\right) + " " + Str(*lpPaint\rcPaint\bottom) + " ")
                    
            EndSelect
            
        Else
            result = BeginPaint(hwnd, *lpPaint)
        EndIf
            
    Else
        result = BeginPaint(hwnd, *lpPaint)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newwglCreateContext(hdc)
    
    debuglog("***********************wglCreateContext")
    
    result = wglCreateContext(hdc)
    
    ProcedureReturn result
    
EndProcedure

Procedure newwglMakeCurrent(hdc, *hglrc)
    
    debuglog("***********************wglMakeCurrent(hdc, *hglrc)")
    
    ;result = wglMakeCurrent(hdc, *hglrc)
    
    ;ProcedureReturn result
    
    hwnd = WindowFromDC_(hdc)
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null
        
        If *trackWin\rootPanelex <> #Null
            
            hdc = getDivertedBuffer(*trackWin, hdc, #True)
            ;debuglog(Str(hdc))
            
            result = wglMakeCurrent(hdc, *hglrc)
            ;debuglog("result2: " + Str(result))
            
        Else
            result = wglMakeCurrent(hdc, *hglrc)
        EndIf
            
    Else
        result = wglMakeCurrent(hdc, *hglrc)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newDrawText(hDC, *lpchText, nCount, *lpRect.RECT, uFormat)
    
    ;debuglog("***********************DrawText(hDC, *lpchText, nCount, lpRect.RECT, uFormat)")
    
    ;text.s = Trim(PeekS(*lpchText))
    
    If uFormat & #DT_CALCRECT
        
        ;result = gdiDrawText(hDC, *lpchText, nCount, *lpRect.RECT, uFormat)
        
        CallFunctionFast(*GdipCreateFromHDC, hDC, @GraphicObject)
        CallFunctionFast(*GdipSetCompositingQuality, GraphicObject, 1) ; QualityModeHighSpeed
        CallFunctionFast(*GdipSetSmoothingMode, GraphicObject, 2)      ; QualityModeHigh
        ;GdipSetCompositingMode(GraphicObject, 1)
        GdipSetTextRenderingHint(GraphicObject, 3)
        ;GdipSetPixelOffsetMode(GraphicsObject, 4)
        
        GdipCreateFontFromDC(hDC, @fontObject)
        
        recf.RECTF
        GdipMeasureString(GraphicObject, *lpchText, nCount, fontObject, recf, #Null, recf, @codepointsFitted, @linesFilled)
        
        *lpRect\left = recf\left
        *lpRect\top = recf\top
        *lpRect\right = recf\right
        *lpRect\bottom = recf\bottom
        
        If ncount = 1
            *lpRect\right - 4
        EndIf
        
        CallFunctionFast(*GdipDeleteGraphics, GraphicObject)
        GdipDeleteFont(fontObject)
        
        result = *lpRect\bottom-*lpRect\top
        
    Else
        
        CallFunctionFast(*GdipCreateFromHDC, hDC, @GraphicObject)
        CallFunctionFast(*GdipSetCompositingQuality, GraphicObject, 1) ; QualityModeHighSpeed
        CallFunctionFast(*GdipSetSmoothingMode, GraphicObject, 2)      ; QualityModeHigh
        ;GdipSetCompositingMode(GraphicObject, 1)
        GdipSetTextRenderingHint(GraphicObject, 3)
        ;GdipSetPixelOffsetMode(GraphicsObject, 4)
        
        GdipCreateFontFromDC(hDC, @fontObject)
        
        c = GetTextColor_(hDC)
        ARGB = MakeColour(255, Red(c), Green(c), Blue(c))
        GdipCreateSolidFill(ARGB, @brush)
        
        ;*text = AllocateMemory(StringByteLength(txtbuff, #PB_Unicode)+2)
        ;PokeS(*text, txtbuff, -1, #PB_Unicode)
        
        If clipPath <> #Null
            GdipSetClipPath(GraphicObject, clipPath, 0)
        EndIf
        
        ;GdipCreateStringFormat(0, 0, @format)
        ;GdipSetStringFormatAlign(format, 2)
        
        recf.RECTF
        recf\left = *lpRect\left
        recf\top = *lpRect\top
        recf\right = *lpRect\right
        recf\bottom = *lpRect\bottom
        ;DT_VCENTER
        GdipDrawString(GraphicObject, *lpchText, nCount, fontObject, recf, format, brush)
        
        ;FreeMemory(*text)
        CallFunctionFast(*GdipDeleteGraphics, GraphicObject)
        GdipDeleteFont(fontObject)
        GdipDeleteBrush(brush)
        ;GdipDeleteStringFormat(format)
        
        result = recf\bottom-recf\top
        
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newDrawText_(hDC, *lpchText, nCount, *lpRect.RECT, uFormat)
    
    ;debuglog("***********************DrawText(hDC, *lpchText, nCount, lpRect.RECT, uFormat)")
    
    Debug *currentTrackwin
    
    result = gdiDrawText(hDC, *lpchText, nCount, *lpRect, uFormat)
    
    ProcedureReturn result
    
EndProcedure

;-

Procedure KillProcess_ProGUI(pid)
    phandle = OpenProcess_ (#PROCESS_TERMINATE, #False, pid)
    If phandle <> #Null
        If TerminateProcess_ (phandle, 1)
            Result = #True
        EndIf
        CloseHandle_ (phandle)
    EndIf
    ProcedureReturn Result
EndProcedure 

; makes sure process terminates after period of time even if trial timeout window is disabled
Procedure monitorTrialTimeoutWindow(*dummy)
    
    Repeat
        RandomSeed(ElapsedMilliseconds())
        Delay(20000+Random(300000))  ; wait minimum of 20 secs plus random amount of seconds upto 5 minutes
        KillProcess_ProGUI(GetCurrentProcessId_())
        macro_verifyKeys()
        HaltProGUI = #True
    ForEver
    
EndProcedure

Global HaltProGUI
Procedure trialThread(*dummy)
    
    CompilerIf #DEBUGENABLED = -1
        debuglog("trial thread: started.")
    CompilerEndIf
    
    Repeat
        
        Delay(10)
        
        LockMutex(trialMutex)
        
        If trialCounter > 0
            trialCounter = trialCounter - 1
        Else
            If trialThreadStop = #False
                HaltProGUI = #True
                CreateThread(@monitorTrialTimeoutWindow(), 0)
                UnlockMutex(trialMutex)
                MessageRequester("ProGUI Trial timeout", "Your trial time has run out for this session!", #PB_MessageRequester_Ok)
                KillProcess_ProGUI(GetCurrentProcessId_())
                macro_verifyKeys()
                Repeat
                    Delay(100)
                ForEver
            EndIf
        EndIf
        
        If trialThreadStop = #True
            UnlockMutex(trialMutex)
            Break
        EndIf
        UnlockMutex(trialMutex)
        
    ForEver
    
    CompilerIf #DEBUGENABLED = -1
        debuglog("trial thread: stopped.")
    CompilerEndIf
    
    LockMutex(trialMutex)
    trialThreadStopped = #True
    UnlockMutex(trialMutex)
    
    ProcedureReturn 1337
    
EndProcedure

;- StartProGUI
ProcedureDLL StartProGUI(user.s, k1.l, k2.l, k3.l, k4.l, k5.l, k6.l, k7.l)
    Static startProGUICalled
    
    If startProGUICalled = #False
        
        CompilerIf #DISABLEPROTECTION = 0
            CompilerIf #LIBRARY = 0
                macro_verifyHash()
                If *MD5mem <> 0
                    FreeMemory(*MD5mem)
                EndIf
            CompilerEndIf
        CompilerEndIf
        
        If regk1 = 0
            reguser = user
            regk1 = k1
            regk2 = k2
            regk3 = k3
            regk4 = k4
            regk5 = k5
            regk6 = k6
            regk7 = k7
            
            CompilerIf #DISABLEPROTECTION = 0
                trialThreadID = ThreadID(CreateThread(@trialThread(), 0))
                Repeat
                    GetExitCodeThread_(trialThreadID, @ExitCode)
                    If ExitCode <> #STATUS_PENDING
                        CompilerIf #DEBUGENABLED = -1
                            debuglog("waiting for trial thread...")
                        CompilerEndIf
                        Delay(100)
                    EndIf
                Until ExitCode = #STATUS_PENDING
                macro_verifyKeys()
            CompilerEndIf
        EndIf
        
        ; create hook to intercept creation of new windows for keeping track of windows
        ; i.e. handling windows dropped inside panelEx page with autoscroll turned on
        If WindowHook = 0
            CompilerIf #DEBUGENABLED = -1
                debuglog("creating window hook...")
            CompilerEndIf
            threadId = GetCurrentThreadId_()
            WindowHook = SetWindowsHookEx_(#WH_CALLWNDPROC, @CallWndProcHook(), 0, threadId)
            CompilerIf #DEBUGENABLED = -1
                debuglog("window hook created.")
            CompilerEndIf
        EndIf
        
        startProGUICalled = #True
        
        ; start animation thread
        CompilerIf #DEBUGENABLED = -1
            debuglog("creating animation thread...")
        CompilerEndIf
        animationThreadHandle = ThreadID(CreateThread(@animationThread(), 0))
        animationThreadID = GetThreadIDFromHandle(animationThreadHandle)
        CompilerIf #DEBUGENABLED = -1
            debuglog("animation thread created.")
        CompilerEndIf
        
    EndIf
    
EndProcedure

; used for enumerating and closing down windows on detach process
Procedure EnumWindowsProc(hwnd, lParam)
    
    GetWindowThreadProcessId_(hwnd, @processID)
    If processID = lParam
        DestroyWindow_(hwnd)
    EndIf
    ;debuglog("destroy")
    
    ProcedureReturn #True
EndProcedure

; used for enumerating and hiding windows on detach process
Procedure EnumHideWindowsProc(hwnd, lParam)
    
    GetWindowThreadProcessId_(hwnd, @processID)
    If processID = lParam
        ShowWindow_(hwnd, #SW_HIDE)
    EndIf
    
    ProcedureReturn #True
EndProcedure

ProcedureDLL ProGUI_End()
    
    ; get rid of animation thread
    If animationThreadHandle <> #Null
        For n = 0 To 100
            If animationThreadHwnd <> #Null
                PostMessage_(animationThreadHwnd, #WM_CLOSE, 0, 0)
            EndIf
            ;If animationThreadHwnd = #Null
            ;    TerminateThread_(animationThreadHandle, 1337)
            ;EndIf
            GetExitCodeThread_(animationThreadHandle, @ExitCode)
            If ExitCode = 1337 Or ExitCode <> #STATUS_PENDING
                CompilerIf #DEBUGENABLED = -1
                    debuglog("animation thread terminated.")
                CompilerEndIf
                Break
            EndIf
            CompilerIf #DEBUGENABLED = -1
                debuglog("waiting for animation thread..."+Str(n))
            CompilerEndIf
            Delay(10)
        Next
        CompilerIf #DEBUGENABLED = -1
            debuglog("continue free up...")
        CompilerEndIf
    EndIf
    
    ; get rid of trialthread
    If trialThreadID <> 0
        LockMutex(trialMutex)
        trialThreadStop = #True
        trialCounter = 0
        UnlockMutex(trialMutex)
        For n = 0 To 100
            LockMutex(trialMutex)
            If trialThreadStopped = #True
                TerminateThread_(trialThreadID, 1337)
                trialThreadStopped + 1
            EndIf
            UnlockMutex(trialMutex)
            GetExitCodeThread_(trialThreadID, @ExitCode)
            If ExitCode = 1337 Or ExitCode <> #STATUS_PENDING
                CompilerIf #DEBUGENABLED = -1
                    debuglog("trial thread terminated.")
                CompilerEndIf
                Break
            EndIf
            CompilerIf #DEBUGENABLED = -1
                debuglog("waiting for trial thread..."+Str(n))
            CompilerEndIf
            Delay(10)
        Next
    EndIf
    
    ; hide client windows left open before the dll is detached
    CompilerIf #DEBUGENABLED = 0
        EnumWindows_(@EnumHideWindowsProc(), GetCurrentProcessId_())
    CompilerEndIf
    
    FreeRebar(-1)
    debuglog("freed rebars")
    FreeToolBarEx(-1)
    debuglog("freed toolbars")
    FreeMenuEx(-1)
    debuglog("freed menus")
    
    If WindowHook <> 0
        UnhookWindowsHookEx_(WindowHook)
    EndIf
    
    If KeyboardHook <> 0
        UnhookWindowsHookEx_(KeyboardHook)
    EndIf
    
    If HotKeyHook <> 0
        UnhookWindowsHookEx_(HotKeyHook)
    EndIf
    
    ForEach menuCallback()
        If menuCallback()\oldCallback <> 0
            If IsWindow_(menuCallback()\WindowID)
                SetWindowLongPtr_(menuCallback()\WindowID, #GWLP_WNDPROC, menuCallback()\oldCallback)
            EndIf
        EndIf
    Next
    
    ; make sure there are no client windows left open before the dll is detached
    EnumWindows_(@EnumWindowsProc(), GetCurrentProcessId_())
    
    ExitXPtheme()
    ExitGDIPlus()
    ExitDwmapi()
    ExitMMCSS()
    
    GlobalDeleteAtom_(panelexAtom)
    GlobalDeleteAtom_(panelexPageAtom)
    GlobalDeleteAtom_(trackwinAtom)
    GlobalDeleteAtom_(txtcontrolAtom)
    GlobalDeleteAtom_(buttonexAtom)
    GlobalDeleteAtom_(splitterexAtom)
    GlobalDeleteAtom_(explorerbarAtom)
    GlobalDeleteAtom_(graphAtom)
    
    CompilerIf #DEBUGENABLED <> 0
        debuglog("bye bye!")
        Delay(1000)
    CompilerEndIf
    
EndProcedure

CompilerIf #LIBRARY = 0
    ProcedureDLL AttachProcess(Instance)
        
        ProGUI_Instance = Instance
        ProGUI_Init()
        
    EndProcedure
CompilerEndIf

;- DetachProcess
CompilerIf #LIBRARY = 0
    ProcedureDLL DetachProcess(Instance)
        ProGUI_End()
        
    EndProcedure
    
    ProcedureDLL AttachThread(Instance)
    EndProcedure
    
    ProcedureDLL DetachThread(Instance)
    EndProcedure
CompilerEndIf

