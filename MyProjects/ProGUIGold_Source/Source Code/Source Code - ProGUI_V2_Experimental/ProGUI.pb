Structure DrawingInfoStruct
    Type.l                ; Type of the DC
    Window.i              ; Window associated to the DC (if any)
    dc.i                  ; DC (Display Device Context)
    ReleaseProcedure.i    ; Address to a procedure to release the DC when StopDrawing() is called
    PixelBuffer.i         ; Address of the memory pixel buffer (DirectX)
    Pitch.l               ; Bytes per line (DirectX)
    width.l
    height.l
    Depth.l
EndStructure 

CompilerIf Defined(GUITHREADINFO, #PB_Structure) = #False
    Structure GUITHREADINFO
        cbSize.l
        flags.l
        hwndActive.i
        hwndFocus.i
        hwndCapture.i
        hwndMenuOwner.i
        hwndMoveSize.i
        hwndCaret.i
        rcCaret.RECT
    EndStructure
CompilerEndIf

