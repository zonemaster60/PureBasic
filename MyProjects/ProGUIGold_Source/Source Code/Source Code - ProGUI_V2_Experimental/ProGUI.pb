                                    ; CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #toolstripDropdownGradient3, #returnColour),getMenuColourEx(6, #toolstripDropdownGradient4, #returnColour),1,@colour2)
                                    ; CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour2,right,(*nmTBCust\rc\bottom/2)+1,dropWidth,(*nmTBCust\rc\bottom/2))
                                    ; 
                                    ; CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                                    ; CallFunctionFast(*GdipDeleteBrush,colour)
                                    ; CallFunctionFast(*GdipDeleteBrush,colour2)
                                    ; 
                                    ; ; draw dropdown glyph
                                    ; ImageList_Draw_(toolstripDropdownGlyph, 0, *nmTBCust\hdc, *nmTBCust\rc\left+right+((dropWidth/2)-3), *nmTBCust\rc\top+((*nmTBCust\rc\bottom/2)-7), #ILD_NORMAL)
                                    ; 
                                    ; ; draw top end drop rounded corner
                                    ; topleftPixel = GetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\top)
                                    ; SetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\top, topleftPixel)
                                    ; topleftPixel = AlphaBlend (topleftPixelSrc , topleftPixel , 145)
                                    ; SetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\top, topleftPixelSrc)
                                    ; SetPixel_(*nmTBCust\hdc, right+dropWidth-2,*nmTBCust\rc\top+1, topleftPixel)
                                    ; topleftPixel = AlphaBlend (topleftPixelSrc , topleftPixel , 115)
                                    ; SetPixel_(*nmTBCust\hdc, right+dropWidth-2,*nmTBCust\rc\top, topleftPixel)
