ProcedureDLL AddGraphRange(id.i, minX.d, maxX.d, minY.d, maxY.d, colour.l, showBorder.b, label.s, noRefresh.b) ; Adds a coloured range box to a graph
    
    hwnd = getHwndFromUniqueID(id)
    If hwnd <> #Null
        id = hwnd
    EndIf
    *graph.GL_Graphs = GetProp_(id, graphAtom)
    If *graph = #Null
        ProcedureReturn #False
    EndIf
            
    AddElement(*graph\range())
    *graph\range()\xMin = minX
    *graph\range()\xMax = maxX
    *graph\range()\yMin = minY
    *graph\range()\yMax = maxY
    *graph\range()\colour = colour
    *graph\range()\label = label
    *graph\range()\showBorder = showBorder
    
    If noRefresh = #False
        RefreshGraph(*graph\handle)
    EndIf
    
    ProcedureReturn *graph\range()
    
EndProcedure

ProcedureDLL AddGraphPolyRange(id.i, label.s, colour.l, *points.POINTD, numberOfPoints.i, isFilled.b, thickness.i, dashStyle.i, isClosed.b, noRefresh.b) ; Adds a coloured polygon range to a graph
    
    hwnd = getHwndFromUniqueID(id)
    If hwnd <> #Null
        id = hwnd
    EndIf
    *graph.GL_Graphs = GetProp_(id, graphAtom)
    If *graph = #Null
        ProcedureReturn #False
    EndIf
            
    AddElement(*graph\prange())
    *graph\prange()\label = label
    *graph\prange()\colour = colour
    *graph\prange()\isFilled = isFilled
    *graph\prange()\thickness = thickness
    *graph\prange()\dashStyle = dashStyle
    *graph\prange()\isClosed = isClosed
    
    Dim *graph\prange()\pnt(numberOfPoints)
    For n = 0 To numberOfPoints-1
        CopyStructure(*points, *graph\prange()\pnt(n), POINTD)
        *points + SizeOf(POINTD)
    Next
    
    If noRefresh = #False
        RefreshGraph(*graph\handle)
    EndIf
    
    ProcedureReturn *graph\prange()
    
EndProcedure

ProcedureDLL AddGraphLine(id.i, *points.POINTD, numberOfPoints.i, colour.l, lineThickness.i, style.i, label.s, nodeType.i, nodeSize.i, noRenderLine.b, showOnLegend.b, showFloatingLabel.b, noRefresh.b) ; Adds a line to a graph
    
    hwnd = getHwndFromUniqueID(id)
    If hwnd <> #Null
        id = hwnd
    EndIf
    *graph.GL_Graphs = GetProp_(id, graphAtom)
    If *graph = #Null
        ProcedureReturn #False
    EndIf
            
    AddElement(*graph\Line())
    For n = 0 To numberOfPoints-1
        AddElement(*graph\Line()\pnt())
        CopyStructure(*points, *graph\Line()\pnt(), POINTD)
        *points + SizeOf(POINTD)
    Next
    *graph\Line()\colour = colour
    *graph\Line()\label = label
    If lineThickness = #Null
        *graph\Line()\thickness = #GL_Default_lineThickness
    Else
        *graph\Line()\thickness = lineThickness
    EndIf
    *graph\Line()\nodeType = nodeType
    *graph\Line()\style = style
    If nodeSize = #Null
        *graph\Line()\nodeSize = #GL_Default_lineNodeSize
    Else
        *graph\Line()\nodeSize = nodeSize
    EndIf
    *graph\Line()\noLines = noRenderLine
    
    *graph\Line()\showOnLegend = showOnLegend
    *graph\Line()\showFloatingLabel = showFloatingLabel
    
    If *graph\Line()\showOnLegend = #True
        updateLegend(*graph)
    EndIf
    
    If noRefresh = #False
        RefreshGraph(*graph\handle)
    EndIf
    
    ProcedureReturn *graph\Line()
    
EndProcedure

; parameter callback takes the *value.d (pointer to double precision value) and must return a colour value
ProcedureDLL AddGraphDensityPlot(id.i, minX.d, maxX.d, minY.d, maxY.d, *density2DArray.double, numberOfCols.i, numberOfRows.i, minColour.l, maxColour.l, label.s, *callback, noRefresh.b) ; Adds a density plot to a graph
    
    hwnd = getHwndFromUniqueID(id)
    If hwnd <> #Null
        id = hwnd
    EndIf
    *graph.GL_Graphs = GetProp_(id, graphAtom)
    If *graph = #Null
        ProcedureReturn #False
    EndIf
            
    AddElement(*graph\density())
    *graph\density()\label = label
    *graph\density()\xMin = minX
    *graph\density()\xMax = maxX
    *graph\density()\yMin = minY
    *graph\density()\yMax = maxY
    *graph\density()\minColour = minColour
    *graph\density()\maxColour = maxColour
    
    *graph\density()\gridlineColour = #GL_Default_densityGridlineColour
    *graph\density()\gridlineWidth = #GL_Default_densityGridlineThickness
    *graph\density()\showGridlines = #GL_Default_densityShowGridlines
    *graph\density()\showValues = #GL_Default_densityShowValues
    *graph\density()\showValuesOnHover = #GL_Default_densityShowValuesOnHover
    *graph\density()\valueFont = GL_Default_densityFont
    *graph\density()\valueColour = #GL_Default_densityValueColour
    
    *graph\density()\callback = *callback
    
    Dim density.d(numberOfCols, numberOfRows)
    For x = 0 To ArraySize(density(), 1)
        For y = 0 To ArraySize(density(), 2)
            density(x, y) = *density2DArray\d
            *density2DArray + SizeOf(double)
        Next
    Next
    
    Dim *graph\density()\Plot(ArraySize(density(), 1), ArraySize(density(), 2))
    Dim *graph\density()\plotCache(ArraySize(density(), 1), ArraySize(density(), 2))
    CopyArray(density(), *graph\density()\Plot())
    
    ; find smallest value
    minValue.d = Infinity()
    For y = 0 To ArraySize(density(), 2)
        For x = 0 To ArraySize(density(), 1)
            If density(x, y) < minValue
                minValue = density(x, y)
            EndIf
        Next
    Next
    *graph\density()\minValue = minValue
    ;Debug "minValue: "+StrD(*graph\density()\minValue)
    
    ; find largest value
    maxValue.d = -Infinity()
    For y = 0 To ArraySize(density(), 2)
        For x = 0 To ArraySize(density(), 1)
            If density(x, y) > maxValue
                maxValue = density(x, y)
            EndIf
        Next
    Next
    *graph\density()\maxValue = maxValue
    ;Debug "maxValue: "+StrD(*graph\density()\maxValue)
    
    If noRefresh = #False
        RefreshGraph(*graph\handle)
    EndIf
    
    ProcedureReturn *graph\density()
    
EndProcedure

ProcedureDLL SetGraphDensityPlotGridlines(id.i, densityPlotID.i, showGridlines.b, thickness.i, colour.l, noRefresh.b) ; Sets a graph density plot gridlines 
    
    hwnd = getHwndFromUniqueID(id)
    If hwnd <> #Null
        id = hwnd
    EndIf
    *graph.GL_Graphs = GetProp_(id, graphAtom)
    If *graph = #Null
        ProcedureReturn #False
    EndIf
            
    ForEach *graph\density()
        
        If *graph\density() = densityPlotID
            
            *graph\density()\showGridlines = showGridlines
            *graph\density()\gridlineWidth = thickness
            *graph\density()\gridlineColour = colour
            
            If noRefresh = #False
                RefreshGraph(*graph\handle)
            EndIf
            
            retval = #True
            Break
        EndIf
        
    Next
            
    ProcedureReturn retval
    
EndProcedure

ProcedureDLL SetGraphDensityPlotValueOptions(id.i, densityPlotID.i, showValues.b, showValuesOnHover, noRefresh.b) ; Sets a graph density plot options 
    
    hwnd = getHwndFromUniqueID(id)
    If hwnd <> #Null
        id = hwnd
    EndIf
    *graph.GL_Graphs = GetProp_(id, graphAtom)
    If *graph = #Null
        ProcedureReturn #False
    EndIf
            
    ForEach *graph\density()
        
        If *graph\density() = densityPlotID
            
            *graph\density()\showValues = showValues
            *graph\density()\showValuesOnHover = showValuesOnHover
            
            If noRefresh = #False
                RefreshGraph(*graph\handle)
            EndIf
            
            retval = #True
            Break
        EndIf
        
    Next
           
    ProcedureReturn retval
    
EndProcedure

Procedure AddGraphBars_(id.i, Array bars.GL_GraphBar(1), isHorizontal.b, noRefresh.b) ; Adds a bar chart to a graph
    
    hwnd = getHwndFromUniqueID(id)
    If hwnd <> #Null
        id = hwnd
    EndIf
    *graph.GL_Graphs = GetProp_(id, graphAtom)
    If *graph = #Null
        ProcedureReturn #False
    EndIf
            
    AddElement(*graph\bars())
    *graph\bars()\isHorizontal = isHorizontal
    
    Dim *graph\bars()\bar(ArraySize(bars()))
    CopyArray(bars(), *graph\bars()\bar())
    
    If noRefresh = #False
        RefreshGraph(*graph\handle)
    EndIf
    
    ProcedureReturn *graph\bars()
    
EndProcedure

ProcedureDLL AddGraphBars(id.i, *bars.GL_GraphBar, numberOfBars.i, isHorizontal.b, noRefresh.b) ; Adds a bar chart to a graph
    
    hwnd = getHwndFromUniqueID(id)
    If hwnd <> #Null
        id = hwnd
    EndIf
    *graph.GL_Graphs = GetProp_(id, graphAtom)
    If *graph = #Null
        ProcedureReturn #False
    EndIf
            
    AddElement(*graph\bars())
    *graph\bars()\isHorizontal = isHorizontal
    
    Dim *graph\bars()\bar(numberOfBars)
    
    For n = 0 To numberOfBars-1
        CopyStructure(*bars, *graph\bars()\bar(n), GL_GraphBar)
        *bars + SizeOf(GL_GraphBar)
    Next
    
    If noRefresh = #False
        RefreshGraph(*graph\handle)
    EndIf
    
    ProcedureReturn *graph\bars()
    
EndProcedure

ProcedureDLL AddGraphFeatureLabel(id.i, label.s, colour.l, GL_Font.i, x.f, y.f, angle.f, noRefresh.b) ; Adds a feature text label to a graph
    
    hwnd = getHwndFromUniqueID(id)
    If hwnd <> #Null
        id = hwnd
    EndIf
    *graph.GL_Graphs = GetProp_(id, graphAtom)
    If *graph = #Null
        ProcedureReturn #False
    EndIf
            
    AddElement(*graph\label())
    *graph\label()\label = label
    *graph\label()\colour = colour
    If GL_Font = #Null
        *graph\label()\font = GL_Default_font
    Else
        *graph\label()\font = GL_Font
    EndIf
    *graph\label()\x = x
    *graph\Label()\y = y
    *graph\Label()\angle = angle
    
