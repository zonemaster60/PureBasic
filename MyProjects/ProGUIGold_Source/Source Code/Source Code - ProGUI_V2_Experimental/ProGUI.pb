Global ReturnString$  ; used for dll procedures that return a string



Procedure ErrorHandler()
    ErrorMessage.s = "A program error was detected:" + #CRLF$
    ErrorMessage + #CRLF$
    ErrorMessage + "Error message: " + ErrorMessage() + #CRLF$
    ErrorMessage + "Error code:    " + Str(ErrorCode()) + #CRLF$
    ErrorMessage + "Code address:  " + Str(ErrorAddress()) + #CRLF$
    
    If ErrorCode() = #PB_OnError_InvalidMemory
        ErrorMessage + "Target address:  " + Str(ErrorTargetAddress()) + #CRLF$
    EndIf
    
    If ErrorLine() = - 1
        ErrorMessage + "Sourcecode line: Enable OnError lines support to get code line information." + #CRLF$
    Else
        ErrorMessage + "Sourcecode line: " + Str(ErrorLine()) + #CRLF$
        ErrorMessage + "Sourcecode file: " + ErrorFile() + #CRLF$
    EndIf
    
    MessageRequester("ProGUI error", ErrorMessage)
    
EndProcedure

Procedure GetProcAddress(*lib, name$)
    
    *buff = AllocateMemory(StringByteLength(name$, #PB_Ascii) + 1)
    If *buff
        
        PokeS(*buff, name$, -1, #PB_Ascii)
        *address = GetProcAddress_(*lib, *buff)
        FreeMemory(*buff)
        
    EndIf
    
    ProcedureReturn *address
    
EndProcedure

;-
Procedure InitDwmapi()
    
    Dwmapi = OpenLibrary(#PB_Any, "dwmapi.dll")
    If Dwmapi <> #Null
        
        *DwmIsCompositionEnabled = GetFunction(Dwmapi, "DwmIsCompositionEnabled")
        *DwmEnableComposition = GetFunction(Dwmapi, "DwmEnableComposition")
        *DwmSetWindowAttribute = GetFunction(Dwmapi, "DwmSetWindowAttribute")
        *DwmFlush = GetFunction(Dwmapi, "DwmFlush")
        *DwmSetPresentParameters = GetFunction(Dwmapi, "DwmSetPresentParameters")
        Global DwmGetCompositionTimingInfo.DwmGetCompositionTimingInfo = GetFunction(Dwmapi, "DwmGetCompositionTimingInfo")
        Global DwmEnableMMCSS.DwmEnableMMCSS = GetFunction(Dwmapi, "DwmEnableMMCSS")
        Global DwmFlush.DwmFlush = GetFunction(Dwmapi, "DwmFlush")
        
        CallFunctionFast(*DwmIsCompositionEnabled, @CompositionEnabled)
        
        CompilerIf #DwmEnableMMCSS = #True
            DwmEnableMMCSS(#True) ; Notifies the Desktop Window Manager (DWM) to opt in to Multimedia Class Schedule Service (MMCSS) scheduling while the calling process is alive.
        CompilerEndIf
            
    EndIf
    
EndProcedure

Procedure ExitDwmapi()
    If Dwmapi <> #Null
        CloseLibrary(Dwmapi)
    EndIf
EndProcedure

Procedure InitMMCSS()
    MMCSS = OpenLibrary(#PB_Any, "Avrt.dll")
    If MMCSS <> #Null
        Global AvSetMmThreadCharacteristics.AvSetMmThreadCharacteristics = GetFunction(MMCSS, "AvSetMmThreadCharacteristicsW")
    EndIf
EndProcedure

Procedure ExitMMCSS()
    If MMCSS <> #Null
        CloseLibrary(MMCSS)
    EndIf
EndProcedure

Prototype OpenThemeData(hwnd.i, pszClassList.p-unicode)
Prototype GetCurrentThemeName(*pszThemeFileName, dwMaxNameChars, *pszColorBuff, cchMaxColorChars, *pszSizeBuff, cchMaxSizeChars)
Procedure InitXPtheme()
    
    If XPthemeActive = #Null
        
        XPthemeActive = LoadLibrary_("UxTheme.dll")
        If XPthemeActive <> #Null
            
            OpenThemeData.OpenThemeData = GetProcAddress(XPthemeActive, "OpenThemeData")
            *IsThemeBackgroundPartiallyTransparent = GetProcAddress(XPthemeActive, "IsThemeBackgroundPartiallyTransparent")
            *DrawThemeBackground = GetProcAddress(XPthemeActive, "DrawThemeBackground")
            *DrawThemeBackgroundEx = GetProcAddress(XPthemeActive, "DrawThemeBackgroundEx")
            *DrawThemeParentBackground = GetProcAddress(XPthemeActive, "DrawThemeParentBackground")
            *DrawThemeParentBackgroundEx = GetProcAddress(XPthemeActive, "DrawThemeParentBackgroundEx")
            *DrawThemeEdge = GetProcAddress(XPthemeActive, "DrawThemeEdge")
            *CloseThemeData = GetProcAddress(XPthemeActive, "CloseThemeData")
            *GetThemeSysColorBrush = GetProcAddress(XPthemeActive, "GetThemeSysColorBrush")
            *GetThemeSysColor = GetProcAddress(XPthemeActive, "GetThemeSysColor")
            *GetThemeColor = GetProcAddress(XPthemeActive, "GetThemeColor")
            *GetThemeRect = GetProcAddress(XPthemeActive, "GetThemeRect")
            *GetThemeFont = GetProcAddress(XPthemeActive, "GetThemeFont")
            *SetWindowTheme = GetProcAddress(XPthemeActive, "SetWindowTheme")
            
            Global GetCurrentThemeName.GetCurrentThemeName = GetProcAddress(XPthemeActive, "GetCurrentThemeName")
            
            *tmem = AllocateMemory(255)
            GetCurrentThemeName(*tmem, 100, 0, 0, 0, 0)
            name.s = PeekS(*tmem, -1, #PB_Unicode)
            FreeMemory(*tmem)
            name = RemoveString(name, " ")
            If name <> ""
                ThemesEnabled = #True
            Else
                ThemesEnabled = #False
            EndIf
            
            Window = GetForegroundWindow_()
            
            hTheme = OpenThemeData(Window, "scrollbar")
            If hTheme <> 0
                XPthemeColour = CallFunctionFast(*GetThemeSysColor, hTheme, 2)
                SetDefaultGlobalSkinColourTheme(XPthemeColour)
                ;Debug "R: "+Str(Red(XPthemeColour))+" G: "+Str(Green(XPthemeColour))+" B: "+Str(Blue(XPthemeColour))
            EndIf
            
            hThemeExplorerbar = OpenThemeData(Window, "explorerbar")
            hThemeRebar = OpenThemeData(Window, "rebar")
            hThemeTab = OpenThemeData(Window, "tab")
            hThemeToolbar = OpenThemeData(Window, "toolbar")
            hThemeMenu = OpenThemeData(Window, "menu")
            hThemeButton = OpenThemeData(Window, "button")
            
        EndIf
    EndIf
    
    ProcedureReturn XPthemeActive
EndProcedure

Procedure ExitXPtheme()
    If XPthemeActive <> #Null
        If hTheme <> #Null
            CallFunctionFast(*CloseThemeData, hTheme)
            CallFunctionFast(*CloseThemeData, hThemeExplorerbar)
            CallFunctionFast(*CloseThemeData, hThemeRebar)
            CallFunctionFast(*CloseThemeData, hThemeTab)
            CallFunctionFast(*CloseThemeData, hThemeToolbar)
            CallFunctionFast(*CloseThemeData, hThemeMenu)
            CallFunctionFast(*CloseThemeData, hThemeButton)
        EndIf
        FreeLibrary_(XPthemeActive)
    EndIf
EndProcedure


Procedure InitGDIPlus()
    
    If *gdiplusToken = 0
        GDIPlusHandle = OpenLibrary(#PB_Any,"GDIPlus.DLL")
        If GDIPlusHandle
            CoInitialize_(#Null)
            CompilerIf #DEBUGENABLED = -1
                debuglog("GDI+ Library opened ok.")
            CompilerEndIf
            gdpsi.GdiplusStartupInput
            gdpsi\GdiplusVersion = 1
            gdpsi\DebugEventCallback = 0
            gdpsi\SuppressBackgroundThread = #True
            gdpsi\SuppressExternalCodecs = 0
            CompilerIf #DEBUGENABLED = -1
                debuglog("starting GDI+...")
            CompilerEndIf
            CallFunction(GDIPlusHandle, "GdiplusStartup", @*gdiplusToken, @gdpsi, @gdpso)
            CallFunctionFast(gdpso\NotificationHook, @*gdiplusHookToken)
            CompilerIf #DEBUGENABLED = -1
                debuglog("GDI+ started ok: token: "+Str(*gdiplusToken)+" "+Str(*gdiplusHookToken))
                debuglog("hook: "+Str(gdpso\NotificationHook)+" "+Str(gdpso\NotificationUnHook))
            CompilerEndIf
            
            *GdipCreateFromHDC = GetFunction(GDIPlusHandle,"GdipCreateFromHDC")
            *GdipCreateFromHWND = GetFunction(GDIPlusHandle,"GdipCreateFromHWND")
            *GdipCreateLineBrushI = GetFunction(GDIPlusHandle,"GdipCreateLineBrushI")
