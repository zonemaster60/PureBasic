;                 
;                 *group\collapsed = #True
;                 
;                 SetButtonExState(*group\header, #True)
                
            EndIf
            
        Else
            
            If *group\collapsed = #True
                
;                 GetClientRect_(*group\group, srcRc.RECT)
;                 MapWindowPoints_(*group\group, GetParent_(*group\group), srcRc, 2)
;                 CopyStructure(srcRc, dstRc.RECT, RECT)
