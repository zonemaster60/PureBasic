;                         ry.d = Round((pointy-*graph\yAxisMin)*(grheight/Abs(*graph\yAxisMax-*graph\yAxisMin))+*graph\yOffset, #PB_Round_Nearest)
;                         
;                         rx2.d = Round((npointx-*graph\xAxisMin)*(grwidth/Abs(*graph\xAxisMax-*graph\xAxisMin))+*graph\xOffset, #PB_Round_Nearest)
;                         ry2.d = Round((npointy-*graph\yAxisMin)*(grheight/Abs(*graph\yAxisMax-*graph\yAxisMin))+*graph\yOffset, #PB_Round_Nearest)
