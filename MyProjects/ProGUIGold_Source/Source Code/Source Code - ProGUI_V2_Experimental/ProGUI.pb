                SetSkinProperty(sysXBarSkin, "explorerbar group header", "disabled", "background position", "right: 4; top: 50%; masked: true;")
                SetSkinProperty(sysXBarSkin, "explorerbar group header", "disabled", "image", "noclip: true;")
