;Procedure newBeginBufferedAnimation(hwnd, hdcTarget, *rcTarget.RECT, dwFormat, *pPaintParams.BP_PAINTPARAMS, *pAnimationParams.BP_ANIMATIONPARAMS, *phdcFrom, *phdcTo)
Procedure newBeginBufferedAnimation(hwnd, hdcTarget, *rcTarget.RECT, dwFormat, *pPaintParams.BP_PAINTPARAMS, *pAnimationParams.BP_ANIMATIONPARAMS, *phdcFrom, *phdcTo)
    
    ;class.s = Space(255)
    ;GetClassName_(hwnd, @class, 255)
