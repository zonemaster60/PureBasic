#MAXGETS = 1000

; used for keeping track of all windows in progui
Structure trackWindows Align #MEMORY_ALLOCATION_ALIGNMENT
    
    hwnd.i                 ; handle of the window
    callbackProc.i         ; original callback procedure of the window
    parent.i               ; parent hwnd
    *parentTrackWin        ; pointer to parent trackWindows structure
    windowType.l           ; identifies the type of window, used for ProGUI window control specific logic
    transparent.b          ; flags whether this window needs to be set to ws_ex_transparent if in ProGUI container
    isTransparent.b        ; flagged to true if ws_ex_transparent is currently set
    visible.b              ; flagged to true iv WS_VISIBLE is set
    limitSizeSet.b         ; true if limit window size has been set
    limitSize.RECT         ; used to limit the size of the window when resized
    *panelex               ; stores pointer to PanelEx structure if PanelEx window
    *panelexpage           ; stores pointer to PanelExPage if PanelExPage window
    rootPanelexHwnd.i      ; stores root (parent ancestor) panelex hwnd
    rootPanelexPageHwnd.i  ; stores root (parent ancestor) panelexpage hwnd
    *rootPanelex           ; stores pointer to root panelex
    *rootPanelexPage       ; stores pointer to root panelexpage
    *parentPanelEx         ; stores pointer to first parent panelex in nested panelex tree for use with none progui controls diverted rendering
    containsChildCntrl.b   ; flagged if PanelEx contains visible none ProGUI controls that are children or distant children of nested panelexes
    hBrush.i               ; stores handle to static control's cached background brush if in panelexpage
    
    ; diverted rendering of none progui controls in panelex page
    divertedDC.i            ; new Device Context that the control will render to
    divertedWinDC.i
    divertedOriginalDC.i    ; original Device Context handle
    divertedlpPaintDCIndex.i
    divertedlpPaintDCs.i[#MAXGETS]
    divertedGetIndex.i
    divertedGetDC.i[#MAXGETS] ; original Device Context handle when GetDC, GetDCEx or GetWindowDC is used
    divertedGetType.b[#MAXGETS]
    divertedBuffer.i          ; new bitmap selected into divertedDC that the control will render to
    divertedWinBuffer.i
    divertedWidth.i         ; the current width of the diverted bitmap
    divertedHeight.i        ; the current height of the diverted bitmap
    divertedWinWidth.i      ; the current width of the diverted bitmap
    divertedWinHeight.i     ; the current height of the diverted bitmap
    divertedRedraw.b        ; mutual exclusive spin lock used for diferentiating between control triggered redraw and RefreshPanelEx triggered redraw
    divertedRefresh.b
    divertedInsideDefWin.b  ; flagged to true if inside DefaultWindowProcedure
    divertedClipRgn.i       ; new divertedDC clip region, copied from original
    divertedOrgClipRgn.i    ; original DC default clip region
    divertedWinClipRgn.i       ; new divertedDC clip region, copied from original
    divertedWinOrgClipRgn.i    ; original DC default clip region
    *divertedlpTimerFunc    ; diverted lpTimerFunc callback pointer for use with diverted Scrollbars Vista+ theme animation fade
    divertedScrollTrack.l
    divertedLWidth.i
    divertedLHeight.i
    divertedDummyDC.i
    divertedDummyRgn.i
    divertedSetNoRedraw.b
    divertedLastRc.RECT
    divertedRefreshCount.b
    
    noPaint.b ; if set to true blocks all rendering of the window
    noErase.b ; is set to true blocks all erase background of the window
    noblit.b
EndStructure

