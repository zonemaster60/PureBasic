;                                     EndIf
                                    
                                    ; ;/ draw toolstrip dropdown
                                    ; dropWidth = 11
                                    ; 
                                    ; ; get bottom round drop corner pixels
                                    ; bPixelSrc = GetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\bottom-1)
                                    ; 
                                    ; ; get top round drop corner pixels
                                    ; topleftPixelSrc = GetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\top)
