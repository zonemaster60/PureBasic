                    SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected", "text", "font: "+fname+", "+Str(fheight)+", bold; colour: rgb("+Str(Red(fcolour))+","+Str(Green(fcolour))+","+Str(Blue(fcolour))+")")
                EndIf
