    MenuItemEx(GL_Command_Reset, "Use &default ranges", 0, 0, 0, 0)
    MenuItemEx(GL_Command_SetRanges, "Set &ranges", 0, 0, 0, 0)
    MenuBarEx()
    MenuItemEx(GL_Command_ZoomIn, "Zoom &In", 0, 0, 0, 0)
    MenuItemEx(GL_Command_ZoomOut, "Zoom &Out", 0, 0, 0, 0)
