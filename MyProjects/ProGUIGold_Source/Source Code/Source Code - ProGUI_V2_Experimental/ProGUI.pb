;- Border/Mask Structures
Structure BorderPart
    dat.i ; *img or *rgn
    datPremultiplied.i ; used with autostretch for keeping premultiplied copy of image GDI alphablit
    width.l
    height.l
EndStructure
Structure BorderImage
    
    crc32.i ; used to check whether this image has changed and redraw parts if so
    rc.RECT
    
    ; border image parts
    topLeft.BorderPart
    topRight.BorderPart
    bottomLeft.BorderPart
    bottomRight.BorderPart
    top.BorderPart
    left.BorderPart
    right.BorderPart
    bottom.BorderPart
    
EndStructure
Structure BorderMasks
    
    crc32.i ; used to check whether this image has changed and redraw parts if so
    rc.RECT
    maskrgn.i
    maskwidth.i
    maskheight.i
    
    ; border mask parts
    topLeft.BorderPart
    topRight.BorderPart
    bottomLeft.BorderPart
    bottomRight.BorderPart
    top.BorderPart
    left.BorderPart
    right.BorderPart
    bottom.BorderPart
    
EndStructure
Structure Borders
    
    thisimage.s
    thismask.s
    Map image.BorderImage()
    Map mask.BorderMasks()
    *srcHandle ; used if this is a copy
    
    autoStretchSides.RECT ; if side of rect not equal zero then auto stretch that image part instead of repeating
    
EndStructure

; used for auto border and auto mask (image processing)
Structure side
    c.i   ; current pixel colour brightness
    lc.i  ; last lowest pixel colour brightness
    a.i   ; current pixel alpha
    la.i  ; last pixel alpha (highest/lowest)
    x.i   ; current pixel x pos
    y.i   ; current pixel y pos
    lx.i  ; last pixel x pos
    ly.i  ; last pixel y pos
EndStructure

;- Skin Structures
Enumeration 1
    #SKIN_RES_ICON ; private
    #SKIN_RES_IMAGE; private
    #SKIN_RES_DATA ; private
EndEnumeration

#SKIN_SAVE_PACKAGE = $1

Structure skinProperties
    name.s
    value.s
    resType.i
    resData.i
    resDataSize.i
EndStructure

Structure skinStates
    name.s
    List property.skinProperties()
EndStructure

Structure skinComponents
    name.s
    List state.skinStates()
EndStructure

Structure skins
    name.s
    author.s
    date.s
    version.s
    url.s
    List component.skinComponents()
    autoUpdate.b ; if set to true, SetSkinProperty will automatically update all controls currently using this skin
EndStructure

