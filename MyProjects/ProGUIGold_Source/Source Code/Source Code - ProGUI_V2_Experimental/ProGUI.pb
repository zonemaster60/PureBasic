ProcedureDLL SetGraphAxisRanges(id.i, minX.d, maxX.d, minY.d, maxY.d, noRefresh.b) ; Sets the minimum and maximum range values of a graph's axis
    
    If minX >= maxX Or minY >= maxY
        ProcedureReturn #False
    EndIf
    
    hwnd = getHwndFromUniqueID(id)
    If hwnd <> #Null
        id = hwnd
    EndIf
    *graph.GL_Graphs = GetProp_(id, graphAtom)
    If *graph = #Null
        ProcedureReturn #False
    EndIf
    
    *graph\oxAxisMin = minX
    *graph\oyAxisMin = minY
    *graph\oxAxisMax = maxX
    *graph\oyAxisMax = maxY
    *graph\xAxisMin = minX
    *graph\yAxisMin = minY
    *graph\xAxisMax = maxX
    *graph\yAxisMax = maxY
    *graph\xOffset = 0
    *graph\yOffset = 0
    
    If noRefresh = #False
        RefreshGraph(*graph\handle)
    EndIf
            
    ProcedureReturn #True
    
EndProcedure

