Macro LOWORD( word ) : (word & $FFFF) : EndMacro
Macro HIWORD( word ) : ((word >> 16) & $FFFF) : EndMacro

ProcedureDLL LWord(Long.l) ; Returns the low-order word from a 32-bit number.
    ProcedureReturn (Long & $FFFF)
EndProcedure

ProcedureDLL HWord(Long.l) ; Returns the high-order word from a 32-bit number.
    ProcedureReturn ((Long >> 16) & $FFFF)
EndProcedure

Macro AlphaBlend ( lColor , RColor , Alpha )
    
    RGB ( ( ( Red ( RColor ) * Alpha + Red ( lColor ) * ( 256 - Alpha ) ) / 256 ) , ( ( Green ( RColor ) * Alpha + Green ( lColor ) * ( 256 - Alpha ) ) / 256 ) , ( ( Blue ( RColor ) * Alpha + Blue ( lColor ) * ( 256 - Alpha ) ) / 256 ) )
    
EndMacro

Macro IntersectRect(a, b)
    Bool(a\right >= b\left And a\left <= b\right And a\bottom >= b\top And a\top <= b\bottom)
EndMacro

CompilerIf #DEBUGENABLED = -1
    Global previousMutex
    Macro LockMutex(mutex)
        
        mutexTime = ElapsedMilliseconds()
        While TryLockMutex(mutex) = #False
            
            If ElapsedMilliseconds() > mutexTime + 1000
                
                debuglog("***********")
                debuglog("mutex boom! :"+Str(mutex)+" Line: "+Str(#PB_Compiler_Line))
                If FindMapElement(previousMutexLine(), Str(mutex)) <> #False
                    debuglog("previous lock line: "+previousMutexLine())
                EndIf
                debuglog("txtlink: "+Str(txtcontrolLinksMutex))
                debuglog("menu: "+Str(menuMutex))
                debuglog("panel: "+Str(panelExMutex))
                debuglog("***********")
                Repeat
                    Delay(1000)
                ForEver
                
                UnlockMutex(mutex)
            EndIf
        Wend
        
        previousMutexLine(Str(mutex)) = Str(#PB_Compiler_Line)
        
    EndMacro
CompilerEndIf

; - Function pTransform converts
; a RGB subcolor using a scale
; where 0 = 0 and 255 = lScale
Procedure pTransform(lScale, lColor)
    ProcedureReturn lColor - Int(lColor * lScale / 255)
EndProcedure

; - Function pMask splits a color
; into its rgb components And
; transforms the color using
; a scale 0..255
Procedure pMask(lScale, lColor)
    
    r = Red(lColor)
    g = Green(lColor)
    b = Blue(lColor)
    
    r = pTransform(lScale, r)
    g = pTransform(lScale, g)
    b = pTransform(lScale, b)
    
    ProcedureReturn RGB(r, g, b)
    
EndProcedure



; gets dimensions of windows handle to image or icon
; returns true if icon
Procedure GetImageDimensions(image.i, *width, *Height)
    
    If GetIconInfo_(image, @info.ICONINFO) <> 0
        If info\hbmColor
            image = info\hbmColor
        ElseIf info\hbmMask
            image = info\hbmMask
        EndIf
        RET = 1
    EndIf
    
    GetObject_(image, SizeOf(BITMAP), BM.BITMAP)
    
    If info\hbmColor <> 0
        DeleteObject_(info\hbmColor)
    EndIf
    If info\hbmMask <> 0
        DeleteObject_(info\hbmMask)
    EndIf
    
    PokeI(*width, BM\bmWidth)
    PokeI(*Height, BM\bmHeight)
    
    ProcedureReturn RET
    
EndProcedure

Procedure MakeLong(low.w, high.w)
    ProcedureReturn (high * $10000) | (low & $FFFF)
EndProcedure

;returns true if string is a number, can be a decimal number
Procedure IsNumeric(String$)
    If String$ And Trim(String$) <> "."
        *p.BYTE = @String$
        Repeat
            char = *p\b & $FF
            If (char >= '0' And char <= '9') Or char=0 Or char=46
                *p+1
            Else
                ProcedureReturn 0
            EndIf
        Until char = 0
        ProcedureReturn 1
    EndIf
    ProcedureReturn 0
EndProcedure

