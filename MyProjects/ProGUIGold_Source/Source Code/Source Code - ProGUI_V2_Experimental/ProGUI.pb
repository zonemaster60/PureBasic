Procedure getControlPanelExParent(hwnd, srcHwnd = #Null)
    
    If srcHwnd = #Null
        srcHwnd = hwnd
    EndIf
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null And *trackWin\rootPanelex <> #Null And *trackWin\windowType <> #WINDOWTYPE_PANELEX And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE
        
        *trackWin = *trackWin\parentTrackWin
        If *trackWin <> #Null
            
            If *trackWin\windowType = #WINDOWTYPE_PANELEXPAGE
                ProcedureReturn hwnd
            Else
                ProcedureReturn getControlPanelExParent(*trackWin\hwnd, srcHwnd)
            EndIf
            
        EndIf
        
    EndIf
    
    ProcedureReturn srcHwnd
    
EndProcedure

Procedure setControlTransparent(hwnd, state, level = 0)
    
    class.s = Space(255)
    GetClassName_(hwnd, @class, 255)
    debuglog("*** setControlTransparent: " + class + " " + Str(state))
    
;     If level = 0 And state = #True
;         
;         *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
;         If *trackWin <> #Null And *trackWin\rootPanelex <> #Null And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE And *trackWin\windowType <> #WINDOWTYPE_PANELEX
;             Repeat
;                 *trackWin = *trackWin\parentTrackWin
;                 If *trackWin <> #Null And *trackWin\rootPanelex <> #Null And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE And *trackWin\windowType <> #WINDOWTYPE_PANELEX And GetWindowLongPtr_(*trackWin\hwnd, #GWL_STYLE) & #WS_EX_TRANSPARENT = #False
;                     hwnd = *trackWin\hwnd
;                     Break
;                 EndIf
;             Until *trackWin = #Null
;         EndIf
;         
;     EndIf
    
    If level = 0 And state = #True
        hwnd = getControlPanelExParent(hwnd)
    EndIf
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null
        
        If state = #True
            
            If *trackWin\rootPanelexHwnd <> hwnd And *trackWin\rootPanelexPageHwnd <> hwnd
            
                gwlExStyle = GetWindowLongPtr_(hwnd, #GWL_EXSTYLE)
                If Not gwlExStyle & #WS_EX_TRANSPARENT
                    ;debuglog("windowshow in panelex: setting to ws_wx_transparent")
                    SetWindowLongPtr_(hwnd, #GWL_EXSTYLE, gwlExStyle | #WS_EX_TRANSPARENT)
                EndIf
                
        ;         gwlStyle = GetWindowLongPtr_(hwnd, #GWL_STYLE)
        ;         If Not gwlStyle & #WS_CLIPCHILDREN
        ;            SetWindowLongPtr_(hwnd, #GWL_STYLE, gwlStyle | #WS_CLIPCHILDREN|#WS_CLIPSIBLINGS)
        ;         EndIf
                
                ;gwlStyle = GetWindowLongPtr_(hwnd, #GWL_STYLE)
                ;If Not gwlStyle & #WS_CLIPSIBLINGS
                ;    SetWindowLongPtr_(hwnd, #GWL_STYLE, gwlStyle | #WS_CLIPSIBLINGS)
                ;EndIf
                
                
;                 If *trackWin\windowType <> #WINDOWTYPE_PANELEX And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE
;                     gwlStyle = GetWindowLongPtr_(hwnd, #GWL_STYLE)
;                     SetWindowLongPtr_(hwnd, #GWL_STYLE, gwlStyle &~ #WS_CLIPCHILDREN &~ #WS_CLIPSIBLINGS)
;                 EndIf
                
                Select *trackWin\windowType
                    Case #WINDOWTYPE_PBFRAME, #WINDOWTYPE_STATIC, #WINDOWTYPE_PBSPLITTER;, #WINDOWTYPE_SYSTAB, #WINDOWTYPE_SYSBUTTON, #WINDOWTYPE_UPDOWN
                        
                        gwlStyle = GetWindowLongPtr_(hwnd, #GWL_STYLE)
                        SetWindowLongPtr_(hwnd, #GWL_STYLE, gwlStyle | #WS_CLIPCHILDREN | #WS_CLIPSIBLINGS)
                        
                EndSelect
                
            EndIf
                
        Else
            
            gwlExStyle = GetWindowLongPtr_(hwnd, #GWL_EXSTYLE)
            If gwlExStyle & #WS_EX_TRANSPARENT
                ;debuglog("windowshow not in panelex: setting to not ws_wx_transparent")
                SetWindowLongPtr_(hwnd, #GWL_EXSTYLE, gwlExStyle &~ #WS_EX_TRANSPARENT)
            EndIf
            
        EndIf
        
        chwnd = GetWindow_(hwnd, #GW_CHILD)
        While chwnd <> #Null
            
            ;class.s = Space(255)
            ;GetClassName_(chwnd, @class, 255)
            ;debuglog("Child " + class + " " + Str(chwnd))
            
            setControlTransparent(chwnd, state, level+1)
            
            chwnd = GetWindow_(chwnd, #GW_HWNDNEXT)
            
        Wend
        
    EndIf
        
EndProcedure

Procedure setControlVisibility(*trackWin.trackWindows, state)
    
    *trackWin\visible = state
    
;     chwnd = GetWindow_(*trackWin\hwnd, #GW_CHILD)
;     While chwnd <> #Null
;         
;         *ctrackWin.trackWindows = GetProp_(chwnd, trackwinAtom)
;         
;         setControlVisibility(*ctrackWin, state)
;         
;         chwnd = GetWindow_(chwnd, #GW_HWNDNEXT)
;         
;     Wend
        
EndProcedure

Procedure setControlNoRedraw(*trackWin.trackWindows, state, nested = #False)
    
    If state = #True
        *trackWin\divertedSetNoRedraw + 1
    Else
        *trackWin\divertedSetNoRedraw - 1
        If *trackWin\divertedSetNoRedraw < 0
            *trackWin\divertedSetNoRedraw = 0
        EndIf
    EndIf
    
    If nested = #False
        ValidateRect_(*trackWin\hwnd, 0)
        RedrawWindow_(*trackWin\hwnd, #Null, #Null, #RDW_VALIDATE|#RDW_FRAME)
    EndIf
        
    chwnd = GetWindow_(*trackWin\hwnd, #GW_CHILD)
    While chwnd <> #Null
        
        *ctrackWin.trackWindows = GetProp_(chwnd, trackwinAtom)
        
        setControlNoRedraw(*ctrackWin, state, #True)
        
        chwnd = GetWindow_(chwnd, #GW_HWNDNEXT)
        
    Wend
        
EndProcedure
    
;- ****
Procedure SubclassTrackwinProc(WindowID,message,wParam,lParam)
    
    *trackWin.trackWindows = GetProp_(WindowID, trackwinAtom)
    If *trackWin = #Null
        ProcedureReturn #False
    EndIf
    
    ; process classic style window scrollbars if themes disabled and in Panelex
    If ThemesEnabled = #False And *trackWin\rootPanelex <> #Null And *trackWin\windowType <> #WINDOWTYPE_PANELEX And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE
        result = handleClassicScrollbars(*trackWin, WindowID, message, wParam, lParam)
        If result <> #False
            ProcedureReturn 0
        EndIf
    EndIf
        
    ; process any styled ComboBoxes in ToolBarEx
    If *trackWin\windowType = #WINDOWTYPE_SYSCOMBOBOX Or *trackWin\windowType = #WINDOWTYPE_SYSCOMBOBOXEDIT
        result = handleStyledComboBox(*trackWin, WindowID, message, wParam, lParam)
        If result <> #False
            ProcedureReturn result
        EndIf
    EndIf
    
    ;If *trackWin\windowType = #WINDOWTYPE_PBCONTAINER
    ;    debuglog("Message: " + Hex(message))
    ;EndIf
    
    ;If message = #WM_DRAWITEM
    ;    debuglog("#WM_DRAWITEM")
    ;EndIf
        
    Select message
            
;         Case #WM_NCCALCSIZE
;             
;             If *trackWin\rootPanelex <> #Null And *trackWin\windowType <> #WINDOWTYPE_PANELEX And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE
;                 
;                 *nccs_params.NCCALCSIZE_PARAMS = lParam
;                 
;                 CallWindowProc_(*trackWin\callbackProc, WindowID, message, #False, *nccs_params\rgrc[0])
;                 
;                 *nccs_params\rgrc[1] = *nccs_params\rgrc[2]
;                 
;                 ProcedureReturn #WVR_ALIGNLEFT|#WVR_ALIGNTOP
;                 ;ProcedureReturn #WVR_REDRAW
;                 
;             Else
;                 Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
;             EndIf
;             
        Case #WM_NCDESTROY
            
            Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
            
            ; delete cached static control backbrush if set
            If *trackWin\hBrush <> #Null
                DeleteObject_(*trackWin\hBrush)
                *trackWin\hBrush = #Null
            EndIf
            
            FreeStructure(*trackWin)
            RemoveProp_(WindowID, trackwinAtom)
            
        Case #WM_MOUSEMOVE
            
            If mouseCaptured = #False Or GetAncestor_(WindowID, #GA_ROOT) <> WindowID
                Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
            EndIf
            
        Case #WM_WINDOWPOSCHANGING
            
            *pos.WINDOWPOS = lParam
            
            If *trackWin\windowType = #WINDOWTYPE_REBAR
                ForEach rebarGadget()
                    If rebarGadget()\Handle = WindowID
                        
                        *pos.WINDOWPOS = lParam
                        
                        ; send rebar update message to apps main window
                        sendRebarUpdatedMsg(*pos\cy)
                        Break
                        
                    EndIf
                Next
            EndIf
            
            ; delete cached static control backbrush if set
            If *trackWin\hBrush <> #Null
                DeleteObject_(*trackWin\hBrush)
                *trackWin\hBrush = #Null
            EndIf
            
            ; LimitWindowSize code
            If *trackWin\limitSizeSet = #True
                If Not *pos\flags & $8000 ; maximized/minimized etc..
                    If *pos\cx < *trackWin\limitSize\left And *trackWin\limitSize\left > 0
                        
                        GetWindowRect_(WindowID, rc.RECT)
                        If *pos\x > rc\left 
                            xdelta = *pos\cx-*trackWin\limitSize\left
                            *pos\x = *pos\x + xdelta
                        EndIf
                        *pos\cx = *trackWin\limitSize\left
                        
                    ElseIf *pos\cx > *trackWin\limitSize\right And *trackWin\limitSize\right > 0
                        
                        GetWindowRect_(WindowID, rc.RECT)
                        If *pos\x < rc\left 
                            xdelta = *pos\cx-*trackWin\limitSize\right
                            *pos\x = *pos\x + xdelta
                        EndIf
                        *pos\cx = *trackWin\limitSize\right
                        
                    EndIf
                    If *pos\cy < *trackWin\limitSize\top And *trackWin\limitSize\top > 0
                        
                        GetWindowRect_(WindowID, rc.RECT)
                        If *pos\y > rc\top 
                            ydelta = *pos\cy-*trackWin\limitSize\top
                            *pos\y = *pos\y + ydelta
                        EndIf
                        *pos\cy = *trackWin\limitSize\top
                        
                    ElseIf *pos\cy > *trackWin\limitSize\bottom And *trackWin\limitSize\bottom > 0
                        
                        GetWindowRect_(WindowID, rc.RECT)
                        If *pos\y < rc\top 
                            ydelta = *pos\cy-*trackWin\limitSize\bottom
                            *pos\y = *pos\y + ydelta
                        EndIf
                        *pos\cy = *trackWin\limitSize\bottom
                        
                    EndIf
                EndIf
            EndIf
            
            Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
            
        Case #WM_WINDOWPOSCHANGED
            
            ; if window is in panelexpage with autoscroll then flag that panelexpage needs area re-calculating
            *ptrackWin.trackWindows = *trackWin\parentTrackWin
            If *ptrackWin <> #Null And *ptrackWin\windowType = #WINDOWTYPE_PANELEXPAGE
                *panelexpage.panelexpages = *ptrackWin\panelexpage
                *panelex.panelexs = *panelexpage\panelex
                If *panelexpage\autoScroll = #True And *panelex\displayedPage = *panelexpage
                    
                    *panelexpage\calcArea = #True
                    
                EndIf
                
            EndIf
            
            Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
            
        Case #WM_SETREDRAW
            
            ;*trackWin\visible = wParam
            ;setControlVisibility(*trackWin, wParam)
            
            If *trackWin\rootPanelex <> #Null
                ;*trackWin\divertedSetNoRedraw = 1-wParam
                ;ValidateRect_(WindowID, 0)
                ;RedrawWindow_(WindowID, #Null, #Null, #RDW_VALIDATE|#RDW_FRAME)
                setControlNoRedraw(*trackWin, 1-wParam)
            Else
                Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
            EndIf
             
        Case #WM_SHOWWINDOW
            
            If wparam = #True
                hwnd = getControlPanelExParent(*trackWin\hwnd)
                *ttrackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
                If *ttrackWin <> #Null
                    setControlVisibility(*ttrackWin, wParam)
                EndIf
            EndIf
                
            ;*trackWin\visible = wParam
            setControlVisibility(*trackWin, wParam)
            
            ; detect if window's parent has changed and update trackWin if so
            parent = GetParent_(*trackWin\hwnd)
            If parent <> *trackWin\parent
                
                oldParent = *trackWin\parent
                *oldParentTrackWin = *trackWin\parentTrackWin
                *trackWin\parent = parent
                *trackWin\parentTrackWin = GetProp_(*trackWin\parent, trackwinAtom)
                updateTrackWinRootPanelEx(*oldParentTrackWin)
                
                ; delete cached static control backbrush if set
                If *trackWin\hBrush <> #Null
                    DeleteObject_(*trackWin\hBrush)
                    *trackWin\hBrush = #Null
                EndIf
                
            EndIf
            
            updateTrackWinRootPanelEx(*trackWin)
            
            *panelexpage.panelexpages = GetProp_(*trackWin\parent, panelexpageAtom)
            If *panelexpage = #Null
                *panelexpage.panelexpages = GetProp_(oldParent, panelexpageAtom)
            EndIf
            
            ;class.s = Space(255)
            ;GetClassName_(*trackWin\hwnd, @class, 255)
            ;debuglog("#WM_SHOWWINDOW: " + Str(*trackWin\hwnd) + " " + class + " visible: " + Str(*trackWin\visible))
            
            If *trackWin\rootPanelex <> #Null
                    
                ;gwlExStyle = GetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE)
                ;If Not gwlExStyle & #WS_EX_TRANSPARENT
                ;    ;debuglog("windowshow in panelex: setting to ws_wx_transparent")
                ;    SetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE, gwlExStyle | #WS_EX_TRANSPARENT)
                ;EndIf
                
                setControlTransparent(*trackWin\hwnd, #True)
                
            Else
                
                gwlExStyle = GetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE)
                If gwlExStyle & #WS_EX_TRANSPARENT
                    ;debuglog("windowshow not in panelex: setting to not ws_wx_transparent")
                    ;SetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE, gwlExStyle &~ #WS_EX_TRANSPARENT)
                    
                    setControlTransparent(*trackWin\hwnd, #False)
                    
                    *panelex.panelexs = *trackWin\panelex
                    If *panelex <> #Null
                        *panelexpage.panelexpages = *panelex\displayedPage
                        If *panelexpage <> #Null
                            *panelexpage\dontdraw = 0
                        EndIf
                    EndIf
                    
                EndIf
                
            EndIf
            
            ;/ if window is in panelexpage with autoscroll then update panelexpage
            If *panelexpage <> #Null
                
                ; parent is a panelexpage
                If *panelexpage\Handle = *trackWin\parent
                    
                    found = #True
                    
                ; old parent is panelexpage
                Else
                    
                    found = #False
                    
                EndIf
                
                If *panelexpage\autoScroll = #True
                    
                    ;debuglog("show: "+Str(*trackWin\hwnd))
                    
                    GetWindowRect_(*trackWin\hwnd, rc.RECT)
                    MapWindowPoints_(0, *panelexpage\handle, rc, 2)
                    
                    If *panelexpage\Handle = *trackWin\parent
                        If wParam = #True ; shown
                            If rc\right > *panelexpage\area\right
                                *panelexpage\area\right = rc\right-1
                            EndIf
                            If rc\bottom > *panelexpage\area\bottom
                                *panelexpage\area\bottom = rc\bottom-1
                            EndIf
                        Else ; hidden
                            *panelexpage\calcArea = #True
                        EndIf
                    ElseIf *panelexpage\Handle = oldParent
                        *panelexpage\calcArea = #True
                    EndIf
                    
                EndIf
                
;                 If *trackWin\rootPanelex <> #Null
;                     
;                     ;gwlExStyle = GetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE)
;                     ;If Not gwlExStyle & #WS_EX_TRANSPARENT
;                     ;    ;debuglog("windowshow in panelex: setting to ws_wx_transparent")
;                     ;    SetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE, gwlExStyle | #WS_EX_TRANSPARENT)
;                     ;EndIf
;                     
;                     setControlTransparent(*trackWin\hwnd, #True)
;                     
;                 Else
;                     
;                     gwlExStyle = GetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE)
;                     If gwlExStyle & #WS_EX_TRANSPARENT
;                         ;debuglog("windowshow not in panelex: setting to not ws_wx_transparent")
;                         ;SetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE, gwlExStyle &~ #WS_EX_TRANSPARENT)
;                         
;                         setControlTransparent(*trackWin\hwnd, #False)
;                         
;                         *panelex.panelexs = *trackWin\panelex
;                         If *panelex <> #Null
;                             *panelexpage.panelexpages = *panelex\displayedPage
;                             If *panelexpage <> #Null
;                                 *panelexpage\dontdraw = 0
;                             EndIf
;                         EndIf
;                         
;                     EndIf
;                     
;                 EndIf
                
;                 ; if window should be transparent in panelex page then handle ws_ex_transparent states
;                 If found = #True And *trackWin\transparent = #True
;                     
;                     gwlExStyle = GetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE)
;                     If Not gwlExStyle & #WS_EX_TRANSPARENT
;                         ;debuglog("windowshow in panelex: setting to ws_wx_transparent")
;                         SetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE, gwlExStyle | #WS_EX_TRANSPARENT)
;                     EndIf
;                     
;                 ElseIf found = #False And *trackWin\transparent = #True
;                     
;                     gwlExStyle = GetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE)
;                     If gwlExStyle & #WS_EX_TRANSPARENT
;                         ;debuglog("windowshow not in panelex: setting to not ws_wx_transparent")
;                         SetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE, gwlExStyle &~ #WS_EX_TRANSPARENT)
;                         
;                         *panelex.panelexs = *trackWin\panelex
;                         If *panelex <> #Null
;                             *panelexpage.panelexpages = *panelex\displayedPage
;                             If *panelexpage <> #Null
;                                 *panelexpage\dontdraw = 0
;                             EndIf
;                         EndIf
;                         
;                     EndIf
;                     
;                 EndIf
                
                *panelex.panelexs = *panelexpage\panelex
                RefreshPanelEx(*panelex\Handle, 0, #PNLX_ERASEALLCHILDREN | #PNLX_UPDATESCROLLING)
                
            EndIf
            
            If GetWindowLongPtr_(*trackWin\hwnd, #GWL_EXSTYLE) & #WS_EX_TRANSPARENT
                *trackWin\isTransparent = #True
            Else
                *trackWin\isTransparent = #False
            EndIf
            
            Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
            
        Case #WM_PAINT
            
            If *trackWin\rootPanelex <> #Null And *trackWin\divertedSetNoRedraw <> #False;(*trackWin\divertedSetNoRedraw <> #False Or *trackWin\noPaint = #True)
                
                BeginPaint_(WindowID, @ps.PAINTSTRUCT)
                ps\fErase = 0
                ps\rcPaint\top = 0
                ps\rcPaint\left = 0
                ps\rcPaint\right = 0
                ps\rcPaint\bottom = 0
                EndPaint_(WindowID, @ps)
                
                ProcedureReturn 1
                
            EndIf
            
            ; stop default rendering of PureBasic frame gadget if inside panelex page
            found = #False
            Select *trackWin\windowType
                    
                Case #WINDOWTYPE_PBFRAME;, #WINDOWTYPE_STATIC
                    
                    *ptrackWin.trackWindows = *trackWin\parentTrackWin
                    If *ptrackWin <> #Null
                        
                        If *ptrackWin\windowType = #WINDOWTYPE_PANELEXPAGE
                            
                            BeginPaint_(WindowID, @ps.PAINTSTRUCT)
                            ps\fErase = 0
                            ps\rcPaint\top = 0
                            ps\rcPaint\left = 0
                            ps\rcPaint\right = 0
                            ps\rcPaint\bottom = 0
                            EndPaint_(WindowID, @ps)
                            result = 1
                            
                            found = #True
                            
                        EndIf
                        
                    EndIf
                    
            EndSelect
            
            If found = #False
                Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
            EndIf
            
        Case #WM_NCPAINT
            
            If *trackWin\rootPanelex <> #Null; Or *trackWin\noErase = #True
                
                If *trackWin\divertedSetNoRedraw <> #False
                   
                    ProcedureReturn 0
                    
                EndIf
                
                Select *trackWin\windowType
                        
                    Case #WINDOWTYPE_PBCONTAINER, #WINDOWTYPE_CALENDAR
                            
                        ;debuglog("#WM_NCPAINT")
                        
                        dc = getDivertedBuffer(*trackWin)
                        GetWindowRect_(*trackWin\hwnd, rc.RECT)
                        rc\right = rc\right-rc\left
                        rc\bottom = rc\bottom-rc\top
                        rc\left = 0
                        rc\top = 0
                        
                        style = GetWindowLongPtr_(WindowID, #GWL_EXSTYLE)
                        If style & #WS_EX_CLIENTEDGE
                            ;debuglog("WS_EX_CLIENTEDGE")
                            DrawEdge_(dc, rc, #BDR_SUNKENOUTER, #BF_RECT|#BF_ADJUST)
                            DrawEdge_(dc, rc, #BDR_SUNKENINNER, #BF_RECT|#BF_ADJUST)
                            DrawEdge_(dc, rc, #BDR_SUNKENINNER, #BF_RECT|#BF_FLAT)
                        ElseIf style & #WS_EX_STATICEDGE
                            ;debuglog("WS_EX_STATICEDGE")
                            DrawEdge_(dc, rc, #BDR_SUNKENOUTER, #BF_RECT)
                        ElseIf style & #WS_EX_WINDOWEDGE
                            ;debuglog("WS_EX_WINDOWEDGE")
                            DrawEdge_(dc, rc, #BDR_RAISEDOUTER, #BF_RECT|#BF_ADJUST)
                            DrawEdge_(dc, rc, #BDR_RAISEDINNER, #BF_RECT|#BF_ADJUST)
                            DrawEdge_(dc, rc, #BDR_RAISEDINNER, #BF_RECT|#BF_FLAT)
                        ElseIf style & #WS_EX_DLGMODALFRAME
                            ;debuglog("WS_EX_DLGMODALFRAME")
                        Else
                            style = GetWindowLongPtr_(WindowID, #GWL_STYLE)
                            If style & #WS_BORDER
                                ;debuglog("#WS_BORDER")
                                DrawEdge_(dc, rc, #BDR_SUNKENOUTER, #BF_RECT|#BF_MONO)
                            EndIf
                        EndIf
                        
                        ProcedureReturn 0
                    
                EndSelect
                
            EndIf
            
            If *trackWin\rootPanelex <> #Null And *trackWin\windowType <> #WINDOWTYPE_PANELEX And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE And *trackWin\windowType <> #WINDOWTYPE_PBFRAME
                If *trackWin\windowType = #WINDOWTYPE_RICHEDIT
                    ;debuglog("-------------- WM_NCPAINT")
                EndIf

                *trackWin\divertedRefreshCount + 1
            EndIf
            
            Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
            
            If *trackWin\rootPanelex <> #Null And *trackWin\windowType <> #WINDOWTYPE_PANELEX And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE And *trackWin\windowType <> #WINDOWTYPE_PBFRAME
                ;*trackWin\divertedRefreshCount - 1
                
                If *trackWin\windowType = #WINDOWTYPE_RICHEDIT
                    ;debuglog("-------------- END WM_NCPAINT")
                EndIf
            EndIf
            
;         Case #WM_PRINTCLIENT
;             
;             If *trackWin\rootPanelex <> #Null
;      
;                 debuglog("#WM_PRINTCLIENT")
;                 
;                 If lParam & #PRF_CLIENT
;                     wParam = getDivertedBuffer(*trackWin, wParam, #True)
;                 ElseIf lParam & #PRF_NONCLIENT
;                     wParam = getDivertedBuffer(*trackWin, wParam)
;                 EndIf
;                 
;                 Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
;                 
;                 If *trackWin\divertedRedraw = #False
;                     
;                     *panelex.panelexs = *trackWin\parentPanelex
;                     *panelexpage.panelexpages = *panelex\displayedPage
;                     
;                     GetClipBox_(*trackWin\divertedDC, updateRect.RECT)
;                     MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
;                     
;                     SetWindowOrgEx_(*trackWin\divertedDC, 0, 0, 0)
;                     
;                     *trackWin\divertedRefresh = #True
;                     RefreshPanelEx(*panelex\Handle, updateRect)
;                 
;                 EndIf
;                 
;                 ProcedureReturn result
;                 
;             EndIf
;             
;             Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
;             
        Case #WM_ERASEBKGND
            
            If *trackWin\rootPanelex <> #Null And *trackWin\divertedSetNoRedraw <> #False
                
                ProcedureReturn 1
                
            EndIf
            
            If *trackWin\windowType = #WINDOWTYPE_PANELEXPAGE And *trackWin\rootPanelexPageHwnd = *trackWin\hwnd
                
;                     If *trackWin\containsChildCntrl = #True
;                         ;debuglog("--------------")
;                         ;debuglog("page: "+Str(windowid))
;                         GetClientRect_(WindowID, rc.RECT)
;                         root = *trackWin\rootPanelexPageHwnd
;                         MapWindowPoints_(WindowID, root, rc, 2)
;                         GetClipBox_(wParam, clipRc.RECT)
;                         If IntersectRect_(trc.RECT, clipRc, rc) <> #False
;                             excludePanelExChildWindows(wParam, *trackWin)
;                         EndIf
;                         ;debuglog("--------------")
;                     EndIf
            
            ; check if there are any panelExs in this window and this window is not a panelexpage
            ; then exclude the client rect of each panelex from the background erase of this window
            ; make sure this window isn't a panelexpage
            ElseIf *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE And *trackWin\windowType <> #WINDOWTYPE_PANELEX
                
                chwnd = GetWindow_(WindowID, #GW_CHILD)
                While chwnd <> #Null
                    
                    *ctrackWin.trackWindows = GetProp_(chwnd, trackwinAtom)
                    If *ctrackWin <> #Null And *ctrackWin\windowType = #WINDOWTYPE_PANELEX And *ctrackWin\visible = #True
                        
                        GetWindowRect_(chwnd, @rc.RECT)
                        MapWindowPoints_(0, WindowID, @rc, 2)
                        ExcludeClipRect_(wParam, rc\left, rc\top, rc\right, rc\bottom)
                        
                    EndIf
                        
                    chwnd = GetWindow_(chwnd, #GW_HWNDNEXT)
                    
                Wend
                
            EndIf
            
            If *trackWin\rootPanelex <> #Null And *trackWin\windowType <> #WINDOWTYPE_PANELEX And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE
                
                If *trackWin\noErase = #True
                    
                    ProcedureReturn 1
                    
                Else
                    
                    ;class.s = Space(255)
                    ;GetClassName_(*trackWin\hwnd, @class, 255)
                    ;debuglog("#WM_ERASEBKGND: " + Str(*trackWin\hwnd) + " " + class)
                    
                    ;sysbrush = GetSysColorBrush_(brush-1)
                    ;If sysbrush <> #Null
                    ;    brush = sysbrush
                    ;EndIf
                    ;GetClientRect_(*trackWin\hwnd, rc.RECT)
                    ;FillRect_(wParam, rc, brush)
                    
                    wParam = getDivertedBuffer(*trackWin, wParam, #True)
                    Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
                    ProcedureReturn Result
                    
                EndIf
                
;                 Select *trackWin\windowType
;                         
;                     Case #WINDOWTYPE_EDIT, #WINDOWTYPE_RICHEDIT, #WINDOWTYPE_SYSBUTTON, #WINDOWTYPE_SYSSCROLLBAR, #WINDOWTYPE_SYSPROGRESSBAR, #WINDOWTYPE_STATIC, #WINDOWTYPE_LISTBOX, #WINDOWTYPE_LISTVIEW, #WINDOWTYPE_PBFRAME, #WINDOWTYPE_SYSTAB, #WINDOWTYPE_TREEVIEW, #WINDOWTYPE_WEBExplorer, #WINDOWTYPE_WEBDocObject, #WINDOWTYPE_PUREWEB
;                         
;                         ProcedureReturn 1
;                         
;                     Default
;                         
;                         ;class.s = Space(255)
;                         ;GetClassName_(*trackWin\hwnd, @class, 255)
;                         ;debuglog("#WM_ERASEBKGND: " + Str(*trackWin\hwnd) + " " + class)
;                         
;                         wParam = getDivertedBuffer(*trackWin, wParam, #True)
;                         Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
;                         ProcedureReturn Result
;                         
;                 EndSelect
                
            EndIf
             
            Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
            
        Case #WM_SIZE
            
            If *trackWin\visible = #True And *trackWin\rootPanelex <> #Null And *trackWin\windowType <> #WINDOWTYPE_PANELEX And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE
                
                *panelex.panelexs = *trackWin\parentPanelex
                *panelexpage.panelexpages = *panelex\displayedPage
                
                ;If *panelexpage\Handle = *trackWin\parent
                
                    SendMessage_(*trackWin\hwnd, #WM_SETREDRAW, #False, 0)
                    Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
                    SendMessage_(*trackWin\hwnd, #WM_SETREDRAW, #True, 0)
                    
                    If *trackWin\divertedSetNoRedraw = 0
                        
                        GetClipBox_(*trackWin\divertedDC, updateRect.RECT)
                        MapWindowPoints_(*trackWin\hwnd, *panelexpage\Handle, updateRect, 2)

                        RedrawWindow_(*trackWin\hwnd, 0, 0, #RDW_UPDATENOW|#RDW_INVALIDATE)
                        
                        ;*trackWin\divertedRefresh = #True
                        ;RefreshPanelEx(*panelex\Handle, updateRect)
                        
                    EndIf
                    
                    ;Debug "noredraw: " + Str(*trackWin\divertedSetNoRedraw)
                    ;class.s = Space(255)
                    ;GetClassName_(*trackWin\hwnd, @class, 255)
                    ;Debug class
                    
                ;Else
                ;    Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
                ;EndIf
                
            Else
                Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
            EndIf
            
        Default
            
            Result = CallWindowProc_(*trackWin\callbackProc,WindowID,message,wParam,lParam)
            
    EndSelect
    
    ProcedureReturn Result
    
EndProcedure
;- ***

Procedure KeyboardHook(nCode, wParam, lParam)
    
    Result = CallNextHookEx_(0, nCode, wParam, lParam)
    
    If HaltProGUI = #True
        ProcedureReturn 0
    EndIf
    
    Select nCode
        Case #HC_ACTION
            
            ;debuglog(Str(wParam))
            
            ; alt key or f10 pressed, activate menu
            If wParam = 18 Or (menuExF10Disable = 0 And wParam = 121)
                ;debuglog(Str(lParam|#KF_UP))
                
                If lParam|#KF_UP = 540573697 Or lParam|#KF_UP = 4489217
                    
                    ;debuglog(Str(menuKeyboardActive))
                    
                    If menuKeyboardActive = #False
                        
                        ; search for a menu toolbar
                        ForEach menuex()
                            If menuex()\toolbarID > 0
                                menuKeyboardActive = #True
                                altActivated = #True
                                menuToolbar = menuex()\toolbarID
                                menuOldFocus = SetFocus_(menuToolbar)
                                SendMessage_(menuToolbar, #TB_SETHOTITEM, 0, 0)
                                ProcedureReturn #True
                            EndIf
                        Next
                        
                    Else
                        menuKeyboardActive = #False
                        menuHotItemNext = -1
                        menuItemOver = -1
                        menuHotItem = -1
                        altActivated = #False
                        EndMenu_()
                        SetFocus_(menuOldFocus)
                        SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
                        UpdateWindow_(menuToolbar)
                        ProcedureReturn #True
                    EndIf
                EndIf
                
                If menuHotItem = -2 And lParam|#KF_UP = -1070039039
                    menuKeyboardActive = #False
                    menuHotItemNext = -1
                    menuItemOver = -1
                    menuHotItem = -1
                    altActivated = #False
                    menuex()\active = 0
                    EndMenu_()
                    SetFocus_(menuOldFocus)
                    SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
                    UpdateWindow_(menuToolbar)
                    ProcedureReturn #True
                EndIf
                
            EndIf
            
            If wParam = #VK_ESCAPE And altActivated = #True; And menuKeyboardActive = #False
                debuglog("escape")
                SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
                UpdateWindow_(menuToolbar)
                SetFocus_(menuOldFocus)
                menuKeyboardActive = #False
                altActivated = #False
                menuHotItemNext = -1
                menuItemOver = -1
                menuHotItem = -1
                ProcedureReturn Result
            EndIf
            
            ; this code solves bug with clicking on same selected menu title
            If altActivated = #True
                If wParam = #VK_DOWN And (lParam>> 16 & $FFFF = 336 Or lParam>> 16 & $FFFF = 16720)
                    altActivated = -2
                ElseIf wParam = #VK_RETURN And lParam|#KF_UP = 1867777
                    altActivated = -2
                ElseIf wParam <> 18 And wParam <> 121 And wParam <> #VK_RIGHT And wParam <> #VK_LEFT And wParam <> #VK_DOWN And wParam <> #VK_RETURN
                    altActivated = -2
                EndIf
            EndIf
            
            ; handle scroll menu hot keys
            If menuScrollHandle <> 0
                
                k = MapVirtualKey_(wParam, 2)
                ;c.s = Chr(PeekW(@k))
                c.s = Chr(k&$FFFF)
                ForEach menuScrollHotKey()
                    If menuScrollHotKey()\hotkey = c And menuex()\popupid = menuScrollHandle
                        
                        mnfo.MENUITEMINFO_Fixed
                        mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                        mnfo\fMask = #MIIM_SUBMENU
                        GetMenuItemInfo_(originalScrollMenu, menuScrollHotKey()\id, 0, @mnfo)
                        If mnfo\hSubMenu = 0
                            SendMessage_(menuex()\WindowID, #WM_COMMAND, MakeLong(menuScrollHotKey()\id, 0), 0)
                            menuKeyboardActive = #False
                            menuHotItemNext = -1
                            menuItemOver = -1
                            menuHotItem = -1
                            altActivated = #False
                            menuex()\active = 0
                            EndMenu_()
                            SetFocus_(menuOldFocus)
                        EndIf
                    EndIf
                Next
            EndIf
            
            
    EndSelect
    
    ProcedureReturn Result
EndProcedure


Procedure dropShadowCallback(Window, message, wParam, lParam)
    
    Select message
        Case #WM_DESTROY
            ChangeCurrentElement(drpShadow(), GetWindowLongPtr_(Window, #GWLP_USERDATA))
            DeleteDC_(drpShadow()\hdc)
            DeleteObject_(drpShadow()\bitmap)
            DeleteElement(drpShadow())
        Default
            Result  = DefWindowProc_(Window, message, wParam, lParam)
    EndSelect
    
    ProcedureReturn Result
EndProcedure


Procedure dropShadow(dx, dy, width, height, colour, Alpha, flags)
    Static hBitmap, hBitmapHdc, hBitmapWidth, hBitmapHeight, hBitmapAlpha, hBitmapColour
    Static vBitmap, vBitmapHdc, vBitmapWidth, vBitmapHeight, vBitmapAlpha, vBitmapColour
    
    
    If flags & #DropShadowFlushCache
        If hBitmap <> 0
            DeleteDC_(hBitmapHdc)
            DeleteObject_(hBitmap)
            hBitmap = 0
            hBitmapHdc = 0
            hBitmapWidth = 0
            hBitmapHeight = 0
            hBitmapAlpha = 0
            vBitmapColour = 0
            RET = #True
        EndIf
        If vBitmap <> 0
            DeleteDC_(vBitmapHdc)
            DeleteObject_(vBitmap)
            vBitmap = 0
            vBitmapHdc = 0
            vBitmapWidth = 0
            vBitmapHeight = 0
            vBitmapAlpha = 0
            vBitmapColour = 0
            RET = #True
        EndIf
        ProcedureReturn RET
    EndIf
    
    If dropShadowClass = ""
        dropShadowClass = #AppName+"_DropShadow"
        wc.WNDCLASSEX
        wc\cbSize  = SizeOf(WNDCLASSEX)
        wc\style = 0
        wc\lpfnWndProc  = @dropShadowCallback()
        wc\lpszClassName  = @dropShadowClass
        RegisterClassEx_(@wc)
    EndIf
    
    If width <= 0 Or height <= 0 Or Alpha <= 0
        ProcedureReturn 0
    EndIf
    
    sr = Red(colour)
    sg = Green(colour)
    sb = Blue(colour)
    
    Window = CreateWindowEx_(#WS_EX_LAYERED|#WS_EX_TRANSPARENT|#WS_EX_TOOLWINDOW|#WS_EX_TOPMOST|#WS_EX_NOACTIVATE, dropShadowClass, 0, 0, 0, 0, 0, 0, 0, #Null,  GetModuleHandle_(0), #Null)
    If Window <> 0
        
        hdc = GetWindowDC_(Window)
        shdc = CreateCompatibleDC_(hdc)
        bitmap = CreateCompatibleBitmap_(hdc, width, height)
        
        AddElement(drpShadow())
        drpShadow()\hwnd = Window
        drpShadow()\hdc = shdc
        drpShadow()\bitmap = bitmap
        SetWindowLongPtr_(Window, #GWLP_USERDATA, @drpShadow())
        
        ; render new shadow to cache bitmap if size change necessary or alpha changes
        If flags & #DropShadowVertical
            ;debuglog("Vertical")
            
            ; make sure the height is large enough to contain corners
            h = height
            If flags & #DropShadowStart
                h = h + width
            ElseIf flags & #DropShadowEnd
                h = h + width
            ElseIf flags & #DropShadowNoEnds
                h = h + (width*2)
            EndIf
            
            ; if bitmap doesn't exist or requested dimensions won't fit in bitmap then create new bitmap
            If vBitmap = 0 Or width > vBitmapWidth Or h > vBitmapHeight Or Alpha <> vBitmapAlpha Or colour <> vBitmapColour
                ;debuglog("rendering vertical dropshadow...")
                
                If vBitmap <> 0 ; free old bitmap if exists
                    DeleteDC_(vBitmapHdc)
                    DeleteObject_(vBitmap)
                EndIf
                
                vBitmap = CreateCompatibleBitmap_(hdc, width, h)
                vBitmapHdc = CreateCompatibleDC_(hdc)
                vBitmapWidth = width
                vBitmapHeight = h
                vBitmapColour = colour
                vBitmapAlpha = Alpha
                
                ; render new whole dropshadow including corners
                *mem = AllocateMemory(vBitmapWidth * vBitmapHeight * 4)
                
                lSize = vBitmapWidth
                For y = 0 To vBitmapHeight-1
                    ; Check If near start of corner end If so reduce the Alpha
                    ; To create the corners:
                    If y < lSize  ; top corner
                        lInitC = (Alpha * (y+1)) / lSize
                    ElseIf y >= vBitmapHeight-lSize ; bottom corner
                        lInitC = ((vBitmapHeight-y) * Alpha) / lSize
                    Else
                        lInitC = Alpha
                    EndIf
                    
                    ; Set the Alpha according To distance from the edge:            
                    For x = 0 To lSize - 1
                        lC = (lInitC * (lSize-1-x)) / lSize
                        r = (sr*lC)/$FF
                        g = (sg*lC)/$FF
                        b = (sb*lC)/$FF
                        PokeL(*mem+((x*4)+((vBitmapHeight-y-1)*vBitmapWidth*4)), b|g<<8|r<<16|lC<<24)
                    Next
                Next
                
                bmi.BITMAPINFO
                bmi\bmiHeader\biSize = SizeOf(BITMAPINFOHEADER)
                bmi\bmiHeader\biWidth = vBitmapWidth
                bmi\bmiHeader\biHeight = vBitmapHeight
                bmi\bmiHeader\biPlanes = 1
                bmi\bmiHeader\biBitCount = 32
                bmi\bmiHeader\biCompression = #BI_RGB 
                
                SetDIBits_(vBitmapHdc, vBitmap, 0, bmi\bmiHeader\biHeight, *mem, @bmi, #DIB_RGB_COLORS)
                FreeMemory(*mem)
                
            EndIf
            
            ; blit the parts of the shadow we need
            SelectObject_(vBitmapHdc, vBitmap)
            SelectObject_(shdc, bitmap)
            If flags & #DropShadowStart
                ;debuglog("blit #DropShadowStart")
                BitBlt_(shdc, 0, 0, width, height, vBitmapHdc, 0, 0, #SRCCOPY)
            ElseIf flags & #DropShadowEnd
                ;debuglog("blit #DropShadowEnd")
                BitBlt_(shdc, 0, 0, width, height, vBitmapHdc, 0, (vBitmapHeight-height), #SRCCOPY)
            ElseIf flags & #DropShadowNoEnds
                ;debuglog("blit #DropShadowNoEnds")
                BitBlt_(shdc, 0, 0, width, height, vBitmapHdc, 0, width, #SRCCOPY)
            Else
                ;debuglog("blit whole")
                If height < vBitmapHeight
                    BitBlt_(shdc, 0, 0, width, height-width, vBitmapHdc, 0, 0, #SRCCOPY)
                    BitBlt_(shdc, 0, height-width, width, width, vBitmapHdc, 0, (vBitmapHeight-width), #SRCCOPY)
                Else
                    BitBlt_(shdc, 0, 0, width, height, vBitmapHdc, 0, 0, #SRCCOPY)
                EndIf
            EndIf
            
        ElseIf Not flags & #DropShadowVertical
            ;debuglog("Horizontal")
            
            ; make sure the width is large enough to contain corners
            w = width
            If flags & #DropShadowStart
                w = w + height
            ElseIf flags & #DropShadowEnd
                w = w + height
            ElseIf flags & #DropShadowNoEnds
                w = w + (height*2)
            EndIf
            
            ; if bitmap doesn't exist or requested dimensions won't fit in bitmap then create new bitmap
            If hBitmap = 0 Or w > hBitmapWidth Or height > hBitmapHeight Or Alpha <> hBitmapAlpha Or colour <> hBitmapColour
                ;debuglog("rendering horizontal dropshadow...")
                
                If hBitmap <> 0 ; free old bitmap if exists
                    DeleteDC_(hBitmapHdc)
                    DeleteObject_(hBitmap)
                EndIf
                
                hBitmap = CreateCompatibleBitmap_(hdc, w, height)
                hBitmapHdc = CreateCompatibleDC_(hdc)
                hBitmapWidth = w
                hBitmapHeight = height
                hBitmapColour = colour
                hBitmapAlpha = Alpha
                
                ; render new whole dropshadow including corners
                *mem = AllocateMemory(hBitmapWidth * hBitmapHeight * 4)
                
                lSize = hBitmapHeight
                For x = 0 To hBitmapWidth-1
                    ; Check If near start of corner end If so reduce the Alpha
                    ; To create the corners:
                    If x < lSize  ; left corner
                        lInitC = (Alpha * (x+1)) / lSize
                    ElseIf x >= hBitmapWidth-lSize ; right corner
                        lInitC = ((hBitmapWidth-x) * Alpha) / lSize
                    Else
                        lInitC = Alpha
                    EndIf
                    
                    ; Set the Alpha according To distance from the edge:            
                    For y = 0 To lSize - 1
                        lC = (lInitC * (lSize-1-y)) / lSize
                        r = (sr*lC)/$FF
                        g = (sg*lC)/$FF
                        b = (sb*lC)/$FF
                        PokeL(*mem+((x*4)+((hBitmapHeight-y-1)*hBitmapWidth*4)), b|g<<8|r<<16|lC<<24)
                    Next
                Next
                
                bmi.BITMAPINFO
                bmi\bmiHeader\biSize = SizeOf(BITMAPINFOHEADER)
                bmi\bmiHeader\biWidth = hBitmapWidth
                bmi\bmiHeader\biHeight = hBitmapHeight
                bmi\bmiHeader\biPlanes = 1
                bmi\bmiHeader\biBitCount = 32
                bmi\bmiHeader\biCompression = #BI_RGB 
                
                SetDIBits_(hBitmapHdc, hBitmap, 0, bmi\bmiHeader\biHeight, *mem, @bmi, #DIB_RGB_COLORS)
                FreeMemory(*mem)
                
            EndIf
            
            ; blit the parts of the shadow we need
            SelectObject_(hBitmapHdc, hBitmap)
            SelectObject_(shdc, bitmap)
            If flags & #DropShadowStart
                ;debuglog("blit #DropShadowStart")
                BitBlt_(shdc, 0, 0, width, height, hBitmapHdc, 0, 0, #SRCCOPY)
            ElseIf flags & #DropShadowEnd
                ;debuglog("blit #DropShadowEnd")
                BitBlt_(shdc, 0, 0, width, height, hBitmapHdc, (hBitmapWidth-width), 0, #SRCCOPY)
            ElseIf flags & #DropShadowNoEnds
                ;debuglog("blit #DropShadowNoEnds")
                BitBlt_(shdc, 0, 0, width, height, hBitmapHdc, height, 0, #SRCCOPY)
            Else
                ;debuglog("blit whole")
                If width < hBitmapWidth
                    BitBlt_(shdc, 0, 0, width-height, height, hBitmapHdc, 0, 0, #SRCCOPY)
                    BitBlt_(shdc, width-height, 0, height, height, hBitmapHdc, (hBitmapWidth-height), 0, #SRCCOPY)
                Else
                    BitBlt_(shdc, 0, 0, width, height, hBitmapHdc, 0, 0, #SRCCOPY)
                EndIf
            EndIf
            
        EndIf
        
        sz.SIZE
        sz\cx = width
        sz\cy = height
        pnt.POINT
        pnt\x = dx
        pnt\y = dy
        ContextOffset.POINT
        BlendMode.BLENDFUNCTION
        BlendMode\SourceConstantAlpha = 255
        BlendMode\AlphaFormat = 1
        UpdateLayeredWindow_(Window, 0, @pnt, @sz, shdc, @ContextOffset, 0, @BlendMode, 2)
        
        
        ShowWindow_(Window, #SW_SHOWNA)
        
        
        ReleaseDC_(Window, hdc)
        
        ProcedureReturn Window
    EndIf
    
    ProcedureReturn 0
    
EndProcedure

Procedure attachTrackWinToHwnd(hwnd)
    
    If GetParent_(hwnd) <> #HWND_MESSAGE ; not message only window
                        
        *trackWin.trackWindows = AllocateStructure(trackWindows)
        *trackWin\hwnd = hwnd
        *trackWin\parent = GetParent_(hwnd)
        *trackWin\parentTrackWin = GetProp_(*trackWin\parent, trackwinAtom)
        
        If GetWindowLongPtr_(hwnd, #GWL_EXSTYLE) & #WS_EX_TRANSPARENT
            *trackWin\isTransparent = #True
        EndIf
        
        class.s = Space(255)
        GetClassName_(hwnd, @class, 255)
        
        ; assign windowType based on class and flag as transparent when in container if needed
        If class = panelExContainerClass
            *trackWin\windowType = #WINDOWTYPE_PANELEX
            *trackWin\transparent = #True
        ElseIf class = panelExPageClass
            *trackWin\windowType = #WINDOWTYPE_PANELEXPAGE
        ElseIf class = "ToolbarWindow32"
            *trackWin\windowType = #WINDOWTYPE_TOOLBAREX
            *trackWin\transparent = #True
        ElseIf class = "ComboBox"
            *trackWin\windowType = #WINDOWTYPE_SYSCOMBOBOX
        ElseIf class = "Edit"
            tclass.s = Space(255)
            GetClassName_(*trackWin\parent, @tclass, 255)
            If tclass  = "ComboBox"
                *trackWin\windowType = #WINDOWTYPE_SYSCOMBOBOXEDIT
            Else
                *trackWin\windowType = #WINDOWTYPE_EDIT
                *trackWin\noErase = #True
                *trackWin\transparent = #True
            EndIf
        ElseIf class = "msctls_progress32"
            *trackWin\windowType = #WINDOWTYPE_SYSPROGRESSBAR
            *trackWin\noErase = #True
            *trackWin\transparent = #True
        ElseIf class = "Button"
            
            style = GetWindowLongPtr_(hwnd, #GWL_STYLE)
            If (style & #BS_GROUPBOX = #BS_GROUPBOX)
                *trackWin\windowType = #WINDOWTYPE_PBFRAME
                *trackWin\noErase = #True
            Else
                *trackWin\windowType = #WINDOWTYPE_SYSBUTTON
                *trackWin\noErase = #True
                *trackWin\transparent = #True
            EndIf
            
        ElseIf class = "PureContainer"
            *trackWin\windowType = #WINDOWTYPE_PBCONTAINER
            *trackWin\transparent = #True
        ElseIf class = "SysTabControl32"
            *trackWin\windowType = #WINDOWTYPE_SYSTAB
            *trackWin\noErase = #True
        ElseIf class = "ReBarWindow32"
            *trackWin\windowType = #WINDOWTYPE_REBAR
            *trackWin\transparent = #True
        ElseIf class = "ScrollBar"
            *trackWin\windowType = #WINDOWTYPE_SYSSCROLLBAR
            *trackWin\noErase = #True
            *trackWin\transparent = #True
        ElseIf class = #AppName+"_ScrollbarBox"
            *trackWin\windowType = #WINDOWTYPE_SCROLLBARBOX
        ElseIf class = "Static"
            *trackWin\windowType = #WINDOWTYPE_STATIC
            *trackWin\noErase = #True
            *trackWin\transparent = #True
        ElseIf FindString(class, "richedit", 1, #PB_String_NoCase) > 0
            *trackWin\windowType = #WINDOWTYPE_RICHEDIT
            *trackWin\noErase = #True
            *trackWin\transparent = #True
        ElseIf class = "ListBox"
            *trackWin\windowType = #WINDOWTYPE_LISTBOX
            *trackWin\noErase = #True
            *trackWin\transparent = #True
        ElseIf class = "SysListView32"
            *trackWin\windowType = #WINDOWTYPE_LISTVIEW
            *trackWin\noErase = #True
            *trackWin\transparent = #True
        ElseIf class = "SysHeader32"
            *trackWin\windowType = #WINDOWTYPE_SYSHEADER
            *trackWin\transparent = #True
        ElseIf class = "msctls_updown32"
            *trackWin\windowType = #WINDOWTYPE_UPDOWN
            *trackWin\transparent = #True
        ElseIf class = "PureSplitter"
            *trackWin\windowType = #WINDOWTYPE_PBSPLITTER
            *trackWin\transparent = #True
        ElseIf class = "SysTreeView32"
            *trackWin\windowType = #WINDOWTYPE_TREEVIEW
            *trackWin\noErase = #True
            *trackWin\transparent = #True
        ElseIf class = "msctls_trackbar32"
            *trackWin\windowType = #WINDOWTYPE_TRACKBAR
            *trackWin\transparent = #True
        ElseIf class = "SysMonthCal32"
            *trackWin\windowType = #WINDOWTYPE_CALENDAR
            *trackWin\transparent = #True
        ElseIf class = "PureWeb"
            *trackWin\windowType = #WINDOWTYPE_PUREWEB
            *trackWin\noErase = #True
            *trackWin\noPaint = #True
            *trackWin\transparent = #True
        ElseIf class = "Shell Embedding"
            *trackWin\windowType = #WINDOWTYPE_ShellEmbed
            *trackWin\noErase = #True
            *trackWin\noPaint = #True
            *trackWin\transparent = #True
        ElseIf class = "Internet Explorer_Server"
            *trackWin\windowType = #WINDOWTYPE_WEBExplorer
            *trackWin\noErase = #True
            *trackWin\noPaint = #True
            *trackWin\transparent = #True
        ElseIf class = "Shell DocObject View"
            *trackWin\windowType = #WINDOWTYPE_WEBDocObject
            *trackWin\noErase = #True
            *trackWin\noPaint = #True
            *trackWin\transparent = #True
        EndIf
        
        *ptrackWin.trackWindows = *trackwin\parentTrackWin
        If *ptrackWin <> #Null And *ptrackWin\windowType = #WINDOWTYPE_PANELEXPAGE
            SetWindowLongPtr_(hwnd, #GWL_EXSTYLE, GetWindowLongPtr_(hwnd, #GWL_EXSTYLE) | #WS_EX_TRANSPARENT)
        EndIf
        
        *trackWin\callbackProc = GetWindowLongPtr_(hwnd, #GWLP_WNDPROC)
        SetProp_(hwnd, trackwinAtom, *trackWin)
        SetWindowLongPtr_(hwnd, #GWLP_WNDPROC, @SubclassTrackwinProc())
        debuglog("trackwin: "+Str(hwnd)+" "+class+" callback: "+Str(*trackWin\callbackProc))
        
        updateTrackWinRootPanelEx(*trackWin)
        
    EndIf
    
EndProcedure

Procedure CallWndProcHook(nCode, wParam, lParam)
    Static lastmenuHotItem
    
    
    *cwp.CWPSTRUCT = lParam
    
    If CompositionEnabled = #False And menuEraseBuffered = #True
        If (*cwp\message = #WM_PAINT Or *cwp\message = #WM_NOTIFY) And menuEraseBufferInvalid = -1
            
            class.s = Space(255)
            GetClassName_(*cwp\hwnd, @class, 255)
            
            If class <> "#32768"
                If menuWindow <> 0
                    GetWindowRect_(menuWindow, @rc.RECT)
                    GetWindowRect_(*cwp\hwnd, @rec.RECT)
                    If IntersectRect(rc, rec)
                        menuEraseBufferInvalid = #True
                        ;debuglog("paint :"+Str(*cwp\hwnd))
                    EndIf
                EndIf
            EndIf
            
        EndIf
        
    EndIf
    
    Select nCode
            
        Case #HC_ACTION
            
            *cwp.CWPSTRUCT = lParam
            
            Select *cwp\message
                
                Case #WM_GETMINMAXINFO
                    
                    ; subclass the Window with our Window tracking proc
                    *trackWin.trackWindows = GetProp_(*cwp\hwnd, trackwinAtom)
                    If *trackWin = #Null
                        attachTrackWinToHwnd(*cwp\hwnd)
                    EndIf
                    
                Case #WM_NCCREATE
                    
                    ; subclass the Window with our Window tracking proc
                    *trackWin.trackWindows = GetProp_(*cwp\hwnd, trackwinAtom)
                    If *trackWin = #Null
                        attachTrackWinToHwnd(*cwp\hwnd)
                    EndIf
                    
                Case #WM_CREATE
                    
                    ;/ make sure window is a popup
                    class.s = Space(255)
                    GetClassName_(*cwp\hwnd, @class, 255)
                    
                    If class = "#32768" And menuHandle <> 0 ; menu
                        
                        ; remove CS_SAVEBITS from class when menu tracking
                        If CompositionEnabled = #False
                            style = GetClassLongPtr_(*cwp\hwnd, #GCL_STYLE)
                            If menuActive <> 0 And menuHotItem <> -1 And menuHotItem <> lastmenuHotItem
                                If style & #CS_SAVEBITS
                                    style = style & ~ #CS_SAVEBITS
                                    SetClassLongPtr_(*cwp\hwnd, #GCL_STYLE, style)
                                EndIf
                            Else
                                If Not style & #CS_SAVEBITS
                                    style = style | #CS_SAVEBITS
                                    SetClassLongPtr_(*cwp\hwnd, #GCL_STYLE, style)
                                EndIf
                            EndIf
                        EndIf
                        
                        miniMenuWindow = *cwp\hwnd
                        
                        ; subclass the window
                        OldSubclassWndProc = SetWindowLongPtr_(*cwp\hwnd, #GWLP_WNDPROC, @SubclassWndProc())
                        
                        ; sync update of menu toolbar buttons with menu window
                        If menuActive <> 0
                            
                            SendMessage_(menuToolbar, #TB_SETHOTITEM, menuHotItem, 0)
                            SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
                            RedrawWindow_(menuToolbar,0,0,#RDW_INVALIDATE|#RDW_ERASENOW|#RDW_UPDATENOW)
                            SendMessage_(menuToolbar, #WM_SETREDRAW, #False, 0)
                            lastmenuHotItem = menuHotItem
                            
                        EndIf
                        
                    ; if this window is a system drop-shadow and menuex is open then destroy  
                    ElseIf class = "SysShadow" And menuHandle <> 0
                        
                        DestroyWindow_(*cwp\hwnd)
                        
                    ; hack to get rid of 2 pixel graphical glitch in toolbars when CCS_NODIVIDER is set after toolbar is visible
                    ; works by intercepting toolbar window before visible and setting CCS_NODIVIDER
                    ElseIf class = "ToolbarWindow32"
                        
                        OldStyle=GetWindowLongPtr_(*cwp\hwnd, #GWL_STYLE)
                        SetWindowLongPtr_(*cwp\hwnd, #GWL_STYLE, OldStyle | #CCS_NODIVIDER)
                    
                    EndIf
                    
                Case #WM_DESTROY
                    
                    ; make sure window is a popup
                    class.s = Space(255)
                    GetClassName_(*cwp\hwnd, @class, 255)
                    
                    If class = "#32768" ; menu
                        
                        ; destroy any shadows attached to menu
                        ForEach shadow()
                            If shadow()\hwnd = *cwp\hwnd
                                DestroyWindow_(shadow()\rightShadow)
                                DestroyWindow_(shadow()\bottomShadow)
                                DestroyWindow_(shadow()\leftBottomShadow)
                                DeleteElement(shadow())
                            EndIf
                        Next
                        
                    EndIf
                    
            EndSelect

    EndSelect
    
    Result = CallNextHookEx_(0, nCode, wParam, lParam)
    
    ProcedureReturn Result
    
EndProcedure


ProcedureDLL CreateMenuEx(MenuID.l, WindowID.i, style.l)  ; Creates a "floating" menu bar, see docs for different styles...
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    *ID.IDHwndLookup = generateUniqueID(MenuID)
    If *ID = #Null
        ProcedureReturn #False
    EndIf
    
    menuToolbar = ToolBarExID(CreateToolBarEx(#ProGUI_Any, WindowID, 0, 0, #CCS_NORESIZE | #CCS_NODIVIDER | #TBSTYLE_AUTOSIZE | #TBSTYLE_FLAT | #TBSTYLE_LIST | #TBSTYLE_WRAPABLE))
    If menuToolbar = 0
        UnlockMutex(menuMutex)
        ProcedureReturn 0 ; exit if error creating toolbar
    EndIf
    LockMutex(toolbarMutex)
    ForEach toolbarEx()
        If toolbarEx()\Handle = menuToolbar
            toolbarEx()\isMenu = #True
            Break
        EndIf
    Next
    
    SendMessage_(menuToolbar, #TB_SETEXTENDEDSTYLE, 0, 0)
    
    ; disable toolbar theming , no dodge vista fading
    If XPthemeActive <> 0
        CallFunctionFast(*SetWindowTheme, menuToolbar, @null.w, @null.w)
    EndIf
    
    
    padding = SendMessage_(menuToolbar, #TB_GETPADDING, 0, 0)
    SendMessage_(menuToolbar, #TB_SETPADDING, 0, MakeLong(0,0));MakeLong(6,PeekW(@padding+2)))
    
    If style = #UISTYLE_OFFICE2003
        style = 6
    EndIf
    
    LastElement(menuex())
    AddElement(menuex())
    menuex()\id = *ID\ID
    menuex()\WindowID = WindowID
    menuex()\toolbarID = menuToolbar
    menuex()\popupid = -1
    menuex()\buttonID = -1
    menuex()\style = style
    currentMenuEx = *ID\ID
    
    ; check if a menu callback has been created for this windowid
    found = 0
    ForEach menuCallback()
        If menuCallback()\WindowID = WindowID
            found = -1
            Break
        EndIf
    Next
    
    ; if menu call back hasnt been created then create one
    If found = 0
        ProGUIOldCallBack = SetWindowLongPtr_(WindowID, #GWLP_WNDPROC, @MyWindowCallback())
        LastElement(menuCallback())
        AddElement(menuCallback())
        menuCallback()\WindowID = WindowID
        menuCallback()\callback = @MyWindowCallback()
        menuCallback()\oldCallback = ProGUIOldCallBack
        SetWindowLongPtr_(WindowID, #GWL_STYLE, GetWindowLongPtr_(WindowID, #GWL_STYLE)|#WS_CLIPCHILDREN)
    EndIf
    
    ; create hook to intercept creation of new windows for popup menus
    If WindowHook = 0
        threadId = GetWindowThreadProcessId_(WindowID, 0)
        WindowHook = SetWindowsHookEx_(#WH_CALLWNDPROC, @CallWndProcHook(), 0, threadId)
    EndIf
    
    ; create hook to handle keyboard navigation
    If KeyboardHook = 0
        threadId = GetWindowThreadProcessId_(WindowID, 0)
        KeyboardHook = SetWindowsHookEx_(#WH_KEYBOARD, @KeyboardHook(), 0, threadId)
    EndIf
    
    ; check if currentMenuEXFont has been set
    If currentMenuEXFont = 0
        metrics.NONCLIENTMETRICS
        metrics\cbSize = SizeOf(NONCLIENTMETRICS)
        
        SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
        currentMenuEXFont = CreateFontIndirect_(metrics\lfMenuFont)
    EndIf
    
    UnlockMutex(menuMutex)
    UnlockMutex(toolbarMutex)
    
    If MenuID = #ProGUI_Any
        ProcedureReturn *ID\ID
    Else
        ProcedureReturn menuToolbar
    EndIf
    
EndProcedure

ProcedureDLL CreatePopupMenuEx(MenuID.l, style.l) ; Creates a popup menu
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    *ID.IDHwndLookup = generateUniqueID(MenuID)
    If *ID = #Null
        ProcedureReturn #False
    EndIf
    
    popupid = CreatePopupMenu(#PB_Any)
    If popupid = 0
        Debug "Error creating popup menu!"
        UnlockMutex(menuMutex)
        ProcedureReturn 0
    EndIf
    
    If style = #UISTYLE_OFFICE2003
        style = 6
    EndIf
    
    ; create new menu entry
    LastElement(menuex())
    AddElement(menuex())
    
    menuex()\id = *ID\ID
    menuex()\toolbarID = -1
    menuex()\popupid = MenuID(popupid)
    menuex()\purepopupid = popupid
    menuex()\buttonID = -1
    menuex()\singleMenu = -1
    menuex()\style = style
    
    currentMenuTitleEX = menuex()\popupid
    currentMenuEx = MenuID
    
    UnlockMutex(menuMutex)
    
    ProcedureReturn currentMenuTitleEX
    
EndProcedure

ProcedureDLL DisplayPopupMenuEx(menu.i, WindowID.i, x.l, y.l) ; Displays a PopupMenuEx on screen at x, y coordinates
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    If ListSize(itemex()) = 0
        UnlockMutex(menuMutex)
        ProcedureReturn 0
    EndIf
    
    ; check if a menu callback has been created for this windowid
    found = 0
    ForEach menuCallback()
        If menuCallback()\WindowID = WindowID
            found = -1
            Break
        EndIf
    Next
    
    ; if menu call back hasnt been created then create one
    If found = 0
        ProGUIOldCallBack = SetWindowLongPtr_(WindowID, #GWLP_WNDPROC, @MyWindowCallback())
        LastElement(menuCallback())
        AddElement(menuCallback())
        menuCallback()\WindowID = WindowID
        menuCallback()\callback = @MyWindowCallback()
        menuCallback()\oldCallback = ProGUIOldCallBack
    EndIf
    
    ; create hook to intercept creation of new windows for popup menus
    If WindowHook = 0
        threadId = GetWindowThreadProcessId_(WindowID, 0)
        WindowHook = SetWindowsHookEx_(#WH_CALLWNDPROC, @CallWndProcHook(), 0, threadId)
    EndIf
    
    ; create hook to handle keyboard navigation
    If KeyboardHook = 0
        threadId = GetWindowThreadProcessId_(WindowID, 0)
        KeyboardHook = SetWindowsHookEx_(#WH_KEYBOARD, @KeyboardHook(), 0, threadId)
    EndIf
    
    ; check if currentMenuEXFont has been set
    If currentMenuEXFont = 0
        metrics.NONCLIENTMETRICS
        metrics\cbSize = SizeOf(NONCLIENTMETRICS)
        
        SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
        currentMenuEXFont = CreateFontIndirect_(metrics\lfMenuFont)
    EndIf
    
    ForEach menuex()
        If menuex()\id = menu Or menuex()\popupid = menu
            
            *thisMenuEx = @menuex()
            
            ; makesure the menu has at least one item
            found = #False
            ForEach itemex()
                If itemex()\menuex = @menuex()
                    found = #True
                    Break
                EndIf
            Next
            If found = #False
                UnlockMutex(menuMutex)
                ProcedureReturn 0
            EndIf
            
            menuWindow = 0
            menuTitleOffset = 0
            menuTitleVOffset = 0
            menuTitleWidth = 0
            subMenuActive = 0
            lastSubMenu = 0
            menuOldFocus = GetFocus_()
            menuWindowWidth = CalcMenuItemWidth(menuex()\popupid)
            menuex()\measuredWidth = menuWindowWidth
            menuex()\measuredHeight = CalcMenuItemHeight(menuex()\popupid)
            menuHandle = menuex()\popupid
            menuExHandle = @menuex()
            
            menuex()\root = #True
            menuWindowXpos = x
            
            ; find nearest display monitor to window
            prc.RECT
            prc\left = x
            prc\top = y
            prc\right = prc\left
            prc\bottom = prc\top
            hmonitor = MonitorFromRect_(@prc, #MONITOR_DEFAULTTONEAREST)
            minfo.MONITORINFO
            minfo\cbSize = SizeOf(MONITORINFO)
            GetMonitorInfo_(hmonitor, @minfo)
            menuPositionOffset = 0
            If x+menuWindowWidth+5 > minfo\rcWork\right
                menuWindowXpos = (minfo\rcWork\right-menuWindowWidth)-5 ; store the predicted x pos of menu window for use with title dropshadow
                menuPositionOffset = (x+menuWindowWidth)-minfo\rcWork\right+6
                x = menuWindowXpos
            EndIf
            
            threadId = GetWindowThreadProcessId_(WindowID, 0)
            menuHook = SetWindowsHookEx_(#WH_MSGFILTER, @miniMsgHook(), 0, threadId)
            menuMouseHook = SetWindowsHookEx_(#WH_MOUSE_LL, @miniMouseHook(), 0, 0)
            UnlockMutex(menuMutex)
            TrackPopupMenuEx_(menuex()\popupid, #TPM_VERTICAL, x, y, WindowID, 0)
            UnhookWindowsHookEx_(menuMouseHook)
            UnhookWindowsHookEx_(menuHook)
            LockMutex(menuMutex)
            ChangeCurrentElement(menuex(), *thisMenuEx)
            menuHandle = 0
            menuExHandle = 0
            
            menuHandle = 0
            menuex()\active = 0
            menuActive = 0
            dropdownActive = 0
            menuDraw = 0
            menuex()\root = #False
            menuKeyboardActive = #False
            If menuOldFocus <> 0
                SetFocus_(menuOldFocus)
                menuOldFocus = 0
            EndIf
            
            UnlockMutex(menuMutex)
            ProcedureReturn #True
        EndIf
    Next
    
    UnlockMutex(menuMutex)
    ProcedureReturn 0
EndProcedure

ProcedureDLL MenuExF10Disable(disable.b)
    
    menuExF10Disable = disable
    
EndProcedure

ProcedureDLL MenuExAutoHotKeyDisable(disable.b)
    
    menuExAutoHotKeyDisable = disable
    
EndProcedure

Procedure resetMenuMetrics(menu.i)  ; windows handle
    
    If IsMenu_(menu) <> 0
        items = GetMenuItemCount_(menu)
        If items <> -1
            
            ; force WM_MEASUREITEM
            minfo.MENUITEMINFO_Fixed
            minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
            minfo\fMask = #MIIM_BITMAP
            
            UnlockMutex(menuMutex)
            For n = 0 To items-1
                SetMenuItemInfo_(menu, n, #True, @minfo)
            Next
            LockMutex(menuMutex)
            
            updateDefaultDisabledImages(menu, 2)
            
        EndIf
        ProcedureReturn #True
    EndIf
    
    ProcedureReturn 0
EndProcedure

ProcedureDLL SetMenuExStyle(menu.i, style.l) ; sets the rendering style of a menuEx
    
    macro_protectCommand()
    
    If style = #UISTYLE_OFFICE2003
        style = 6
    EndIf
    
    LockMutex(menuMutex)
    
    ForEach menuex()
        If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
            
            menu = menuex()\popupid
            If menuex()\singleMenu = 0
                toolbarID = menuex()\toolbarID
                found = -1
            Else
                found = -2
            EndIf
            Break
            
        EndIf
    Next
    
    If found = -1
        ForEach menuex()
            If menuex()\toolbarID = toolbarID
                menuex()\style = style
                menuex()\bufferWidth = 0
                menuex()\bufferHeight = 0
                resetMenuMetrics(menuex()\popupid)
            EndIf
        Next
        resizeToolbar(toolbarID)
        UnlockMutex(menuMutex)
        ProcedureReturn #True
    ElseIf found = -2
        ForEach menuex()
            If menuex()\popupid = menu
                menuex()\style = style
                menuex()\bufferWidth = 0
                menuex()\bufferHeight = 0
                resetMenuMetrics(menuex()\popupid)
            EndIf
        Next
        UnlockMutex(menuMutex)
        ProcedureReturn #True
    EndIf
    
    UnlockMutex(menuMutex)
    ProcedureReturn 0
EndProcedure

ProcedureDLL MenuTitleEx(title.s) ; Creates a title on menu bar
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    ; check that there is a current id and it exists
    found = 0
    If currentMenuEx <> -1
        ForEach menuex()
            If menuex()\id = currentMenuEx
                toolbarID = menuex()\toolbarID
                WindowID = menuex()\WindowID
                style = menuex()\style
                
                If menuex()\popupid = -1 And menuex()\buttonID = -1
                    DeleteElement(menuex())
                EndIf
                
                found = -1
                Break
            EndIf
        Next
    EndIf
    
    ; exit if it is not found
    If found = 0
        UnlockMutex(menuMutex)
        ProcedureReturn 0
    EndIf
    
    
    popupid = CreatePopupMenu(#PB_Any)
    If popupid = 0
        UnlockMutex(menuMutex)
        ProcedureReturn 0 ; exit if popup couldnt be created
    EndIf
    
    ; set the menu to not modal
    ;minfo.MENUINFO
    ;minfo\cbSize = SizeOf(MENUINFO)
    ;minfo\fMask = #MIM_STYLE
    ;minfo\dwStyle = #MNS_MODELESS
    ;SetMenuInfo_(MenuID(popupid), @minfo)
    
    buttonID = ToolBarButtonEx(#ProGUI_Any, title, #BTNS_DROPDOWN)
    If buttonID = -1
        UnlockMutex(menuMutex)
        ProcedureReturn 0 ; exit if error creating toolbar button
    EndIf
    
    AddElement(menuex())
    menuex()\id = currentMenuEx
    menuex()\WindowID = WindowID
    menuex()\toolbarID = toolbarID
    menuex()\popupid = MenuID(popupid)
    menuex()\purepopupid = popupid
    menuex()\buttonID = buttonID
    menuex()\style = style
    currentMenuTitleEX = menuex()\popupid
    
    UnlockMutex(menuMutex)
    
    hdc = CreateCompatibleDC_(0)
    SelectObject_(hdc, currentMenuEXFont)
    DrawText_(hdc, title, Len(title), @rec.RECT, #DT_SINGLELINE | #DT_CALCRECT)
    DeleteDC_(hdc)
    
    button.TBBUTTONINFO
    button\cbSize = SizeOf(TBBUTTONINFO)
    button\dwMask = #TBIF_SIZE
    button\cx = rec\right+#MENUEXPADX
    
    ; reset menu bar height if font too small
    If rec\bottom+#MENUEXPADY < #MENUEXMINHEIGHT
        rec\bottom = #MENUEXMINHEIGHT - #MENUEXPADY
    EndIf
    
    ; 2003 style
    If style = 6
        button\cx = button\cx - 2
        rec\bottom = rec\bottom - 3
        ; 2007 style
    ElseIf style = #UISTYLE_OFFICE2007
        button\cx = button\cx - 2
        rec\bottom = rec\bottom - 2
    EndIf
    
    SendMessage_(toolbarID, #TB_SETBUTTONSIZE, 0, MakeLong(0, rec\bottom+#MENUEXPADY))
    SendMessage_(toolbarID, #TB_SETBUTTONINFO, buttonID, @button)
    
EndProcedure


ProcedureDLL SetMenuExImageSize(width.l, height.l) ; sets the image dimensions for icons in menu
    
    macro_protectCommand()
    
    menuExItemIconWidth = width
    menuExItemIconHeight = height
EndProcedure


ProcedureDLL MenuItemEx(MenuItemID.l, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, submenu.i) ; Creates a menu item with an optional icon
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    ;check that there is a current id and it exists
    found = 0
    If currentMenuEx <> -1
        ForEach menuex()
            If menuex()\id = currentMenuEx And menuex()\popupid = currentMenuTitleEX
                menuex()\bufferWidth = 0
                menuex()\bufferHeight = 0
                found = -1
                Break
            EndIf
        Next
    EndIf
    
    ; exit if it is not found
    If found = 0
        UnlockMutex(menuMutex)
        ProcedureReturn 0
    EndIf
    
    ; handle #ProGUI_Any for menu item id
    If MenuItemID = #ProGUI_Any
        Repeat
            ; generate unique id
            MenuItemID = generateUniqueCommandID_wordUnsigned()
            ; check that same id doesnt already exist
            found = 0
            thisMenuEx = @menuex()
            ForEach menuex()
                
                minfo.MENUITEMINFO_Fixed
                minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                minfo\fMask = #MIIM_ID
                If GetMenuItemInfo_(menuex()\popupid, MenuItemID, 0, @minfo) <> 0
                    found = #True
                    Break
                EndIf
                
            Next
            ChangeCurrentElement(menuex(), thisMenuEx)
        Until found = 0
        ProGUI_Any = #True
    EndIf
    
    minfo.MENUITEMINFO_Fixed
    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    If submenu = 0
        minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA|#MIIM_STRING
    Else  ; sub menu attached
        
        ; search for existing id if submenu is not a handle to a menu
        If IsMenu_(submenu) = 0
            thisMenuEx = @menuex()
            ForEach menuex()
                If menuex()\id = submenu
                    submenu = menuex()\popupid
                    Break
                EndIf
            Next
            ChangeCurrentElement(menuex(), thisMenuEx)
        EndIf
        
        minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA|#MIIM_SUBMENU|#MIIM_STRING
        minfo\hSubMenu = submenu
    EndIf
    minfo\fType = #MFT_OWNERDRAW
    minfo\wID = MenuItemID
    LastElement(itemex())
    AddElement(itemex())
    itemex()\text = text
    minfo\dwItemData = @itemex()
    minfo\dwTypeData = @text
    minfo\cch = Len(text)
    
    itemex()\menuex = @menuex()
    itemex()\popupid = menuex()\popupid
    itemex()\pos = GetMenuItemCount_(menuex()\popupid)
    itemex()\imageWidth = menuExItemIconWidth
    itemex()\imageHeight = menuExItemIconHeight
    itemex()\defDisabledStyle = menuex()\style
    
    ; add automatic shortcut if found in text
    autoHotKey(menuex()\WindowID, MenuItemID, text)
    
    If normalImageID <> 0
        
        menuIcons = ImageList_Create_(menuExItemIconWidth, menuExItemIconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
        If menuIcons <> 0
            
            itemex()\ImageList = menuIcons
            error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
            If error = -1
                error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
            EndIf
            If error <> -1
                itemex()\normal = -1
            EndIf
            
            If hotImageID <> 0
                error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hotImageID)
                If error = -1
                    error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(hotImageID))
                EndIf
                
                If error <> -1
                    itemex()\hot = -1
                Else
                    error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
                    If error = -1
                        error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
                    EndIf
                EndIf
            Else
                error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
                If error = -1
                    error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
                EndIf
            EndIf
            
            If disabledImageID <> 0
                error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImageID)
                If error = -1
                    error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(disabledImageID))
                EndIf
                If error <> -1
                    itemex()\disabled = -1
                Else
                    disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
                    error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
                    DestroyIcon_(disabledImg)
                EndIf
            Else
                disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
                error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
                DestroyIcon_(disabledImg)
            EndIf
        EndIf
        
    EndIf
    
    popupid = menuex()\popupid
    UnlockMutex(menuMutex)
    If InsertMenuItem_(popupid, -1, #True, @minfo) = 0
        debuglog("failed on: "+text)
        ProcedureReturn #False
    EndIf
    
    If ProGUI_Any = #True
        ProcedureReturn MenuItemID
    EndIf
    
    ProcedureReturn #True
    
EndProcedure

ProcedureDLL MenuBarEx()
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    ;check that there is a current id and it exists
    found = 0
    If currentMenuEx <> -1
        ForEach menuex()
            If menuex()\id = currentMenuEx And menuex()\popupid = currentMenuTitleEX
                menuex()\bufferWidth = 0
                menuex()\bufferHeight = 0
                found = -1
                Break
            EndIf
        Next
    EndIf
    
    ; exit if it is not found
    If found = 0
        UnlockMutex(menuMutex)
        ProcedureReturn 0
    EndIf
    
    minfo.MENUITEMINFO_Fixed
    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA
    minfo\fType = #MFT_OWNERDRAW
    minfo\wID = 0
    LastElement(itemex())
    AddElement(itemex())
    itemex()\text = ""
    minfo\dwItemData = @itemex()
    
    itemex()\menuex = @menuex()
    itemex()\popupid = menuex()\popupid
    itemex()\pos = GetMenuItemCount_(menuex()\popupid)
    itemex()\imageWidth = menuExItemIconWidth
    itemex()\imageHeight = menuExItemIconHeight
    
    popupid = menuex()\popupid
    UnlockMutex(menuMutex)
    InsertMenuItem_(popupid, -1, #True, @minfo)
    
EndProcedure

ProcedureDLL SetMenuItemEx(menu.i, itemID.l, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, submenu.i) ; Sets a menu item with optional image data
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    ;check that menu exists, search by id or handle
    found = 0
    ForEach menuex()
        If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
            
            For n = 0 To count
                minfo.MENUITEMINFO_Fixed
                minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                minfo\fMask = #MIIM_ID
                If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) <> 0
                    found = #True
                    Break 2
                EndIf
            Next
            
        EndIf
    Next
    
    If found = #True
        
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_DATA|#MIIM_STATE
        If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) = 0
            UnlockMutex(menuMutex)
            ProcedureReturn #False
        EndIf
        ChangeCurrentElement(itemex(), minfo\dwItemData)
        
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        If submenu = 0
            minfo\fMask = #MIIM_STRING|#MIIM_BITMAP
        Else  ; sub menu attached
            
            ; search for existing id if submenu is not a handle to a menu
            If IsMenu_(submenu) = 0
                thisMenuEx = @menuex()
                ForEach menuex()
                    If menuex()\id = submenu
                        submenu = menuex()\popupid
                        Break
                    EndIf
                Next
                ChangeCurrentElement(menuex(), thisMenuEx)
            EndIf
            
            minfo\fMask = #MIIM_SUBMENU|#MIIM_BITMAP|#MIIM_STRING
            minfo\hSubMenu = submenu
        EndIf
        minfo\dwTypeData = @text
        minfo\cch = Len(text)
        
        ; remove old automatic shortcut if found in old text
        autoHotKey(menuex()\WindowID, itemID, itemex()\text)
        ; add automatic shortcut if found in text
        autoHotKey(menuex()\WindowID, itemID, text)
        
        itemex()\text = text
        
        If normalImageID <> 0
            
            itemex()\imageWidth = menuExItemIconWidth
            itemex()\imageHeight = menuExItemIconHeight
            
            ImageList_Destroy_(itemex()\ImageList)
            
            menuIcons = ImageList_Create_(menuExItemIconWidth, menuExItemIconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
            If menuIcons <> 0
                itemex()\ImageList = menuIcons
                error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
                If error = -1
                    error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
                EndIf
                If error <> -1
                    itemex()\normal = -1
                EndIf
                
                If hotImageID <> 0
                    error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hotImageID)
                    If error = -1
                        error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(hotImageID))
                    EndIf
                    
                    If error <> -1
                        itemex()\hot = -1
                    Else
                        error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
                        If error = -1
                            error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
                        EndIf
                    EndIf
                Else
                    error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
                    If error = -1
                        error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
                    EndIf
                EndIf
                
                If disabledImageID <> 0
                    error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImageID)
                    If error = -1
                        error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(disabledImageID))
                    EndIf
                    If error <> -1
                        itemex()\disabled = -1
                    Else
                        disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
                        error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
                        DestroyIcon_(disabledImg)
                    EndIf
                Else
                    disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
                    error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
                    DestroyIcon_(disabledImg)
                EndIf
            EndIf
            
        EndIf
        
        old = GetSubMenu_(menuex()\popupid, itemex()\pos)
        If old <> 0 And submenu <> 0
            popupid = menuex()\popupid
            *thisMenuEx = @menuex()
            *thisItemEx = @itemex()
            UnlockMutex(menuMutex)
            RemoveMenu_(popupid, itemID, 0)
            LockMutex(menuMutex)
            ChangeCurrentElement(menuex(), *thisMenuEx)
            ChangeCurrentElement(itemex(), *thisItemEx)
            minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA|#MIIM_SUBMENU|#MIIM_STRING
            minfo\hSubMenu = submenu
            minfo\fType = #MFT_OWNERDRAW
            minfo\wID = itemID
            minfo\dwItemData = @itemex()
            minfo\dwTypeData = @text
            minfo\cch = Len(text)
            pos = itemex()\pos
            UnlockMutex(menuMutex)
            InsertMenuItem_(popupid, pos, #True, @minfo)
            LockMutex(menuMutex)
        Else
            popupid = menuex()\popupid
            *thisMenuEx = @menuex()
            *thisItemEx = @itemex()
            UnlockMutex(menuMutex)
            SetMenuItemInfo_(popupid, itemID, 0, @minfo)
            LockMutex(menuMutex)
            ChangeCurrentElement(menuex(), *thisMenuEx)
            ChangeCurrentElement(itemex(), *thisItemEx)
        EndIf
        
        menuex()\bufferWidth = 0
        menuex()\bufferHeight = 0
        
        UnlockMutex(menuMutex)
        ProcedureReturn #True
    EndIf
    
    UnlockMutex(menuMutex)
    ProcedureReturn 0
EndProcedure

ProcedureDLL RemoveMenuItemEx(menu.i, itemID.l, byPosition.b) ; Removes a menu item from menuEx
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    ;check that menu exists, search by id or handle
    found = 0
    ForEach menuex()
        If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
            
            If byPosition = #False
                count = GetMenuItemCount_(menuex()\popupid)
                For n = 0 To count
                    minfo.MENUITEMINFO_Fixed
                    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                    minfo\fMask = #MIIM_ID
                    If GetMenuItemInfo_(menuex()\popupid, n, #True, @minfo) <> 0
                        If minfo\wID = itemID
                            found = #True
                            Break 2
                        EndIf
                    EndIf
                Next
            Else
                n = itemID
                found = #True
                Break
            EndIf
            
        EndIf
    Next
    
    ; free associated itemEx and images
    If found = #True
        mnfo.MENUITEMINFO_Fixed
        mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        mnfo\fMask = #MIIM_DATA	
        If GetMenuItemInfo_(menuex()\popupid, n, #True, @mnfo) <> 0
            ChangeCurrentElement(itemex(), mnfo\dwItemData)
            ImageList_Destroy_(itemex()\ImageList)
            
            *thisMenuEx = @menuex()
            *thisItemEx = @itemex()
            popupid = menuex()\popupid
            UnlockMutex(menuMutex)
            success = RemoveMenu_(popupid, n, #MF_BYPOSITION)
            LockMutex(menuMutex)
            ChangeCurrentElement(menuex(), *thisMenuEx)
            ChangeCurrentElement(itemex(), *thisItemEx)
            
            ; remove automatic shortcut if found in text
            autoHotKey(menuex()\WindowID, -1, itemex()\text)
            
            DeleteElement(itemex())
            
            ; update new positions of items
            count = GetMenuItemCount_(menuex()\popupid)
            mnfo.MENUITEMINFO_Fixed
            mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
            mnfo\fMask = #MIIM_DATA	
            For z = 0 To count-1
                If GetMenuItemInfo_(menuex()\popupid, z, #True, @mnfo) <> 0
                    ChangeCurrentElement(itemex(), mnfo\dwItemData)
                    itemex()\pos = z
                EndIf
            Next
            
            menuex()\bufferWidth = 0
            menuex()\bufferHeight = 0
            
            UnlockMutex(menuMutex)
            ProcedureReturn success
        Else
            UnlockMutex(menuMutex)
            ProcedureReturn 0
        EndIf
    EndIf
    
    UnlockMutex(menuMutex)
    ProcedureReturn 0
EndProcedure

ProcedureDLL InsertMenuItemEx(menu.i, Position.l, newItemID.l, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, submenu.i) ; Inserts a new menu item into a menuEx
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    ;check that menu exists, search by id or handle
    found = 0
    ForEach menuex()
        If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
            
            found = -1
            Break
            
        EndIf
    Next
    
    If found = -1
        
        ; detect special scroll item mode from submenu
        If submenu < 0
            scroll = submenu
            submenu = 0
        EndIf
        
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        If submenu = 0
            minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA|#MIIM_STRING
        Else  ; sub menu attached
            
            ; search for existing id if submenu is not a handle to a menu
            If IsMenu_(submenu) = 0
                thisMenuEx = @menuex()
                ForEach menuex()
                    If menuex()\id = submenu
                        submenu = menuex()\popupid
                        Break
                    EndIf
                Next
                ChangeCurrentElement(menuex(), thisMenuEx)
            EndIf
            
            minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA|#MIIM_SUBMENU|#MIIM_STRING
            minfo\hSubMenu = submenu
        EndIf
        minfo\fType = #MFT_OWNERDRAW
        minfo\wID = newItemID
        LastElement(itemex())
        AddElement(itemex())
        minfo\dwItemData = @itemex()
        minfo\dwTypeData = @text
        minfo\cch = Len(text)
        itemex()\text = text
        itemex()\menuex = @menuex()
        itemex()\popupid = menuex()\popupid
        If scroll < 0
            itemex()\scroll = scroll
        EndIf
        If Position <= -1
            itemex()\pos = GetMenuItemCount_(menuex()\popupid)
        Else
            itemex()\pos = Position
        EndIf
        itemex()\imageWidth = menuExItemIconWidth
        itemex()\imageHeight = menuExItemIconHeight
        
        ; add automatic shortcut if found in text
        autoHotKey(menuex()\WindowID, MenuItemID, text)
        
        If normalImageID <> 0
            
            menuIcons = ImageList_Create_(menuExItemIconWidth, menuExItemIconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
            If menuIcons <> 0
                itemex()\ImageList = menuIcons
                error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
                If error = -1
                    error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
                EndIf
                If error <> -1
                    itemex()\normal = -1
                EndIf
                
                If hotImageID <> 0
                    error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hotImageID)
                    If error = -1
                        error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(hotImageID))
                    EndIf
                    
                    If error <> -1
                        itemex()\hot = -1
                    Else
                        error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
                        If error = -1
                            error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
                        EndIf
                    EndIf
                Else
                    error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
                    If error = -1
                        error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
                    EndIf
                EndIf
                
                If disabledImageID <> 0
                    error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImageID)
                    If error = -1
                        error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(disabledImageID))
                    EndIf
                    If error <> -1
                        itemex()\disabled = -1
                    Else
                        disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
                        error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
                        DestroyIcon_(disabledImg)
                    EndIf
                Else
                    disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
                    error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
                    DestroyIcon_(disabledImg)
                EndIf
            EndIf
            
        EndIf
        
        popupid = menuex()\popupid
        
        *thisMenuEx = @menuex()
        *thisItemEx = @itemex()
        UnlockMutex(menuMutex)
        RET = InsertMenuItem_(popupid, Position, #True, @minfo)
        LockMutex(menuMutex)
        ChangeCurrentElement(menuex(), *thisMenuEx)
        ChangeCurrentElement(itemex(), *thisItemEx)
        If RET <> 0
            If Position > -1
                thisItemEx = @itemex()
                
                ; update new positions of items
                count = GetMenuItemCount_(menuex()\popupid)
                mnfo.MENUITEMINFO_Fixed
                mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                mnfo\fMask = #MIIM_DATA	
                For n = 0 To count-1
                    If GetMenuItemInfo_(menuex()\popupid, n, #True, @mnfo) <> 0
                        ChangeCurrentElement(itemex(), mnfo\dwItemData)
                        itemex()\pos = n
                    EndIf
                Next
                
                ChangeCurrentElement(itemex(), thisItemEx)
            EndIf
            menuex()\bufferWidth = 0
            menuex()\bufferHeight = 0
            
            UnlockMutex(menuMutex)
            ProcedureReturn #True
        EndIf
        
        UnlockMutex(menuMutex)
        ProcedureReturn 0
    EndIf
    
    UnlockMutex(menuMutex)
    ProcedureReturn 0
EndProcedure


ProcedureDLL.s GetMenuItemExText(menu.i, itemID.l)
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    ;check that menu exists, search by id or handle
    found = 0
    ForEach menuex()
        If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
            
            ForEach itemex()
                
                minfo.MENUITEMINFO_Fixed
                minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                minfo\fMask = #MIIM_ID
                GetMenuItemInfo_(menuex()\popupid, itemex()\pos, #True, @minfo)
                
                If itemex()\popupid = menuex()\popupid And minfo\wID = itemID
                    found = #True
                    Break 2
                EndIf
            Next
            
        EndIf
    Next
    
    If found = #True
        ReturnString$ = itemex()\text
        debuglog(ReturnString$)
    Else
        ReturnString$ = ""
    EndIf
    
    UnlockMutex(menuMutex)
    ProcedureReturn ReturnString$ 
EndProcedure

; ProcedureDLL SetMenuExTitleText(menu.l, Position.l, text.s)
; 
; ;check that menu exists, search by id or handle
; found = 0
; ForEach menuex()
; If menuex()\id = menu Or menuex()\toolbarID = menu
; 
; If SendMessage_(menuex()\toolbarID, #TB_COMMANDTOINDEX, menuex()\buttonID, 0) = Position
; ProcedureReturn ChangeToolbarExButton(menuex()\toolbarID, menuex()\buttonID, text, 0, 0, 0)
; EndIf
; 
; EndIf
; Next
; 
; ProcedureReturn 0
; EndProcedure

ProcedureDLL SetMenuExFont(fontID.i) ; Sets the font that MenuExs use for rendering text
    
    macro_protectCommand()
    
    CompilerIf #LIBRARY = 1
        If IsFont(fontID)
            fontID = FontID(fontID)
        EndIf
    CompilerEndIf
    
    If GetObjectType_(fontID) <> #OBJ_FONT
        ProcedureReturn 0
    EndIf
    
    If GetObject_(fontID, SizeOf(LOGFONT), @fontnfo.LOGFONT) <> 0
        DeleteObject_(currentMenuEXFont)
        currentMenuEXFont = CreateFontIndirect_(fontnfo)
    Else  
        ProcedureReturn #False
    EndIf
    
    minfo.MENUITEMINFO_Fixed
    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    minfo\fMask = #MIIM_BITMAP
    LockMutex(menuMutex)
    ForEach menuex()
        
        menuex()\bufferWidth = 0
        menuex()\bufferHeight = 0
        
        If menuex()\singleMenu = 0
            
            ; change our current menuex font to the new menu font
            hdc = CreateCompatibleDC_(0)
            SelectObject_(hdc, currentMenuEXFont)
            
            ; get old height of toolbar
            oldheight = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)
            oldheight = (oldheight>>16)
            
            ; re-calc the toolbar button dimensions with the new font
            buttontxt.s = ""
            bufflen = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, 0)
            If bufflen > 0
                CompilerIf #PB_Compiler_Unicode
                    bufflen = bufflen * 2
                CompilerEndIf
                *mem = AllocateMemory(bufflen+2)
                SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, *mem)
                buttontxt = PeekS(*mem, bufflen)
                FreeMemory(*mem)
            EndIf
            
            DrawText_(hdc, buttontxt, Len(buttontxt), @rec.RECT, #DT_SINGLELINE | #DT_CALCRECT)
            
            DeleteDC_(hdc)
            
            buttoni.TBBUTTONINFO
            buttoni\cbSize = SizeOf(TBBUTTONINFO)
            buttoni\dwMask = #TBIF_SIZE
            buttoni\cx = rec\right+#MENUEXPADX
            
            ; reset menu bar height if font too small
            If rec\bottom+#MENUEXPADY < #MENUEXMINHEIGHT
                rec\bottom = #MENUEXMINHEIGHT - #MENUEXPADY
            EndIf
            
            ; 2003 style
            If menuex()\style = 6
                buttoni\cx = buttoni\cx - 2
                rec\bottom = rec\bottom - 3
            EndIf
            
            SendMessage_(menuex()\toolbarID, #TB_SETBUTTONSIZE, 0, MakeLong(0, rec\bottom+#MENUEXPADY))
            SendMessage_(menuex()\toolbarID, #TB_SETBUTTONINFO, menuex()\buttonID, @buttoni)
            
            ; check if the toolbar is in a rebar
            ForEach rebarGadget()
                If GetParent_(menuex()\toolbarID) = rebarGadget()\Handle
                    
                    ; find bar that our toolbar is contained in
                    max = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0,0)
                    For n = 0 To max
                        band.REBARBANDINFO
                        band\cbSize = SizeOf(REBARBANDINFO)
                        band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
                        SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, n, @band)
                        
                        dwBtnSize = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)>>16
                        If band\hwndChild = menuex()\toolbarID
                            
                            ; calc old height delta between toolbar and band
                            hdelta = band\cyMinChild-oldheight
                            
                            ; set rebar band's new height
                            band\fMask = #RBBIM_CHILDSIZE
                            band\cyMinChild = dwBtnSize+hdelta
                            SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, n, @band)
                            
                            Break
                        EndIf
                    Next
                    
                    Break
                EndIf
            Next
            
        EndIf
        
        For n = 0 To GetMenuItemCount_(menuex()\popupid)-1
            SetMenuItemInfo_(menuex()\popupid, n, #True, @minfo)
        Next
    Next
    
    UnlockMutex(menuMutex)
    ProcedureReturn #True
    
EndProcedure

ProcedureDLL GetMenuExFont() ; Gets the font that MenuExs use for rendering text
    
    macro_protectCommand()
    
    ProcedureReturn currentMenuEXFont
    
EndProcedure

ProcedureDLL MenuExID(id.l)
    
    LockMutex(menuMutex)
    ForEach menuex()
        If menuex()\id = id And menuex()\toolbarID = -1
            RET = menuex()\popupid
            Break
        ElseIf menuex()\id = id And menuex()\toolbarID <> -1
            RET = menuex()\toolbarid
            Break
        EndIf
    Next
    
    UnlockMutex(menuMutex)
    ProcedureReturn RET
EndProcedure

ProcedureDLL DisableMenuItemEx(menu.i, itemID.l, state.b)
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    ;check that menu exists, search by id or handle
    ForEach menuex()
        If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
            
            count = GetMenuItemCount_(menuex()\popupid)
            For n = 0 To count
                
                minfo.MENUITEMINFO_Fixed
                minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                minfo\fMask = #MIIM_ID
                If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) <> 0
                    found = #True
                    Break 2
                EndIf
            Next
            
        EndIf
    Next
    
    If found = #True
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_STATE|#MIIM_DATA
        If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) = 0
            UnlockMutex(menuMutex)
            ProcedureReturn 0
        EndIf
        oldstate = minfo\fState
        
        ChangeCurrentElement(itemex(), minfo\dwItemData)
        
        If state <> 0
            oldstate = oldstate & ~#MFS_ENABLED
            minfo\fState = oldstate|#MFS_GRAYED
            ; disable automatic shortcut if found in text  
            autoHotKey(menuex()\WindowID, -1, itemex()\text)
        Else
            oldstate = oldstate & ~#MFS_GRAYED
            minfo\fState = oldstate|#MFS_ENABLED
            ; add automatic shortcut if found in text
            autoHotKey(menuex()\WindowID, itemID, itemex()\text)
        EndIf
        
        minfo\fMask = #MIIM_STATE
        If SetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) <> 0
            menuex()\bufferWidth = 0
            menuex()\bufferHeight = 0
            UnlockMutex(menuMutex)
            ProcedureReturn #True
        Else
            UnlockMutex(menuMutex)
            ProcedureReturn 0
        EndIf
    EndIf
    
    UnlockMutex(menuMutex)
    ProcedureReturn 0
    
EndProcedure


ProcedureDLL SetMenuExItemState(menu.i, itemID.l, state.l) ; Sets a menu item checkbox/radiocheck state
    
    macro_protectCommand()
    
    Static groupNo.l
    Static radioGroupActive.l
    
    LockMutex(menuMutex)
    
    ;check that menu exists, search by id or handle
    found = 0
    ForEach menuex()
        If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
            
            For n = 0 To count
                minfo.MENUITEMINFO_Fixed
                minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                minfo\fMask = #MIIM_ID
                If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) <> 0
                    found = #True
                    Break 2
                EndIf
            Next
            
        EndIf
    Next
    
    If found = #True
        
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_DATA|#MIIM_STATE
        If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) = 0
            UnlockMutex(menuMutex)
            ProcedureReturn #False
        EndIf
        ChangeCurrentElement(itemex(), minfo\dwItemData)
        
        oldstate = minfo\fState
        
        If state & #ItemEx_UseIcon
            itemex()\checkIcon = #True
        ElseIf Not state & #ItemEx_UseIcon
            itemex()\checkIcon = #False
        EndIf
        
        If state & #ItemEx_ShowCheckbox
            
            minfo.MENUITEMINFO_Fixed
            minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
            minfo\fMask = #MIIM_STATE
            minfo\fState = oldstate | #MFS_CHECKED
            
            popupid = menuex()\popupid
            *thisMenuEx = @menuex()
            *thisItemEx = @itemex()
            UnlockMutex(menuMutex)
            RET = SetMenuItemInfo_(popupid, itemID, 0, minfo)
            LockMutex(menuMutex)
            ChangeCurrentElement(menuex(), *thisMenuEx)
            ChangeCurrentElement(itemex(), *thisItemEx)
            If RET = 0
                UnlockMutex(menuMutex)
                ProcedureReturn #False
            EndIf
            
        ElseIf state & #ItemEx_ShowRadiocheck
            
            If itemex()\radiocheck = 0
                
                ; if this is a new radiocheck on new window then new group
                If radioGroupActive <> 0 And radioGroupActive <> menuex()\popupid
                    groupNo = groupNo + 1
                EndIf
                
                itemex()\radiocheck = #True
                itemex()\groupNo = groupNo
                minfo\fMask = #MIIM_STATE
                minfo\fState = oldstate | #MFS_CHECKED
                minfo\fType = #MFT_RADIOCHECK
                
                popupid = menuex()\popupid
                *thisMenuEx = @menuex()
                *thisItemEx = @itemex()
                UnlockMutex(menuMutex)
                SetMenuItemInfo_(popupid, itemID, 0, minfo)
                LockMutex(menuMutex)
                ChangeCurrentElement(menuex(), *thisMenuEx)
                ChangeCurrentElement(itemex(), *thisItemEx)
                
                radioGroupActive = menuex()\popupid
                
                ; remove bullet from any previous same group radiochecks created
                thisPos = itemex()\pos
                ForEach itemex()
                    If itemex()\groupNo = groupNo And itemex()\radiocheck = #True And itemex()\pos <> thisPos
                        minfo.MENUITEMINFO_Fixed
                        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                        minfo\fMask = #MIIM_STATE
                        GetMenuItemInfo_(itemex()\popupid, itemex()\pos, #True, @minfo)
                        oldstate = minfo\fState
                        
                        minfo\fMask = #MIIM_STATE
                        minfo\fState = oldstate & ~#MFS_CHECKED
                        
                        popupid = itemex()\popupid
                        pos = itemex()\pos
                        *thisMenuEx = @menuex()
                        *thisItemEx = @itemex()
                        UnlockMutex(menuMutex)
                        SetMenuItemInfo_(popupid, pos, #True, minfo)
                        LockMutex(menuMutex)
                        ChangeCurrentElement(menuex(), *thisMenuEx)
                        ChangeCurrentElement(itemex(), *thisItemEx)
                    EndIf
                Next
                
            Else  ; item already a radiocheck, make it the current selection and deselect all others in group
                
                thisGroup = itemex()\groupNo
                thisPos = itemex()\pos
                
                minfo\fMask = #MIIM_STATE
                minfo\fState = oldstate | #MFS_CHECKED
                minfo\fType = #MFT_RADIOCHECK
                
                popupid = menuex()\popupid
                *thisMenuEx = @menuex()
                *thisItemEx = @itemex()
                UnlockMutex(menuMutex)
                SetMenuItemInfo_(popupid, itemID, 0, minfo)
                LockMutex(menuMutex)
                ChangeCurrentElement(menuex(), *thisMenuEx)
                ChangeCurrentElement(itemex(), *thisItemEx)
                
                ForEach itemex()
                    If itemex()\groupNo = thisGroup And itemex()\radiocheck = #True And itemex()\pos <> thisPos
                        minfo.MENUITEMINFO_Fixed
                        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                        minfo\fMask = #MIIM_STATE
                        GetMenuItemInfo_(itemex()\popupid, itemex()\pos, #True, @minfo)
                        oldstate = minfo\fState
                        
                        minfo\fMask = #MIIM_STATE
                        minfo\fState = oldstate & ~#MFS_CHECKED
                        
                        popupid = itemex()\popupid
                        pos = itemex()\pos
                        *thisMenuEx = @menuex()
                        *thisItemEx = @itemex()
                        UnlockMutex(menuMutex)
                        SetMenuItemInfo_(popupid, pos, #True, minfo)
                        LockMutex(menuMutex)
                        ChangeCurrentElement(menuex(), *thisMenuEx)
                        ChangeCurrentElement(itemex(), *thisItemEx)
                    EndIf
                Next
            EndIf
            
        ElseIf state = 0
            
            minfo.MENUITEMINFO_Fixed
            minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
            minfo\fMask = #MIIM_STATE
            oldstate = oldstate & ~#MFS_CHECKED
            minfo\fState = oldstate|#MFS_UNCHECKED
            
            popupid = menuex()\popupid
            *thisMenuEx = @menuex()
            *thisItemEx = @itemex()
            UnlockMutex(menuMutex)
            RET = SetMenuItemInfo_(popupid, itemID, 0, minfo)
            LockMutex(menuMutex)
            ChangeCurrentElement(menuex(), *thisMenuEx)
            ChangeCurrentElement(itemex(), *thisItemEx)
            If RET = 0
                UnlockMutex(menuMutex)
                ProcedureReturn #False
            EndIf
            
        EndIf
        
        If state & #ItemEx_EndRadiocheckGroup
            groupNo = groupNo + 1
            radioGroupActive = 0
        EndIf
        
        menuex()\bufferWidth = 0
        menuex()\bufferHeight = 0
        
        UnlockMutex(menuMutex)
        ProcedureReturn #True
    EndIf
    
    If state & #ItemEx_EndRadiocheckGroup
        groupNo = groupNo + 1
        radioGroupActive = 0
        UnlockMutex(menuMutex)
        ProcedureReturn #True
    EndIf
    
    UnlockMutex(menuMutex)
    ProcedureReturn #False
    
EndProcedure

ProcedureDLL GetMenuExItemState(menu.i, itemID.l) ; Gets a menu item checkbox/radiocheck state
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    ;check that menu exists, search by id or handle
    found = 0
    ForEach menuex()
        If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
            
            For n = 0 To count
                minfo.MENUITEMINFO_Fixed
                minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                minfo\fMask = #MIIM_ID
                If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) <> 0
                    found = #True
                    Break 2
                EndIf
            Next
            
        EndIf
    Next
    
    If found = #True
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_STATE
        If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) = 0
            UnlockMutex(menuMutex)
            ProcedureReturn -1
        EndIf
        If minfo\fState & #MFS_CHECKED
            UnlockMutex(menuMutex)
            ProcedureReturn #True
        ElseIf Not minfo\fState & #MFS_CHECKED
            UnlockMutex(menuMutex)
            ProcedureReturn #False
        EndIf
    EndIf
    
    UnlockMutex(menuMutex)
    ProcedureReturn -1
EndProcedure

ProcedureDLL CalcMenuItemWidth(menu.i) ; Calculates the width of a popup menu
    
    GetMenuItemRect_(0, menu, n, @reccy.RECT)
    If reccy\right-reccy\left <> 0
        ProcedureReturn reccy\right-reccy\left+6
    EndIf
    
    menuWidth.l = 0
    items = GetMenuItemCount_(menu)
    
    x = 0
    If items <> -1
        rec.RECT
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_FTYPE|#MIIM_DATA|#MIIM_STRING|#MIIM_SUBMENU
        
        For n = 0 To items-1
            
            width = 0
            minfo\cch = 0
            minfo\dwTypeData = 0
            
            text.s = ""
            GetMenuItemInfo_(menu, n, #True, @minfo)
            
            ; if the menu item is our custom menu item
            If minfo\fType & #MFT_OWNERDRAW
                
                width = measureMenuWidth(minfo\dwItemData)
                
                p = GetSystemMetrics_(#SM_CXMENUSIZE)
                
                If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003
                    p = p - 2
                ElseIf menuex()\style = #UISTYLE_OFFICE2007
                    p = p + 1
                EndIf
                width = width + p
                
                If minfo\hSubMenu <> 0
                    ;width = width + GetSystemMetrics_(#SM_CXMENUSIZE)+2
                EndIf
                
            Else
                
                If minfo\cch > 0
                    CompilerIf #PB_Compiler_Unicode
                        *mem = AllocateMemory(minfo\cch*2+2)
                    Else
                        *mem = AllocateMemory(minfo\cch+2)
                    CompilerEndIf
                    
                    minfo\dwTypeData = @*mem
                    minfo\cch = minfo\cch+1
                    GetMenuItemInfo_(menu, n, #True, @minfo)
                    text = PeekS(minfo\dwTypeData)
                    FreeMemory(*mem)
                    
                    width = (GetSystemMetrics_(#SM_CXMENUCHECK)*2.5)+12
                    
                    hdc = CreateCompatibleDC_(0)
                    
                    oldFont = SelectObject_(hdc, currentMenuEXFont)
                    
                    DrawText_(hdc, text, Len(text), @rec, #DT_SINGLELINE | #DT_CALCRECT)
                    
                    SelectObject_(hdc, oldFont)
                    
                    DeleteDC_(hdc)
                    
                    width = width + rec\right
                    
                EndIf
                
            EndIf
            
            If width > menuWidth
                menuWidth = width
            EndIf
            
        Next
    EndIf
    
    
    ProcedureReturn menuWidth
EndProcedure

ProcedureDLL GetMenuExBarHeight(menu.i)
    
    macro_protectCommand()
    
    LockMutex(menuMutex)
    
    ForEach menuex()
        If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
            
            GetClientRect_(menuex()\toolbarID, rc.RECT)
            height = rc\bottom-rc\top
            
            UnlockMutex(menuMutex)
            ProcedureReturn height
            
        EndIf
    Next
    
    UnlockMutex(menuMutex)
    ProcedureReturn 0
EndProcedure

Procedure CalcMenuItemHeight(menu.i)
    
    menuHeight.l = 0
    items = GetMenuItemCount_(menu)
    
    If items <> -1
        rec.RECT
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_FTYPE|#MIIM_DATA|#MIIM_STRING|#MIIM_SUBMENU
        
        hdc = CreateCompatibleDC_(0)
        
        oldFont = SelectObject_(hdc, currentMenuEXFont)
        
        For n = 0 To items-1
            
            minfo\cch = 0
            minfo\dwTypeData = 0
            
            text.s = ""
            GetMenuItemInfo_(menu, n, #True, @minfo)
            
            ; if the menu item is our custom menu item
            If minfo\fType & #MFT_OWNERDRAW
                
                menuHeight = menuHeight + measureMenuItemHeight(hdc, minfo\dwItemData)
                
            EndIf
            
        Next
        
        SelectObject_(hdc, oldFont)
        DeleteDC_(hdc)
        
    EndIf
    
    ; get associated menuex
    LockMutex(menuMutex)
    thisMenuEx = @menuex()
    ForEach menuex()
        If menuex()\popupid = menu
            Break
        EndIf
    Next
    
    If menuex()\style < 5
        menuHeight = menuHeight + 6
    ElseIf menuex()\style = 5
        menuHeight = menuHeight + 5
    Else
        menuHeight = menuHeight + 3
    EndIf
    ChangeCurrentElement(menuex(), thisMenuEx)
    UnlockMutex(menuMutex)
    
    ProcedureReturn menuHeight;(menuHeight+3)
EndProcedure


ProcedureDLL FreeMenuEx(menu.i) ; frees an extended menu from memory
    
    LockMutex(menuMutex)
    
    ;search for menu by id or handle
    ForEach menuex()
        If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu Or menu = -1
            
            If menuex()\toolbarID <> -1
                FreeToolBarEx(menuex()\toolbarID)
            EndIf
            
            Repeat
            Until RemoveMenuItemEx(menuex()\popupid, 0, #True) = 0
            
            If IsMenu(menuex()\purepopupid)
                FreeMenu(menuex()\purepopupid)
            EndIf
            
            ; free any menuitemex resources belonging to menu
            ForEach itemex()
                If itemex()\popupid = menuex()\popupid
                    If itemex()\ImageList <> 0
                        ImageList_Destroy_(itemex()\ImageList)
                    EndIf
                    DeleteElement(itemex())
                EndIf
            Next
            
            ; free menu window buffer if exists
            If menuex()\hdc <> 0
                DeleteObject_(menuex()\Buffer)
                DeleteDC_(menuex()\hdc)
            EndIf
            
            DeleteElement(menuex())
            
            If menu <> -1
                UnlockMutex(menuMutex)
                ProcedureReturn #True
            EndIf
            
        EndIf
    Next
    
    If menu = -1
        UnlockMutex(menuMutex)
        ProcedureReturn #True
    EndIf
    
    UnlockMutex(menuMutex)
    ProcedureReturn #False
    
EndProcedure


;--
;- ToolBarEx
;--
Procedure toolBarExCallback(Window, message, wParam, lParam)
    
    ; get associated panelex page structure pointer from hwnd
    *panelexpage.panelexpages = GetProp_(Window, panelexpageAtom)
    If *panelexpage = #Null
        ; get associated panel structure pointer from hwnd
        *panelex.panelexs = GetProp_(Window, panelexAtom)
        If *panelex = #Null
            ProcedureReturn #False
        Else
            *panelexpage.panelexpages = *panelex\displayedPage
        EndIf
    Else
        *panelex.panelexs = *panelexpage\panelex
    EndIf
    If *panelexpage = #Null Or *panelex = #Null
        ProcedureReturn #False
    EndIf
    
    ; get associated toolbarex structure from child hwnd
    toolbar = GetWindow_(*panelexpage\Handle, #GW_CHILD)
    If toolbar = #Null
        ProcedureReturn #False
    EndIf
    
    ForEach toolbarex()
        If toolbarex()\Handle = toolbar
            found = #True
            Break
        EndIf
    Next
    If found = #False
        ProcedureReturn #False
    EndIf
    
    Select message
        
        Case #WM_SIZE
            
            width = LOWORD(lParam)
            height = HIWORD(lParam)
            
            Debug "resize"
            
    EndSelect
    
    ProcedureReturn Result
    
EndProcedure

ProcedureDLL CreateToolBarEx(id.l, WindowID.i, iconWidth.l, iconHeight.l, style.l) ; Creates an extended toolbar
    
    macro_protectCommand()
    
    If id <> #ProGUI_Any
        ; check that same id doesnt already exist
        ForEach toolbarEx()
            If toolbarEx()\id = id
                ProcedureReturn 0
            EndIf
        Next
    EndIf
    
    panelex = PanelExID(CreatePanelEx(#ProGUI_Any, WindowID, 0, 0, 100, 100, @toolBarExCallback()), -1)
    If panelex = #Null
        ProcedureReturn #False
    EndIf
    AddPanelExPage(panelex, 0)
    WindowID = PanelExID(panelex, 0)
    
    If id = #ProGUI_Any
        id = CreateToolBar(#PB_Any, PanelExID(panelex, 0))
        hTbGad = PeekI(IsToolBar(id)) ; get api handle to toolbar, sly ;)
        ProGUI_Any = #True
    Else
        hTbGad = CreateToolBar(id, PanelExID(panelex, 0))
    EndIf
    
    If hTbGad <> 0
        ;font = LoadFontex("Verdana", 20, 0)
        ;SendMessage_(hTbGad, #WM_SETFONT, font, #True)
        LastElement(toolbarEx())
        AddElement(toolbarEx())
        
        currentToolbarEX = id
        toolbarEx()\id = id
        toolbarEx()\Handle = hTbGad
        toolbarEx()\WindowID = WindowID
        toolbarEx()\lastRowCount = 1
        toolbarEx()\panelex = panelex
        
        ; make toolbar use tooltips
        style = style|#TBSTYLE_TOOLTIPS
        
        rStyle = SendMessage_(hTbGad, #TB_GETSTYLE, 0, 0)
        rStyle = rStyle | style | #TBSTYLE_CUSTOMERASE
        
        exstyle = #TBSTYLE_EX_DRAWDDARROWS
        
        If style & #TBSTYLE_HIDECLIPPEDBUTTONS
            exstyle = exstyle | #TBSTYLE_EX_HIDECLIPPEDBUTTONS
        EndIf
        
        SendMessage_(hTbGad, #TB_SETEXTENDEDSTYLE, 0, exstyle)
        
        SendMessage_(hTbGad, #TB_SETSTYLE, 0, rStyle)
        
        toolbarEx()\style = style
        
        ; check for new UI style flags
        If style & #UISTYLE_OFFICE2003
            toolbarEx()\UIStyle = #UISTYLE_OFFICE2003
        ElseIf style & #UISTYLE_OFFICE2007
            toolbarEx()\UIStyle = #UISTYLE_OFFICE2007
        EndIf
        
        ; check for image style
        If style & #UISTYLE_IMAGE
            toolbarEx()\UIStyle = #UISTYLE_IMAGE
        EndIf
        
        If iconWidth = 0 And iconHeight = 0
            toolbarEx()\normalImageList = -1
            toolbarEx()\hotImageList = -1
            toolbarEx()\disabledImageList = -1
        Else
            ImageList_Destroy_(SendMessage_(hTbGad, #TB_GETIMAGELIST, 0, 0))
            ImageList_Destroy_(SendMessage_(hTbGad, #TB_GETHOTIMAGELIST, 0, 0))
            ImageList_Destroy_(SendMessage_(hTbGad, #TB_GETDISABLEDIMAGELIST, 0, 0))
            
            hToolBarIcons = ImageList_Create_(iconWidth, iconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
            SendMessage_(hTbGad, #TB_SETIMAGELIST, $0, hToolBarIcons)
            toolbarEx()\normalImageList = hToolBarIcons
            
            hToolBarIcons = ImageList_Create_(iconWidth, iconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
            SendMessage_(hTbGad, #TB_SETHOTIMAGELIST, $0, hToolBarIcons)
            toolbarEx()\hotImageList = hToolBarIcons
            
            hToolBarIcons = ImageList_Create_(iconWidth, iconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
            SendMessage_(hTbGad, #TB_SETDISABLEDIMAGELIST, $0, hToolBarIcons)
            toolbarEx()\disabledImageList = hToolBarIcons
        EndIf
        
        ; check if a menu callback has been created for this windowid
        found = 0
        ForEach menuCallback()
            If menuCallback()\WindowID = WindowID
                found = -1
                Break
            EndIf
        Next
        
        ; if menu call back hasnt been created then create one
        If found = 0
            ProGUIOldCallBack = SetWindowLongPtr_(WindowID, #GWLP_WNDPROC, @MyWindowCallback())
            LastElement(menuCallback())
            AddElement(menuCallback())
            menuCallback()\WindowID = WindowID
            menuCallback()\callback = @MyWindowCallback()
            menuCallback()\oldCallback = ProGUIOldCallBack
            SetWindowLongPtr_(WindowID, #GWL_STYLE, GetWindowLongPtr_(WindowID, #GWL_STYLE)|#WS_CLIPCHILDREN)
        EndIf
        
        ; create hook to intercept creation of new windows for popup menus
        If WindowHook = 0
            threadId = GetWindowThreadProcessId_(WindowID, 0)
            WindowHook = SetWindowsHookEx_(#WH_CALLWNDPROC, @CallWndProcHook(), 0, threadId)
        EndIf
        
        ; create hook to handle keyboard navigation
        If KeyboardHook = 0
            threadId = GetWindowThreadProcessId_(WindowID, 0)
            KeyboardHook = SetWindowsHookEx_(#WH_KEYBOARD, @KeyboardHook(), 0, threadId)
        EndIf
        
        ; check if currentMenuEXFont has been set
        If currentMenuEXFont = 0
            metrics.NONCLIENTMETRICS
            metrics\cbSize = SizeOf(NONCLIENTMETRICS)
            
            SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
            currentMenuEXFont = CreateFontIndirect_(metrics\lfMenuFont)
        EndIf
        
        If ProGUI_Any = #False
            ProcedureReturn panelex
        Else
            ProcedureReturn id
        EndIf
        
    EndIf
    
    ProcedureReturn 0
    
EndProcedure

ProcedureDLL SetToolBarExStyle(toolbar.i, style.l)  ; Sets the rendering style of an extended toolbar
    
    macro_protectCommand()
    
    ; find toolbar handle
    ForEach toolbarEx()
        If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
            
            toolbarEx()\UIStyle = style
            
            updateDefaultDisabledImages(toolbarEx()\id, 4)
            
            RedrawWindow_(GetAncestor_(toolbarEx()\Handle, #GA_ROOT), 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
            
            ProcedureReturn #True
        EndIf
    Next
    
    ProcedureReturn 0
EndProcedure

ProcedureDLL FreeToolBarEx(toolbar.i) ; Frees an extended toolbar from memory
    
    ;search for toolbar by id or handle
    ForEach toolbarEx()
        If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar Or toolbar = -1
            
            ;remove buttons associated with toolbar
            ForEach toolbarExButton()
                If toolbarExButton()\toolbarID = toolbarEx()\id
                    ;remove tooltip if exists
                    ForEach toolbartip()
                        If toolbartip()\id = toolbarExButton()\id
                            DeleteElement(toolbartip())
                            Break
                        EndIf
                    Next
                    
                    ; if button contains a gadget then hide and re-parent gadget window to root window
                    If toolbarExButton()\gadget <> 0
                        
                        ShowWindow_(toolbarExButton()\gadget, #SW_HIDE)
                        SetParent_(toolbarExButton()\gadget, GetAncestor_(toolbarExButton()\gadget, #GA_ROOT))
                        
                    EndIf
                    
                    DeleteElement(toolbarExButton())
                EndIf
            Next
            
            ; free image lists
            If toolbarEx()\normalImageList <> -1
                ImageList_Destroy_(toolbarEx()\normalImageList)
            EndIf
            
            If toolbarEx()\hotImageList <> -1
                ImageList_Destroy_(toolbarEx()\hotImageList)
            EndIf
            
            If toolbarEx()\disabledImageList <> -1
                ImageList_Destroy_(toolbarEx()\disabledImageList)
            EndIf
            
            If IsToolBar(toolbarEx()\id)
                FreeToolBar(toolbarEx()\id)
            EndIf
            
            DeleteElement(toolbarEx())
            
            If toolbar <> -1
                ProcedureReturn #True
            EndIf
        EndIf
    Next
    
    If toolbar = -1
        ProcedureReturn #True
    EndIf
    ProcedureReturn 0
    
EndProcedure

Procedure ImageListInsertIcon(himl.i, hicon.i, pos)
    
    If hicon <> 0
        error = ImageList_ReplaceIcon_(himl, -1, hicon)
        If error = -1
            ProcedureReturn 0
        EndIf
    EndIf
    
    count = ImageList_GetImageCount_(himl)
    
    For n = count-1 To pos+1 Step -1
        ;lerror = ImageList_Copy_(himl, n-1, himl, n, 1) ; ILCF_SWAP
        ;If error = 0
        ;  ProcedureReturn 0
        ;EndIf
        icon1 = ImageList_GetIcon_(himl, n, #ILD_TRANSPARENT)
        icon2 = ImageList_GetIcon_(himl, n-1, #ILD_TRANSPARENT)
        ImageList_ReplaceIcon_(himl, n, icon2)
        ImageList_ReplaceIcon_(himl, n-1, icon1)
        DestroyIcon_(icon1)
        DestroyIcon_(icon2)
    Next
    
    ProcedureReturn #True
    
EndProcedure

; updates positions/dimensions of button gadgets in current toolbarEx()
Procedure updateToolBarExButtonGadgets()
    
    ForEach toolbarExButton()
        If toolbarExButton()\toolbarExHandle = toolbarEx()\handle And toolbarExButton()\gadget <> 0
            
            pos = SendMessage_(toolbarEx()\handle, #TB_COMMANDTOINDEX, toolbarExButton()\id, 0)
            SendMessage_(toolbarEx()\Handle, #TB_GETITEMRECT, pos, @rc.RECT)
            
            height = (rc\bottom-rc\top)-toolbarExButton()\gadgetPad\bottom
            SetWindowPos_(toolbarExButton()\gadget, 0, rc\left+toolbarExButton()\gadgetPad\left, rc\top+toolbarExButton()\gadgetPad\top, (rc\right-rc\left)-(toolbarExButton()\gadgetPad\left+toolbarExButton()\gadgetPad\right), height, #SWP_NOACTIVATE|#SWP_NOOWNERZORDER|#SWP_NOZORDER)
            
            class.s = Space(255)
            GetClassName_(toolbarExButton()\gadget, @class, 255)
            ; gadget is ComboBox, need to send custom height change
            If class = "ComboBox"
                height = height - 6
                SendMessage_(toolbarExButton()\gadget, #CB_SETITEMHEIGHT, -1, height)
            EndIf
            
        EndIf
    Next
    
    idealsize = $0463 ; #TB_GETIDEALSIZE
    SendMessage_(toolbarEx()\handle, idealsize, #False, size.SIZE)
    GetClientRect_(GetParent_(toolbarEx()\panelex), prc.RECT)
    size\cx = prc\right
    cx = size\cx
    SendMessage_(toolbarEx()\handle, idealsize, #True, size.SIZE)
    cy = size\cy
    SetWindowPos_(toolbarEx()\panelex, 0, 0, 0, cx, cy, #SWP_NOREPOSITION|#SWP_NOREDRAW)
    
EndProcedure

ProcedureDLL ToolBarImageButtonEx(buttonID.l, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, style.l) ; Creates an image toolbar button
    
    macro_protectCommand()
    
    ftext.s = text
    
    ; check if separator bar flag has been passed
    If style & #BTNS_SEP
        ProcedureReturn ToolBarSeparatorEx()
    EndIf
    
    ; exit if toolbar hasnt been created
    If currentToolbarEX = -1
        ProcedureReturn 0
    EndIf
    
    If buttonID = #ProGUI_Any
        
        Repeat
            ; generate unique toolbar button id so as not to conflict with user toolbars
            buttonID = generateUniqueCommandID_wordUnsigned()
            ; check that same id doesnt already exist
            found = 0
            ForEach toolbarExButton()
                If toolbarExButton()\id = buttonID
                    found = -1
                    Break
                EndIf
            Next
        Until found = 0
        
    Else
        ; make sure toolbar button id doesnt exist
        ForEach toolbarExButton()
            If toolbarExButton()\id = buttonID And toolbarExButton()\toolbarID = currentToolbarEX
                ProcedureReturn 0
            EndIf
        Next
    EndIf
    
    ; find current toolbar id
    ForEach toolbarEx()
        If toolbarEx()\id = currentToolbarEX
            
            If normalImageID = 0
                normalImageID = nullicon
            EndIf
            If hotImageID = 0
                If normalImageID <> nullicon
                    hotImageID = normalImageID
                Else
                    hotImageID = nullicon
                EndIf
            EndIf
            If disabledImageID = 0
                If normalImageID <> nullicon
                    disabledImageID = defaultDisabledImage(normalImageID, toolbarEx()\UIStyle)
                    defaultDisabled = #True
                Else
                    disabledImageID = nullicon
                EndIf
            EndIf
            
            error.l = ImageList_ReplaceIcon_(toolbarEx()\normalImageList, -1, normalImageID)
            If error = -1
                error = ImageList_ReplaceIcon_(toolbarEx()\normalImageList, -1, hBitmap_to_hIcon(normalImageID))
            EndIf
            error.l = ImageList_ReplaceIcon_(toolbarEx()\hotImageList, -1, hotImageID)
            If error = -1
                error = ImageList_ReplaceIcon_(toolbarEx()\hotImageList, -1, hBitmap_to_hIcon(hotImageID))
            EndIf
            error.l = ImageList_ReplaceIcon_(toolbarEx()\disabledImageList, -1, disabledImageID)
            If error = -1
                error = ImageList_ReplaceIcon_(toolbarEx()\disabledImageList, -1, hBitmap_to_hIcon(disabledImageID))
            EndIf
            If defaultDisabled = #True
                DestroyIcon_(disabledImageID)
            EndIf
            
            btncount.l = SendMessage_(toolbarEx()\Handle, #TB_BUTTONCOUNT, 0, 0)
            
            btn.TBBUTTON
            If text <> ""
                
                If FindString(text, "\", 1) > 0
                    rc.RECT
                    hdc = CreateCompatibleDC_(0)
                    text = renderText(hdc, text, @rc, 0, #DT_CALCRECT|#RTXT_RETURNSTRING)
                    DeleteDC_(hdc)
                EndIf
                
                *p = AllocateMemory(StringByteLength(text)+2)
                PokeS(*p, text)
                idString = SendMessage_(toolbarEx()\Handle, #TB_ADDSTRING, 0, *p)
                FreeMemory(*p)
                btn\iString = idString
            Else
                btn\iString = -1
            EndIf
            btn\idCommand = buttonID
            If normalImageID = nullicon
                btn\iBitmap = #I_IMAGENONE
            Else
                btn\iBitmap = btncount
            EndIf
            btn\fsState = #TBSTATE_ENABLED
            ;If Style = 0
            ;  btn\fsStyle = toolbarEx()\Style
            ;Else
            btn\fsStyle = style
            ;EndIf
            
            LastElement(toolbarExButton())
            AddElement(toolbarExButton())
            btn\dwData = @toolbarExButton()
            toolbarExButton()\id = buttonID
            toolbarExButton()\toolbarID = currentToolbarEX
            toolbarExButton()\toolbarExHandle = toolbarex()\Handle
            toolbarExButton()\toolbarEx = @toolbarEx()
            toolbarExButton()\normalImage = normalImageID
            toolbarExButton()\hotImage = hotImageID
            toolbarExButton()\disabledImage = disabledImageID
            toolbarExButton()\defDisabledImage = defaultDisabled
            toolbarExButton()\defDisabledStyle = toolbarEx()\UIStyle
            toolbarExButton()\text = ftext
            
            ; normal mode
            If ToolbarExInsert = #False
                suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
                ; insert mode, i.e called from InsertToolBarImageButtonEx etc...
            Else
                If ToolbarExInsertPos >= btncount+1
                    ToolbarExInsertPos = -1
                ElseIf ToolbarExInsertPos < -1
                    ToolbarExInsertPos = 0
                EndIf
                If ToolbarExInsertPos = -1
                    suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
                Else
                    
                    ImageListInsertIcon(toolbarEx()\normalImageList, 0, ToolbarExInsertPos)
                    ImageListInsertIcon(toolbarEx()\hotImageList, 0, ToolbarExInsertPos)
                    ImageListInsertIcon(toolbarEx()\disabledImageList, 0, ToolbarExInsertPos)
                    
                    suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, ToolbarExInsertPos, @btn)
                EndIf
            EndIf
            
            SendMessage_(toolbarEx()\Handle, #TB_AUTOSIZE, 0, 0)
            
            ; if #UISTYLE_OFFICE2003/#UISTYLE_OFFICE2007 style then increase height of toolbar by 3 pixels
            If (toolbarEx()\UIStyle = #UISTYLE_OFFICE2003 Or toolbarEx()\UIStyle = #UISTYLE_OFFICE2007) And toolbarEx()\height = 0
                Size = SendMessage_(toolbarEx()\Handle, #TB_GETBUTTONSIZE, 0, 0)
                width = (Size&$FFFF)
                height = (Size>> 16 & $FFFF)+3
                SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONSIZE, 0, MakeLong(width, height))
                toolbarEx()\height = height
            EndIf
            
            If toolbarEx()\UIStyle = #UISTYLE_IMAGE
                ImageList_GetImageInfo_(toolbarEx()\normalImageList, 0, @imf.IMAGEINFO)
                height = imf\rcImage\bottom-imf\rcImage\top
                width = imf\rcImage\right-imf\rcImage\left
                SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONSIZE, 0, MakeLong(width, height))
                SendMessage_(toolbarEx()\Handle, #TB_SETPADDING, 0, MakeLong(0, 0))
                toolbarEx()\height = height
            EndIf
            
            
            ; resize and position any buttons that contain a gadget in this toolbarEx
            updateToolBarExButtonGadgets()
            
            
            ProcedureReturn buttonID
        EndIf
    Next
    
    ProcedureReturn 0
    
EndProcedure

ProcedureDLL ToolBarButtonEx(buttonID.l, text.s, style.l) ; Creates a normal text toolbar button
    
    macro_protectCommand()
    
    ; check if separator bar flag has been passed
    If style & #BTNS_SEP
        ProcedureReturn ToolBarSeparatorEx()
    EndIf
    
    ; exit if toolbar hasnt been created
    If currentToolbarEX = -1
        ProcedureReturn 0
    EndIf
    
    ProcedureReturn ToolBarImageButtonEx(buttonID, text, 0, 0, 0, style)
    
EndProcedure


ProcedureDLL ToolBarSeparatorEx() ; Creates a ToolbarEx separator
    
    macro_protectCommand()
    
    ; exit if toolbar hasnt been created
    If currentToolbarEX = -1
        ProcedureReturn 0
    EndIf
    
    Repeat
        ; generate unique toolbar id so as not to conflict with user toolbars
        buttonID = generateUniqueCommandID_wordUnsigned()
        ; check that same id doesnt already exist
        found = 0
        ForEach toolbarExButton()
            If toolbarExButton()\id = buttonID
                found = -1
                Break
            EndIf
        Next
    Until found = 0
    
    ; find current toolbar id
    ForEach toolbarEx()
        If toolbarEx()\id = currentToolbarEX
            
            ImageList_ReplaceIcon_(toolbarEx()\normalImageList, -1, nullicon)
            ImageList_ReplaceIcon_(toolbarEx()\hotImageList, -1, nullicon)
            ImageList_ReplaceIcon_(toolbarEx()\disabledImageList, -1, nullicon)
            
            btncount = SendMessage_(toolbarEx()\Handle, #TB_BUTTONCOUNT, 0, 0)
            
            btn.TBBUTTON
            btn\iString = -1
            btn\idCommand = buttonID
            btn\iBitmap = #I_IMAGENONE
            btn\fsState = 0;#TBSTATE_ENABLED
            btn\fsStyle = 0
            
            LastElement(toolbarExButton())
            AddElement(toolbarExButton())
            btn\dwData = @toolbarExButton()
            toolbarExButton()\id = buttonID
            toolbarExButton()\toolbarID = currentToolbarEX
            toolbarExButton()\toolbarExHandle = toolbarex()\Handle
            toolbarExButton()\toolbarEx = @toolbarEx()
            toolbarExButton()\normalImage = -1
            toolbarExButton()\hotImage = -1
            toolbarExButton()\disabledImage = -1
            toolbarExButton()\separator = #True
            
            ; normal mode
            If ToolbarExInsert = #False
                suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
                ; insert mode, i.e called from InsertToolBarImageButtonEx etc...
            Else
                If ToolbarExInsertPos >= btncount+1
                    ToolbarExInsertPos = -1
                ElseIf ToolbarExInsertPos < -1
                    ToolbarExInsertPos = 0
                EndIf
                If ToolbarExInsertPos = -1
                    suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
                Else
                    
                    ImageListInsertIcon(toolbarEx()\normalImageList, 0, ToolbarExInsertPos)
                    ImageListInsertIcon(toolbarEx()\hotImageList, 0, ToolbarExInsertPos)
                    ImageListInsertIcon(toolbarEx()\disabledImageList, 0, ToolbarExInsertPos)
                    
                    suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, ToolbarExInsertPos, @btn)
                EndIf
            EndIf
            
            tbnfo.TBBUTTONINFO
            tbnfo\cbSize = SizeOf(TBBUTTONINFO)
            tbnfo\dwMask = #TBIF_SIZE
            tbnfo\cx = 6
            SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONINFO, buttonID, @tbnfo)
            
            
            ; resize and position any buttons that contain a gadget in this toolbarEx
            updateToolBarExButtonGadgets()
            
            
            ProcedureReturn buttonID
        EndIf
    Next
    
    ProcedureReturn 0
    
EndProcedure


ProcedureDLL ToolBarDropdownImageButtonEx(buttonID.l, MenuID.i, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, style.l) ; Creates a dropdown type toolbar button
    
    macro_protectCommand()
    
    ; try and find matching menu
    dropdownMenuex = -1
    ForEach menuex()
        If menuex()\popupid = MenuID Or menuex()\id = MenuID
            menuStyle = menuex()\style
            MenuID = menuex()\popupid
            dropdownMenuex = @menuex()
            If menuex()\toolbarID = currentToolbarEX And menuex()\buttonID = buttonID
                ProcedureReturn 0
            EndIf
            Break
        EndIf
    Next
    
    ; if there isn't a dropdown style flag then add default
    If Not style & #BTNS_WHOLEDROPDOWN And Not style & #BTNS_DROPDOWN
        style = style | #BTNS_DROPDOWN
    EndIf
    
    buttonID = ToolBarImageButtonEx(buttonID, text, normalImageID, hotImageID, disabledImageID, style)
    If buttonID = 0
        ProcedureReturn 0
    EndIf
    
    
    ; get handle to current toolbar
    ForEach toolbarEx()
        If toolbarEx()\id = currentToolbarEX
            toolbarHandle = toolbarEx()\Handle
            WindowID = toolbarEx()\WindowID
            Break
        EndIf
    Next
    
    ; create new menu entry
    LastElement(menuex())
    AddElement(menuex())
    
    ; generate unique menu id
    *ID.IDHwndLookup = generateUniqueID(#ProGUI_Any)
    
    menuex()\id = *ID\ID
    menuex()\toolbarID = toolbarHandle
    menuex()\popupid = MenuID
    menuex()\buttonID = buttonID
    menuex()\singleMenu = -1
    menuex()\style = menuStyle
    menuex()\dropdownMenuex = dropdownMenuex
    
    ; check if a menu callback has been created for this windowid
    found = 0
    ForEach menuCallback()
        If menuCallback()\WindowID = WindowID
            found = -1
            Break
        EndIf
    Next
    
    ; if menu call back hasnt been created then create one
    If found = 0
        ProGUIOldCallBack = SetWindowLongPtr_(WindowID, #GWLP_WNDPROC, @MyWindowCallback())
        LastElement(menuCallback())
        AddElement(menuCallback())
        menuCallback()\WindowID = WindowID
        menuCallback()\callback = @MyWindowCallback()
        menuCallback()\oldCallback = ProGUIOldCallBack
        SetWindowLongPtr_(WindowID, #GWL_STYLE, GetWindowLongPtr_(WindowID, #GWL_STYLE)|#WS_CLIPCHILDREN)
    EndIf
    
    ProcedureReturn buttonID
    
EndProcedure

ProcedureDLL ToolBarExAttachDropdownMenu(toolbar.i, buttonID.l, menu.i)
    
    macro_protectCommand()
    
    ; find toolbar handle
    found = 0
    ForEach toolbarEx()
        If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
            
            ; find button id
            ForEach toolbarExButton()
                If toolbarExButton()\id = buttonID
                    
                    ; find menu
                    ForEach menuex()
                        If menuex()\id = menu Or menuex()\popupid = menu
                            menu = menuex()\popupid
                            dropdownMenuex = @menuex()
                            Break
                        EndIf
                    Next
                    
                    found = -1
                    Break
                EndIf
            Next
            
            Break 
        EndIf
    Next
    
    If found = -1
        
        ; find existing menu attached to button
        ForEach menuex()
            If menuex()\singleMenu = -1 And menuex()\toolbarID = toolbarEx()\Handle And menuex()\buttonID = buttonID
                menuex()\popupid = menu
                menuex()\dropdownMenuex = dropdownMenuex
                ProcedureReturn #True
            EndIf
        Next
        
    EndIf
    
    ProcedureReturn 0
    
EndProcedure

ProcedureDLL ToolBarExGadget(buttonID.l, GadgetID.i, LeftPadding.l, TopPadding.l, RightPadding.l, BottomPadding.l, ApplyUIStyle.b) ; Adds a gadget/control to the current ToolBarEx
    
    macro_protectCommand()
    
    ; exit if toolbar hasnt been created
    If currentToolbarEX = -1
        ProcedureReturn 0
    EndIf
    
    ; exit if GadgetId not a valid hwnd 
    If IsWindow_(GadgetID) = #False
        ProcedureReturn 0
    EndIf
    
    GetWindowRect_(GadgetID, @rec.RECT)
    gWidth = rec\right - rec\left
    gHeight = rec\bottom - rec\top
    
    If buttonID = #ProGUI_Any
        
        Repeat
            ; generate unique toolbar id so as not to conflict with user toolbars
            buttonID = generateUniqueCommandID_wordUnsigned()
            ; check that same id doesnt already exist
            found = 0
            ForEach toolbarExButton()
                If toolbarExButton()\id = buttonID
                    found = -1
                    Break
                EndIf
            Next
        Until found = 0
        
    Else
        ; make sure toolbar button id doesnt exist
        ForEach toolbarExButton()
            If toolbarExButton()\id = buttonID And toolbarExButton()\toolbarID = currentToolbarEX
                ProcedureReturn 0
            EndIf
        Next
    EndIf
    
    ; find current toolbar id
    ForEach toolbarEx()
        If toolbarEx()\id = currentToolbarEX
            
            ImageList_ReplaceIcon_(toolbarEx()\normalImageList, -1, nullicon)
            ImageList_ReplaceIcon_(toolbarEx()\hotImageList, -1, nullicon)
            ImageList_ReplaceIcon_(toolbarEx()\disabledImageList, -1, nullicon)
            
            btncount = SendMessage_(toolbarEx()\Handle, #TB_BUTTONCOUNT, 0, 0)
            
            btn.TBBUTTON
            btn\iString = -1
            btn\idCommand = buttonID
            btn\iBitmap = #I_IMAGENONE
            
            LastElement(toolbarExButton())
            AddElement(toolbarExButton())
            btn\dwData = @toolbarExButton()
            toolbarExButton()\id = buttonID
            toolbarExButton()\toolbarID = currentToolbarEX
            toolbarExButton()\toolbarExHandle = toolbarex()\Handle
            toolbarExButton()\toolbarEx = @toolbarEx()
            toolbarExButton()\normalImage = -1
            toolbarExButton()\hotImage = -1
            toolbarExButton()\disabledImage = -1
            toolbarExButton()\gadget = GadgetID
            toolbarExButton()\gadgetStyled = ApplyUIStyle
            toolbarExButton()\gadgetPad\left = LeftPadding
            toolbarExButton()\gadgetPad\top = TopPadding
            toolbarExButton()\gadgetPad\right = RightPadding
            toolbarExButton()\gadgetPad\bottom = BottomPadding
            
            ; normal mode
            If ToolbarExInsert = #False
                suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
                ; insert mode, i.e called from InsertToolBarImageButtonEx etc...
            Else
                If ToolbarExInsertPos >= btncount+1
                    ToolbarExInsertPos = -1
                ElseIf ToolbarExInsertPos < -1
                    ToolbarExInsertPos = 0
                EndIf
                If ToolbarExInsertPos = -1
                    suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
                Else
                    
                    ImageListInsertIcon(toolbarEx()\normalImageList, 0, ToolbarExInsertPos)
                    ImageListInsertIcon(toolbarEx()\hotImageList, 0, ToolbarExInsertPos)
                    ImageListInsertIcon(toolbarEx()\disabledImageList, 0, ToolbarExInsertPos)
                    
                    suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, ToolbarExInsertPos, @btn)
                EndIf
            EndIf
            
            tbnfo.TBBUTTONINFO
            tbnfo\cbSize = SizeOf(TBBUTTONINFO)
            tbnfo\dwMask = #TBIF_SIZE
            tbnfo\cx = gWidth+LeftPadding+RightPadding
            SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONINFO, buttonID, @tbnfo)
            
            SendMessage_(toolbarEx()\Handle, #TB_GETITEMRECT, btncount, @rc.RECT)
            
            ShowWindow_(GadgetID, #SW_HIDE)
            
            class.s = Space(255)
            GetClassName_(GadgetID, @class, 255)
            
            height = (rc\bottom-rc\top)-BottomPadding
            
            SetParent_(GadgetID, toolbarEx()\Handle)
            
            SetWindowPos_(GadgetID, 0, rc\left+LeftPadding, rc\top+TopPadding, gWidth, height, #SWP_NOACTIVATE|#SWP_NOOWNERZORDER|#SWP_NOZORDER)
            
            ; gadget is ComboBox, need to send custom height change
            If class = "ComboBox"
                height = height - 6
                SendMessage_(GadgetID, #CB_SETITEMHEIGHT, -1, height)
            EndIf
            
            ShowWindow_(GadgetID, #SW_SHOW)
            
            
            ; resize and position any buttons that contain a gadget in this toolbarEx
            updateToolBarExButtonGadgets()
            
            
            ProcedureReturn buttonID
        EndIf
    Next
    
    ProcedureReturn 0
    
EndProcedure

ProcedureDLL InsertToolBarButtonEx(toolbar.i, position.l, buttonID.l, text.s, style.l) ; Inserts a toolbar button at position
    
    macro_protectCommand()
    
    ; find toolbar handle
    ForEach toolbarEx()
        If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
            
            ToolbarExInsert = #True
            ToolbarExInsertPos = position
            thisToolbar = currentToolbarEX
            currentToolbarEX = toolbarEx()\id
            success = ToolBarImageButtonEx(buttonID, text,0, 0, 0, style)
            ToolbarExInsert = #False
            currentToolbarEX = thisToolbar
            
            Break 
        EndIf
    Next
    
    ProcedureReturn success
    
EndProcedure

ProcedureDLL InsertToolBarImageButtonEx(toolbar.i, position.l, buttonID.l, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, style.l) ; Inserts a toolbar image button at position
    
    macro_protectCommand()
    
    ; find toolbar handle
    ForEach toolbarEx()
        If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
            
            ToolbarExInsert = #True
            ToolbarExInsertPos = position
            thisToolbar = currentToolbarEX
            currentToolbarEX = toolbarEx()\id
            success = ToolBarImageButtonEx(buttonID, text, normalImageID, hotImageID, disabledImageID, style)
            ToolbarExInsert = #False
            currentToolbarEX = thisToolbar
            
            Break 
        EndIf
    Next
    
    ProcedureReturn success
    
EndProcedure

