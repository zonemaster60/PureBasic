;- Prototype AlphaBlend, GradientFill commands from Gdi32.lib
Prototype GdiAlphaBlend_(ddc, dx, dy, dwidth, dheight, sdc, sx, sy, swidth, sheight, BlendMode)
Prototype GdiGradientFill_(hdc, pVertex, dwNumVertex, pMesh, dwNumMesh, dwMode)

ProcedureDLL MakeRGB(Red, Green, Blue)
    ProcedureReturn RGB(Red, Green, Blue)
EndProcedure

ProcedureDLL.l MakeColor(a.l,r.l,g.l,b.l) ; Creates a Windows API compatible 32bit color value with alpha channel.
    RetVal = b|g<<8|r<<16|a<<24
    ProcedureReturn RetVal
EndProcedure

ProcedureDLL.l MakeColour(a.l,r.l,g.l,b.l) ; Creates a Windows API compatible 32bit colour value with alpha channel.
    RetVal = b|g<<8|r<<16|a<<24
    ProcedureReturn RetVal
EndProcedure

ProcedureDLL.l AlphaBlendColour(lColor.l, RColor.l, Alpha.l) ; Returns 32bit colour value mixed with LColor + (RColour * Alpha)
    ProcedureReturn RGB ( ( ( Red ( RColor ) * Alpha + Red ( lColor ) * ( 256 - Alpha ) ) / 256 ) , ( ( Green ( RColor ) * Alpha + Green ( lColor ) * ( 256 - Alpha ) ) / 256 ) , ( ( Blue ( RColor ) * Alpha + Blue ( lColor ) * ( 256 - Alpha ) ) / 256 ) )
EndProcedure

ProcedureDLL.l AlphaBlendColor(lColor.l, RColor.l, Alpha.l) ; Returns 32bit color value mixed with LColor + (RColour * Alpha)
    ProcedureReturn RGB ( ( ( Red ( RColor ) * Alpha + Red ( lColor ) * ( 256 - Alpha ) ) / 256 ) , ( ( Green ( RColor ) * Alpha + Green ( lColor ) * ( 256 - Alpha ) ) / 256 ) , ( ( Blue ( RColor ) * Alpha + Blue ( lColor ) * ( 256 - Alpha ) ) / 256 ) )
EndProcedure

