                    tfcolour = AlphaBlendColour(tfcolour, RGB(255,255,255), 50)
                    SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected hot", "text", "font: "+fname+", "+Str(fheight)+", bold; colour: rgb("+Str(Red(tfcolour))+","+Str(Green(tfcolour))+","+Str(Blue(tfcolour))+")")
                EndIf
