    UIOffice2007Colours(#toolbarSeparatorShadow)\Grey = RGB(221,224,227)
    
    
    ; copy 2007 blue colours into olive theme slot
    For n = 0 To #MaxUIComponents
        UIOffice2007Colours(n)\Olive = UIOffice2007Colours(n)\Blue
    Next
    
    ; copy default colours into custom slots
    For n = 0 To #MaxUIComponents
        UIOffice2007Colours(n)\CustomSilver = UIOffice2007Colours(n)\Silver
        UIOffice2007Colours(n)\CustomBlue = UIOffice2007Colours(n)\Blue
        UIOffice2007Colours(n)\CustomOlive = UIOffice2007Colours(n)\Olive
        UIOffice2007Colours(n)\CustomGrey = UIOffice2007Colours(n)\Grey
    Next
    
EndProcedure

; procedure returns a colour brush based on a style and index determined by windows theme
Procedure getMenuColour(style, index)
    
    If UIColourMode = #UICOLOURMODE_DEFAULT Or UIColourMode = #UICOLOURMODE_CUSTOM
        
        If hTheme <> 0
            
            r = Red(XPthemeColour)
            g = Green(XPthemeColour)
            b = Blue(XPthemeColour)
            
            ;debuglog("colors: "+Str(r)+" "+Str(g)+" "+Str(b))
            
            ;Whidbey style colours
            If style = #UISTYLE_WHIDBEY
                ; 3 different colour highlight styles depending on theme colour
                ; colour is more silver/grey
                If r >= 200 And g >= 200 And b >= 200
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIWhidbeyColours(index)\Silver
                    Else
                        colour = UIWhidbeyColours(index)\CustomSilver
                    EndIf
                    
                    ; colour is more blue
                ElseIf r < 200 And g < 200 And b >= 200
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIWhidbeyColours(index)\Blue
                    Else
                        colour = UIWhidbeyColours(index)\CustomBlue
                    EndIf
                    
                    ; colour is more green
                ElseIf r >= 200 And g >= 200 And b < 200
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIWhidbeyColours(index)\Olive
                    Else
                        colour = UIWhidbeyColours(index)\CustomOlive
                    EndIf
                    
                    ; any other colour combination, default to clasic grey
                Else
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIWhidbeyColours(index)\Grey
                    Else
                        colour = UIWhidbeyColours(index)\CustomGrey
                    EndIf
                    
                EndIf
            EndIf
            
        Else ; couldn't open theme
             ;Whidbey style colours
            If style = #UISTYLE_WHIDBEY
                
                If index < 0
                    ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                EndIf
                
                If UIColourMode = #UICOLOURMODE_DEFAULT
                    colour = UIWhidbeyColours(index)\Grey
                Else
                    colour = UIWhidbeyColours(index)\CustomGrey
                EndIf
                
            EndIf
        EndIf
        ; overide automatic colour scheme selection
    Else
        Select UIColourMode
            Case #UICOLOURMODE_DEFAULT_BLUE
                
                If index < 0
                    ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
                EndIf
                
                ;Whidbey style colours
                If style = #UISTYLE_WHIDBEY
                    colour = UIWhidbeyColours(index)\Blue
                EndIf
                
            Case #UICOLOURMODE_DEFAULT_OLIVE
                
                If index < 0
                    ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
                EndIf
                
                ;Whidbey style colours
                If style = #UISTYLE_WHIDBEY
                    colour = UIWhidbeyColours(index)\Olive
                EndIf  
                
            Case #UICOLOURMODE_DEFAULT_SILVER
                
                If index < 0
                    ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
                EndIf
                
                ;Whidbey style colours
                If style = #UISTYLE_WHIDBEY
                    colour = UIWhidbeyColours(index)\Silver
                EndIf  
                
            Case #UICOLOURMODE_DEFAULT_GREY
                
                If index < 0
                    ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                EndIf
                
                ;Whidbey style colours
                If style = #UISTYLE_WHIDBEY
                    colour = UIWhidbeyColours(index)\Grey
                EndIf  
                
            Case #UICOLOURMODE_CUSTOM_BLUE
                
                If index < 0
                    ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
                EndIf
                
                ;Whidbey style colours
                If style = #UISTYLE_WHIDBEY
                    colour = UIWhidbeyColours(index)\CustomBlue
                EndIf
                
            Case #UICOLOURMODE_CUSTOM_OLIVE
                
                If index < 0
                    ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
                EndIf
                
                ;Whidbey style colours
                If style = #UISTYLE_WHIDBEY
                    colour = UIWhidbeyColours(index)\CustomOlive
                EndIf
                
            Case #UICOLOURMODE_CUSTOM_SILVER
                
                If index < 0
                    ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
                EndIf
                
                ;Whidbey style colours
                If style = #UISTYLE_WHIDBEY
                    colour = UIWhidbeyColours(index)\CustomSilver
                EndIf
                
            Case #UICOLOURMODE_CUSTOM_GREY
                
                If index < 0
                    ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                EndIf
                
                ;Whidbey style colours
                If style = #UISTYLE_WHIDBEY
                    colour = UIWhidbeyColours(index)\CustomGrey
                EndIf
                
        EndSelect
    EndIf
    
    If index <> #menuTextColor And index <> #disabledColor And index <> #menuTitleTextColor And index <> #menuTitleInactiveTextColor And index <> #menuTitleHotTextColor And index <> #menuTitleHeldTextColor And index <> #selectedTextColor And index <> #menuDropShadow ; exceptions for colours!
        
        ; create cached brush for component if does not exist or colour changed
        If brushHandle(index)\Handle = 0 Or brushHandle(index)\colour <> colour
            DeleteObject_(brushHandle(index)\Handle)
            brushHandle(index)\Handle = CreateSolidBrush_(colour)
            brushHandle(index)\colour = colour
        EndIf
        
        ProcedureReturn brushHandle(index)\Handle
        
    EndIf
    ProcedureReturn colour
EndProcedure

; procedure returns a colour based on a style and index determined by windows theme
Procedure getMenuColourEx(style, index, mode)
    
    ;/ Automatic theme based colour scheme slection
    If UIColourMode = #UICOLOURMODE_DEFAULT Or UIColourMode = #UICOLOURMODE_CUSTOM
        
        If hTheme <> 0
            
            r = Red(XPthemeColour)
            g = Green(XPthemeColour)
            b = Blue(XPthemeColour)
            
            ;debuglog("colors: "+Str(r)+" "+Str(g)+" "+Str(b))
            
            ;/ 2003 style colours
            If style = 6 Or style = #UISTYLE_OFFICE2003
                
                ; 3 different colour highlight styles depending on theme colour
                ; colour is more silver/grey
                If r >= 200 And g >= 200 And b >= 200
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIOffice2003Colours(index)\Silver
                    Else
                        colour = UIOffice2003Colours(index)\CustomSilver
                    EndIf
                    
                    ; colour is more blue
                ElseIf r < 200 And g < 200 And b >= 200
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIOffice2003Colours(index)\Blue
                    Else
                        colour = UIOffice2003Colours(index)\CustomBlue
                    EndIf
                    
                    ; colour is more green
                ElseIf r >= 200 And g >= 200 And b < 200
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIOffice2003Colours(index)\Olive
                    Else
                        colour = UIOffice2003Colours(index)\CustomOlive
                    EndIf
                    
                    ; any other colour combination, default to clasic grey
                Else
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIOffice2003Colours(index)\Grey
                    Else
                        colour = UIOffice2003Colours(index)\CustomGrey
                    EndIf
                    
                EndIf
                
                ;/ 2007 style colours
            ElseIf style = #UISTYLE_OFFICE2007
                
                ; 3 different colour highlight styles depending on theme colour
                ; colour is more silver/grey
                If r >= 200 And g >= 200 And b >= 200
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIOffice2007Colours(index)\Silver
                    Else
                        colour = UIOffice2007Colours(index)\CustomSilver
                    EndIf
                    
                    ; colour is more blue
                ElseIf r < 200 And g < 200 And b >= 200
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIOffice2007Colours(index)\Blue
                    Else
                        colour = UIOffice2007Colours(index)\CustomBlue
                    EndIf
                    
                    ; colour is more green
                ElseIf r >= 200 And g >= 200 And b < 200
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIOffice2007Colours(index)\Olive
                    Else
                        colour = UIOffice2007Colours(index)\CustomOlive
                    EndIf
                    
                    ; any other colour combination, default to clasic grey
                Else
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                    EndIf
                    
                    If UIColourMode = #UICOLOURMODE_DEFAULT
                        colour = UIOffice2007Colours(index)\Grey
                    Else
                        colour = UIOffice2007Colours(index)\CustomGrey
                    EndIf
                    
                EndIf
                
            EndIf
            
        Else ; couldn't open theme
            
            ;/ 2003 style colours
            If style = 6 Or style = #UISTYLE_OFFICE2003
                
                If index < 0
                    ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                EndIf
                
                If UIColourMode = #UICOLOURMODE_DEFAULT
                    colour = UIOffice2003Colours(index)\Grey
                Else
                    colour = UIOffice2003Colours(index)\CustomGrey
                EndIf
                
                ;/ 2007 style colours
            ElseIf style = #UISTYLE_OFFICE2007
                
                If index < 0
                    ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                EndIf
                
                If UIColourMode = #UICOLOURMODE_DEFAULT
                    colour = UIOffice2007Colours(index)\Grey
                Else
                    colour = UIOffice2007Colours(index)\CustomGrey
                EndIf
                
            EndIf
            
        EndIf
        
        ;/ overide automatic colour scheme selection
    Else
        
        ;/ 2003 style colours
        If style = 6 Or style = #UISTYLE_OFFICE2003
            
            Select UIColourMode
                Case #UICOLOURMODE_DEFAULT_BLUE
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
                    EndIf
                    
                    colour = UIOffice2003Colours(index)\Blue
                    
                Case #UICOLOURMODE_DEFAULT_OLIVE
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
                    EndIf
                    
                    colour = UIOffice2003Colours(index)\Olive
                    
                Case #UICOLOURMODE_DEFAULT_SILVER
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
                    EndIf
                    
                    colour = UIOffice2003Colours(index)\Silver
                    
                Case #UICOLOURMODE_DEFAULT_GREY
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                    EndIf
                    
                    colour = UIOffice2003Colours(index)\Grey
                    
                Case #UICOLOURMODE_CUSTOM_BLUE
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
                    EndIf
                    
                    colour = UIOffice2003Colours(index)\CustomBlue
                    
                Case #UICOLOURMODE_CUSTOM_OLIVE
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
                    EndIf
                    
                    colour = UIOffice2003Colours(index)\CustomOlive
                    
                Case #UICOLOURMODE_CUSTOM_SILVER
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
                    EndIf
                    
                    colour = UIOffice2003Colours(index)\CustomSilver
                    
                Case #UICOLOURMODE_CUSTOM_GREY
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                    EndIf
                    
                    colour = UIOffice2003Colours(index)\CustomGrey
                    
            EndSelect
            
            ;/ 2007 style colours
        ElseIf style = #UISTYLE_OFFICE2007
            
            Select UIColourMode
                Case #UICOLOURMODE_DEFAULT_BLUE
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
                    EndIf
                    
                    colour = UIOffice2007Colours(index)\Blue
                    
                Case #UICOLOURMODE_DEFAULT_OLIVE
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
                    EndIf
                    
                    colour = UIOffice2007Colours(index)\Olive
                    
                Case #UICOLOURMODE_DEFAULT_SILVER
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
                    EndIf
                    
                    colour = UIOffice2007Colours(index)\Silver
                    
                Case #UICOLOURMODE_DEFAULT_GREY
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                    EndIf
                    
                    colour = UIOffice2007Colours(index)\Grey
                    
                Case #UICOLOURMODE_CUSTOM_BLUE
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
                    EndIf
                    
                    colour = UIOffice2007Colours(index)\CustomBlue
                    
                Case #UICOLOURMODE_CUSTOM_OLIVE
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
                    EndIf
                    
                    colour = UIOffice2007Colours(index)\CustomOlive
                    
                Case #UICOLOURMODE_CUSTOM_SILVER
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
                    EndIf
                    
                    colour = UIOffice2007Colours(index)\CustomSilver
                    
                Case #UICOLOURMODE_CUSTOM_GREY
                    
                    If index < 0
                        ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
                    EndIf
                    
                    colour = UIOffice2007Colours(index)\CustomGrey
                    
            EndSelect
        EndIf
    EndIf
    
    If mode & #returnColour
        ProcedureReturn colour
    ElseIf mode & #returnRGBColour
        If PeekB(@colour+3)&$FF <> 0 ; check that the colour isn't made with makecolor, if so then return propper rgb
            colour = RGB(Blue(colour), Green(colour), Red(colour))
        EndIf
        ProcedureReturn colour
    Else
        
        If PeekB(@colour+3)&$FF <> 0 ; check that the colour isn't made with makecolor, if so then return propper rgb
            colour = RGB(Blue(colour), Green(colour), Red(colour))
        EndIf
        
        ; create cached brush for component if does not exist or colour changed
        If brushHandle(index)\Handle = 0 Or brushHandle(index)\colour <> colour
            DeleteObject_(brushHandle(index)\Handle)
            brushHandle(index)\Handle = CreateSolidBrush_(colour)
            brushHandle(index)\colour = colour
        EndIf
        
        ProcedureReturn brushHandle(index)\Handle
    EndIf
EndProcedure

Procedure defaultDisabledImage(normalImage, style)
    
    ;If style > 0 And style < #UISTYLE_WHIDBEY
    ;  ProcedureReturn ImgBlend(normalImage, 255, 0, 0, RGB(200,200,200), 140, #ImgBlend_Greyscale|#ImgBlend_ReturnIcon)
    If style = #UISTYLE_WHIDBEY
        ProcedureReturn ImgBlend(normalImage, 80, 0, 0, 0, 0, #ImgBlend_ReturnIcon)
    ElseIf style = 6 Or style = #UISTYLE_OFFICE2003
        ProcedureReturn ImgHueBlend(normalImage, 255, getMenuColourEx(style, #toolstripBackground4, #returnRGBColour), 0, 0.64, RGB(210,210,210), 110, #ImgBlend_ReturnIcon)
    ElseIf style = #UISTYLE_OFFICE2007
        ProcedureReturn ImgHueBlend(normalImage, 190, getMenuColourEx(style, #menuHeldGradientColor2, #returnRGBColour), -0.1, 0.49, getMenuColourEx(style, #menuHeldGradientColor1, #returnRGBColour), 80, #ImgBlend_ReturnIcon)
    Else
        ProcedureReturn ImgBlend(normalImage, 120, 0, 0, 0, 0, #ImgBlend_Greyscale|#ImgBlend_ReturnIcon)
    EndIf
    
EndProcedure

; mode = 0: update all, mode = 1: update items in handle (menuex), mode = 2: update items in handle (hmenu)
; mode = 3: update all ToolBarEx buttons, mode = 4: update ToolBarEx buttons by handle(toolbarEx()\id)
Procedure updateDefaultDisabledImages(handle.i, mode)
    
    ; iterate through all menu items and update disabled state icons if no custom icon specified
    If ListSize(itemex()) > 0 And mode < 3
        *thisItemEx = @itemex()
        ForEach itemex()
            If itemex()\normal = -1 And itemex()\disabled = 0  ; normal icon exists and no custom disabled state icon
                
                action = #False
                
                If mode = 0 ; update all items in every menuex
                    action = #True
                    ;debuglog("mode 0")
                ElseIf mode = 1 ; only update items in specified menuex handle
                    If itemex()\menuex = handle
                        *thisMenuEx = @menuex()
                        ChangeCurrentElement(menuex(), itemex()\menuex)
                        If itemex()\defDisabledStyle <> menuex()\style
                            action = #True
                            ;debuglog("mode 1")
                        EndIf
                        ChangeCurrentElement(menuex(), *thisMenuEx)
                    EndIf
                ElseIf mode = 2 ; only update items in specified hmenu handle
                    If itemex()\popupid = handle
                        *thisMenuEx = @menuex()
                        ChangeCurrentElement(menuex(), itemex()\menuex)
                        If itemex()\defDisabledStyle <> menuex()\style
                            action = #True
                            ;debuglog("mode 2 "+Str(Random(10000)))
                        EndIf
                        ChangeCurrentElement(menuex(), *thisMenuEx)
                    EndIf
                EndIf
                
                If action = #True
                    *thisMenuEx = @menuex()
                    ChangeCurrentElement(menuex(), itemex()\menuex)
                    normalIcon = ImageList_GetIcon_(itemex()\ImageList, 0, 0)
                    disabledIcon = defaultDisabledImage(normalIcon, menuex()\style)
                    error.l = ImageList_ReplaceIcon_(itemex()\ImageList, 2, disabledIcon)
                    DestroyIcon_(disabledIcon)
                    DestroyIcon_(normalIcon)
                    itemex()\defDisabledStyle = menuex()\style
                    ;debuglog("updated icon!")
                    ChangeCurrentElement(menuex(), *thisMenuEx)
                EndIf
                
            EndIf
        Next
        ChangeCurrentElement(itemex(), *thisItemEx)
    EndIf
    
    ; update all ToolBarEx disabled images
    If mode = 0 Or mode >= 3
        ; iterate through all ToolBarEx buttons and update disabled state icons if no custom icon specified
        If ListSize(toolbarExButton()) > 0
            
            *thistoolbarExButton = @toolbarExButton()
            ForEach toolbarExButton()
                
                If mode = 0 Or mode = 3 Or (mode = 4 And toolbarExButton()\toolbarID = handle)
                    
                    If toolbarExButton()\defDisabledImage = #True
                        
                        *thistoolbarEx = @toolbarEx()
                        ChangeCurrentElement(toolbarEx(), toolbarExButton()\toolbarEx)
                        
                        If mode = 4 And toolbarEx()\UIStyle = toolbarExButton()\defDisabledStyle
                            ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
                            Continue
                        EndIf
                        
                        If toolbarEx()\normalImageList <> -1
                            
                            index = SendMessage_(toolbarEx()\Handle, #TB_COMMANDTOINDEX, toolbarExButton()\id, 0)
                            
                            normalIcon = ImageList_GetIcon_(toolbarEx()\normalImageList, index, 0)
                            If normalIcon <> nullicon
                                
                                disabledIcon = defaultDisabledImage(normalIcon, toolbarEx()\UIStyle)
                                ImageList_ReplaceIcon_(toolbarEx()\disabledImageList, index, disabledIcon)
                                DestroyIcon_(disabledIcon)
                                toolbarExButton()\defDisabledStyle = toolbarEx()\UIStyle
                                
                            EndIf
                            DestroyIcon_(normalIcon)
                            
                        EndIf
                        
                        ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
                        
                    EndIf
                    
                EndIf
                
            Next
            ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
        EndIf
    EndIf
    
EndProcedure

; send WM_SETREDRAW false to all top level child windows
Procedure EnumChildWMSetRedraw(hwnd, lParam)
    
    If lParam <> 0 And GetWindowLongPtr_(hwnd, #GWL_STYLE) & #WS_VISIBLE
        If GetParent_(hwnd) = lParam
            AddElement(skinHwndRedraw())
            skinHwndRedraw() = hwnd
            SendMessage_(hwnd, #WM_SETREDRAW, #False, 0)
        EndIf
    EndIf
    
    ProcedureReturn #True
EndProcedure
Procedure EnumWindowsSetRedraw(hwnd, lParam)
    
    GetWindowThreadProcessId_(hwnd, @processID)
    If processID = lParam
        
        ClearList(skinHwndRedraw())
        If GetWindowLongPtr_(hwnd, #GWL_STYLE) & #WS_VISIBLE
            redrawHwnd = hwnd
        Else
            redrawHwnd = 0
        EndIf
        EnumChildWindows_(hwnd, @EnumChildWMSetRedraw(), redrawHwnd)
        
        ForEach skinHwndRedraw()
            SendMessage_(skinHwndRedraw(), #WM_SETREDRAW, #True, 0)
        Next
        
    EndIf
    
    ProcedureReturn #True
EndProcedure

ProcedureDLL SetUIColourMode(mode.l)
    
    macro_protectCommand()
    
    name.s = ""
    Select mode
        Case #UICOLOURMODE_DEFAULT
            UIColourMode = mode
            found = #True
        Case #UICOLOURMODE_DEFAULT_BLUE
            UIColourMode = mode
            found = #True
            name = "blue"
        Case #UICOLOURMODE_DEFAULT_OLIVE
            UIColourMode = mode
            found = #True
            name = "olive"
        Case #UICOLOURMODE_DEFAULT_SILVER
            UIColourMode = mode
            found = #True
            name = "silver"
        Case #UICOLOURMODE_DEFAULT_GREY
            UIColourMode = mode
            found = #True
            name = "grey"
        Case #UICOLOURMODE_CUSTOM
            UIColourMode = mode
            found = #True
        Case #UICOLOURMODE_CUSTOM_BLUE
            UIColourMode = mode
            found = #True
            name = "blue"
        Case #UICOLOURMODE_CUSTOM_OLIVE
            UIColourMode = mode
            found = #True
            name = "olive"
        Case #UICOLOURMODE_CUSTOM_SILVER
            UIColourMode = mode
            found = #True
            name = "silver"
        Case #UICOLOURMODE_CUSTOM_GREY
            UIColourMode = mode
            found = #True
            name = "grey"
    EndSelect
    
    If found = #True
        
        EnumWindows_(@EnumWindowsSetRedraw(), GetCurrentProcessId_())
        
        blitExFlush()
        
        ; re-render any styled rebar backgrounds with new theme
        RenderRebarBackgrounds(#True)
        
        updateDefaultDisabledImages(0, 0)
        
        ;ForEach menuCallback()
        ;  If menuCallback()\WindowID <> 0
        ;    RedrawWindow_(menuCallback()\WindowID, 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
        ;  EndIf
        ;Next
        
        ForEach menuex()
            menuex()\bufferWidth = 0
            menuex()\bufferHeight = 0
        Next
        
        SetGlobalSkinColourTheme(name)
        
    EndIf
    
    ProcedureReturn found
EndProcedure

ProcedureDLL GetUIColourMode() ; Returns the current user interface colour mode
    
    macro_protectCommand()
    
    ProcedureReturn UIColourMode
    
EndProcedure

ProcedureDLL GetCurrentColourScheme() ; Returns the current active colour scheme
    
    macro_protectCommand()
    
    If UIColourMode = #UICOLOURMODE_CUSTOM
        ProcedureReturn getMenuColourEx(#UISTYLE_OFFICE2003, -1, 0)
    Else
        ProcedureReturn getMenuColourEx(#UISTYLE_OFFICE2003, -1, 0)-5
    EndIf
    
EndProcedure

ProcedureDLL GetUIColour(style.l, component.l, colourScheme.l) ; returns the colour of a UI style component
    
    macro_protectCommand()
    
    ; make sure component isn't out of bounds!
    If component < 0 Or component >= #MaxUIComponents
        ProcedureReturn #False
    EndIf
    
    If style = #UISTYLE_WHIDBEY
        
        ; returns the current automatically selected colourscheme
        If colourScheme = 0
            colourScheme = getMenuColourEx(#UISTYLE_OFFICE2003, -1, 0)
        EndIf
        
        Select colourScheme
            Case #UICOLOURMODE_DEFAULT_BLUE
                colour = UIWhidbeyColours(component)\Blue
            Case #UICOLOURMODE_DEFAULT_SILVER
                colour = UIWhidbeyColours(component)\Silver
            Case #UICOLOURMODE_DEFAULT_OLIVE
                colour = UIWhidbeyColours(component)\Olive
            Case #UICOLOURMODE_DEFAULT_GREY
                colour = UIWhidbeyColours(component)\Grey
            Case #UICOLOURMODE_CUSTOM_BLUE
                colour = UIWhidbeyColours(component)\CustomBlue
            Case #UICOLOURMODE_CUSTOM_SILVER
                colour = UIWhidbeyColours(component)\CustomSilver
            Case #UICOLOURMODE_CUSTOM_OLIVE
                colour = UIWhidbeyColours(component)\CustomOlive
            Case #UICOLOURMODE_CUSTOM_GREY
                colour = UIWhidbeyColours(component)\CustomGrey
        EndSelect
        
    ElseIf style = #UISTYLE_OFFICE2003
        
        Select colourScheme
            Case #UICOLOURMODE_DEFAULT_BLUE
                colour = UIOffice2003Colours(component)\Blue
            Case #UICOLOURMODE_DEFAULT_SILVER
                colour = UIOffice2003Colours(component)\Silver
            Case #UICOLOURMODE_DEFAULT_OLIVE
                colour = UIOffice2003Colours(component)\Olive
            Case #UICOLOURMODE_DEFAULT_GREY
                colour = UIOffice2003Colours(component)\Grey
            Case #UICOLOURMODE_CUSTOM_BLUE
                colour = UIOffice2003Colours(component)\CustomBlue
            Case #UICOLOURMODE_CUSTOM_SILVER
                colour = UIOffice2003Colours(component)\CustomSilver
            Case #UICOLOURMODE_CUSTOM_OLIVE
                colour = UIOffice2003Colours(component)\CustomOlive
            Case #UICOLOURMODE_CUSTOM_GREY
                colour = UIOffice2003Colours(component)\CustomGrey
            Default
                colour = getMenuColourEx(#UISTYLE_OFFICE2003, component, #returnColour)
        EndSelect
        
    ElseIf style = #UISTYLE_OFFICE2007
        
        Select colourScheme
            Case #UICOLOURMODE_DEFAULT_BLUE
                colour = UIOffice2007Colours(component)\Blue
            Case #UICOLOURMODE_DEFAULT_SILVER
                colour = UIOffice2007Colours(component)\Silver
            Case #UICOLOURMODE_DEFAULT_OLIVE
                colour = UIOffice2007Colours(component)\Olive
            Case #UICOLOURMODE_DEFAULT_GREY
                colour = UIOffice2007Colours(component)\Grey
            Case #UICOLOURMODE_CUSTOM_BLUE
                colour = UIOffice2007Colours(component)\CustomBlue
            Case #UICOLOURMODE_CUSTOM_SILVER
                colour = UIOffice2007Colours(component)\CustomSilver
            Case #UICOLOURMODE_CUSTOM_OLIVE
                colour = UIOffice2007Colours(component)\CustomOlive
            Case #UICOLOURMODE_CUSTOM_GREY
                colour = UIOffice2007Colours(component)\CustomGrey
            Default
                colour = getMenuColourEx(#UISTYLE_OFFICE2007, component, #returnColour)
        EndSelect
        
    EndIf
    
    ; colour format is makecolor return rgb format
    Select component
        Case #menuHotColor
        Case #menuHotBorder
        Case #menuHeldColor
        Case #menuHeldBorder
        Case #menuBarColor
        Case #separatorBar
        Case #selectedColor
        Case #selectedBorder
        Case #background
        Case #gripperSolid
        Case #gripperShadow
        Case #menuCheckboxBackground
        Case #menuCheckboxBorder
        Case #menuCheckboxSelectedBackground
        Case #menuCheckboxSelectedBorder
        Case #menuCheckboxDisabledBackground
        Case #menuCheckboxDisabledBorder
        Case #toolbarButtonTextColor
        Case #toolbarButtonHotTextColor
        Case #toolbarButtonDisabledTextColor
        Case #toolbarSeparator
        Case #toolbarSeparatorShadow
        Default
            colour = RGB(Blue(colour), Green(colour), Red(colour))
    EndSelect
    
    ProcedureReturn colour
EndProcedure

ProcedureDLL SetUIColour(style.l, component.l, colour.l, colourScheme.l, noUpdate.b) ; sets the colour of a UI style component
    
    macro_protectCommand()
    
    ; make sure colourScheme is a custom colour slot
    If colourScheme < #UICOLOURMODE_CUSTOM
        colourScheme = colourScheme + #UICOLOURMODE_CUSTOM
    EndIf
    
    ; make sure colourScheme is within possible values
    If colourScheme < #UICOLOURMODE_CUSTOM
        ProcedureReturn #False
    ElseIf colourScheme > #UICOLOURMODE_CUSTOM_GREY
        ProcedureReturn #False
    EndIf
    
    ; make sure component isn't out of bounds!
    If component < 0 Or component >= #MaxUIComponents
        ProcedureReturn #False
    EndIf
    
    ; returns the current automatically selected colourscheme
    If colourScheme = #UICOLOURMODE_CUSTOM
        colourScheme = getMenuColourEx(style, -1, 0)
    EndIf
    
    ; colour format exceptions
    Select component
        Case #menuHotColor
        Case #menuHotBorder
        Case #menuHeldColor
        Case #menuHeldBorder
        Case #menuBarColor
        Case #separatorBar
        Case #selectedColor
        Case #selectedBorder
        Case #background
        Case #gripperSolid
        Case #gripperShadow
        Case #menuCheckboxBackground
        Case #menuCheckboxBorder
        Case #menuCheckboxSelectedBackground
        Case #menuCheckboxSelectedBorder
        Case #menuCheckboxDisabledBackground
        Case #menuCheckboxDisabledBorder
        Case #toolbarButtonTextColor
        Case #toolbarButtonHotTextColor
        Case #toolbarButtonDisabledTextColor
        Case #toolbarSeparator
        Case #toolbarSeparatorShadow
        Default
            colour = MakeColor(255, Red(colour), Green(colour), Blue(colour))
    EndSelect
    
    If style = #UISTYLE_WHIDBEY
        
        Select colourScheme
            Case #UICOLOURMODE_CUSTOM_BLUE
                UIWhidbeyColours(component)\CustomBlue = colour
            Case #UICOLOURMODE_CUSTOM_SILVER
                UIWhidbeyColours(component)\CustomSilver = colour
            Case #UICOLOURMODE_CUSTOM_OLIVE
                UIWhidbeyColours(component)\CustomOlive = colour
            Case #UICOLOURMODE_CUSTOM_GREY
                UIWhidbeyColours(component)\CustomGrey = colour
        EndSelect
        
        result = #True
        
    ElseIf style = #UISTYLE_OFFICE2003
        
        Select colourScheme
            Case #UICOLOURMODE_CUSTOM_BLUE
                UIOffice2003Colours(component)\CustomBlue = colour
            Case #UICOLOURMODE_CUSTOM_SILVER
                UIOffice2003Colours(component)\CustomSilver = colour
            Case #UICOLOURMODE_CUSTOM_OLIVE
                UIOffice2003Colours(component)\CustomOlive = colour
            Case #UICOLOURMODE_CUSTOM_GREY
                UIOffice2003Colours(component)\CustomGrey = colour
        EndSelect
        
        result = #True
        
    ElseIf style = #UISTYLE_OFFICE2007
        
        Select colourScheme
            Case #UICOLOURMODE_CUSTOM_BLUE
                UIOffice2007Colours(component)\CustomBlue = colour
            Case #UICOLOURMODE_CUSTOM_SILVER
                UIOffice2007Colours(component)\CustomSilver = colour
            Case #UICOLOURMODE_CUSTOM_OLIVE
                UIOffice2007Colours(component)\CustomOlive = colour
            Case #UICOLOURMODE_CUSTOM_GREY
                UIOffice2007Colours(component)\CustomGrey = colour
        EndSelect
        
        result = #True
        
    EndIf
    
    If result = #True And noUpdate = #False
        blitExFlush()
        
        ; re-render any styled rebar backgrounds with new theme
        RenderRebarBackgrounds(#True)
        
        updateDefaultDisabledImages(0, 0)
        
        ForEach menuCallback()
            If menuCallback()\WindowID <> 0
                RedrawWindow_(menuCallback()\WindowID, 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
            EndIf
        Next
        
        ForEach menuex()
            menuex()\bufferWidth = 0
            menuex()\bufferHeight = 0
        Next
    EndIf
    
    ProcedureReturn result
EndProcedure

; returns color value extracted from string if detected
Procedure checkColourValue(txt.s)
    
    txt = LCase(txt)
    
    If FindString(txt, "rgba", 1) > 0 And FindString(txt, ")", 1) > FindString(txt, "(", 1)
        txt = ReplaceString(txt, " ", "")
        txt = ReplaceString(txt, "rgba", "")
        txt = ReplaceString(txt, "(", "")
        txt = ReplaceString(txt, ")", "")
        txt = ReplaceString(txt, ";", "")
        r = Val(StringField(txt, 1, ","))
        g = Val(StringField(txt, 2, ","))
        b = Val(StringField(txt, 3, ","))
        a$ = StringField(txt, 4, ",")
        If FindString(a$, ".", 1) > 0
            a = ValF(a$)*255
        Else
            a = Val(a$)
        EndIf
        If a = 0
            a = 1
        EndIf
        ProcedureReturn MakeColor(a, r, g, b)
    ElseIf FindString(txt, "rgb", 1) > 0 And FindString(txt, ")", 1) > FindString(txt, "(", 1)
        txt = ReplaceString(txt, " ", "")
        txt = ReplaceString(txt, "rgb", "")
        txt = ReplaceString(txt, "(", "")
        txt = ReplaceString(txt, ")", "")
        txt = ReplaceString(txt, ";", "")
        r = Val(StringField(txt, 1, ","))
        g = Val(StringField(txt, 2, ","))
        b = Val(StringField(txt, 3, ","))
        ProcedureReturn RGB(r, g, b)
    ElseIf FindString(txt, "getuicolour", 1) > 0 And FindString(txt, ")", 1) > FindString(txt, "(", 1)
        
        txt = ReplaceString(txt, " ", "")
        txt = ReplaceString(txt, "#", "")
        txt = ReplaceString(txt, "getuicolour", "")
        txt = ReplaceString(txt, "(", "")
        txt = ReplaceString(txt, ")", "")
        txt = ReplaceString(txt, ";", "")
        style$ = UCase(StringField(txt, 1, ","))
        component$ = StringField(txt, 2, ",")
        colourScheme$ = UCase(StringField(txt, 3, ","))
        
        Select style$
            Case "UISTYLE_WHIDBEY"
                style = #UISTYLE_WHIDBEY
            Case "UISTYLE_OFFICE2003"
                style = #UISTYLE_OFFICE2003
            Case "UISTYLE_OFFICE2007"
                style = #UISTYLE_OFFICE2007
        EndSelect
        
        Select component$
            Case "menutitletextcolor"
                component = #menuTitleTextColor
            Case "menutitlehottextcolor"
                component = #menuTitleHotTextColor
            Case "menutitleheldtextcolor"
                component = #menuTitleHeldTextColor
            Case "menutitleinactivetextcolor"
                component = #menuTitleInactiveTextColor
            Case "menutextcolor"
                component = #menuTextColor
            Case "menuhotcolor"
                component = #menuHotColor
            Case "menuhotgradientcolor1"
                component = #menuHotGradientColor1
            Case "menuhotgradientcolor2"
                component = #menuHotGradientColor2
            Case "menuhotborder"
                component = #menuHotBorder
            Case "menuheldcolor"
                component = #menuHeldColor
            Case "menuheldgradientcolor1"
                component = #menuHeldGradientColor1
            Case "menuheldgradientcolor2"
                component = #menuHeldGradientColor2
            Case "menuheldborder"
                component = #menuHeldBorder
            Case "menubarcolor"
                component = #menuBarColor
            Case "menucheckboxbackground"
                component = #menuCheckboxBackground
            Case "menucheckboxborder"
                component = #menuCheckboxBorder
            Case "menucheckboxselectedbackground"
                component = #menuCheckboxSelectedBackground
            Case "menucheckboxselectedborder"
                component = #menuCheckboxSelectedBorder
            Case "menucheckboxdisabledbackground"
                component = #menuCheckboxDisabledBackground
            Case "menucheckboxdisabledborder"
                component = #menuCheckboxDisabledBorder
            Case "menudropshadow"
                component = #menuDropShadow
            Case "bargradientcolor1"
                component = #barGradientColor1
            Case "bargradientcolor2"
                component = #barGradientColor2
            Case "bargradientcolor3"
                component = #barGradientColor3
            Case "bargradientcolor4"
                component = #barGradientColor4
            Case "separatorbar"
                component = #separatorBar
            Case "selectedcolor"
                component = #selectedColor
            Case "selectedtextcolor"
                component = #selectedTextColor
            Case "selectedborder"
                component = #selectedBorder
            Case "disabledcolor"
                component = #disabledColor
            Case "background"
                component = #background
            Case "rebarbackground1"
                component = #rebarBackground1
            Case "rebarbackground2"
                component = #rebarBackground2
            Case "toolstripbackground1"
                component = #toolstripBackground1
            Case "toolstripbackground2"
                component = #toolstripBackground2
            Case "toolstripbackground3"
                component = #toolstripBackground3
            Case "toolstripbackground4"
                component = #toolstripBackground4
            Case "toolstripdropdowngradient1"
                component = #toolstripDropdownGradient1
            Case "toolstripdropdowngradient2"
                component = #toolstripDropdownGradient2
            Case "toolstripdropdowngradient3"
                component = #toolstripDropdownGradient3
            Case "toolstripdropdowngradient4"
                component = #toolstripDropdownGradient4
            Case "toolstripshadow"
                component = #toolstripShadow
            Case "grippersolid"
                component = #gripperSolid
            Case "grippershadow"
                component = #gripperShadow
            Case "selectgradientcolor1"
                component = #SelectGradientColor1
            Case "selectgradientcolor2"
                component = #SelectGradientColor2
            Case "stickyselectgradientcolor1"
                component = #StickySelectGradientColor1
            Case "stickyselectgradientcolor2"
                component = #StickySelectGradientColor2
            Case "stickyselectbordercolor"
                component = #StickySelectBorderColor
            Case "toolbarbuttontextcolor"
                component = #toolbarButtonTextColor
            Case "toolbarbuttonhottextcolor"
                component = #toolbarButtonHotTextColor
            Case "toolbarbuttondisabledtextcolor"
                component = #toolbarButtonDisabledTextColor
            Case "toolbarhotgradientcolor1"
                component = #toolbarHotGradientColor1
            Case "toolbarhotgradientcolor2"
                component = #toolbarHotGradientColor2
            Case "toolbarseparator"
                component = #toolbarSeparator
            Case "toolbarseparatorshadow"
                component = #toolbarSeparatorShadow
        EndSelect
        
        Select colourScheme$
            Case "UICOLOURMODE_DEFAULT"
                colourScheme = #UICOLOURMODE_DEFAULT
            Case "UICOLOURMODE_DEFAULT_BLUE"
                colourScheme = #UICOLOURMODE_DEFAULT_BLUE
            Case "UICOLOURMODE_DEFAULT_GREY"
                colourScheme = #UICOLOURMODE_DEFAULT_GREY
            Case "UICOLOURMODE_DEFAULT_OLIVE"
                colourScheme = #UICOLOURMODE_DEFAULT_OLIVE
            Case "UICOLOURMODE_DEFAULT_SILVER"
                colourScheme = #UICOLOURMODE_DEFAULT_SILVER
            Case "UICOLOURMODE_CUSTOM"
                colourScheme = #UICOLOURMODE_CUSTOM
            Case "UICOLOURMODE_CUSTOM_BLUE"
                colourScheme = #UICOLOURMODE_CUSTOM_BLUE
            Case "UICOLOURMODE_CUSTOM_GREY"
                colourScheme = #UICOLOURMODE_CUSTOM_GREY
            Case "UICOLOURMODE_CUSTOM_OLIVE"
                colourScheme = #UICOLOURMODE_CUSTOM_OLIVE
            Case "UICOLOURMODE_CUSTOM_SILVER"
                colourScheme = #UICOLOURMODE_CUSTOM_SILVER
        EndSelect
        
        ProcedureReturn GetUIColour(style, component, colourScheme)
        
    ElseIf FindString(txt, "#", 1) > 0
        pos = FindString(txt, "#", 1) + 1
        p = pos
        Repeat
            If (Asc(Mid(txt, p, 1)) >= 48 And Asc(Mid(txt, p, 1)) <= 57) Or (Asc(Mid(txt, p, 1)) >= 97 And Asc(Mid(txt, p, 1)) <= 102)
                found = found + 1
            Else
                Break
            EndIf
            p = p + 1
        Until p > Len(txt) Or p-pos > 6
        If found = 6
            c = Val("$"+Mid(txt, pos, 6))
            ProcedureReturn RGB(Blue(c), Green(c), Red(c))
        EndIf
    Else
        
        txt = Trim(txt)
        txt = ReplaceString(txt, ";", "")
        
        ; check special system colour constants
        txtu.s = UCase(txt)
        col = -1
        Select txtu
            Case "COLOR_3DDKSHADOW"
                col = GetSysColor_(#COLOR_3DDKSHADOW)
            Case "COLOR_3DFACE"
                col = GetSysColor_(#COLOR_3DFACE)
            Case "COLOR_3DHIGHLIGHT"
                col = GetSysColor_(#COLOR_3DHIGHLIGHT)
            Case "COLOR_3DLIGHT"
                col = GetSysColor_(#COLOR_3DLIGHT)
            Case "COLOR_3DSHADOW"
                col = GetSysColor_(#COLOR_3DSHADOW)
            Case "COLOR_ACTIVEBORDER"
                col = GetSysColor_(#COLOR_ACTIVEBORDER)
            Case "COLOR_ACTIVECAPTION"
                col = GetSysColor_(#COLOR_ACTIVECAPTION)
            Case "COLOR_APPWORKSPACE"
                col = GetSysColor_(#COLOR_APPWORKSPACE)
            Case "COLOR_BACKGROUND"
                col = GetSysColor_(#COLOR_BACKGROUND)
            Case "COLOR_BTNFACE"
                col = GetSysColor_(#COLOR_BTNFACE)
            Case "COLOR_BTNHIGHLIGHT"
                col = GetSysColor_(#COLOR_BTNHIGHLIGHT)
            Case "COLOR_BTNHILIGHT"
                col = GetSysColor_(#COLOR_BTNHILIGHT)
            Case "COLOR_BTNSHADOW"
                col = GetSysColor_(#COLOR_BTNSHADOW)
            Case "COLOR_BTNTEXT"
                col = GetSysColor_(#COLOR_BTNTEXT)
            Case "COLOR_CAPTIONTEXT"
                col = GetSysColor_(#COLOR_CAPTIONTEXT)
            Case "COLOR_DESKTOP"
                col = GetSysColor_(#COLOR_DESKTOP)
            Case "COLOR_GRADIENTACTIVECAPTION"
                col = GetSysColor_(#COLOR_GRADIENTACTIVECAPTION)
            Case "COLOR_GRADIENTINACTIVECAPTION"
                col = GetSysColor_(#COLOR_GRADIENTINACTIVECAPTION)
            Case "COLOR_GRAYTEXT"
                col = GetSysColor_(#COLOR_GRAYTEXT)
            Case "COLOR_HIGHLIGHT"
                col = GetSysColor_(#COLOR_HIGHLIGHT)
            Case "COLOR_HIGHLIGHTTEXT"
                col = GetSysColor_(#COLOR_HIGHLIGHTTEXT)
            Case "COLOR_HOTLIGHT"
                col = GetSysColor_(#COLOR_HOTLIGHT)
            Case "COLOR_INACTIVEBORDER"
                col = GetSysColor_(#COLOR_INACTIVEBORDER)
            Case "COLOR_INACTIVECAPTION"
                col = GetSysColor_(#COLOR_INACTIVECAPTION)
            Case "COLOR_INACTIVECAPTIONTEXT"
                col = GetSysColor_(#COLOR_INACTIVECAPTIONTEXT)
            Case "COLOR_INFOBK"
                col = GetSysColor_(#COLOR_INFOBK)
            Case "COLOR_INFOTEXT"
                col = GetSysColor_(#COLOR_INFOTEXT)
            Case "COLOR_MENU"
                col = GetSysColor_(#COLOR_MENU)
            Case "COLOR_MENUHILIGHT"
                col = GetSysColor_(#COLOR_MENUHILIGHT)
            Case "COLOR_MENUBAR"
                col = GetSysColor_(#COLOR_MENUBAR)
            Case "COLOR_MENUTEXT"
                col = GetSysColor_(#COLOR_MENUTEXT)
            Case "COLOR_SCROLLBAR"
                col = GetSysColor_(#COLOR_SCROLLBAR)
            Case "COLOR_WINDOW"
                col = GetSysColor_(#COLOR_WINDOW)
            Case "COLOR_WINDOWFRAME"
                col = GetSysColor_(#COLOR_WINDOWFRAME)
            Case "COLOR_WINDOWTEXT"
                col = GetSysColor_(#COLOR_WINDOWTEXT)
        EndSelect
        
        If col <> -1
            ProcedureReturn col
        EndIf
        
        If FindMapElement(colour(), txt)
            
            ProcedureReturn RGB(Blue(colour()), Green(colour()), Red(colour()))
            
        EndIf
        
    EndIf
    
    ProcedureReturn -1
    
EndProcedure

Procedure blitExFlush()
    
    For n = 0 To #MaxUIComponents
        
        ; flush #UISTYLE_OFFICE2003 cache
        If UIOffice2003Colours(n)\hdc <> 0
            DeleteObject_(UIOffice2003Colours(n)\bitmap)
            DeleteDC_(UIOffice2003Colours(n)\hdc)
            UIOffice2003Colours(n)\hdc = 0
            UIOffice2003Colours(n)\bitmap = 0
            UIOffice2003Colours(n)\width = 0
            UIOffice2003Colours(n)\height = 0
        EndIf
        ForEach UIOffice2003Colours(n)\dBlitEx()
            If UIOffice2003Colours(n)\dBlitEx()\hdc <> 0
                DeleteObject_(UIOffice2003Colours(n)\dBlitEx()\bitmap)
                DeleteDC_(UIOffice2003Colours(n)\dBlitEx()\hdc)
                UIOffice2003Colours(n)\dBlitEx()\hdc = 0
                UIOffice2003Colours(n)\dBlitEx()\bitmap = 0
                UIOffice2003Colours(n)\dBlitEx()\width = 0
                UIOffice2003Colours(n)\dBlitEx()\height = 0
            EndIf
        Next
        
        ; flush #UISTYLE_OFFICE2007 cache
        If UIOffice2007Colours(n)\hdc <> 0
            DeleteObject_(UIOffice2007Colours(n)\bitmap)
            DeleteDC_(UIOffice2007Colours(n)\hdc)
            UIOffice2007Colours(n)\hdc = 0
            UIOffice2007Colours(n)\bitmap = 0
            UIOffice2007Colours(n)\width = 0
            UIOffice2007Colours(n)\height = 0
        EndIf
        ForEach UIOffice2007Colours(n)\dBlitEx()
            If UIOffice2007Colours(n)\dBlitEx()\hdc <> 0
                DeleteObject_(UIOffice2007Colours(n)\dBlitEx()\bitmap)
                DeleteDC_(UIOffice2007Colours(n)\dBlitEx()\hdc)
                UIOffice2007Colours(n)\dBlitEx()\hdc = 0
                UIOffice2007Colours(n)\dBlitEx()\bitmap = 0
                UIOffice2007Colours(n)\dBlitEx()\width = 0
                UIOffice2007Colours(n)\dBlitEx()\height = 0
            EndIf
        Next
        
    Next
    
EndProcedure

; used for cacheing complex fixed size & dynamic sized rendered components as bitmaps
Procedure blitEx(hdc.i, style.l, component.l, *rec.RECT, mode.l)
    
    ; get the width and height of the component to be rendered
    width = *rec\right-*rec\left
    height = *rec\bottom-*rec\top
    
    ;debuglog("Width: "+Str(width)+" Height: "+Str(height))
    
    If mode & #DynamicBlitEx
        mode = mode &~ #DynamicBlitEx
        Dynamic = #True
    EndIf
    
    ;/ Office 2003 Style
    If style = 6 Or style = #UISTYLE_OFFICE2003
        
        If Dynamic = #False
            
            ; decide if to re-cache and redraw
            If UIOffice2003Colours(component)\hdc = 0
                redraw = #True
            Else
                If mode = 0
                    If width > UIOffice2003Colours(component)\width Or height > UIOffice2003Colours(component)\height
                        redraw = #True
                    EndIf
                ElseIf mode = #ForceHorizontalRedraw And (UIOffice2003Colours(component)\width <> width Or height > UIOffice2003Colours(component)\height)
                    redraw = #True
                ElseIf mode = #ForceVerticalRedraw And (UIOffice2003Colours(component)\height <> height Or width > UIOffice2003Colours(component)\width)
                    redraw = #True
                ElseIf mode = #ForceRedraw And (UIOffice2003Colours(component)\width <> width Or UIOffice2003Colours(component)\height <> height)
                    redraw = #True
                EndIf
            EndIf
            
            If redraw = #True
                ; free old bitmap cache if exists
                If UIOffice2003Colours(component)\hdc <> 0
                    DeleteObject_(UIOffice2003Colours(component)\bitmap)
                    DeleteDC_(UIOffice2003Colours(component)\hdc)
                EndIf
                
                ; create new bitmap cache
                UIOffice2003Colours(component)\hdc = CreateCompatibleDC_(hdc)
                UIOffice2003Colours(component)\bitmap = CreateCompatibleBitmap_(hdc, width, height)
                UIOffice2003Colours(component)\width = width
                UIOffice2003Colours(component)\height = height
                
                SelectObject_(UIOffice2003Colours(component)\hdc, UIOffice2003Colours(component)\bitmap)
                
            EndIf
            
            chdc = UIOffice2003Colours(component)\hdc
            cbitmap = UIOffice2003Colours(component)\bitmap
            
        Else
            
            new = #True
            ForEach UIOffice2003Colours(component)\dBlitEx()
                If mode = 0 And UIOffice2003Colours(component)\dBlitEx()\width = width And UIOffice2003Colours(component)\dBlitEx()\height = height
                    new = #False
                    Break
                ElseIf mode = #ForceHorizontalRedraw And UIOffice2003Colours(component)\dBlitEx()\width = width
                    new = #False
                    If height > UIOffice2003Colours(component)\dBlitEx()\height
                        redraw = #True
                    EndIf
                    Break
                ElseIf mode = #ForceVerticalRedraw And UIOffice2003Colours(component)\dBlitEx()\height = height
                    new = #False
                    If width > UIOffice2003Colours(component)\dBlitEx()\width
                        redraw = #True
                    EndIf
                    Break
                EndIf
            Next
            
            If new = #True Or redraw = #True
                
                If new = #True
                    AddElement(UIOffice2003Colours(component)\dBlitEx())
                    redraw = #True
                EndIf
                
                ; free old bitmap cache if exists
                If UIOffice2003Colours(component)\dBlitEx()\hdc <> 0
                    DeleteObject_(UIOffice2003Colours(component)\dBlitEx()\bitmap)
                    DeleteDC_(UIOffice2003Colours(component)\dBlitEx()\hdc)
                EndIf
                
                ; create new bitmap cache
                UIOffice2003Colours(component)\dBlitEx()\hdc = CreateCompatibleDC_(hdc)
                UIOffice2003Colours(component)\dBlitEx()\bitmap = CreateCompatibleBitmap_(hdc, width, height)
                UIOffice2003Colours(component)\dBlitEx()\width = width
                UIOffice2003Colours(component)\dBlitEx()\height = height
                
                SelectObject_(UIOffice2003Colours(component)\dBlitEx()\hdc, UIOffice2003Colours(component)\dBlitEx()\bitmap)
            EndIf
            
            chdc = UIOffice2003Colours(component)\dBlitEx()\hdc
            cbitmap = UIOffice2003Colours(component)\dBlitEx()\bitmap
            cwidth = UIOffice2003Colours(component)\dBlitEx()\width
            cheight = UIOffice2003Colours(component)\dBlitEx()\height
            
        EndIf
        
        If redraw = #True
            
            ;/ render the component onto cache bitmap
            Select component
                Case #menuHotGradientColor1
                    
                    If InitGDIPlus() <> 0
                        p1.POINT
                        p1\x = 0
                        p1\y = 0
                        p2.POINT
                        p2\x = 0
                        p2\y = height-1
                        
                        CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                        CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #menuHotGradientColor1, #returnColour),getMenuColourEx(6, #menuHotGradientColor2, #returnColour),1,@colour)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
                        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                        CallFunctionFast(*GdipDeleteBrush,colour)  
                    EndIf
                    
                Case #menuHeldGradientColor1
                    
                    If InitGDIPlus() <> 0
                        p1.POINT
                        p1\x = 0
                        p1\y = 0
                        p2.POINT
                        p2\x = 0
                        p2\y = height-1
                        
                        CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                        CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #menuHeldGradientColor1, #returnColour),getMenuColourEx(6, #menuHeldGradientColor2, #returnColour),1,@colour)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
                        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                        CallFunctionFast(*GdipDeleteBrush,colour)  
                    EndIf
                    
                Case #menuBarColor  ; render gradient bar
                    
                    If InitGDIPlus() <> 0
                        p1.POINT
                        p1\x = 0
                        p1\y = 0
                        p2.POINT
                        p2\x = (width/2)-1
                        p2\y = 0
                        
                        p3.POINT
                        p3\x = (width/2)
                        p3\y = 0
                        p4.POINT
                        p4\x = width-1
                        p4\y = 0
                        
                        CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                        CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #barGradientColor1, #returnColour),getMenuColourEx(6, #barGradientColor2, #returnColour),1,@colour)
                        CallFunctionFast(*GdipCreateLineBrushI,p3,p4,getMenuColourEx(6, #barGradientColor3, #returnColour),getMenuColourEx(6, #barGradientColor4, #returnColour),1,@colour2)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width/2,height)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour2,width/2,0,(width/2)+1,height)
                        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                        CallFunctionFast(*GdipDeleteBrush,colour)
                        CallFunctionFast(*GdipDeleteBrush,colour2)
                    EndIf
                    
                Case #menuCheckboxBorder  ; render checkbox
                    
                    colour = getMenuColourEx(menuex()\style, #menuCheckboxBackground, 0)
                    border = getMenuColourEx(menuex()\style, #menuCheckboxBorder, 0)
                    
                    rc.RECT
                    rc\right = width
                    rc\bottom = height
                    FrameRect_(chdc, rc, border)
                    rc\left = rc\left+1
                    rc\right = rc\right-1
                    rc\top = rc\top+1
                    rc\bottom = rc\bottom-1
                    FillRect_(chdc, rc, colour)
                    
                Case #menuCheckboxSelectedBorder  ; render selected checkbox
                    
                    colour = getMenuColourEx(menuex()\style, #menuCheckboxSelectedBackground, 0)
                    border = getMenuColourEx(menuex()\style, #menuCheckboxSelectedBorder, 0)
                    
                    rc.RECT
                    rc\right = width
                    rc\bottom = height
                    FrameRect_(chdc, rc, border)
                    rc\left = rc\left+1
                    rc\right = rc\right-1
                    rc\top = rc\top+1
                    rc\bottom = rc\bottom-1
                    FillRect_(chdc, rc, colour)
                    
                Case #toolstripBackground1  ; render toolstrip background
                    
                    p1.POINT
                    p1\x = 0
                    p1\y = 0
                    p2.POINT
                    p2\x = 0
                    p2\y = height/2
                    CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                    CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #toolstripBackground1, #returnColour),getMenuColourEx(6, #toolstripBackground2, #returnColour),1,@colour)
                    CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,(height/2)+1)
                    
                    p1.POINT
                    p1\x = 0
                    p1\y = (height/2)+1
                    p2.POINT
                    p2\x = 0
                    p2\y = height-2
                    CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #toolstripBackground3, #returnColour),getMenuColourEx(6, #toolstripBackground4, #returnColour),1,@colour2)
                    CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour2,0,(height/2)+1,width,(height/2)-1)
                    
                    ; draw bottom shadow line
                    shadow = getMenuColourEx(6, #toolstripShadow, #returnColour)
                    CallFunctionFast(*GdipCreateSolidFill,shadow,@colour3)
                    CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour3,0,height-1,width,1)
                    
                    CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                    CallFunctionFast(*GdipDeleteBrush,colour)
                    CallFunctionFast(*GdipDeleteBrush,colour2)
                    CallFunctionFast(*GdipDeleteBrush,colour3)
                    
                Case #SelectGradientColor1
                    
                    If InitGDIPlus() <> 0
                        p1.POINT
                        p1\x = 0
                        p1\y = 0
                        p2.POINT
                        p2\x = 0
                        p2\y = height-1
                        
                        CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                        CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #SelectGradientColor1, #returnColour),getMenuColourEx(6, #SelectGradientColor2, #returnColour),1,@colour)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
                        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                        CallFunctionFast(*GdipDeleteBrush,colour)  
                    EndIf
                    
                Case #toolbarHotGradientColor1
                    
                    If InitGDIPlus() <> 0
                        p1.POINT
                        p1\x = 0
                        p1\y = 0
                        p2.POINT
                        p2\x = 0
                        p2\y = height-1
                        
                        CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                        CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #toolbarHotGradientColor1, #returnColour),getMenuColourEx(6, #toolbarHotGradientColor2, #returnColour),1,@colour)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
                        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                        CallFunctionFast(*GdipDeleteBrush,colour)  
                    EndIf
                    
            EndSelect
            
            debuglog("Created new #UISTYLE_OFFICE2003 blitCache: "+Str(component)+" Width: "+Str(width)+" Height: "+Str(height))
            
        EndIf
        
        ;/ Office 2007 Style
    ElseIf style = #UISTYLE_OFFICE2007
        
        If Dynamic = #False
            
            ; decide if to re-cache and redraw
            If UIOffice2007Colours(component)\hdc = 0
                redraw = #True
            Else
                If mode = 0
                    If width > UIOffice2007Colours(component)\width Or height > UIOffice2007Colours(component)\height
                        redraw = #True
                    EndIf
                ElseIf mode = #ForceHorizontalRedraw And (UIOffice2007Colours(component)\width <> width Or height > UIOffice2007Colours(component)\height)
                    redraw = #True
                ElseIf mode = #ForceVerticalRedraw And (UIOffice2007Colours(component)\height <> height Or width > UIOffice2007Colours(component)\width)
                    redraw = #True
                ElseIf mode = #ForceRedraw And (UIOffice2007Colours(component)\width <> width Or UIOffice2007Colours(component)\height <> height)
                    redraw = #True
                EndIf
            EndIf
            
            If redraw = #True
                ; free old bitmap cache if exists
                If UIOffice2007Colours(component)\hdc <> 0
                    DeleteObject_(UIOffice2007Colours(component)\bitmap)
                    DeleteDC_(UIOffice2007Colours(component)\hdc)
                EndIf
                
                ; create new bitmap cache
                UIOffice2007Colours(component)\hdc = CreateCompatibleDC_(hdc)
                UIOffice2007Colours(component)\bitmap = CreateCompatibleBitmap_(hdc, width, height)
                UIOffice2007Colours(component)\width = width
                UIOffice2007Colours(component)\height = height
                
                SelectObject_(UIOffice2007Colours(component)\hdc, UIOffice2007Colours(component)\bitmap)
                
            EndIf
            
            chdc = UIOffice2007Colours(component)\hdc
            cbitmap = UIOffice2007Colours(component)\bitmap
            
        Else
            
            new = #True
            ForEach UIOffice2007Colours(component)\dBlitEx()
                If mode = 0 And UIOffice2007Colours(component)\dBlitEx()\width = width And UIOffice2007Colours(component)\dBlitEx()\height = height
                    new = #False
                    Break
                ElseIf mode = #ForceHorizontalRedraw And UIOffice2007Colours(component)\dBlitEx()\width = width
                    new = #False
                    If height > UIOffice2007Colours(component)\dBlitEx()\height
                        redraw = #True
                    EndIf
                    Break
                ElseIf mode = #ForceVerticalRedraw And UIOffice2007Colours(component)\dBlitEx()\height = height
                    new = #False
                    If width > UIOffice2007Colours(component)\dBlitEx()\width
                        redraw = #True
                    EndIf
                    Break
                EndIf
            Next
            
            If new = #True Or redraw = #True
                
                If new = #True
                    AddElement(UIOffice2007Colours(component)\dBlitEx())
                    redraw = #True
                EndIf
                
                ; free old bitmap cache if exists
                If UIOffice2007Colours(component)\dBlitEx()\hdc <> 0
                    DeleteObject_(UIOffice2007Colours(component)\dBlitEx()\bitmap)
                    DeleteDC_(UIOffice2007Colours(component)\dBlitEx()\hdc)
                EndIf
                
                ; create new bitmap cache
                UIOffice2007Colours(component)\dBlitEx()\hdc = CreateCompatibleDC_(hdc)
                UIOffice2007Colours(component)\dBlitEx()\bitmap = CreateCompatibleBitmap_(hdc, width, height)
                UIOffice2007Colours(component)\dBlitEx()\width = width
                UIOffice2007Colours(component)\dBlitEx()\height = height
                
                SelectObject_(UIOffice2007Colours(component)\dBlitEx()\hdc, UIOffice2007Colours(component)\dBlitEx()\bitmap)
            EndIf
            
            chdc = UIOffice2007Colours(component)\dBlitEx()\hdc
            cbitmap = UIOffice2007Colours(component)\dBlitEx()\bitmap
            cwidth = UIOffice2007Colours(component)\dBlitEx()\width
            cheight = UIOffice2007Colours(component)\dBlitEx()\height
            
        EndIf
        
        If redraw = #True
            
            ;/ render the component onto cache bitmap
            Select component
                Case #menuHotGradientColor1
                    
                    If InitGDIPlus() <> 0
                        p1.POINT
                        p1\x = 0
                        p1\y = 0
                        p2.POINT
                        p2\x = 0
                        p2\y = height-1
                        
                        CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                        CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #menuHotGradientColor1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #menuHotGradientColor2, #returnColour),1,@colour)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
                        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                        CallFunctionFast(*GdipDeleteBrush,colour)  
                    EndIf
                    
                Case #menuHeldGradientColor1
                    
                    If InitGDIPlus() <> 0
                        p1.POINT
                        p1\x = 0
                        p1\y = 0
                        p2.POINT
                        p2\x = 0
                        p2\y = height-1
                        
                        CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                        CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #menuHeldGradientColor1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #menuHeldGradientColor2, #returnColour),1,@colour)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
                        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                        CallFunctionFast(*GdipDeleteBrush,colour)  
                    EndIf
                    
                Case #menuBarColor  ; render gradient bar
                    
                    If InitGDIPlus() <> 0
                        p1.POINT
                        p1\x = 0
                        p1\y = 0
                        p2.POINT
                        p2\x = (width/2)-1
                        p2\y = 0
                        
                        p3.POINT
                        p3\x = (width/2)
                        p3\y = 0
                        p4.POINT
                        p4\x = width-1
                        p4\y = 0
                        
                        CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                        CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #barGradientColor1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #barGradientColor2, #returnColour),1,@colour)
                        CallFunctionFast(*GdipCreateLineBrushI,p3,p4,getMenuColourEx(#UISTYLE_OFFICE2007, #barGradientColor3, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #barGradientColor4, #returnColour),1,@colour2)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width/2,height)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour2,width/2,0,(width/2)+1,height)
                        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                        CallFunctionFast(*GdipDeleteBrush,colour)
                        CallFunctionFast(*GdipDeleteBrush,colour2)
                    EndIf
                    
                Case #menuCheckboxBorder  ; render checkbox
                    
                    colour = getMenuColourEx(menuex()\style, #menuCheckboxBackground, 0)
                    border = getMenuColourEx(menuex()\style, #menuCheckboxBorder, 0)
                    
                    rc.RECT
                    rc\right = width
                    rc\bottom = height
                    FrameRect_(chdc, rc, border)
                    rc\left = rc\left+1
                    rc\right = rc\right-1
                    rc\top = rc\top+1
                    rc\bottom = rc\bottom-1
                    FillRect_(chdc, rc, colour)
                    
                Case #menuCheckboxSelectedBorder  ; render selected checkbox
                    
                    colour = getMenuColourEx(menuex()\style, #menuCheckboxSelectedBackground, 0)
                    border = getMenuColourEx(menuex()\style, #menuCheckboxSelectedBorder, 0)
                    
                    rc.RECT
                    rc\right = width
                    rc\bottom = height
                    FrameRect_(chdc, rc, border)
                    rc\left = rc\left+1
                    rc\right = rc\right-1
                    rc\top = rc\top+1
                    rc\bottom = rc\bottom-1
                    FillRect_(chdc, rc, colour)
                    
                Case #toolstripBackground1  ; render toolstrip background
                    
                    p1.POINT
                    p1\x = 0
                    p1\y = 0
                    p2.POINT
                    p2\x = 0
                    p2\y = height/2
                    CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                    CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #toolstripBackground1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #toolstripBackground2, #returnColour),1,@colour)
                    CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,(height/2)+1)
                    
                    p1.POINT
                    p1\x = 0
                    p1\y = (height/2)+1
                    p2.POINT
                    p2\x = 0
                    p2\y = height-2
                    CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #toolstripBackground3, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #toolstripBackground4, #returnColour),1,@colour2)
                    CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour2,0,(height/2)+1,width,(height/2)-1)
                    
                    ; draw bottom shadow line
                    shadow = getMenuColourEx(#UISTYLE_OFFICE2007, #toolstripShadow, #returnColour)
                    CallFunctionFast(*GdipCreateSolidFill,shadow,@colour3)
                    CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour3,0,height-1,width,1)
                    
                    CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                    CallFunctionFast(*GdipDeleteBrush,colour)
                    CallFunctionFast(*GdipDeleteBrush,colour2)
                    CallFunctionFast(*GdipDeleteBrush,colour3)
                    
                Case #SelectGradientColor1
                    
                    If InitGDIPlus() <> 0
                        p1.POINT
                        p1\x = 0
                        p1\y = 0
                        p2.POINT
                        p2\x = 0
                        p2\y = height-1
                        
                        CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                        CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #SelectGradientColor1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #SelectGradientColor2, #returnColour),1,@colour)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
                        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                        CallFunctionFast(*GdipDeleteBrush,colour)  
                    EndIf
                    
                Case #toolbarHotGradientColor1
                    
                    If InitGDIPlus() <> 0
                        p1.POINT
                        p1\x = 0
                        p1\y = 0
                        p2.POINT
                        p2\x = 0
                        p2\y = height-1
                        
                        CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
                        CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #toolbarHotGradientColor1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #toolbarHotGradientColor2, #returnColour),1,@colour)
                        CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
                        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                        CallFunctionFast(*GdipDeleteBrush,colour)  
                    EndIf
                    
            EndSelect
            
            debuglog("Created new #UISTYLE_OFFICE2007 blitCache: "+Str(component)+" Width: "+Str(width)+" Height: "+Str(height))
            
        EndIf
        
    EndIf
    
    ; render the cached component
    SelectObject_(chdc, cbitmap)
    If Dynamic = #False
        BitBlt_(hdc, *rec\left, *rec\top, width, height, chdc, 0, 0, #SRCCOPY)
    Else
        
        ;hRgn = CreateRectRgn_(*rec\left, *rec\top, *rec\right, *rec\bottom)
        ;hRgn = CreateRectRgn_(*rec\left, *rec\top, *rec\left+width, *rec\top+height)
        ;selectClipRgn_(hdc, hRgn)
        
        ;debuglog("this works: "+Str(*rec\left)+" "+Str(*rec\top)+" "+Str(width)+" "+Str(height)+" "+Str(chdc))
        BitBlt_(hdc, *rec\left, *rec\top, width, height, chdc, 0, 0, #SRCCOPY)
        
        ;SelectClipRgn_(hdc, 0)
        ;DeleteObject_(hRgn)
        
    EndIf
    
EndProcedure

;- Title shadow macros
Macro addTitleDropShadow()
    ; add drop shadows to menu title
    pnt.POINT
    pnt2.POINT
    AddElement(titleShadow())
    titleShadow()\hwnd = *nmhdr\hwndFrom
    titleShadow()\x = *nmTBCust\rc\left
    titleShadow()\y = *nmTBCust\rc\top
    If menuTitleVOffset <> -1
        pnt\x =*nmTBCust\rc\right
        pnt\y =*nmTBCust\rc\top+4
        pnt2\x =*nmTBCust\rc\left
        pnt2\y =*nmTBCust\rc\bottom
        MapWindowPoints_(*nmhdr\hwndFrom, 0, @pnt, 1)
        MapWindowPoints_(*nmhdr\hwndFrom, 0, @pnt2, 1)
        ; find nearest display monitor to edge of title
        prc.RECT
        prc\left = menuWindowXpos
        prc\top = pnt\y
        prc\right = prc\left
        prc\bottom = prc\top
        hmonitor = MonitorFromRect_(@prc, #MONITOR_DEFAULTTONEAREST)
        minfo.MONITORINFO
        minfo\cbSize = SizeOf(MONITORINFO)
        GetMonitorInfo_(hmonitor, @minfo)
        
        ; handle drawing of shadow either side of button when inbetween screens
        If pnt\x > minfo\rcWork\right
            titleShadow()\bottomShadow = dropShadow(minfo\rcWork\right, pnt2\y, (pnt\x-minfo\rcWork\right)+4, 5, colour, Alpha, #DropShadowEnd)
            pxl = 1
        ElseIf pnt2\x < menuWindowXpos
            titleShadow()\bottomShadow = dropShadow(pnt2\x+4, pnt2\y, (menuWindowXpos-pnt2\x)-4, 5, colour, Alpha, #DropShadowStart)
        EndIf
        
        titleShadow()\rightShadow = dropShadow(pnt\x, pnt\y, 5, (*nmTBCust\rc\bottom-*nmTBCust\rc\top)-5+pxl, colour, Alpha, #DropShadowVertical|#DropShadowStart)
    Else
        pnt\x =*nmTBCust\rc\right
        pnt\y =*nmTBCust\rc\top
        MapWindowPoints_(*nmhdr\hwndFrom, 0, @pnt, 1)
        titleShadow()\rightShadow = dropShadow(pnt\x, pnt\y-1, 5, (*nmTBCust\rc\bottom-*nmTBCust\rc\top)+1, colour, Alpha, #DropShadowVertical|#DropShadowStart)
        pnt\x =*nmTBCust\rc\left+4
        pnt\y =*nmTBCust\rc\bottom
        MapWindowPoints_(*nmhdr\hwndFrom, 0, @pnt, 1)
        titleShadow()\bottomShadow = dropShadow(pnt\x, pnt\y, (*nmTBCust\rc\right-*nmTBCust\rc\left), 5, colour, Alpha, 0)
    EndIf
EndMacro

Macro destroyTitleShadows()
    ; destroy title dropshadows if exists
    If ListSize(titleShadow()) > 0
        ForEach titleShadow()
            If titleShadow()\hwnd = *nmhdr\hwndFrom And titleShadow()\x = *nmTBCust\rc\left And titleShadow()\y = *nmTBCust\rc\top
                DestroyWindow_(titleShadow()\rightShadow)
                DestroyWindow_(titleShadow()\bottomShadow)
                DeleteElement(titleShadow())
                Break
            EndIf
        Next
    EndIf
EndMacro

;- render item text macro
Macro renderItemText(flags)
    
    text.s = itemex()\text
    p = FindString(text, #ShortcutCode, 1)
    If p <> 0
        Repeat
            If Mid(text, n, 1) = #ShortcutCode And Mid(text, n+1, 1) = #ShortcutCode
                text = Mid(text, 1, n)+Mid(text, n+2, Len(text))
            ElseIf Mid(text, n, 1) = #ShortcutCode And Mid(text, n+1, 1) <> #ShortcutCode
                foundShortcut = #True
                p = n
                Break
            EndIf
            n = n + 1
        Until n >= Len(text)
    EndIf
    
    If foundShortcut = #True
        txt.s = Mid(text, 1, p-1)
        shortcut.s = Mid(text, p+1)
        renderText(*item\hdc, txt, @rec, currentMenuEXFont, flags)
        rec\left = 0
        renderText(*item\hdc, shortcut, @rec, currentMenuEXFont, #DT_CALCRECT)
        width = rec\right
        rec\left = *item\rcItem\right-width-GetSystemMetrics_(#SM_CXMENUCHECK)-6
        rec\right = rec\left+width
        rec\top = *item\rcItem\top
        rec\bottom = *item\rcItem\bottom-1
        renderText(*item\hdc, shortcut, @rec, currentMenuEXFont, flags)
    Else
        renderText(*item\hdc, text, @rec, currentMenuEXFont, flags)
    EndIf
EndMacro

;- render item submenu arrow
Macro renderSubArrow()
    
    mnfo.MENUITEMINFO_Fixed
    mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    mnfo\fMask = #MIIM_SUBMENU
    GetMenuItemInfo_(*item\hwndItem, itemex()\pos, #True, @mnfo)
    
    ; if this item is a submenu draw black arrow icon
    If mnfo\hSubMenu <> 0
        width = GetSystemMetrics_(#SM_CXMENUCHECK)+2
        height = (*item\rcItem\bottom-3)-(*item\rcItem\top+3)
        
        arrowDC = CreateCompatibleDC_(*item\hdc)
        arrowBitmap = CreateCompatibleBitmap_(*item\hdc, width, height)
        SelectObject_(arrowDC, arrowBitmap)
        rc.RECT
        rc\left = 0
        rc\right = width
        rc\top = 0
        rc\bottom = height
        
        DrawFrameControl_(arrowDC, rc, #DFC_MENU, #DFCS_MENUARROW)
        TransparentBlt_(*item\hdc, *item\rcItem\right-width, *item\rcItem\top+3, width, height, arrowDC, 0, 0, width, height, RGB(255,255,255))
        DeleteDC_(arrowDC)
        DeleteObject_(arrowBitmap)
        
        ExcludeClipRect_(*item\hdc, *item\rcItem\right-width,*item\rcItem\top, *item\rcItem\right, *item\rcItem\bottom-1)
    EndIf
EndMacro

Macro renderSubArrowColour(colour)
    
    mnfo.MENUITEMINFO_Fixed
    mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    mnfo\fMask = #MIIM_SUBMENU
    GetMenuItemInfo_(itemex()\popupid, *item\itemID, 0, @mnfo)
    
    ; if this item is a submenu draw black arrow icon
    If mnfo\hSubMenu <> 0
        width = GetSystemMetrics_(#SM_CXMENUCHECK)+2
        height = (*item\rcItem\bottom-3)-(*item\rcItem\top+3)
        arrowDC = CreateCompatibleDC_(*item\hdc)
        arrowBitmap = CreateCompatibleBitmap_(*item\hdc, width, height)
        SelectObject_(arrowDC, arrowBitmap)
        rc.RECT
        rc\left = 0
        rc\right = width
        rc\top = 0
        rc\bottom = height
        
        DrawFrameControl_(arrowDC, rc, #DFC_MENU, #DFCS_MENUARROW)
        TransparentBlt_(*item\hdc, *item\rcItem\right-width, *item\rcItem\top+3, width, height, arrowDC, 0, 0, width, height, RGB(255,255,255))
        c = CreateSolidBrush_(colour)
        oldBrush = SelectObject_(*item\hdc, c)
        ExtFloodFill_(*item\hdc, *item\rcItem\right-width+(width/2)-1, *item\rcItem\top+3+(height/2)-1, 0, #FLOODFILLSURFACE)
        SelectObject_(*item\hdc, oldBrush)
        DeleteObject_(c)
        DeleteDC_(arrowDC)
        DeleteObject_(arrowBitmap)
        ExcludeClipRect_(*item\hdc, *item\rcItem\right-width,*item\rcItem\top, *item\rcItem\right, *item\rcItem\bottom-1)
    EndIf
EndMacro

Procedure drawDropDownGlyph(hdc, x, y, width, height, color)
    
    pen = CreatePen_(#PS_SOLID, 0, color)
    fill = CreateSolidBrush_(color)
    oldpen = SelectObject_(hdc, pen)
    oldfill = SelectObject_(hdc, fill)
    
    width = width - 1
    height = height - 1
    
    Dim pnt.POINT(3)
    pnt(0)\x = x+width/2
    pnt(0)\y = y+height
    pnt(1)\x = x
    pnt(1)\y = y
    pnt(2)\x = x+width
    pnt(2)\y = y
    
    Polygon_(hdc, @pnt(), 3)
    
    SelectObject_(hdc, oldpen)
    SelectObject_(hdc, oldfill)
    DeleteObject_(fill)
    DeleteObject_(pen)
    
EndProcedure



Procedure backupHDCAlpha(divertedwindow, hdc, *area.RECT)
    Static alphaImage
    
    bitmap = GetCurrentObject_(hdc, #OBJ_BITMAP)
    
    *panelexpage.panelexpages = GetProp_(divertedwindow, panelexpageAtom)
    If *panelexpage = #Null
        ProcedureReturn #False
    EndIf
    
    *panelex.panelexs = *panelexpage\panelex
    If *panelex = #Null
        ProcedureReturn #False
    EndIf
    
    If *panelex\alphaBitmap <> 0 And ImageID(*panelex\alphaBitmap) = bitmap
        found = *panelex\alphaBitmap
        hwnd = *panelex\handle
    EndIf
    
    If found <> 0
        
        CopyStructure(*area, rc.RECT, RECT)
        GetWindowOrgEx_(hdc, @p.POINT)
        
        rc\left - p\x
        rc\right - p\x
        rc\top - p\y
        rc\bottom - p\y
        
        If alphaImage = 0
            alphaImage = CreateImage(#PB_Any, rc\right-rc\left, rc\bottom-rc\top, 32)
            textdc = StartDrawing(ImageOutput(alphaImage))
            DrawingMode(#PB_2DDrawing_AllChannels)
            trc.RECT
            trc\right = width
            trc\bottom = height
            Box(trc\left, trc\top, trc\right-trc\left, trc\bottom-trc\top, RGBA(0,0,0,255))
            StopDrawing()
            ProcedureReturn 0
        EndIf
        
        StartDrawing(ImageOutput(found))
        
        If alphaImage = 0
            DrawingMode(#PB_2DDrawing_AllChannels)
        Else
            DrawingMode(#PB_2DDrawing_AlphaChannel)
            DrawImage(ImageID(alphaImage), rc\left, rc\top)
            FreeImage(alphaImage)
            alphaImage = 0
        EndIf
        
        StopDrawing()
    EndIf
    
EndProcedure

Macro FastRed(Color)
    
    Color & 255
    
EndMacro 

Macro FastGreen(Color)
    
    (Color & 65535) >> 8
    
EndMacro 

Macro FastBlue(Color)
    
    (Color & 16777215) >> 16
    
EndMacro

Macro FastAlpha(Color)
    
    ;(Color & 4294967295) >> 24
    Alpha(Color)
    
EndMacro

Macro FastRGBA(r,g,b,a)
    
    r|g<<8|b<<16|a<<24
    
EndMacro

Global alphaTextWidth
Global alphaTextHeight
Global alphaTextRgn
Procedure FilterCallback(x, y, s, t)
    Static tAlpha
    alpha = FastAlpha(t)
    
    If x < alphaTextWidth And y < alphaTextHeight
        
        If PtInRegion_(alphaTextRgn, x, y)
            
            alphaS = FastAlpha(s)
            If alphaS = 255
                tAlpha = alpha
            EndIf
            
            uAlpha = FastBlue(s)
            iAlpha = 255-uAlpha
            ;u32_Pix_A = (u32_Inv * u32_Pix_A + u32_Alpha * 255 ) / 255
            ;r = (iAlpha * Red(t) + uAlpha * Red(t)) / 255
            ;g = (iAlpha * Green(t) + uAlpha * Green(t)) / 255
            ;b = (iAlpha * Blue(t) + uAlpha * Blue(t)) / 255
            alpha = (iAlpha * tAlpha + uAlpha * 255) / 255
            
            If alphaS = 255 And alpha = 0
                alpha = 0
            EndIf
            
            If alphaS = 0 And tAlpha = 0
                alpha = (iAlpha * 0 + uAlpha * 255) / 355
            EndIf
            
        EndIf
        
    EndIf
    
    ;ProcedureReturn FastRGBA(FastRed(255), FastGreen(0), FastBlue(0), 255)
    ProcedureReturn FastRGBA(FastRed(t), FastGreen(t), FastBlue(t), alpha)
EndProcedure

Procedure ConvertToAlpha(Image, transcolor, intensity)
    
    Structure BGRA
        blue.a
        green.a
        red.a
        alpha.a
    EndStructure
    
    ;   GetObject_(bitmap, SizeOf(BITMAP), bmp.BITMAP)
    ;   *bits.BGRA = bmp\bmBits
    ;   For i=0 To bmp\bmHeight-1
    ;     For j=0 To bmp\bmWidthBytes-1 Step 4
    ;       *px.BGRA = *bits + bmp\bmWidthBytes * i + j
    ;       If *px\blue=Blue(transcolor) And *px\green=Green(transcolor) And *px\red=Red(transcolor)
    ;         *px\alpha = 0
    ;       Else
    ;         *px\alpha = intensity
    ;       EndIf
    ;     Next
    ;   Next
    
    GetObject_(Image, SizeOf(BITMAP), bmp.BITMAP)
    *bits.BGRA = bmp\bmBits
    For i=0 To bmp\bmHeight-1
        For j=0 To bmp\bmWidthBytes-1 Step 4
            *px.BGRA = *bits + bmp\bmWidthBytes * i + j
            ;       If *px\blue=Blue(transcolor) And *px\green=Green(transcolor) And *px\red=Red(transcolor)
            ;         *px\alpha = 0
            ;       Else
            ;         *px\alpha = intensity
            ;       EndIf
            *px\alpha = (*px\red+*px\green+*px\blue)
        Next
    Next
    
    ;   GetObject_(Image, SizeOf(BITMAP), bmp.BITMAP)
    ;   *bits.BGRA = bmp\bmBits
    ;   For i=0 To bmp\bmHeight-1
    ;     For j=0 To bmp\bmWidthBytes-1 Step 4
    ;       *px.BGRA = *bits + bmp\bmWidthBytes * i + j
    ; ;       If *px\blue=Blue(transcolor) And *px\green=Green(transcolor) And *px\red=Red(transcolor)
    ; ;         *px\alpha = 0
    ; ;       Else
    ; ;         *px\alpha = intensity
    ; ;       EndIf
    ;       If *px\alpha = 0
    ;         *px\alpha = intensity
    ;       Else
    ;         *px\alpha = 0
    ;       EndIf
    ;     Next
    ;   Next
    
EndProcedure


Procedure alphaText(hdc, txt.s, *rc.RECT, thisFont, style, hwnd)
    Static textImage, *trackWin.trackWindows
    
;     If hwnd <> #Null
;         
;         *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
;     
;     EndIf
;     Debug hwnd
;     If *trackWin <> #Null
;         
;         If *trackWin\rootPanelex <> #Null
;             
;             If *trackWin\windowType = #WINDOWTYPE_TOOLBAREX
;                 ;Debug "toolt " + Str(Random(255))
;                 ;If hwnd <> #Null
;                 ;    found = *trackWin\divertedBuffer
;                 ;    hdc = *trackWin\divertedDC
;                 ;Else
;                     Debug "poo"
;                     hBitmap = GetCurrentObject_(hdc, #OBJ_BITMAP)
;                     GetObject_(hBitmap, SizeOf(BITMAP), @BM.BITMAP)
;                     If BM\bmBits
;                         
;                         If Depth = 0
;                             Depth = BM\bmBitsPixel
;                         EndIf
;                 
;                         found = CreateImage(#PB_Any, BM\bmWidth, BM\bmHeight, Depth)
;                         If found <> #Null
;                             ddc = StartDrawing(ImageOutput(found))
;                             BitBlt_(ddc, 0, 0, BM\bmWidth, BM\bmHeight, hdc, 0, 0, #SRCCOPY)
;                             StopDrawing()
;                         EndIf
;                         
;                         odc = hdc
;                         hdc = *trackWin\divertedDC
;                         
;                     EndIf
;                     
;                 ;EndIf
;             EndIf
;         
;         EndIf
;     
;     EndIf
    
;     *panelexpage.panelexpages = GetProp_(hwnd, panelexpageAtom)
;     
;     If *panelexpage = #Null
;         ProcedureReturn #False
;     EndIf
;     
;     bitmap = GetCurrentObject_(hdc, #OBJ_BITMAP)
;     
;     While hwnd <> #Null And *panelexpage <> #Null
;         *panelex.panelexs = *panelexpage\panelex
;         If *panelex <> #Null And *panelex\alphaBitmap <> #Null And ImageID(*panelex\alphaBitmap) = bitmap
