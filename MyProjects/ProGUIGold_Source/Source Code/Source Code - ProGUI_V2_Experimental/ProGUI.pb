                SetSkinProperty(office2007SplitterSkin, "splitterex:black", "pressed", "gripper background", "gradient:  rgb(240,241,242), rgb(195,200,206), 0.25, rgb(240,241,242), 0.75, rgb(195,200,206);")
                SetSkinPropertyData(office2007SplitterSkin, "splitterex:black", "pressed", "gripper background image", ImageID(BlackSplitterOffice2007GripperImage))
                SetSkinProperty(office2007SplitterSkin, "splitterex:black", "pressed", "gripper background position", "x: centre; y: centre;")
                SetSkinPropertyData(office2007SplitterSkin, "splitterex:black", "pressed", "gripper border image", ImageID(BlackSplitterOffice2007BorderImage))
                SetSkinProperty(office2007SplitterSkin, "splitterex:black", "pressed", "gripper border mask", "-1;")
                
                SetSkinProperty(office2007SplitterSkin, "splitterex:grey", "pressed", "gripper background", "gradient:  rgb(240,241,242), rgb(195,200,206), 0.25, rgb(240,241,242), 0.75, rgb(195,200,206);")
                SetSkinPropertyData(office2007SplitterSkin, "splitterex:grey", "pressed", "gripper background image", ImageID(BlackSplitterOffice2007GripperImage))
                SetSkinProperty(office2007SplitterSkin, "splitterex:grey", "pressed", "gripper background position", "x: centre; y: centre;")
                SetSkinPropertyData(office2007SplitterSkin, "splitterex:grey", "pressed", "gripper border image", ImageID(BlackSplitterOffice2007BorderImage))
                SetSkinProperty(office2007SplitterSkin, "splitterex:grey", "pressed", "gripper border mask", "-1;")
                
                
        EndSelect
        
        SkinAutoUpdateRepress = #False
        
    EndIf
    
EndProcedure
