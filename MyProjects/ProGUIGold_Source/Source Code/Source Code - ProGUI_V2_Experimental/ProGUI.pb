;         EndIf
;         hwnd = GetParent_(GetParent_(hwnd))
;         *panelexpage.panelexpages = GetProp_(hwnd, panelexpageAtom)
;     Wend
    
    If found <> #False
        
        CopyStructure(*rc, rc.RECT, RECT)
        width = rc\right-rc\left
        height = rc\bottom-rc\top
        
        If width > 0 And height > 0
            
            width + 2
            
            GetWindowOrgEx_(hdc, @p.POINT)
            rc\left - p\x
            rc\right - p\x
            rc\top - p\y
            rc\bottom - p\y
            rc\left-2
            If textImage = 0 Or ImageWidth(textImage) < width Or ImageHeight(textImage) < height
                If textImage <> 0
                    FreeImage(textImage)
                EndIf
                textImage = CreateImage(#PB_Any, width, height, 32)
            EndIf
            textdc = StartDrawing(ImageOutput(textImage))
            DrawingMode(#PB_2DDrawing_AllChannels)
            trc.RECT
            trc\left+2
            trc\right = width
            trc\bottom = height
            Box(0, 0, width, height, RGBA(0,0,0,255))
            SetTextColor_(textdc, RGB(255,255,255))
            rendertext(textdc, txt, trc, thisFont, style|#DT_OVERRIDECOLOUR)
            StopDrawing()
            
            alphaTextWidth = rc\left+width
            alphaTextHeight = rc\top+height
            alphaTextRgn = CreateRectRgn_(rc\left,rc\top,rc\right,rc\bottom)
            GetClipRgn_(hdc, alphaTextRgn)
            
            StartDrawing(ImageOutput(found))
            DrawingMode(#PB_2DDrawing_AllChannels)
            CustomFilterCallback(@FilterCallback())
            DrawingMode(#PB_2DDrawing_CustomFilter)
            
            DrawImage(ImageID(textImage), rc\left, rc\top)
            
            StopDrawing()
            DeleteObject_(alphaTextRgn)
        EndIf
        
