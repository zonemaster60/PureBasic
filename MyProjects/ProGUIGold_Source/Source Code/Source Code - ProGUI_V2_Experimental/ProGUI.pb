;                         pPaintParams\dwFlags | #BPPF_ERASE
;                         pPaintParams\pBlendFunction = @blend
;                         *pPaintParams = pPaintParams
;                     EndIf

;                     sysbrush = GetSysColorBrush_(brush-1)
;                     If sysbrush <> #Null
;                         brush = sysbrush
;                     EndIf
;                     GetClientRect_(hwnd, rc.RECT)
;                     FillRect_(hdcTarget, rc, brush)
                    
            EndSelect
            
            result = BeginBufferedAnimation(hwnd, hdcTarget, *rcTarget, dwFormat, *pPaintParams, *pAnimationParams, *phdcFrom, *phdcTo)
            
            ;Debug(Str(*phdcFrom))
            ;Debug(Str(*phdcTo))
            
;             sysbrush = GetSysColorBrush_(brush-1)
;             If sysbrush <> #Null
;                 brush = sysbrush
;             EndIf
;             GetClientRect_(hwnd, rc.RECT)
;             FillRect_(*phdcFrom, rc, brush)
;             FillRect_(*phdcTo, rc, brush)
            
            ;debuglog("result: " + Str(result))
            
        Else
            result = BeginBufferedAnimation(hwnd, hdcTarget, *rcTarget, dwFormat, *pPaintParams, *pAnimationParams, *phdcFrom, *phdcTo)
        EndIf
            
    Else
        result = BeginBufferedAnimation(hwnd, hdcTarget, *rcTarget, dwFormat, *pPaintParams, *pAnimationParams, *phdcFrom, *phdcTo)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

