        EndIf
            
    Else
        result = ScrollWindowEx(hWnd, dx, dy, *prcScroll.RECT, *prcClip.RECT, hrgnUpdate, *prcUpdate, flags)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newDefWindowProc(*trackWin.trackWindows, hWnd, Msg, wParam, lParam, isANSI = #False)
    
    ;debuglog("DefWindowProc WM_NCPAINT")
    
    ;class.s = Space(255)
    ;GetClassName_(hwnd, @class, 255)
    ;debuglog("DefWindowProc " + class + " " + Str(hwnd))
    
    dc = getDivertedBuffer(*trackWin)
    GetWindowRect_(*trackWin\hwnd, rc.RECT)
    rc\right = rc\right-rc\left
    rc\bottom = rc\bottom-rc\top
    rc\left = 0
    rc\top = 0
    
    If *trackWin\divertedClipRgn <> #Null
        DeleteObject_(*trackWin\divertedClipRgn)
    EndIf
        
    *trackWin\divertedClipRgn = CreateRectRgnIndirect_(rc)
    SelectClipRgn_(dc, *trackWin\divertedClipRgn)
    
    SetWindowOrgEx_(dc, 0, 0, 0)
    
    If ThemesEnabled = #False
        
        ;debuglog("No themes")
        
        style = GetWindowLongPtr_(hWnd, #GWL_EXSTYLE)
        If style & #WS_EX_CLIENTEDGE
            ;debuglog("WS_EX_CLIENTEDGE")
            DrawEdge_(dc, rc, #BDR_SUNKENOUTER, #BF_RECT|#BF_ADJUST)
            DrawEdge_(dc, rc, #BDR_SUNKENINNER, #BF_RECT|#BF_ADJUST)
            ;DrawEdge_(dc, rc, #BDR_SUNKENINNER, #BF_RECT|#BF_FLAT)
        ElseIf style & #WS_EX_STATICEDGE
            ;debuglog("WS_EX_STATICEDGE")
            DrawEdge_(dc, rc, #BDR_SUNKENOUTER, #BF_RECT)
        ElseIf style & #WS_EX_WINDOWEDGE
            ;debuglog("WS_EX_WINDOWEDGE")
            DrawEdge_(dc, rc, #BDR_RAISEDOUTER, #BF_RECT|#BF_ADJUST)
            DrawEdge_(dc, rc, #BDR_RAISEDINNER, #BF_RECT|#BF_ADJUST)
            DrawEdge_(dc, rc, #BDR_RAISEDINNER, #BF_RECT|#BF_FLAT)
        ElseIf style & #WS_EX_DLGMODALFRAME
            ;debuglog("WS_EX_DLGMODALFRAME")
        Else
            ;debuglog("other style")
            style = GetWindowLongPtr_(hWnd, #GWL_STYLE)
            If style & #WS_BORDER
                ;debuglog("#WS_BORDER")
                DrawEdge_(dc, rc, #BDR_SUNKENOUTER, #BF_RECT|#BF_MONO)
            EndIf
        EndIf
        
        drawClassicScrollbars(*trackWin)
        
    Else
        
        If isANSI = #False
            result = DefWindowProcW(hWnd, Msg, wParam, lParam)
        Else
            result = DefWindowProcA(hWnd, Msg, wParam, lParam)
        EndIf
        
        If *trackWin\windowType = #WINDOWTYPE_LISTBOX
            DrawEdge_(dc, rc, #BDR_SUNKENOUTER, #BF_RECT|#BF_MONO|#BF_ADJUST)
            DrawEdge_(dc, rc, #BDR_RAISEDINNER, #BF_RECT|#BF_MONO)
        EndIf
        
    EndIf
    
    ProcedureReturn result
    
EndProcedure
    
Procedure newDefWindowProcW(hWnd, Msg, wParam, lParam)
    
    Select Msg
            
        Case #WM_NCPAINT
            
            *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
            If *trackWin <> #Null
                
                If *trackWin\rootPanelex <> #Null And *trackWin\windowType <> #WINDOWTYPE_PANELEX And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE
                    
                    result = newDefWindowProc(*trackWin.trackWindows, hWnd, Msg, wParam, lParam)
                    
;                     debuglog("yo bitch")
;                     CurrentDefWindowProcHwnd = hWnd
;                     *trackWin\divertedInsideDefWin = #True
;                     ;result = DefWindowProcW(hWnd, Msg, wParam, lParam)
;                     ;dc = getDivertedBuffer(*trackWin)
;                     ;brush = CreateSolidBrush_(RGB(Random(255),0,0))
;                     ;rc.RECT
;                     ;rc\right = *trackWin\divertedWidth
;                     ;rc\bottom = *trackWin\divertedHeight
;                     ;FillRect_(dc, rc, brush)
;                     ;DeleteObject_(brush)
;                     
;                     *trackWin\divertedInsideDefWin = #False
;                     CurrentDefWindowProcHwnd = #Null
                    
                Else
                    result = DefWindowProcW(hWnd, Msg, wParam, lParam)
                EndIf
                
            Else
                result = DefWindowProcW(hWnd, Msg, wParam, lParam)
            EndIf
            
        Default
        
            result = DefWindowProcW(hWnd, Msg, wParam, lParam)
            
    EndSelect
            
    ProcedureReturn result
    
EndProcedure

Procedure newDefWindowProcA(hWnd, Msg, wParam, lParam)
    
    Select Msg
            
        Case #WM_NCPAINT
            
            *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
            If *trackWin <> #Null
                
                If *trackWin\rootPanelex <> #Null And *trackWin\windowType <> #WINDOWTYPE_PANELEX And *trackWin\windowType <> #WINDOWTYPE_PANELEXPAGE
                    
                    result = newDefWindowProc(*trackWin.trackWindows, hWnd, Msg, wParam, lParam, #True)
                    
                Else
                    result = DefWindowProcA(hWnd, Msg, wParam, lParam)
                EndIf
                
            Else
                result = DefWindowProcA(hWnd, Msg, wParam, lParam)
            EndIf
            
        Default
        
            result = DefWindowProcA(hWnd, Msg, wParam, lParam)
            
    EndSelect
            
    ProcedureReturn result
    
EndProcedure

Procedure newCreateCaret(hWnd, hBitmap, nWidth, nHeight)
    
    debuglog("CreateCaret")
    
    If caret\nIDEvent <> #Null
        
        KillTimer_(0, caret\nIDEvent)
        caret\nIDEvent = #Null
        
    EndIf
    
    If nWidth = #Null
        nWidth = #SM_CXBORDER
    EndIf
    If nHeight = #Null
        nHeight = #SM_CYBORDER
    EndIf
    
    caret\width = nWidth
    caret\height = nHeight
    caret\show = #False
    caret\render = #False
    caret\hideCount = 0
    caret\blinkTime = GetCaretBlinkTime_()
    caret\activate = -1
    caret\lpos\x = -1
    caret\lpos\y = -1
    caret\hwnd = hwnd
    
    *trackWin.trackWindows = GetProp_(caret\hwnd, trackwinAtom)
    If *trackWin <> #Null
        If *trackWin\rootPanelex <> #Null
            result = #True
        Else
            result = CreateCaret(hWnd, hBitmap, nWidth, nHeight)
        EndIf
    Else
        result = CreateCaret(hWnd, hBitmap, nWidth, nHeight)
    EndIf
    ;result = #True;CreateCaret(hWnd, hBitmap, nWidth, nHeight)
    
    ProcedureReturn result
    
EndProcedure

Procedure newDestroyCaret()
    
    caret\show = #False
    caret\render = #False
    caret\activate = -1
    caret\hideCount = 0
    
    If caret\nIDEvent <> #Null
        
        KillTimer_(0, caret\nIDEvent)
        caret\nIDEvent = #Null
        
        *trackWin.trackWindows = GetProp_(caret\hwnd, trackwinAtom)
        If *trackWin <> #Null
            
            If *trackWin\rootPanelex <> #Null And *trackWin\divertedSetNoRedraw = #False
            
                debuglog("DestroyCaret")
                
                *panelex.panelexs = *trackWin\parentPanelex
                *panelexpage.panelexpages = *panelex\displayedPage
                
                updateRect.RECT
                updateRect\left = caret\pos\x
                updateRect\top = caret\pos\y
                updateRect\right = updateRect\left + caret\width
                updateRect\bottom = updateRect\top + caret\height
                MapWindowPoints_(caret\hwnd, *panelexpage\Handle, updateRect, 2)
                
                *trackWin\divertedRefresh = #True
                RefreshPanelEx(*panelex\Handle, updateRect)
                
            EndIf
            
        EndIf
        
    EndIf
    
    caret\hwnd = #Null
    
    result = DestroyCaret()
    
    ProcedureReturn result
    
EndProcedure

Procedure newShowCaret(hWnd)
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null And hwnd = caret\hwnd
        
        If *trackWin\rootPanelex <> #Null
        
            debuglog("ShowCaret " + Str(caret\show))
            
            If caret\hideCount < 2
                
                If caret\pos\x <> caret\lpos\x And caret\lpos\x <> -1
                    caret\activate = #True
                EndIf
                
                If caret\activate = #True Or *trackWin\windowType <> #WINDOWTYPE_EDIT
                    
                    If *trackWin\windowType = #WINDOWTYPE_RICHEDIT
                        SendMessage_(*trackWin\hwnd, #EM_EXGETSEL, 0, range.charrange)
                        If range\cpMin <> range\cpMax
                            selection = #True
                        EndIf
                    EndIf
                    
                    If selection = #False And *trackWin\divertedSetNoRedraw = #False
                        
                        caret\show = #True
                        caret\nIDEvent = SetTimer(0, caret\nIDEvent, caret\blinkTime, @newCaretTimerFunc())
                        
                        *panelex.panelexs = *trackWin\parentPanelex
                        *panelexpage.panelexpages = *panelex\displayedPage
                        
                        updateRect.RECT
                        updateRect\left = caret\pos\x
                        updateRect\top = caret\pos\y
                        updateRect\right = updateRect\left + caret\width
                        updateRect\bottom = updateRect\top + caret\height
                        MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
                        
                        *trackWin\divertedRefresh = #True
                        RefreshPanelEx(*panelex\Handle, updateRect)
                        
                    EndIf
                    
                EndIf
                
                If caret\activate <> #True And caret\pos\x = caret\lpos\x
                    caret\activate + 1
                EndIf
                
                result = #True
                
            Else
                result = #False
            EndIf
            
            If caret\hideCount > 0
                caret\hideCount - 1
            EndIf
            
        Else
            result = ShowCaret(hWnd)
        EndIf
        
    Else
        result = ShowCaret(hWnd)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newHideCaret(hWnd)
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null And hwnd = caret\hwnd
        
        If *trackWin\rootPanelex <> #Null
        
            debuglog("HideCaret " + Str(caret\show))
            result = #True
            
        Else
            result = HideCaret(hWnd)
        EndIf
        
        If caret\nIDEvent <> #Null
            KillTimer_(0, caret\nIDEvent)
            caret\nIDEvent = #Null
        EndIf
        
        caret\hideCount + 1
        
    Else
        result = HideCaret(hWnd)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newSetCaretPos(x, y)
    
    ;debuglog("SetCaretPos")
    
    If caret\hwnd <> #Null
        
        *trackWin.trackWindows = GetProp_(caret\hwnd, trackwinAtom)
        
        caret\pos\x = x
        caret\pos\y = y
        
        If caret\pos\x <> caret\lpos\x Or caret\pos\y <> caret\lpos\y
            If *trackWin <> #Null And *trackWin\rootPanelex <> #Null
                caret\nIDEvent = SetTimer(0, caret\nIDEvent, caret\blinkTime, @newCaretTimerFunc())
                caret\render = #True
            EndIf
        EndIf
        
        ; erase last position
        If *trackWin <> #Null And *trackWin\rootPanelex <> #Null And *trackWin\divertedSetNoRedraw = #False
            
            *panelex.panelexs = *trackWin\parentPanelex
            *panelexpage.panelexpages = *panelex\displayedPage
            
            debuglog("SetCaretPos: " + Str(caret\pos\x) + " " + Str(caret\lpos\x))
            
            updateRect.RECT
            updateRect\left = caret\epos\x
            updateRect\top = caret\epos\y
            updateRect\right = updateRect\left + caret\width
            updateRect\bottom = updateRect\top + caret\height
            MapWindowPoints_(caret\hwnd, *panelexpage\Handle, updateRect, 2)
            
            *trackWin\divertedRefresh = #True
            RefreshPanelEx(*panelex\Handle, updateRect)
            
        EndIf
        
        CopyStructure(caret\pos, caret\lpos, POINT) ; last pos
        CopyStructure(caret\pos, caret\epos, POINT) ; erase pos
        ;debuglog("caret x: " + Str(x))
        
    EndIf
    
    result = SetCaretPos(x, y)
    
    ProcedureReturn result
    
EndProcedure

Procedure newSetCaretBlinkTime(uMSeconds)
    
    ;debuglog("SetCaretBlinkTime")
    
    caret\blinkTime = uMSeconds
    
    result = SetCaretBlinkTime(uMSeconds)
    
    ProcedureReturn result
    
EndProcedure

Procedure newCaretTimerFunc(hwnd, uMsg, *idEvent, dwTime)
    
    *trackWin.trackWindows = GetProp_(caret\hwnd, trackwinAtom)
    If *trackWin <> #Null
        
        If *trackWin\rootPanelex <> #Null
        
            caret\render = 1-caret\render
            
            ;debuglog("!!! Refresh triggered from caret Timer !!! " + Str(Random(255)))
            
            If *trackWin\divertedRedraw = #False And *trackWin\divertedSetNoRedraw = #False
            
                *panelex.panelexs = *trackWin\parentPanelex
                *panelexpage.panelexpages = *panelex\displayedPage
                
                updateRect.RECT
                updateRect\left = caret\pos\x
                updateRect\top = caret\pos\y
                updateRect\right = updateRect\left + caret\width
                updateRect\bottom = updateRect\top + caret\height
                MapWindowPoints_(caret\hwnd, *panelexpage\Handle, updateRect, 2)
                
                *trackWin\divertedRefresh = #True
                RefreshPanelEx(*panelex\Handle, updateRect)
                
            EndIf
            
        EndIf
        
    EndIf
    
EndProcedure

Procedure newlpTimerFunc_(hwnd, uMsg, *idEvent, dwTime)
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null
        
        ; calculate window frame offsets
        GetWindowRect_(*trackWin\hwnd, wrc.RECT)
        MapWindowPoints_(0, *trackWin\hwnd, wrc, 2)
        
        If wrc\left < 0
           frameXOffset = -wrc\left
        EndIf
        If wrc\top < 0
           frameYOffset = -wrc\top
        EndIf
        
        wrc\left + frameXOffset
        wrc\top + frameYOffset
        wrc\right + frameXOffset
        wrc\bottom + frameYOffset
        
        If *trackWin\divertedClipRgn <> #Null
            DeleteObject_(*trackWin\divertedClipRgn)
        EndIf
        
        *trackWin\divertedClipRgn = CreateRectRgnIndirect_(wrc)
        SelectClipRgn_(*trackWin\divertedDC, *trackWin\divertedClipRgn)
        
        lpTimerFunc.lpTimerFunc = *trackWin\divertedlpTimerFunc
        result = lpTimerFunc(hwnd, uMsg, *idEvent, dwTime)
        
        If *trackWin\divertedRedraw = #False And *trackWin\divertedSetNoRedraw = #False
            
            ;debuglog("!!! Refresh triggered from Timer !!! " + Str(Random(255)))
            
            *panelex.panelexs = *trackWin\parentPanelex
            *panelexpage.panelexpages = *panelex\displayedPage
            
            GetClipBox_(*trackWin\divertedDC, updateRect.RECT)
            MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
            
            *trackWin\divertedRefresh = #True
            RefreshPanelEx(*panelex\Handle, updateRect)
        
        EndIf
        
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newlpTimerFunc(hwnd, uMsg, *idEvent, dwTime)
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null
        
        ; calculate window frame offsets
        GetWindowRect_(*trackWin\hwnd, wrc.RECT)
        MapWindowPoints_(0, *trackWin\hwnd, wrc, 2)
        
        If wrc\left < 0
           frameXOffset = -wrc\left
        EndIf
        If wrc\top < 0
           frameYOffset = -wrc\top
        EndIf
        
        If frameXOffset = 0 And frameYOffset = 0
        
            lpTimerFunc.lpTimerFunc = *trackWin\divertedlpTimerFunc
            result = lpTimerFunc(hwnd, uMsg, *idEvent, dwTime)
            
            If *trackWin\divertedRedraw = #False And *trackWin\divertedSetNoRedraw = #False
                
                ;debuglog("!!! Refresh triggered from Timer !!! " + Str(Random(255)))
                
                *panelex.panelexs = *trackWin\parentPanelex
                *panelexpage.panelexpages = *panelex\displayedPage
                
                GetClipBox_(*trackWin\divertedDC, updateRect.RECT)
                MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
                
                *trackWin\divertedRefresh = #True
                RefreshPanelEx(*panelex\Handle, updateRect)
            
            EndIf
            
        Else
            
            lpTimerFunc.lpTimerFunc = *trackWin\divertedlpTimerFunc
            result = lpTimerFunc(hwnd, uMsg, *idEvent, dwTime)
            
            If *trackWin\divertedRedraw = #False And *trackWin\divertedSetNoRedraw = #False
                
                ;debuglog("!!! Refresh triggered from Timer !!! " + Str(Random(255)))
                
                *panelex.panelexs = *trackWin\parentPanelex
                *panelexpage.panelexpages = *panelex\displayedPage
                
                GetClipBox_(*trackWin\divertedWinDC, updateRect.RECT)
                MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
                
                updateRect\left - frameXOffset
                updateRect\top - frameYOffset
                
                *trackWin\divertedRefresh = #True
                RefreshPanelEx(*panelex\Handle, updateRect)
            
            EndIf
            
        EndIf
        
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newSetTimer(hWnd, *nIDEvent, uElapse, *lpTimerFunc)
    
    If ThemesEnabled = #True
        
        *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
        If *trackWin <> #Null
            
            If *trackWin\rootPanelex <> #Null
            
                Select *trackWin\windowType
                        
                    Case #WINDOWTYPE_PANELEX, #WINDOWTYPE_PANELEXPAGE
                    
                    ; do nothing
                    
                    Default
                    ;Case #WINDOWTYPE_SYSSCROLLBAR, #WINDOWTYPE_RICHEDIT, #WINDOWTYPE_LISTBOX
                        
                        ;debuglog("SetTimer")
                        ;debuglog("*nIDEvent: " + Str(*nIDEvent))
                        ;debuglog("*lpTimerFunc: " + Str(*lpTimerFunc))
                        
                        If *lpTimerFunc <> #Null
                            *trackWin\divertedlpTimerFunc = *lpTimerFunc
                            *lpTimerFunc = @newlpTimerFunc()
                        EndIf
                        
                EndSelect
                
            EndIf
            
        EndIf
        
    EndIf
        
    result = SetTimer(hWnd, *nIDEvent, uElapse, *lpTimerFunc)
    
    ProcedureReturn result
    
EndProcedure

Procedure newWindowFromDC(hDC)
    
    hwnd = CallFunctionFast(*WindowFromDC, hDC)
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null; And *trackWin\windowType = #WINDOWTYPE_PBCONTAINER
        class.s = Space(255)
        GetClassName_(hwnd, @class, 255)
        debuglog("WindowFromDC " + class)
    EndIf
    
    ProcedureReturn hwnd
    
EndProcedure

Procedure newGetDC(hWnd)
    
    ;class.s = Space(255)
    ;GetClassName_(hwnd, @class, 255)
    ;debuglog("GetDC " + Str(hwnd) + "class: " + class + " " + Str(Random(255)))
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null
        
        If *trackWin\rootPanelex <> #Null
        
            class.s = Space(255)
            GetClassName_(hwnd, @class, 255)
            debuglog("GetDC " + class + " " + Str(hwnd))
            
            If *trackWin\windowType = #WINDOWTYPE_REBAR
                ;debuglog("getdc")
            EndIf
            
            Select *trackWin\windowType
                    
                Case #WINDOWTYPE_PANELEX, #WINDOWTYPE_PANELEXPAGE, #WINDOWTYPE_PBFRAME
                    
                    ; do nothing
                    result = GetDC(hWnd)
                    
                Default    
                ;Case #WINDOWTYPE_EDIT, #WINDOWTYPE_RICHEDIT, #WINDOWTYPE_LISTBOX, #WINDOWTYPE_LISTVIEW
                    
                    ;class.s = Space(255)
                    ;GetClassName_(hwnd, @class, 255)
                    ;debuglog("GetDC " + class + " " + Str(hwnd))
                    
                    *trackWin\divertedRefreshCount + 1
                    
                    result = GetDC(hWnd)
                    result = getDivertedBuffer(*trackWin, result, #True, #True)
                    
;                 Default
;                     
;                     result = GetDC(hWnd)
                    
            EndSelect
            
        Else
            result = GetDC(hWnd)
        EndIf
            
    Else
        result = GetDC(hWnd)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newGetDCEx(hWnd, hrgnClip, flags.l)
    
    ;class.s = Space(255)
    ;GetClassName_(hwnd, @class, 255)
    ;debuglog("GetDCEx " + class)
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null
        
        If *trackWin\rootPanelex <> #Null
        
            ;class.s = Space(255)
            ;GetClassName_(hwnd, @class, 255)
            ;debuglog("GetDCEx " + class + " " + Str(hwnd))
            
            If *trackWin\windowType = #WINDOWTYPE_REBAR
                ;debuglog("getdcex")
            EndIf
            
            Select *trackWin\windowType
                    
                Case #WINDOWTYPE_PANELEX, #WINDOWTYPE_PANELEXPAGE, #WINDOWTYPE_PBFRAME
                    
                    ; do nothing
                    result = GetDCEx(hWnd, hrgnClip, flags)
                    
                Default    
                ;Case #WINDOWTYPE_EDIT, #WINDOWTYPE_RICHEDIT, #WINDOWTYPE_LISTBOX, #WINDOWTYPE_LISTVIEW
                   
                    If flags & #DCX_WINDOW
;                         class.s = Space(255)
;                         GetClassName_(hwnd, @class, 255)
;                         debuglog("GetDCEx " + class + " " + Str(hwnd))
;                         debuglog("hrgnClip: " + Str(hrgnClip))
;                         If flags <> #Null
;                             debuglog("flags: " + Str(flags))
;                             If flags & #DCX_WINDOW
;                                 debuglog("#DCX_WINDOW")
;                             EndIf
;                             If flags & #DCX_CACHE
;                                 debuglog("#DCX_CACHE")
;                             EndIf
;                             If flags & #DCX_PARENTCLIP
;                                 debuglog("#DCX_PARENTCLIP")
;                             EndIf
;                             If flags & #DCX_CLIPSIBLINGS
;                                 debuglog("#DCX_CLIPSIBLINGS")
;                             EndIf
;                             If flags & #DCX_CLIPCHILDREN
;                                 debuglog("#DCX_CLIPCHILDREN")
;                             EndIf
;                             If flags & #DCX_NORESETATTRS
;                                 debuglog("#DCX_NORESETATTRS")
;                             EndIf
;                             If flags & #DCX_LOCKWINDOWUPDATE
;                                 debuglog("#DCX_LOCKWINDOWUPDATE")
;                             EndIf
;                             If flags & #DCX_EXCLUDERGN
;                                 debuglog("#DCX_EXCLUDERGN")
;                             EndIf
;                             ;If flags & #DCX_INTERSECTRGN
;                             ;    debuglog("#DCX_INTERSECTRGN")
;                             ;    If hrgnClip <> #Null
;                             ;        ExtSelectClipRgn_()
;                             ;    EndIf
;                             ;EndIf
;                             If flags & #DCX_INTERSECTUPDATE
;                                 debuglog("#DCX_INTERSECTUPDATE")
;                             EndIf
;                             If flags & #DCX_VALIDATE
;                                 debuglog("#DCX_VALIDATE")
;                             EndIf
;                         EndIf
;                         If hrgnClip <> #Null
;                             ;newrgn = CreateRectRgn_(0, 0, 0, 0)
;                             ;CombineRgn_(newrgn, hrgnClip, 0, #RGN_COPY)
;                         EndIf
                        
                        *trackWin\divertedRefreshCount + 1
                        
                        result = GetDCEx(hWnd, hrgnClip, flags)
                        result = getDivertedBuffer(*trackWin, result, #False, #True)
;                         If flags & #DCX_INTERSECTRGN
;                             debuglog("#DCX_INTERSECTRGN")
;                             If hrgnClip <> #Null
;                                 GetWindowRect_(*trackWin\hwnd, wrc.RECT)
;                                 MapWindowPoints_(0, *trackWin\hwnd, wrc, 2)
;                                 
;                                 If wrc\left < 0
;                                    ;frameXOffset = -wrc\left
;                                 EndIf
;                                 If wrc\top < 0
;                                    ;frameYOffset = -wrc\top
;                                 EndIf
;                                 MapWindowPoints_(0, *trackWin\hwnd, pt.POINT, 1)
;                                 ;OffsetRgn_(newrgn, pt\x+frameXOffset, pt\y+frameYOffset)
;                                 ;Debug CombineRgn_(newrgn, *trackWin\divertedClipRgn, newrgn, #RGN_AND)
;                                 ;SelectClipRgn_(*trackWin\divertedDC, newrgn)
;                                 ;ExtSelectClipRgn_(*trackWin\divertedDC, newrgn, #RGN_AND)
;                             EndIf
;                         EndIf
                        
                    Else
                        
                        result = GetDCEx(hWnd, hrgnClip, flags)
                        If flags & #DCX_CACHE ;#DCX_CACHE, #DCX_CLIPSIBLINGS
                            result = getDivertedBuffer(*trackWin, result, #True, #True, #True)
                        Else
                            result = getDivertedBuffer(*trackWin, result, #True, #True)
                        EndIf
                        
                    EndIf
                    
;                 Default
;                     
;                     result = GetDCEx(hWnd, hrgnClip, flags)
;                     
            EndSelect
            
        Else
            result = GetDCEx(hWnd, hrgnClip, flags)
        EndIf
            
    Else
        result = GetDCEx(hWnd, hrgnClip, flags)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newGetWindowDC(hWnd)
    
    ;class.s = Space(255)
    ;GetClassName_(hwnd, @class, 255)
    ;debuglog("GetWindowDC " + class + " " + Str(hwnd))
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null
        
        If *trackWin\rootPanelex <> #Null
        
            ;class.s = Space(255)
            ;GetClassName_(hwnd, @class, 255)
            ;debuglog("GetWindowDC " + class + " " + Str(hwnd))
            
            If *trackWin\windowType = #WINDOWTYPE_REBAR
                ;debuglog("getwindowdc")
            EndIf
            
            Select *trackWin\windowType
                    
                Case #WINDOWTYPE_PANELEX, #WINDOWTYPE_PANELEXPAGE, #WINDOWTYPE_PBFRAME
                    
                    ; do nothing
                    result = GetWindowDC(hwnd)
                    
                Default
                ;Case #WINDOWTYPE_SYSSCROLLBAR, #WINDOWTYPE_RICHEDIT, #WINDOWTYPE_LISTBOX, #WINDOWTYPE_LISTVIEW
                    
                    *trackWin\divertedRefreshCount + 1
                    
                    result = GetWindowDC(hwnd)
                    result = getDivertedBuffer(*trackWin, result, #False, #True)
                    
;                 Default
;                     
;                     result = GetWindowDC(hwnd)
                    
            EndSelect
            
        Else
            result = GetWindowDC(hwnd)
        EndIf
            
    Else
        result = GetWindowDC(hwnd)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

Procedure newReleaseDC(hWnd, hDC)
    
    *trackWin.trackWindows = GetProp_(hwnd, trackwinAtom)
    If *trackWin <> #Null And *trackWin\rootPanelex <> #Null
        
        If *trackWin\divertedBuffer <> #Null
            
            If *trackWin\windowType = #WINDOWTYPE_REBAR
                ;debuglog("releasedc")
            EndIf
            
            *trackWin\divertedGetIndex - 1
            If *trackWin\divertedGetIndex < 0
                *trackWin\divertedGetIndex = 0
            EndIf
            If *trackWin\divertedGetDC[*trackWin\divertedGetIndex] <> #Null
                result = ReleaseDC(hwnd, *trackWin\divertedGetDC[*trackWin\divertedGetIndex])
                isClient = *trackWin\divertedGetType[*trackWin\divertedGetIndex]
                *trackWin\divertedGetType[*trackWin\divertedGetIndex] = #Null
                *trackWin\divertedGetDC[*trackWin\divertedGetIndex] = #Null
            Else
                result = #True
            EndIf
            
            *trackWin\divertedRefreshCount - 1
            If *trackWin\divertedRefreshCount < 0
                *trackWin\divertedRefreshCount = 0
            EndIf
            
            If *trackWin\divertedRedraw = #False And *trackWin\divertedSetNoRedraw = #False; And *trackWin\divertedGetIndex = 0; And *trackWin\divertedRefreshCount = 0 ;And *trackWin\divertedGetIndex = 0
                
                class.s = Space(255)
                GetClassName_(hwnd, @class, 255)
                debuglog("ReleaseDC " + class + " " + Str(hwnd))
                ;debuglog("!!! Refresh triggered from ReleaseDC !!!")
                
                If *trackWin\windowType = #WINDOWTYPE_RICHEDIT
                    ;debuglog("refresh")
                EndIf
                
                GetWindowRect_(*trackWin\hwnd, wrc.RECT)
                MapWindowPoints_(0, *trackWin\hwnd, wrc, 2)
                
                If wrc\left < 0
                   frameXOffset = -wrc\left
                EndIf
                If wrc\top < 0
                   frameYOffset = -wrc\top
                EndIf
                
                If isClient = #True Or (isClient = #False And frameXOffset = 0 And frameYOffset = 0)
                    
                    *panelex.panelexs = *trackWin\parentPanelex
                    *panelexpage.panelexpages = *panelex\displayedPage
                    
                    GetClipBox_(*trackWin\divertedDC, updateRect.RECT)
                    ;GetRgnBox_(*trackWin\divertedClipRgn, updateRect.RECT)
                    MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
                    ;updateRect\left - frameXOffset
                    ;updateRect\top - frameYOffset
                    
                    If *trackWin\windowType = #WINDOWTYPE_CALENDAR
                        RedrawWindow_(*trackWin\hwnd, 0, 0, #RDW_INVALIDATE|#RDW_ERASENOW)
                    EndIf
                    
                    *trackWin\divertedRefresh = #True
                    RefreshPanelEx(*panelex\Handle, updateRect)
                    
                ElseIf isClient = #False
                    
                    *panelex.panelexs = *trackWin\parentPanelex
                    *panelexpage.panelexpages = *panelex\displayedPage
                    
                    GetClipBox_(*trackWin\divertedWinDC, updateRect.RECT)
                    ;GetRgnBox_(*trackWin\divertedWinClipRgn, updateRect.RECT)
                    ;IntersectRect_(updateRect, cupdateRect, updateRect)
                    ;GetWindowRect_(hwnd, updateRect.RECT)
                    ;MapWindowPoints_(hwnd, 0, updateRect, 2)
                    ;updateRect\left - frameXOffset*2
                    ;updateRect\top - frameYOffset*2
                    ;updateRect\right - frameXOffset
                    ;updateRect\bottom - frameYOffset
                    updateRect\left - frameXOffset
                    updateRect\top - frameYOffset
                    ;updateRect\right + frameXOffset
                    ;updateRect\bottom + frameYOffset
                    MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
                    
                    *trackWin\divertedRefresh = #True
                    RefreshPanelEx(*panelex\Handle, updateRect)
                    
                EndIf
                
;                 *panelex.panelexs = *trackWin\parentPanelex
;                 *panelexpage.panelexpages = *panelex\displayedPage
;                 
;                 GetClipBox_(*trackWin\divertedDC, updateRect.RECT)
;                 updateRect\left - frameXOffset
;                 updateRect\top - frameYOffset
;                 MapWindowPoints_(hwnd, *panelexpage\Handle, updateRect, 2)
;                 
;                 *trackWin\divertedRefresh = #True
;                 RefreshPanelEx(*panelex\Handle, updateRect)
                
            EndIf
            
        Else
            result = ReleaseDC(hwnd, hDC)
        EndIf
        
    Else
        result = ReleaseDC(hwnd, hDC)
    EndIf
    
    ProcedureReturn result
    
EndProcedure

