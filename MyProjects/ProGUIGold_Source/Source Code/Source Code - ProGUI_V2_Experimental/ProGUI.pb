                SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "background position", "right: 4; top: 50%; masked: true;")
                SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "image", "noclip: true;")
                SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "image position", "x: 0%; y: 50%;")
