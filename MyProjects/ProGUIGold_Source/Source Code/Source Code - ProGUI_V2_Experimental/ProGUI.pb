;     
;     gInsctX = 0
;     gInsctY = 0
;     ProcedureReturn(#False);
;   EndIf
;   
;   ;Is the intersection along the line segments?
;   mua = numera / denom
;   mub = numerb / denom
;   If (mua < 0 Or mua > 1 Or mub < 0 Or mub > 1)
