;   numerb = (x2-x1) * (y1-y3) - (y2-y1) * (x1-x3)
;   
;   ;Are the lines coincident?
;   If( (Abs(numera) < DBL_EPSILON) And (Abs(numerb) < DBL_EPSILON) And (Abs(denom) < DBL_EPSILON) )
