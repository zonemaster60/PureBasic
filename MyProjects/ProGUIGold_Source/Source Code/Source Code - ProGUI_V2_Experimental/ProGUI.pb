;                         setGraphToolTipXY(*graph, hwnd)
;                         
;                         RefreshGraph(*graph\handle)
                        
                    Case GL_Command_ZoomIn
                        
;                         glzoom.d = #GL_ZoomFactor
;                         
;                         ; if zoomed beyond max floating point precision then exit
;                         If Len(StringField(StrD(*graph\xAxisMax), 2, ".")) > #GL_ZoomMaxFloatingPointPrecision Or Len(StringField(StrD(*graph\yAxisMax), 2, ".")) > #GL_ZoomMaxFloatingPointPrecision
;                             ProcedureReturn #False
