                SetSkinProperty(sysXBarSkin, "explorerbar group header", "pressed", "cursor", "hand;")
                If XPthemeActive <> #False
                    i.f = 1.3
                    tfcolour = RGB(Red(fcolour)*i, Green(fcolour)*i, Blue(fcolour)*i)
                    tfcolour = AlphaBlendColour(tfcolour, RGB(255,255,255), 50)
                    SetSkinProperty(sysXBarSkin, "explorerbar group header", "pressed", "text", "font: "+fname+", "+Str(fheight)+", bold; colour: rgb("+Str(Red(tfcolour))+","+Str(Green(tfcolour))+","+Str(Blue(tfcolour))+")")
                EndIf
                ; disabled
                SetSkinProperty(sysXBarSkin, "explorerbar group header", "disabled", "background", "4;")
