                    SetSkinProperty(sysXBarSkin, "explorerbar group item", "pressed", "text", "font: "+fname+", "+Str(fheight)+", underline"+"; colour: rgb("+Str(Red(tfcolour))+","+Str(Green(tfcolour))+","+Str(Blue(tfcolour))+")")
