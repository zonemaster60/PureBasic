                        rgn = CreateRectRgn_(0, 0, 0, 0)
                        SelectClipRgn_(*trackWin\divertedOriginalDC, rgn)
                        DeleteObject_(rgn)
                        hdcTarget = *trackWin\divertedOriginalDC
