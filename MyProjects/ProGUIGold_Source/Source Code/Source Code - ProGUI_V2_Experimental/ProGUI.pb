CompilerIf #PB_Compiler_Processor = #PB_Processor_x86
    Import "LDE64.lib"
        LDE(*hAddr, hSize)
    EndImport
CompilerElse
    Import "LDE64x64.lib"
        LDE(*hAddr, hSize)
    EndImport
CompilerEndIf

Structure opcodes
    opcode.a[15]
EndStructure

#JMPopcodeLen = 5
#hookMemSize = $1000

Global *hookMem
Global LDEX64

CompilerIf #PB_Compiler_Processor = #PB_Processor_x64
    LDEX64 = 64
CompilerEndIf

Procedure hook(lib, functionName.s, *newFunc, *originalFunc.integer)
    
    Static *nextHookMem
    
    If *hookMem = #False
        *hookMem = VirtualAlloc_(#Null, #hookMemSize, #MEM_RESERVE | #MEM_COMMIT, #PAGE_EXECUTE_READWRITE)
        If Not *hookMem
            ProcedureReturn #False
        EndIf
        *nextHookMem = *hookMem
        debuglog("*hookmem: " + Hex(*hookMem))
    EndIf
    
    debuglog("")
    debuglog("Hook " + functionName)
    
    *function = GetFunction(lib, functionName)
    If *function <> #Null
    
        ; check first instruction of *function
        *asm.opcodes = *function
        If *asm\opcode[0] = $EB ; if short relative jmp (hot patch) then overwrite jmp dest instead
            debuglog("Found short relative jmp (hot patch) !!")
            *dispb.byte = *asm + 1 ; displacement
            *asm = *function + *dispb\b + 2 ; calculate destination virtual address
            *function = *asm
        EndIf
        Repeat
            opcodelen = LDE(*asm, LDEX64)
            If opcodelen = -1
                ProcedureReturn #False
            EndIf
            totalLen + opcodelen
            *asm + opcodelen
        Until totalLen >= #JMPopcodeLen
        
        hookMemSize = totalLen + #JMPopcodeLen ; + 5 bytes for jmp opcode back to orignal func
        
        If VirtualProtect_(*function, totalLen, #PAGE_EXECUTE_READWRITE, @oldProtect) = #False
            ProcedureReturn #False
        EndIf
        
        ; copy stolen bytes from original func into next free space in our trampoline memory area
        CopyMemory(*function, *nextHookMem, totalLen)
        
        ; check our stolen bytes for any relative calls and if found, patch using the new location 
        *asm = *nextHookMem
        Repeat
            opcodelen = LDE(*asm, LDEX64)
            If opcodelen = -1
                ProcedureReturn #False
            EndIf
            If *asm\opcode[0] = $E8
                debuglog("Found relative call !!")
                *pl.long = *asm + 1
                *origAddress = (*function + (*asm-*nextHookMem)) + *pl\l + 5
                debuglog("*origAddress: " + Hex(*origAddress))
                *pl\l = *origAddress - *asm - 5 ; patch using new relative location
            EndIf
            *asm + opcodelen
            tlen + opcodelen    
        Until tlen = totalLen
        
        ; tap onto the end of stolen bytes a relative jmp back to original func just after stolen bytes length
        *pb.ascii = *nextHookMem + totalLen
        *pb\a = $E9 ; relative jmp
        *pl.long = *pb + 1
        *pl\l = (*function + totalLen) - (*nextHookMem + totalLen) - 5
        
        ; replace start of orignal func with relative jmp to new diverted func
        *pb.ascii = *function
        *pb\a = $E9
        *pl.long = *pb + 1
        *pl\l = *newFunc - *function - 5
        
        debuglog("func:    " + Hex(*function))
        debuglog("newFunc: " + Hex(*newFunc))
        debuglog("hookMem: " + Hex(*nextHookMem) + " size: " + Str(totalLen) + " bytes")
        
        VirtualProtect_(*function, totalLen, oldProtect, @oldProtect)
        
        *originalFunc\i = *nextHookMem
        
        *nextHookMem + hookMemSize
        
        ProcedureReturn #True
        
    Else
        debuglog("Function not found.")
    EndIf
    
    ProcedureReturn #False
    
EndProcedure

CompilerIf #PB_Compiler_Processor = #PB_Processor_x64
  #lib$ = "MinHook.x64.lib"
CompilerElse
  #lib$ = "MinHook.x86.lib"
CompilerEndIf

Import #lib$
  MH_Initialize()
  MH_CreateHook(*pTarget, *pDetour, *ppOriginal)
  MH_CreateHookApiEx(pszModule.p-unicode, pszProcName.p-ascii, *pDetour, *ppOriginal, *ppTarget)
  MH_EnableHook(*pTarget)
  MH_DisableHook(*pTarget)
  MH_RemoveHook(*pTarget)
  MH_QueueEnableHook(*pTarget)
  MH_QueueDisableHook(*pTarget)
  MH_ApplyQueued()
  MH_Uninitialize()
EndImport

