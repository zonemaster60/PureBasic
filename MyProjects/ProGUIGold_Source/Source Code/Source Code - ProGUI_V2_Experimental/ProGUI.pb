                ;- **** radio button
            Case "sysradiobuttonskin"
                
                ; radio button
                ; system radio normal state theme image
                w = 16 : h = 16
                Global themeRadioButtonNormalImage = CreateImage(#PB_Any, w, h, 32)
                hdc = StartDrawing(ImageOutput(themeRadioButtonNormalImage))
                DrawingMode(#PB_2DDrawing_AllChannels)
                Box(0, 0, w, h, RGBA(125, 125, 125, 0))
                rc.RECT
                rc\left = 0
                rc\top = 0
                rc\right = w
                rc\bottom = h
                If ThemesEnabled = #True
                    CallFunctionFast(*DrawThemeBackground, hThemeButton, hdc, 2, 0, @rc, 0)
                Else
                    Box(0, 0, w, h, RGBA(0, 255, 0, 0))
                    rc\left + 1
                    rc\top + 1
                    rc\bottom - 1
                    rc\right - 1
                    DrawFrameControl_(hdc, rc, #DFC_BUTTON, #DFCS_BUTTONRADIO)
                    DrawingMode(#PB_2DDrawing_AlphaChannel)
                    Box(0, 0, w, h, RGBA(0, 0, 0, 255))
                    DrawingMode(#PB_2DDrawing_AllChannels)
                    FillArea(0, 0, -1, RGBA(255,255,255, 0))
