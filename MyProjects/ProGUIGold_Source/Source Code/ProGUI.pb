  index.b
  dontdraw.b ; used for diverted drawing in panelex etc
  
  skin.i ; stores handle of current skin
  componentname.s ; stores overide skin component name
  txt.s ; used to store the text of the skinned buttonex
  bk.i[#buttonexstates]
  bkstyle.i[#buttonexstates]
  bkx.i[#buttonexstates]
  bky.i[#buttonexstates]
  obk.i[#buttonexstates]
  obkstyle.i[#buttonexstates]
  obkx.i[#buttonexstates]
  obky.i[#buttonexstates]
  bkimage.i[#buttonexstates] ; used for storing background image in skinned buttonex
  bkwidth.i[#buttonexstates]
  bkheight.i[#buttonexstates]
  obkimage.i[#buttonexstates] ; overlay
  obkwidth.i[#buttonexstates]
  obkheight.i[#buttonexstates]
  border.i[#buttonexstates] ; used for storing background border in skinned buttonex
  borderrect.RECT[#buttonexstates]
  mask.i[#buttonexstates] ; mask
  imgx.i[#buttonexstates] ; used for positioning image in skinned buttonex
  imgy.i[#buttonexstates] ; used for positioning image in skinned buttonex
  imgxpercent.i[#buttonexstates] ; used for storing x positioning style of image in skinned buttonex
  imgypercent.i[#buttonexstates] ; used for storing y positioning style of image in skinned buttonex
  imgalign.i[#buttonexstates]
  imgpad.paddings[#buttonexstates]
  txtx.i[#buttonexstates]
  txty.i[#buttonexstates]
  txtxpercent.i[#buttonexstates]
  txtypercent.i[#buttonexstates]
  txtalign.i[#buttonexstates]
  txtpad.paddings[#buttonexstates]
  font.i[#buttonexstates] ; used to store text font of skinned buttonex
  fontcolour.i[#buttonexstates]
  cursor.i[#buttonexstates] ; mouse pointer cursor handle
  
  radioGroup.i ; used with radio button, stores group number
  
  toggle.b ; used for flagging whether a togglebutton or not
  radio.b ; used for flagging whether a radio button or not
  check.b ; used for flagging whehter a check button or not
EndStructure

