ProcedureDLL SetMenuExFont(fontID.i) ; Sets the font that MenuExs use for rendering text
  
  macro_protectCommand()
  
  CompilerIf #LIBRARY = 1
    If IsFont(fontID)
      fontID = FontID(fontID)
    EndIf
  CompilerEndIf
  
  If GetObjectType_(fontID) <> #OBJ_FONT
    ProcedureReturn 0
  EndIf
  
  If GetObject_(fontID, SizeOf(LOGFONT), @fontnfo.LOGFONT) <> 0
    DeleteObject_(currentMenuEXFont)
    currentMenuEXFont = CreateFontIndirect_(fontnfo)
  Else  
    ProcedureReturn #False
  EndIf
  
  minfo.MENUITEMINFO_Fixed
  minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
  minfo\fMask = #MIIM_BITMAP
  LockMutex(menuMutex)
  ForEach menuex()
    
    menuex()\bufferWidth = 0
    menuex()\bufferHeight = 0
    
    If menuex()\singleMenu = 0
      
      ; change our current menuex font to the new menu font
      hdc = CreateCompatibleDC_(0)
      SelectObject_(hdc, currentMenuEXFont)
      
      ; get old height of toolbar
      oldheight = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)
      oldheight = (oldheight>>16)
      
      ; re-calc the toolbar button dimensions with the new font
      buttontxt.s = ""
      bufflen = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, 0)
      If bufflen > 0
        CompilerIf #PB_Compiler_Unicode
          bufflen = bufflen * 2
        CompilerEndIf
        *mem = AllocateMemory(bufflen+2)
        SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, *mem)
        buttontxt = PeekS(*mem, bufflen)
        FreeMemory(*mem)
      EndIf
      
      DrawText_(hdc, buttontxt, Len(buttontxt), @rec.RECT, #DT_SINGLELINE | #DT_CALCRECT)
      
      DeleteDC_(hdc)
      
      buttoni.TBBUTTONINFO
      buttoni\cbSize = SizeOf(TBBUTTONINFO)
      buttoni\dwMask = #TBIF_SIZE
      buttoni\cx = rec\right+#MENUEXPADX
      
      ; reset menu bar height if font too small
      If rec\bottom+#MENUEXPADY < #MENUEXMINHEIGHT
        rec\bottom = #MENUEXMINHEIGHT - #MENUEXPADY
      EndIf
      
      ; 2003 style
      If menuex()\style = 6
        buttoni\cx = buttoni\cx - 2
        rec\bottom = rec\bottom - 3
      EndIf
      
      SendMessage_(menuex()\toolbarID, #TB_SETBUTTONSIZE, 0, MakeLong(0, rec\bottom+#MENUEXPADY))
      SendMessage_(menuex()\toolbarID, #TB_SETBUTTONINFO, menuex()\buttonID, @buttoni)
      
      ; check if the toolbar is in a rebar
      ForEach rebarGadget()
        If GetParent_(menuex()\toolbarID) = rebarGadget()\Handle
          
          ; find bar that our toolbar is contained in
          max = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0,0)
          For n = 0 To max
            band.REBARBANDINFO
            band\cbSize = SizeOf(REBARBANDINFO)
            band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
            SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, n, @band)
            
            dwBtnSize = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)>>16
            If band\hwndChild = menuex()\toolbarID
              
              ; calc old height delta between toolbar and band
              hdelta = band\cyMinChild-oldheight
              
              ; set rebar band's new height
              band\fMask = #RBBIM_CHILDSIZE
              band\cyMinChild = dwBtnSize+hdelta
              SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, n, @band)
              
              Break
            EndIf
          Next
          
          Break
        EndIf
      Next
      
    EndIf
    
    For n = 0 To GetMenuItemCount_(menuex()\popupid)-1
      SetMenuItemInfo_(menuex()\popupid, n, #True, @minfo)
    Next
  Next
  
  UnlockMutex(menuMutex)
  ProcedureReturn #True

EndProcedure

ProcedureDLL GetMenuExFont() ; Gets the font that MenuExs use for rendering text
  
  macro_protectCommand()
  
  ProcedureReturn currentMenuEXFont
  
EndProcedure

ProcedureDLL MenuExID(id.l)
  
  LockMutex(menuMutex)
  ForEach menuex()
    If menuex()\id = id And menuex()\toolbarID = -1
      ret = menuex()\popupid
      Break
    ElseIf menuex()\id = id And menuex()\toolbarID <> -1
      ret = menuex()\toolbarid
      Break
    EndIf
  Next
  
  UnlockMutex(menuMutex)
  ProcedureReturn ret
EndProcedure

ProcedureDLL DisableMenuItemEx(menu.i, itemID.l, state.b)
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  ;check that menu exists, search by id or handle
  ForEach menuex()
    If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
      
      count = GetMenuItemCount_(menuex()\popupid)
      For n = 0 To count
        
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_ID
        If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) <> 0
          found = #True
          Break 2
        EndIf
      Next
      
    EndIf
  Next
  
  If found = #True
    minfo.MENUITEMINFO_Fixed
    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    minfo\fMask = #MIIM_STATE|#MIIM_DATA
    If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) = 0
      UnlockMutex(menuMutex)
      ProcedureReturn 0
    EndIf
    oldstate = minfo\fState
    
    ChangeCurrentElement(itemex(), minfo\dwItemData)
      
    If state <> 0
      oldstate = oldstate & ~#MFS_ENABLED
      minfo\fState = oldstate|#MFS_GRAYED
      ; disable automatic shortcut if found in text  
      autoHotKey(menuex()\WindowID, -1, itemex()\text)
    Else
      oldstate = oldstate & ~#MFS_GRAYED
      minfo\fState = oldstate|#MFS_ENABLED
      ; add automatic shortcut if found in text
      autoHotKey(menuex()\WindowID, itemID, itemex()\text)
    EndIf
    
    minfo\fMask = #MIIM_STATE
    If SetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) <> 0
      menuex()\bufferWidth = 0
      menuex()\bufferHeight = 0
      UnlockMutex(menuMutex)
      ProcedureReturn #True
    Else
      UnlockMutex(menuMutex)
      ProcedureReturn 0
    EndIf
  EndIf
  
  UnlockMutex(menuMutex)
  ProcedureReturn 0
  
EndProcedure


ProcedureDLL SetMenuExItemState(menu.i, itemID.l, state.l) ; Sets a menu item checkbox/radiocheck state
  
  macro_protectCommand()
  
  Static groupNo.l
  Static radioGroupActive.l
  
  LockMutex(menuMutex)
  
  ;check that menu exists, search by id or handle
  found = 0
  ForEach menuex()
    If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
      
      For n = 0 To count
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_ID
        If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) <> 0
          found = #True
          Break 2
        EndIf
      Next
      
    EndIf
  Next
  
  If found = #True
    
    minfo.MENUITEMINFO_Fixed
    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    minfo\fMask = #MIIM_DATA|#MIIM_STATE
    If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) = 0
      UnlockMutex(menuMutex)
      ProcedureReturn #False
    EndIf
    ChangeCurrentElement(itemex(), minfo\dwItemData)
    
    oldstate = minfo\fState
    
    If state & #ItemEx_UseIcon
      itemex()\checkIcon = #True
    ElseIf Not state & #ItemEx_UseIcon
      itemex()\checkIcon = #False
    EndIf
    
    If state & #ItemEx_ShowCheckbox
      
      minfo.MENUITEMINFO_Fixed
      minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
      minfo\fMask = #MIIM_STATE
      minfo\fState = oldstate | #MFS_CHECKED
      
      popupid = menuex()\popupid
      *thisMenuEx = @menuex()
      *thisItemEx = @itemex()
      UnlockMutex(menuMutex)
      ret = SetMenuItemInfo_(popupid, itemID, 0, minfo)
      LockMutex(menuMutex)
      ChangeCurrentElement(menuex(), *thisMenuEx)
      ChangeCurrentElement(itemex(), *thisItemEx)
      If ret = 0
        UnlockMutex(menuMutex)
        ProcedureReturn #False
      EndIf
      
    ElseIf state & #ItemEx_ShowRadiocheck
      
      If itemex()\radiocheck = 0
        
        ; if this is a new radiocheck on new window then new group
        If radioGroupActive <> 0 And radioGroupActive <> menuex()\popupid
          groupNo = groupNo + 1
        EndIf
        
        itemex()\radiocheck = #True
        itemex()\groupNo = groupNo
        minfo\fMask = #MIIM_STATE
        minfo\fState = oldstate | #MFS_CHECKED
        minfo\fType = #MFT_RADIOCHECK
        
        popupid = menuex()\popupid
        *thisMenuEx = @menuex()
        *thisItemEx = @itemex()
        UnlockMutex(menuMutex)
        SetMenuItemInfo_(popupid, itemID, 0, minfo)
        LockMutex(menuMutex)
        ChangeCurrentElement(menuex(), *thisMenuEx)
        ChangeCurrentElement(itemex(), *thisItemEx)
        
        radioGroupActive = menuex()\popupid
        
        ; remove bullet from any previous same group radiochecks created
        thisPos = itemex()\pos
        ForEach itemex()
          If itemex()\groupNo = groupNo And itemex()\radiocheck = #True And itemex()\pos <> thisPos
            minfo.MENUITEMINFO_Fixed
            minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
            minfo\fMask = #MIIM_STATE
            GetMenuItemInfo_(itemex()\popupid, itemex()\pos, #True, @minfo)
            oldstate = minfo\fState
            
            minfo\fMask = #MIIM_STATE
            minfo\fState = oldstate & ~#MFS_CHECKED
            
            popupid = itemex()\popupid
            pos = itemex()\pos
            *thisMenuEx = @menuex()
            *thisItemEx = @itemex()
            UnlockMutex(menuMutex)
            SetMenuItemInfo_(popupid, pos, #True, minfo)
            LockMutex(menuMutex)
            ChangeCurrentElement(menuex(), *thisMenuEx)
            ChangeCurrentElement(itemex(), *thisItemEx)
          EndIf
        Next
        
      Else  ; item already a radiocheck, make it the current selection and deselect all others in group
        
        thisGroup = itemex()\groupNo
        thisPos = itemex()\pos
        
        minfo\fMask = #MIIM_STATE
        minfo\fState = oldstate | #MFS_CHECKED
        minfo\fType = #MFT_RADIOCHECK
        
        popupid = menuex()\popupid
        *thisMenuEx = @menuex()
        *thisItemEx = @itemex()
        UnlockMutex(menuMutex)
        SetMenuItemInfo_(popupid, itemID, 0, minfo)
        LockMutex(menuMutex)
        ChangeCurrentElement(menuex(), *thisMenuEx)
        ChangeCurrentElement(itemex(), *thisItemEx)
        
        ForEach itemex()
          If itemex()\groupNo = thisGroup And itemex()\radiocheck = #True And itemex()\pos <> thisPos
            minfo.MENUITEMINFO_Fixed
            minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
            minfo\fMask = #MIIM_STATE
            GetMenuItemInfo_(itemex()\popupid, itemex()\pos, #True, @minfo)
            oldstate = minfo\fState
            
            minfo\fMask = #MIIM_STATE
            minfo\fState = oldstate & ~#MFS_CHECKED
            
            popupid = itemex()\popupid
            pos = itemex()\pos
            *thisMenuEx = @menuex()
            *thisItemEx = @itemex()
            UnlockMutex(menuMutex)
            SetMenuItemInfo_(popupid, pos, #True, minfo)
            LockMutex(menuMutex)
            ChangeCurrentElement(menuex(), *thisMenuEx)
            ChangeCurrentElement(itemex(), *thisItemEx)
          EndIf
        Next
      EndIf
      
    ElseIf state = 0
      
      minfo.MENUITEMINFO_Fixed
      minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
      minfo\fMask = #MIIM_STATE
      oldstate = oldstate & ~#MFS_CHECKED
      minfo\fState = oldstate|#MFS_UNCHECKED
      
      popupid = menuex()\popupid
      *thisMenuEx = @menuex()
      *thisItemEx = @itemex()
      UnlockMutex(menuMutex)
      ret = SetMenuItemInfo_(popupid, itemID, 0, minfo)
      LockMutex(menuMutex)
      ChangeCurrentElement(menuex(), *thisMenuEx)
      ChangeCurrentElement(itemex(), *thisItemEx)
      If ret = 0
        UnlockMutex(menuMutex)
        ProcedureReturn #False
      EndIf
      
    EndIf
    
    If state & #ItemEx_EndRadiocheckGroup
      groupNo = groupNo + 1
      radioGroupActive = 0
    EndIf
    
    menuex()\bufferWidth = 0
    menuex()\bufferHeight = 0
    
    UnlockMutex(menuMutex)
    ProcedureReturn #True
  EndIf
  
  If state & #ItemEx_EndRadiocheckGroup
    groupNo = groupNo + 1
    radioGroupActive = 0
    UnlockMutex(menuMutex)
    ProcedureReturn #True
  EndIf
  
  UnlockMutex(menuMutex)
  ProcedureReturn #False
  
EndProcedure

ProcedureDLL GetMenuExItemState(menu.i, itemID.l) ; Gets a menu item checkbox/radiocheck state
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  ;check that menu exists, search by id or handle
  found = 0
  ForEach menuex()
    If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
      
      For n = 0 To count
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_ID
        If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) <> 0
          found = #True
          Break 2
        EndIf
      Next
      
    EndIf
  Next
  
  If found = #True
    minfo.MENUITEMINFO_Fixed
    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    minfo\fMask = #MIIM_STATE
    If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) = 0
      UnlockMutex(menuMutex)
      ProcedureReturn -1
    EndIf
    If minfo\fState & #MFS_CHECKED
      UnlockMutex(menuMutex)
      ProcedureReturn #True
    ElseIf Not minfo\fState & #MFS_CHECKED
      UnlockMutex(menuMutex)
      ProcedureReturn #False
    EndIf
  EndIf
  
  UnlockMutex(menuMutex)
  ProcedureReturn -1
EndProcedure

ProcedureDLL CalcMenuItemWidth(menu.i) ; Calculates the width of a popup menu
  
  GetMenuItemRect_(0, menu, n, @reccy.RECT)
  If reccy\right-reccy\left <> 0
    ProcedureReturn reccy\right-reccy\left+6
  EndIf
  
  menuWidth.l = 0
  items = GetMenuItemCount_(menu)
  
  x = 0
  If items <> -1
    rec.RECT
    minfo.MENUITEMINFO_Fixed
    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    minfo\fMask = #MIIM_FTYPE|#MIIM_DATA|#MIIM_STRING|#MIIM_SUBMENU
    
    For n = 0 To items-1

      width = 0
      minfo\cch = 0
      minfo\dwTypeData = 0
      
      text.s = ""
      GetMenuItemInfo_(menu, n, #True, @minfo)
      
      ; if the menu item is our custom menu item
      If minfo\fType & #MFT_OWNERDRAW
        
        width = measureMenuWidth(minfo\dwItemData)
        
        p = GetSystemMetrics_(#SM_CXMENUSIZE)
        
        If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003
          p = p - 2
        ElseIf menuex()\style = #UISTYLE_OFFICE2007
          p = p + 1
        EndIf
        width = width + p
        
        If minfo\hSubMenu <> 0
          ;width = width + GetSystemMetrics_(#SM_CXMENUSIZE)+2
        EndIf
        
      Else
        
        If minfo\cch > 0
          CompilerIf #PB_Compiler_Unicode
            *mem = AllocateMemory(minfo\cch*2+2)
          Else
            *mem = AllocateMemory(minfo\cch+2)
          CompilerEndIf
          
          minfo\dwTypeData = @*mem
          minfo\cch = minfo\cch+1
          GetMenuItemInfo_(menu, n, #True, @minfo)
          text = PeekS(minfo\dwTypeData)
          FreeMemory(*mem)
          
          width = (GetSystemMetrics_(#SM_CXMENUCHECK)*2.5)+12
          
          hdc = CreateCompatibleDC_(0)
          
          oldFont = SelectObject_(hdc, currentMenuEXFont)
          
          DrawText_(hdc, text, Len(text), @rec, #DT_SINGLELINE | #DT_CALCRECT)
          
          SelectObject_(hdc, oldFont)
          
          DeleteDC_(hdc)
          
          width = width + rec\right
          
        EndIf
        
      EndIf
      
      If width > menuWidth
        menuWidth = width
      EndIf
      
    Next
  EndIf
  
  
  ProcedureReturn menuWidth
EndProcedure

ProcedureDLL GetMenuExBarHeight(menu.i)
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  ForEach menuex()
    If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
      
      GetClientRect_(menuex()\toolbarID, rc.RECT)
      height = rc\bottom-rc\top
      
      UnlockMutex(menuMutex)
      ProcedureReturn height
      
    EndIf
  Next
  
  UnlockMutex(menuMutex)
  ProcedureReturn 0
EndProcedure

Procedure CalcMenuItemHeight(menu.i)

  menuHeight.l = 0
  items = GetMenuItemCount_(menu)
  
  If items <> -1
    rec.RECT
    minfo.MENUITEMINFO_Fixed
    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    minfo\fMask = #MIIM_FTYPE|#MIIM_DATA|#MIIM_STRING|#MIIM_SUBMENU
    
    hdc = CreateCompatibleDC_(0)
    
    oldFont = SelectObject_(hdc, currentMenuEXFont)
    
    For n = 0 To items-1

      minfo\cch = 0
      minfo\dwTypeData = 0
      
      text.s = ""
      GetMenuItemInfo_(menu, n, #True, @minfo)
      
      ; if the menu item is our custom menu item
      If minfo\fType & #MFT_OWNERDRAW

        menuHeight = menuHeight + measureMenuItemHeight(hdc, minfo\dwItemData)
        
      EndIf

    Next
    
    SelectObject_(hdc, oldFont)
    DeleteDC_(hdc)
    
  EndIf
  
  ; get associated menuex
  LockMutex(menuMutex)
  thisMenuEx = @menuex()
  ForEach menuex()
    If menuex()\popupid = menu
      Break
    EndIf
  Next
  
  If menuex()\style < 5
    menuHeight = menuHeight + 6
  ElseIf menuex()\style = 5
    menuHeight = menuHeight + 5
  Else
    menuHeight = menuHeight + 3
  EndIf
  ChangeCurrentElement(menuex(), thisMenuEx)
  UnlockMutex(menuMutex)
  
  ProcedureReturn menuHeight;(menuHeight+3)
EndProcedure


ProcedureDLL FreeMenuEx(menu.i) ; frees an extended menu from memory
  
  LockMutex(menuMutex)
  
  ;search for menu by id or handle
  ForEach menuex()
    If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu Or menu = -1
      
      If menuex()\toolbarID <> -1
        FreeToolBarEx(menuex()\toolbarID)
      EndIf
      
      Repeat
      Until RemoveMenuItemEx(menuex()\popupid, 0, #True) = 0
      
      If IsMenu(menuex()\purepopupid)
        FreeMenu(menuex()\purepopupid)
      EndIf
      
      ; free any menuitemex resources belonging to menu
      ForEach itemex()
        If itemex()\popupid = menuex()\popupid
          If itemex()\ImageList <> 0
            ImageList_Destroy_(itemex()\ImageList)
          EndIf
          DeleteElement(itemex())
        EndIf
      Next
      
      ; free menu window buffer if exists
      If menuex()\hdc <> 0
        DeleteObject_(menuex()\Buffer)
        DeleteDC_(menuex()\hdc)
      EndIf
      
      DeleteElement(menuex())
      
      If menu <> -1
        UnlockMutex(menuMutex)
        ProcedureReturn #True
      EndIf

    EndIf
  Next
  
  If menu = -1
    UnlockMutex(menuMutex)
    ProcedureReturn #True
  EndIf
  
  UnlockMutex(menuMutex)
  ProcedureReturn #False
  
EndProcedure


;--
;- ToolBarEx
;--
ProcedureDLL CreateToolBarEx(id.l, WindowID.i, iconWidth.l, iconHeight.l, style.l) ; Creates an extended toolbar
  
  macro_protectCommand()
  
  If id <> #ProGUI_Any
    ; check that same id doesnt already exist
    ForEach toolbarEx()
      If toolbarEx()\id = id
        ProcedureReturn 0
      EndIf
    Next
  EndIf
  
  If id = #ProGUI_Any
    id = CreateToolBar(#PB_Any, WindowID)
    hTbGad = PeekI(IsToolBar(id)) ; get api handle to toolbar, sly ;)
    ProGUI_Any = #True
  Else
    hTbGad = CreateToolBar(id, WindowID)
  EndIf
  
  If hTbGad <> 0
    
    LastElement(toolbarEx())
    AddElement(toolbarEx())
    
    currentToolbarEX = id
    toolbarEx()\id = id
    toolbarEx()\Handle = hTbGad
    toolbarEx()\WindowID = WindowID
    toolbarEx()\lastRowCount = 1
    
    ; make toolbar use tooltips
    style = style|#TBSTYLE_TOOLTIPS
    
    rStyle = SendMessage_(hTbGad, #TB_GETSTYLE, 0, 0)
    rStyle = rStyle | style
    
    exstyle = #TBSTYLE_EX_DRAWDDARROWS
    
    If style & #TBSTYLE_HIDECLIPPEDBUTTONS
      exstyle = exstyle | #TBSTYLE_EX_HIDECLIPPEDBUTTONS
    EndIf
    
    SendMessage_(hTbGad, #TB_SETEXTENDEDSTYLE, 0, exstyle)
      
    SendMessage_(hTbGad, #TB_SETSTYLE, 0, rStyle)
    
    toolbarEx()\style = style
    
    ; check for new UI style flags
    If style & #UISTYLE_OFFICE2003
      toolbarEx()\UIStyle = #UISTYLE_OFFICE2003
    ElseIf style & #UISTYLE_OFFICE2007
      toolbarEx()\UIStyle = #UISTYLE_OFFICE2007
    EndIf
    
    ; check for image style
    If style & #UISTYLE_IMAGE
      toolbarEx()\UIStyle = #UISTYLE_IMAGE
    EndIf
    
    If iconWidth = 0 And iconHeight = 0
      toolbarEx()\normalImageList = -1
      toolbarEx()\hotImageList = -1
      toolbarEx()\disabledImageList = -1
    Else
      ImageList_Destroy_(SendMessage_(hTbGad, #TB_GETIMAGELIST, 0, 0))
      ImageList_Destroy_(SendMessage_(hTbGad, #TB_GETHOTIMAGELIST, 0, 0))
      ImageList_Destroy_(SendMessage_(hTbGad, #TB_GETDISABLEDIMAGELIST, 0, 0))
      
      hToolBarIcons = ImageList_Create_(iconWidth, iconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
      SendMessage_(hTbGad, #TB_SETIMAGELIST, $0, hToolBarIcons)
      toolbarEx()\normalImageList = hToolBarIcons
      
      hToolBarIcons = ImageList_Create_(iconWidth, iconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
      SendMessage_(hTbGad, #TB_SETHOTIMAGELIST, $0, hToolBarIcons)
      toolbarEx()\hotImageList = hToolBarIcons
      
      hToolBarIcons = ImageList_Create_(iconWidth, iconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
      SendMessage_(hTbGad, #TB_SETDISABLEDIMAGELIST, $0, hToolBarIcons)
      toolbarEx()\disabledImageList = hToolBarIcons
    EndIf
    
    ; check if a menu callback has been created for this windowid
    found = 0
    ForEach menuCallback()
      If menuCallback()\WindowID = WindowID
        found = -1
        Break
      EndIf
    Next
    
    ; if menu call back hasnt been created then create one
    If found = 0
      ProGUIOldCallBack = SetWindowLongPtr_(WindowID, #GWLP_WNDPROC, @MyWindowCallback())
      LastElement(menuCallback())
      AddElement(menuCallback())
      menuCallback()\WindowID = WindowID
      menuCallback()\callback = @MyWindowCallback()
      menuCallback()\oldCallback = ProGUIOldCallBack
      SetWindowLongPtr_(WindowID, #GWL_STYLE, GetWindowLongPtr_(WindowID, #GWL_STYLE)|#WS_CLIPCHILDREN)
    EndIf
    
    ; create hook to intercept creation of new windows for popup menus
    If WindowHook = 0
      threadId = GetWindowThreadProcessId_(WindowID, 0)
      WindowHook = SetWindowsHookEx_(#WH_CALLWNDPROC, @CallWndProcHook(), 0, threadId)
    EndIf
    
    ; create hook to handle keyboard navigation
    If KeyboardHook = 0
      threadId = GetWindowThreadProcessId_(WindowID, 0)
      KeyboardHook = SetWindowsHookEx_(#WH_KEYBOARD, @KeyboardHook(), 0, threadId)
    EndIf
    
    ; check if currentMenuEXFont has been set
    If currentMenuEXFont = 0
      metrics.NONCLIENTMETRICS
      metrics\cbSize = SizeOf(NONCLIENTMETRICS)
      
      SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
      currentMenuEXFont = CreateFontIndirect_(metrics\lfMenuFont)
    EndIf
    
    If ProGUI_Any = #False
      ProcedureReturn hTbGad
    Else
      ProcedureReturn id
    EndIf
    
  EndIf

  ProcedureReturn 0
  
EndProcedure

ProcedureDLL SetToolBarExStyle(toolbar.i, style.l)  ; Sets the rendering style of an extended toolbar
  
  macro_protectCommand()
  
  ; find toolbar handle
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      toolbarEx()\UIStyle = style
      
      updateDefaultDisabledImages(toolbarEx()\id, 4)
      
      RedrawWindow_(GetAncestor_(toolbarEx()\Handle, #GA_ROOT), 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
      
      ProcedureReturn #True
    EndIf
  Next
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL FreeToolBarEx(toolbar.i) ; Frees an extended toolbar from memory
  
  ;search for toolbar by id or handle
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar Or toolbar = -1

      ;remove buttons associated with toolbar
      ForEach toolbarExButton()
        If toolbarExButton()\toolbarID = toolbarEx()\id
          ;remove tooltip if exists
          ForEach toolbartip()
            If toolbartip()\id = toolbarExButton()\id
              DeleteElement(toolbartip())
              Break
            EndIf
          Next
          
          ; if button contains a gadget then hide and re-parent gadget window to root window
          If toolbarExButton()\gadget <> 0
            
            ShowWindow_(toolbarExButton()\gadget, #SW_HIDE)
            SetParent_(toolbarExButton()\gadget, GetAncestor_(toolbarExButton()\gadget, #GA_ROOT))
          
          EndIf
          
          DeleteElement(toolbarExButton())
        EndIf
      Next

      ; free image lists
      If toolbarEx()\normalImageList <> -1
        ImageList_Destroy_(toolbarEx()\normalImageList)
      EndIf
      
      If toolbarEx()\hotImageList <> -1
        ImageList_Destroy_(toolbarEx()\hotImageList)
      EndIf
      
      If toolbarEx()\disabledImageList <> -1
        ImageList_Destroy_(toolbarEx()\disabledImageList)
      EndIf
      
      If IsToolBar(toolbarEx()\id)
        FreeToolBar(toolbarEx()\id)
      EndIf
      
      DeleteElement(toolbarEx())
      
      If toolbar <> -1
        ProcedureReturn #True
      EndIf
    EndIf
  Next
  
  If toolbar = -1
    ProcedureReturn #True
  EndIf
  ProcedureReturn 0
  
EndProcedure

Procedure ImageListInsertIcon(himl.i, hicon.i, pos)
  
  If hicon <> 0
    error = ImageList_ReplaceIcon_(himl, -1, hicon)
    If error = -1
      ProcedureReturn 0
    EndIf
  EndIf
  
  count = ImageList_GetImageCount_(himl)
  
  For n = count-1 To pos+1 Step -1
    ;lerror = ImageList_Copy_(himl, n-1, himl, n, 1) ; ILCF_SWAP
    ;If error = 0
    ;  ProcedureReturn 0
    ;EndIf
    icon1 = ImageList_GetIcon_(himl, n, #ILD_TRANSPARENT)
    icon2 = ImageList_GetIcon_(himl, n-1, #ILD_TRANSPARENT)
    ImageList_ReplaceIcon_(himl, n, icon2)
    ImageList_ReplaceIcon_(himl, n-1, icon1)
    DestroyIcon_(icon1)
    DestroyIcon_(icon2)
  Next
  
  ProcedureReturn #True
  
EndProcedure

; updates positions/dimensions of button gadgets in current toolbarEx()
Procedure updateToolBarExButtonGadgets()
  
  ForEach toolbarExButton()
    If toolbarExButton()\toolbarExHandle = toolbarEx()\handle And toolbarExButton()\gadget <> 0
      
      pos = SendMessage_(toolbarEx()\handle, #TB_COMMANDTOINDEX, toolbarExButton()\id, 0)
      SendMessage_(toolbarEx()\Handle, #TB_GETITEMRECT, pos, @rc.RECT)
      
      height = (rc\bottom-rc\top)-toolbarExButton()\gadgetPad\bottom
      SetWindowPos_(toolbarExButton()\gadget, 0, rc\left+toolbarExButton()\gadgetPad\left, rc\top+toolbarExButton()\gadgetPad\top, (rc\right-rc\left)-(toolbarExButton()\gadgetPad\left+toolbarExButton()\gadgetPad\right), height, #SWP_NOACTIVATE|#SWP_NOOWNERZORDER|#SWP_NOZORDER)
      
      class.s = Space(255)
      GetClassName_(toolbarExButton()\gadget, @class, 255)
      ; gadget is ComboBox, need to send custom height change
      If class = "ComboBox"
        height = height - 6
        SendMessage_(toolbarExButton()\gadget, #CB_SETITEMHEIGHT, -1, height)
      EndIf
      
    EndIf
  Next
        
EndProcedure

ProcedureDLL ToolBarImageButtonEx(buttonID.l, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, style.l) ; Creates an image toolbar button
  
  macro_protectCommand()
  
  ftext.s = text
  
  ; check if separator bar flag has been passed
  If style & #BTNS_SEP
    ProcedureReturn ToolBarSeparatorEx()
  EndIf
  
  ; exit if toolbar hasnt been created
  If currentToolbarEX = -1
    ProcedureReturn 0
  EndIf
  
  If buttonID = #ProGUI_Any
    
    Repeat
      ; generate unique toolbar id so as not to conflict with user toolbars
      buttonID = generateUniqueID_wordUnsigned()
      ; check that same id doesnt already exist
      found = 0
      ForEach toolbarExButton()
        If toolbarExButton()\id = buttonID
          found = -1
          Break
        EndIf
      Next
    Until found = 0
    
  Else
    ; make sure toolbar button id doesnt exist
    ForEach toolbarExButton()
      If toolbarExButton()\id = buttonID And toolbarExButton()\toolbarID = currentToolbarEX
        ProcedureReturn 0
      EndIf
    Next
  EndIf
  
  ; find current toolbar id
  ForEach toolbarEx()
    If toolbarEx()\id = currentToolbarEX
      
      If normalImageID = 0
        normalImageID = nullicon
      EndIf
      If hotImageID = 0
        If normalImageID <> nullicon
          hotImageID = normalImageID
        Else
          hotImageID = nullicon
        EndIf
      EndIf
      If disabledImageID = 0
        If normalImageID <> nullicon
          disabledImageID = defaultDisabledImage(normalImageID, toolbarEx()\UIStyle)
          defaultDisabled = #True
        Else
          disabledImageID = nullicon
        EndIf
      EndIf
      
      error.l = ImageList_ReplaceIcon_(toolbarEx()\normalImageList, -1, normalImageID)
      If error = -1
        error = ImageList_ReplaceIcon_(toolbarEx()\normalImageList, -1, hBitmap_to_hIcon(normalImageID))
      EndIf
      error.l = ImageList_ReplaceIcon_(toolbarEx()\hotImageList, -1, hotImageID)
      If error = -1
        error = ImageList_ReplaceIcon_(toolbarEx()\hotImageList, -1, hBitmap_to_hIcon(hotImageID))
      EndIf
      error.l = ImageList_ReplaceIcon_(toolbarEx()\disabledImageList, -1, disabledImageID)
      If error = -1
        error = ImageList_ReplaceIcon_(toolbarEx()\disabledImageList, -1, hBitmap_to_hIcon(disabledImageID))
      EndIf
      If defaultDisabled = #True
        DestroyIcon_(disabledImageID)
      EndIf
      
      btncount.l = SendMessage_(toolbarEx()\Handle, #TB_BUTTONCOUNT, 0, 0)
      
      btn.TBBUTTON
      If text <> ""
        
        If FindString(text, "\", 1) > 0
          rc.RECT
          hdc = CreateCompatibleDC_(0)
          text = renderText(hdc, text, @rc, 0, #DT_CALCRECT|#RTXT_RETURNSTRING)
          DeleteDC_(hdc)
        EndIf
          
        *p = AllocateMemory(StringByteLength(text)+2)
        PokeS(*p, text)
        idString = SendMessage_(toolbarEx()\Handle, #TB_ADDSTRING, 0, *p)
        FreeMemory(*p)
        btn\iString = idString
      Else
        btn\iString = -1
      EndIf
      btn\idCommand = buttonID
      If normalImageID = nullicon
        btn\iBitmap = #I_IMAGENONE
      Else
        btn\iBitmap = btncount
      EndIf
      btn\fsState = #TBSTATE_ENABLED
      ;If Style = 0
      ;  btn\fsStyle = toolbarEx()\Style
      ;Else
      btn\fsStyle = style
      ;EndIf
      
      LastElement(toolbarExButton())
      AddElement(toolbarExButton())
      btn\dwData = @toolbarExButton()
      toolbarExButton()\id = buttonID
      toolbarExButton()\toolbarID = currentToolbarEX
      toolbarExButton()\toolbarExHandle = toolbarex()\Handle
      toolbarExButton()\toolbarEx = @toolbarEx()
      toolbarExButton()\normalImage = normalImageID
      toolbarExButton()\hotImage = hotImageID
      toolbarExButton()\disabledImage = disabledImageID
      toolbarExButton()\defDisabledImage = defaultDisabled
      toolbarExButton()\defDisabledStyle = toolbarEx()\UIStyle
      toolbarExButton()\text = ftext
      
      ; normal mode
      If ToolbarExInsert = #False
        suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
      ; insert mode, i.e called from InsertToolBarImageButtonEx etc...
      Else
        If ToolbarExInsertPos >= btncount+1
          ToolbarExInsertPos = -1
        ElseIf ToolbarExInsertPos < -1
          ToolbarExInsertPos = 0
        EndIf
        If ToolbarExInsertPos = -1
          suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
        Else
          
          ImageListInsertIcon(toolbarEx()\normalImageList, 0, ToolbarExInsertPos)
          ImageListInsertIcon(toolbarEx()\hotImageList, 0, ToolbarExInsertPos)
          ImageListInsertIcon(toolbarEx()\disabledImageList, 0, ToolbarExInsertPos)
        
          suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, ToolbarExInsertPos, @btn)
        EndIf
      EndIf

      SendMessage_(toolbarEx()\Handle, #TB_AUTOSIZE, 0, 0)
      
      ; if #UISTYLE_OFFICE2003/#UISTYLE_OFFICE2007 style then increase height of toolbar by 3 pixels
      If (toolbarEx()\UIStyle = #UISTYLE_OFFICE2003 Or toolbarEx()\UIStyle = #UISTYLE_OFFICE2007) And toolbarEx()\height = 0
        Size = SendMessage_(toolbarEx()\Handle, #TB_GETBUTTONSIZE, 0, 0)
        width = (Size&$FFFF)
        height = (Size>> 16 & $FFFF)+3
        SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONSIZE, 0, MakeLong(width, height))
        toolbarEx()\height = height
      EndIf
      
      If toolbarEx()\UIStyle = #UISTYLE_IMAGE
        ImageList_GetImageInfo_(toolbarEx()\normalImageList, 0, @imf.IMAGEINFO)
        height = imf\rcImage\bottom-imf\rcImage\top
        width = imf\rcImage\right-imf\rcImage\left
        SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONSIZE, 0, MakeLong(width, height))
        SendMessage_(toolbarEx()\Handle, #TB_SETPADDING, 0, MakeLong(0, 0))
        toolbarEx()\height = height
      EndIf
      
      
      ; resize and position any buttons that contain a gadget in this toolbarEx
      updateToolBarExButtonGadgets()
      
      
      ProcedureReturn buttonID
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL ToolBarButtonEx(buttonID.l, text.s, style.l) ; Creates a normal text toolbar button
  
  macro_protectCommand()
  
  ; check if separator bar flag has been passed
  If style & #BTNS_SEP
    ProcedureReturn ToolBarSeparatorEx()
  EndIf
  
  ; exit if toolbar hasnt been created
  If currentToolbarEX = -1
    ProcedureReturn 0
  EndIf
  
  ProcedureReturn ToolBarImageButtonEx(buttonID, text, 0, 0, 0, style)
  
EndProcedure


ProcedureDLL ToolBarSeparatorEx() ; Creates a ToolbarEx separator
  
  macro_protectCommand()
  
  ; exit if toolbar hasnt been created
  If currentToolbarEX = -1
    ProcedureReturn 0
  EndIf

  Repeat
    ; generate unique toolbar id so as not to conflict with user toolbars
    buttonID = generateUniqueID_wordUnsigned()
    ; check that same id doesnt already exist
    found = 0
    ForEach toolbarExButton()
      If toolbarExButton()\id = buttonID
        found = -1
        Break
      EndIf
    Next
  Until found = 0

  ; find current toolbar id
  ForEach toolbarEx()
    If toolbarEx()\id = currentToolbarEX
      
      ImageList_ReplaceIcon_(toolbarEx()\normalImageList, -1, nullicon)
      ImageList_ReplaceIcon_(toolbarEx()\hotImageList, -1, nullicon)
      ImageList_ReplaceIcon_(toolbarEx()\disabledImageList, -1, nullicon)
      
      btncount = SendMessage_(toolbarEx()\Handle, #TB_BUTTONCOUNT, 0, 0)
      
      btn.TBBUTTON
      btn\iString = -1
      btn\idCommand = buttonID
      btn\iBitmap = #I_IMAGENONE
      btn\fsState = 0;#TBSTATE_ENABLED
      btn\fsStyle = 0
      
      LastElement(toolbarExButton())
      AddElement(toolbarExButton())
      btn\dwData = @toolbarExButton()
      toolbarExButton()\id = buttonID
      toolbarExButton()\toolbarID = currentToolbarEX
      toolbarExButton()\toolbarExHandle = toolbarex()\Handle
      toolbarExButton()\toolbarEx = @toolbarEx()
      toolbarExButton()\normalImage = -1
      toolbarExButton()\hotImage = -1
      toolbarExButton()\disabledImage = -1
      toolbarExButton()\separator = #True
      
      ; normal mode
      If ToolbarExInsert = #False
        suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
      ; insert mode, i.e called from InsertToolBarImageButtonEx etc...
      Else
        If ToolbarExInsertPos >= btncount+1
          ToolbarExInsertPos = -1
        ElseIf ToolbarExInsertPos < -1
          ToolbarExInsertPos = 0
        EndIf
        If ToolbarExInsertPos = -1
          suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
        Else
          
          ImageListInsertIcon(toolbarEx()\normalImageList, 0, ToolbarExInsertPos)
          ImageListInsertIcon(toolbarEx()\hotImageList, 0, ToolbarExInsertPos)
          ImageListInsertIcon(toolbarEx()\disabledImageList, 0, ToolbarExInsertPos)
        
          suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, ToolbarExInsertPos, @btn)
        EndIf
      EndIf

      tbnfo.TBBUTTONINFO
      tbnfo\cbSize = SizeOf(TBBUTTONINFO)
      tbnfo\dwMask = #TBIF_SIZE
      tbnfo\cx = 6
      SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONINFO, buttonID, @tbnfo)
      
      
      ; resize and position any buttons that contain a gadget in this toolbarEx
      updateToolBarExButtonGadgets()
      
      
      ProcedureReturn buttonID
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure


ProcedureDLL ToolBarDropdownImageButtonEx(buttonID.l, MenuID.i, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, style.l) ; Creates a dropdown type toolbar button
  
  macro_protectCommand()
  
  ; try and find matching menu
  dropdownMenuex = -1
  ForEach menuex()
    If menuex()\popupid = MenuID Or menuex()\id = MenuID
      menuStyle = menuex()\style
      MenuID = menuex()\popupid
      dropdownMenuex = @menuex()
      If menuex()\toolbarID = currentToolbarEX And menuex()\buttonID = buttonID
        ProcedureReturn 0
      EndIf
      Break
    EndIf
  Next

  ; if there isn't a dropdown style flag then add default
  If Not style & #BTNS_WHOLEDROPDOWN And Not style & #BTNS_DROPDOWN
    style = style | #BTNS_DROPDOWN
  EndIf
  
  buttonID = ToolBarImageButtonEx(buttonID, text, normalImageID, hotImageID, disabledImageID, style)
  If buttonID = 0
    ProcedureReturn 0
  EndIf

  
  ; get handle to current toolbar
  ForEach toolbarEx()
    If toolbarEx()\id = currentToolbarEX
      toolbarHandle = toolbarEx()\Handle
      WindowID = toolbarEx()\WindowID
      Break
    EndIf
  Next
  
  ; create new menu entry
  LastElement(menuex())
  AddElement(menuex())
  
  ; generate unique menu id
  Repeat
    id = generateUniqueID()
    found = 0
    ForEach menuex()
      If menuex()\id = id
        found = -1
        Break
      EndIf
    Next
  Until found = 0
  
  menuex()\id = id
  menuex()\toolbarID = toolbarHandle
  menuex()\popupid = MenuID
  menuex()\buttonID = buttonID
  menuex()\singleMenu = -1
  menuex()\style = menuStyle
  menuex()\dropdownMenuex = dropdownMenuex
  
  ; check if a menu callback has been created for this windowid
  found = 0
  ForEach menuCallback()
    If menuCallback()\WindowID = WindowID
      found = -1
      Break
    EndIf
  Next
  
  ; if menu call back hasnt been created then create one
  If found = 0
    ProGUIOldCallBack = SetWindowLongPtr_(WindowID, #GWLP_WNDPROC, @MyWindowCallback())
    LastElement(menuCallback())
    AddElement(menuCallback())
    menuCallback()\WindowID = WindowID
    menuCallback()\callback = @MyWindowCallback()
    menuCallback()\oldCallback = ProGUIOldCallBack
    SetWindowLongPtr_(WindowID, #GWL_STYLE, GetWindowLongPtr_(WindowID, #GWL_STYLE)|#WS_CLIPCHILDREN)
  EndIf
  
  
  
  ProcedureReturn buttonID
  
EndProcedure

ProcedureDLL ToolBarExAttachDropdownMenu(toolbar.i, buttonID.l, menu.i)
  
  macro_protectCommand()
  
  ; find toolbar handle
  found = 0
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      ; find button id
      ForEach toolbarExButton()
        If toolbarExButton()\id = buttonID
          
          ; find menu
          ForEach menuex()
            If menuex()\id = menu Or menuex()\popupid = menu
              menu = menuex()\popupid
              dropdownMenuex = @menuex()
              Break
            EndIf
          Next
          
          found = -1
          Break
        EndIf
      Next
      
      Break 
    EndIf
  Next
  
  If found = -1

    ; find existing menu attached to button
    ForEach menuex()
      If menuex()\singleMenu = -1 And menuex()\toolbarID = toolbarEx()\Handle And menuex()\buttonID = buttonID
        menuex()\popupid = menu
        menuex()\dropdownMenuex = dropdownMenuex
        ProcedureReturn #True
      EndIf
    Next
    
  EndIf
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL ToolBarExGadget(buttonID.l, GadgetID.i, LeftPadding.l, TopPadding.l, RightPadding.l, BottomPadding.l, ApplyUIStyle.b) ; Adds a gadget/control to the current ToolBarEx
  
  macro_protectCommand()
  
  ; exit if toolbar hasnt been created
  If currentToolbarEX = -1
    ProcedureReturn 0
  EndIf
  
  ; exit if GadgetId not a valid hwnd 
  If IsWindow_(GadgetID) = #False
    ProcedureReturn 0
  EndIf
  
  GetWindowRect_(GadgetID, @rec.RECT)
  gWidth = rec\right - rec\left
  gHeight = rec\bottom - rec\top

  If buttonID = #ProGUI_Any
    
    Repeat
      ; generate unique toolbar id so as not to conflict with user toolbars
      buttonID = generateUniqueID_wordUnsigned()
      ; check that same id doesnt already exist
      found = 0
      ForEach toolbarExButton()
        If toolbarExButton()\id = buttonID
          found = -1
          Break
        EndIf
      Next
    Until found = 0
    
  Else
    ; make sure toolbar button id doesnt exist
    ForEach toolbarExButton()
      If toolbarExButton()\id = buttonID And toolbarExButton()\toolbarID = currentToolbarEX
        ProcedureReturn 0
      EndIf
    Next
  EndIf

  ; find current toolbar id
  ForEach toolbarEx()
    If toolbarEx()\id = currentToolbarEX
      
      ImageList_ReplaceIcon_(toolbarEx()\normalImageList, -1, nullicon)
      ImageList_ReplaceIcon_(toolbarEx()\hotImageList, -1, nullicon)
      ImageList_ReplaceIcon_(toolbarEx()\disabledImageList, -1, nullicon)
      
      btncount = SendMessage_(toolbarEx()\Handle, #TB_BUTTONCOUNT, 0, 0)
      
      btn.TBBUTTON
      btn\iString = -1
      btn\idCommand = buttonID
      btn\iBitmap = #I_IMAGENONE
      
      LastElement(toolbarExButton())
      AddElement(toolbarExButton())
      btn\dwData = @toolbarExButton()
      toolbarExButton()\id = buttonID
      toolbarExButton()\toolbarID = currentToolbarEX
      toolbarExButton()\toolbarExHandle = toolbarex()\Handle
      toolbarExButton()\toolbarEx = @toolbarEx()
      toolbarExButton()\normalImage = -1
      toolbarExButton()\hotImage = -1
      toolbarExButton()\disabledImage = -1
      toolbarExButton()\gadget = GadgetID
      toolbarExButton()\gadgetStyled = ApplyUIStyle
      toolbarExButton()\gadgetPad\left = LeftPadding
      toolbarExButton()\gadgetPad\top = TopPadding
      toolbarExButton()\gadgetPad\right = RightPadding
      toolbarExButton()\gadgetPad\bottom = BottomPadding
      
      ; normal mode
      If ToolbarExInsert = #False
        suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
      ; insert mode, i.e called from InsertToolBarImageButtonEx etc...
      Else
        If ToolbarExInsertPos >= btncount+1
          ToolbarExInsertPos = -1
        ElseIf ToolbarExInsertPos < -1
          ToolbarExInsertPos = 0
        EndIf
        If ToolbarExInsertPos = -1
          suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, btncount+1, @btn)
        Else
          
          ImageListInsertIcon(toolbarEx()\normalImageList, 0, ToolbarExInsertPos)
          ImageListInsertIcon(toolbarEx()\hotImageList, 0, ToolbarExInsertPos)
          ImageListInsertIcon(toolbarEx()\disabledImageList, 0, ToolbarExInsertPos)
        
          suc = SendMessage_(toolbarEx()\Handle, #TB_INSERTBUTTON, ToolbarExInsertPos, @btn)
        EndIf
      EndIf

      tbnfo.TBBUTTONINFO
      tbnfo\cbSize = SizeOf(TBBUTTONINFO)
      tbnfo\dwMask = #TBIF_SIZE
      tbnfo\cx = gWidth+LeftPadding+RightPadding
      SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONINFO, buttonID, @tbnfo)
      
      SendMessage_(toolbarEx()\Handle, #TB_GETITEMRECT, btncount, @rc.RECT)
      
      ShowWindow_(GadgetID, #SW_HIDE)

      class.s = Space(255)
      GetClassName_(GadgetID, @class, 255)
      
      height = (rc\bottom-rc\top)-BottomPadding
      
      SetParent_(GadgetID, toolbarEx()\Handle)
      
      SetWindowPos_(GadgetID, 0, rc\left+LeftPadding, rc\top+TopPadding, gWidth, height, #SWP_NOACTIVATE|#SWP_NOOWNERZORDER|#SWP_NOZORDER)
      
      ; gadget is ComboBox, need to send custom height change
      If class = "ComboBox"
        height = height - 6
        SendMessage_(GadgetID, #CB_SETITEMHEIGHT, -1, height)
      EndIf
      
      ShowWindow_(GadgetID, #SW_SHOW)
      
      
      ; resize and position any buttons that contain a gadget in this toolbarEx
      updateToolBarExButtonGadgets()
      
      
      ProcedureReturn buttonID
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL InsertToolBarButtonEx(toolbar.i, position.l, buttonID.l, text.s, style.l) ; Inserts a toolbar button at position
  
  macro_protectCommand()
  
  ; find toolbar handle
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      ToolbarExInsert = #True
      ToolbarExInsertPos = position
      thisToolbar = currentToolbarEX
      currentToolbarEX = toolbarEx()\id
      success = ToolBarImageButtonEx(buttonID, text,0, 0, 0, style)
      ToolbarExInsert = #False
      currentToolbarEX = thisToolbar
      
      Break 
    EndIf
  Next
  
  ProcedureReturn success
  
EndProcedure

ProcedureDLL InsertToolBarImageButtonEx(toolbar.i, position.l, buttonID.l, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, style.l) ; Inserts a toolbar image button at position
  
  macro_protectCommand()
  
  ; find toolbar handle
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      ToolbarExInsert = #True
      ToolbarExInsertPos = position
      thisToolbar = currentToolbarEX
      currentToolbarEX = toolbarEx()\id
      success = ToolBarImageButtonEx(buttonID, text, normalImageID, hotImageID, disabledImageID, style)
      ToolbarExInsert = #False
      currentToolbarEX = thisToolbar
      
      Break 
    EndIf
  Next
  
  ProcedureReturn success
  
EndProcedure

