        SetSkinProperty(sysToggleButtonSkin, "togglebuttonex", "selected hot", "text position", "x: 50%; y: 50%;")
        SetSkinProperty(sysToggleButtonSkin, "togglebuttonex", "selected hot", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; selected pressed
        SetSkinProperty(sysToggleButtonSkin, "togglebuttonex", "selected pressed", "background", "10;")
        SetSkinProperty(sysToggleButtonSkin, "togglebuttonex", "selected pressed", "image position", "x: 50%; y: 50%;")
        SetSkinProperty(sysToggleButtonSkin, "togglebuttonex", "selected pressed", "image padding", "top: 2; left: 6; bottom: 2; right: 4;")
        SetSkinProperty(sysToggleButtonSkin, "togglebuttonex", "selected pressed", "text position", "x: 50%; y: 50%;")
        SetSkinProperty(sysToggleButtonSkin, "togglebuttonex", "selected pressed", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")  
        
      ;- **** sticky button
      Case "sysstickybuttonskin"
        
        ; create system sticky toggle button skin
        Global sysStickyButtonSkin = CreateSkin("sysStickyButtonSkin")
        ; normal
        SetSkinProperty(sysStickyButtonSkin, "togglebuttonex", "normal", "background", "8;")
        SetSkinProperty(sysStickyButtonSkin, "togglebuttonex", "normal", "image position", "x: 50%; y: 50%;")
        SetSkinProperty(sysStickyButtonSkin, "togglebuttonex", "normal", "image padding", "top: 2; left: 6; bottom: 2; right: 4;")
        SetSkinProperty(sysStickyButtonSkin, "togglebuttonex", "normal", "text position", "x: 50%; y: 50%;")
        SetSkinProperty(sysStickyButtonSkin, "togglebuttonex", "normal", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; hot
        SetSkinProperty(sysStickyButtonSkin, "togglebuttonex", "hot", "background", "9;")
        SetSkinProperty(sysStickyButtonSkin, "togglebuttonex", "hot", "image position", "x: 50%; y: 50%;")
