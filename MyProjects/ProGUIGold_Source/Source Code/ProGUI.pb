        StopDrawing()
        
        ; system check box inbetween state theme image
        w = 16 : h = 16
        Global themeCheckButtonInbetweenImage = CreateImage(#PB_Any, w, h, 32)
        hdc = StartDrawing(ImageOutput(themeCheckButtonInbetweenImage))
        DrawingMode(#PB_2DDrawing_AllChannels)
        Box(0, 0, w, h, RGBA(255, 255, 255, 0))
        rc.RECT
        rc\top = 0
        rc\left = 0
        rc\right = w
        rc\bottom = h
        If ThemesEnabled = #True
          CallFunctionFast(*DrawThemeBackground, hThemeButton, hdc, 3, 9, @rc, 0)
        Else
          Box(0, 0, w, h, RGBA(0, 255, 0, 0))
          rc\left + 1
          rc\top + 1
          rc\bottom - 2
          rc\right - 2
          DrawFrameControl_(hdc, rc, #DFC_BUTTON, #DFCS_BUTTON3STATE|#DFCS_CHECKED)
          DrawingMode(#PB_2DDrawing_AlphaChannel)
          Box(0, 0, w, h, RGBA(0, 0, 0, 255))
          DrawingMode(#PB_2DDrawing_AllChannels)
          FillArea(0, 0, -1, RGBA(255,255,255, 0))
        EndIf
        StopDrawing()
        ; system Check inbetween hot state theme image
        w = 16 : h = 16
        Global themeCheckButtonInbetweenHotImage = CreateImage(#PB_Any, w, h, 32)
        hdc = StartDrawing(ImageOutput(themeCheckButtonInbetweenHotImage))
        DrawingMode(#PB_2DDrawing_AllChannels)
        Box(0, 0, w, h, RGBA(255, 255, 255, 0))
        rc.RECT
        rc\top = 0
        rc\left = 0
        rc\right = w
        rc\bottom = h
        If ThemesEnabled = #True
          CallFunctionFast(*DrawThemeBackground, hThemeButton, hdc, 3, 10, @rc, 0)
        Else
          Box(0, 0, w, h, RGBA(0, 255, 0, 0))
          rc\left + 1
          rc\top + 1
          rc\bottom - 2
          rc\right - 2
          DrawFrameControl_(hdc, rc, #DFC_BUTTON, #DFCS_BUTTON3STATE|#DFCS_CHECKED)
          DrawingMode(#PB_2DDrawing_AlphaChannel)
          Box(0, 0, w, h, RGBA(0, 0, 0, 255))
          DrawingMode(#PB_2DDrawing_AllChannels)
          FillArea(0, 0, -1, RGBA(255,255,255, 0))
        EndIf
        StopDrawing()
        ; system Check inbetween pressed state theme image
        w = 16 : h = 16
        Global themeCheckButtonInbetweenPressedImage = CreateImage(#PB_Any, w, h, 32)
        hdc = StartDrawing(ImageOutput(themeCheckButtonInbetweenPressedImage))
        DrawingMode(#PB_2DDrawing_AllChannels)
        Box(0, 0, w, h, RGBA(255, 255, 255, 0))
        rc.RECT
        rc\top = 0
        rc\left = 0
        rc\right = w
        rc\bottom = h
        If ThemesEnabled = #True
          CallFunctionFast(*DrawThemeBackground, hThemeButton, hdc, 3, 11, @rc, 0)
        Else
          Box(0, 0, w, h, RGBA(0, 255, 0, 0))
          rc\left + 1
          rc\top + 1
          rc\bottom - 2
          rc\right - 2
          DrawFrameControl_(hdc, rc, #DFC_BUTTON, #DFCS_BUTTON3STATE|#DFCS_CHECKED|#DFCS_PUSHED)
          DrawingMode(#PB_2DDrawing_AlphaChannel)
          Box(0, 0, w, h, RGBA(0, 0, 0, 255))
          DrawingMode(#PB_2DDrawing_AllChannels)
          FillArea(0, 0, -1, RGBA(255,255,255, 0))
        EndIf
        StopDrawing()
        
        ; create system check button skin
        Global sysCheckButtonSkin = CreateSkin("sysCheckButtonSkin")
        ; normal
        SetSkinPropertyData(sysCheckButtonSkin, "checkbuttonex", "normal", "image", ImageID(themeCheckButtonNormalImage))
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "normal", "background", "-1;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "normal", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "normal", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "normal", "text position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "normal", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; hot
        SetSkinPropertyData(sysCheckButtonSkin, "checkbuttonex", "hot", "image", ImageID(themeCheckButtonHotImage))
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "hot", "background", "-1;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "hot", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "hot", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "hot", "text position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "hot", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; pressed
        SetSkinPropertyData(sysCheckButtonSkin, "checkbuttonex", "pressed", "image", ImageID(themeCheckButtonPressedImage))
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "pressed", "background", "-1;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "pressed", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "pressed", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "pressed", "text position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "pressed", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; disabled
        SetSkinPropertyData(sysCheckButtonSkin, "checkbuttonex", "disabled", "image", ImageID(themeCheckButtonDisabledImage))
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "disabled", "background", "-1;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "disabled", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "disabled", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "disabled", "text position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "disabled", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; selected normal
        SetSkinPropertyData(sysCheckButtonSkin, "checkbuttonex", "selected", "image", ImageID(themeCheckButtonSelectedImage))
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected", "background", "-1;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected", "text position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; selected hot
        SetSkinPropertyData(sysCheckButtonSkin, "checkbuttonex", "selected hot", "image", ImageID(themeCheckButtonSelectedHotImage))
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected hot", "background", "-1;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected hot", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected hot", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected hot", "text position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected hot", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; selected pressed
        SetSkinPropertyData(sysCheckButtonSkin, "checkbuttonex", "selected pressed", "image", ImageID(themeCheckButtonSelectedPressedImage))
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected pressed", "background", "-1;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected pressed", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected pressed", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected pressed", "text position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "selected pressed", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        
        ; inbetween
        SetSkinPropertyData(sysCheckButtonSkin, "checkbuttonex", "inbetween", "image", ImageID(themeCheckButtonInbetweenImage))
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween", "background", "-1;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween", "text position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; inbetween hot
        SetSkinPropertyData(sysCheckButtonSkin, "checkbuttonex", "inbetween hot", "image", ImageID(themeCheckButtonInbetweenHotImage))
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween hot", "background", "-1;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween hot", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween hot", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween hot", "text position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween hot", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; inbetween pressed
        SetSkinPropertyData(sysCheckButtonSkin, "checkbuttonex", "inbetween pressed", "image", ImageID(themeCheckButtonInbetweenPressedImage))
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween pressed", "background", "-1;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween pressed", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween pressed", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween pressed", "text position", "x: 0; y: centre;")
        SetSkinProperty(sysCheckButtonSkin, "checkbuttonex", "inbetween pressed", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        
      ;- **** explorer bar
      Case "sysxbarskin"
        
        ; explorer bar
        ; system explorer bar group header normal state theme image
        w = 19 : h = 19
        Global themeXBarHeaderNormalImage = CreateImage(#PB_Any, w, h, 32)
        hdc = StartDrawing(ImageOutput(themeXBarHeaderNormalImage))
        DrawingMode(#PB_2DDrawing_AllChannels)
        Box(0, 0, w, h, RGBA(255, 255, 255, 0))
        rc.RECT
        rc\left = 0
        rc\top = 0
        rc\right = w
        rc\bottom = h
        If ThemesEnabled = #True
          CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, hdc, 6, 1, @rc, 0)
        Else
          Box(0, 0, w, h, RGBA(0, 255, 0, 0))
          rc\left + 1
          rc\top + 1
          rc\bottom - 1
          rc\right - 1
          DrawImage(ImageID(xbar_office2007_black_glyph_up), ((rc\right-rc\left)/2)-(ImageWidth(xbar_office2007_black_glyph_up)/2)+1, ((rc\bottom-rc\top)/2)-(ImageHeight(xbar_office2007_black_glyph_up)/2)+1)
        EndIf
        FillArea(0, 0, -1, RGB(255,255,255))  
        StopDrawing()
        addAlphaToXpTheme(themeXBarHeaderNormalImage)
        
        ; system explorer bar group header hot state theme image
        Global themeXBarHeaderHotImage = CreateImage(#PB_Any, w, h, 32)
        hdc = StartDrawing(ImageOutput(themeXBarHeaderHotImage))
        DrawingMode(#PB_2DDrawing_AllChannels)
        Box(0, 0, w, h, RGBA(255, 255, 255, 0))
        rc.RECT
        rc\left = 0
        rc\top = 0
        rc\right = w
        rc\bottom = h
        If ThemesEnabled = #True
          CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, hdc, 6, 2, @rc, 0)
        Else
          FillRect_(hdc, rc, GetSysColorBrush_(#COLOR_BTNFACE))
          rc\left + 1
          rc\top + 1
          rc\bottom - 1
          rc\right - 1
          DrawEdge_(hdc, rc, #BDR_RAISEDINNER, #BF_RECT)
          DrawingMode(#PB_2DDrawing_AlphaChannel)
          Box(0, 0, w, h, RGBA(0, 0, 0, 255))
          DrawingMode(#PB_2DDrawing_AllChannels)
          DrawImage(ImageID(xbar_office2007_black_glyph_up), ((rc\right-rc\left)/2)-(ImageWidth(xbar_office2007_black_glyph_up)/2)+1, ((rc\bottom-rc\top)/2)-(ImageHeight(xbar_office2007_black_glyph_up)/2)+1)
        EndIf
        FillArea(0, 0, -1, RGB(255,255,255))
        StopDrawing()
        addAlphaToXpTheme(themeXBarHeaderHotImage)
        
        ; system explorer bar group header pressed state theme image
        Global themeXBarHeaderPressedImage = CreateImage(#PB_Any, w, h, 32)
        hdc = StartDrawing(ImageOutput(themeXBarHeaderPressedImage))
        DrawingMode(#PB_2DDrawing_AllChannels)
        Box(0, 0, w, h, RGBA(255, 255, 255, 0))
        rc.RECT
        rc\left = 0
        rc\top = 0
        rc\right = w
        rc\bottom = h
        If ThemesEnabled = #True
          CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, hdc, 6, 3, @rc, 0)
        Else
          FillRect_(hdc, rc, GetSysColorBrush_(#COLOR_BTNFACE))
          rc\left + 1
          rc\top + 1
          rc\bottom - 1
          rc\right - 1
          DrawEdge_(hdc, rc, #BDR_SUNKENOUTER, #BF_RECT)
          DrawingMode(#PB_2DDrawing_AlphaChannel)
          Box(0, 0, w, h, RGBA(0, 0, 0, 255))
          DrawingMode(#PB_2DDrawing_AllChannels)
          DrawImage(ImageID(xbar_office2007_black_glyph_up), ((rc\right-rc\left)/2)-(ImageWidth(xbar_office2007_black_glyph_up)/2)+1, ((rc\bottom-rc\top)/2)-(ImageHeight(xbar_office2007_black_glyph_up)/2)+1)
        EndIf
        FillArea(0, 0, -1, RGB(255,255,255))
        StopDrawing()
        addAlphaToXpTheme(themeXBarHeaderPressedImage)
        
        ; system explorer bar group header disabled state theme image
        Global themeXBarHeaderDisabledImage = CreateImage(#PB_Any, w, h, 32)
        hdc = StartDrawing(ImageOutput(themeXBarHeaderDisabledImage))
        DrawingMode(#PB_2DDrawing_AllChannels)
        Box(0, 0, w, h, RGBA(255, 255, 255, 0))
        rc.RECT
        rc\left = 0
        rc\top = 0
        rc\right = w
        rc\bottom = h
        If ThemesEnabled = #True
          CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, hdc, 6, 0, @rc, 0)
        EndIf
        FillArea(0, 0, -1, RGB(255,255,255))
        StopDrawing()
        addAlphaToXpTheme(themeXBarHeaderDisabledImage)
        
        ; system explorer bar group header selected normal state theme image
        Global themeXBarHeaderSelectedNormalImage = CreateImage(#PB_Any, w, h, 32)
        hdc = StartDrawing(ImageOutput(themeXBarHeaderSelectedNormalImage))
        DrawingMode(#PB_2DDrawing_AllChannels)
        Box(0, 0, w, h, RGBA(255, 255, 255, 0))
        rc.RECT
        rc\left = 0
        rc\top = 0
        rc\right = w
        rc\bottom = h
        If ThemesEnabled = #True
          CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, hdc, 7, 1, @rc, 0)
        Else
          Box(0, 0, w, h, RGBA(0, 255, 0, 0))
          rc\left + 1
          rc\top + 1
          rc\bottom - 1
          rc\right - 1
          DrawImage(ImageID(xbar_office2007_black_glyph_down), ((rc\right-rc\left)/2)-(ImageWidth(xbar_office2007_black_glyph_down)/2)+1, ((rc\bottom-rc\top)/2)-(ImageHeight(xbar_office2007_black_glyph_down)/2)+1)
        EndIf
        FillArea(0, 0, -1, RGB(255,255,255))
        StopDrawing()
        addAlphaToXpTheme(themeXBarHeaderSelectedNormalImage)
        
        ; system explorer bar group header selected hot state theme image
        Global themeXBarHeaderSelectedHotImage = CreateImage(#PB_Any, w, h, 32)
        hdc = StartDrawing(ImageOutput(themeXBarHeaderSelectedHotImage))
        DrawingMode(#PB_2DDrawing_AllChannels)
        Box(0, 0, w, h, RGBA(255, 255, 255, 0))
        rc.RECT
        rc\left = 0
        rc\top = 0
        rc\right = w
        rc\bottom = h
        If ThemesEnabled = #True
          CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, hdc, 7, 2, @rc, 0)
        Else
          FillRect_(hdc, rc, GetSysColorBrush_(#COLOR_BTNFACE))
          rc\left + 1
          rc\top + 1
          rc\bottom - 1
          rc\right - 1
          DrawEdge_(hdc, rc, #BDR_RAISEDINNER, #BF_RECT)
          DrawingMode(#PB_2DDrawing_AlphaChannel)
          Box(0, 0, w, h, RGBA(0, 0, 0, 255))
          DrawingMode(#PB_2DDrawing_AllChannels)
          DrawImage(ImageID(xbar_office2007_black_glyph_down), ((rc\right-rc\left)/2)-(ImageWidth(xbar_office2007_black_glyph_down)/2)+1, ((rc\bottom-rc\top)/2)-(ImageHeight(xbar_office2007_black_glyph_down)/2)+1)
        EndIf
        FillArea(0, 0, -1, RGB(255,255,255))
        StopDrawing()
        addAlphaToXpTheme(themeXBarHeaderSelectedHotImage)
        
        ; system explorer bar group header selected pressed state theme image
        Global themeXBarHeaderSelectedPressedImage = CreateImage(#PB_Any, w, h, 32)
        hdc = StartDrawing(ImageOutput(themeXBarHeaderSelectedPressedImage))
        DrawingMode(#PB_2DDrawing_AllChannels)
        Box(0, 0, w, h, RGBA(255, 255, 255, 0))
        rc.RECT
        rc\left = 0
        rc\top = 0
        rc\right = w
        rc\bottom = h
        If ThemesEnabled = #True
          CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, hdc, 7, 3, @rc, 0)
        Else
          FillRect_(hdc, rc, GetSysColorBrush_(#COLOR_BTNFACE))
          rc\left + 1
          rc\top + 1
          rc\bottom - 1
          rc\right - 1
          DrawEdge_(hdc, rc, #BDR_SUNKENOUTER, #BF_RECT)
          DrawingMode(#PB_2DDrawing_AlphaChannel)
          Box(0, 0, w, h, RGBA(0, 0, 0, 255))
          DrawingMode(#PB_2DDrawing_AllChannels)
          DrawImage(ImageID(xbar_office2007_black_glyph_down), ((rc\right-rc\left)/2)-(ImageWidth(xbar_office2007_black_glyph_down)/2)+1, ((rc\bottom-rc\top)/2)-(ImageHeight(xbar_office2007_black_glyph_down)/2)+1)
        EndIf
        FillArea(0, 0, -1, RGB(255,255,255))
        StopDrawing()
        addAlphaToXpTheme(themeXBarHeaderSelectedPressedImage)
        
        ; create system explorerbar skin
        Global sysXBarSkin = CreateSkin("sysXBarSkin")
        ; main explorerbar skin
        ; normal
        SetSkinProperty(sysXBarSkin, "explorerbar", "normal", "background", "1;")
        SetSkinProperty(sysXBarSkin, "explorerbar", "normal", "group background", "3;")
        SetSkinProperty(sysXBarSkin, "explorerbar", "normal", "margin", "top: 12; left: 12; bottom: 12; right: 12;")
        SetSkinProperty(sysXBarSkin, "explorerbar", "normal", "group margin", "top: 10; left: 12; bottom: 10; right: 12;")
        SetSkinProperty(sysXBarSkin, "explorerbar", "normal", "group padding", "bottom: 15;")
        SetSkinProperty(sysXBarSkin, "explorerbar", "normal", "item padding", "bottom: 2;")
        SetSkinProperty(sysXBarSkin, "explorerbar", "normal", "header height", "25;")
        SetSkinProperty(sysXBarSkin, "explorerbar", "normal", "item height", "22;")
        ; explorerbar group header toggle button skin
        ; normal
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "normal", "background", "4;")
        SetSkinPropertyData(sysXBarSkin, "explorerbar group header", "normal", "background image", ImageID(themeXBarHeaderNormalImage))
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "normal", "background position", "right: 4; top: 50%; masked: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "normal", "image", "noclip: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "normal", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "normal", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "normal", "text position", "x: 12; y: centre;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "normal", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        If ThemesEnabled = #True
          tempimg = CreateImage(#PB_Any, 1, 1, 32)
          hdc = StartDrawing(ImageOutput(tempimg))
          retval = CallFunctionFast(*GetThemeFont, hThemeExplorerbar, hdc, 1, 1, 210, font.LOGFONTW); 210 = #TMT_FONT
          StopDrawing()
          FreeImage(tempimg)
          If retval = 0
            CallFunctionFast(*GetThemeColor, hThemeExplorerbar, 5, 1, 3803, @fcolour) ; 3803 = #TMT_TEXTCOLOR
            fname.s = PeekS(@font\lfFaceName, -1, #PB_Unicode)
            fheight = font\lfHeight
            fheight = font\lfHeight: If fheight<0: fheight = -fheight: EndIf
            fheight*72.0/GetScreenDPI()
            SetSkinProperty(sysXBarSkin, "explorerbar group header", "normal", "text", "font: "+fname+", "+Str(fheight)+", bold; colour: rgb("+Str(Red(fcolour))+","+Str(Green(fcolour))+","+Str(Blue(fcolour))+")")
          EndIf
        Else
          fname.s = GetFontNamep(DefaultFont)
          fheight = GetFontSize(DefaultFont)
          SetSkinProperty(sysXBarSkin, "explorerbar group header", "normal", "text", "font: "+fname+", "+Str(fheight)+", bold; colour: rgb("+Str(Red(fcolour))+","+Str(Green(fcolour))+","+Str(Blue(fcolour))+")")
        EndIf
        ; hot
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "hot", "background", "4;")
        SetSkinPropertyData(sysXBarSkin, "explorerbar group header", "hot", "background image", ImageID(themeXBarHeaderHotImage))
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "hot", "background position", "right: 4; top: 50%; masked: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "hot", "image", "noclip: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "hot", "image position", "x: 0%; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "hot", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "hot", "text position", "x: 12; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "hot", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "hot", "cursor", "hand;")
        If XPthemeActive <> #False
          i.f = 1.3
          tfcolour = RGB(Red(fcolour)*i, Green(fcolour)*i, Blue(fcolour)*i)
          tfcolour = AlphaBlendColour(tfcolour, RGB(255,255,255), 50)
          SetSkinProperty(sysXBarSkin, "explorerbar group header", "hot", "text", "font: "+fname+", "+Str(fheight)+", bold; colour: rgb("+Str(Red(tfcolour))+","+Str(Green(tfcolour))+","+Str(Blue(tfcolour))+")")
        EndIf
        ; pressed
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "pressed", "background", "4;")
        SetSkinPropertyData(sysXBarSkin, "explorerbar group header", "pressed", "background image", ImageID(themeXBarHeaderPressedImage))
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "pressed", "background position", "right: 4; top: 50%; masked: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "pressed", "image", "noclip: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "pressed", "image position", "x: 0%; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "pressed", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "pressed", "text position", "x: 12; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "pressed", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "pressed", "cursor", "hand;")
        If XPthemeActive <> #False
          i.f = 1.3
          tfcolour = RGB(Red(fcolour)*i, Green(fcolour)*i, Blue(fcolour)*i)
          tfcolour = AlphaBlendColour(tfcolour, RGB(255,255,255), 50)
          SetSkinProperty(sysXBarSkin, "explorerbar group header", "pressed", "text", "font: "+fname+", "+Str(fheight)+", bold; colour: rgb("+Str(Red(tfcolour))+","+Str(Green(tfcolour))+","+Str(Blue(tfcolour))+")")
        EndIf
        ; disabled
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "disabled", "background", "4;")
        SetSkinPropertyData(sysXBarSkin, "explorerbar group header", "disabled", "background image", ImageID(themeXBarHeaderDisabledImage))
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "disabled", "background position", "right: 4; top: 50%; masked: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "disabled", "image", "noclip: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "disabled", "image position", "x: 0%; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "disabled", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "disabled", "text position", "x: 12; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "disabled", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; selected normal
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected", "background", "4;")
        SetSkinPropertyData(sysXBarSkin, "explorerbar group header", "selected", "background image", ImageID(themeXBarHeaderSelectedNormalImage))
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected", "background position", "right: 4; top: 50%; masked: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected", "image", "noclip: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected", "image position", "x: 0%; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected", "text position", "x: 12; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        If XPthemeActive <> #False
          SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected", "text", "font: "+fname+", "+Str(fheight)+", bold; colour: rgb("+Str(Red(fcolour))+","+Str(Green(fcolour))+","+Str(Blue(fcolour))+")")
        EndIf
        ; selected hot
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected hot", "background", "4;")
        SetSkinPropertyData(sysXBarSkin, "explorerbar group header", "selected hot", "background image", ImageID(themeXBarHeaderSelectedHotImage))
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected hot", "background position", "right: 4; top: 50%; masked: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected hot", "image", "noclip: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected hot", "image position", "x: 0%; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected hot", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected hot", "text position", "x: 12; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected hot", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected hot", "cursor", "hand;")
        If XPthemeActive <> #False
          i.f = 1.3
          tfcolour = RGB(Red(fcolour)*i, Green(fcolour)*i, Blue(fcolour)*i)
          tfcolour = AlphaBlendColour(tfcolour, RGB(255,255,255), 50)
          SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected hot", "text", "font: "+fname+", "+Str(fheight)+", bold; colour: rgb("+Str(Red(tfcolour))+","+Str(Green(tfcolour))+","+Str(Blue(tfcolour))+")")
        EndIf
        ; selected pressed
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "background", "4;")
        SetSkinPropertyData(sysXBarSkin, "explorerbar group header", "selected pressed", "background image", ImageID(themeXBarHeaderSelectedPressedImage))
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "background position", "right: 4; top: 50%; masked: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "image", "noclip: true;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "image position", "x: 0%; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "text position", "x: 12; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "cursor", "hand;")
        If XPthemeActive <> #False
          i.f = 1.3
          tfcolour = RGB(Red(fcolour)*i, Green(fcolour)*i, Blue(fcolour)*i)
          tfcolour = AlphaBlendColour(tfcolour, RGB(255,255,255), 50)
          SetSkinProperty(sysXBarSkin, "explorerbar group header", "selected pressed", "text", "font: "+fname+", "+Str(fheight)+", bold; colour: rgb("+Str(Red(tfcolour))+","+Str(Green(tfcolour))+","+Str(Blue(tfcolour))+")")
        EndIf
        ; explorerbar group item toggle button skin
        ; normal
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "background", "-1;");"RGBA(255, 255, 0, 255);")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "image position", "x: 0; y: centre;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "text position", "x: 0; y: centre;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        If ThemesEnabled = #True
          tempimg = CreateImage(#PB_Any, 1, 1, 32)
          hdc = StartDrawing(ImageOutput(tempimg))
          retval = CallFunctionFast(*GetThemeFont, hThemeExplorerbar, hdc, 1, 1, 210, font.LOGFONTW); 210 = #TMT_FONT
          StopDrawing()
          FreeImage(tempimg)
          If retval = 0
            CallFunctionFast(*GetThemeColor, hThemeExplorerbar, 5, 1, 3803, @fcolour) ; 3803 = #TMT_TEXTCOLOR
            fname.s = PeekS(@font\lfFaceName, -1, #PB_Unicode)
            fheight = font\lfHeight
            fheight = font\lfHeight: If fheight<0: fheight = -fheight: EndIf
            fheight*72.0/GetScreenDPI()
            Debug "xbar skin item font:"+fname+" size: "+Str(fheight)+" colour: "+Str(Red(fcolour))+" "+Str(Green(fcolour))+" "+Str(Blue(fcolour))
            SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "text", "font: "+fname+", "+Str(fheight)+"; colour: rgb("+Str(Red(fcolour))+","+Str(Green(fcolour))+","+Str(Blue(fcolour))+")")
          EndIf
        Else
          fname.s = GetFontNamep(DefaultFont)
          fheight = GetFontSize(DefaultFont)
          SetSkinProperty(sysXBarSkin, "explorerbar group item", "normal", "text", "font: "+fname+", "+Str(fheight)+"; colour: rgb("+Str(Red(fcolour))+","+Str(Green(fcolour))+","+Str(Blue(fcolour))+")")
        EndIf
        ; hot
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "hot", "background", "-1;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "hot", "image position", "x: 0; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "hot", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "hot", "text position", "x: 0; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "hot", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "hot", "cursor", "hand;")
        If XPthemeActive <> #False
          i.f = 1.3
          tfcolour = RGB(Red(fcolour)*i, Green(fcolour)*i, Blue(fcolour)*i)
          tfcolour = AlphaBlendColour(tfcolour, RGB(255,255,255), 50)
          SetSkinProperty(sysXBarSkin, "explorerbar group item", "hot", "text", "font: "+fname+", "+Str(fheight)+", underline"+"; colour: rgb("+Str(Red(tfcolour))+","+Str(Green(tfcolour))+","+Str(Blue(tfcolour))+")")
        EndIf
        ; pressed
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "pressed", "background", "-1;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "pressed", "image position", "x: 0; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "pressed", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "pressed", "text position", "x: 0; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "pressed", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "pressed", "cursor", "hand;")
        If XPthemeActive <> #False
          i.f = 0.9
          tfcolour = RGB(Red(fcolour)*i, Green(fcolour)*i, Blue(fcolour)*i)
          SetSkinProperty(sysXBarSkin, "explorerbar group item", "pressed", "text", "font: "+fname+", "+Str(fheight)+", underline"+"; colour: rgb("+Str(Red(tfcolour))+","+Str(Green(tfcolour))+","+Str(Blue(tfcolour))+")")
        EndIf
        ; disabled
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "disabled", "background", "-1;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "disabled", "image position", "x: 0; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "disabled", "image padding", "top: 2; left: 0; bottom: 2; right: 4;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "disabled", "text position", "x: 0; y: 50%;")
        SetSkinProperty(sysXBarSkin, "explorerbar group item", "disabled", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        If XPthemeActive <> #False
          SetSkinProperty(sysXBarSkin, "explorerbar group item", "disabled", "text", "font: "+fname+", "+Str(fheight))
        EndIf
        
      ;- **** explorer bar office2007
      Case "office2007xbarskin"
        
        ; create office2007 explorerbar skin
        Global office2007XBarSkin = CreateSkin("office2007XBarSkin")
        ; main explorerbar skin
