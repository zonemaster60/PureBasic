#LIBRARY = 0  ; 1 = compile for PureBasic Library
#DISABLEPROTECTION = 1  ; 1 = disable
#DEBUGENABLED = 0 ; -1 = enable debug


IncludeFile "debuglog.pb"


#AppName = "ProGUI"
#Version = 1.41

CompilerIf #DISABLEPROTECTION = 0
  IncludeFile "CipherSaber2.pb"
  IncludeFile "verify.pb"
  IncludeFile "verify2.pb"
  IncludeFile "verify3.pb"
  IncludeFile "verify4.pb"
  IncludeFile "hash.pb"
CompilerElse
  Macro macro_protectCommand()
  EndMacro
  Macro macro_verifyKeys()
  EndMacro
  Macro macro_loadHash()
  EndMacro
  Macro macro_verifyHash()
  EndMacro
  Macro macro_hash()
  EndMacro
CompilerEndIf

