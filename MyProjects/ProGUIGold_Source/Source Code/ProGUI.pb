  ; copy default colours into custom slots
  For n = 0 To #MaxUIComponents
    UIWhidbeyColours(n)\CustomSilver = UIWhidbeyColours(n)\Silver
    UIWhidbeyColours(n)\CustomBlue = UIWhidbeyColours(n)\Blue
    UIWhidbeyColours(n)\CustomOlive = UIWhidbeyColours(n)\Olive
    UIWhidbeyColours(n)\CustomGrey = UIWhidbeyColours(n)\Grey
  Next

