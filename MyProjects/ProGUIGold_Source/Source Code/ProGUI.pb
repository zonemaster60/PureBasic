ProcedureDLL SetGlobalSkinColourTheme(Name.s) ; Sets the global colour theme name that all the skins will use if supported
  
  macro_protectCommand()
  
  GlobalSkinColourTheme = Trim(LCase(Name))
  
  ; broadcast update skin message to all current process's top level windows's children
  UpdateSkins(0)
  
  ProcedureReturn #True
    
EndProcedure

ProcedureDLL.s GetGlobalSkinColourTheme() ; Gets the current global colour theme name
  
  macro_protectCommand()
  
  If GlobalSkinColourTheme <> ""
    ReturnString$ = GlobalSkinColourTheme
  Else
    ReturnString$ = DefaultGlobalSkinColourTheme
  EndIf
    
  ProcedureReturn ReturnString$
    
EndProcedure

ProcedureDLL SetSkinPath(Path.s) ; Sets the file path of where skins/resources are automatically looked for
  
  macro_protectCommand()
  
  If Path <> "" And FileSize(Path) = -2 ; is dir
    If Mid(Path, Len(Path), 1) <> "\"
      Path = Path + "\"
    EndIf
    SkinPath = Path
    ProcedureReturn #True
  EndIf
    
  ProcedureReturn #False
    
EndProcedure

ProcedureDLL LoadSkin(Path.s) ; Loads and returns handle to a skin
  
  macro_protectCommand()
  
  skinName.s = ""
  skinAuthor.s = ""
  skinDate.s = ""
  skinVersion.s = ""
  skinURL.s = ""
  
  If Path <> ""
    
    If SkinPath <> ""
      SkinLastCurrentDir = GetCurrentDirectory()
      SetCurrentDirectory(SkinPath)
    EndIf
    
    If GetExtensionPart(Path) <> "skn"
      Path = GetPathPart(Path)+StringField(GetFilePart(Path), 1, ".")+".skn"
    EndIf
    xml = LoadXML(#PB_Any, Path)
    If xml = 0
      xml = LoadXML(#PB_Any, GetPathPart(Path)+StringField(GetFilePart(Path), 1, ".")+"\"+GetFilePart(Path))
    EndIf
    If xml = 0
      If FileSize(GetPathPart(Path)+StringField(GetFilePart(Path), 1, ".")+".sknz") > 0
        pack = OpenPack(0, GetPathPart(Path)+StringField(GetFilePart(Path), 1, ".")+".sknz")
        If ExaminePack(0)
              
          While NextPackEntry(0)
            
            name.s = PackEntryName(0)
            If name = "define_skin.xml"
              size = PackEntrySize(0)
              *mem = AllocateMemory(size)
              If *mem <> #Null
                If UncompressPackMemory(0, *mem, size, name)
                  xml = CatchXML(#PB_Any, *mem, size)
                EndIf
                FreeMemory(*mem)
              EndIf
              Break
            EndIf
            
          Wend
          
        EndIf
        
        ClosePack(0)
      EndIf
    EndIf
    If xml <> 0
      
      If XMLStatus(xml) = #PB_XML_Success
        
        skinNode = MainXMLNode(xml)
        name.s = LCase(GetXMLNodeName(skinNode))
        If name = "skin"
          
          node = ChildXMLNode(skinNode)
          name.s = LCase(GetXMLNodeName(node))
          Repeat
            If name = "name"
              skinName =  GetXMLAttribute(node, "id")
            ElseIf name = "author"
              skinAuthor =  GetXMLAttribute(node, "id")
            ElseIf name = "date"
              skinDate =  GetXMLAttribute(node, "id")
            ElseIf name = "version"
              skinVersion =  GetXMLAttribute(node, "id")
            ElseIf name = "url"
              skinURL =  GetXMLAttribute(node, "id")
            EndIf
            node = NextXMLNode(node)
            name.s = LCase(GetXMLNodeName(node))
          Until node = 0 Or name = "component"
          componentNode = node
          
          skinName = StringField(GetFilePart(Path), 1, ".") ; overide skin's internal name
          newSkin = CreateSkin(skinName)
          If newSkin = 0
            FreeXML(xml)
            If SkinPath <> ""
              SetCurrentDirectory(SkinLastCurrentDir)
            EndIf
            ProcedureReturn 0
          EndIf
          
          Repeat
            name = LCase(GetXMLNodeName(componentNode))
            If name = "component"
              component.s = LCase(GetXMLAttribute(componentNode, "id"))
              stateNode = ChildXMLNode(componentNode)
              Repeat
                name = LCase(GetXMLNodeName(stateNode))
                If name = "state"
                  state.s = LCase(GetXMLAttribute(stateNode, "id"))
                  propertyNode = ChildXMLNode(stateNode)
                  Repeat
                    name = LCase(GetXMLNodeName(propertyNode))
                    If name = "property"

                      property.s = LCase(GetXMLAttribute(propertyNode, "id"))
                      value.s = GetXMLNodeText(propertyNode)
                      value = ReplaceString(value, Chr(13), "")
                      value = ReplaceString(value, Chr(10), "")
                      value = ReplaceString(value, Chr(9), "")
                      value = Trim(value, Chr(32))
                      Debug "************"
                      Debug component
                      Debug state
                      Debug property
                      Debug value
                      
                      SkinAutoUpdateRepress = #True
                      If SetSkinProperty(newSkin, component, state, property, value) < 0
                        loaded = -2
                        SkinAutoUpdateRepress = #False
                        Break 3
                      EndIf
                      SkinAutoUpdateRepress = #False
                      
                      loaded = newSkin
                      
                      propertyNode = NextXMLNode(propertyNode)
                    Else
                      loaded = -1
                      Break 3
                    EndIf
                  Until propertyNode = 0
                  
                  stateNode = NextXMLNode(stateNode)
                Else
                  loaded = -1
                  Break 2
                EndIf
              Until stateNode = 0
              
              componentNode = NextXMLNode(componentNode)
            Else
              loaded -1
              Break
            EndIf
          Until componentNode = 0
          
          If loaded <= 0 And newSkin <> 0
            FreeSkin(newSkin)
          EndIf
          
        EndIf
        
      EndIf
      
      FreeXML(xml)
      
    EndIf
    
    If SkinPath <> ""
      SetCurrentDirectory(SkinLastCurrentDir)
    EndIf
    
  EndIf
  
  ProcedureReturn loaded
  
EndProcedure

ProcedureDLL SaveSkin(Skin.i, Path.s, Flags.i) ; Saves a skin
  
  macro_protectCommand()
  
  If Path <> "" And CheckFilename(GetFilePart(Path)) = #False
    ProcedureReturn #False
  EndIf
  
  ForEach skin()
    If @skin() = Skin
      ChangeCurrentElement(skin(), Skin)
      found = #True
      Break
    EndIf
  Next
  
  If found = #True
    
    If SkinPath <> ""
      SkinLastCurrentDir = GetCurrentDirectory()
      SetCurrentDirectory(SkinPath)
    EndIf
    
    pathpart.s = GetPathPart(Path)
    If pathpart <> ""
      SetCurrentDirectory(pathpart)
    EndIf
    
    skinname.s = StringField(GetFilePart(Path), 1, ".")
    
    ; if specified path filename is blank then use internal name
    If skinname = ""
      skinname = skin()\name
    EndIf
    
    subdir.s = ""
    If Flags & #SKIN_SAVE_PACKAGE
      pack = CreatePack(0, skinname+".sknz")
      If pack = 0
        If SkinPath <> ""
          SetCurrentDirectory(SkinLastCurrentDir)
        EndIf
        ProcedureReturn 0
      EndIf
    Else
      ; if sub directory with skin name doesnt exist then create
      If FileSize(skinname) = -1
        If CreateDirectory(skinname) <> 0
          subdir.s = skinname+"\"
        EndIf
      ElseIf FileSize(skinname) = -2 ; dir exists
        subdir.s = skinname+"\"
      EndIf
    EndIf
    
    xml = CreateXML(#PB_Any)
    If xml <> 0
      
      mainNode = CreateXMLNode(RootXMLNode(xml),"")
      If mainNode <> 0
        
        SetXMLNodeName(mainNode, "Skin")
        
        nameNode = CreateXMLNode(mainNode, "") 
        SetXMLNodeName(nameNode, "Name")
        SetXMLAttribute(nameNode, "id", skinname)
        
        If skin()\author <> ""
          authorNode = CreateXMLNode(mainNode, "") 
          SetXMLNodeName(authorNode, "Author")
          SetXMLAttribute(authorNode, "id", skin()\author)
        EndIf
        
        If skin()\date <> ""
          dateNode = CreateXMLNode(mainNode, "") 
          SetXMLNodeName(dateNode, "Date")
          SetXMLAttribute(dateNode, "id", skin()\date)
        EndIf
        
        If skin()\version <> ""
          versionNode = CreateXMLNode(mainNode, "") 
          SetXMLNodeName(versionNode, "Version")
          SetXMLAttribute(versionNode, "id", skin()\version)
        EndIf
        
        If skin()\url <> ""
          urlNode = CreateXMLNode(mainNode, "") 
          SetXMLNodeName(urlNode, "URL")
          SetXMLAttribute(urlNode, "id", skin()\url)
        EndIf
        
        ForEach skin()\component()
          
          component = CreateXMLNode(mainNode, "") 
          SetXMLNodeName(component, "Component")
          SetXMLAttribute(component, "id", skin()\component()\name) 
          
          ForEach skin()\component()\state()
            
            state = CreateXMLNode(component, "") 
            SetXMLNodeName(state, "State")
            SetXMLAttribute(state, "id", skin()\component()\state()\name)
            
            ForEach skin()\component()\state()\property()
              
              property = CreateXMLNode(state, "") 
              SetXMLNodeName(property, "Property")
              SetXMLAttribute(property, "id", skin()\component()\state()\property()\name)
              SetXMLNodeText(property, skin()\component()\state()\property()\value)
              
              ; if resource data is set and value contains valid path
              If skin()\component()\state()\property()\resData <> 0
                value.s = getSkinValueNoParams(skin()\component()\state()\property()\value)
                If isPathSkinResource(value) = #True
                  If Flags & #SKIN_SAVE_PACKAGE
                    filename.s = GetFilePart(value)
                    ; makesure file doesn't already exist in pack
                    If ExaminePack(0)
                      
                      found = #False
                      While NextPackEntry(0)
                        
                        name.s = PackEntryName(0)
                        If name = filename
                          found = #True
                          Break
                        EndIf
                        
                      Wend
                      
                    EndIf
                    If found = #True
                      Continue
                    EndIf
                    If AddPackFile(0, value, filename) = 0 And found = #False
                      If AddPackFile(0, skin()\name+"\"+value, filename) = 0
                        
                        oldpack = OpenPack(1, skin()\name+".sknz")
                        If oldpack <> 0
                          
                          If ExaminePack(1)
              
                            While NextPackEntry(1)
                              
                              name.s = PackEntryName(1)
                              If name = value
                                size = PackEntrySize(1)
                                *mem = AllocateMemory(size)
                                If *mem <> #Null
                                  If UncompressPackMemory(1, *mem, size, name)
                                    f = CreateFile(#PB_Any, GetTemporaryDirectory()+name)
                                    WriteData(f, *mem, size)
                                    CloseFile(f)
                                    AddPackFile(0, GetTemporaryDirectory()+name, name)
                                    DeleteFile(GetTemporaryDirectory()+name)
                                  EndIf
                                  FreeMemory(*mem)
                                EndIf
                                Break
                              EndIf
                              
                            Wend
                            
                          EndIf
                          
                          ClosePack(1)
                        EndIf
                        
                      EndIf
                    EndIf
                  Else
                    ; copy resource file into same dir as skin
                    If CopyFile(value, subdir+GetFilePart(value)) = 0
                      If CopyFile(skin()\name+"\"+value, subdir+GetFilePart(value)) = 0
                      
                        If GetPathPart(value) = "" And FileSize(skin()\name+".sknz") > 0
                          pack = OpenPack(1, skin()\name+".sknz")
                          If pack <> 0
                            
                            If ExaminePack(1)
                
                              While NextPackEntry(1)
                                
                                name.s = PackEntryName(1)
                                If name = value
                                  size = PackEntrySize(1)
                                  *mem = AllocateMemory(size)
                                  If *mem <> #Null
                                    If UncompressPackMemory(1, *mem, size, name)
                                      *file = CreateFile(#PB_Any, subdir+GetFilePart(value))
                                      If *file <> 0
                                        WriteData(*file, *mem, size)
                                        CloseFile(*file)
                                      EndIf
                                    EndIf
                                    FreeMemory(*mem)
                                  EndIf
                                  Break
                                EndIf
                                
                              Wend
                              
                            EndIf
                            
                            ClosePack(1)
                          EndIf
                        EndIf
                        
                      EndIf
                    EndIf
                  EndIf
                  v.s = ReplaceString(skin()\component()\state()\property()\value, value, "")
                  SetXMLNodeText(property, GetFilePart(value)+v)
                Else ; not a resource  
                  
                  If Flags & #SKIN_SAVE_PACKAGE
                    ; detect if a font
                    subparams = CountSkinPropertySubParams(Skin, skin()\Component()\name, skin()\component()\State()\name, skin()\component()\State()\Property()\name, "font")
                    If subParams > 1
                      
                      fontname.s = GetSkinPropertySubParamp(Skin, skin()\Component()\name, skin()\component()\State()\name, skin()\component()\State()\Property()\name, "font", 1)
                      fontsize = Val(GetSkinPropertySubParamp(Skin, skin()\Component()\name, skin()\component()\State()\name, skin()\component()\State()\Property()\name, "font", 2))
                      Debug "detected font"
                      Debug "fontname: "+fontname
                      Debug "fontsize: "+Str(fontsize)
                      
                      ; if a web-safe font then don't embed
                      If isFontWebSafe(fontname) = #True
                        Continue
                      EndIf
                      
                      ; makesure file doesn't already exist in pack
                      If ExaminePack(0)
                        
                        found = #False
                        While NextPackEntry(0)
                          
                          name.s = PackEntryName(0)
                          If FindString(LCase(name), LCase(fontname)) > 0
                            found = #True
                            Break
                          EndIf
                          
                        Wend
                        
                      EndIf
                      If found = #True
                        Continue
                      EndIf
                      
                      hdc = CreateCompatibleDC_(0)
                      font = FontID(skin()\component()\State()\Property()\resData)
                      
                      If SelectObject_(hdc, font)
                        lgByteSize = GetFontData_(hdc, 0, 0, 0, 0)
                        If lgByteSize <> #GDI_ERROR
                          Debug "fontdatasize: "+Str(lgByteSize)
                          *fontBytes = AllocateMemory(lgByteSize)
                          If GetFontData_(hdc, 0, 0, *fontBytes, lgByteSize) = lgByteSize
                            AddPackMemory(0, *fontBytes, lgByteSize, fontname+".fnt")
                          EndIf
                          FreeMemory(*fontBytes)
                        EndIf
                      EndIf
                      
                      DeleteDC_(hdc)
                      
                    EndIf
                    
                  ; not a skin package
                  Else
                    
                    ; detect if a font
                    subparams = CountSkinPropertySubParams(Skin, skin()\Component()\name, skin()\component()\State()\name, skin()\component()\State()\Property()\name, "font")
                    If subParams > 1
                      
                      fontname.s = GetSkinPropertySubParamp(Skin, skin()\Component()\name, skin()\component()\State()\name, skin()\component()\State()\Property()\name, "font", 1)
                      fontsize = Val(GetSkinPropertySubParamp(Skin, skin()\Component()\name, skin()\component()\State()\name, skin()\component()\State()\Property()\name, "font", 2))
                      Debug "detected font"
                      Debug "fontname: "+fontname
                      Debug "fontsize: "+Str(fontsize)
                      
                      ; if a web-safe font then don't embed
                      If isFontWebSafe(fontname) = #True
                        Continue
                      EndIf
                      
                      ; create font data file into same dir as skin
                      hdc = CreateCompatibleDC_(0)
                      font = FontID(skin()\component()\State()\Property()\resData)
                      
                      If SelectObject_(hdc, font)
                        lgByteSize = GetFontData_(hdc, 0, 0, 0, 0)
                        If lgByteSize <> #GDI_ERROR
                          Debug "dir fontdatasize: "+Str(lgByteSize)
                          *fontBytes = AllocateMemory(lgByteSize)
                          If GetFontData_(hdc, 0, 0, *fontBytes, lgByteSize) = lgByteSize
                            
                              f = CreateFile(#PB_Any, subdir+fontname+".fnt")
                              WriteData(f, *fontBytes, lgByteSize)
                              CloseFile(f)
                            
                          EndIf
                          FreeMemory(*fontBytes)
                        EndIf
                      EndIf
                      
                      DeleteDC_(hdc)
                      
                    EndIf
                    
                  EndIf
                  
                EndIf
              EndIf
              
            Next
            
          Next
          
        Next
        
        FormatXML(xml, #PB_XML_WindowsNewline|#PB_XML_ReFormat, 3)
        If Flags & #SKIN_SAVE_PACKAGE
          size = ExportXMLSize(xml)
          *mem = AllocateMemory(size)
          ExportXML(xml, *mem, size)
          OpenPack(0, skinname+".sknz")
          AddPackMemory(0, *mem, size, "define_skin.xml")
          
          FreeMemory(*mem)
        Else
          If SaveXML(xml, subdir+skinname+".skn") <> 0
            ret = #True
          EndIf
        EndIf
        
      EndIf
      
      FreeXML(xml)
      
      If Flags & #SKIN_SAVE_PACKAGE
        ClosePack(0)
      EndIf
      
    EndIf
    
    If SkinPath <> ""
      SetCurrentDirectory(SkinLastCurrentDir)
    EndIf
    
  EndIf
  
  ProcedureReturn ret
  
EndProcedure

ProcedureDLL CreateSkin(Name.s) ; Creates a skin
  
  macro_protectCommand()
  
  LastElement(skin())
  If AddElement(skin()) <> 0
    skin()\name = Name
    skin()\autoUpdate = #True
    ProcedureReturn @skin()
  EndIf
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL.s GetSkinName(Skin.i) ; Returns the name of a skin.
  
  macro_protectCommand()
  
  ReturnString$ = ""
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  ForEach skin()
    If @skin() = Skin
      ReturnString$ = skin()\name
      Break
    EndIf
  Next
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  
  ProcedureReturn ReturnString$
EndProcedure

ProcedureDLL SetSkinName(Skin.i, Name$) ; Sets the name of a skin.
  
  macro_protectCommand()
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  ForEach skin()
    If @skin() = Skin
      skin()\name = Name$
      ret = #True
      Break
    EndIf
  Next
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  
  ProcedureReturn ret
EndProcedure

ProcedureDLL GetSkinHandle(Name.s) ; Returns the handle of a created/loaded Skin by name.
  
  macro_protectCommand()
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  ForEach skin()
    If Trim(LCase(skin()\name)) = Trim(LCase(name))
      *skin = @skin()
      Break
    EndIf
  Next
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  
  ProcedureReturn *skin
EndProcedure

ProcedureDLL SetSkinAutoUpdate(Skin.i, State.b) ; Sets whether all controls using the specified skin are automatically updated when the skin is changed, State = true/false.
  
  macro_protectCommand()
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  ForEach skin()
    If @skin() = Skin
      If State = #False
        skin()\autoUpdate = #False
      ElseIf State = #True
        skin()\autoUpdate = #True
      EndIf
      result = #True
      Break
    EndIf
  Next
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  
  ProcedureReturn result
  
EndProcedure

ProcedureDLL GetSkinAutoUpdate(Skin.i) ; Returns true if all controls using the specified skin are automatically updated, false otherwise.
  
  macro_protectCommand()
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  ForEach skin()
    If @skin() = Skin
      result = skin()\autoUpdate
      Break
    EndIf
  Next
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  
  ProcedureReturn result
  
EndProcedure

ProcedureDLL SetSkinProperty(Skin.i, Component.s, State.s, Property.s, Value.s) ; Sets a skin's property
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  Value = LCase(Value)
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  ForEach skin()
    If @skin() = Skin
      
      ; check component for optional colour theme name separated by colon
      ; and format components as "component:colourtheme" so hash will always work
      If FindString(Component, ":", 1) > 0
        colourTheme.s = Trim(StringField(Component, 2, ":"))
        Component = Trim(StringField(Component, 1, ":"))+":"+colourTheme
      EndIf
      
      selectSkinProperty(Component, State, Property)
      
      skin()\component()\state()\property()\value = Value
      
      ; if the value property is a file resource then load it
      ret = isPathSkinResource(Value)
      If ret = #True
        
        ret = loadSkinResource(Value)
        
      ElseIf ret = 0
        
        ;detect if value contains gradient and create into property data
        subparams = CountSkinPropertySubParams(Skin, Component, State, Property, "gradient")
        If subparams > 1
          
          p.s = GetSkinPropertySubParamp(Skin, Component, State, Property, "gradient", 1)
          If p = "vertical" Or p = "ellipse" Or p = "rectangle"
            
            If p = "vertical"
              style = #VerticalGRADIENT
            ElseIf p = "ellipse"
              style = #EllipseGRADIENT
            ElseIf p = "rectangle"
              style = #RectangleGRADIENT
            EndIf
            
            c1 = Val(GetSkinPropertySubParamp(Skin, Component, State, Property, "gradient", 2))
            c2 = Val(GetSkinPropertySubParamp(Skin, Component, State, Property, "gradient", 3))
            nxt = 4
          Else
            c1 = Val(GetSkinPropertySubParamp(Skin, Component, State, Property, "gradient", 1))
            c2 = Val(GetSkinPropertySubParamp(Skin, Component, State, Property, "gradient", 2))
            nxt = 3
          EndIf
          
          ; no alpha then remake colour with alpha
          If Alpha(c1) = 0
            c1 = MakeColor(255, Red(c1), Green(c1), Blue(c1))
          EndIf
          
          ; no alpha then remake colour with alpha
          If Alpha(c2) = 0
            c2 = MakeColor(255, Red(c2), Green(c2), Blue(c2))
          EndIf
          
          gradient = CreateGradient(style, c1, c2)
          If gradient <> 0
            
            SetSkinPropertyData(Skin, Component, State, Property, gradient)
            SetSkinPropertyDataSize(Skin, Component, State, Property, SizeOf(gradient))
            
            ; extract any extra sub params as gradient colour pairs
            If subparams >= 4
              n = nxt
              Repeat
                pos$ = GetSkinPropertySubParamp(Skin, Component, State, Property, "gradient", n)
                c$ = GetSkinPropertySubParamp(Skin, Component, State, Property, "gradient", n+1)
                If pos$ <> "" Or c$ <> ""
                  pos.f = ValF(pos$)
                  c = Val(c$)
                  If Alpha(c) = 0
                    c = MakeColor(255, Red(c), Green(c), Blue(c))
                  EndIf
                  SetGradientColour(gradient, pos, c)
                  n = n + 2
                EndIf
              Until pos$ = "" And c$ = ""
            EndIf
            
          EndIf
          
        EndIf
        
        ;detect if value contains font and create into property data
        subparams = CountSkinPropertySubParams(Skin, Component, State, Property, "font")
        If subParams > 1
          
          fontname.s = GetSkinPropertySubParamp(Skin, Component, State, Property, "font", 1)
          fontsize = Val(GetSkinPropertySubParamp(Skin, Component, State, Property, "font", 2))
 
          
          ; if optional extra style params then iterate through and create style flag for loadfont
          style = 0
          If subparams > 2
            For n = 3 To subparams
              Select GetSkinPropertySubParamp(Skin, Component, State, Property, "font", n)
                Case "underlined"
                  style = style | #PB_Font_Underline
                Case "underline"
                  style = style | #PB_Font_Underline
                Case "italic"
                  style = style | #PB_Font_Italic
                Case "bold"
                  style = style | #PB_Font_Bold
                Case "strikethrough"
                  style = style | #PB_Font_StrikeOut
                Case "strike"
                  style = style | #PB_Font_StrikeOut
                Case "strikeout"
                  style = style | #PB_Font_StrikeOut
                Case "striked"
                  style = style | #PB_Font_StrikeOut
              EndSelect
            Next
          EndIf
          
          ; try and load font from skin dir/pack if exists
          If SkinPath <> ""
            SkinLastCurrentDir = GetCurrentDirectory()
            SetCurrentDirectory(SkinPath)
          EndIf
          
          If FileSize(skin()\name+"\"+fontname+".fnt") > 0
            
            lib = OpenLibrary(#PB_Any, "Gdi32.dll")
            If lib
              #FR_PRIVATE = $10
              #FR_NOT_ENUM = $20
              pname.s = skin()\name+"\"+fontname+".fnt"
              CallFunction(lib, "AddFontResourceExW", @pname, #FR_PRIVATE|#FR_NOT_ENUM, 0)
              CloseLibrary(lib)
            EndIf
            
          ElseIf FileSize(skin()\name+".sknz") > 0
          
            pack = OpenPack(0, skin()\name+".sknz")
            If pack <> 0
              
              If ExaminePack(0)
                
                While NextPackEntry(0)
                  
                  name.s = PackEntryName(0)
                  If FindString(LCase(name), LCase(fontname)) > 0
                    size = PackEntrySize(0)
                    *mem = AllocateMemory(size)
                    If *mem <> #Null
                      If UncompressPackMemory(0, *mem, size, name)
                        Debug "decompressed font"
                        AddFontMemResourceEx_(*mem, size, 0, @numfonts)
                        Debug "number of fonts added from mem: "+Str(numfonts)
                      EndIf
                      FreeMemory(*mem)
                    EndIf
                    Break
                  EndIf
                  
                Wend
                
              EndIf
              
              ClosePack(0)
            EndIf
          EndIf
          
          font = LoadFont(#PB_Any, fontname, fontsize, style)
          If font <> 0
            Debug "font loaded"
            SetSkinPropertyData(Skin, Component, State, Property, font)
            SetSkinPropertyDataSize(Skin, Component, State, Property, 0)
          Else
            Debug "font doesn't exist!"
          EndIf
          
        EndIf
        
        ret = #True
      EndIf
      
      SkinAutoUpdate = skin()\autoUpdate
      
      If ListSize(skin()) > 0
        ChangeCurrentElement(skin(), *thisSkin)
      EndIf
      
      If SkinAutoUpdate = #True And SkinAutoUpdateRepress = #False
        UpdateSkins(Skin)
      EndIf
      
      ProcedureReturn ret
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  ProcedureReturn #False
EndProcedure

ProcedureDLL SetSkinPropertyParam(Skin.i, Component.s, State.s, Property.s, Parameter.s, Value.s) ; Sets a skin property parameter's value.
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  Parameter = LCase(Parameter)
  Value = LCase(Value)
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  ForEach skin()
    If @skin() = Skin
      
      selectSkinProperty(Component, State, Property)
      oldValue.s = skin()\component()\state()\property()\value
      newValue.s = ""
      
      ; find parameter
      i = 1
      found = 0
      Repeat
        param$ = StringField(oldValue, i, ";")
        If FindString(param$, Parameter) > 0
          If Mid(param$, 1, 1) = " "
            newValue = ReplaceString(oldValue, param$, " "+Parameter+": "+Value)
          Else
            newValue = ReplaceString(oldValue, param$, Parameter+": "+Value)
          EndIf
          found = #True
          Break
        EndIf
        i + 1
      Until param$ = ""
      
      If found = #False
        newValue = oldValue
        If newValue <> "" And Mid(newValue, Len(newValue), 1) <> ";"
          newValue = newValue + "; "
        EndIf
        newValue = newValue + Parameter+": "+Value+";"
      EndIf
      
      ;Debug "param: "+Parameter
      ;Debug "value: "+Value
      ;Debug "old: "+skin()\component()\state()\property()\value
      ;Debug "new: "+newValue
      skin()\component()\state()\property()\value = newValue
      
      SetSkinProperty(Skin, Component, State, Property, newValue)
      
      If ListSize(skin()) > 0
        ChangeCurrentElement(skin(), *thisSkin)
      EndIf
      
      ProcedureReturn ret
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  ProcedureReturn #False
EndProcedure

Procedure.s GetSkinPropertyp(Skin.i, Component.s, State.s, Property.s) ; Gets a skin's property
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  
  ret$ = ""
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  
  
  ForEach skin()
    If @skin() = Skin
      
      Component = componentColourTheme(Component, State, Property)
      
      If isSkinProperty(Component, State, Property) = #True
      
        ret$ = skin()\component()\state()\property()\value
        r.s = ret$
        
        pos = FindString(ret$, "rgba", 1)
        If pos > 0
          epos = FindString(ret$, ")", pos)
          c = checkColourValue(Mid(ret$, pos, (epos+1)-pos))
          If c <> -1
            r.s = ReplaceString(ret$, Mid(ret$, pos, (epos+1)-pos), Str(c))
          EndIf
        EndIf
        
        pos = FindString(ret$, "rgb", 1)
        If pos > 0
          epos = FindString(ret$, ")", pos)
          c = checkColourValue(Mid(ret$, pos, (epos+1)-pos))
          If c <> -1
            r.s = ReplaceString(ret$, Mid(ret$, pos, (epos+1)-pos), Str(c))
          EndIf
        EndIf
        
        If FindString(r, ",", 1) = 0 And FindString(r, ":", 1) = 0 And CountString(r, ";") <= 1 
          c = checkColourValue(ret$)
          If c <> -1
            ret$ = Str(c)
          EndIf
        EndIf
       
      EndIf
      
      Break
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  
  ProcedureReturn ret$
EndProcedure

ProcedureDLL.s GetSkinProperty(Skin.i, Component.s, State.s, Property.s) ; Gets a skin's property
  
  macro_protectCommand()
  
  ReturnString$ = GetSkinPropertyp(Skin, Component, State, Property)
  
  ProcedureReturn ReturnString$
  
EndProcedure

Procedure.s GetSkinPropertyParamp(*skin, Component.s, State.s, Property.s, Parameter.s) ; Returns a skin property parameter value
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  
  ret$ = ""
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  ForEach skin()
    If @skin() = *skin
      
      Component = componentColourTheme(Component, State, Property)
      
      If isSkinProperty(Component, State, Property) = #True
      
        If Parameter = ""
          ret$ = StringField(skin()\component()\state()\property()\value, 1, ";")
          ret$ = Trim(Trim(ret$),";")
          
          If ListSize(skin()) > 0
            ChangeCurrentElement(skin(), *thisSkin)
          EndIf
          ProcedureReturn ret$
        EndIf
        
        Dim param.skinValueParam(1)
        If getSkinValueParams(skin()\component()\state()\property()\value, param()) = #True
          
          For n = 0 To ArraySize(param())-1
            
            name.s = LCase(param(n)\name)
            var.s = LCase(param(n)\var)
            If name = LCase(Parameter)
              If CountSkinPropertySubParams(*skin, Component, State, Property, Parameter) = 1
                c = checkColourValue(var)
                If c <> -1
                  var = Str(c)
                EndIf
              EndIf
              ret$ = var
              
              If ListSize(skin()) > 0
                ChangeCurrentElement(skin(), *thisSkin)
              EndIf
              ProcedureReturn ret$
            EndIf
            
          Next
        Else
          ret$ = Trim(Trim(skin()\component()\state()\property()\value),";")
        EndIf
            
      EndIf
      
      Break
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  
  ProcedureReturn ret$
EndProcedure

ProcedureDLL.s GetSkinPropertyParam(*skin, Component.s, State.s, Property.s, Parameter.s) ; Returns a skin property parameter value
  
  macro_protectCommand()
  
  ReturnString$ = GetSkinPropertyParamp(*skin, Component, State, Property, Parameter)
  
  ProcedureReturn ReturnString$
  
EndProcedure

Procedure.s GetSkinPropertySubParamp(Skin.i, Component.s, State.s, Property.s, Parameter.s, Index.i) ; Returns a skin property parameter's comma separated sub value
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  
  ret$ = ""
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  If Index = 0
    Index = 1
  EndIf
  
  ForEach skin()
    If @skin() = Skin
      
      Component = componentColourTheme(Component, State, Property)
      
      If isSkinProperty(Component, State, Property)
      
        If Parameter = ""
          
          If ListSize(skin()) > 0
            ChangeCurrentElement(skin(), *thisSkin)
          EndIf
          ProcedureReturn ret$
        EndIf
        
        Dim param.SkinValueParam(1)
        If getSkinValueParams(skin()\component()\state()\property()\value, param()) = #True
          
          For n = 0 To ArraySize(param())-1
            
            name.s = LCase(param(n)\name)
            var.s = LCase(param(n)\var)
            If name = LCase(Parameter)
              
              spos = 1
              i = 1
              For pos = 1 To Len(var)
                s.s = Mid(var, pos, 1)
                
                If s = Chr(34) And block = #False And inQuote = #False
                  block = #True
                  inQuote = #True
                ElseIf s = Chr(34) And inQuote = #True
                  block = #False
                  inQuote = #False
                EndIf
                
                If s = Chr(39) And block = #False And inQuote = #False
                  block = #True
                  inQuote = #True
                ElseIf s = Chr(39) And inQuote = #True
                  block = #False
                  inQuote = #False
                EndIf
                
                If (s = "(" Or s = Chr(123)) And block = #False
                  block = #True
                ElseIf (s = ")" Or s = Chr(125))
                  block = #False
                EndIf
                If s = "," And block = #False
                  subparam.s = Trim(Mid(var,spos, (pos)-spos))
                  
                  If i = Index
                    c = checkColourValue(subparam)
                    If c <> -1
                      subparam = Str(c)
                    EndIf
                    ret$ = subparam
                    
                    If ListSize(skin()) > 0
                      ChangeCurrentElement(skin(), *thisSkin)
                    EndIf
                    ProcedureReturn ret$
                  EndIf
                  i = i + 1
                  spos = pos+1
                EndIf
                
              Next
              subparam.s = Trim(Mid(var,spos, (pos)-spos))
              If i = index
                c = checkColourValue(subparam)
                If c <> -1
                  subparam = Str(c)
                EndIf
                ret$ = subparam
                
                If ListSize(skin()) > 0
                  ChangeCurrentElement(skin(), *thisSkin)
                EndIf
                ProcedureReturn ret$
              EndIf
              
              Break
              
            EndIf
            
          Next
        
        EndIf
            
      EndIf
      
      Break
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  ProcedureReturn ret$
EndProcedure

ProcedureDLL.s GetSkinPropertySubParam(Skin.i, Component.s, State.s, Property.s, Parameter.s, Index.i) ; Returns a skin property parameter's comma separated sub value
  
  macro_protectCommand()
  
  ReturnString$ = GetSkinPropertySubParamp(Skin.i, Component.s, State.s, Property.s, Parameter.s, Index.i)
  
  ProcedureReturn ReturnString$
  
EndProcedure

ProcedureDLL CountSkinPropertySubParams(Skin.i, Component.s, State.s, Property.s, Parameter.s) ; Returns number of skin property parameter's comma separated sub values
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  ForEach skin()
    If @skin() = Skin
      
      Component = componentColourTheme(Component, State, Property)
      
      If isSkinProperty(Component, State, Property) = #True
      
        If Parameter = ""
          If ListSize(skin()) > 0
            ChangeCurrentElement(skin(), *thisSkin)
          EndIf
          ProcedureReturn 0
        EndIf
        
        Dim param.SkinValueParam(1)
        If getSkinValueParams(skin()\component()\state()\property()\value, param()) = #True
          
          For n = 0 To ArraySize(param())-1
            
            name.s = LCase(param(n)\name)
            var.s = LCase(param(n)\var)
            
            If name = LCase(Parameter)
              
              pos = FindString(var, "(", 1)
              If pos > 0
                epos = FindString(var, ")", pos)
                var = ReplaceString(var, Mid(var, pos, (epos+1)-pos), "#")
              EndIf
              
              pos = FindString(var, Chr(34), 1)
              If pos > 0
                epos = FindString(var, Chr(34), pos+1)
                var = ReplaceString(var, Mid(var, pos, (epos+1)-pos), "#")
              EndIf
              
              pos = FindString(var, Chr(39), 1)
              If pos > 0
                epos = FindString(var, Chr(39), pos+1)
                var = ReplaceString(var, Mid(var, pos, (epos+1)-pos), "#")
              EndIf
              
              pos = FindString(var, Chr(123), 1)
              If pos > 0
                epos = FindString(var, Chr(125), pos+1)
                var = ReplaceString(var, Mid(var, pos, (epos+1)-pos), "#")
              EndIf
              
              i = 1
              Repeat
                subparam.s = StringField(var, i, ",")
                i = i + 1
              Until subparam = ""
              If ListSize(skin()) > 0
                ChangeCurrentElement(skin(), *thisSkin)
              EndIf
              ProcedureReturn i-2
              
            EndIf
            
          Next
        
        EndIf
            
      EndIf
      
      Break
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  ProcedureReturn 0
EndProcedure

ProcedureDLL GetSkinPropertyColour(Skin.i, Component.s, State.s, Property.s) ; if skin's property is a colour then returns numerical colour value else -1
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  ForEach skin()
    If @skin() = Skin
      
      Component = componentColourTheme(Component, State, Property)
      
      If isSkinProperty(Component, State, Property) = #True
      
        value.s = skin()\component()\state()\property()\value
        r.s = value
        
        pos = FindString(value, "rgba", 1)
        If pos > 0
          epos = FindString(value, ")", pos)
          c = checkColourValue(Mid(value, pos, (epos+1)-pos))
          If c <> -1
            r.s = ReplaceString(value, Mid(value, pos, (epos+1)-pos), Str(c))
          EndIf
        EndIf
        
        pos = FindString(value, "rgb", 1)
        If pos > 0
          epos = FindString(value, ")", pos)
          c = checkColourValue(Mid(value, pos, (epos+1)-pos))
          If c <> -1
            r.s = ReplaceString(value, Mid(value, pos, (epos+1)-pos), Str(c))
          EndIf
        EndIf
        
        If FindString(r, ",", 1) = 0 And FindString(r, ":", 1) = 0 And CountString(r, ";") <= 1 
          c = checkColourValue(value)
          If ListSize(skin()) > 0
            ChangeCurrentElement(skin(), *thisSkin)
          EndIf
          ProcedureReturn c
        EndIf
        
      EndIf
      
      Break
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  ProcedureReturn -1
EndProcedure

ProcedureDLL GetSkinPropertySubParamColour(Skin.i, Component.s, State.s, Property.s, Parameter.s, Index.i) ; if skin property parameter's comma separated sub value is a colour then returns numerical colour value else -1
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  If Index = 0
    Index = 1
  EndIf
  
  ForEach skin()
    If @skin() = Skin
      
      Component = componentColourTheme(Component, State, Property)
      
      If isSkinProperty(Component, State, Property) = #True
            
        If Parameter = ""
          If ListSize(skin()) > 0
            ChangeCurrentElement(skin(), *thisSkin)
          EndIf
          ProcedureReturn -1
        EndIf
        
        Dim param.SkinValueParam(1)
        If getSkinValueParams(skin()\component()\state()\property()\value, param()) = #True
          
          For n = 0 To ArraySize(param())-1
            
            name.s = LCase(param(n)\name)
            var.s = LCase(param(n)\var)
            If name = LCase(Parameter)
              
              spos = 1
              i = 1
              For pos = 1 To Len(var)
                s.s = Mid(var, pos, 1)
                
                If s = Chr(34) And block = #False And inQuote = #False
                  block = #True
                  inQuote = #True
                ElseIf s = Chr(34) And inQuote = #True
                  block = #False
                  inQuote = #False
                EndIf
                
                If s = Chr(39) And block = #False And inQuote = #False
                  block = #True
                  inQuote = #True
                ElseIf s = Chr(39) And inQuote = #True
                  block = #False
                  inQuote = #False
                EndIf
                
                If (s = "(" Or s = Chr(123)) And block = #False
                  block = #True
                ElseIf (s = ")" Or s = Chr(125))
                  block = #False
                EndIf
                If s = "," And block = #False
                  subparam.s = Trim(Mid(var,spos, (pos)-spos))
                  
                  If i = Index
                    If ListSize(skin()) > 0
                      ChangeCurrentElement(skin(), *thisSkin)
                    EndIf
                    ProcedureReturn checkColourValue(subparam)
                  EndIf
                  i = i + 1
                  spos = pos+1
                EndIf
                
              Next
              subparam.s = Trim(Mid(var,spos, (pos)-spos))
              If i = index
                If ListSize(skin()) > 0
                  ChangeCurrentElement(skin(), *thisSkin)
                EndIf
                ProcedureReturn checkColourValue(subparam)
              EndIf
              
              Break
              
            EndIf
            
          Next
        
        EndIf
        
      EndIf
      
      Break
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  ProcedureReturn -1
EndProcedure

ProcedureDLL GetSkinPropertyData(Skin.i, Component.s, State.s, Property.s) ; Gets a pointer to skin's property data
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  ForEach skin()
    If @skin() = Skin
      
      Component = componentColourTheme(Component, State, Property)
      
      If isSkinProperty(Component, State, Property) = #True
      
        If skin()\component()\state()\property()\resType = #SKIN_RES_IMAGE
          ret = ImageID(skin()\component()\state()\property()\resData)
          If ListSize(skin()) > 0
            ChangeCurrentElement(skin(), *thisSkin)
          EndIf
          ProcedureReturn ret
        EndIf
        ret = skin()\component()\state()\property()\resData
        If ListSize(skin()) > 0
          ChangeCurrentElement(skin(), *thisSkin)
        EndIf
        ProcedureReturn ret
        
      EndIf
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  ProcedureReturn 0
EndProcedure

ProcedureDLL GetSkinPropertyDataSize(Skin.i, Component.s, State.s, Property.s) ; Get the size in bytes of skin's property data
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  ForEach skin()
    If @skin() = Skin
      
      Component = componentColourTheme(Component, State, Property)
      
      If isSkinProperty(Component, State, Property) = #True
      
        ret = skin()\component()\state()\property()\resDataSize
        If ListSize(skin()) > 0
          ChangeCurrentElement(skin(), *thisSkin)
        EndIf
        ProcedureReturn ret
        
      EndIf
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  ProcedureReturn 0
EndProcedure

ProcedureDLL SetSkinPropertyData(Skin.i, Component.s, State.s, Property.s, ResourceData.i) ; Set skin's property data
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  ForEach skin()
    If @skin() = Skin
      
      ; check component for optional colour theme name separated by colon
      ; and format components as "component:colourtheme" so hash will always work
      If FindString(Component, ":", 1) > 0
        colourTheme.s = Trim(StringField(Component, 2, ":"))
        Component = Trim(StringField(Component, 1, ":"))+":"+colourTheme
      EndIf
      
      selectSkinProperty(Component, State, Property)
      skin()\component()\state()\property()\resData = ResourceData
      skin()\component()\state()\property()\resType = #SKIN_RES_DATA
      If ListSize(skin()) > 0
        ChangeCurrentElement(skin(), *thisSkin)
      EndIf
      ProcedureReturn #True
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  ProcedureReturn 0
EndProcedure

ProcedureDLL SetSkinPropertyDataSize(Skin.i, Component.s, State.s, Property.s, DataSize.i) ; Set the size in bytes of skin's property data
  
  macro_protectCommand()
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  ForEach skin()
    If @skin() = Skin
      
      ; check component for optional colour theme name separated by colon
      ; and format components as "component:colourtheme" so hash will always work
      If FindString(Component, ":", 1) > 0
        colourTheme.s = Trim(StringField(Component, 2, ":"))
        Component = Trim(StringField(Component, 1, ":"))+":"+colourTheme
      EndIf
      
      selectSkinProperty(Component, State, Property)
      skin()\component()\state()\property()\resDataSize = DataSize
      If ListSize(skin()) > 0
        ChangeCurrentElement(skin(), *thisSkin)
      EndIf
      ProcedureReturn #True
      
    EndIf
  Next
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  ProcedureReturn 0
EndProcedure

ProcedureDLL MergeSkins(*SourceSkin.skins, *DestinationSkin.skins) ; Merges the source skin into the destination skin.
  
  macro_protectCommand()
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  ForEach skin()
    If @skin() = *SourceSkin
      foundSourceSkin = #True
    EndIf
    If @skin() = *DestinationSkin
      foundDestinationSkin = #True
    EndIf
    If foundSourceSkin = #True And foundDestinationSkin = #True
      Break
    EndIf
  Next
  
  If foundSourceSkin = #True And foundDestinationSkin = #True
    
    ForEach *SourceSkin\component()
      ForEach *SourceSkin\component()\state()
        ForEach *SourceSkin\component()\state()\property()
          
          selectSkinPropertyBySkin(*DestinationSkin, *SourceSkin\component()\name, *SourceSkin\component()\state()\name, *SourceSkin\component()\state()\property()\name)
          ;If *DestinationSkin\component()\state()\property()\value = ""
            *DestinationSkin\component()\state()\property()\value = *SourceSkin\component()\state()\property()\value
            *DestinationSkin\component()\state()\property()\resData = *SourceSkin\component()\state()\property()\resData
            *DestinationSkin\component()\state()\property()\resDataSize = *SourceSkin\component()\state()\property()\resDataSize
            *DestinationSkin\component()\state()\property()\resType = *SourceSkin\component()\state()\property()\resType
          ;EndIf
          
        Next
      Next
    Next
    
    ret = #True
    
  EndIf
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  
  ProcedureReturn ret
  
EndProcedure

ProcedureDLL CopySkin(Skin.i) ; Returns a copy of the specified skin
  
  macro_protectCommand()
  
  ForEach skin()
    If @skin() = Skin
      
      *tskin = @skin()
      
      LastElement(skin())
      If AddElement(skin()) <> 0
        CopyStructure(*tskin, @skin(), skins)
        ProcedureReturn @skin()
      EndIf
      
      ProcedureReturn 0
      
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL CopySkinComponent(*Skin.skins, ComponentName.s, NewName.s) ; Creates a copy of the specified ComponentName$ as NewName$.
  
  macro_protectCommand()
  
  ForEach skin()
    If @skin() = *Skin
      
      AddElement(skin()\component())
      *new.skinComponents = skin()\component()
      selectSkinProperty(ComponentName, "", "")
      If Trim(LCase(skin()\component()\name)) = Trim(LCase(ComponentName))
        CopyStructure(skin()\component(), *new, skinComponents)
        *new\name = NewName
        ret = #True
      Else
        ChangeCurrentElement(skin()\component(), *new)
        DeleteElement(skin()\component())
      EndIf
      Break
      
    EndIf
  Next
  
  ProcedureReturn ret
  
EndProcedure

ProcedureDLL IsSkin(Skin.i) ; Returns true if handle is a skin.
  
  macro_protectCommand()
  
  ForEach skin()
    If @skin() = Skin
      ProcedureReturn #True
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL FreeSkin(Skin.i) ; Frees a skin from memory.
  
  macro_protectCommand()
  
  ForEach skin()
    If @skin() = Skin
      
      ForEach skin()\component()
        ForEach skin()\component()\state()
          ForEach skin()\component()\state()\property()
            If skin()\component()\state()\property()\resData <> 0
              Debug "found data"
              
              Select skin()\component()\state()\property()\resType 
                Case #SKIN_RES_ICON
                  Debug "freeing icon"
                  DestroyIcon_(skin()\component()\state()\property()\resData)
                  Continue
                Case #SKIN_RES_IMAGE
                  Debug "freeing image"
                  FreeImage(skin()\component()\state()\property()\resData)
                  Continue
                Case #SKIN_RES_DATA
                  
                  If IsFont(skin()\component()\state()\property()\resData) <> 0
                    Debug "freeing font"
                    FreeFont(skin()\component()\state()\property()\resData)
                    Continue
                  EndIf
                  
                  If FreeGradient(skin()\component()\state()\property()\resData) = #True
                    Debug "freed gradient"
                    Continue
                  EndIf
                  
                  Debug "freeing data"
                  FreeMemory(*oldResData)
              EndSelect
              
            EndIf
          Next
        Next
      Next
      
      DeleteElement(skin())
      ProcedureReturn #True
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

;--
;- MenuEx
;--
Procedure displayDelayedShadows(hwnd, uMsg, idEvent, dwTime)
  ForEach drpShadow()
    If drpShadow()\delayed = #True
      ShowWindow_(drpShadow()\hwnd, #SW_SHOWNA)
    EndIf
  Next
  KillTimer_(hwnd, idEvent)
EndProcedure

Procedure doMenuShadows(WindowID)
  
  If ListSize(shadow()) > 0
    *thisShadow = @shadow()
    ForEach shadow()
      If shadow()\hwnd = WindowID
        ProcedureReturn 0
      EndIf
    Next
    ChangeCurrentElement(shadow(), *thisShadow)
  EndIf
  
  ; create drop shadows
  If systemDropShadowsEnabled = #True
    
    GetWindowRect_(WindowID, @rec.RECT)
    width = rec\right-rec\left
    height = rec\bottom-rec\top
    wp.POINT
    wp\x = rec\left
    wp\y = rec\top
    lSize = 5
    LastElement(shadow())
    AddElement(shadow())
    shadow()\hwnd = WindowID
    
    If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2007
      colour = getMenuColourEx(menuex()\style, #menuDropShadow, #returnColour)
      Alpha = PeekB(@colour+3)&$FF
      colour = RGB(Blue(colour), Green(colour), Red(colour))
    ElseIf menuex()\style = 5
      colour = getMenuColour(5, #menuDropShadow)
      Alpha = PeekB(@colour+3)&$FF
      colour = RGB(Blue(colour), Green(colour), Red(colour))
    Else
      Alpha = 40
      colour = 0
    EndIf
    
    ;/ if submenu and on left of parent then handle special dropshadow rendering for vertical shadow
    If subMenuActive = #True
      
      thisPopupUserData = @popupUserData()
      ChangeCurrentElement(popupUserData(), popupUserData()\parentPopupUserData)
      bottomShadowHidden = popupUserData()\bottomShadowHandle
      bottomShadowX = popupUserData()\bottomShadowX
      bottomShadowY = popupUserData()\bottomShadowY
      bottomShadowWidth = popupUserData()\bottomShadowWidth
      bottomShadowFlags = popupUserData()\bottomShadowFlags
      leftBottomShadowX = popupUserData()\leftBottomShadowX
      leftBottomShadowY = popupUserData()\leftBottomShadowY
      leftBottomShadowWidth = popupUserData()\leftBottomShadowWidth
      leftBottomShadowHandle = popupUserData()\leftBottomShadowHandle
      GetWindowRect_(popupUserData()\WindowID, @rec.RECT)
      parentSubmenu = popupUserData()\submenu
      ChangeCurrentElement(popupUserData(), thisPopupUserData)
      
      If parentSubmenu = 0 And menuTitleVOffset = -1 And leftBottomShadowWidth = 0
        extraHeight = menuTitleHeight-1
        bottomShadowX = bottomShadowX+lSize
        bottomShadowWidth = bottomShadowWidth-lSize
        bottomShadowFlags = #DropShadowEnd
      EndIf
      
      If thisMenuWindowYBottom <= rec\bottom+extraHeight And rec\left > wp\x
        ; don't display a vertical drop shadow
      ElseIf thisMenuWindowYBottom > rec\bottom+extraHeight And rec\left > wp\x
        
        shadow()\rightShadow = dropShadow(wp\x+width, rec\bottom+extraHeight, lSize, thisMenuWindowYBottom-(rec\bottom+extraHeight), colour, Alpha, #DropShadowVertical|#DropShadowNoEnds)
        If parentSubmenu = 0 And menuTitleVOffset = -1 And extraHeight = 0
          
          ; create new shadow into tmp slot
          popupUserData()\bottomShadowTmp = dropShadow(leftBottomShadowX-lSize, leftBottomShadowY, leftBottomShadowWidth+lSize, lSize, colour, Alpha, #DropShadowNoEnds)
          ; hide parents bottom shadow
          ShowWindow_(leftBottomShadowHandle, #SW_HIDE)
          popupUserData()\bottomShadowHidden = leftBottomShadowHandle
          
        Else
          ; create new shadow into tmp slot
          popupUserData()\bottomShadowTmp = dropShadow(bottomShadowX-lSize, bottomShadowY, bottomShadowWidth+lSize, lSize, colour, Alpha, bottomShadowFlags)
          ; hide parents bottom shadow
          ShowWindow_(bottomShadowHidden, #SW_HIDE)
          popupUserData()\bottomShadowHidden = bottomShadowHidden
        EndIf
        
      Else
        shadow()\rightShadow = dropShadow(wp\x+width, wp\y+lSize, lSize, height-lSize, colour, Alpha, #DropShadowVertical|#DropShadowStart)
      EndIf
      
      ;/ draw normal vertical shadow  
    Else
      shadow()\rightShadow = dropShadow(wp\x+width, wp\y+lSize, lSize, height-lSize, colour, Alpha, #DropShadowVertical|#DropShadowStart)
    EndIf
    
    If menuTitleVOffset <> -1
      ;/ If submenu And ypos/height inside parents then make bottom dropshadow flushed against side of parent
      If subMenuActive = #True
        
        If thisMenuWindowYBottom < rec\bottom
          
          If rec\left < wp\x ; parent on left side
            xpos = wp\x
            w = width+lSize-1
            flags = #DropShadowEnd
          Else  ; parent on right side
            xpos = wp\x+lSize
            w = width-lSize-1
            flags = #DropShadowStart
          EndIf
          shadow()\bottomShadow = dropShadow(xpos, wp\y+height, w, lSize, colour, Alpha, flags)
          popupUserData()\bottomShadowX = xpos
          popupUserData()\bottomShadowY = wp\y+height
          popupUserData()\bottomShadowWidth = w
          popupUserData()\bottomShadowFlags = flags
          
        ElseIf thisMenuWindowYBottom = rec\bottom  ; submenu and parent's bottom equal
          
          ; create new shadow spanning with of parent and this window
          If rec\left < wp\x ; parent on left side
            xpos = rec\left+lSize
            w = (wp\x+width)-rec\left-1
          Else  ; parent on right side
            xpos = wp\x+lSize
            w = (rec\right-wp\x)-1
          EndIf
          shadow()\bottomShadow = dropShadow(xpos, wp\y+height, w, lSize, colour, Alpha, 0)
          ; hide parents bottom shadow
          ShowWindow_(bottomShadowHidden, #SW_HIDE)
          popupUserData()\bottomShadowHidden = bottomShadowHidden
          popupUserData()\bottomShadowX = xpos
          popupUserData()\bottomShadowY = wp\y+height
          popupUserData()\bottomShadowWidth = w
          
        Else
          shadow()\bottomShadow = dropShadow(wp\x+lSize, wp\y+height, width-1, lSize, colour, Alpha, 0)
          popupUserData()\bottomShadowX = wp\x+lSize
          popupUserData()\bottomShadowY = wp\y+height
          popupUserData()\bottomShadowWidth = width-1
        EndIf
        ;/ if not sub menu draw normal bottom shadow
      Else
        shadow()\bottomShadow = dropShadow(wp\x+lSize, wp\y+height, width-1, lSize, colour, Alpha, 0)
        popupUserData()\bottomShadowX = wp\x+lSize
        popupUserData()\bottomShadowY = wp\y+height
        popupUserData()\bottomShadowWidth = width-1
      EndIf
      popupUserData()\bottomShadowHandle = shadow()\bottomShadow
      
      ;/ upside down shadows
    Else
      If menuex()\style = 6
        If menuTitleOffset > 3
          offset = menuTitleOffset-4
        ElseIf menuTitleOffset = 3
          offset = menuTitleOffset-3
        ElseIf menuTitleOffset = 2
          offset = menuTitleOffset-2
        ElseIf menuTitleOffset = 1
          offset = menuTitleOffset-1
        Else
          offset = menuTitleOffset
        EndIf
      ElseIf menuex()\style = 5
        If menuTitleOffset > 3
          offset = menuTitleOffset-2
        ElseIf menuTitleOffset = 3
          offset = menuTitleOffset-2
        ElseIf menuTitleOffset = 2
          offset = menuTitleOffset-2
        ElseIf menuTitleOffset = 1
          offset = menuTitleOffset-1
        Else
          offset = menuTitleOffset
        EndIf
      Else
        If menuTitleOffset > 3
          offset = menuTitleOffset-4
        ElseIf menuTitleOffset = 3
          offset = menuTitleOffset-3
        ElseIf menuTitleOffset = 2
          offset = menuTitleOffset-2
        ElseIf menuTitleOffset = 1
          offset = menuTitleOffset-1
        Else
          offset = menuTitleOffset
        EndIf
      EndIf
      
      If subMenuActive = #True
        
        If thisMenuWindowYBottom < rec\bottom
          
          If rec\left < wp\x ; parent on left side
            xpos = wp\x
            w = width+lSize-1
            flags = #DropShadowEnd
          Else  ; parent on right side
            xpos = wp\x+lSize
            w = width-lSize-1
            flags = #DropShadowStart
          EndIf
          shadow()\bottomShadow = dropShadow(xpos, wp\y+height, w, lSize, colour, Alpha, flags)
          popupUserData()\bottomShadowX = xpos
          popupUserData()\bottomShadowY = wp\y+height
          popupUserData()\bottomShadowWidth = w
          popupUserData()\bottomShadowFlags = flags
          
        ElseIf thisMenuWindowYBottom = rec\bottom  ; submenu and parent's bottom equal
          
          ;/ submenu parent is root
          If parentSubmenu = 0
            If rec\left < wp\x ; parent on left side
              
              w = bottomShadowWidth+width+lSize-1
              bottomShadowX = bottomShadowX - lSize
              shadow()\bottomShadow = dropShadow(bottomShadowX, bottomShadowY, w, lSize, colour, Alpha, #DropShadowEnd)
              popupUserData()\bottomShadowX = bottomShadowX
              popupUserData()\bottomShadowY = bottomShadowY
              popupUserData()\bottomShadowWidth = w
              popupUserData()\bottomShadowFlags = #DropShadowEnd
              ShowWindow_(bottomShadowHidden, #SW_HIDE)
              popupUserData()\bottomShadowHidden = bottomShadowHidden
              
            Else  ; parent on right side
              
              ; if there is a left bottom shadow
              If leftBottomShadowWidth > 0
                xpos = wp\x+lSize
                w = width+leftBottomShadowWidth-1
                shadow()\bottomShadow = dropShadow(xpos, wp\y+height, w, lSize, colour, Alpha, #DropShadowStart)
                popupUserData()\bottomShadowX = xpos
                popupUserData()\bottomShadowY = wp\y+height
                popupUserData()\bottomShadowWidth = w
                popupUserData()\bottomShadowFlags = #DropShadowStart
                ShowWindow_(leftBottomShadowHandle, #SW_HIDE)
                popupUserData()\bottomShadowHidden = leftBottomShadowHandle
              Else
                xpos = wp\x+lSize
                w = width-lSize-1
                shadow()\bottomShadow = dropShadow(xpos, wp\y+height, w, lSize, colour, Alpha, #DropShadowStart)
                popupUserData()\bottomShadowX = xpos
                popupUserData()\bottomShadowY = wp\y+height
                popupUserData()\bottomShadowWidth = w
                popupUserData()\bottomShadowFlags = #DropShadowStart
              EndIf
              
            EndIf
            ;/ parent not root
          Else
            
            ; create new shadow spanning with of parent and this window
            If rec\left < wp\x ; parent on left side
              xpos = rec\left+lSize
              w = (wp\x+width)-rec\left-1
            Else  ; parent on right side
              xpos = wp\x+lSize
              w = (rec\right-wp\x)-1
            EndIf
            shadow()\bottomShadow = dropShadow(xpos, wp\y+height, w, lSize, colour, Alpha, 0)
            ; hide parents bottom shadow
            ShowWindow_(bottomShadowHidden, #SW_HIDE)
            popupUserData()\bottomShadowHidden = bottomShadowHidden
            popupUserData()\bottomShadowX = xpos
            popupUserData()\bottomShadowY = wp\y+height
            popupUserData()\bottomShadowWidth = w
            
          EndIf
          
        Else
          
          ; if parent is on right and this window is below title height then get rid of overlaping lsize
          If parentSubmenu = 0 And leftBottomShadowWidth = 0 And rec\left > wp\x And thisMenuWindowYBottom < rec\bottom+menuTitleHeight
            width = width - lSize
            flags = #DropShadowStart
          EndIf
          
          shadow()\bottomShadow = dropShadow(wp\x+lSize, wp\y+height, width-1, lSize, colour, Alpha, flags)
          popupUserData()\bottomShadowX = wp\x+lSize
          popupUserData()\bottomShadowY = wp\y+height
          popupUserData()\bottomShadowWidth = width-1
          
        EndIf
        
        popupUserData()\bottomShadowHandle = shadow()\bottomShadow
        
        ;/ if not sub menu draw normal bottom shadow
      Else
        ; find nearest display monitor to menu window and limit bottom shadow to menu's monitor edge
       
        If menuex()\style = 6
          tmenuTitleWidth = menuTitleWidth
        ElseIf menuex()\style = 5
          tmenuTitleWidth = menuTitleWidth - 4
        Else
          tmenuTitleWidth = menuTitleWidth
        EndIf
        
        w = (width-tmenuTitleWidth)+lSize-1
        x = wp\x+tmenuTitleWidth+offset+w
        prc.RECT
        prc\left = wp\x
        prc\top = wp\y+height
        prc\right = prc\left
        prc\bottom = prc\top
        hmonitor = MonitorFromRect_(@prc, #MONITOR_DEFAULTTONEAREST)
        minfo.MONITORINFO
        minfo\cbSize = SizeOf(MONITORINFO)
        GetMonitorInfo_(hmonitor, @minfo)
        If x > minfo\rcWork\right
          w = w - (x-minfo\rcWork\right-lSize-1)
        EndIf
        If menuTitleXpos < wp\x
          w = w - offset
        EndIf
        ; draw top shadow to right of menutitle
        shadow()\bottomShadow = dropShadow(wp\x+tmenuTitleWidth+offset, wp\y+height, w, lSize, colour, Alpha, #DropShadowEnd)
        ; draw top shadow to left of menutitle if need to
        If wp\x < menuTitleXpos
          shadow()\leftBottomShadow = dropShadow(wp\x+lSize, wp\y+height, (menuTitleXpos-wp\x)-lSize, lSize, colour, Alpha, #DropShadowStart)
          popupUserData()\leftBottomShadowX = wp\x+lSize
          popupUserData()\leftBottomShadowY = wp\y+height
          popupUserData()\leftBottomShadowWidth = (menuTitleXpos-wp\x)-lSize
          popupUserData()\leftBottomShadowHandle = shadow()\leftBottomShadow
        EndIf
        
        popupUserData()\bottomShadowX = wp\x+tmenuTitleWidth+offset
        popupUserData()\bottomShadowY = wp\y+height
        popupUserData()\bottomShadowWidth = w
        popupUserData()\bottomShadowHandle = shadow()\bottomShadow
        
      EndIf
    EndIf
  EndIf
  
EndProcedure




Procedure SubclassWndProc(WindowID,message,wParam.l,lParam)
  Static menuWindowOpenCount  ; counts the number of new subclassed windows currently open
  Static menuStyle ; keeps track of root menu's menu style
  Static destroying, destroy
  
  If HaltProGUI = #True
    ProcedureReturn 0
  EndIf
  
  inMenuWindow = #False
  
  LockMutex(menuMutex)
  
  ; save current menuex to this popup window
  userdat = GetWindowLongPtr_(WindowID, #GWLP_USERDATA)
  If userdat = 0
    menuDraw = 0;#False
    currentSub = lastSubMenu
    
    ForEach menuex()
      If @menuex() = menuExHandle
        Break
      EndIf
    Next
    
    ; if this is a root menu window
    If lastPopupUserData = 0
      menuStyle = menuex()\style
      destroy = 0
      destroying = 0
    EndIf
    
    ; is this is a submenu with different style then make this have root style
    originalStyle = -1
    If subMenuActive = #True And lastSubMenu <> 0
      ForEach menuex()
        If menuex()\popupid = lastSubMenu
          originalStyle = menuex()\style
          menuex()\style = menuStyle
          resetMenuMetrics(menuex()\popupid)
          Break
        EndIf
      Next
    EndIf
    
    AddElement(popupUserData())
    popupUserData()\menuExPtr = @menuex()
    popupUserData()\originalStyle = originalStyle
    popupUserData()\WindowID = WindowID
    popupUserData()\submenu = lastSubMenu
    popupUserData()\lastMenuYPos = lastMenuYPos
    popupUserData()\parentPopupUserData = lastPopupUserData
    lastPopupUserData = @popupUserData()
    SetWindowLongPtr_(WindowID, #GWLP_USERDATA, @popupUserData())
    
    ; deactivate selection fade if styles greater then whidbey
    If menuex()\style >= 5
      If systemSelectionFadeEnabled = #False
        SystemParametersInfo_(#SPI_GETSELECTIONFADE, 0, @systemSelectionFadeEnabled, 0)  ; get system menu drop shadow status
        If systemSelectionFadeEnabled = #True
          SystemParametersInfo_(#SPI_SETSELECTIONFADE, 0, #False, 0) ; temp disable system selection fade
        EndIf
      EndIf
    EndIf
    
    ; if this window should be scrolled then put window id into menuScrollWindow
    If menuScrollWindow = 0 And menuScrollHandle <> 0
      menuScrollWindow = WindowID
    EndIf
    
    menuWindowOpenCount = menuWindowOpenCount + 1
    
    destroy = #False
    
  Else
    ChangeCurrentElement(popupUserData(), userdat)
    ChangeCurrentElement(menuex(), popupUserData()\menuExPtr)
  EndIf
  
  If message = #WM_DESTROY
    
    If popupUserData()\parentPopupUserData <> 0
      thisPopupUserData = @popupUserData()
      ChangeCurrentElement(popupUserData(), popupUserData()\parentPopupUserData)
      currentSub = popupUserData()\submenu
      ChangeCurrentElement(popupUserData(), thisPopupUserData)
    EndIf
    
    lastMenuWindowXpos = popupUserData()\lastWindowXpos
    lastPopupUserData = popupUserData()\parentPopupUserData
    lastMenuYPos = popupUserData()\lastMenuYPos
    If popupUserData()\bottomShadowTmp <> 0
      DestroyWindow_(popupUserData()\bottomShadowTmp)
    EndIf
    If popupUserData()\bottomShadowHidden <> 0
      ShowWindow_(popupUserData()\bottomShadowHidden, #SW_SHOWNA)
    EndIf
    If popupUserData()\originalStyle >= 0
      menuex()\style = popupUserData()\originalStyle
      resetMenuMetrics(menuex()\popupid)
    EndIf
    DeleteElement(popupUserData())
    Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
    SetWindowLongPtr_(WindowID, #GWLP_WNDPROC, OldSubclassWndProc)
    
    menuWindowOpenCount = menuWindowOpenCount - 1
    
    ; re-enable system selection fade if enabled and last window left open
    If systemSelectionFadeEnabled = #True And menuWindowOpenCount <= 0
      SystemParametersInfo_(#SPI_SETSELECTIONFADE, 0, #True, 0) ; re-enable system selection fade
      systemSelectionFadeEnabled = #False
    EndIf
    
    destroy = #True
    
    UnlockMutex(menuMutex)
    ProcedureReturn Result
    
  ; undocumented windows message (took me a while to find this one!) to do with menu-item selection, modifying wparam changes active selcted item
  ElseIf message = 485
    
    If wParam < 0
      
      If popupUserData()\submenu <> 0
        menu = popupUserData()\submenu
      Else
        menu = menuHandle
      EndIf
      
      mx = DesktopMouseX()
      my = DesktopMouseY()
      
      ;as fucking MenuItemFromPoint_ doesn't work at all now (fucking microsoft! lol) this nice workaround is in order
      mrc.RECT
      GetWindowRect_(WindowID, @mrc)
      itemCount = GetMenuItemCount_(menu)
      ; get menu item under mouse y coord from menu window
      For n = 0 To itemCount
        GetMenuItemRect_(WindowID, menu, n, @irc.RECT)
        If my >= irc\top And my <= irc\bottom
          Break
        EndIf
      Next
      
      ;if submenu then extend active selection of parent item so that submenu doesn't deselect
      ret = GetSubMenu_(menu, n)
      If ret <> 0
        If my > mrc\top+1 And my < mrc\bottom-1
          If mx > mrc\left And mx < mrc\right
            wparam = n
          EndIf
        EndIf
      ; extend item selction based on real window width (due to another quirk in Windows!)
      ; fucking Microsoft engineers = retards  
      Else
        If my > mrc\top+1 And my < mrc\bottom-1
          If mx > mrc\left+1 And mx < mrc\right-2
            wparam = n
          EndIf
        EndIf
      EndIf
      
    EndIf
    
    If wParam < 0
      inMenuWindow = #False
    Else
      inMenuWindow = #True
    EndIf
    
    ; handle deselection of submenu first item windows menu quirk
    If popupUserData()\submenu = 0
      menu = menuHandle
    Else
      menu = popupUserData()\submenu
    EndIf
    ret = GetSubMenu_(menu, wParam)
    If ret <> 0
      thisPopupUserData = @popupUserData()
      ForEach popupUserData()
        If popupUserData()\submenu = ret And popupUserData()\WindowID <> WindowID
          SendMessage_(popupUserData()\WindowID, 485, -1, 0)
          Break
        EndIf
      Next
      ChangeCurrentElement(popupUserData(), thisPopupUserData)
      lastSubMenu = ret
    Else
      lastSubMenu = #False
    EndIf
    
    If wParam > = 0
      ret = GetSubMenu_(menuHandle, wParam)
      If ret <> 0
        subMenuActive = #True
      Else
        subMenuActive = #False
      EndIf
    Else
      subMenuActive = #False
    EndIf
    
    ;debuglog("mx:"+Str(mx)+" my:"+Str(my))
    ;debuglog(Str(MenuItemFromPoint_(WindowID, menuHandle, mx,my)))
    
    ;/ handle menu scrolling
    If menuScrollWindow = WindowID And menuScrollEnd = #False
      mnfo.MENUITEMINFO_Fixed
      mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
      mnfo\fMask = #MIIM_DATA
      If GetMenuItemInfo_(menuScrollHandle, wParam, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
        If menuScrollActive = #False And IsThread(menuScrollThread) = 0
          If itemex()\scroll = -2
            menuScrollActive = #True
            menuScrollThread = CreateThread(@menuExScroll(), 1)
          ElseIf itemex()\scroll = -1
            menuScrollActive = #True
            menuScrollThread = CreateThread(@menuExScroll(), 0)
          EndIf
        EndIf
        
        If itemex()\scroll = 0
          menuScrollActive = #False
        EndIf
      Else
        menuScrollActive = #False
      EndIf
    EndIf
    
    ; if scrolling then disable selection messages from getting through
    If menuScrolling = #True Or menuScrollEnd = #True
      wParam = -1
    EndIf
     
    UnlockMutex(menuMutex)
    ProcedureReturn CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
    
    
  ElseIf message = #WM_WINDOWPOSCHANGING
    
    ; stop redrawing and message from being handled when scrolling
    If WindowID = menuScrollWindow
      If menuScrolling = #True Or menuScrollActive = #True
        *wp.WINDOWPOS = lParam
        *wp\flags = #SWP_NOREDRAW|#SWP_NOSIZE|#SWP_NOZORDER|#SWP_NOOWNERZORDER|#SWP_NOMOVE|#SWP_NOACTIVATE
        UnlockMutex(menuMutex)
        ProcedureReturn 0
      EndIf
    EndIf
    
    ; do special flicker free erasing for menu tracking
    If CompositionEnabled = #False And menuex()\active <> 0
    
      *wp.WINDOWPOS = lParam
      If destroying = #True
        
        If lastMenuWidth <> 0
          doMenuTrackErase(WindowID)
        EndIf
        
        GetWindowRect_(WindowID, @rc.RECT)
        lastMenuX = rc\left
        lastMenuY = rc\top
        lastMenuWidth = rc\right-rc\left
        lastMenuHeight = rc\bottom-rc\top
        *wp\flags = #SWP_NOREDRAW
        destroying = #False
        
        If menuEraseBufferInvalid <> #True
          menuEraseBufferInvalid = 0
        EndIf
        
        UnlockMutex(menuMutex)
        ProcedureReturn 0
      EndIf
      
      ; If popupUserData()\WindowPosChangingTimes = 0
        ; dhdc = GetDC_(0)
        ; debuglog(Str(dhdc))
        ; If menuWindowEraseHdc = 0
          ; menuWindowEraseHdc = CreateCompatibleDC_(dhdc)
          ; menuWindowEraseBuffer = CreateCompatibleBitmap_(dhdc, 1024, 768)
          ; SelectObject_(menuWindowEraseHdc, menuWindowEraseBuffer)
        ; EndIf
        ; BitBlt_(menuWindowEraseHdc, 0, 0, 500, 500, dhdc, menuWindowPx, menuWindowPy, #SRCCOPY)
        ; ReleaseDC_(0, dhdc)
      ; EndIf
      
      If popupUserData()\WindowPosChangingTimes = 1
        destroying = #True
        
        If menuEraseBuffered = #True
          GetWindowRect_(WindowID, @rec.RECT)
          doMenuTrackBufferedErase(-1, @rec)
        EndIf
        
        ; little hack to get rid of graphical rendering glitch at right, left & top of menu toolbar when highspeed tracking
        If lastMenuWidth <> 0
          GetWindowRect_(WindowID, @rec.RECT)
          If rec\right < lastMenuX+lastMenuWidth
            rc.RECT
            rc\left = rec\right
            rc\right = lastMenuX+lastMenuWidth
            rc\top = lastMenuY
            rc\bottom = lastMenuY+lastMenuHeight
            MapWindowPoints_(0, menuToolbar, @rc, 2)
            SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
            RedrawWindow_(menuToolbar,rc, 0, #RDW_INVALIDATE|#RDW_UPDATENOW)
            SendMessage_(menuToolbar, #WM_SETREDRAW, #False, 0)
          EndIf
          
          If rec\left > lastMenuX
            rc.RECT
            rc\left = rec\left
            rc\right = lastMenuX
            rc\top = lastMenuY
            rc\bottom = lastMenuY+lastMenuHeight
            MapWindowPoints_(0, menuToolbar, @rc, 2)
            SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
            RedrawWindow_(menuToolbar,rc, 0, #RDW_INVALIDATE|#RDW_UPDATENOW)
            SendMessage_(menuToolbar, #WM_SETREDRAW, #False, 0)
          EndIf
          
          If rec\top > lastMenuY+lastMenuHeight
            rc.RECT
            rc\left = lastMenuX
            rc\right = lastMenuX+lastMenuWidth
            rc\top = lastMenuY
            rc\bottom = lastMenuY+lastMenuHeight
            MapWindowPoints_(0, menuToolbar, @rc, 2)
            SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
            RedrawWindow_(menuToolbar,rc, 0, #RDW_INVALIDATE|#RDW_UPDATENOW)
            SendMessage_(menuToolbar, #WM_SETREDRAW, #False, 0)
          EndIf
        EndIf

      EndIf
    EndIf
    
  EndIf
  
  ; handle delay of dropshadow display
  If menuex()\active <> 0 And (message = #WM_PAINT Or message = #WM_PRINT)
    ;SetTimer_(WindowID, 742369, 300, @displayDelayedShadows())
  EndIf
  
  ; track erase
  If menuex()\active <> 0 And CompositionEnabled = #False And message = #WM_PAINT
    Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)

    doMenuTrackErase(WindowID)
    menuEraseBufferInvalid = -1
    
    UnlockMutex(menuMutex)
    ProcedureReturn Result
  EndIf
  
  ; draw dropshadows
  If message = #WM_WINDOWPOSCHANGED And popupUserData()\WindowPosChangingTimes = 2
    If destroy <> #True
      doMenuShadows(WindowID)
    EndIf
  EndIf
  
  borderwidth = itemex()\imageWidth+menuSideBarPadding

  ;/ classic styles
  If menuex()\style < 5
    
    Select message
        
      Case #WM_ERASEBKGND
        
        If menuex()\hdc = 0 Or menuex()\bufferWidth <> menuex()\measuredWidth Or menuex()\bufferHeight <> menuex()\measuredHeight
          rec.RECT
          GetWindowRect_(WindowID, @rec)
          rc.RECT
          rc\left = 0
          rc\right = (rec\right - rec\left)
          rc\top = 0
          rc\bottom = (rec\bottom-rec\top)
          
          ; fill background
          FillRect_(wParam, rc, GetSysColorBrush_(#COLOR_MENU))
        Else
          BitBlt_(wParam, 0, 0, menuex()\bufferWidth, menuex()\bufferHeight, menuex()\hdc, 0, 0, #SRCCOPY)
        EndIf
      
      Case #WM_NCPAINT
        
        Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
        
        ; vista/windows 7 style - draw hilite border
        If ThemesEnabled = #True And (Comctl32MajorVersion > 6 Or (Comctl32MajorVersion = 6 And Comctl32MinorVersion > 0))
          hdc = GetWindowDC_(WindowID)
        
          rec.RECT
          GetWindowRect_(WindowID, @rec)
          height = rec\bottom-rec\top
          width = rec\right-rec\left
  
          CallFunctionFast(*GetThemeColor, hThemeMenu, 9, 1, 3821, @Color)
          Color = CreateSolidBrush_(Color)
          
          rec\top = 1
          rec\bottom = 3
          rec\right = width-1
          rec\left = 1
          FillRect_(hdc, rec, Color)
          
          rec\top = height-3
          rec\bottom = height-1
          rec\right = width-1
          rec\left = 1
          FillRect_(hdc, rec, Color)
          
          rec\top = 3
          rec\bottom = height-3
          rec\right = 3
          rec\left = 1
          FillRect_(hdc, rec, Color)
          
          rec\top = 3
          rec\bottom = height-3
          rec\right = width-1
          rec\left = width-3
          FillRect_(hdc, rec, Color)
          
          DeleteObject_(Color)
          ReleaseDC_(WindowID, hdc)
        EndIf
      
      Case #WM_PRINT
        
        Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)

        ; vista/windows 7 style - draw hilite border
        If ThemesEnabled = #True And (Comctl32MajorVersion > 6 Or (Comctl32MajorVersion = 6 And Comctl32MinorVersion > 0))
          hdc = wParam
          
          rec.RECT
          GetWindowRect_(WindowID, @rec)
          height = rec\bottom-rec\top
          width = rec\right-rec\left
          
          CallFunctionFast(*GetThemeColor, hThemeMenu, 9, 1, 3821, @Color)
          Color = CreateSolidBrush_(Color)
          
          rec\top = 1
          rec\bottom = 3
          rec\right = width-1
          rec\left = 1
          FillRect_(hdc, rec, Color)
          
          rec\top = height-3
          rec\bottom = height-1
          rec\right = width-1
          rec\left = 1
          FillRect_(hdc, rec, Color)
          
          rec\top = 3
          rec\bottom = height-3
          rec\right = 3
          rec\left = 1
          FillRect_(hdc, rec, Color)
          
          rec\top = 3
          rec\bottom = height-3
          rec\right = width-1
          rec\left = width-3
          FillRect_(hdc, rec, Color)
          
          DeleteObject_(Color)
          ReleaseDC_(WindowID, hdc)
        EndIf
        
      Case #WM_WINDOWPOSCHANGING
        
        Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
        
        popupUserData()\WindowPosChangingTimes = popupUserData()\WindowPosChangingTimes + 1
        
        *wp.WINDOWPOS = lParam
        
        ; re-position if at edge of screen
        If subMenuActive = #False
          If menuPositionOffset > 5
            *wp\x = *wp\x + 5
          ElseIf menuPositionOffset = 5
            *wp\x = *wp\x + 4
          ElseIf menuPositionOffset = 4
            *wp\x = *wp\x + 3
          ElseIf menuPositionOffset = 3
            *wp\x = *wp\x + 2
          ElseIf menuPositionOffset = 2
            *wp\x = *wp\x + 1
          EndIf
          *wp\cx = menuWindowWidth
        EndIf
        
        ; if this is a submenu, decide whether to place offset left or right of parent
        If popupUserData()\WindowPosChangingTimes = 2
          If popupUserData()\lastWindowXpos = 0
            popupUserData()\lastWindowXpos = lastMenuWindowXpos
          EndIf
          
          If subMenuActive = #True
            ; right
            If *wp\x > lastMenuWindowXpos
              
              thisPopupUserData = @popupUserData()
              thisMenuEx = @menuex()
              ChangeCurrentElement(popupUserData(), popupUserData()\parentPopupUserData)
              ChangeCurrentElement(menuex(), popupUserData()\menuExPtr)
              If menuex()\root = #True
                *wp\x = menuWindowXpos+menuWindowWidth-1
              Else
                *wp\x = *wp\x + 5
              EndIf
              ChangeCurrentElement(popupUserData(), thisPopupUserData)
              ChangeCurrentElement(menuex(), thisMenuEx)
              
              *wp\y = *wp\y + 2
              
              ; left
            Else
              *wp\x = *wp\x - 2
              *wp\y = *wp\y + 2
            EndIf
            
            ; make sure submenu is in workspace
            ; find nearest display monitor to window
            prc.RECT
            prc\left = *wp\x
            prc\top = *wp\y
            prc\right = *wp\x
            prc\bottom = *wp\y
            hmonitor = MonitorFromRect_(@prc, #MONITOR_DEFAULTTONEAREST)
            minfo.MONITORINFO
            minfo\cbSize = SizeOf(MONITORINFO)
            GetMonitorInfo_(hmonitor, @minfo)
            GetWindowRect_(WindowID, @rec.RECT)
            If *wp\x+rec\right > minfo\rcWork\right
              *wp\x = lastMenuWindowXpos-rec\right+1
            ElseIf *wp\y+rec\bottom > minfo\rcWork\bottom
              *wp\y = minfo\rcWork\bottom-rec\bottom
            EndIf
            
          EndIf
          lastMenuWindowXpos = *wp\x
          thisMenuWindowYBottom = thisMenuWindowYBottom + *wp\y
        EndIf
        
        ; catch correct correct height and above ^ code makes this bottom y value
        If *wp\cy > 0
          thisMenuWindowYBottom = *wp\cy
        EndIf
    
      Default
        Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
    EndSelect
    
  ;/ office xp whidbey style
  ElseIf menuex()\style = 5
    Select message

      Case #WM_WINDOWPOSCHANGING
        
      Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
      
      popupUserData()\WindowPosChangingTimes = popupUserData()\WindowPosChangingTimes + 1
      
      *wp.WINDOWPOS = lParam
      
      ; re-position if at edge of screen
      If subMenuActive = #False
        If menuPositionOffset > 5
          *wp\x = *wp\x + 5
        ElseIf menuPositionOffset = 5
          *wp\x = *wp\x + 4
        ElseIf menuPositionOffset = 4
          *wp\x = *wp\x + 3
        ElseIf menuPositionOffset = 3
          *wp\x = *wp\x + 2
        ElseIf menuPositionOffset = 2
          *wp\x = *wp\x + 1
        EndIf
        *wp\cx = menuWindowWidth
      EndIf
      
      *wp\cy = *wp\cy - 1
      
      
      ; if this is a submenu, decide whether to place offset left or right of parent
      If popupUserData()\WindowPosChangingTimes = 2
        If popupUserData()\lastWindowXpos = 0
          popupUserData()\lastWindowXpos = lastMenuWindowXpos
        EndIf
        
        If subMenuActive = #True
          ; right
          If *wp\x > lastMenuWindowXpos
            
            thisPopupUserData = @popupUserData()
            thisMenuEx = @menuex()
            ChangeCurrentElement(popupUserData(), popupUserData()\parentPopupUserData)
            ChangeCurrentElement(menuex(), popupUserData()\menuExPtr)
            If menuex()\root = #True
              *wp\x = menuWindowXpos+menuWindowWidth-1
            Else
              *wp\x = *wp\x + 5
            EndIf
            ChangeCurrentElement(popupUserData(), thisPopupUserData)
            ChangeCurrentElement(menuex(), thisMenuEx)
            
            *wp\y = *wp\y + 2
            
            ; left
          Else
            *wp\x = *wp\x - 2
            *wp\y = *wp\y + 2
          EndIf
          
          ; make sure submenu is in workspace
          ; find nearest display monitor to window
          prc.RECT
          prc\left = *wp\x
          prc\top = *wp\y
          prc\right = *wp\x
          prc\bottom = *wp\y
          hmonitor = MonitorFromRect_(@prc, #MONITOR_DEFAULTTONEAREST)
          minfo.MONITORINFO
          minfo\cbSize = SizeOf(MONITORINFO)
          GetMonitorInfo_(hmonitor, @minfo)
          GetWindowRect_(WindowID, @rec.RECT)
          If *wp\x+rec\right > minfo\rcWork\right
            *wp\x = lastMenuWindowXpos-rec\right+1
          ElseIf *wp\y+rec\bottom > minfo\rcWork\bottom
            *wp\y = minfo\rcWork\bottom-rec\bottom
          EndIf
          
        EndIf
        lastMenuWindowXpos = *wp\x
        thisMenuWindowYBottom = thisMenuWindowYBottom + *wp\y
      EndIf
      
      ; catch correct correct height and above ^ code makes this bottom y value
      If *wp\cy > 0
        thisMenuWindowYBottom = *wp\cy
      EndIf
      
      UnlockMutex(menuMutex)
      ProcedureReturn 0
    
    Case #WM_ERASEBKGND
      
      If menuex()\hdc = 0 Or menuex()\bufferWidth <> menuex()\measuredWidth Or menuex()\bufferHeight <> menuex()\measuredHeight
        rec.RECT
        GetWindowRect_(WindowID, @rec)
        
        ; fill background to right of bar
        rc.RECT
        rc\left = borderwidth+1
        rc\right = (rec\right - rec\left)
        rc\top = 0
        rc\bottom = (rec\bottom-rec\top)
        colour = getMenuColour(menuex()\style, #background)
        FillRect_(wParam, rc, colour)
        
        ; draw bar
        rc\left = 0
        rc\right = borderwidth+1
        colour = getMenuColour(menuex()\style, #menuBarColor)
        FillRect_(wParam, rc, colour)
      Else
        BitBlt_(wParam, 0, 0, menuex()\bufferWidth, menuex()\bufferHeight, menuex()\hdc, 0, 0, #SRCCOPY)
      EndIf
      
    Case #WM_NCPAINT
      
      Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)

      hdc = GetWindowDC_(WindowID)
      
      rec.RECT
      GetWindowRect_(WindowID, @rec)
      
      rc.RECT
      rc\right = (rec\right - rec\left)-1
      rc\left = 1
      rc\bottom = (rec\bottom - rec\top)-1
      rc\top = 1
      colour = getMenuColour(#UISTYLE_WHIDBEY, #background)
      FrameRect_(hdc, rc, colour)
      
      ; due to fucking dodgyness of windows this nice hack is in order :)
      BitBlt_(hdc, 0, 2, rec\right-rec\left, 1, hdc, 0, 1, #SRCCOPY) ; copy top line 1 pixel below
      BitBlt_(hdc, 2, 0, 1, rec\bottom-rec\top, hdc, 1, 0, #SRCCOPY) ; copy left line 1 pixel across to the right
      
      ; due to fucking dodgyness of windows this nice hack is in order :)
      BitBlt_(hdc, 0, (rec\bottom-rec\top)-3, rec\right-rec\left, 1, hdc, 0, (rec\bottom-rec\top)-2, #SRCCOPY) ; copy bottom line 1 pixel up
      BitBlt_(hdc, rec\right-rec\left-3, 0, 1, rec\bottom-rec\top, hdc, rec\right-rec\left-2, 0, #SRCCOPY) ; copy right line 1 pixel across to left
      
      rec\right = rec\right - rec\left
      rec\left = 0
      rec\bottom = rec\bottom - rec\top
      bottom = rec\bottom
      rec\top = 0
      colour = getMenuColour(menuex()\style, #menuHeldBorder)
      FrameRect_(hdc, rec, colour)
      
      If menuWindow = 0
        menuWindow = WindowID
      EndIf
      
      If menuTitleWidth <> 0 And WindowID = menuWindow

        rec.RECT
        If menuTitleOffset > 3
          offset = menuTitleOffset-2
        ElseIf menuTitleOffset = 3
          offset = menuTitleOffset-2
        ElseIf menuTitleOffset = 2
          offset = menuTitleOffset-2
        ElseIf menuTitleOffset = 1
          offset = menuTitleOffset-1
        Else
          offset = menuTitleOffset
        EndIf
        
        rec\left = 1+offset
        rec\right = (menuTitleWidth-5)+offset
        rec\top = 0
        rec\bottom = 1
        If menuTitleVOffset = -1
          rec\top = bottom-1
          rec\bottom = bottom
        EndIf
        colour = getMenuColour(menuex()\style, #menuBarColor)
        FillRect_(hdc, rec, colour)
      
      EndIf
      
      ReleaseDC_(WindowID, hdc)
     
    Case #WM_PRINT

      Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)

      hdc = wParam
    
      GetWindowRect_(WindowID, @rec)

      rc.RECT
      rc\right = (rec\right - rec\left)-1
      rc\left = 1
      rc\bottom = (rec\bottom - rec\top)-1
      rc\top = 1
      colour = getMenuColour(#UISTYLE_WHIDBEY, #background)
      FrameRect_(hdc, rc, colour)
      
      ; due to fucking dodgyness of windows this nice hack is in order :)
      BitBlt_(hdc, 0, 2, rec\right-rec\left, 1, hdc, 0, 1, #SRCCOPY) ; copy top line 1 pixel below
      BitBlt_(hdc, 2, 0, 1, rec\bottom-rec\top, hdc, 1, 0, #SRCCOPY) ; copy left line 1 pixel across to the right
      
      ; due to fucking dodgyness of windows this nice hack is in order :)
      BitBlt_(hdc, 0, (rec\bottom-rec\top)-3, rec\right-rec\left, 1, hdc, 0, (rec\bottom-rec\top)-2, #SRCCOPY) ; copy bottom line 1 pixel up
      BitBlt_(hdc, rec\right-rec\left-3, 0, 1, rec\bottom-rec\top, hdc, rec\right-rec\left-2, 0, #SRCCOPY) ; copy right line 1 pixel across to left
      
      rec\right = rec\right - rec\left
      rec\left = 0
      rec\bottom = rec\bottom - rec\top
      rec\top = 0
      bottom = rec\bottom
      
      ; if dropdown menu then make border same colour as button border
      If dropdownActive = #True
        thdc = GetWindowDC_(menuToolbar)
        pnt.POINT
        pnt\x = menuTitleXpos
        pnt\y = menuTitleYpos-5
        MapWindowPoints_(0, menuToolbar, @pnt, 1)
        colour = GetPixel_(thdc, pnt\x, pnt\y)
        ReleaseDC_(menuToolbar, thdc)
        colour = CreateSolidBrush_(colour)
        FrameRect_(hdc, rec, colour)
        DeleteObject_(colour)
      Else
        colour = getMenuColour(menuex()\style, #menuHeldBorder)
        FrameRect_(hdc, rec, colour)
      EndIf
      
      If menuWindow = 0
        menuWindow = WindowID
      EndIf
      
      If menuTitleWidth <> 0 And WindowID = menuWindow
        
        rec.RECT
        If menuTitleOffset > 3
          offset = menuTitleOffset-2
        ElseIf menuTitleOffset = 3
          offset = menuTitleOffset-2
        ElseIf menuTitleOffset = 2
          offset = menuTitleOffset-2
        ElseIf menuTitleOffset = 1
          offset = menuTitleOffset-1
        Else
          offset = menuTitleOffset
        EndIf
        
        rec\left = 1+offset
        rec\right = (menuTitleWidth-5)+offset
        rec\top = 0
        rec\bottom = 1
        If menuTitleVOffset = -1
          rec\top = bottom-1
          rec\bottom = bottom
        EndIf

        colour = getMenuColour(menuex()\style, #menuBarColor)
        FillRect_(hdc, rec, colour)
        
      EndIf
      
    Default
      Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
    EndSelect

  ;- Office 2003/2007 style
  ElseIf menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2007
    
    If menuex()\style = #UISTYLE_OFFICE2007
      borderwidth = borderwidth + 2
    EndIf
    
    Select message

      
      Case #WM_CREATE
        
        style = GetWindowLongPtr_(WindowID, #GWL_STYLE)
        style = style & ~#WS_BORDER
        style = style & ~#WS_CAPTION
        SetWindowLongPtr_(WindowID, #GWL_STYLE, style)
        style = GetWindowLongPtr_(WindowID, #GWL_EXSTYLE)
        style = style & ~#WS_EX_WINDOWEDGE
        style = style & ~#WS_EX_DLGMODALFRAME
        SetWindowLongPtr_(WindowID, #GWL_EXSTYLE, style)

      Case #WM_NCCALCSIZE
       
        If wParam = #True
          
          *nc.NCCALCSIZE_PARAMS = lParam
          ; *nc\rgrc[0]\top = *nc\rgrc[0]\top + 2
          ; *nc\rgrc[0]\left = *nc\rgrc[0]\left + 1
          ; *nc\rgrc[0]\right = *nc\rgrc[0]\right - 1
          ; *nc\rgrc[0]\bottom = *nc\rgrc[0]\bottom - 2
          
          *nc\rgrc[0]\top = *nc\rgrc[0]\top + 2
          *nc\rgrc[0]\left = *nc\rgrc[0]\left + 1
          *nc\rgrc[0]\right = *nc\rgrc[0]\right - 1
          *nc\rgrc[0]\bottom = *nc\rgrc[0]\bottom -2
          
          UnlockMutex(menuMutex)
          ProcedureReturn #WVR_REDRAW
        
        EndIf
        
        UnlockMutex(menuMutex)
        ProcedureReturn 0

      Case #WM_WINDOWPOSCHANGING
        
        popupUserData()\WindowPosChangingTimes = popupUserData()\WindowPosChangingTimes + 1
        
        *wp.WINDOWPOS = lParam
        
        ; re-position if at edge of screen
        If subMenuActive = #False
          If menuPositionOffset > 5
            *wp\x = *wp\x + 5
          ElseIf menuPositionOffset = 5
            *wp\x = *wp\x + 4
          ElseIf menuPositionOffset = 4
            *wp\x = *wp\x + 3
          ElseIf menuPositionOffset = 3
            *wp\x = *wp\x + 2
          ElseIf menuPositionOffset = 2
            *wp\x = *wp\x + 1
          EndIf
          *wp\cx = menuWindowWidth
        Else
          *wp\cx = *wp\cx - 2 ; move width of menu in 2 pixels
        EndIf
        
        
        *wp\cy = *wp\cy - 3 ; move hight of menu in 3 pixels
        
        ; if this is a submenu, decide whether to place offset left or right of parent
        If popupUserData()\WindowPosChangingTimes = 2
          If popupUserData()\lastWindowXpos = 0
            popupUserData()\lastWindowXpos = lastMenuWindowXpos
          EndIf
          
          
          If subMenuActive = #True
            
            ; right
            If *wp\x > lastMenuWindowXpos
              
              thisPopupUserData = @popupUserData()
              thisMenuEx = @menuex()
              ChangeCurrentElement(popupUserData(), popupUserData()\parentPopupUserData)
              ChangeCurrentElement(menuex(), popupUserData()\menuExPtr)
              If menuex()\root = #True
                *wp\x = menuWindowXpos+menuWindowWidth-1
              Else
                *wp\x = *wp\x + 3
              EndIf
              ChangeCurrentElement(popupUserData(), thisPopupUserData)
              ChangeCurrentElement(menuex(), thisMenuEx)

              *wp\y = *wp\y + 2
            ; left
            Else
              *wp\y = *wp\y + 2
            EndIf
            
            ; make sure submenu is in workspace
            ; find nearest display monitor to window
            prc.RECT
            prc\left = *wp\x
            prc\top = *wp\y
            prc\right = *wp\x
            prc\bottom = *wp\y
            hmonitor = MonitorFromRect_(@prc, #MONITOR_DEFAULTTONEAREST)
            minfo.MONITORINFO
            minfo\cbSize = SizeOf(MONITORINFO)
            GetMonitorInfo_(hmonitor, @minfo)
            GetWindowRect_(WindowID, @rec.RECT)
            If *wp\x+rec\right > minfo\rcWork\right
              *wp\x = lastMenuWindowXpos-rec\right+1
            ElseIf *wp\y+rec\bottom > minfo\rcWork\bottom
              *wp\y = minfo\rcWork\bottom-rec\bottom
            EndIf

          EndIf
          
          lastMenuWindowXpos = *wp\x
          thisMenuWindowYBottom = thisMenuWindowYBottom + *wp\y
        EndIf

        ; catch correct correct height and above ^ code makes this bottom y value
        If *wp\cy > 0
          thisMenuWindowYBottom = *wp\cy
        EndIf
        
        UnlockMutex(menuMutex)
        
        Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
        
        ProcedureReturn 0
      
      Case #WM_ERASEBKGND

        If menuex()\hdc = 0 Or menuex()\bufferWidth <> menuex()\measuredWidth Or menuex()\bufferHeight <> menuex()\measuredHeight
          rec.RECT
          GetWindowRect_(WindowID, @rec)
          
          rc.RECT
          rc\right = borderwidth+2
          rc\bottom = (rec\bottom-rec\top)-4
          blitEx(wParam, menuex()\style, #menuBarColor, @rc, #ForceHorizontalRedraw)
          
          rec\right = (rec\right - rec\left) - 2
          rec\left = borderwidth+2
          rec\bottom = rc\bottom
          rec\top = 0
          c = getMenuColourEx(menuex()\style, #background, 0)
          ;c = CreateSolidBrush_(RGB(255,0,0))
          FillRect_(wParam, rec, c)
        Else
          BitBlt_(wParam, 0, 0, menuex()\bufferWidth, menuex()\bufferHeight, menuex()\hdc, 0, 0, #SRCCOPY)
        EndIf
        
      Case #WM_NCPAINT

        hdc = GetWindowDC_(WindowID)
        
        rec.RECT
        GetWindowRect_(WindowID, @rec)
        
        ; draw top line of background
        rc.RECT
        rc\right = (rec\right - rec\left)-1
        rc\left = 1
        rc\top = 1
        rc\bottom = rc\top+1
        colour = getMenuColourEx(menuex()\style, #background, 0)
        ;c = CreateSolidBrush_(RGB(0,255,255))
        FrameRect_(hdc, rc, colour)
        
        ; draw bottom line of background
        rc.RECT
        rc\right = (rec\right - rec\left)-1
        rc\left = 1
        rc\top = (rec\bottom - rec\top)-2
        rc\bottom = rc\top+1
        ;c = CreateSolidBrush_(RGB(0,255,0))
        FrameRect_(hdc, rc, colour)
        
        ; draw menu border
        rec\right = (rec\right - rec\left)
        rec\left = 0
        rec\bottom = rec\bottom - rec\top
        rec\top = 0
        colour = getMenuColourEx(menuex()\style, #menuHeldBorder, 0)
        FrameRect_(hdc, rec, colour)
        
        If menuWindow = 0
          menuWindow = WindowID
        EndIf
        
        If menuTitleWidth <> 0 And WindowID = menuWindow
          
          If menuTitleOffset > 3
            offset = menuTitleOffset-4
          ElseIf menuTitleOffset = 3
            offset = menuTitleOffset-3
          ElseIf menuTitleOffset = 2
            offset = menuTitleOffset-2
          ElseIf menuTitleOffset = 1
            offset = menuTitleOffset-1
          Else
            offset = menuTitleOffset
          EndIf
          
          rec.RECT
          rec\left = 1+offset
          rec\right = (menuTitleWidth-1)+offset
          rec\top = 0
          rec\bottom = 1
          If menuTitleVOffset = -1
            rec\top = rc\bottom
            rec\bottom = rc\bottom+1
          EndIf
          colour = getMenuColourEx(menuex()\style, #background, 0)
          FillRect_(hdc, rec, colour)
          
        EndIf
        
        ReleaseDC_(WindowID, hdc)
        
      Case #WM_PRINT
        
        Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
        
        hdc = wParam

        GetWindowRect_(WindowID, @rec)
        
        ; draw 1 pixel gradient bar onto top line
        rc.RECT
        rc\left = 1
        rc\right = borderwidth+3
        rc\top = 2
        rc\bottom = rc\top+1
        blitEx(hdc, menuex()\style, #menuBarColor, @rc, #ForceHorizontalRedraw)
        
        ; draw 2 pixel column of gradient to left of window
        rc.RECT
        rc\top = 3
        rc\left = 1
        rc\right = 3
        rc\bottom = (rec\bottom-rec\top)-3
        If menuex()\hdc = 0 Or menuex()\bufferWidth <> menuex()\measuredWidth Or menuex()\bufferHeight <> menuex()\measuredHeight
          blitEx(wParam, menuex()\style, #menuBarColor, @rc, 0)
        Else
          BitBlt_(wParam, 1, 3, 2, menuex()\bufferHeight, menuex()\hdc, 0, 0, #SRCCOPY)
        EndIf
        
        ; draw 1 pixel line of background right of bar
        colour = getMenuColourEx(menuex()\style, #background, 0)
        ;c = CreateSolidBrush_(RGB(0,255,0))
        rc\top = 2
        rc\bottom = rc\top+1
        rc\left = borderwidth+3
        rc\right = rec\right-rec\left
        FillRect_(hdc, rc, colour)
        
        rc.RECT
        rc\right = (rec\right - rec\left)-1
        rc\left = 0
        rc\bottom = (rec\bottom - rec\top)-1
        rc\top = 1
        FrameRect_(hdc, rc, colour)
        
        ; due to fucking wm_print just ignoring wm_nccalcsize! this nice hack is in order :)
        BitBlt_(hdc, 0, rec\bottom-rec\top-3, rec\right-rec\left, 1, hdc, 0, 2, #SRCCOPY) ; copy top line to bottom line 1 pixel down
        BitBlt_(hdc, rec\right-rec\left-3, 0, 2, rec\bottom-rec\top, hdc, rec\right-rec\left-5, 0, #SRCCOPY) ; copy right line 1 pixel across 
        
        ; draw border around window
        rec\right = rec\right - rec\left
        rec\left = 0
        rec\bottom = rec\bottom - rec\top
        rec\top = 0
        
        ; if dropdown menu then make border same colour as button border
        If dropdownActive = #True
          ;thdc = GetWindowDC_(menuToolbar)
          ;pnt.POINT
          ;pnt\x = menuTitleXpos
          ;pnt\y = menuTitleYpos-5
          ;MapWindowPoints_(0, menuToolbar, @pnt, 1)
          ;colour = GetPixel_(thdc, pnt\x, pnt\y)
          ;ReleaseDC_(menuToolbar, thdc)
          ;colour = CreateSolidBrush_(colour)
          
          colour = dropdownHeldColour
          FrameRect_(hdc, rec, colour)
          ;DeleteObject_(colour)
        Else
          colour = getMenuColourEx(menuex()\style, #menuHeldBorder, 0)
          FrameRect_(hdc, rec, colour)
        EndIf
        
        If menuWindow = 0
          menuWindow = WindowID
        EndIf
        
        ; GetWindowRect_(WindowID, @rc.RECT)
        ; If menuex()\hdc = 0 Or menuex()\bufferWidth <> rc\right-rc\left Or menuex()\bufferHeight <> rc\bottom-rc\top
          ; debuglog("menu buffered")
          ; If menuex()\hdc <> 0
            ; deleteobject_(menuex()\Buffer)
            ; deletedc_(menuex()\hdc)
          ; EndIf
          ; menuex()\bufferWidth = rc\right-rc\left
          ; menuex()\bufferHeight = rc\bottom-rc\top
          ; menuex()\hdc = CreateCompatibleDC_(hdc)
          ; menuex()\Buffer = CreateCompatibleBitmap_(hdc, menuex()\bufferWidth, menuex()\bufferHeight)
          ; SelectObject_(menuex()\hdc, menuex()\Buffer)
          ; BitBlt_(menuex()\hdc, 0, 0, menuex()\bufferWidth-1, menuex()\bufferHeight-2, hdc, 1, 2, #SRCCOPY)
        ; EndIf
        
        If menuTitleWidth <> 0 And WindowID = menuWindow
          
          rec.RECT
          If menuTitleOffset > 3
            offset = menuTitleOffset-4
          ElseIf menuTitleOffset = 3
            offset = menuTitleOffset-3
          ElseIf menuTitleOffset = 2
            offset = menuTitleOffset-2
          ElseIf menuTitleOffset = 1
            offset = menuTitleOffset-1
          Else
            offset = menuTitleOffset
          EndIf
          
          rec\left = 1+offset
          rec\right = (menuTitleWidth-1)+offset
          rec\top = 0
          rec\bottom = 1
          If menuTitleVOffset = -1
            rec\top = rc\bottom
            rec\bottom = rc\bottom+2
          EndIf
          colour = getMenuColourEx(menuex()\style, #background, 0)
          FillRect_(hdc, rec, colour)
          
        EndIf
        
      Default
        Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
    EndSelect
  Else
    Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
  EndIf
  
  ;Result = CallWindowProc_(OldSubclassWndProc,WindowID,message,wParam,lParam)
  UnlockMutex(menuMutex)
  ProcedureReturn Result
EndProcedure


Procedure handleStyledComboBox(WindowID,message,wParam,lParam)
  
  If trackWin()\windowType = #WINDOWTYPE_SYSCOMBOBOX Or trackWin()\windowType = #WINDOWTYPE_SYSCOMBOBOXEDIT
    
    
    Select message
        
      Case #WM_MOUSEMOVE
        
        
        ; makesure combobox is in a toolbarEx
        If ListSize(toolbarExButton()) > 0
          *thistoolbarEx = @toolbarEx()
          *thistoolbarExButton = @toolbarExButton()
          found = 0
          ForEach toolbarExButton()
            If (toolbarExButton()\gadget = WindowID Or toolbarExButton()\gadget = GetParent_(WindowID)) And toolbarExButton()\gadgetStyled <> 0
              
              ChangeCurrentElement(toolbarEx(), toolbarExButton()\toolbarEx)
              
              If Not toolbarExButton()\gadgetStyledState & #TOOLBAREXGADGET_HOVER
              
                tm.TRACKMOUSEEVENT
                tm\cbSize = SizeOf(TRACKMOUSEEVENT)
                tm\dwFlags = #TME_LEAVE
                tm\hwndTrack = Window
                TrackMouseEvent_(@tm)

                toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState | #TOOLBAREXGADGET_HOVER
                  
                GetClientRect_(toolbarExButton()\gadget, @trc.RECT)
                MapWindowPoints_(toolbarExButton()\gadget, toolbarExButton()\toolbarExHandle, @trc, 2)
                UnlockMutex(trackWinMutex)
                RedrawWindow_(toolbarExButton()\toolbarExHandle, trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ALLCHILDREN)
                LockMutex(trackWinMutex)
                FindMapElement(trackWin(),Str(WindowID))
              
              EndIf
              
              Break
            EndIf
          Next
          ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
          ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
        EndIf
        
        
      Case #WM_MOUSELEAVE  
        
        ; makesure combobox is in a toolbarEx
        If ListSize(toolbarExButton()) > 0
          *thistoolbarEx = @toolbarEx()
          *thistoolbarExButton = @toolbarExButton()
          found = 0
          ForEach toolbarExButton()
            If (toolbarExButton()\gadget = WindowID Or toolbarExButton()\gadget = GetParent_(WindowID)) And toolbarExButton()\gadgetStyled <> 0
              ChangeCurrentElement(toolbarEx(), toolbarExButton()\toolbarEx)
              
              pt.POINT
              GetCursorPos_(@pt)
              
              hwnd = WindowFromPoint_(PeekQ(pt))
              FindMapElement(trackWin(),Str(WindowID))
              
              If hwnd <> toolbarExButton()\gadget And GetParent_(hwnd) <> toolbarExButton()\gadget And Not IsChild_(toolbarExButton()\gadget, hwnd)
                
                toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState &~ #TOOLBAREXGADGET_HOVER
                  
                GetClientRect_(toolbarExButton()\gadget, @trc.RECT)
                MapWindowPoints_(toolbarExButton()\gadget, toolbarExButton()\toolbarExHandle, @trc, 2)
                UnlockMutex(trackWinMutex)
                RedrawWindow_(toolbarExButton()\toolbarExHandle, trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ALLCHILDREN)
                LockMutex(trackWinMutex)
                FindMapElement(trackWin(),Str(WindowID))
                
              EndIf
              
              
              Break
            EndIf
          Next
          ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
          ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
        EndIf
      
      Case #WM_PAINT
      
        If trackWin()\windowType = #WINDOWTYPE_SYSCOMBOBOX
          
          ; makesure combobox is in a toolbarEx
          If ListSize(toolbarExButton()) > 0
            *thistoolbarEx = @toolbarEx()
            *thistoolbarExButton = @toolbarExButton()
            found = 0
            ForEach toolbarExButton()
              If toolbarExButton()\gadget = WindowID And toolbarExButton()\gadgetStyled <> 0
                ChangeCurrentElement(toolbarEx(), toolbarExButton()\toolbarEx)
                UIStyle = toolbarEx()\UIStyle
                state = toolbarExButton()\gadgetStyledState
                toolbarParent = GetParent_(toolbarEx()\handle)
                found = #True
                Break
              EndIf
            Next
            ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
            ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
          EndIf
          
          ; if toolbar has no style then see if toolbar is in rebar and get style from that instead
          If UIStyle = 0
            ForEach rebarGadget()
              If rebarGadget()\handle = toolbarParent
                UIStyle = rebarGadget()\UIStyle
                Break
              EndIf
            Next
          EndIf
          
          If found = #True

            glyphw = 5
            glyphh = 3
            framepad = 1
            dropwidth = 13
            
            GetClientRect_(WindowID, @rc.RECT)
            
            ; grab handle to the child edit hwnd
            editHwnd = GetWindow_(WindowID, #GW_CHILD|#GW_HWNDFIRST)
            If editHwnd <> 0
              GetClientRect_(editHwnd, @erc.RECT)
              MapWindowPoints_(editHwnd, WindowID, @erc, 2)
              
              offsetEdit = 4
              If erc\left <> offsetEdit
                ;Debug "need to offset"
                UnlockMutex(trackWinMutex)
                SetWindowPos_(editHwnd, 0, offsetEdit, erc\top, 0, 0, #SWP_NOACTIVATE|#SWP_NOSIZE|#SWP_NOZORDER|#SWP_NOOWNERZORDER)
                LockMutex(trackWinMutex)
                GetClientRect_(editHwnd, @erc.RECT)
                MapWindowPoints_(editHwnd, WindowID, @erc, 2)
              EndIf
              
              width = dropwidth+erc\left-1
              If erc\right <> rc\right-width
                ;Debug "need to adjust width"
                LockMutex(trackWinMutex)
                SetWindowPos_(editHwnd, 0, 0, 0, (rc\right-erc\left)-width, erc\bottom-erc\top, #SWP_NOACTIVATE|#SWP_NOMOVE|#SWP_NOZORDER|#SWP_NOOWNERZORDER)
                UnlockMutex(trackWinMutex)
                GetClientRect_(editHwnd, @erc.RECT)
                MapWindowPoints_(editHwnd, WindowID, @erc, 2)
              EndIf
            
            EndIf
            
            
            BeginPaint_(WindowID, @ps.PAINTSTRUCT)
            
            ;blitEx(ps\hdc, toolbarEx()\UIStyle, #toolstripBackground1, @rc, #ForceVerticalRedraw|#DynamicBlitEx)
            
            back = CreateSolidBrush_(RGB(255,255,255))
            
            ; draw border if hot, dropdown active or has focus
            If state & #TOOLBAREXGADGET_HOVER Or state & #TOOLBAREXGADGET_DROPDOWN Or state & #TOOLBAREXGADGET_FOCUS
              bordercol = getMenuColourEx(UIStyle, #menuHotBorder, 0)
              FrameRect_(ps\hdc, rc, bordercol)
            EndIf
  
            trc.RECT
            ;/ fill background around child edit
            If editHwnd <> 0
              ; left
              trc\left = rc\left+framepad
              trc\top = rc\top+framepad
              trc\bottom = rc\bottom-framepad
              trc\right = erc\left
              FillRect_(ps\hdc, trc, back)
              ; top
              trc\left = erc\left
              trc\top = rc\top+framepad
              trc\bottom = erc\top
              trc\right = erc\right
              FillRect_(ps\hdc, trc, back)
              ; bottom
              trc\left = erc\left
              trc\top = erc\bottom
              trc\bottom = rc\bottom-framepad
              trc\right = erc\right
              FillRect_(ps\hdc, trc, back)
              ; right
              trc\left = erc\right
              trc\top = rc\top+framepad
              trc\bottom = rc\bottom-framepad
              trc\right = (rc\right-dropwidth)-1
              FillRect_(ps\hdc, trc, back)
            ;/ if child edit doesn't exist then fill whole background
            Else
              trc\left = framepad
              trc\top = framepad
              trc\bottom = rc\bottom-framepad
              trc\right = (rc\right-dropwidth)-1
              FillRect_(ps\hdc, trc, back)
            EndIf
            
            ; draw hot dropdown button
            If (state & #TOOLBAREXGADGET_HOVER Or state & #TOOLBAREXGADGET_FOCUS) And Not state & #TOOLBAREXGADGET_DROPDOWN
              trc\left = rc\right-(dropwidth+framepad)
              trc\top = rc\top+framepad
              trc\bottom = rc\bottom-framepad
              trc\right = rc\right-framepad
              blitEx(ps\hdc, UIStyle, #toolbarHotGradientColor1, @trc, #ForceVerticalRedraw|#DynamicBlitEx)
              trc\left = rc\right-(dropwidth+framepad+1)
              trc\top = rc\top
              trc\bottom = rc\bottom
              trc\right = rc\right
              FrameRect_(ps\hdc, trc, bordercol)
            ; draw selected dropdown button
            ElseIf state & #TOOLBAREXGADGET_DROPDOWN
              trc\left = rc\right-(dropwidth+framepad)
              trc\top = rc\top+framepad
              trc\bottom = rc\bottom-framepad
              trc\right = rc\right-framepad
              blitEx(ps\hdc, UIStyle, #SelectGradientColor1, @trc, #ForceVerticalRedraw|#DynamicBlitEx)
              trc\left = rc\right-(dropwidth+framepad+1)
              trc\top = rc\top
              trc\bottom = rc\bottom
              trc\right = rc\right
              FrameRect_(ps\hdc, trc, bordercol)
            Else
            ; draw normal dropdown button
              trc\left = rc\right-(dropwidth+framepad)
              trc\top = rc\top+framepad
              trc\bottom = rc\bottom-framepad
              trc\right = rc\right-framepad
              FrameRect_(ps\hdc, trc, back)
            EndIf
            
            
            
            width = trc\right-trc\left
            height = trc\bottom-trc\top
            
            drawDropDownGlyph(ps\hdc, trc\left+((width/2)-glyphw/2), trc\top+((height/2)-glyphh/2), glyphw, glyphh, 0)
            
            DeleteObject_(back)
            
            If editHwnd = 0
              
              trc\left = framepad+1
              trc\top = framepad+1
              trc\bottom = rc\bottom-framepad-1
              trc\right = (rc\right-dropwidth)-6
              trgn = CreateRectRgn_(trc\left, trc\top, trc\right, trc\bottom)
              orgn = SelectClipRgn_(ps\hdc, trgn)
              
              CallWindowProc_(trackWin()\callbackProc,WindowID,#WM_PAINT,ps\hdc,lParam)
              
              SelectClipRgn_(ps\hdc, 0)
            EndIf
            
            EndPaint_(WindowID, @ps)
            
            ProcedureReturn 1
            
          EndIf
          
        EndIf
      

    EndSelect
    
  EndIf
  
EndProcedure

Structure xWins
  parenthwnd.i
  hdc.i
  last.i
  lastrc.RECT
EndStructure
Procedure excludeWins(hwnd, *xwin.xWins)
  LockMutex(trackWinMutex)
  FindMapElement(trackWin(),Str(GetParent_(hwnd)))
  ptype = trackWin()\windowType
  
  ;tclass.s = Space(255)
  ;GetClassName_(hwnd, @tclass, 255)
  ;Debug tclass
  
  FindMapElement(trackWin(),Str(hwnd))
  
  ; system tab control exception, always makes sure excluded from clip
  ; note, different handeling for XP
  If (trackWin()\windowType = #WINDOWTYPE_SYSTAB And OSVersion >= #PB_OS_Windows_Vista) Or (trackWin()\windowType = #WINDOWTYPE_SYSTAB And OSVersion < #PB_OS_Windows_Vista And ptype = #WINDOWTYPE_PANELEXPAGE Or ptype = #WINDOWTYPE_PANELEX)
    GetWindowRect_(hwnd, @rc.RECT)
    *xwin\parenthwnd = getRootPanelExPageHwnd(hwnd)
    MapWindowPoints_(0, *xwin\parenthwnd, @rc, 2)
    setPanelExClippedRect(@rc, hwnd, *xwin\parenthwnd)
    ExcludeClipRect_(*xwin\hdc, rc\left, rc\top, rc\right, rc\bottom)
  EndIf
  
;   tclass.s = Space(255)
;   wnd = hwnd
;   Repeat
;     wnd = GetParent_(wnd)
;     GetClassName_(wnd, @tclass, 255)
;     If tclass = "SysTabControl32"
;       GetWindowRect_(hwnd, @rc.RECT)
;       *xwin\parenthwnd = getRootPanelExPageHwnd(hwnd)
;       MapWindowPoints_(0, *xwin\parenthwnd, @rc, 2)
;       setPanelExClippedRect(@rc, hwnd, *xwin\parenthwnd)
;       ExcludeClipRect_(*xwin\hdc, rc\left, rc\top, rc\right, rc\bottom)
;       ;Debug "found : "+Str(hwnd)
;       
;       Break
;     EndIf
;   Until wnd = 0
  
  ; if not set as ws_ex_transparent and not progui control or progressbar then exclude
  If found = 0 And Not GetWindowLongPtr_(hwnd, #GWL_EXSTYLE) & #WS_EX_TRANSPARENT And ((trackWin()\windowType > #WINDOWTYPE_TEXTCONTROLEX And trackWin()\windowType <> #WINDOWTYPE_SYSPROGRESSBAR And trackWin()\windowType <> #WINDOWTYPE_TOOLBAREX) Or trackWin()\windowType = 0) And trackWin()\windowType <> #WINDOWTYPE_SYSCHECKBOX
  ; And trackWin()\windowType <> #WINDOWTYPE_SYSTAB
    *xwin\parenthwnd = getRootPanelExPageHwnd(hwnd)
    
    If GetWindowLongPtr_(hwnd, #GWL_STYLE) & #WS_VISIBLE And GetWindowLongPtr_(GetParent_(hwnd), #GWL_STYLE) & #WS_VISIBLE
      
      GetWindowRect_(hwnd, @rc.RECT)
      MapWindowPoints_(0, *xwin\parenthwnd, @rc, 2)
      
      setPanelExClippedRect(@rc, hwnd, *xwin\parenthwnd)
      
      If ptype = #WINDOWTYPE_PANELEXPAGE Or ptype = #WINDOWTYPE_PANELEX
        If rc\right-rc\left <> 0 And rc\bottom-rc\top <> 0
          
          ExcludeClipRect_(*xwin\hdc, rc\left, rc\top, rc\right, rc\bottom)
          
          ; check if the window has system scrollbars and exclude if so
          scinfo.SCROLLBARINFO
          scinfo\cbSize = SizeOf(SCROLLBARINFO)
          If GetScrollBarInfo_(hwnd, #OBJID_HSCROLL, @scinfo)
            ; if the horizontal scrollbar is visible
            If scinfo\rgstate[0] <> $00008000 And scinfo\rgstate[0] <> $00010000 And scinfo\rgstate[0] <> $00000001
              MapWindowPoints_(0, *xwin\parenthwnd, @scinfo\rcScrollBar, 2) ; scrollbar rect is in screen coords
              ExcludeClipRect_(*xwin\hdc, scinfo\rcScrollBar\left, scinfo\rcScrollBar\top, scinfo\rcScrollBar\right, scinfo\rcScrollBar\bottom)
              hShown = #True
              left = scinfo\rcScrollBar\right
              bottom = scinfo\rcScrollBar\bottom
            EndIf
          EndIf
          If GetScrollBarInfo_(hwnd, #OBJID_VSCROLL, @scinfo)
            ; if the vertical scrollbar is visible
            If scinfo\rgstate[0] <> $00008000 And scinfo\rgstate[0] <> $00010000 And scinfo\rgstate[0] <> $00000001
              MapWindowPoints_(0, *xwin\parenthwnd, @scinfo\rcScrollBar, 2) ; scrollbar rect is in screen coords
              ExcludeClipRect_(*xwin\hdc, scinfo\rcScrollBar\left, scinfo\rcScrollBar\top, scinfo\rcScrollBar\right, scinfo\rcScrollBar\bottom)
              vShown = #True
              top = scinfo\rcScrollBar\bottom
              right = scinfo\rcScrollBar\right
            EndIf
          EndIf
          If hShown = #True And vShown = #True
            ; this hack is necessary to fix dodgy Microsoft rendering of bottom right scroll box
            ; really sloppy programming by MS, patched it as best I can though.
            trc.RECT
            trc\left = left : trc\right = right : trc\top = top : trc\bottom = bottom
            FillRect_(*xwin\hdc, trc, GetSysColorBrush_(#COLOR_3DFACE))
            ExcludeClipRect_(*xwin\hdc, left, top, right, bottom)
          EndIf
            
        EndIf
      EndIf
      
    EndIf
 
  EndIf
  
  UnlockMutex(trackWinMutex)
  ProcedureReturn #True
  
EndProcedure


;- ****
Procedure SubclassTrackwinProc(WindowID,message,wParam,lParam)
  
  LockMutex(trackWinMutex)
  
  ; should never fail, unless window is being destroyed
  error = FindMapElement(trackWin(),Str(WindowID))
  If error = 0
    ;debuglog("Oh shit trackWin() not found! :/ !!")
    UnlockMutex(trackWinMutex)
    ProcedureReturn 0
  EndIf
  ;debuglog("cunt: "+MapKey(trackWin()))
  
  ; process any styled ComboBoxes in ToolBarEx
  result = handleStyledComboBox(WindowID,message,wParam,lParam)
  If result <> 0
    UnlockMutex(trackWinMutex)
    ProcedureReturn result
  EndIf
  
  ;If trackWin()\windowType = #WINDOWTYPE_SYSCHECKBOX
  ;  ;Debug "yay!"
  ;  UnlockMutex(trackWinMutex)
  ;  ProcedureReturn 1
  ;EndIf
  
  Select message
      
    Case #WM_MOUSEMOVE
      
      If mouseCaptured = #False Or GetAncestor_(WindowID, #GA_ROOT) <> WindowID
        Result = CallWindowProc_(trackWin()\callbackProc,WindowID,message,wParam,lParam)
      ;Else
      ;  Debug "blocked"
      EndIf
   
    Case #WM_WINDOWPOSCHANGING
      
      If trackWin()\created = #True
        trackWin()\created = #False
      EndIf
      
      ForEach rebarGadget()
        If rebarGadget()\Handle = WindowID
          
          *pos.WINDOWPOS = lParam
          
          ; send rebar update message to apps main window
          sendRebarUpdatedMsg(*pos\cy)
          FindMapElement(trackWin(),Str(WindowID))
          Break
          
        EndIf
      Next
      
      ; LimitWindowSize code
      *pos.WINDOWPOS = lParam
      If Not *pos\flags & $8000 ; maximized/minimized etc..
        If *pos\cx < trackWin()\limitSize\left And trackWin()\limitSize\left > 0
          
          GetWindowRect_(WindowID, rc.RECT)
          If *pos\x > rc\left 
            xdelta = *pos\cx-trackWin()\limitSize\left
            *pos\x = *pos\x + xdelta
          EndIf
          *pos\cx = trackWin()\limitSize\left
          
        ElseIf *pos\cx > trackWin()\limitSize\right And trackWin()\limitSize\right > 0
          
          GetWindowRect_(WindowID, rc.RECT)
          If *pos\x < rc\left 
            xdelta = *pos\cx-trackWin()\limitSize\right
            *pos\x = *pos\x + xdelta
          EndIf
          *pos\cx = trackWin()\limitSize\right
          
        EndIf
        If *pos\cy < trackWin()\limitSize\top And trackWin()\limitSize\top > 0
          
          GetWindowRect_(WindowID, rc.RECT)
          If *pos\y > rc\top 
            ydelta = *pos\cy-trackWin()\limitSize\top
            *pos\y = *pos\y + ydelta
          EndIf
          *pos\cy = trackWin()\limitSize\top
          
        ElseIf *pos\cy > trackWin()\limitSize\bottom And trackWin()\limitSize\bottom > 0
          
          GetWindowRect_(WindowID, rc.RECT)
          If *pos\y < rc\top 
            ydelta = *pos\cy-trackWin()\limitSize\bottom
            *pos\y = *pos\y + ydelta
          EndIf
          *pos\cy = trackWin()\limitSize\bottom
          
        EndIf
      EndIf
      
      
      Result = CallWindowProc_(trackWin()\callbackProc,WindowID,message,wParam,lParam)
      
    Case #WM_WINDOWPOSCHANGED
      
      ;/ if window is in panelexpage with autoscroll then update panelexpage
      LockMutex(panelMutex)
      If ListSize(panelexpage()) > 0
        ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
        *previousPanelExPage = @panelexpage()
        *previousPanelEx = @panelex()
        
        ForEach panelexpage()
          If panelexpage()\Handle = trackWin()\parent Or panelexpage()\Handle = oldParent
            
            If panelexpage()\Handle = trackWin()\parent
              found = #True
            Else
              found = #False
            EndIf
            
            If panelexpage()\autoScroll = #True And panelexpage()\displayed <> #False
              
              GetClientRect_(WindowID, @rc.RECT)
              MapWindowPoints_(WindowID, panelexpage()\handle, @rc, 2)
              
              calcarea.ScrollingChildWindows
              calcarea\Window = panelexpage()\Handle
              EnumChildWindows_(calcarea\Window, @ScrollingChildWindowsEnumProc(), @calcarea)
              lright = panelexpage()\area\right
              lbottom = panelexpage()\area\bottom
              panelexpage()\area\right = calcarea\rc\right-1;-calcarea\rc\left
              panelexpage()\area\bottom = calcarea\rc\bottom-1;-calcarea\rc\top
              
              If lright <> panelexpage()\area\right Or lbottom <> panelexpage()\area\bottom
              
;                 debuglog("poschanging: "+Str(windowid))
;               
;                 updatePanelExPageScrolling(0, 0)
;                 
;                 handlePanelExPageAutoScroll()
;                 updatePanelExPageScrollbars()
;                 
;                 If panelexpage()\hScrollVisible = #True And panelexpage()\vScrollVisible = #True
;                   RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
;                   RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
;                   RedrawWindow_(panelexpage()\scrollBarBox,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
;                 ElseIf panelexpage()\hScrollVisible = #True
;                   RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
;                 ElseIf panelexpage()\vScrollVisible = #True
;                   RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
;                 EndIf
;                 
;                 *thisPanelEx = @panelex()
;                 *thisPanelExPage = @panelexpage()
;                 handle = panelexpage()\Handle
;                 UnlockMutex(panelMutex)
;                 UnlockMutex(trackWinMutex)
;                 validateProgressbars(handle) ; invalidates panelex hwnd and validates any sys progress bars inside
;                 RedrawWindow_(panelexpage()\Handle,0,0,#RDW_ERASE|#RDW_ALLCHILDREN)
;                 SetWindowPos_(WindowID, 0, 0, 0, 0, 0, #SWP_NOACTIVATE|#SWP_NOMOVE|#SWP_NOSIZE|#SWP_NOZORDER)
;                 LockMutex(panelMutex)
;                 LockMutex(trackWinMutex)
;                 ChangeCurrentElement(panelex(), *thisPanelEx)
;                 ChangeCurrentElement(panelexpage(), *thisPanelExPage)
                
              EndIf
              
            EndIf
            
            
            
            ; need to find map again because of calling redraw window callback above
            ; should never fail, :/ famous last words lol
            FindMapElement(trackWin(),Str(WindowID))
            
            Break
          EndIf
        Next
        
        ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
        ChangeCurrentElement(panelexpage(), *previousPanelExPage)
        ChangeCurrentElement(panelex(), *previousPanelEx)
      EndIf
      UnlockMutex(panelMutex)
      
      Result = CallWindowProc_(trackWin()\callbackProc,WindowID,message,wParam,lParam)
      
    Case #WM_SHOWWINDOW
      
      ; detect if window's parent has changed and update trackWin if so
      parent = GetParent_(WindowID)
      If parent <> trackWin()\parent
        oldParent = trackWin()\parent
        trackWin()\parent = parent
      EndIf
      
      
      ;/ if window is in panelexpage with autoscroll then update panelexpage
      LockMutex(panelMutex)
      If ListSize(panelexpage()) > 0
        ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
        *previousPanelExPage = @panelexpage()
        
        ForEach panelexpage()
          If panelexpage()\Handle = trackWin()\parent Or panelexpage()\Handle = oldParent
            
            If panelexpage()\Handle = trackWin()\parent
              found = #True
            Else
              found = #False
            EndIf
            
            
            If panelexpage()\autoScroll = #True
              debuglog("show: "+Str(windowid))
              
              GetClientRect_(WindowID, @rc.RECT)
              MapWindowPoints_(WindowID, panelexpage()\handle, @rc, 2)
              
              
              If panelexpage()\Handle = trackWin()\parent
                If rc\right > panelexpage()\area\right
                  panelexpage()\area\right = rc\right
                EndIf
                If rc\bottom > panelexpage()\area\bottom
                  panelexpage()\area\bottom = rc\bottom
                EndIf
              ElseIf panelexpage()\Handle = oldParent
                
                calcarea.ScrollingChildWindows
                calcarea\Window = panelexpage()\Handle
                EnumChildWindows_(calcarea\Window, @ScrollingChildWindowsEnumProc(), @calcarea)
                panelexpage()\area\right = calcarea\rc\right;-calcarea\rc\left
                panelexpage()\area\bottom = calcarea\rc\bottom;-calcarea\rc\top
                
              EndIf
              
              
              updatePanelExPageScrolling(0, 0)
              
              handlePanelExPageAutoScroll()
              updatePanelExPageScrollbars()
              
              If panelexpage()\hScrollVisible = #True And panelexpage()\vScrollVisible = #True
                RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
                RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
                RedrawWindow_(panelexpage()\scrollBarBox,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
              ElseIf panelexpage()\hScrollVisible = #True
                RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
              ElseIf panelexpage()\vScrollVisible = #True
                RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
              EndIf
              
              
            EndIf
            
            *thisPanelEx = @panelex()
            *thisPanelExPage = @panelexpage()
            handle = panelexpage()\Handle
            UnlockMutex(panelMutex)
            UnlockMutex(trackWinMutex)
            validateProgressbars(handle) ; invalidates panelex hwnd and validates any sys progress bars inside
            RedrawWindow_(panelexpage()\Handle,0,0,#RDW_ERASE|#RDW_ALLCHILDREN)
            SetWindowPos_(WindowID, 0, 0, 0, 0, 0, #SWP_NOACTIVATE|#SWP_NOMOVE|#SWP_NOSIZE|#SWP_NOZORDER)
            LockMutex(panelMutex)
            LockMutex(trackWinMutex)
            ChangeCurrentElement(panelex(), *thisPanelEx)
            ChangeCurrentElement(panelexpage(), *thisPanelExPage)
            
            ; need to find map again because of calling redraw window callback above
            ; should never fail, :/ famous last words lol
            FindMapElement(trackWin(),Str(WindowID))
            
            Break
          EndIf
        Next
        
        ; if window should be transparent in panelex page then handle ws_ex_transparent states
        If found = #True And trackWin()\transparent = #True
          If Not GetWindowLongPtr_(WindowID, #GWL_EXSTYLE) & #WS_EX_TRANSPARENT
            debuglog("windowshow in panelex: setting to ws_wx_transparent")
            SetWindowLongPtr_(WindowID, #GWL_EXSTYLE, #WS_EX_TRANSPARENT)
          EndIf
        ElseIf found = #False And trackWin()\transparent = #True
          If GetWindowLongPtr_(WindowID, #GWL_EXSTYLE) & #WS_EX_TRANSPARENT
            debuglog("windowshow not in panelex: setting to not ws_wx_transparent")
            SetWindowLongPtr_(WindowID, #GWL_EXSTYLE, 0)
            
            ForEach panelexpage()
              If panelexpage()\containerHandle = WindowID
                panelexpage()\dontdraw = 0
              EndIf
            Next
            
          EndIf
        EndIf
        
        ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
        ChangeCurrentElement(panelexpage(), *previousPanelExPage)
      EndIf
      UnlockMutex(panelMutex)
    
      Result = CallWindowProc_(trackWin()\callbackProc,WindowID,message,wParam,lParam)
      
    Case #WM_PAINT
      
      ; stop default rendering of PureBasic frame gadget if inside panelex page
      found = 0
      If trackWin()\windowType = #WINDOWTYPE_PBFRAME
        parentclass.s = Space(255)
        GetClassName_(GetParent_(WindowID), @parentclass, 255)
        If parentclass = panelExPageClass
          
          BeginPaint_(WindowID, @ps.PAINTSTRUCT)
          ps\fErase = 0
          ps\rcPaint\top = 0
          ps\rcPaint\left = 0
          ps\rcPaint\right = 0
          ps\rcPaint\bottom = 0
          EndPaint_(WindowID, @ps)
          result = 1
          
          found = #True
        EndIf
      EndIf
      
      
      If found = #False
        Result = CallWindowProc_(trackWin()\callbackProc,WindowID,message,wParam,lParam)
      EndIf
    
    Case #WM_ERASEBKGND
      
      
      If trackWin()\windowType = #WINDOWTYPE_PANELEXPAGE And GetWindowLongPtr_(WindowID, #GWL_STYLE) & #WS_VISIBLE
        xwin.xWins
        xwin\parenthwnd = WindowID
        xwin\hdc = wParam
        UnlockMutex(trackWinMutex)
        EnumChildWindows_(WindowID, @excludeWins(), xwin)
        LockMutex(trackWinMutex)
        FindMapElement(trackWin(),Str(WindowID))
      EndIf
      
      
      ;/ check if there are any panelExs in this window and this window is not a panelexpage
      ;/ then exclude the client rect of each panelex from the background erase of this window
      ;- make sure this window isn't a panelexpage
      If trackWin()\windowType <> #WINDOWTYPE_PANELEXPAGE
        
        LockMutex(panelMutex)
        If ListSize(panelex()) > 0
          ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
          *previousPanelEx = @panelex() 
          
          ForEach panelex()
            If GetParent_(panelex()\Handle) = WindowID
              
              GetWindowRect_(panelex()\Handle, @rc.RECT)
              MapWindowPoints_(0, WindowID, @rc, 2)
              ExcludeClipRect_(wParam, rc\left, rc\top, rc\right, rc\bottom)
              
              ;debuglog("found panelex in main window! "+Str(panelex()\Handle))
              
            EndIf
          Next
            
          ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
          ChangeCurrentElement(panelex(), *previousPanelEx)
        EndIf
        UnlockMutex(panelMutex)
        
      EndIf
      
      
      Result = CallWindowProc_(trackWin()\callbackProc,WindowID,message,wParam,lParam)
      
      
    Case #WM_DESTROY
      
      Result = CallWindowProc_(trackWin()\callbackProc,WindowID,message,wParam,lParam)
      DeleteMapElement(trackWin(), Str(WindowID))
      
      ;class.s = Space(255)
      ;GetClassName_(WindowID, @class, 255)
      ;debuglog("WM_DESTROY "+Str(WindowID)+" "+class+" "+Str(MapSize(trackWin())))
    
    Default
      
      
      
      Result = CallWindowProc_(trackWin()\callbackProc,WindowID,message,wParam,lParam)
  EndSelect
  
  UnlockMutex(trackWinMutex)
  

  ProcedureReturn Result
EndProcedure
;- ***

Procedure KeyboardHook(nCode, wParam, lParam)
  
  Result = CallNextHookEx_(0, nCode, wParam, lParam)
  
  If HaltProGUI = #True
    ProcedureReturn 0
  EndIf
  
  Select nCode
    Case #HC_ACTION
      
      ;debuglog(Str(wParam))
      
      ; alt key or f10 pressed, activate menu
      If wParam = 18 Or (menuExF10Disable = 0 And wParam = 121)
        ;debuglog(Str(lParam|#KF_UP))
        
        If lParam|#KF_UP = 540573697 Or lParam|#KF_UP = 4489217
         
          ;debuglog(Str(menuKeyboardActive))
          
          If menuKeyboardActive = #False
            
            ; search for a menu toolbar
            ForEach menuex()
              If menuex()\toolbarID > 0
                menuKeyboardActive = #True
                altActivated = #True
                menuToolbar = menuex()\toolbarID
                menuOldFocus = SetFocus_(menuToolbar)
                SendMessage_(menuToolbar, #TB_SETHOTITEM, 0, 0)
                ProcedureReturn #True
              EndIf
            Next
            
          Else
            menuKeyboardActive = #False
            menuHotItemNext = -1
            menuItemOver = -1
            menuHotItem = -1
            altActivated = #False
            EndMenu_()
            SetFocus_(menuOldFocus)
            SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
            UpdateWindow_(menuToolbar)
            ProcedureReturn #True
          EndIf
        EndIf
        
        If menuHotItem = -2 And lParam|#KF_UP = -1070039039
          menuKeyboardActive = #False
          menuHotItemNext = -1
          menuItemOver = -1
          menuHotItem = -1
          altActivated = #False
          menuex()\active = 0
          EndMenu_()
          SetFocus_(menuOldFocus)
          SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
          UpdateWindow_(menuToolbar)
          ProcedureReturn #True
        EndIf
        
      EndIf
      
      If wParam = #VK_ESCAPE And altActivated = #True; And menuKeyboardActive = #False
        debuglog("escape")
        SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
        UpdateWindow_(menuToolbar)
        SetFocus_(menuOldFocus)
        menuKeyboardActive = #False
        altActivated = #False
        menuHotItemNext = -1
        menuItemOver = -1
        menuHotItem = -1
        ProcedureReturn Result
      EndIf
      
      ; this code solves bug with clicking on same selected menu title
      If altActivated = #True
        If wParam = #VK_DOWN And (lParam>> 16 & $FFFF = 336 Or lParam>> 16 & $FFFF = 16720)
          altActivated = -2
        ElseIf wParam = #VK_RETURN And lParam|#KF_UP = 1867777
          altActivated = -2
        ElseIf wParam <> 18 And wParam <> 121 And wParam <> #VK_RIGHT And wParam <> #VK_LEFT And wParam <> #VK_DOWN And wParam <> #VK_RETURN
          altActivated = -2
        EndIf
      EndIf

      ; handle scroll menu hot keys
      If menuScrollHandle <> 0

        k = MapVirtualKey_(wParam, 2)
        ;c.s = Chr(PeekW(@k))
        c.s = Chr(k&$FFFF)
        ForEach menuScrollHotKey()
          If menuScrollHotKey()\hotkey = c And menuex()\popupid = menuScrollHandle
            
            mnfo.MENUITEMINFO_Fixed
            mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
            mnfo\fMask = #MIIM_SUBMENU
            GetMenuItemInfo_(originalScrollMenu, menuScrollHotKey()\id, 0, @mnfo)
            If mnfo\hSubMenu = 0
              SendMessage_(menuex()\WindowID, #WM_COMMAND, MakeLong(menuScrollHotKey()\id, 0), 0)
              menuKeyboardActive = #False
              menuHotItemNext = -1
              menuItemOver = -1
              menuHotItem = -1
              altActivated = #False
              menuex()\active = 0
              EndMenu_()
              SetFocus_(menuOldFocus)
            EndIf
          EndIf
        Next
      EndIf
      
      
  EndSelect
  
  ProcedureReturn Result
EndProcedure


Procedure dropShadowCallback(Window, message, wParam, lParam)

  Select message
    Case #WM_DESTROY
      ChangeCurrentElement(drpShadow(), GetWindowLongPtr_(Window, #GWLP_USERDATA))
      DeleteDC_(drpShadow()\hdc)
      DeleteObject_(drpShadow()\bitmap)
      DeleteElement(drpShadow())
    Default
      Result  = DefWindowProc_(Window, message, wParam, lParam)
  EndSelect
  
  ProcedureReturn Result
EndProcedure


Procedure dropShadow(dx, dy, width, height, colour, Alpha, flags)
  Static hBitmap, hBitmapHdc, hBitmapWidth, hBitmapHeight, hBitmapAlpha, hBitmapColour
  Static vBitmap, vBitmapHdc, vBitmapWidth, vBitmapHeight, vBitmapAlpha, vBitmapColour
  
  
  If flags & #DropShadowFlushCache
    If hBitmap <> 0
      DeleteDC_(hBitmapHdc)
      DeleteObject_(hBitmap)
      hBitmap = 0
      hBitmapHdc = 0
      hBitmapWidth = 0
      hBitmapHeight = 0
      hBitmapAlpha = 0
      vBitmapColour = 0
      ret = #True
    EndIf
    If vBitmap <> 0
      DeleteDC_(vBitmapHdc)
      DeleteObject_(vBitmap)
      vBitmap = 0
      vBitmapHdc = 0
      vBitmapWidth = 0
      vBitmapHeight = 0
      vBitmapAlpha = 0
      vBitmapColour = 0
      ret = #True
    EndIf
    ProcedureReturn ret
  EndIf
  
  If dropShadowClass = ""
    dropShadowClass = #AppName+"_DropShadow"
    wc.WNDCLASSEX
    wc\cbSize  = SizeOf(WNDCLASSEX)
    wc\style = 0
    wc\lpfnWndProc  = @dropShadowCallback()
    wc\lpszClassName  = @dropShadowClass
    RegisterClassEx_(@wc)
  EndIf
  
  If width <= 0 Or height <= 0 Or Alpha <= 0
    ProcedureReturn 0
  EndIf
  
  sr = Red(colour)
  sg = Green(colour)
  sb = Blue(colour)
  
  Window = CreateWindowEx_(#WS_EX_LAYERED|#WS_EX_TRANSPARENT|#WS_EX_TOOLWINDOW|#WS_EX_TOPMOST|#WS_EX_NOACTIVATE, dropShadowClass, 0, 0, 0, 0, 0, 0, 0, #Null,  GetModuleHandle_(0), #Null)
  If Window <> 0
    
    hdc = GetWindowDC_(Window)
    shdc = CreateCompatibleDC_(hdc)
    bitmap = CreateCompatibleBitmap_(hdc, width, height)
    
    AddElement(drpShadow())
    drpShadow()\hwnd = Window
    drpShadow()\hdc = shdc
    drpShadow()\bitmap = bitmap
    SetWindowLongPtr_(Window, #GWLP_USERDATA, @drpShadow())
    
    ; render new shadow to cache bitmap if size change necessary or alpha changes
    If flags & #DropShadowVertical
      ;debuglog("Vertical")
      
      ; make sure the height is large enough to contain corners
      h = height
      If flags & #DropShadowStart
        h = h + width
      ElseIf flags & #DropShadowEnd
        h = h + width
      ElseIf flags & #DropShadowNoEnds
        h = h + (width*2)
      EndIf
      
      ; if bitmap doesn't exist or requested dimensions won't fit in bitmap then create new bitmap
      If vBitmap = 0 Or width > vBitmapWidth Or h > vBitmapHeight Or Alpha <> vBitmapAlpha Or colour <> vBitmapColour
        ;debuglog("rendering vertical dropshadow...")
        
        If vBitmap <> 0 ; free old bitmap if exists
          DeleteDC_(vBitmapHdc)
          DeleteObject_(vBitmap)
        EndIf
        
        vBitmap = CreateCompatibleBitmap_(hdc, width, h)
        vBitmapHdc = CreateCompatibleDC_(hdc)
        vBitmapWidth = width
        vBitmapHeight = h
        vBitmapColour = colour
        vBitmapAlpha = Alpha
        
        ; render new whole dropshadow including corners
        *mem = AllocateMemory(vBitmapWidth * vBitmapHeight * 4)
        
        lSize = vBitmapWidth
        For y = 0 To vBitmapHeight-1
          ; Check If near start of corner end If so reduce the Alpha
          ; To create the corners:
          If y < lSize  ; top corner
            lInitC = (Alpha * (y+1)) / lSize
          ElseIf y >= vBitmapHeight-lSize ; bottom corner
            lInitC = ((vBitmapHeight-y) * Alpha) / lSize
          Else
            lInitC = Alpha
          EndIf
          
          ; Set the Alpha according To distance from the edge:            
          For x = 0 To lSize - 1
            lC = (lInitC * (lSize-1-x)) / lSize
            r = (sr*lC)/$FF
            g = (sg*lC)/$FF
            b = (sb*lC)/$FF
            PokeL(*mem+((x*4)+((vBitmapHeight-y-1)*vBitmapWidth*4)), b|g<<8|r<<16|lC<<24)
          Next
        Next
        
        bmi.BITMAPINFO
        bmi\bmiHeader\biSize = SizeOf(BITMAPINFOHEADER)
        bmi\bmiHeader\biWidth = vBitmapWidth
        bmi\bmiHeader\biHeight = vBitmapHeight
        bmi\bmiHeader\biPlanes = 1
        bmi\bmiHeader\biBitCount = 32
        bmi\bmiHeader\biCompression = #BI_RGB 
        
        SetDIBits_(vBitmapHdc, vBitmap, 0, bmi\bmiHeader\biHeight, *mem, @bmi, #DIB_RGB_COLORS)
        FreeMemory(*mem)
        
      EndIf
      
      ; blit the parts of the shadow we need
      SelectObject_(vBitmapHdc, vBitmap)
      SelectObject_(shdc, bitmap)
      If flags & #DropShadowStart
        ;debuglog("blit #DropShadowStart")
        BitBlt_(shdc, 0, 0, width, height, vBitmapHdc, 0, 0, #SRCCOPY)
      ElseIf flags & #DropShadowEnd
        ;debuglog("blit #DropShadowEnd")
        BitBlt_(shdc, 0, 0, width, height, vBitmapHdc, 0, (vBitmapHeight-height), #SRCCOPY)
      ElseIf flags & #DropShadowNoEnds
        ;debuglog("blit #DropShadowNoEnds")
        BitBlt_(shdc, 0, 0, width, height, vBitmapHdc, 0, width, #SRCCOPY)
      Else
        ;debuglog("blit whole")
        If height < vBitmapHeight
          BitBlt_(shdc, 0, 0, width, height-width, vBitmapHdc, 0, 0, #SRCCOPY)
          BitBlt_(shdc, 0, height-width, width, width, vBitmapHdc, 0, (vBitmapHeight-width), #SRCCOPY)
        Else
          BitBlt_(shdc, 0, 0, width, height, vBitmapHdc, 0, 0, #SRCCOPY)
        EndIf
      EndIf
  
    ElseIf Not flags & #DropShadowVertical
      ;debuglog("Horizontal")
      
      ; make sure the width is large enough to contain corners
      w = width
      If flags & #DropShadowStart
        w = w + height
      ElseIf flags & #DropShadowEnd
        w = w + height
      ElseIf flags & #DropShadowNoEnds
        w = w + (height*2)
      EndIf
      
      ; if bitmap doesn't exist or requested dimensions won't fit in bitmap then create new bitmap
      If hBitmap = 0 Or w > hBitmapWidth Or height > hBitmapHeight Or Alpha <> hBitmapAlpha Or colour <> hBitmapColour
        ;debuglog("rendering horizontal dropshadow...")
        
        If hBitmap <> 0 ; free old bitmap if exists
          DeleteDC_(hBitmapHdc)
          DeleteObject_(hBitmap)
        EndIf
        
        hBitmap = CreateCompatibleBitmap_(hdc, w, height)
        hBitmapHdc = CreateCompatibleDC_(hdc)
        hBitmapWidth = w
        hBitmapHeight = height
        hBitmapColour = colour
        hBitmapAlpha = Alpha
        
        ; render new whole dropshadow including corners
        *mem = AllocateMemory(hBitmapWidth * hBitmapHeight * 4)
        
        lSize = hBitmapHeight
        For x = 0 To hBitmapWidth-1
          ; Check If near start of corner end If so reduce the Alpha
          ; To create the corners:
          If x < lSize  ; left corner
            lInitC = (Alpha * (x+1)) / lSize
          ElseIf x >= hBitmapWidth-lSize ; right corner
            lInitC = ((hBitmapWidth-x) * Alpha) / lSize
          Else
            lInitC = Alpha
          EndIf
          
          ; Set the Alpha according To distance from the edge:            
          For y = 0 To lSize - 1
            lC = (lInitC * (lSize-1-y)) / lSize
            r = (sr*lC)/$FF
            g = (sg*lC)/$FF
            b = (sb*lC)/$FF
            PokeL(*mem+((x*4)+((hBitmapHeight-y-1)*hBitmapWidth*4)), b|g<<8|r<<16|lC<<24)
          Next
        Next
        
        bmi.BITMAPINFO
        bmi\bmiHeader\biSize = SizeOf(BITMAPINFOHEADER)
        bmi\bmiHeader\biWidth = hBitmapWidth
        bmi\bmiHeader\biHeight = hBitmapHeight
        bmi\bmiHeader\biPlanes = 1
        bmi\bmiHeader\biBitCount = 32
        bmi\bmiHeader\biCompression = #BI_RGB 
        
        SetDIBits_(hBitmapHdc, hBitmap, 0, bmi\bmiHeader\biHeight, *mem, @bmi, #DIB_RGB_COLORS)
        FreeMemory(*mem)
        
      EndIf
      
      ; blit the parts of the shadow we need
      SelectObject_(hBitmapHdc, hBitmap)
      SelectObject_(shdc, bitmap)
      If flags & #DropShadowStart
        ;debuglog("blit #DropShadowStart")
        BitBlt_(shdc, 0, 0, width, height, hBitmapHdc, 0, 0, #SRCCOPY)
      ElseIf flags & #DropShadowEnd
        ;debuglog("blit #DropShadowEnd")
        BitBlt_(shdc, 0, 0, width, height, hBitmapHdc, (hBitmapWidth-width), 0, #SRCCOPY)
      ElseIf flags & #DropShadowNoEnds
        ;debuglog("blit #DropShadowNoEnds")
        BitBlt_(shdc, 0, 0, width, height, hBitmapHdc, height, 0, #SRCCOPY)
      Else
        ;debuglog("blit whole")
        If width < hBitmapWidth
          BitBlt_(shdc, 0, 0, width-height, height, hBitmapHdc, 0, 0, #SRCCOPY)
          BitBlt_(shdc, width-height, 0, height, height, hBitmapHdc, (hBitmapWidth-height), 0, #SRCCOPY)
        Else
          BitBlt_(shdc, 0, 0, width, height, hBitmapHdc, 0, 0, #SRCCOPY)
        EndIf
      EndIf
      
    EndIf
    
    sz.SIZE
    sz\cx = width
    sz\cy = height
    pnt.POINT
    pnt\x = dx
    pnt\y = dy
    ContextOffset.POINT
    BlendMode.BLENDFUNCTION
    BlendMode\SourceConstantAlpha = 255
    BlendMode\AlphaFormat = 1
    UpdateLayeredWindow_(Window, 0, @pnt, @sz, shdc, @ContextOffset, 0, @BlendMode, 2)
    
    
    ShowWindow_(Window, #SW_SHOWNA)
    
    
    ReleaseDC_(Window, hdc)
    
    ProcedureReturn Window
  EndIf
  
  ProcedureReturn 0
  
EndProcedure


Procedure CallWndProcHook(nCode, wParam, lParam)
  Static lastmenuHotItem
  
  
  *cwp.CWPSTRUCT = lParam
  
  If CompositionEnabled = #False And menuEraseBuffered = #True
    If (*cwp\message = #WM_PAINT Or *cwp\message = #WM_NOTIFY) And menuEraseBufferInvalid = -1
      
      class.s = Space(255)
      GetClassName_(*cwp\hwnd, @class, 255)
      
      If class <> "#32768"
        If menuWindow <> 0
          GetWindowRect_(menuWindow, @rc.RECT)
          GetWindowRect_(*cwp\hwnd, @rec.RECT)
          If IntersectRect_(@nrec.RECT, rc, rec) <> 0
            menuEraseBufferInvalid = #True
            ;debuglog("paint :"+Str(*cwp\hwnd))
          EndIf
        EndIf
      EndIf
      
    EndIf

  EndIf
  
  Select nCode
    Case #HC_ACTION
      
      *cwp.CWPSTRUCT = lParam

      If *cwp\message = #WM_CREATE
        
        ;/ make sure window is a popup
        class.s = Space(255)
        GetClassName_(*cwp\hwnd, @class, 255)
        
        If class = "#32768" And menuHandle <> 0 ; menu
        
          ; remove CS_SAVEBITS from class when menu tracking
          If CompositionEnabled = #False
            style = GetClassLongPtr_(*cwp\hwnd, #GCL_STYLE)
            If menuActive <> 0 And menuHotItem <> -1 And menuHotItem <> lastmenuHotItem
              If style & #CS_SAVEBITS
                style = style & ~ #CS_SAVEBITS
                SetClassLongPtr_(*cwp\hwnd, #GCL_STYLE, style)
              EndIf
            Else
              If Not style & #CS_SAVEBITS
                style = style | #CS_SAVEBITS
                SetClassLongPtr_(*cwp\hwnd, #GCL_STYLE, style)
              EndIf
            EndIf
          EndIf
          
          miniMenuWindow = *cwp\hwnd

          ; subclass the window
          OldSubclassWndProc = SetWindowLongPtr_(*cwp\hwnd, #GWLP_WNDPROC, @SubclassWndProc())
          
          ; sync update of menu toolbar buttons with menu window
          If menuActive <> 0
            ;If menuHotItem <> -1 And menuHotItem <> lastmenuHotItem
              
              SendMessage_(menuToolbar, #TB_SETHOTITEM, menuHotItem, 0)
              SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
              GetUpdateRect_(menuToolbar, @rc.RECT, #False)
              RedrawWindow_(menuToolbar,rc,0,#RDW_ERASENOW|#RDW_UPDATENOW)
              SendMessage_(menuToolbar, #WM_SETREDRAW, #False, 0)
              lastmenuHotItem = menuHotItem
            ;EndIf
          EndIf
          
        ; if this window is a system drop-shadow and menuex is open then destroy  
        ElseIf class = "SysShadow" And menuHandle <> 0
          
          DestroyWindow_(*cwp\hwnd)
       
        ;/ if not a menu or shadow or other unwanted class
        ;/ then subclass the Window with our Window tracking proc
        ElseIf class <> "#32768" And class <> "SysShadow" And class <> dropShadowClass And class <> "tooltips_class32" And class <> "MSCTFIME UI" And class <> "CLIPBRDWNDCLASS" And class <> "CicMarshalWndClass" And class <> "IME" And class <> "ComboLBox" And class <> "DDEMLEvent" And class <> "Message" And class <> "Static" And class <> "GDI+ Hook Window Class" And class <> scrollbarBoxClass
          If GetParent_(*cwp\hwnd) <> #HWND_MESSAGE ; not message only window
            ; subclass the window
            ;debuglog("class: "+class)
            
            LockMutex(trackWinMutex)
            
              trackWin(Str(*cwp\hwnd))\created = #True
              trackWin()\hwnd = *cwp\hwnd
              ; assign windowType based on class and flag as transparent when in container if needed
              If class = panelExContainerClass
                trackWin()\windowType = #WINDOWTYPE_PANELEX
                trackWin()\transparent = #True
              ElseIf class = panelExPageClass
                trackWin()\windowType = #WINDOWTYPE_PANELEXPAGE
              ElseIf class = buttonExClass
                trackWin()\windowType = #WINDOWTYPE_BUTTONEX
                trackWin()\transparent = #True
              ElseIf class = textControlExClass
                trackWin()\windowType = #WINDOWTYPE_TEXTCONTROLEX
                trackWin()\transparent = #True
              ElseIf class = "ToolbarWindow32"
                trackWin()\windowType = #WINDOWTYPE_TOOLBAREX
              ElseIf class = "ComboBox"
                trackWin()\windowType = #WINDOWTYPE_SYSCOMBOBOX
              ElseIf class = "Edit"
                tclass.s = Space(255)
                GetClassName_(GetParent_(*cwp\hwnd), @tclass, 255)
                If tclass  = "ComboBox"
                  trackWin()\windowType = #WINDOWTYPE_SYSCOMBOBOXEDIT
                Else
                  trackWin()\windowType = #WINDOWTYPE_EDIT
                EndIf
              ElseIf class = "msctls_progress32"
                trackWin()\windowType = #WINDOWTYPE_SYSPROGRESSBAR
              ElseIf class = "Button"
                
                style = GetWindowLongPtr_(*cwp\hwnd, #GWL_STYLE)
                If (style & #BS_GROUPBOX = #BS_GROUPBOX)
                  trackWin()\windowType = #WINDOWTYPE_PBFRAME
                Else
                  trackWin()\windowType = #WINDOWTYPE_SYSCHECKBOX
                EndIf
                
              ElseIf class = "PureContainer"
                trackWin()\windowType = #WINDOWTYPE_PBCONTAINER
              ElseIf class = "SysTabControl32"
                trackWin()\windowType = #WINDOWTYPE_SYSTAB
              EndIf
              trackWin()\callbackProc = SetWindowLongPtr_(*cwp\hwnd, #GWLP_WNDPROC, @SubclassTrackwinProc())
              debuglog("trackwin: "+Str(*cwp\hwnd)+" "+class+" callback: "+Str(trackWin()\callbackProc))
              
            UnlockMutex(trackWinMutex)
              
            
            ; hack to get rid of 2 pixel graphical glitch in toolbars when CCS_NODIVIDER is set after toolbar is visible
            ; works by intercepting toolbar window before visible and setting CCS_NODIVIDER
            If class = "ToolbarWindow32"
              OldStyle=GetWindowLongPtr_(*cwp\hwnd,#GWL_STYLE)
              SetWindowLongPtr_(*cwp\hwnd,#GWL_STYLE, OldStyle|#CCS_NODIVIDER)
            EndIf
            
          EndIf
        EndIf
        
      EndIf
      
      If *cwp\message = #WM_DESTROY
        
        ; make sure window is a popup
        class.s = Space(255)
        GetClassName_(*cwp\hwnd, @class, 255)
        
        If class = "#32768" ; menu

          ; destroy any shadows attached to menu
          ForEach shadow()
            If shadow()\hwnd = *cwp\hwnd
              DestroyWindow_(shadow()\rightShadow)
              DestroyWindow_(shadow()\bottomShadow)
              DestroyWindow_(shadow()\leftBottomShadow)
              DeleteElement(shadow())
            EndIf
          Next
          
        EndIf
        
      EndIf

  EndSelect
  
  Result = CallNextHookEx_(0, nCode, wParam, lParam)
  ProcedureReturn Result
EndProcedure


ProcedureDLL CreateMenuEx(MenuID.l, WindowID.i, style.l)  ; Creates a "floating" menu bar, see docs for different styles...
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  If MenuID <> #ProGUI_Any
    ; check that id doesnt already exist
    ForEach menuex()
      If menuex()\id = MenuID
        UnlockMutex(menuMutex)
        ProcedureReturn 0
      EndIf
    Next
  Else
    MenuID = generateUniqueID()
    ProGUI_Any = #True
  EndIf
  
  menuToolbar = ToolBarExID(CreateToolBarEx(#ProGUI_Any, WindowID, 0, 0, #CCS_NORESIZE | #CCS_NODIVIDER | #TBSTYLE_AUTOSIZE | #TBSTYLE_FLAT | #TBSTYLE_LIST | #TBSTYLE_WRAPABLE))
  If menuToolbar = 0
    UnlockMutex(menuMutex)
    ProcedureReturn 0 ; exit if error creating toolbar
  EndIf
  LockMutex(toolbarMutex)
  ForEach toolbarEx()
    If toolbarEx()\Handle = menuToolbar
      toolbarEx()\isMenu = #True
      Break
    EndIf
  Next

  SendMessage_(menuToolbar, #TB_SETEXTENDEDSTYLE, 0, 0)
  
  ; disable toolbar theming , no dodge vista fading
  If XPthemeActive <> 0
    CallFunctionFast(*SetWindowTheme, menuToolbar, @null.w, @null.w)
  EndIf
  
  
  padding = SendMessage_(menuToolbar, #TB_GETPADDING, 0, 0)
  SendMessage_(menuToolbar, #TB_SETPADDING, 0, MakeLong(0,0));MakeLong(6,PeekW(@padding+2)))
  
  If style = #UISTYLE_OFFICE2003
    style = 6
  EndIf
  
  LastElement(menuex())
  AddElement(menuex())
  menuex()\id = MenuID
  menuex()\WindowID = WindowID
  menuex()\toolbarID = menuToolbar
  menuex()\popupid = -1
  menuex()\buttonID = -1
  menuex()\style = style
  currentMenuEx = MenuID
  
  ; check if a menu callback has been created for this windowid
  found = 0
  ForEach menuCallback()
    If menuCallback()\WindowID = WindowID
      found = -1
      Break
    EndIf
  Next
  
  ; if menu call back hasnt been created then create one
  If found = 0
    ProGUIOldCallBack = SetWindowLongPtr_(WindowID, #GWLP_WNDPROC, @MyWindowCallback())
    LastElement(menuCallback())
    AddElement(menuCallback())
    menuCallback()\WindowID = WindowID
    menuCallback()\callback = @MyWindowCallback()
    menuCallback()\oldCallback = ProGUIOldCallBack
    SetWindowLongPtr_(WindowID, #GWL_STYLE, GetWindowLongPtr_(WindowID, #GWL_STYLE)|#WS_CLIPCHILDREN)
  EndIf
  
  ; create hook to intercept creation of new windows for popup menus
  If WindowHook = 0
    threadId = GetWindowThreadProcessId_(WindowID, 0)
    WindowHook = SetWindowsHookEx_(#WH_CALLWNDPROC, @CallWndProcHook(), 0, threadId)
  EndIf
  
  ; create hook to handle keyboard navigation
  If KeyboardHook = 0
    threadId = GetWindowThreadProcessId_(WindowID, 0)
    KeyboardHook = SetWindowsHookEx_(#WH_KEYBOARD, @KeyboardHook(), 0, threadId)
  EndIf
  
  ; check if currentMenuEXFont has been set
  If currentMenuEXFont = 0
    metrics.NONCLIENTMETRICS
    metrics\cbSize = SizeOf(NONCLIENTMETRICS)
    
    SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
    currentMenuEXFont = CreateFontIndirect_(metrics\lfMenuFont)
  EndIf
  
  UnlockMutex(menuMutex)
  UnlockMutex(toolbarMutex)
  
  If ProGUI_Any = #False
    ProcedureReturn menuToolbar
  Else
    ProcedureReturn MenuID
  EndIf
  
EndProcedure

ProcedureDLL CreatePopupMenuEx(MenuID.l, style.l) ; Creates a popup menu
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  If MenuID = #ProGUI_Any
    
    ; generate unique menu id
    MenuID = generateUniqueID() 
    
  Else
    ; check that id doesnt already exist
    ForEach menuex()
      If menuex()\id = MenuID
        UnlockMutex(menuMutex)
        ProcedureReturn 0
      EndIf
    Next
  EndIf
  
  popupid = CreatePopupMenu(#PB_Any)
  If popupid = 0
    Debug "Error creating popup menu!"
    UnlockMutex(menuMutex)
    ProcedureReturn 0
  EndIf
  
  If style = #UISTYLE_OFFICE2003
    style = 6
  EndIf
  
  ; create new menu entry
  LastElement(menuex())
  AddElement(menuex())
  
  menuex()\id = MenuID
  menuex()\toolbarID = -1
  menuex()\popupid = MenuID(popupid)
  menuex()\purepopupid = popupid
  menuex()\buttonID = -1
  menuex()\singleMenu = -1
  menuex()\style = style
  
  currentMenuTitleEX = menuex()\popupid
  currentMenuEx = MenuID
  
  UnlockMutex(menuMutex)
  
  ProcedureReturn currentMenuTitleEX
  
EndProcedure

ProcedureDLL DisplayPopupMenuEx(menu.i, WindowID.i, x.l, y.l) ; Displays a PopupMenuEx on screen at x, y coordinates
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  If ListSize(itemex()) = 0
    UnlockMutex(menuMutex)
    ProcedureReturn 0
  EndIf
  
  ; check if a menu callback has been created for this windowid
  found = 0
  ForEach menuCallback()
    If menuCallback()\WindowID = WindowID
      found = -1
      Break
    EndIf
  Next
  
  ; if menu call back hasnt been created then create one
  If found = 0
    ProGUIOldCallBack = SetWindowLongPtr_(WindowID, #GWLP_WNDPROC, @MyWindowCallback())
    LastElement(menuCallback())
    AddElement(menuCallback())
    menuCallback()\WindowID = WindowID
    menuCallback()\callback = @MyWindowCallback()
    menuCallback()\oldCallback = ProGUIOldCallBack
  EndIf
  
  ; create hook to intercept creation of new windows for popup menus
  If WindowHook = 0
    threadId = GetWindowThreadProcessId_(WindowID, 0)
    WindowHook = SetWindowsHookEx_(#WH_CALLWNDPROC, @CallWndProcHook(), 0, threadId)
  EndIf
  
  ; create hook to handle keyboard navigation
  If KeyboardHook = 0
    threadId = GetWindowThreadProcessId_(WindowID, 0)
    KeyboardHook = SetWindowsHookEx_(#WH_KEYBOARD, @KeyboardHook(), 0, threadId)
  EndIf
  
  ; check if currentMenuEXFont has been set
  If currentMenuEXFont = 0
    metrics.NONCLIENTMETRICS
    metrics\cbSize = SizeOf(NONCLIENTMETRICS)
    
    SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
    currentMenuEXFont = CreateFontIndirect_(metrics\lfMenuFont)
  EndIf
  
  ForEach menuex()
    If menuex()\id = menu Or menuex()\popupid = menu
      
      *thisMenuEx = @menuex()
      
      ; makesure the menu has at least one item
      found = #False
      ForEach itemex()
        If itemex()\menuex = @menuex()
          found = #True
          Break
        EndIf
      Next
      If found = #False
        UnlockMutex(menuMutex)
        ProcedureReturn 0
      EndIf
      
      menuWindow = 0
      menuTitleOffset = 0
      menuTitleVOffset = 0
      menuTitleWidth = 0
      subMenuActive = 0
      lastSubMenu = 0
      menuOldFocus = GetFocus_()
      menuWindowWidth = CalcMenuItemWidth(menuex()\popupid)
      menuex()\measuredWidth = menuWindowWidth
      menuex()\measuredHeight = CalcMenuItemHeight(menuex()\popupid)
      menuHandle = menuex()\popupid
      menuExHandle = @menuex()
      
      menuex()\root = #True
      menuWindowXpos = x
      
      ; find nearest display monitor to window
      prc.RECT
      prc\left = x
      prc\top = y
      prc\right = prc\left
      prc\bottom = prc\top
      hmonitor = MonitorFromRect_(@prc, #MONITOR_DEFAULTTONEAREST)
      minfo.MONITORINFO
      minfo\cbSize = SizeOf(MONITORINFO)
      GetMonitorInfo_(hmonitor, @minfo)
      menuPositionOffset = 0
      If x+menuWindowWidth+5 > minfo\rcWork\right
        menuWindowXpos = (minfo\rcWork\right-menuWindowWidth)-5 ; store the predicted x pos of menu window for use with title dropshadow
        menuPositionOffset = (x+menuWindowWidth)-minfo\rcWork\right+6
        x = menuWindowXpos
      EndIf
      
      threadId = GetWindowThreadProcessId_(WindowID, 0)
      menuHook = SetWindowsHookEx_(#WH_MSGFILTER, @miniMsgHook(), 0, threadId)
      menuMouseHook = SetWindowsHookEx_(#WH_MOUSE_LL, @miniMouseHook(), 0, 0)
      UnlockMutex(menuMutex)
      TrackPopupMenuEx_(menuex()\popupid, #TPM_VERTICAL, x, y, WindowID, 0)
      UnhookWindowsHookEx_(menuMouseHook)
      UnhookWindowsHookEx_(menuHook)
      LockMutex(menuMutex)
      ChangeCurrentElement(menuex(), *thisMenuEx)
      menuHandle = 0
      menuExHandle = 0
      
      menuHandle = 0
      menuex()\active = 0
      menuActive = 0
      dropdownActive = 0
      menuDraw = 0
      menuex()\root = #False
      menuKeyboardActive = #False
      If menuOldFocus <> 0
        SetFocus_(menuOldFocus)
        menuOldFocus = 0
      EndIf
      
      UnlockMutex(menuMutex)
      ProcedureReturn #True
    EndIf
  Next
  
  UnlockMutex(menuMutex)
  ProcedureReturn 0
EndProcedure

ProcedureDLL MenuExF10Disable(disable.b)
  
  menuExF10Disable = disable
  
EndProcedure

ProcedureDLL MenuExAutoHotKeyDisable(disable.b)
  
  menuExAutoHotKeyDisable = disable
  
EndProcedure

Procedure resetMenuMetrics(menu.i)  ; windows handle
  
  If IsMenu_(menu) <> 0
    items = GetMenuItemCount_(menu)
    If items <> -1
      
      ; force WM_MEASUREITEM
      minfo.MENUITEMINFO_Fixed
      minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
      minfo\fMask = #MIIM_BITMAP
      
      UnlockMutex(menuMutex)
      For n = 0 To items-1
        SetMenuItemInfo_(menu, n, #True, @minfo)
      Next
      LockMutex(menuMutex)
      
      updateDefaultDisabledImages(menu, 2)
      
    EndIf
    ProcedureReturn #True
  EndIf

  ProcedureReturn 0
EndProcedure

ProcedureDLL SetMenuExStyle(menu.i, style.l) ; sets the rendering style of a menuEx
  
  macro_protectCommand()
  
  If style = #UISTYLE_OFFICE2003
    style = 6
  EndIf
  
  LockMutex(menuMutex)
  
  ForEach menuex()
    If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
      
      menu = menuex()\popupid
      If menuex()\singleMenu = 0
        toolbarID = menuex()\toolbarID
        found = -1
      Else
        found = -2
      EndIf
      Break
      
    EndIf
  Next
  
  If found = -1
    ForEach menuex()
      If menuex()\toolbarID = toolbarID
        menuex()\style = style
        menuex()\bufferWidth = 0
        menuex()\bufferHeight = 0
        resetMenuMetrics(menuex()\popupid)
      EndIf
    Next
    resizeToolbar(toolbarID)
    UnlockMutex(menuMutex)
    ProcedureReturn #True
  ElseIf found = -2
    ForEach menuex()
      If menuex()\popupid = menu
        menuex()\style = style
        menuex()\bufferWidth = 0
        menuex()\bufferHeight = 0
        resetMenuMetrics(menuex()\popupid)
      EndIf
    Next
    UnlockMutex(menuMutex)
    ProcedureReturn #True
  EndIf
  
  UnlockMutex(menuMutex)
  ProcedureReturn 0
EndProcedure

ProcedureDLL MenuTitleEx(title.s) ; Creates a title on menu bar
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  ; check that there is a current id and it exists
  found = 0
  If currentMenuEx <> -1
    ForEach menuex()
      If menuex()\id = currentMenuEx
        toolbarID = menuex()\toolbarID
        WindowID = menuex()\WindowID
        style = menuex()\style
        
        If menuex()\popupid = -1 And menuex()\buttonID = -1
          DeleteElement(menuex())
        EndIf
        
        found = -1
        Break
      EndIf
    Next
  EndIf
  
  ; exit if it is not found
  If found = 0
    UnlockMutex(menuMutex)
    ProcedureReturn 0
  EndIf
  
  
  popupid = CreatePopupMenu(#PB_Any)
  If popupid = 0
    UnlockMutex(menuMutex)
    ProcedureReturn 0 ; exit if popup couldnt be created
  EndIf
  
  ; set the menu to not modal
  ;minfo.MENUINFO
  ;minfo\cbSize = SizeOf(MENUINFO)
  ;minfo\fMask = #MIM_STYLE
  ;minfo\dwStyle = #MNS_MODELESS
  ;SetMenuInfo_(MenuID(popupid), @minfo)
  
  buttonID = ToolBarButtonEx(#ProGUI_Any, title, #BTNS_DROPDOWN)
  If buttonID = -1
    UnlockMutex(menuMutex)
    ProcedureReturn 0 ; exit if error creating toolbar button
  EndIf
  
  AddElement(menuex())
  menuex()\id = currentMenuEx
  menuex()\WindowID = WindowID
  menuex()\toolbarID = toolbarID
  menuex()\popupid = MenuID(popupid)
  menuex()\purepopupid = popupid
  menuex()\buttonID = buttonID
  menuex()\style = style
  currentMenuTitleEX = menuex()\popupid
  
  UnlockMutex(menuMutex)
  
  hdc = CreateCompatibleDC_(0)
  SelectObject_(hdc, currentMenuEXFont)
  DrawText_(hdc, title, Len(title), @rec.RECT, #DT_SINGLELINE | #DT_CALCRECT)
  DeleteDC_(hdc)
  
  button.TBBUTTONINFO
  button\cbSize = SizeOf(TBBUTTONINFO)
  button\dwMask = #TBIF_SIZE
  button\cx = rec\right+#MENUEXPADX

  ; reset menu bar height if font too small
  If rec\bottom+#MENUEXPADY < #MENUEXMINHEIGHT
    rec\bottom = #MENUEXMINHEIGHT - #MENUEXPADY
  EndIf
  
  ; 2003 style
  If style = 6
    button\cx = button\cx - 2
    rec\bottom = rec\bottom - 3
  ; 2007 style
  ElseIf style = #UISTYLE_OFFICE2007
    button\cx = button\cx - 2
    rec\bottom = rec\bottom - 2
  EndIf
  
  SendMessage_(toolbarID, #TB_SETBUTTONSIZE, 0, MakeLong(0, rec\bottom+#MENUEXPADY))
  SendMessage_(toolbarID, #TB_SETBUTTONINFO, buttonID, @button)
  
EndProcedure


ProcedureDLL SetMenuExImageSize(width.l, height.l) ; sets the image dimensions for icons in menu
  
  macro_protectCommand()
  
  menuExItemIconWidth = width
  menuExItemIconHeight = height
EndProcedure


ProcedureDLL MenuItemEx(MenuItemID.l, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, submenu.i) ; Creates a menu item with an optional icon
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  ;check that there is a current id and it exists
  found = 0
  If currentMenuEx <> -1
    ForEach menuex()
      If menuex()\id = currentMenuEx And menuex()\popupid = currentMenuTitleEX
        menuex()\bufferWidth = 0
        menuex()\bufferHeight = 0
        found = -1
        Break
      EndIf
    Next
  EndIf
  
  ; exit if it is not found
  If found = 0
    UnlockMutex(menuMutex)
    ProcedureReturn 0
  EndIf
  
  ; handle #ProGUI_Any for menu item id
  If MenuItemID = #ProGUI_Any
    Repeat
      ; generate unique id
      MenuItemID = generateUniqueID_wordUnsigned()
      ; check that same id doesnt already exist
      found = 0
      thisMenuEx = @menuex()
      ForEach menuex()
        
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_ID
        If GetMenuItemInfo_(menuex()\popupid, MenuItemID, 0, @minfo) <> 0
          found = #True
          Break
        EndIf
        
      Next
      ChangeCurrentElement(menuex(), thisMenuEx)
    Until found = 0
    ProGUI_Any = #True
  EndIf
  
  minfo.MENUITEMINFO_Fixed
  minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
  If submenu = 0
    minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA|#MIIM_STRING
  Else  ; sub menu attached
    
    ; search for existing id if submenu is not a handle to a menu
    If IsMenu_(submenu) = 0
      thisMenuEx = @menuex()
      ForEach menuex()
        If menuex()\id = submenu
          submenu = menuex()\popupid
          Break
        EndIf
      Next
      ChangeCurrentElement(menuex(), thisMenuEx)
    EndIf
    
    minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA|#MIIM_SUBMENU|#MIIM_STRING
    minfo\hSubMenu = submenu
  EndIf
  minfo\fType = #MFT_OWNERDRAW
  minfo\wID = MenuItemID
  LastElement(itemex())
  AddElement(itemex())
  itemex()\text = text
  minfo\dwItemData = @itemex()
  minfo\dwTypeData = @text
  minfo\cch = Len(text)
  
  itemex()\menuex = @menuex()
  itemex()\popupid = menuex()\popupid
  itemex()\pos = GetMenuItemCount_(menuex()\popupid)
  itemex()\imageWidth = menuExItemIconWidth
  itemex()\imageHeight = menuExItemIconHeight
  itemex()\defDisabledStyle = menuex()\style
  
  ; add automatic shortcut if found in text
  autoHotKey(menuex()\WindowID, MenuItemID, text)
  
  If normalImageID <> 0
    
    menuIcons = ImageList_Create_(menuExItemIconWidth, menuExItemIconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
    If menuIcons <> 0
      
      itemex()\ImageList = menuIcons
      error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
      If error = -1
        error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
      EndIf
      If error <> -1
        itemex()\normal = -1
      EndIf
      
      If hotImageID <> 0
        error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hotImageID)
        If error = -1
          error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(hotImageID))
        EndIf
        
        If error <> -1
          itemex()\hot = -1
        Else
          error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
          If error = -1
            error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
          EndIf
        EndIf
      Else
        error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
        If error = -1
          error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
        EndIf
      EndIf
      
      If disabledImageID <> 0
        error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImageID)
        If error = -1
          error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(disabledImageID))
        EndIf
        If error <> -1
          itemex()\disabled = -1
        Else
          disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
          error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
          DestroyIcon_(disabledImg)
        EndIf
      Else
        disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
        error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
        DestroyIcon_(disabledImg)
      EndIf
    EndIf
      
  EndIf
  
  popupid = menuex()\popupid
  UnlockMutex(menuMutex)
  If InsertMenuItem_(popupid, -1, #True, @minfo) = 0
    debuglog("failed on: "+text)
    ProcedureReturn #False
  EndIf
  
  If ProGUI_Any = #True
    ProcedureReturn MenuItemID
  EndIf
  
  ProcedureReturn #True
  
EndProcedure

ProcedureDLL MenuBarEx()
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  ;check that there is a current id and it exists
  found = 0
  If currentMenuEx <> -1
    ForEach menuex()
      If menuex()\id = currentMenuEx And menuex()\popupid = currentMenuTitleEX
        menuex()\bufferWidth = 0
        menuex()\bufferHeight = 0
        found = -1
        Break
      EndIf
    Next
  EndIf
  
  ; exit if it is not found
  If found = 0
    UnlockMutex(menuMutex)
    ProcedureReturn 0
  EndIf
  
  minfo.MENUITEMINFO_Fixed
  minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
  minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA
  minfo\fType = #MFT_OWNERDRAW
  minfo\wID = 0
  LastElement(itemex())
  AddElement(itemex())
  itemex()\text = ""
  minfo\dwItemData = @itemex()
  
  itemex()\menuex = @menuex()
  itemex()\popupid = menuex()\popupid
  itemex()\pos = GetMenuItemCount_(menuex()\popupid)
  itemex()\imageWidth = menuExItemIconWidth
  itemex()\imageHeight = menuExItemIconHeight
  
  popupid = menuex()\popupid
  UnlockMutex(menuMutex)
  InsertMenuItem_(popupid, -1, #True, @minfo)
  
EndProcedure

ProcedureDLL SetMenuItemEx(menu.i, itemID.l, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, submenu.i) ; Sets a menu item with optional image data
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  ;check that menu exists, search by id or handle
  found = 0
  ForEach menuex()
    If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
      
      For n = 0 To count
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_ID
        If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) <> 0
          found = #True
          Break 2
        EndIf
      Next
      
    EndIf
  Next
  
  If found = #True
    
    minfo.MENUITEMINFO_Fixed
    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    minfo\fMask = #MIIM_DATA|#MIIM_STATE
    If GetMenuItemInfo_(menuex()\popupid, itemID, 0, @minfo) = 0
      UnlockMutex(menuMutex)
      ProcedureReturn #False
    EndIf
    ChangeCurrentElement(itemex(), minfo\dwItemData)
    
    minfo.MENUITEMINFO_Fixed
    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    If submenu = 0
      minfo\fMask = #MIIM_STRING|#MIIM_BITMAP
    Else  ; sub menu attached
      
      ; search for existing id if submenu is not a handle to a menu
      If IsMenu_(submenu) = 0
        thisMenuEx = @menuex()
        ForEach menuex()
          If menuex()\id = submenu
            submenu = menuex()\popupid
            Break
          EndIf
        Next
        ChangeCurrentElement(menuex(), thisMenuEx)
      EndIf
      
      minfo\fMask = #MIIM_SUBMENU|#MIIM_BITMAP|#MIIM_STRING
      minfo\hSubMenu = submenu
    EndIf
    minfo\dwTypeData = @text
    minfo\cch = Len(text)
    
    ; remove old automatic shortcut if found in old text
    autoHotKey(menuex()\WindowID, itemID, itemex()\text)
    ; add automatic shortcut if found in text
    autoHotKey(menuex()\WindowID, itemID, text)
    
    itemex()\text = text
    
    If normalImageID <> 0
      
      itemex()\imageWidth = menuExItemIconWidth
      itemex()\imageHeight = menuExItemIconHeight
      
      ImageList_Destroy_(itemex()\ImageList)
      
      menuIcons = ImageList_Create_(menuExItemIconWidth, menuExItemIconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
      If menuIcons <> 0
        itemex()\ImageList = menuIcons
        error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
        If error = -1
          error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
        EndIf
        If error <> -1
          itemex()\normal = -1
        EndIf
        
        If hotImageID <> 0
          error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hotImageID)
          If error = -1
            error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(hotImageID))
          EndIf
          
          If error <> -1
            itemex()\hot = -1
          Else
            error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
            If error = -1
              error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
            EndIf
          EndIf
        Else
          error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
          If error = -1
            error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
          EndIf
        EndIf
        
        If disabledImageID <> 0
          error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImageID)
          If error = -1
            error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(disabledImageID))
          EndIf
          If error <> -1
            itemex()\disabled = -1
          Else
            disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
            error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
            DestroyIcon_(disabledImg)
          EndIf
        Else
          disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
          error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
          DestroyIcon_(disabledImg)
        EndIf
      EndIf
      
    EndIf
    
    old = GetSubMenu_(menuex()\popupid, itemex()\pos)
    If old <> 0 And submenu <> 0
      popupid = menuex()\popupid
      *thisMenuEx = @menuex()
      *thisItemEx = @itemex()
      UnlockMutex(menuMutex)
      RemoveMenu_(popupid, itemID, 0)
      LockMutex(menuMutex)
      ChangeCurrentElement(menuex(), *thisMenuEx)
      ChangeCurrentElement(itemex(), *thisItemEx)
      minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA|#MIIM_SUBMENU|#MIIM_STRING
      minfo\hSubMenu = submenu
      minfo\fType = #MFT_OWNERDRAW
      minfo\wID = itemID
      minfo\dwItemData = @itemex()
      minfo\dwTypeData = @text
      minfo\cch = Len(text)
      pos = itemex()\pos
      UnlockMutex(menuMutex)
      InsertMenuItem_(popupid, pos, #True, @minfo)
      LockMutex(menuMutex)
    Else
      popupid = menuex()\popupid
      *thisMenuEx = @menuex()
      *thisItemEx = @itemex()
      UnlockMutex(menuMutex)
      SetMenuItemInfo_(popupid, itemID, 0, @minfo)
      LockMutex(menuMutex)
      ChangeCurrentElement(menuex(), *thisMenuEx)
      ChangeCurrentElement(itemex(), *thisItemEx)
    EndIf
    
    menuex()\bufferWidth = 0
    menuex()\bufferHeight = 0
    
    UnlockMutex(menuMutex)
    ProcedureReturn #True
  EndIf
  
  UnlockMutex(menuMutex)
  ProcedureReturn 0
EndProcedure

ProcedureDLL RemoveMenuItemEx(menu.i, itemID.l, byPosition.b) ; Removes a menu item from menuEx
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  ;check that menu exists, search by id or handle
  found = 0
  ForEach menuex()
    If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
      
      If byPosition = #False
        count = GetMenuItemCount_(menuex()\popupid)
        For n = 0 To count
          minfo.MENUITEMINFO_Fixed
          minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
          minfo\fMask = #MIIM_ID
          If GetMenuItemInfo_(menuex()\popupid, n, #True, @minfo) <> 0
            If minfo\wID = itemID
              found = #True
              Break 2
            EndIf
          EndIf
        Next
      Else
        n = itemID
        found = #True
        Break
      EndIf
      
    EndIf
  Next
  
  ; free associated itemEx and images
  If found = #True
    mnfo.MENUITEMINFO_Fixed
    mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    mnfo\fMask = #MIIM_DATA	
    If GetMenuItemInfo_(menuex()\popupid, n, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
      ImageList_Destroy_(itemex()\ImageList)
      
      *thisMenuEx = @menuex()
      *thisItemEx = @itemex()
      popupid = menuex()\popupid
      UnlockMutex(menuMutex)
      success = RemoveMenu_(popupid, n, #MF_BYPOSITION)
      LockMutex(menuMutex)
      ChangeCurrentElement(menuex(), *thisMenuEx)
      ChangeCurrentElement(itemex(), *thisItemEx)
      
      ; remove automatic shortcut if found in text
      autoHotKey(menuex()\WindowID, -1, itemex()\text)
      
      DeleteElement(itemex())
      
      ; update new positions of items
      count = GetMenuItemCount_(menuex()\popupid)
      mnfo.MENUITEMINFO_Fixed
      mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
      mnfo\fMask = #MIIM_DATA	
      For z = 0 To count-1
        If GetMenuItemInfo_(menuex()\popupid, z, #True, @mnfo) <> 0
          ChangeCurrentElement(itemex(), mnfo\dwItemData)
          itemex()\pos = z
        EndIf
      Next
      
      menuex()\bufferWidth = 0
      menuex()\bufferHeight = 0
      
      UnlockMutex(menuMutex)
      ProcedureReturn success
    Else
      UnlockMutex(menuMutex)
      ProcedureReturn 0
    EndIf
  EndIf
  
  UnlockMutex(menuMutex)
  ProcedureReturn 0
EndProcedure

ProcedureDLL InsertMenuItemEx(menu.i, Position.l, newItemID.l, text.s, normalImageID.i, hotImageID.i, disabledImageID.i, submenu.i) ; Inserts a new menu item into a menuEx
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  ;check that menu exists, search by id or handle
  found = 0
  ForEach menuex()
    If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
      
      found = -1
      Break
      
    EndIf
  Next
  
  If found = -1
    
    ; detect special scroll item mode from submenu
    If submenu < 0
      scroll = submenu
      submenu = 0
    EndIf
    
    minfo.MENUITEMINFO_Fixed
    minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
    If submenu = 0
      minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA|#MIIM_STRING
    Else  ; sub menu attached
      
      ; search for existing id if submenu is not a handle to a menu
      If IsMenu_(submenu) = 0
        thisMenuEx = @menuex()
        ForEach menuex()
          If menuex()\id = submenu
            submenu = menuex()\popupid
            Break
          EndIf
        Next
        ChangeCurrentElement(menuex(), thisMenuEx)
      EndIf
      
      minfo\fMask = #MIIM_ID|#MIIM_FTYPE|#MIIM_DATA|#MIIM_SUBMENU|#MIIM_STRING
      minfo\hSubMenu = submenu
    EndIf
    minfo\fType = #MFT_OWNERDRAW
    minfo\wID = newItemID
    LastElement(itemex())
    AddElement(itemex())
    minfo\dwItemData = @itemex()
    minfo\dwTypeData = @text
    minfo\cch = Len(text)
    itemex()\text = text
    itemex()\menuex = @menuex()
    itemex()\popupid = menuex()\popupid
    If scroll < 0
      itemex()\scroll = scroll
    EndIf
    If Position <= -1
      itemex()\pos = GetMenuItemCount_(menuex()\popupid)
    Else
      itemex()\pos = Position
    EndIf
    itemex()\imageWidth = menuExItemIconWidth
    itemex()\imageHeight = menuExItemIconHeight
    
    ; add automatic shortcut if found in text
    autoHotKey(menuex()\WindowID, MenuItemID, text)
    
    If normalImageID <> 0
      
      menuIcons = ImageList_Create_(menuExItemIconWidth, menuExItemIconHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
      If menuIcons <> 0
        itemex()\ImageList = menuIcons
        error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
        If error = -1
          error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
        EndIf
        If error <> -1
          itemex()\normal = -1
        EndIf
        
        If hotImageID <> 0
          error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hotImageID)
          If error = -1
            error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(hotImageID))
          EndIf
          
          If error <> -1
            itemex()\hot = -1
          Else
            error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
            If error = -1
              error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
            EndIf
          EndIf
        Else
          error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, normalImageID)
          If error = -1
            error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(normalImageID))
          EndIf
        EndIf
        
        If disabledImageID <> 0
          error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImageID)
          If error = -1
            error = ImageList_ReplaceIcon_(itemex()\ImageList, -1, hBitmap_to_hIcon(disabledImageID))
          EndIf
          If error <> -1
            itemex()\disabled = -1
          Else
            disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
            error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
            DestroyIcon_(disabledImg)
          EndIf
        Else
          disabledImg = defaultDisabledImage(normalImageID, menuex()\style)
          error.l = ImageList_ReplaceIcon_(itemex()\ImageList, -1, disabledImg)
          DestroyIcon_(disabledImg)
        EndIf
      EndIf
    
    EndIf
    
    popupid = menuex()\popupid
    
    *thisMenuEx = @menuex()
    *thisItemEx = @itemex()
    UnlockMutex(menuMutex)
    ret = InsertMenuItem_(popupid, Position, #True, @minfo)
    LockMutex(menuMutex)
    ChangeCurrentElement(menuex(), *thisMenuEx)
    ChangeCurrentElement(itemex(), *thisItemEx)
    If ret <> 0
      If Position > -1
        thisItemEx = @itemex()
        
        ; update new positions of items
        count = GetMenuItemCount_(menuex()\popupid)
        mnfo.MENUITEMINFO_Fixed
        mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        mnfo\fMask = #MIIM_DATA	
        For n = 0 To count-1
          If GetMenuItemInfo_(menuex()\popupid, n, #True, @mnfo) <> 0
            ChangeCurrentElement(itemex(), mnfo\dwItemData)
            itemex()\pos = n
          EndIf
        Next
        
        ChangeCurrentElement(itemex(), thisItemEx)
      EndIf
      menuex()\bufferWidth = 0
      menuex()\bufferHeight = 0
      
      UnlockMutex(menuMutex)
      ProcedureReturn #True
    EndIf
    
    UnlockMutex(menuMutex)
    ProcedureReturn 0
  EndIf
  
  UnlockMutex(menuMutex)
  ProcedureReturn 0
EndProcedure


ProcedureDLL.s GetMenuItemExText(menu.i, itemID.l)
  
  macro_protectCommand()
  
  LockMutex(menuMutex)
  
  ;check that menu exists, search by id or handle
  found = 0
  ForEach menuex()
    If menuex()\id = menu Or menuex()\popupid = menu Or menuex()\toolbarID = menu
      
      ForEach itemex()
        
        minfo.MENUITEMINFO_Fixed
        minfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
        minfo\fMask = #MIIM_ID
        GetMenuItemInfo_(menuex()\popupid, itemex()\pos, #True, @minfo)

        If itemex()\popupid = menuex()\popupid And minfo\wID = itemID
          found = #True
          Break 2
        EndIf
      Next
      
    EndIf
  Next
  
  If found = #True
    ReturnString$ = itemex()\text
    debuglog(ReturnString$)
  Else
    ReturnString$ = ""
  EndIf
  
  UnlockMutex(menuMutex)
  ProcedureReturn ReturnString$ 
EndProcedure

