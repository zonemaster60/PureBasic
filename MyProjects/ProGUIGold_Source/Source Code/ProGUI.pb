EndProcedure

ProcedureDLL DisableToolbarExButton(toolbar.i, buttonID.l, state)
  
  macro_protectCommand()
  
  ; find toolbar handle
  found = 0
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      ; find button id
      found = 0
      ForEach toolbarExButton()
        If toolbarExButton()\id = buttonID
          found = -1
          Break
        EndIf
      Next
      
      Break 
    EndIf
  Next
  
  If found = -1
    ProcedureReturn DisableToolBarButton(toolbarEx()\id, buttonID, state)
  EndIf
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL SelectToolbarExButton(toolbar.i, buttonID.l, state.b)
  
  macro_protectCommand()
  
  ; find toolbar handle
  found = 0
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      ; find button id
      found = 0
      ForEach toolbarExButton()
        If toolbarExButton()\id = buttonID
          found = -1
          Break
        EndIf
      Next
      
      Break 
    EndIf
  Next
  
  If found = -1
    If state <> 0
      state = #True
    EndIf
    error = SendMessage_(toolbarEx()\Handle, #TB_CHECKBUTTON, toolbarExButton()\id, state)
    ProcedureReturn error
  EndIf
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL ChangeToolbarExButton(toolbar.i, buttonID.l, text.s, normalImageID.i, hotImageID.i, disabledImageID.i)
  
  macro_protectCommand()
  
  ftext.s = text
  
  ; find toolbar handle
  found = 0
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      ; find button id
      ForEach toolbarExButton()
        If toolbarExButton()\id = buttonID
          
          If normalImageID = 0
            normalImageID = nullicon
          EndIf
          If hotImageID = 0
            hotImageID = nullicon
          EndIf
          If disabledImageID = 0
            If normalImageID <> nullicon
              disabledImageID = defaultDisabledImage(normalImageID, toolbarEx()\UIStyle)
              defaultDisabled = #True
            Else
              disabledImageID = nullicon
            EndIf
          EndIf

          index = SendMessage_(toolbarEx()\Handle, #TB_COMMANDTOINDEX, buttonID, 0)

          If normalImageID <> -1
            imList = SendMessage_(toolbarEx()\Handle, #TB_GETIMAGELIST,0,0)
            error.l = ImageList_ReplaceIcon_(imList, index, normalImageID)
            If error = -1
              ImageList_ReplaceIcon_(imList, index, hBitmap_to_hIcon(normalImageID))
            EndIf
          EndIf
          
          If hotImageID <> -1
            imList = SendMessage_(toolbarEx()\Handle, #TB_GETHOTIMAGELIST,0,0)
            error.l = ImageList_ReplaceIcon_(imList, index, hotImageID)
            If error = -1
              ImageList_ReplaceIcon_(imList, index, hBitmap_to_hIcon(hotImageID))
            EndIf
          EndIf
          
          If disabledImageID <> -1
            imList = SendMessage_(toolbarEx()\Handle, #TB_GETDISABLEDIMAGELIST,0,0)
            error.l = ImageList_ReplaceIcon_(imList, index, disabledImageID)
            If error = -1
              ImageList_ReplaceIcon_(imList, index, hBitmap_to_hIcon(disabledImageID))
            EndIf
          EndIf
          
          If defaultDisabled = #True
            DestroyIcon_(disabledImageID)
            toolbarExButton()\defDisabledImage = #True
            toolbarExButton()\defDisabledStyle = toolbarEx()\UIStyle
          Else
            toolbarExButton()\defDisabledImage = #False
            toolbarExButton()\defDisabledStyle = 0
          EndIf
          
          If FindString(text, "\", 1) > 0
            rc.RECT
            hdc = CreateCompatibleDC_(0)
            text = renderText(hdc, text, @rc, 0, #DT_CALCRECT|#RTXT_RETURNSTRING)
            DeleteDC_(hdc)
          EndIf
          
          toolbarExButton()\text = ftext
          
          btn.TBBUTTONINFO
          btn\dwMask = #TBIF_TEXT
          btn\pszText = @text
          btn\cchText = Len(text)
          btn\cbSize = SizeOf(btn)
          suc = SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONINFO, buttonID, @btn)
          
          ProcedureReturn #True
        EndIf
      Next
      
      Break 
    EndIf
  Next
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL RemoveToolBarExButton(toolbar.i, buttonID.l, byPosition.b) ; Removes a button from a ToolBarEx
  
  macro_protectCommand()

  ;search for toolbar by id or handle
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      If byPosition = #True
        If SendMessage_(toolbarEx()\Handle, #TB_GETBUTTON, buttonID, @tbinfo.TBBUTTON) = #False
          ProcedureReturn #False
        EndIf
        buttonID = tbinfo\idCommand
      EndIf
      
      ;remove button associated with toolbar
      ForEach toolbarExButton()
        If toolbarExButton()\toolbarID = toolbarEx()\id And toolbarExButton()\id = buttonID
          
          ;remove tooltip if exists
          ForEach toolbartip()
            If toolbartip()\id = toolbarExButton()\id
              DeleteElement(toolbartip())
              Break
            EndIf
          Next
          
          index = SendMessage_(toolbarEx()\Handle, #TB_COMMANDTOINDEX, buttonID, 0)
          success = SendMessage_(toolbarEx()\Handle, #TB_DELETEBUTTON, index, 0)
          
          If success = #True
            ImageList_Remove_(toolbarEx()\normalImageList, index)
            ImageList_Remove_(toolbarEx()\disabledImageList, index)
            ImageList_Remove_(toolbarEx()\hotImageList, index)
            
            ; if button contains a gadget then hide and re-parent gadget window to root window
            If toolbarExButton()\gadget <> 0
              
              ShowWindow_(toolbarExButton()\gadget, #SW_HIDE)
              SetParent_(toolbarExButton()\gadget, GetAncestor_(toolbarExButton()\gadget, #GA_ROOT))
            
            EndIf
            
            DeleteElement(toolbarExButton())
          EndIf
          
          ; resize and position any buttons that contain a gadget in this toolbarEx
          updateToolBarExButtonGadgets()
          
          ProcedureReturn success
        EndIf
      Next
    
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL HideToolBarExButton(toolbar.i, buttonID.l, hide.b) ; Hides a button in a ToolBarEx, hide = True/False
  
  macro_protectCommand()

  ;search for toolbar by id or handle
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      ;find button
      ForEach toolbarExButton()
        If toolbarExButton()\toolbarID = toolbarEx()\id And toolbarExButton()\id = buttonID
          
          success = SendMessage_(toolbarEx()\Handle, #TB_HIDEBUTTON, buttonID, LOWORD(hide))
          
          ; if button contains a gadget then hide/show gadget window
          If success = #True And toolbarExButton()\gadget <> 0
             
            If hide <> 0
              ShowWindow_(toolbarExButton()\gadget, #SW_HIDE)
            Else
              ShowWindow_(toolbarExButton()\gadget, #SW_SHOW)
            EndIf
            
          EndIf
          
          ; resize and position any buttons that contain a gadget in this toolbarEx
          updateToolBarExButtonGadgets()
          
          ProcedureReturn success
        EndIf
      Next
    
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL ToolBarExToolTip(id.i, buttonID.l, text.s) ; Associates a tooltip with a toolbar button.
  
  macro_protectCommand()
  
  ; find toolbar handle
  ForEach toolbarEx()
    If toolbarEx()\id = id Or toolbarEx()\Handle = id
      
      ; check if a tooltip already exists for the id and if so replace associated text
      ForEach toolbartip()
        If toolbartip()\id = buttonID
          toolbartip()\text = text
          ProcedureReturn #True
        EndIf
      Next
      
      AddElement(toolbartip())
      toolbartip()\id = buttonID
      toolbartip()\text = text
      
      ProcedureReturn #True
      
    EndIf
  Next
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL ToolBarExToolTipDelay(id.i, initial.l, autopop.l, reshow.l)
  
  macro_protectCommand()
  
  ; find toolbar handle
  ForEach toolbarEx()
    If toolbarEx()\id = id Or toolbarEx()\Handle = id
      
      tooltip = SendMessage_(toolbarEx()\Handle, #TB_GETTOOLTIPS, 0, 0)
      If initial <> 0
        SendMessage_(tooltip, #TTM_SETDELAYTIME, #TTDT_INITIAL, MakeLong(initial, 0))
      EndIf
      If autopop <> 0
        SendMessage_(tooltip, #TTM_SETDELAYTIME, #TTDT_AUTOPOP, MakeLong(autopop, 0))
      EndIf
      If reshow <> 0
        SendMessage_(tooltip, #TTM_SETDELAYTIME, #TTDT_RESHOW, MakeLong(reshow, 0))
      EndIf
      
      ProcedureReturn #True
      
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL ToolBarExID(id.l)  ; Returns Windows handle of ToolBarEx
  
  ; find toolbar handle
  ForEach toolbarEx()
    If toolbarEx()\id = id
      
      ProcedureReturn toolbarEx()\Handle
      
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL ToolBarExGadgetID(toolbar.i, ButtonID.l)  ; returns the Windows Handle (HWND) of a ToolBarEx gadget/control
  
  ; find toolbar handle
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      ; find button
      ForEach toolbarExButton()
        If toolbarExButton()\toolbarExHandle = toolbarEx()\handle And toolbarExButton()\id = ButtonID
          
          ProcedureReturn toolbarExButton()\gadget
          
        EndIf
      Next
      
    EndIf
  Next
  
  ProcedureReturn #False
EndProcedure

ProcedureDLL ToolBarExButtonWidth(toolbar.i, ButtonID.l)  ; returns width of a ToolBarEx button
  
  ; find toolbar handle
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      tbinfo.TBBUTTONINFO
      tbinfo\cbSize = SizeOf(TBBUTTONINFO)
      tbinfo\dwMask = #TBIF_SIZE
      If SendMessage_(toolbarEx()\Handle, #TB_GETBUTTONINFO, ButtonID, @tbinfo) <> -1
        
        ProcedureReturn tbinfo\cx
        
      Else 
        ProcedureReturn #False
      EndIf
      
    EndIf
  Next
  
  ProcedureReturn #False
EndProcedure

ProcedureDLL SetToolBarExButtonWidth(toolbar.i, ButtonID.l, Width.l)  ; sets the width of a ToolBarEx button
  
  macro_protectCommand()
  
  ; find toolbar handle
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      ; find button
      ForEach toolbarExButton()
        If toolbarExButton()\toolbarExHandle = toolbarEx()\handle And toolbarExButton()\id = ButtonID
          Break
        EndIf
      Next
        
      tbinfo.TBBUTTONINFO
      tbinfo\cbSize = SizeOf(TBBUTTONINFO)
      tbinfo\dwMask = #TBIF_SIZE
      tbinfo\cx = Width+toolbarExButton()\gadgetPad\left+toolbarExButton()\gadgetPad\right
      If SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONINFO, ButtonID, @tbinfo) <> 0
        
        ; resize and position any buttons that contain a gadget in this toolbarEx
        updateToolBarExButtonGadgets()
        
        ProcedureReturn #True
      Else 
        ProcedureReturn #False
      EndIf
      
    EndIf
  Next
  
  ProcedureReturn #False
EndProcedure


ProcedureDLL ToolBarExHeight(toolbar.i)  ; returns height of ToolBarEx
  
  ; find toolbar handle
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      height = SendMessage_(toolbarEx()\Handle, #TB_GETBUTTONSIZE, 0,0)
      height = (height>>16)
      ProcedureReturn height
      
    EndIf
  Next
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL SetToolBarExHeight(toolbar.i, Height.l)  ; sets the height in pixels of all the buttons in a ToolBarEx
  
  macro_protectCommand()
  
  ; find toolbar handle
  ForEach toolbarEx()
    If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
      
      success = SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONSIZE, 0,MakeLong(0, Height))
      If success = #True
        updateToolBarExButtonGadgets()
      EndIf
      ProcedureReturn success
      
    EndIf
  Next
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL DisableToolBarExButtonFade(toolbar.i) ; disables Windows Vista/Windows 7 fade animation
  
  macro_protectCommand()
  
  If OSVersion() >= #PB_OS_Windows_Vista
  
    ; find toolbar handle
    ForEach toolbarEx()
      If toolbarEx()\id = toolbar Or toolbarEx()\Handle = toolbar
        
        If XPthemeActive <> 0
          CallFunctionFast(*SetWindowTheme, toolbarEx()\Handle, @null.w, @null.w)
          
          ; if #UISTYLE_OFFICE2003/#UISTYLE_OFFICE2007 style then increase height of toolbar by 3 pixels
          If (toolbarEx()\UIStyle = #UISTYLE_OFFICE2003 Or toolbarEx()\UIStyle = #UISTYLE_OFFICE2007)
            Size = SendMessage_(toolbarEx()\Handle, #TB_GETBUTTONSIZE, 0, 0)
            width = (Size&$FFFF)
            height = (Size>> 16 & $FFFF)+3
            SendMessage_(toolbarEx()\Handle, #TB_SETBUTTONSIZE, 0, MakeLong(width, height))
            toolbarEx()\height = height
            
          EndIf
          
        EndIf
        
        ProcedureReturn #True
        
      EndIf
    Next
    
  EndIf
  
  ProcedureReturn #False
  
EndProcedure

;--
;- Rebar
;--
Procedure sendRebarUpdatedMsg(height)
  Static lheight
  
  If height = 0
    height = RebarHeight(rebarGadget()\Handle)
  EndIf
  
  If height <> lheight
    handle = rebarGadget()\Handle
    
    If rebarGadget()\UserCallback <> 0
      CallWindowProc_(rebarGadget()\UserCallback, handle, #REBAR_UPDATED, height, handle)
    EndIf
    
    ; send rebar update message to apps main window
    root = GetAncestor_(handle, #GA_ROOT)
    SendMessage_(root, #REBAR_UPDATED, height, handle)
    root = GetAncestor_(handle, #GA_PARENT)
    SendMessage_(root, #REBAR_UPDATED, height, handle)
    
    lheight = height
  EndIf
    
EndProcedure

Procedure UpdateRebarBackgrounds(*oldHBITMAP, *newHBITMAP, style.l)
  
  *oldRebarGadget = @rebarGadget()
  
  ForEach rebarGadget()
    If rebarGadget()\UIStyle = style
      
      rebargadget()\backgroundImage = *newHBITMAP
      
      SendMessage_(rebargadget()\Handle, #WM_SETREDRAW, #False, 0)
      ForEach rebarBand()
        If rebarBand()\Handle = rebarGadget()\Handle

          index = SendMessage_(rebargadget()\Handle, #RB_IDTOINDEX, rebarband()\wID, 0)
          
          binfo.REBARBANDINFO
          binfo\cbSize = SizeOf(REBARBANDINFO)
          binfo\fMask = #RBBIM_BACKGROUND|#RBBIM_STYLE
          
          SendMessage_(rebargadget()\Handle, #RB_GETBANDINFO, index, @binfo)
          If binfo\hbmBack = *oldHBITMAP Or binfo\hbmBack = 0 Or binfo\hbmBack = rebarGadget()\userBackgroundImage
            If *newHBITMAP = 0 And rebargadget()\userBackgroundImage <> 0
              binfo\hbmBack = rebargadget()\userBackgroundImage
            Else
              binfo\hbmBack = *newHBITMAP
            EndIf
            binfo\fStyle = binfo\fStyle | #RBBS_FIXEDBMP
            SendMessage_(rebargadget()\Handle, #RB_SETBANDINFO, index, @binfo)
          EndIf
          
        EndIf
      Next
      SendMessage_(rebargadget()\Handle, #WM_SETREDRAW, #True, 0)
      
    EndIf
  Next
  
  ChangeCurrentElement(RebarGadget(), *oldRebarGadget)
  
EndProcedure

Procedure RenderRebarBackgrounds(ForceRender.b) ; if ForceRender is set to #true then re-render all rebar backgrounds
  
  ; make sure there are some rebars
  If ListSize(rebarGadget()) = 0
    ProcedureReturn 0
  EndIf
  
  ; find largest desktop width if not already found
  desktops = ExamineDesktops()
  For n = 0 To desktops-1
    width = DesktopWidth(n)
    If LargestDesktopWidth < width
      LargestDesktopWidth = width
    EndIf
  Next
  
  width = LargestDesktopWidth+4 ; additional pixels for window border when maxed horizontally?
  height = 256
  
  ;/ #UISTYLE_OFFICE2003
  ; check if forcerender or not created or needs new size
  ; and create/render if so
  image = RebarBackBuffer_Office2003
  If (ForceRender = #True And IsImage(image)) Or image = -1 Or (IsImage(image) And (ImageWidth(image) < width Or ImageHeight(image) < height))
    
    debuglog("Office2003 background needs rendering!")
    
    oldImage = -1
    *oldHBITMAP = 0
    If IsImage(image)
      *oldHBITMAP = ImageID(image)
      oldImage = image
    EndIf
    
    image = CreateImage(#PB_Any, width, height)
    
    StartDrawing(ImageOutput(image))
      DrawingMode(#PB_2DDrawing_Gradient)
      BackColor(getMenuColourEx(6, #rebarBackground1, #returnRGBColour))
      FrontColor(getMenuColourEx(6, #rebarBackground2, #returnRGBColour))
      LinearGradient(0, 0, width/2, 0)
      Box(0, 0, width/2, height)
      DrawingMode(#PB_2DDrawing_Default)
      Box(width/2, 0, width/2, height)
    StopDrawing()
    
    RebarBackBuffer_Office2003 = image
    
    UpdateRebarBackgrounds(*oldHBITMAP, ImageID(image), #UISTYLE_OFFICE2003)
    
    If oldImage <> -1 And IsImage(oldImage)
      FreeImage(oldImage)
    EndIf
    
  EndIf
  
   ;/ #UISTYLE_OFFICE2007
  ; check if forcerender or not created or needs new size
  ; and create/render if so
  image = RebarBackBuffer_Office2007
  If (ForceRender = #True And IsImage(image)) Or image = -1 Or (IsImage(image) And (ImageWidth(image) < width Or ImageHeight(image) < height))
    
    debuglog("Office2007 background needs rendering!")
    
    oldImage = -1
    *oldHBITMAP = 0
    If IsImage(image)
      *oldHBITMAP = ImageID(image)
      oldImage = image
    EndIf
    
    image = CreateImage(#PB_Any, width, height)
    
    StartDrawing(ImageOutput(image))
      DrawingMode(#PB_2DDrawing_Gradient)
      BackColor(getMenuColourEx(#UISTYLE_OFFICE2007, #rebarBackground1, #returnRGBColour))
      FrontColor(getMenuColourEx(#UISTYLE_OFFICE2007, #rebarBackground2, #returnRGBColour))
      LinearGradient(0, 0, width/2, 0)
      Box(0, 0, width/2, height)
      DrawingMode(#PB_2DDrawing_Default)
      Box(width/2, 0, width/2, height)
    StopDrawing()
    
    RebarBackBuffer_Office2007 = image
    
    UpdateRebarBackgrounds(*oldHBITMAP, ImageID(image), #UISTYLE_OFFICE2007)
    
    If oldImage <> -1 And IsImage(oldImage)
      FreeImage(oldImage)
    EndIf
    
  EndIf

EndProcedure

ProcedureDLL CreateRebar(id.l, WindowID.i, backgroundImage.i, style.l, doublebuffer.b) ; Creates a rebar
  
  macro_protectCommand()
  
  If id <> #ProGUI_Any
    ; check that same id isnt in use
    ForEach rebarGadget()
      If rebarGadget()\id = id
        ProcedureReturn 0
      EndIf
    Next
  Else
    id = generateUniqueID()
    ProGUI_Any = #True
  EndIf
  
  rbi.REBARINFO
  rbBand.REBARBANDINFO
  rc.RECT
  icex.INITCOMMONCONTROLSEX
  
  icex\dwSize = SizeOf(INITCOMMONCONTROLSEX)
  icex\dwICC  = #ICC_COOL_CLASSES | #ICC_BAR_CLASSES
  
  InitCommonControlsEx_(@icex)
  
  ; automatically make sure #CCS_NODIVIDER is part of style
  If Not style & #CCS_NODIVIDER
    style = style | #CCS_NODIVIDER
  EndIf

  ; remove band borders if background image is set or #UISTYLE_OFFICE2003
  If backgroundImage <> 0 Or style & #UISTYLE_OFFICE2003
    ; cache whether bandborders is set
    If style & #RBS_BANDBORDERS
      bandBorders = #True
    EndIf
    style = style &~ #RBS_BANDBORDERS
  EndIf
  
  
  hwndRB = CreateWindowEx_(0, "ReBarWindow32", #Null, #WS_CHILD | #WS_VISIBLE | #WS_CLIPSIBLINGS | #WS_CLIPCHILDREN | style, 0, 0, 0, 0, WindowID, #Null,  GetModuleHandle_(0), #Null)
  If hwndRB <> 0
    
    LastElement(rebarGadget())
    AddElement(rebarGadget())
    rebarGadget()\id = id
    rebarGadget()\Handle = hwndRB
    rebarGadget()\WindowID = WindowID
    rebarGadget()\bandBorders = bandBorders
    currentRebarGadget = id
    
    If doublebuffer <> 0
      rebarGadget()\doublebuffer = -1
    EndIf
    
    ; remeber to error check image??
    If backgroundImage <> 0
      rebarGadget()\backgroundImage = backgroundImage
      rebarGadget()\userBackgroundImage = backgroundImage
      If XPthemeActive <> 0
        nulls.s = ""
        CallFunctionFast(*SetWindowTheme, hwndRB, @nulls, @nulls)
      EndIf
    EndIf
    
    ; check for new UI style flags
    If style & #UISTYLE_OFFICE2003
      rebarGadget()\UIStyle = #UISTYLE_OFFICE2003
    ElseIf style & #UISTYLE_OFFICE2007
      rebarGadget()\UIStyle = #UISTYLE_OFFICE2007
    EndIf
    
    ; check for new UI style flags
    If style & #UISTYLE_OFFICE2003
      
      debuglog("set up rebar #UISTYLE_OFFICE2003 background image buffer!")
      
      ; if RebarBackBuffer_Office2003 has already been created then assign to rebar
      If IsImage(RebarBackBuffer_Office2003)
        rebarGadget()\backgroundImage = ImageID(RebarBackBuffer_Office2003)
      Else
        RebarBackBuffer_Office2003 = -1 ; flag to create and render!
      EndIf
      RenderRebarBackgrounds(0)
      
      If XPthemeActive <> 0
        nulls.s = ""
        CallFunctionFast(*SetWindowTheme, hwndRB, @nulls, @nulls)
      EndIf
      
    ElseIf style & #UISTYLE_OFFICE2007
      
      debuglog("set up rebar #UISTYLE_OFFICE2007 background image buffer!")
      
      ; if RebarBackBuffer_Office2007 has already been created then assign to rebar
      If IsImage(RebarBackBuffer_Office2007)
        rebarGadget()\backgroundImage = ImageID(RebarBackBuffer_Office2007)
      Else
        RebarBackBuffer_Office2007 = -1 ; flag to create and render!
      EndIf
      RenderRebarBackgrounds(0)
      
      If XPthemeActive <> 0
        nulls.s = ""
        CallFunctionFast(*SetWindowTheme, hwndRB, @nulls, @nulls)
      EndIf
      
    EndIf
    
    rbi\cbSize = SizeOf(REBARINFO)
    rbi\fMask  = #RBIM_IMAGELIST
    rbi\himl = ImageList
    SendMessage_(hwndRB, #RB_SETBARINFO, 0, @rbi)
    rebarGadget()\rbBand\cbSize = SizeOf(REBARBANDINFO)
    rebarGadget()\rbBand\fMask  = #RBBIM_COLORS | #RBBIM_TEXT | #RBBIM_STYLE | #RBBIM_CHILD  | #RBBIM_CHILDSIZE | #RBBIM_SIZE | #RBBIM_BACKGROUND; | # RBS_AUTOSIZE
    rebarGadget()\rbBand\fStyle = #RBBS_CHILDEDGE;|#RBS_AUTOSIZE;|#RBBS_FIXEDSIZE

    If rebarMouseMoveHook = 0
      threadId = GetWindowThreadProcessId_(hwndRB, 0)
      rebarMouseMoveHook = SetWindowsHookEx_(#WH_MOUSE, @rebarMouseMoveHook(), 0, threadId)
    EndIf
    
    lbrush.LOGBRUSH
    lbrush\lbStyle = #BS_HOLLOW
    brush = CreateBrushIndirect_(lbrush)
    SetClassLongPtr_(hwndRB, #GCL_HBRBACKGROUND, brush)
    
    ; check if a main callback has been created for this windowid
    found = 0
    ForEach menuCallback()
      If menuCallback()\WindowID = WindowID
        found = -1
        Break
      EndIf
    Next
    
    ; if main call back hasnt been created then create one
    If found = 0
      ProGUIOldCallBack = SetWindowLongPtr_(WindowID, #GWLP_WNDPROC, @MyWindowCallback())
      LastElement(menuCallback())
      AddElement(menuCallback())
      menuCallback()\WindowID = WindowID
      menuCallback()\callback = @MyWindowCallback()
      menuCallback()\oldCallback = ProGUIOldCallBack
      SetWindowLongPtr_(WindowID, #GWL_STYLE, GetWindowLongPtr_(WindowID, #GWL_STYLE)|#WS_CLIPCHILDREN)
    EndIf
    
    If ProGUI_Any = #False
      ProcedureReturn hwndRB
    Else
      ProcedureReturn id
    EndIf
  EndIf
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL SetRebarStyle(rebar.i, style.l)  ; Sets the rendering style of a rebar
  
  macro_protectCommand()
  
  ; get handle to rebar
  ForEach rebarGadget()
    If rebarGadget()\id = rebar Or rebarGadget()\Handle = rebar
      
      If rebarGadget()\UIStyle = #UISTYLE_OFFICE2003
        *oldHBITMAP = ImageID(RebarBackBuffer_Office2003)
      ElseIf rebarGadget()\UIStyle = #UISTYLE_OFFICE2007
        *oldHBITMAP = ImageID(RebarBackBuffer_Office2007)
      EndIf
      
      rebarGadget()\UIStyle = style
      
      SendMessage_(rebarGadget()\Handle, #WM_SETREDRAW, #False, 0)
      If style <> 0
        If GetWindowLongPtr_(rebargadget()\Handle, #GWL_STYLE) & #RBS_BANDBORDERS
          rebargadget()\bandBorders = #True
          SetWindowLongPtr_(rebargadget()\Handle, #GWL_STYLE, GetWindowLongPtr_(rebargadget()\Handle, #GWL_STYLE) &~ #RBS_BANDBORDERS)
        EndIf
        nulls.s = ""
        CallFunctionFast(*SetWindowTheme, rebarGadget()\Handle, @nulls, @nulls)
      EndIf
      
      If style = 0
        UpdateRebarBackgrounds(*oldHBITMAP, 0, 0)
        If rebarGadget()\userBackgroundImage = 0
          CallFunctionFast(*SetWindowTheme, rebarGadget()\Handle, 0, 0)
          If rebarGadget()\bandBorders = #True
            SetWindowLongPtr_(rebarGadget()\Handle, #GWL_STYLE, GetWindowLongPtr_(rebarGadget()\Handle, #GWL_STYLE) | #RBS_BANDBORDERS)
            rebarGadget()\bandBorders = #False
          EndIf
        EndIf
      ElseIf style = #UISTYLE_OFFICE2003
        If Not IsImage(RebarBackBuffer_Office2003)
          RebarBackBuffer_Office2003 = -1
          RenderRebarBackgrounds(0)
        EndIf
        UpdateRebarBackgrounds(*oldHBITMAP, ImageID(RebarBackBuffer_Office2003), style)
      ElseIf style = #UISTYLE_OFFICE2007
        If Not IsImage(RebarBackBuffer_Office2007)
          RebarBackBuffer_Office2007 = -1
          RenderRebarBackgrounds(0)
        EndIf
        UpdateRebarBackgrounds(*oldHBITMAP, ImageID(RebarBackBuffer_Office2007), style)
      EndIf
      
      height = SendMessage_(rebarGadget()\Handle, #RB_GETBARHEIGHT, 0,0)
      SetWindowPos_(rebarGadget()\Handle, 0, 0, 0, LOWORD(lParam), height, #SWP_NOMOVE|#SWP_NOOWNERZORDER|#SWP_NOACTIVATE|#SWP_NOREDRAW|#SWP_NOZORDER)
      updateRebar(rebarGadget()\WindowID)
      SendMessage_(rebarGadget()\Handle, #WM_SETREDRAW, #True, 0)
      
      RedrawWindow_(rebarGadget()\WindowID, 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
      
      sendRebarUpdatedMsg(0)
      
      ProcedureReturn #True
    EndIf
  Next
    
  ProcedureReturn 0
EndProcedure

ProcedureDLL SetRebarUserCallback(Rebar.i, UserCallback.i)  ; Sets the User Callback function of a rebar
  
  macro_protectCommand()
  
  If UserCallback <> 0
  
    ; get handle to rebar
    ForEach rebarGadget()
      If rebarGadget()\id = rebar Or rebarGadget()\Handle = rebar
        
        old = rebarGadget()\UserCallback
        rebarGadget()\UserCallback = UserCallback
        
        ProcedureReturn old
      EndIf
    Next
    
  EndIf
    
  ProcedureReturn -1
EndProcedure

ProcedureDLL AddRebarGadget(gadgetID.i, text.s, width.l, minWidth.l, height.l, backgroundImage.i, style.l) ; Adds a gadget to a rebar
  
  macro_protectCommand()
  
  ; exit if Rebar hasnt been created
  If currentRebarGadget = -1
    ProcedureReturn 0
  EndIf
  
  ; find current Rebar id
  ForEach rebarGadget()
    If rebarGadget()\id = currentRebarGadget
      
      rc.RECT
      *p = AllocateMemory(StringByteLength(text)+2)
      PokeS(*p, text)
      rebarGadget()\rbBand\lpText = *p                  ; text to display for our gadget
      rebarGadget()\rbBand\hwndChild = gadgetID                 ; handle to our gadget
      rebarGadget()\rbBand\cxMinChild = minWidth                   ; min width of band (0 hides gadget)
      rebarGadget()\rbBand\cx = width                           ; width of band
      rebarGadget()\rbBand\cxIdeal = width
      rebarGadget()\rbBand\wID = rebarGadget()\currentBandID
      rebarGadget()\rbBand\fMask = #RBBIM_IDEALSIZE|#RBBIM_TEXT|#RBBIM_STYLE|#RBBIM_SIZE|#RBBIM_CHILD|#RBBIM_CHILDSIZE|#RBBIM_ID|#RBBIM_LPARAM|#RBBIM_BACKGROUND
      
      ;-cxHeader
      ;If rebarGadget()\UIStyle = #UISTYLE_OFFICE2003
      ;  rebarGadget()\rbBand\fMask = rebarGadget()\rbBand\fMask | #RBBIM_HEADERSIZE
      ;  ;- yar
      ;  rebarGadget()\rbBand\cxHeader = 11
      ;EndIf
      
      LastElement(rebarBand())
      AddElement(rebarBand())
      rebarBand()\WindowID = rebarGadget()\WindowID
      rebarBand()\Handle = rebarGadget()\Handle
      rebarBand()\wID = rebarGadget()\rbBand\wID
      rebarBand()\GadgetHandle = gadgetID
      rebarBand()\visible = -1
      rebarGadget()\rbBand\lParam = @rebarBand()
      
      fStyle = rebarGadget()\rbBand\fStyle
      If style <> 0
        rebarGadget()\rbBand\fStyle = style
      EndIf
      
      If backgroundImage <> 0
        
        rebarBand()\backgroundImage = backgroundImage
        rebarGadget()\rbBand\hbmBack = backgroundImage
        
        ; remove band borders if background image is set
        SetWindowLongPtr_(rebarGadget()\Handle, #GWL_STYLE, GetWindowLongPtr_(rebarGadget()\Handle, #GWL_STYLE) &~ #RBS_BANDBORDERS)
        
      ElseIf rebarGadget()\backgroundImage <> 0
        rebarGadget()\rbBand\fStyle = rebarGadget()\rbBand\fStyle | #RBBS_FIXEDBMP
        rebarGadget()\rbBand\hbmBack = rebarGadget()\backgroundImage
      Else
        rebarGadget()\rbBand\hbmBack = 0
      EndIf
      
      If height = 0
        dwBtnSize = SendMessage_(gadgetID, #TB_GETBUTTONSIZE, 0,0)
        If dwBtnSize = 0
          GetWindowRect_(gadgetID, @rc)
          rebarGadget()\rbBand\cyMinChild = rc\bottom - rc\top    ; min height of band
        Else
          rebarGadget()\rbBand\cyMinChild = (dwBtnSize>>16)         ; min height of band set to button height
        EndIf
      Else
        rebarGadget()\rbBand\cyMinChild = height
      EndIf
      
      rebargadget()\rbBand\cyChild = rebarGadget()\rbBand\cyMinChild
      ;rebarGadget()\rbBand\cyMaxChild = 1000
      rebarGadget()\rbBand\cyIntegral = 1
      
      ; is the gadget we are attaching a toolbar?
      bf.s = Space(40)
      RealGetWindowClass_(gadgetID, @bf, Len(bf))
      If LCase(bf) = "toolbarwindow32"
        rStyle = SendMessage_(gadgetID, #TB_GETSTYLE, 0, 0)

        ; automatically make sure #CCS_NODIVIDER is part of style
        If Not rStyle & #CCS_NODIVIDER
          rStyle = rStyle | #CCS_NODIVIDER
        EndIf
        ; automatically make sure #CCS_NORESIZE is part of style
        If Not rStyle & #CCS_NORESIZE
          rStyle = rStyle | #CCS_NORESIZE
        EndIf
        
        SendMessage_(gadgetID, #TB_SETSTYLE, 0, rStyle)

        ; if rebar UISTYLEOffice2003 style then search for toolbar handle and remove theme
        ; If rebarGadget()\UIStyle = #UISTYLE_OFFICE2003
          ; ForEach toolbarEx()
            ; If toolbarEx()\Handle = gadgetID
              ; CallFunctionFast(*SetWindowTheme, toolbarEx()\Handle, @null.w, @null.w)
              ; debuglog("cool")
              ; Break
            ; EndIf
          ; Next
        ; EndIf
        
      EndIf

      
      ;/ Add the gadget
      If rebarGadgetInsert = -2
        SendMessage_(rebarGadget()\Handle, #RB_INSERTBAND, -1, @rebarGadget()\rbBand)
      Else
        SendMessage_(rebarGadget()\Handle, #RB_INSERTBAND, rebarGadgetInsert, @rebarGadget()\rbBand)
      EndIf
      FreeMemory(*p)
      rebarGadget()\rbBand\fStyle = fStyle
      
      rebarGadget()\currentBandID = rebarGadget()\currentBandID + 1
      
      ProcedureReturn rebarGadget()\rbBand\wID
      
    EndIf
  Next
  
  ProcedureReturn -1
EndProcedure


ProcedureDLL ShowRebarBand(rebar, band, state)
  
  macro_protectCommand()
  
  ; get handle to rebar if rebar not handle
  If IsWindow_(rebar) = 0
    ForEach rebarGadget()
      If rebarGadget()\id = rebar
        rebar = rebarGadget()\Handle
        Break
      EndIf
    Next
  EndIf
  
  ; get band info
  index = SendMessage_(rebar, #RB_IDTOINDEX, band, 0)
  If index = -1
    index = band
  EndIf
  
  binfo.REBARBANDINFO
  binfo\cbSize = SizeOf(REBARBANDINFO)
  binfo\fMask = #RBBIM_LPARAM
  If SendMessage_(rebar, #RB_GETBANDINFO, index, @binfo) <> 0
    ;SendMessage_(rebar, #WM_SETREDRAW, #False, 0)
    SendMessage_(rebar, #RB_SHOWBAND, index, state)
    If binfo\lParam <> 0
      ChangeCurrentElement(rebarBand(), binfo\lParam)
      If state <> 0
        rebarBand()\visible = -1
      Else
        rebarBand()\visible = 0
      EndIf
    EndIf
    
    updateRebar(rebarBand()\WindowID)
    ;SendMessage_(rebar, #WM_SETREDRAW, #True, 0)
    GetUpdateRect_(rebarBand()\Handle, regen.RECT, #False)
    RedrawWindow_(rebarBand()\Handle, @regen,0,#RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
      
    ProcedureReturn #True
  EndIf
 
  ProcedureReturn 0
EndProcedure


ProcedureDLL RebarHeight(rebar.i) ; returns height of rebar in pixels
  
  ; get handle to rebar
  ForEach rebarGadget()
    If rebarGadget()\id = rebar Or rebarGadget()\Handle = rebar
      rebar = rebarGadget()\Handle
      Break
    EndIf
  Next
  
  ProcedureReturn SendMessage_(rebar, #RB_GETBARHEIGHT, 0, 0)
  
EndProcedure


ProcedureDLL FreeRebar(rebar.i) ; Frees a rebar from memory.
  
  macro_protectCommand()
  
  ; get handle to rebar
  ForEach rebarGadget()
    If rebarGadget()\id = rebar Or rebarGadget()\Handle = rebar Or rebar = -1
      
      Repeat
      Until SendMessage_(rebarGadget()\Handle, #RB_DELETEBAND, 0, 0) = 0
      
      ForEach rebarBand()
        If rebarBand()\Handle = rebarGadget()\Handle
          SetParent_(rebarband()\GadgetHandle, GetParent_(rebarGadget()\handle))
          DeleteElement(rebarBand())
        EndIf
      Next
      
      DestroyWindow_(rebarGadget()\Handle)
      DeleteElement(rebarGadget())
      
      If rebar <> -1
        ProcedureReturn #True
      EndIf
    EndIf
  Next
  
  If rebar = -1
    ProcedureReturn #True
  EndIf
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL DeleteRebarBand(rebar.i, band.l) ; Deletes a Rebar's band.
  
  macro_protectCommand()
  
  ; get handle to rebar
  ForEach rebarGadget()
    If rebarGadget()\id = rebar Or rebarGadget()\Handle = rebar
      
      found = 0
      ForEach rebarBand()
        If rebarBand()\Handle = rebarGadget()\Handle
          
          index = SendMessage_(rebarGadget()\Handle, #RB_IDTOINDEX, band, 0)
          If index <> -1 And rebarBand()\wID = band
            band = index
            found = #True
          ElseIf index = -1
            binfo.REBARBANDINFO
            binfo\cbSize = SizeOf(REBARBANDINFO)
            binfo\fMask = #RBBIM_ID
            SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, band, @binfo)
            If binfo\wID = rebarBand()\wID
              found = #True
            EndIf
          EndIf
          
          If found = #True
            SendMessage_(rebarGadget()\Handle, #RB_DELETEBAND, band, 0)
            DeleteElement(rebarBand())
            rebarGadget()\currentBandID = rebarGadget()\currentBandID - 1
            ProcedureReturn #True
          EndIf
        EndIf
      Next
      
      Break
    EndIf
  Next
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL InsertRebarGadget(rebar.i, band.l, gadgetID.i, text.s, width.l, minWidth.l, height.l, backgroundImage.i, style.l) ; Inserts a gadget to a rebar band.
  
  macro_protectCommand()
  
  ; get handle to rebar
  ForEach rebarGadget()
    If rebarGadget()\id = rebar Or rebarGadget()\Handle = rebar
      
      index = SendMessage_(rebarGadget()\Handle, #RB_IDTOINDEX, band, 0)
      If index <> -1
        band = index
      EndIf
      
      found = #True

      Break
    EndIf
  Next
  
  If found = #True
    currentRebarGadget = rebarGadget()\id
    rebarGadgetInsert = band
    ret = AddRebarGadget(gadgetID, text, width, minWidth, height, backgroundImage, style)
    rebarGadgetInsert = -2  ; de-activate insert mode
    ProcedureReturn ret
  EndIf
  
  ProcedureReturn 0
EndProcedure


Procedure calcRebarSizable(rebar, band)
  
  ; get band count
  count = SendMessage_(rebar, #RB_GETBANDCOUNT, 0, 0)
  ; get index of band
  index = SendMessage_(rebar, #RB_IDTOINDEX, band, 0)
  ; get height of rows not containing our band
  lasttop = -1
  For n = 0 To count-1
    height = SendMessage_(rebar, #RB_GETROWHEIGHT, n, 0)
    SendMessage_(rebar, #RB_GETRECT, n, @rec.RECT)
    
    binfo.REBARBANDINFO
    binfo\cbSize = SizeOf(REBARBANDINFO)
    binfo\fMask = #RBBIM_LPARAM
    SendMessage_(rebar, #RB_GETBANDINFO, n, @binfo)
    ChangeCurrentElement(rebarBand(), binfo\lParam)
    
    If rebarBand()\visible = -1
      If n <> index And lasttop <> rec\top
        
        rheight = rheight + SendMessage_(rebar, #RB_GETROWHEIGHT, n, 0)
        SendMessage_(rebar, #RB_GETBANDBORDERS, n, @rc.RECT)
        rheight = rheight + rc\top + rc\bottom
        
      ElseIf n = index And lasttop = rec\top
        rheight = rheight - SendMessage_(rebar, #RB_GETROWHEIGHT, n, 0)
        SendMessage_(rebar, #RB_GETBANDBORDERS, n, @rc.RECT)
        rheight = rheight - (rc\top + rc\bottom)
      EndIf
      lasttop = rec\top
    EndIf
    
  Next
  
  ProcedureReturn rheight
  
EndProcedure

Procedure EnumChildProc(hwnd, *lParam)
  
  rc.RECT
  GetWindowRect_(*lParam, @rc)
  ;debuglog(Str(rc\bottom))
  
EndProcedure

Procedure updateRebar(WindowID)

  ;find rebar
  found = 0
  ForEach rebarGadget()
    If rebarGadget()\WindowID = WindowID
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    ; get window dimensions
    GetClientRect_(WindowID, @wrc.RECT)

    ; get band count
    count = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0, 0)
    
    ; scan through bands and see witch ones are sizable
    found = 0
    For z = 0 To count-1
      binfo.REBARBANDINFO
      binfo\cbSize = SizeOf(REBARBANDINFO)
      binfo\fMask = #RBBIM_LPARAM|#RBBIM_CHILDSIZE|#RBBIM_STYLE|#RBBIM_ID
      SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, z, @binfo)
      ChangeCurrentElement(rebarBand(), binfo\lParam)
      
      ; found a sizable band
      If binfo\fStyle & #RBBS_SIZEABLE
        
        found = -1
        ;Debug "band "+Str(z)+" is sizable!"
        
        rheight = calcRebarSizable(rebarGadget()\Handle, binfo\wID)
        
        index = SendMessage_(rebarGadget()\Handle, #RB_IDTOINDEX, binfo\wID, 0)
        
        binfo.REBARBANDINFO
        binfo\cbSize = SizeOf(REBARBANDINFO)
        binfo\fMask = #RBBIM_CHILDSIZE
        SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, index, @binfo)

        ;- auto fit to other windows below
        offset = rebarBand()\lastOffset
        GetClientRect_(rebarGadget()\WindowID, @rc.RECT)
        x = rc\right/2
        For y = 0 To rc\bottom
          p.POINT
          p\x = x : p\y = y
          win = ChildWindowFromPoint_(rebarGadget()\WindowID, PeekQ(p))
          If win <> 0 And win <> rebarGadget()\Handle And win <> rebarGadget()\WindowID
            offset = rc\bottom-(y-5)
            If rebarBand()\lastOffset =0
              rebarBand()\lastOffset = offset
            EndIf
            Break
          EndIf
        Next
        
        binfo\cyMinChild=(rc\bottom-offset)-rheight
        
        dontupdate = -1
        SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, index, @binfo)
        dontupdate = 0

      EndIf

    Next
    
    
    ; scan through bands and see witch ones are vertically resizable
    found = 0
    For z = 0 To count-1
      binfo.REBARBANDINFO
      binfo\cbSize = SizeOf(REBARBANDINFO)
      binfo\fMask = #RBBIM_LPARAM|#RBBIM_CHILDSIZE|#RBBIM_STYLE|#RBBIM_ID
      SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, z, @binfo)
      ChangeCurrentElement(rebarBand(), binfo\lParam)

      
      ; found a verticalsizable band
      If binfo\fStyle & #RBBS_VERTICALRESIZEABLE
        
        found = 0
        ;Debug "band "+Str(z)+" is sizable!"
        
        ; see if its sharing any other bands
        For n = 0 To count-1
          
          If n <> z
            binfo2.REBARBANDINFO
            binfo2\cbSize = SizeOf(REBARBANDINFO)
            binfo2\fMask = #RBBIM_CHILDSIZE|#RBBIM_STYLE|#RBBIM_ID
            SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, n, @binfo2)
            
            
            ; found a sizable band
            If binfo2\fStyle & #RBBS_SIZEABLE Or binfo2\fStyle & #RBBS_VERTICALRESIZEABLE
              
              ; see of its sharing our band
              SendMessage_(rebarGadget()\Handle, #RB_GETRECT, z, @rc.RECT)
              SendMessage_(rebarGadget()\Handle, #RB_GETRECT, n, @rc2.RECT)
              If rc\top = rc2\top
                found = -1
                ; re-size band to accomodate height of sizable band if bigger
                ;If binfo\cyMinChild < binfo2\cyMinChild
                If rebarBand()\minheight = 0
                  rebarBand()\minheight = binfo\cyMinChild
                EndIf
                binfo\cyMinChild = binfo2\cyMinChild
                SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, z, @binfo)
                
                ;EndIf
                
              EndIf
            
            EndIf
          EndIf
          
        Next
        
        If found = 0
          If rebarBand()\minheight <> 0
            
            binfo\cyMinChild = rebarBand()\minheight
            SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, z, @binfo)
            rebarBand()\minheight = 0
            
            updateRebar(WindowID)
            
          EndIf
        EndIf
        
      EndIf
      
    Next
    
    ;If found = -1
    ;;GetUpdateRect_(rebarGadget()\handle, regen.RECT, #False)
    ;RedrawWindow_(rebarGadget()\Handle,@regen,0,#RDW_NOERASE|#RDW_NOINTERNALPAINT|#RDW_NOFRAME|#RDW_UPDATENOW)
    ;;RedrawWindow_(rebarGadget()\handle,@regen,0,#RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
    ;EndIf
    
  EndIf  
EndProcedure

ProcedureDLL RebarID(id.l)
  
  ForEach rebarGadget()
    If rebarGadget()\id = id
      ProcedureReturn rebarGadget()\Handle
    EndIf
  Next
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL RebarBandID(Rebar.i, Index.l) ; Returns the ID of the Rebar band at position Index.l
  
  ForEach rebarGadget()
    If rebarGadget()\id = Rebar Or rebarGadget()\Handle = Rebar
      
      binfo.REBARBANDINFO 
      binfo\cbSize = SizeOf(REBARBANDINFO)
      binfo\fmask = #RBBIM_ID
      SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, Index, @binfo)
      
      ProcedureReturn binfo\wID
      
    EndIf
  Next
  
  ProcedureReturn -1
EndProcedure

ProcedureDLL MoveRebarBand(Rebar.i, SourceBandIndex.l, DestinationBandIndex.l) ; Moves a Rebar band to a new zero based index position
  
  macro_protectCommand()
  
  ForEach rebarGadget()
    If rebarGadget()\id = Rebar Or rebarGadget()\Handle = Rebar
      
      ProcedureReturn SendMessage_(rebarGadget()\Handle, #RB_MOVEBAND, SourceBandIndex, DestinationBandIndex)
      
    EndIf
  Next
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL SaveRebarLayout(Rebar.i, Path.s) ; Saves the layout of a Rebar's bands to the file specified in Path.s
  
  macro_protectCommand()
  
  If CheckFilename(GetFilePart(Path)) = #False
    ProcedureReturn 0
  EndIf
  
  ; get handle to rebar
  ForEach rebarGadget()
    If rebarGadget()\id = Rebar Or rebarGadget()\Handle = Rebar
      
      xml = CreateXML(#PB_Any)
      If xml <> 0
        
        mainNode = CreateXMLNode(RootXMLNode(xml), "")
        If mainNode <> 0
          
          SetXMLNodeName(mainNode, "Layout")
          
          bandcount = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0, 0)
          Repeat
            
            binfo.REBARBANDINFO 
            binfo\cbSize = SizeOf(REBARBANDINFO)
            binfo\fmask = #RBBIM_ID|#RBBIM_SIZE|#RBBIM_STYLE
            SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, i, @binfo)
            
            idNode = CreateXMLNode(mainNode, "") 
            SetXMLNodeName(idNode, "Band")
            SetXMLAttribute(idNode, "ID",Str(binfo\wID))
            SetXMLAttribute(idNode, "cx",Str(binfo\cx))
            SetXMLAttribute(idNode, "fStyle",Str(binfo\fStyle))
            
            i = i + 1
          Until i >= bandcount
          
          FormatXML(xml, #PB_XML_WindowsNewline|#PB_XML_ReFormat, 3)
          If SaveXML(xml, path) <> 0
            retval = #True
          EndIf
          
        EndIf
        
        FreeXML(xml)
        
        Break
      EndIf
    EndIf
  Next
  
  ProcedureReturn retval
    
EndProcedure

ProcedureDLL LoadRebarLayout(Rebar.i, LayoutFilename.s) ; Loads a previously saved Rebar's layout
  
  macro_protectCommand()
  
  If CheckFilename(GetFilePart(LayoutFilename)) = #False
    ProcedureReturn 0
  EndIf
  
  ; get handle to rebar
  ForEach rebarGadget()
    If rebarGadget()\id = Rebar Or rebarGadget()\Handle = Rebar
      
      xml = LoadXML(#PB_Any, LayoutFilename)
      If xml <> 0
        If XMLStatus(xml) = #PB_XML_Success
          rebarNode = MainXMLNode(xml)
          name.s = LCase(GetXMLNodeName(rebarNode))
          If name = "layout"
            
            bandcount = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0, 0)
            node = ChildXMLNode(rebarNode)
            Repeat
              
              name.s = LCase(GetXMLNodeName(node))
              
              id = Val(GetXMLAttribute(node, "ID"))
              
              Index = SendMessage_(rebarGadget()\Handle, #RB_IDTOINDEX, id, 0)
              
              binfo.REBARBANDINFO 
              binfo\cbSize = SizeOf(REBARBANDINFO)
              binfo\fmask = #RBBIM_SIZE|#RBBIM_STYLE
              binfo\cx = Val(GetXMLAttribute(node, "cx"))
              binfo\fStyle = Val(GetXMLAttribute(node, "fStyle"))
              SendMessage_(rebarGadget()\Handle, #RB_MOVEBAND, Index, i)
              SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, i, @binfo)
              
              i = i + 1
              node = NextXMLNode(Node)
            Until node = 0
            
            ; handle #TBSTYLE_WRAPABLE toolbars in rebar when dragging bands
            ForEach toolbarEx()
              If rebarGadget()\handle = GetParent_(toolbarEx()\handle)
                
                rows = SendMessage_(toolbarEx()\handle, #TB_GETROWS, 0, 0)
                If rows <> toolbarEx()\lastRowCount
                  
                  ; find band that our toolbar is contained in
                  max = SendMessage_(rebarGadget()\handle, #RB_GETBANDCOUNT, 0,0)
                  For n = 0 To max
                    
                    band.REBARBANDINFO
                    band\cbSize = SizeOf(REBARBANDINFO)
                    band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
                    SendMessage_(rebarGadget()\handle, #RB_GETBANDINFO, n, @band)
                    If band\hwndChild = toolbarEx()\handle
                      
                      dwBtnSize = SendMessage_(toolbarEx()\handle, #TB_GETBUTTONSIZE, 0,0)>>16
                      pad = toolbarEx()\lastRowCount * dwBtnSize
                      
                      toolbarEx()\lastRowCount = rows
            
                      pad = band\cyMinChild-pad
                      
                      dwBtnSize = (dwBtnSize * rows)+pad
                      
                      ; set rebar band's new height
                      band\fMask = #RBBIM_CHILDSIZE
                      band\cyMinChild = dwBtnSize;+hdelta
                      SendMessage_(rebarGadget()\handle, #RB_SETBANDINFO, n, @band)
                      
                      
                      handle = currentDragRebar
                      *this = @rebarGadget()
                      height = RebarHeight(handle)
                      ChangeCurrentElement(rebarGadget(), *this)
                      
                      
                      Break
                    EndIf
                      
                  Next
            
                EndIf
                
              EndIf
            Next
            
            sendRebarUpdatedMsg(0)
            
            retval = #True
          
          EndIf
          
        EndIf
      
        Break
        
        FreeXML(xml)
        
      EndIf
    EndIf
  Next
  
  ProcedureReturn retval
    
EndProcedure

;--
;- TextControlEx
;--
Procedure TextControlExCallback(Window, message, wParam, lParam)
  Static mouseCaptured
  
  ; find associated textcontrol
  ForEach txtcontrol()
    If txtcontrol()\Handle = GetParent_(Window)
      found = #True
      Break
    EndIf
  Next
  
  If found = #False
    ProcedureReturn 0
  EndIf

  Select message
    Case #WM_PAINT
      
      
      SetBkMode_(wParam, #TRANSPARENT)
      
      rc.RECT
      GetClientRect_(Window, @rc.RECT)
      txtcontrol()\width = rc\right-rc\left
      txtcontrol()\height = rc\bottom-rc\top
      
      ; draw background colour fill if flag set
      If txtcontrol()\flags & #TCX_BK_FILL
        brush = CreateSolidBrush_(txtcontrol()\bkcolour)
        FillRect_(wParam, rc, brush)
        DeleteObject_(brush)
      EndIf
      
      rc\left = txtcontrol()\leftpad
      rc\top = txtcontrol()\toppad
      rc\right = txtcontrol()\width-txtcontrol()\rightpad
      rc\bottom = txtcontrol()\height-txtcontrol()\bottompad
      
      ;; visual debug of padding
      ;zrc.RECT
      ;zrc\left = rc\left
      ;zrc\right = rc\right
      ;zrc\top = rc\top
      ;zrc\bottom = rc\bottom
      ;If txtcontrol()\dontdraw = 2
      ;  MapWindowPoints_(Window, lParam, @zrc, 2)
      ;EndIf
      ;hBrush = CreateSolidBrush_(RGB(255,0,0))
      ;FillRect_(wParam, @zrc, hBrush)
      ;DeleteObject_(hBrush)
      
      SetTextColor_(wParam, txtcontrol()\colour)
      
      flags = 0

      If txtcontrol()\font <> 0
        
        GetObject_(txtcontrol()\font, SizeOf(LOGFONT), @fontnfo.LOGFONT)
        
        If txtcontrol()\antialiased <> 0
          fontnfo\lfQuality = 4
        EndIf
        
        font = CreateFontIndirect_(@fontnfo)
        oldfont = SelectObject_(wParam, font)
        
      EndIf
      
      
      p = FindString(LCase(txtcontrol()\txt), "\l", 1)
      If p > 0
        s = 1
        
        linkNo = 0
        Repeat
          
          t.s = Mid(txtcontrol()\txt, s, p-s) ; copy txt before link into txt.s
          p+2 ; move position to start of link ID
          
          ;grab the ID of the link
          For n = p To Len(txtcontrol()\txt)
            If Asc(Mid(txtcontrol()\txt, n, 1)) < 48 Or Asc(Mid(txtcontrol()\txt, n, 1)) > 57
              Break
            EndIf
          Next
          id = Val(Mid(txtcontrol()\txt, p, n-p))
          
          ;grab all of link txt
          e = FindString(txtcontrol()\txt, "\l", n)
          linktxt.s = Mid(txtcontrol()\txt, n, e-n)
          
          If linkNo <> txtcontrol()\linkHoverID
            If FindString(linktxt, "|", 1) <> 0
              linktxt = StringField(linktxt, 1, "|")
            EndIf
          Else
            If FindString(linktxt, "|", 1) <> 0
              linktxt = StringField(linktxt, 2, "|")
            EndIf
          EndIf
          
          txt.s = txt + t + "\l"+Str(id)+linktxt+"\l"
          
          s = e+2
          p = FindString(LCase(txtcontrol()\txt), "\l", s)
          
          linkNo = linkNo + 1
          
        Until p = 0 Or e = 0
        If s < Len(txtcontrol()\txt) And e <> 0
          txt = txt + Mid(txtcontrol()\txt, s)
        EndIf
      
      Else
        txt.s = txtcontrol()\txt
      EndIf
      
      renderTextLinePadding = txtcontrol()\linePadding
      
      If txtcontrol()\flags & #TCX_DISABLE_ESCAPECODES
        renderText(wParam, txt, @rec.RECT, 0, #DT_CALCRECT|#TCX_DISABLE_ESCAPECODES)
      Else
        renderText(wParam, txt, @rec.RECT, 0, #DT_CALCRECT)
      EndIf
      
      If txtcontrol()\flags & #TCX_CENTRE
        twidth = txtcontrol()\width-(txtcontrol()\leftpad+txtcontrol()\rightpad)
        rc\left = rc\left+((twidth/2)-(rec\right/2))
        rc\right = rc\left+rec\right
      ElseIf txtcontrol()\flags & #TCX_RIGHT
        rc\left = (txtcontrol()\width-txtcontrol()\rightpad)-rec\right
      EndIf
      
      If Not txtcontrol()\flags & #TCX_VCENTRE
        flags = #TCX_TOP
        rc\bottom = rec\bottom
      Else
        flags = #TCX_TOP
        theight = txtcontrol()\height-(txtcontrol()\toppad+txtcontrol()\bottompad)
        vCentreY = (theight/2)-((rec\bottom-rec\top)/2)
        rc\top = rc\top + vCentreY
        rc\bottom = rc\bottom + vCentreY
      EndIf
      
      ; limit rendering to fit inside padding
      If rc\left < txtcontrol()\leftpad
        rc\left = txtcontrol()\leftpad
      EndIf
      If rc\right > txtcontrol()\rightpad
        rc\right = txtcontrol()\width-txtcontrol()\rightpad
      EndIf
      If rc\top < txtcontrol()\toppad
        rc\top = txtcontrol()\toppad
      EndIf
      If rc\bottom > txtcontrol()\bottompad
        rc\bottom = txtcontrol()\height-txtcontrol()\bottompad
      EndIf
      

      trc.RECT
      trc\left = rc\left
      trc\right = rc\right
      trc\top = rc\top
      trc\bottom = rc\bottom
      LockMutex(txtcontrolLinksMutex)
      If txtcontrol()\flags & #TCX_DISABLE_ESCAPECODES
        flags = flags | #TCX_DISABLE_ESCAPECODES
        renderText(wParam, txt, trc, 0, #DT_CALCRECT|#TCX_DISABLE_ESCAPECODES)
      Else
        renderText(wParam, txt, trc, 0, #DT_CALCRECT|#RTXT_PROCESS_LINKS)
      EndIf
      UnlockMutex(txtcontrolLinksMutex)
      
      If txtcontrol()\flags & #TCX_IGNORE_COLOR_ESCAPECODE
        flags = flags | #DT_OVERRIDECOLOUR
      EndIf
      
      ;; visual debug of text bounding rect
      ;zrc.RECT
      ;zrc\left = rc\left
      ;zrc\right = rc\left+rec\right
      ;zrc\top = rc\top
      ;zrc\bottom = rc\top+rec\bottom
      ;If txtcontrol()\dontdraw = 2
      ;  MapWindowPoints_(Window, lParam, @zrc, 2)
      ;EndIf
      ;hBrush = CreateSolidBrush_(RGB(0,255,0))
      ;FillRect_(wParam, @zrc, hBrush)
      ;DeleteObject_(hBrush)

      If txtcontrol()\flags & #TCX_END_ELLIPSIS
        flags = flags | #TCX_END_ELLIPSIS
      EndIf
      If txtcontrol()\flags & #TCX_PATH_ELLIPSIS
        flags = flags | #TCX_PATH_ELLIPSIS
      EndIf
      
      renderText(wParam, txt, @rc, 0, flags)
      
      SelectObject_(wParam, oldfont)
      DeleteObject_(font)
    
    Case #WM_MOUSEMOVE
      
      x = LOWORD(lParam)
      y = HIWORD(lParam)      
      
       ; process any links in txtcontrol
      If ListSize(txtcontrol()\link()) > 0
        overLink = 0
        linkNo = 0
        ForEach txtcontrol()\link()
          If x >= txtcontrol()\link()\rc\left And y >= txtcontrol()\link()\rc\top And x <= txtcontrol()\link()\rc\right And y <= txtcontrol()\link()\rc\bottom
            overLink = #True
            txtcontrol()\linkID = txtcontrol()\link()\id
            txtcontrol()\linkHoverID = linkNo
            SetPanelExPageCursor(txtcontrol()\handle, 0, linkMousePointer)
            Break
          EndIf
          linkNo = linkNo + 1
        Next
        If overLink = #False
          txtcontrol()\linkHoverID = -1
          txtcontrol()\linkID = -1
          SetPanelExPageCursor(txtcontrol()\handle, 0, normalMousePointer)
        EndIf
        
        If txtcontrol()\linkHoverID <> txtcontrol()\lastLinkHoverID 
          If txtcontrol()\linkHoverID <> -1
            ; send link hover message to parent window
            PostMessage_(GetParent_(GetParent_(Window)), #TCX_LINK_HOVER, txtcontrol()\linkID, 0)
          Else
            ; send link hover message to parent window
            PostMessage_(GetParent_(GetParent_(Window)), #TCX_LINK_HOVER, -1, 0)
          EndIf
          
          *thisTxt = @txtcontrol()
          RefreshPanelEx(txtcontrol()\Handle)
          ChangeCurrentElement(txtcontrol(), *thisTxt)
          
        EndIf

        If mouseCaptured = 0
          tm.TRACKMOUSEEVENT
          tm\cbSize = SizeOf(TRACKMOUSEEVENT)
          tm\dwFlags = #TME_LEAVE
          tm\hwndTrack = Window
          TrackMouseEvent_(@tm)
          mouseCaptured = #True
        EndIf
        
        txtcontrol()\lastLinkHoverID = txtcontrol()\linkHoverID
        
      EndIf
      
    Case #WM_LBUTTONDOWN
      
      If txtcontrol()\linkHoverID <> -1
        ; send link click message to parent window
        PostMessage_(GetParent_(GetParent_(Window)), #TCX_LINK_CLICK, txtcontrol()\linkID, 0)
      EndIf
      
    Case #WM_MOUSELEAVE
      
      If mouseCaptured = #True
        
        mouseCaptured = #False
        
        If txtcontrol()\linkHoverID <> -1
          
          txtcontrol()\linkHoverID = -1
          txtcontrol()\linkID = -1
          txtcontrol()\lastLinkHoverID = -1
          *thisTxt = @txtcontrol()
          RefreshPanelEx(txtcontrol()\Handle)
          ChangeCurrentElement(txtcontrol(), *thisTxt)
          PostMessage_(GetParent_(GetParent_(Window)), #TCX_LINK_HOVER, -1, 0)
          
        EndIf
      EndIf
      
  EndSelect
  
  ProcedureReturn Result
EndProcedure


ProcedureDLL TextControlEx(Window.i, id.l, x, y, width.l, height.l, text.s, flags.l) ; Creates a TextControlEx
  
  macro_protectCommand()
  
  transparent = 0
  
  If id = #ProGUI_Any
    Repeat
      ; generate unique id so as not to conflict with other textcontrolexs
      id = generateUniqueID()
      ; check that same id doesnt already exist
      found = 0
      ForEach txtcontrol()
        If txtcontrol()\id = id
          found = -1
          Break
        EndIf
      Next
    Until found = 0
    ProGUI_Any = #True
  Else
    ; make sure txt control doesn't already exist
    ForEach txtcontrol()
      If txtcontrol()\id = id
        ProcedureReturn 0
      EndIf
    Next
  EndIf
  
  origwidth = width
  origheight = height
  
  If textControlExFont = 0
    metrics.NONCLIENTMETRICS
    metrics\cbSize = SizeOf(NONCLIENTMETRICS)
    SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
    textControlExFont = CreateFontIndirect_(metrics\lfMessageFont)
  EndIf
  
  If width = 0 Or height = 0
    
    p = FindString(LCase(text), "\l", 1)
    If p > 0
      s = 1
      
      linkNo = 0
      Repeat
        
        t.s = Mid(text, s, p-s) ; copy txt before link into txt.s
        p+2 ; move position to start of link ID
        
        ;grab the ID of the link
        For n = p To Len(text)
          If Asc(Mid(text, n, 1)) < 48 Or Asc(Mid(text, n, 1)) > 57
            Break
          EndIf
        Next
        linkid = Val(Mid(text, p, n-p))
        
        ;grab all of link txt
        e = FindString(text, "\l", n)
        linktxt.s = Mid(text, n, e-n)
        
        linktxt = StringField(linktxt, 1, "|")
       
        txt.s = txt + t + "\l"+Str(linkid)+linktxt+"\l"
        
        s = e+2
        p = FindString(LCase(text), "\l", s)
        
        linkNo = linkNo + 1
        
      Until p = 0 Or e = 0
      If s < Len(text) And e <> 0
        txt = txt + Mid(text, s)
      EndIf
      
    Else
      txt.s = text
    EndIf
    
    rc.RECT
    hdc = CreateCompatibleDC_(0)
    If textControlExFont <> 0
      SelectObject_(hdc, textControlExFont)
    EndIf
    renderTextLinePadding = textControlExLinePadding
    renderText(hdc, txt, @rc, 0, #DT_CALCRECT)
    DeleteDC_(hdc)
    
    If width = 0
      width = rc\right
      exwidth = textControlExLeftpad+textControlExRightpad
    EndIf
    If height = 0
      height = rc\bottom
      exheight = textControlExToppad+textControlExBottompad
    EndIf
  EndIf
  
  backupCurrentPanelEx = currentPanelEx ; store the current panelex for backup after the button is created
  hwnd = PanelExID(CreatePanelEx(#ProGUI_Any, Window, x, y, width+exwidth, height+exheight, @TextControlExCallback()), -1)
  If hwnd <> 0
    
    bk = -1
    If flags & #TCX_BK_GRADIENT And textControlExGradient <> 0
      bk = textControlExGradient
    EndIf
    
    page = AddPanelExImagePage(bk, 0, 0, 0, 0, 0, #PNLX_NOGADGETLIST)
    currentPanelEx = backupCurrentPanelEx
    If page = 0
      FreePanelEx(hwnd)
      ProcedureReturn #False
    EndIf
    
    LastElement(txtcontrol())
    AddElement(txtcontrol())
    txtcontrol()\id = id
    txtcontrol()\Handle = hwnd
    txtcontrol()\width = width
    txtcontrol()\height = height
    txtcontrol()\origwidth = origwidth
    txtcontrol()\origheight = origheight
    txtcontrol()\txt = text
    txtcontrol()\flags = flags
    txtcontrol()\leftpad = textControlExLeftpad
    txtcontrol()\toppad = textControlExToppad
    txtcontrol()\rightpad = textControlExRightpad
    txtcontrol()\bottompad = textControlExBottompad
    txtcontrol()\font = textControlExFont
    txtcontrol()\colour = textControlExColour
    txtcontrol()\bkcolour = textControlExBKColour
    txtcontrol()\Gradient = textControlExGradient
    txtcontrol()\antialiased = textControlExAntialiased
    txtcontrol()\linePadding = textControlExLinePadding
    txtcontrol()\linkID = -1
    txtcontrol()\linkHoverID = -1
    txtcontrol()\lastLinkHoverID = -1
    
    If ProGUI_Any = #False
      ProcedureReturn hwnd
    Else
      ProcedureReturn id
    EndIf
    
  EndIf
  
EndProcedure

ProcedureDLL SetTextControlExPadding(id.i, leftPadding.l, topPadding.l, rightPadding.l, bottomPadding.l) ; Sets the space padding around a TextControlEx
  
  macro_protectCommand()

  If id = -1
    
    textControlExLeftpad = leftPadding
    textControlExToppad = topPadding
    textControlExRightpad = rightPadding
    textControlExBottompad = bottomPadding
    
    ProcedureReturn #True
    
  Else
    
    ForEach txtcontrol()
      If txtcontrol()\id = id Or txtcontrol()\Handle = id
        txtcontrol()\leftpad = leftPadding
        txtcontrol()\rightpad = rightPadding
        txtcontrol()\toppad = topPadding
        txtcontrol()\bottompad = bottomPadding
        
        If txtcontrol()\origwidth = 0 Or txtcontrol()\origheight = 0
          
          text.s = txtcontrol()\txt
          p = FindString(LCase(text), "\l", 1)
          If p > 0
            s = 1
            
            linkNo = 0
            Repeat
              
              t.s = Mid(text, s, p-s) ; copy txt before link into txt.s
              p+2 ; move position to start of link ID
              
              ;grab the ID of the link
              For n = p To Len(text)
                If Asc(Mid(text, n, 1)) < 48 Or Asc(Mid(text, n, 1)) > 57
                  Break
                EndIf
              Next
              linkid = Val(Mid(text, p, n-p))
              
              ;grab all of link txt
              e = FindString(text, "\l", n)
              linktxt.s = Mid(text, n, e-n)
              
              linktxt = StringField(linktxt, 1, "|")
             
              txt.s = txt + t + "\l"+Str(linkid)+linktxt+"\l"
              
              s = e+2
              p = FindString(LCase(text), "\l", s)
              
              linkNo = linkNo + 1
              
            Until p = 0 Or e = 0
            If s < Len(text) And e <> 0
              txt = txt + Mid(text, s)
            EndIf
          Else
            txt.s = txtcontrol()\txt
          EndIf
          
          rc.RECT
          hdc = CreateCompatibleDC_(0)
          If txtcontrol()\font <> 0
            SelectObject_(hdc, txtcontrol()\font)
          EndIf
          renderTextLinePadding = padding
          renderText(hdc, txt, @rc, 0, #DT_CALCRECT)
          DeleteDC_(hdc)
          
          If txtcontrol()\origwidth = 0
            txtcontrol()\width = rc\right
            exwidth = txtcontrol()\leftpad+txtcontrol()\rightpad
          EndIf
          If txtcontrol()\origheight = 0
            txtcontrol()\height = rc\bottom
            exheight = txtcontrol()\toppad+txtcontrol()\bottompad
          EndIf
        EndIf
        
        SetWindowPos_(txtcontrol()\Handle, 0, 0, 0, txtcontrol()\width+exwidth, txtcontrol()\height+exheight, #SWP_NOMOVE|#SWP_NOZORDER)
        
        RefreshPanelEx(txtcontrol()\Handle)
        
        ProcedureReturn #True
      EndIf
    Next
    
  EndIf
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL SetTextControlExFont(id.i, fontID.i, antialiased.b) ; Sets the TextControlEx font
  
  macro_protectCommand()
  
  CompilerIf #LIBRARY = 1
    If IsFont(fontID)
      fontID = FontID(fontID)
    EndIf
  CompilerEndIf

  If id = -1
    
    textControlExAntialiased = antialiased
    
    If fontID <> 0
      textControlExFont = fontID
    Else
      ProcedureReturn 0
    EndIf
    
    ProcedureReturn #True
    
  Else
    
    ForEach txtcontrol()
      If txtcontrol()\id = id Or txtcontrol()\Handle = id
        txtcontrol()\font = fontID
        txtcontrol()\antialiased = antialiased
        
        GetObject_(txtcontrol()\font, SizeOf(LOGFONT), @fontnfo.LOGFONT)
        
        If txtcontrol()\antialiased <> 0
          fontnfo\lfQuality = 4
        EndIf
        
        font = CreateFontIndirect_(@fontnfo)
        
        rc.RECT
        hdc = CreateCompatibleDC_(0)
        SelectObject_(hdc, font)
        renderTextLinePadding = textControlExLinePadding
        renderText(hdc, txtcontrol()\txt, @rc, 0, #DT_CALCRECT)
        DeleteDC_(hdc)
        
        If width = 0
          width = rc\right
          exwidth = textControlExLeftpad+textControlExRightpad
        EndIf
        If height = 0
          height = rc\bottom
          exheight = textControlExToppad+textControlExBottompad
        EndIf
        
        SetWindowPos_(txtcontrol()\Handle, 0, 0, 0, width+exwidth, height+exheight, #SWP_NOMOVE)
        
        RefreshPanelEx(txtcontrol()\Handle)
        
        ProcedureReturn #True
      EndIf
    Next
    
  EndIf
  
  ProcedureReturn 0

EndProcedure

ProcedureDLL SetTextControlExColour(id.i, textColour.l, backColour.l) ; Sets the text colour and backfill colour of a TextControlEx
  
  macro_protectCommand()
  
  If id = -1
  
    textControlExColour = textColour
    textControlExBKColour = backColour
    
    ProcedureReturn #True
    
  Else
    
    ForEach txtcontrol()
      If txtcontrol()\id = id Or txtcontrol()\Handle = id
        txtcontrol()\colour = textColour
        txtcontrol()\bkcolour = backColour
        
        RefreshPanelEx(txtcontrol()\Handle)
        
        ProcedureReturn #True
      EndIf
    Next
    
  EndIf
  
  ProcedureReturn 0
  
EndProcedure


ProcedureDLL SetTextControlExGradient(id.i, Gradient.i) ; Sets the background gradient of a TextControlEx
  
  macro_protectCommand()

  If id = -1
    
    textControlExGradient = Gradient
    
    ProcedureReturn #True
    
  Else
    
    ForEach txtcontrol()
      If txtcontrol()\id = id Or txtcontrol()\Handle = id
        
        txtcontrol()\Gradient = Gradient
        
        noRefresh = #True
        If txtcontrol()\flags & #TCX_BK_GRADIENT
          noRefresh = #False
        EndIf
        
        SetPanelExPageBackground(txtcontrol()\Handle, 0, Gradient, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, noRefresh)
        
        ProcedureReturn #True
      EndIf
    Next
    
  EndIf
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL SetTextControlExText(id.i, text.s) ; Sets the text of a TextControlEx
  
  ForEach txtcontrol()
    If txtcontrol()\id = id Or txtcontrol()\Handle = id
      txtcontrol()\txt = text

      If txtcontrol()\origwidth = 0 Or txtcontrol()\origheight = 0
        
        p = FindString(LCase(text), "\l", 1)
        If p > 0
          s = 1
          
          linkNo = 0
          Repeat
            
            t.s = Mid(text, s, p-s) ; copy txt before link into txt.s
            p+2 ; move position to start of link ID
            
            ;grab the ID of the link
            For n = p To Len(text)
              If Asc(Mid(text, n, 1)) < 48 Or Asc(Mid(text, n, 1)) > 57
                Break
              EndIf
            Next
            linkid = Val(Mid(text, p, n-p))
            
            ;grab all of link txt
            e = FindString(text, "\l", n)
            linktxt.s = Mid(text, n, e-n)
            
            linktxt = StringField(linktxt, 1, "|")
           
            txt.s = txt + t + "\l"+Str(linkid)+linktxt+"\l"
            
            s = e+2
            p = FindString(LCase(text), "\l", s)
            
            linkNo = linkNo + 1
            
          Until p = 0 Or e = 0
          If s < Len(text) And e <> 0
            txt = txt + Mid(text, s)
          EndIf
          
        Else
          txt.s = text
        EndIf
        
        rc.RECT
        hdc = CreateCompatibleDC_(0)
        If txtcontrol()\font <> 0
          SelectObject_(hdc, txtcontrol()\font)
        EndIf
        renderText(hdc, txt, @rc, 0, #DT_CALCRECT)
        DeleteDC_(hdc)
        
        If txtcontrol()\origwidth = 0
          txtcontrol()\width = rc\right
          exwidth = txtcontrol()\leftpad+txtcontrol()\rightpad
        EndIf
        If txtcontrol()\origheight = 0
          txtcontrol()\height = rc\bottom
          exheight = txtcontrol()\toppad+txtcontrol()\bottompad
        EndIf
        
      EndIf
      
      SetWindowPos_(txtcontrol()\Handle, 0, 0, 0, txtcontrol()\width+exwidth, txtcontrol()\height+exheight, #SWP_NOMOVE|#SWP_NOZORDER)
      
      RefreshPanelEx(txtcontrol()\Handle)
      
      ProcedureReturn #True
    EndIf
  Next
  
  ProcedureReturn 0
EndProcedure

ProcedureDLL.s GetTextControlExText(id.i) ; Returns the text of a TextControlEx
  
  ReturnString$ = ""
  
  ForEach txtcontrol()
    If txtcontrol()\id = id Or txtcontrol()\Handle = id
      
      ReturnString$ = txtcontrol()\txt
      
      Break
    EndIf
  Next
  
  ProcedureReturn ReturnString$
  
EndProcedure

ProcedureDLL SetTextControlExStyle(id.i, style.l) ; Sets the style flags for the specified TextControlEx
  
  macro_protectCommand()
  
  ForEach txtcontrol()
    If txtcontrol()\id = id Or txtcontrol()\Handle = id
      
      txtcontrol()\flags = style
      
      If txtcontrol()\flags & #TCX_BK_GRADIENT And txtcontrol()\Gradient <> 0
        SetPanelExPageBackground(txtcontrol()\Handle, 0, txtcontrol()\Gradient, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, #True)
      ElseIf Not txtcontrol()\flags & #TCX_BK_GRADIENT
        SetPanelExPageBackground(txtcontrol()\Handle, 0, -1, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, #PNLX_IGNORE, #True)
      EndIf
      
      RefreshPanelEx(txtcontrol()\Handle)
      
      ProcedureReturn #True
      
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL GetTextControlExStyle(id.i) ; Returns the style flags of the specified TextControlEx
  
  ForEach txtcontrol()
    If txtcontrol()\id = id Or txtcontrol()\Handle = id
      
      ProcedureReturn txtcontrol()\flags
      
    EndIf
  Next
  
  ProcedureReturn #False
  
EndProcedure

ProcedureDLL SetTextControlExLinePadding(id.i, padding.l) ; Sets the TextControlEx spacing between lines
  
  macro_protectCommand()
  
  If id = -1
  
    textControlExLinePadding = padding
    
  Else
    
    ForEach txtcontrol()
      If txtcontrol()\id = id Or txtcontrol()\Handle = id
        txtcontrol()\linePadding = padding
        
        If txtcontrol()\origwidth = 0 Or txtcontrol()\origheight = 0
          
          text.s = txtcontrol()\txt
          p = FindString(LCase(text), "\l", 1)
          If p > 0
            s = 1
            
            linkNo = 0
            Repeat
              
              t.s = Mid(text, s, p-s) ; copy txt before link into txt.s
              p+2 ; move position to start of link ID
              
              ;grab the ID of the link
              For n = p To Len(text)
                If Asc(Mid(text, n, 1)) < 48 Or Asc(Mid(text, n, 1)) > 57
                  Break
                EndIf
              Next
              linkid = Val(Mid(text, p, n-p))
              
              ;grab all of link txt
              e = FindString(text, "\l", n)
              linktxt.s = Mid(text, n, e-n)
              
              linktxt = StringField(linktxt, 1, "|")
             
              txt.s = txt + t + "\l"+Str(linkid)+linktxt+"\l"
              
              s = e+2
              p = FindString(LCase(text), "\l", s)
              
              linkNo = linkNo + 1
              
            Until p = 0 Or e = 0
            If s < Len(text) And e <> 0
              txt = txt + Mid(text, s)
            EndIf
          Else
            txt.s = txtcontrol()\txt
          EndIf
          
          rc.RECT
          hdc = CreateCompatibleDC_(0)
          If txtcontrol()\font <> 0
            SelectObject_(hdc, txtcontrol()\font)
          EndIf
          renderTextLinePadding = padding
          renderText(hdc, txt, @rc, 0, #DT_CALCRECT)
          DeleteDC_(hdc)
          
          If txtcontrol()\origwidth = 0
            txtcontrol()\width = rc\right
            exwidth = txtcontrol()\leftpad+txtcontrol()\rightpad
          EndIf
          If txtcontrol()\origheight = 0
            txtcontrol()\height = rc\bottom
            exheight = txtcontrol()\toppad+txtcontrol()\bottompad
          EndIf
        EndIf
        
        SetWindowPos_(txtcontrol()\Handle, 0, 0, 0, txtcontrol()\width+exwidth, txtcontrol()\height+exheight, #SWP_NOMOVE|#SWP_NOZORDER)
        
        RefreshPanelEx(txtcontrol()\Handle)
        
        ProcedureReturn #True
      EndIf
    Next
    
  EndIf
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL SetTextControlExDimensions(id.i, width.l, height.l) ; Sets the width/height of a previously created TextControlEx
  
  macro_protectCommand()

  
  ForEach txtcontrol()
    If txtcontrol()\id = id Or txtcontrol()\Handle = id
      
      txtcontrol()\origwidth = width
      txtcontrol()\origheight = height
      txtcontrol()\width = width
      txtcontrol()\height = height
      
      If txtcontrol()\origwidth = 0 Or txtcontrol()\origheight = 0
        
        text.s = txtcontrol()\txt
        p = FindString(LCase(text), "\l", 1)
        If p > 0
          s = 1
          
          linkNo = 0
          Repeat
            
            t.s = Mid(text, s, p-s) ; copy txt before link into txt.s
            p+2 ; move position to start of link ID
            
            ;grab the ID of the link
            For n = p To Len(text)
              If Asc(Mid(text, n, 1)) < 48 Or Asc(Mid(text, n, 1)) > 57
                Break
              EndIf
            Next
            linkid = Val(Mid(text, p, n-p))
            
            ;grab all of link txt
            e = FindString(text, "\l", n)
            linktxt.s = Mid(text, n, e-n)
            
            linktxt = StringField(linktxt, 1, "|")
           
            txt.s = txt + t + "\l"+Str(linkid)+linktxt+"\l"
            
            s = e+2
            p = FindString(LCase(text), "\l", s)
            
            linkNo = linkNo + 1
            
          Until p = 0 Or e = 0
          If s < Len(text) And e <> 0
            txt = txt + Mid(text, s)
          EndIf
        Else
          txt.s = txtcontrol()\txt
        EndIf
        
        rc.RECT
        hdc = CreateCompatibleDC_(0)
        If txtcontrol()\font <> 0
          SelectObject_(hdc, txtcontrol()\font)
        EndIf
        renderTextLinePadding = padding
        renderText(hdc, txt, @rc, 0, #DT_CALCRECT)
        DeleteDC_(hdc)
        
        If txtcontrol()\origwidth = 0
          txtcontrol()\width = rc\right
          exwidth = txtcontrol()\leftpad+txtcontrol()\rightpad
        EndIf
        If txtcontrol()\origheight = 0
          txtcontrol()\height = rc\bottom
          exheight = txtcontrol()\toppad+txtcontrol()\bottompad
        EndIf
      EndIf
      
      SetWindowPos_(txtcontrol()\Handle, 0, 0, 0, txtcontrol()\width+exwidth, txtcontrol()\height+exheight, #SWP_NOMOVE|#SWP_NOZORDER)
      
      RefreshPanelEx(txtcontrol()\Handle)
      
      ProcedureReturn #True
    EndIf
  Next
  
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL TextControlExWidth(id.i)  ; Returns the width in pixels of a TextControlEx
  
  ForEach txtcontrol()
    If txtcontrol()\id = id Or txtcontrol()\Handle = id
      
      GetWindowRect_(txtcontrol()\Handle, @rc.RECT)
      ProcedureReturn rc\right-rc\left
      
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL TextControlExHeight(id.i)  ; Returns the height in pixels of a TextControlEx
  
  ForEach txtcontrol()
    If txtcontrol()\id = id Or txtcontrol()\Handle = id
      
      GetWindowRect_(txtcontrol()\Handle, @rc.RECT)
      ProcedureReturn rc\bottom-rc\top
      
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL TextControlExCalcSize(id.i, Text.s, *width.integer, *height.integer) ; Calculates the width and height of the specified text into *width and *height.
  
  ForEach txtcontrol()
    If txtcontrol()\id = id Or txtcontrol()\Handle = id
      
      rc.RECT
      hdc = CreateCompatibleDC_(0)
      If txtcontrol()\font <> 0
        SelectObject_(hdc, txtcontrol()\font)
      EndIf
      renderText(hdc, Text, @rc, 0, #DT_CALCRECT)
      DeleteDC_(hdc)
      
      exwidth = txtcontrol()\leftpad+txtcontrol()\rightpad
      exheight = txtcontrol()\toppad+txtcontrol()\bottompad
      
      *width\i = rc\right+exwidth
      *height\i = rc\bottom+exheight
      
      ProcedureReturn #True
      
    EndIf
  Next
  
  ProcedureReturn #False
  
EndProcedure

ProcedureDLL TextControlExID(id.l)  ; Returns the Windows handle of a TextControlEx
  
  ForEach txtcontrol()
    If txtcontrol()\id = id
      ProcedureReturn txtcontrol()\Handle
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL FreeTextControlEx(id.i)  ; Frees a TextControlEx from memory.
  
  ForEach txtcontrol()
    If txtcontrol()\id = id Or txtcontrol()\Handle = id Or id = -1
      
      FreePanelEx(txtcontrol()\Handle)
      DeleteElement(txtcontrol())
      
      If id <> -1
        ProcedureReturn #True
      EndIf
      
    EndIf
  Next
  
  If id = -1
    ProcedureReturn #True
  EndIf
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL changeListiconSubIcon(listicon.i, itempos.l, subitempos.l, image.i)
  
  macro_protectCommand()
  
  CompilerIf #LIBRARY = 1
    If IsGadget(listicon)
      listicon = GadgetID(listicon)
    EndIf
  CompilerEndIf
  
  icons = SendMessage_(listicon, #LVM_GETIMAGELIST, #LVSIL_SMALL, 0)
  If icons <> 0
    
    SendMessage_(listicon, #LVM_SETEXTENDEDLISTVIEWSTYLE , #LVS_EX_SUBITEMIMAGES, #LVS_EX_SUBITEMIMAGES)

    ; try and find cached previous icon
    imagelistpos = -1
    ForEach lsicon()
      If lsicon()\image = image
        imagelistpos = lsicon()\imagelistpos
        Break
      EndIf
    Next

    If imagelistpos = -1
      
      imagelistpos = ImageList_ReplaceIcon_(icons, -1, image)
      
      LastElement(lsicon())
      AddElement(lsicon())
      lsicon()\imagelistpos = imagelistpos
      lsicon()\image = image
      
    EndIf
    
    item.LV_ITEM
    item\mask = #LVIF_IMAGE
    item\iItem = itempos
    item\iSubItem = subitempos
    item\iImage = imagelistpos

    SendMessage_(listicon, #LVM_SETITEM, 0, @item)
    
  EndIf
  
EndProcedure


;--
;- ButtonEx
;--
Procedure skinnedButtonExCallback(Window, message, wParam, lParam)
  Static mouseCaptured
  
  ; find associated buttonx
  ForEach buttonx()
    If buttonx()\pageHandle = Window
      found = #True
      Break
    EndIf
  Next
  
  If found = #False
    ProcedureReturn 0
  EndIf
  
  ; if noclip is true then paint above border
  If buttonx()\bkstyle & #PNLX_NOCLIP
    paintmsg = #WM_PAINT
  Else
    paintmsg = #WM_ERASEBKGND
  EndIf
  
  Select message
      
    Case #WM_MOUSEMOVE
      
      
      If mouseCaptured = 0 And buttonx()\disabled = #False
        
        tm.TRACKMOUSEEVENT
        tm\cbSize = SizeOf(TRACKMOUSEEVENT)
        tm\dwFlags = #TME_LEAVE
        tm\hwndTrack = Window
        TrackMouseEvent_(@tm)
        
        If buttonx()\toggle = #False
          buttonx()\index = 1 ; hot
        Else
          If buttonx()\selected = #False
            buttonx()\index = 1 ; hot
          ElseIf buttonx()\selected = #True
            buttonx()\index = 5 ; selected hot/hover
          ElseIf buttonx()\selected = #BUTTONEX_INBETWEEN
            buttonx()\index = 8 ; inbetween selected hot/hover
          EndIf
        EndIf
        
        i = buttonx()\index
        bk = buttonx()\bk[i]
        bkstyle = buttonx()\bkstyle[i]
        bkx = buttonx()\bkx[i]
        bky = buttonx()\bky[i]
        obk = buttonx()\obk[i]
        obkstyle = buttonx()\obkstyle[i]
        obkx = buttonx()\obkx[i]
        obky = buttonx()\obky[i]
        bkimage = buttonx()\bkimage[i]
        bkwidth = buttonx()\bkwidth[i]
        bkheight = buttonx()\bkheight[i]
        obkimage = buttonx()\obkimage[i]
        obkwidth = buttonx()\obkwidth[i]
        obkheight = buttonx()\obkheight[i]
        border = buttonx()\border[i]
        If buttonx()\borderrect[i]\left <> 0 And buttonx()\borderrect[i]\top <> 0 And buttonx()\borderrect[i]\bottom And buttonx()\borderrect[i]\right <> 0
          CopyStructure(buttonx()\borderrect[i], @rc.RECT, RECT)
          rectCreated = #True
        EndIf
        mask = buttonx()\mask[i]
        font = buttonx()\font[i]
        fontcolour = buttonx()\fontcolour[i]
        imgx = buttonx()\imgx[i]
        imgy = buttonx()\imgy[i]
        imgxpercent = buttonx()\imgxpercent[i]
        imgypercent = buttonx()\imgypercent[i]
        imgalign = buttonx()\imgalign[i]
        txtx = buttonx()\txtx[i]
        txty = buttonx()\txty[i]
        txtxpercent = buttonx()\txtxpercent[i]
        txtypercent = buttonx()\txtypercent[i]
        txtalign = buttonx()\txtalign[i]
        
        SetPanelExPageBackground(buttonx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
        SetPanelExPageBackground(buttonx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
        
        If rectCreated = #True
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, rc.RECT, 0, #True)
        Else
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, 0, 0, #True)
        EndIf
        
        If buttonx()\cursor <> 0
          SetPanelExPageCursor(buttonx()\Handle, 0, buttonx()\cursor[i])
        EndIf
        
        mouseCaptured = #True
        
        RefreshPanelEx(buttonx()\Handle)
      
      EndIf
    
    Case #WM_MOUSELEAVE
      
      If mouseCaptured = #True And buttonx()\disabled = #False
        
        mouseCaptured = #False
        
        If buttonx()\toggle = #False
          buttonx()\index = 0 ; normal
        Else
          If buttonx()\selected = #False
            buttonx()\index = 0 ; normal
          ElseIf buttonx()\selected = #True
            buttonx()\index = 4 ; selected normal
          ElseIf buttonx()\selected = #BUTTONEX_INBETWEEN
            buttonx()\index = 7 ; inbetween selected normal
          EndIf
        EndIf
        
        i = buttonx()\index
        bk = buttonx()\bk[i]
        bkstyle = buttonx()\bkstyle[i]
        bkx = buttonx()\bkx[i]
        bky = buttonx()\bky[i]
        obk = buttonx()\obk[i]
        obkstyle = buttonx()\obkstyle[i]
        obkx = buttonx()\obkx[i]
        obky = buttonx()\obky[i]
        bkimage = buttonx()\bkimage[i]
        bkwidth = buttonx()\bkwidth[i]
        bkheight = buttonx()\bkheight[i]
        obkimage = buttonx()\obkimage[i]
        obkwidth = buttonx()\obkwidth[i]
        obkheight = buttonx()\obkheight[i]
        border = buttonx()\border[i]
        If buttonx()\borderrect[i]\left <> 0 And buttonx()\borderrect[i]\top <> 0 And buttonx()\borderrect[i]\bottom And buttonx()\borderrect[i]\right <> 0
          CopyStructure(buttonx()\borderrect[i], @rc.RECT, RECT)
          rectCreated = #True
        EndIf
        mask = buttonx()\mask[i]
        font = buttonx()\font[i]
        fontcolour = buttonx()\fontcolour[i]
        imgx = buttonx()\imgx[i]
        imgy = buttonx()\imgy[i]
        imgxpercent = buttonx()\imgxpercent[i]
        imgypercent = buttonx()\imgypercent[i]
        imgalign = buttonx()\imgalign[i]
        txtx = buttonx()\txtx[i]
        txty = buttonx()\txty[i]
        txtxpercent = buttonx()\txtxpercent[i]
        txtypercent = buttonx()\txtypercent[i]
        txtalign = buttonx()\txtalign[i]
        
        SetPanelExPageBackground(buttonx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
        SetPanelExPageBackground(buttonx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
        
        If rectCreated = #True
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, rc.RECT, 0, #True)
        Else
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, 0, 0, #True)
        EndIf
        
        If buttonx()\cursor <> 0
          SetPanelExPageCursor(buttonx()\Handle, 0, buttonx()\cursor[i])
        EndIf
        
        RefreshPanelEx(buttonx()\Handle)
        
      EndIf
      
    Case #WM_LBUTTONDOWN
      
      If buttonx()\disabled = #False
        
        If buttonx()\toggle = #False
          buttonx()\index = 2 ; pressed
        Else
          If buttonx()\selected = #False
            buttonx()\index = 2 ; pressed
          ElseIf buttonx()\selected = #True
            buttonx()\index = 6 ; pressed selected
          ElseIf buttonx()\selected = #BUTTONEX_INBETWEEN
            buttonx()\index = 9 ; inbetween pressed selected
          EndIf
        EndIf
        
        i = buttonx()\index
        bk = buttonx()\bk[i]
        bkstyle = buttonx()\bkstyle[i]
        bkx = buttonx()\bkx[i]
        bky = buttonx()\bky[i]
        obk = buttonx()\obk[i]
        obkstyle = buttonx()\obkstyle[i]
        obkx = buttonx()\obkx[i]
        obky = buttonx()\obky[i]
        bkimage = buttonx()\bkimage[i]
        bkwidth = buttonx()\bkwidth[i]
        bkheight = buttonx()\bkheight[i]
        obkimage = buttonx()\obkimage[i]
        obkwidth = buttonx()\obkwidth[i]
        obkheight = buttonx()\obkheight[i]
        border = buttonx()\border[i]
        If buttonx()\borderrect[i]\left <> 0 And buttonx()\borderrect[i]\top <> 0 And buttonx()\borderrect[i]\bottom And buttonx()\borderrect[i]\right <> 0
          CopyStructure(buttonx()\borderrect[i], @rc.RECT, RECT)
          rectCreated = #True
        EndIf
        mask = buttonx()\mask[i]
        font = buttonx()\font[i]
        fontcolour = buttonx()\fontcolour[i]
        imgx = buttonx()\imgx[i]
        imgy = buttonx()\imgy[i]
        imgxpercent = buttonx()\imgxpercent[i]
        imgypercent = buttonx()\imgypercent[i]
        imgalign = buttonx()\imgalign[i]
        txtx = buttonx()\txtx[i]
        txty = buttonx()\txty[i]
        txtxpercent = buttonx()\txtxpercent[i]
        txtypercent = buttonx()\txtypercent[i]
        txtalign = buttonx()\txtalign[i]
        
        SetPanelExPageBackground(buttonx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
        SetPanelExPageBackground(buttonx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
        
        If rectCreated = #True
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, rc.RECT, 0, #True)
        Else
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, 0, 0, #True)
        EndIf
        
        If buttonx()\cursor <> 0
          SetPanelExPageCursor(buttonx()\Handle, 0, buttonx()\cursor[i])
        EndIf
        
        RefreshPanelEx(buttonx()\Handle)
        
      EndIf
    
    Case #WM_LBUTTONUP
      
      If buttonx()\disabled = #False
        
        If buttonx()\toggle = #False
          buttonx()\index = 1 ; hot
        Else
          If buttonx()\selected = #False
            ; radio button
            If buttonx()\radio = #True
              ; check all other radio buttons of same group and deselect active
              *thisButtonx = @buttonx()
              group = buttonx()\radioGroup
              ForEach buttonx()
                If buttonx()\radio = #True And buttonx()\radioGroup = group And buttonx()\selected = #True
                  buttonx()\selected = #False
                  buttonx()\index = 0
                  
                  i = buttonx()\index
                  bk = buttonx()\bk[i]
                  bkstyle = buttonx()\bkstyle[i]
                  bkx = buttonx()\bkx[i]
                  bky = buttonx()\bky[i]
                  obk = buttonx()\obk[i]
                  obkstyle = buttonx()\obkstyle[i]
                  obkx = buttonx()\obkx[i]
                  obky = buttonx()\obky[i]
                  bkimage = buttonx()\bkimage[i]
                  bkwidth = buttonx()\bkwidth[i]
                  bkheight = buttonx()\bkheight[i]
                  obkimage = buttonx()\obkimage[i]
                  obkwidth = buttonx()\obkwidth[i]
                  obkheight = buttonx()\obkheight[i]
                  border = buttonx()\border[i]
                  If buttonx()\borderrect[i]\left <> 0 And buttonx()\borderrect[i]\top <> 0 And buttonx()\borderrect[i]\bottom And buttonx()\borderrect[i]\right <> 0
                    CopyStructure(buttonx()\borderrect[i], @rc.RECT, RECT)
                    rectCreated = #True
                  EndIf
                  mask = buttonx()\mask[i]
                  font = buttonx()\font[i]
                  fontcolour = buttonx()\fontcolour[i]
                  imgx = buttonx()\imgx[i]
                  imgy = buttonx()\imgy[i]
                  imgxpercent = buttonx()\imgxpercent[i]
                  imgypercent = buttonx()\imgypercent[i]
                  imgalign = buttonx()\imgalign[i]
                  txtx = buttonx()\txtx[i]
                  txty = buttonx()\txty[i]
                  txtxpercent = buttonx()\txtxpercent[i]
                  txtypercent = buttonx()\txtypercent[i]
                  txtalign = buttonx()\txtalign[i]
                  
                  SetPanelExPageBackground(buttonx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
                  SetPanelExPageBackground(buttonx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
                  
                  If rectCreated = #True
                    SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, rc.RECT, 0, #True)
                    rectCreated = #False
                  Else
                    SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, 0, 0, #True)
                  EndIf
                  
                  If buttonx()\cursor <> 0
                    SetPanelExPageCursor(buttonx()\Handle, 0, buttonx()\cursor[i])
                  EndIf
                  
                  RefreshPanelEx(buttonx()\Handle)
                  Break
                EndIf
              Next
              ChangeCurrentElement(buttonx(), *thisButtonx)
              buttonx()\index = 5 ; selected hot/hover
              buttonx()\selected = #True
            Else
              buttonx()\index = 5 ; selected hot/hover
              buttonx()\selected = #True
            EndIf
          ElseIf buttonx()\selected = #True
            buttonx()\index = 1 ; hot
            buttonx()\selected = #False
            ; radio button
            If buttonx()\radio = #True
              buttonx()\index = 5 ; selected hot/hover
              buttonx()\selected = #True
            EndIf
          ElseIf buttonx()\selected = #BUTTONEX_INBETWEEN
              buttonx()\index = 5 ; selected hot/hover
              buttonx()\selected = #True
          EndIf
        EndIf
          
        *this = @buttonx()
        
        i = buttonx()\index
        bk = buttonx()\bk[i]
        bkstyle = buttonx()\bkstyle[i]
        bkx = buttonx()\bkx[i]
        bky = buttonx()\bky[i]
        obk = buttonx()\obk[i]
        obkstyle = buttonx()\obkstyle[i]
        obkx = buttonx()\obkx[i]
        obky = buttonx()\obky[i]
        bkimage = buttonx()\bkimage[i]
        bkwidth = buttonx()\bkwidth[i]
        bkheight = buttonx()\bkheight[i]
        obkimage = buttonx()\obkimage[i]
        obkwidth = buttonx()\obkwidth[i]
        obkheight = buttonx()\obkheight[i]
        border = buttonx()\border[i]
        If buttonx()\borderrect[i]\left <> 0 And buttonx()\borderrect[i]\top <> 0 And buttonx()\borderrect[i]\bottom And buttonx()\borderrect[i]\right <> 0
          CopyStructure(buttonx()\borderrect[i], @rc.RECT, RECT)
          rectCreated = #True
        EndIf
        mask = buttonx()\mask[i]
        font = buttonx()\font[i]
        fontcolour = buttonx()\fontcolour[i]
        imgx = buttonx()\imgx[i]
        imgy = buttonx()\imgy[i]
        imgxpercent = buttonx()\imgxpercent[i]
        imgypercent = buttonx()\imgypercent[i]
        imgalign = buttonx()\imgalign[i]
        txtx = buttonx()\txtx[i]
        txty = buttonx()\txty[i]
        txtxpercent = buttonx()\txtxpercent[i]
        txtypercent = buttonx()\txtypercent[i]
        txtalign = buttonx()\txtalign[i]
        
        SetPanelExPageBackground(buttonx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
        SetPanelExPageBackground(buttonx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
        
        If rectCreated = #True
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, rc.RECT, 0, #True)
        Else
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, 0, 0, #True)
        EndIf
        
        If buttonx()\cursor <> 0
          SetPanelExPageCursor(buttonx()\Handle, 0, buttonx()\cursor[i])
        EndIf
        
        RefreshPanelEx(buttonx()\Handle)
        
        ChangeCurrentElement(buttonx(), *this)
        PostMessage_(GetParent_(GetParent_(Window)), #WM_COMMAND, buttonx()\id, 0)
      EndIf
    
    Case #WM_CAPTURECHANGED
      
      If buttonx()\disabled = #False
        
        If mouseCaptured = #True
          mouseCaptured = #False
          
          If buttonx()\toggle = #False
            buttonx()\index = 0 ; normal
          Else
            If buttonx()\selected = #False
              buttonx()\index = 0 ; normal
            ElseIf buttonx()\selected = #True
              buttonx()\index = 4 ; selected normal
            ElseIf buttonx()\selected = #BUTTONEX_INBETWEEN
              buttonx()\index = 7 ; selected normal
            EndIf
          EndIf
          
          i = buttonx()\index
          bk = buttonx()\bk[i]
          bkstyle = buttonx()\bkstyle[i]
          bkx = buttonx()\bkx[i]
          bky = buttonx()\bky[i]
          obk = buttonx()\obk[i]
          obkstyle = buttonx()\obkstyle[i]
          obkx = buttonx()\obkx[i]
          obky = buttonx()\obky[i]
          bkimage = buttonx()\bkimage[i]
          bkwidth = buttonx()\bkwidth[i]
          bkheight = buttonx()\bkheight[i]
          obkimage = buttonx()\obkimage[i]
          obkwidth = buttonx()\obkwidth[i]
          obkheight = buttonx()\obkheight[i]
          border = buttonx()\border[i]
          If buttonx()\borderrect[i]\left <> 0 And buttonx()\borderrect[i]\top <> 0 And buttonx()\borderrect[i]\bottom And buttonx()\borderrect[i]\right <> 0
            CopyStructure(buttonx()\borderrect[i], @rc.RECT, RECT)
            rectCreated = #True
          EndIf
          mask = buttonx()\mask[i]
          font = buttonx()\font[i]
          fontcolour = buttonx()\fontcolour[i]
          imgx = buttonx()\imgx[i]
          imgy = buttonx()\imgy[i]
          imgxpercent = buttonx()\imgxpercent[i]
          imgypercent = buttonx()\imgypercent[i]
          imgalign = buttonx()\imgalign[i]
          txtx = buttonx()\txtx[i]
          txty = buttonx()\txty[i]
          txtxpercent = buttonx()\txtxpercent[i]
          txtypercent = buttonx()\txtypercent[i]
          txtalign = buttonx()\txtalign[i]
          
          SetPanelExPageBackground(buttonx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
          SetPanelExPageBackground(buttonx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
          
          If rectCreated = #True
            SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, rc.RECT, 0, #True)
          Else
            SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, 0, 0, #True)
          EndIf
          
          If buttonx()\cursor <> 0
            SetPanelExPageCursor(buttonx()\Handle, 0, buttonx()\cursor[i])
          EndIf
          
          RefreshPanelEx(buttonx()\Handle)
          
        EndIf
      EndIf
      
    
    Case paintmsg
      
      dc = wParam
     
      GetClientRect_(Window, @rc.RECT)
      
      If buttonx()\disabled = #True
        index = 3
      Else
        index = buttonx()\index
      EndIf
      
      imgx = buttonx()\imgx[index]
      imgy = buttonx()\imgy[index]
      oimgx = imgx
      oimgy = imgy
      imgWidth = buttonx()\imgWidth
      imgHeight = buttonx()\imgHeight
      
      If buttonx()\imgxpercent = #True
      
        imgx = Round((((rc\right-rc\left)/100.0)*imgx)-(imgWidth/2), #PB_Round_Down)
      
      EndIf
      
      If buttonx()\imgypercent = #True
      
        imgy = Round((((rc\bottom-rc\top)/100.0)*imgy)-(imgHeight/2), #PB_Round_Down)
      
      EndIf
      
      ; right align
      If buttonx()\imgalign & #BUTTONEX_ALIGN_RIGHT
        imgx = ((rc\right-rc\left)-imgWidth)-imgx
      EndIf
      
      ; bottom align
      If buttonx()\imgalign & #BUTTONEX_ALIGN_BOTTOM
        imgy = ((rc\bottom-rc\top)-imgHeight)-imgy
      EndIf
      
      
      font = DefaultFont
      If buttonx()\font[index] <> 0
        font = buttonx()\font[index]
      EndIf
      
      
      txtx = buttonx()\txtx[index]
      txty = buttonx()\txty[index]
      otxtx = txtx
      otxty = txty
      renderTextLinePadding = 0
      renderText(dc, buttonx()\txt, @rec.RECT, font, #DT_CALCRECT)
      txtWidth = rec\right-rec\left
      txtHeight = rec\bottom-rec\top
      
      If buttonx()\txtxpercent = #True
        txtx = Round((((rc\right-rc\left)/100.0)*txtx)-(txtWidth/2), #PB_Round_Down)
      EndIf
      
      If buttonx()\txtypercent = #True
        txty = Round((((rc\bottom-rc\top)/100.0)*txty)-(txtHeight/2), #PB_Round_Down)
      EndIf
      
      ; right align
      If buttonx()\txtalign & #BUTTONEX_ALIGN_RIGHT
        txtx = ((rc\right-rc\left)-txtWidth)-txtx
      EndIf
      
      ; bottom align
      If buttonx()\txtalign & #BUTTONEX_ALIGN_BOTTOM
        txty = ((rc\bottom-rc\top)-txtHeight)-txty
      EndIf
      
      If imgx < buttonx()\imgpad[index]\left
        imgx = buttonx()\imgpad[index]\left
      ElseIf imgx+imgWidth > (rc\right-rc\left)-buttonx()\imgpad[index]\right
        imgx = (rc\right-rc\left)-(ImgWidth+buttonx()\imgpad[index]\right)
      EndIf
      If imgy < buttonx()\imgpad[index]\top
        imgy = buttonx()\imgpad[index]\top
      ElseIf imgy+imgHeight > (rc\bottom-rc\top)-buttonx()\imgpad[index]\bottom
        imgy = (rc\bottom-rc\top)-(ImgHeight+buttonx()\imgpad[index]\bottom)
      EndIf
      
      If txtx < buttonx()\txtpad[index]\left
        txtx = buttonx()\txtpad[index]\left
      ElseIf txtx+txtWidth > (rc\right-rc\left)-buttonx()\txtpad[index]\right
        txtx = (rc\right-rc\left)-(txtWidth+buttonx()\txtpad[index]\right)
      EndIf
      If txty < buttonx()\txtpad[index]\top
        txty = buttonx()\txtpad[index]\top
      ElseIf txty+txtHeight > (rc\bottom-rc\top)-buttonx()\txtpad[index]\bottom
        txty = (rc\bottom-rc\top)-(txtHeight+buttonx()\txtpad[index]\bottom)
      EndIf
      
      If ImageList_GetImageCount_(buttonx()\ImageLists[0]) > 0 And buttonx()\txt <> ""
        If (txtx >= imgx-buttonx()\imgpad[index]\left And txtx <= imgx+imgWidth+buttonx()\imgpad[index]\right) Or (imgx >= txtx-buttonx()\txtpad[index]\left And imgx <= txtx+txtWidth+buttonx()\txtpad[index]\right)
          If (txty >= imgy-buttonx()\imgpad[index]\top And txty <= imgy+imgHeight+buttonx()\imgpad[index]\bottom) Or (imgy >= txty-buttonx()\txtpad[index]\top And imgy <= txty+txtHeight+buttonx()\txtpad[index]\bottom)
            
            If buttonx()\imgalign & #BUTTONEX_ALIGN_RIGHT
              If oimgx = 50 And buttonx()\imgxpercent ; centred
                txtx = ((rc\right-rc\left)/2)-((txtWidth+buttonx()\txtpad[index]\right+buttonx()\imgpad[index]\left+imgWidth)/2)
                If txtx < buttonx()\txtpad[index]\left
                  txtx = buttonx()\txtpad[index]\left
                EndIf
              EndIf
              imgx = txtx+txtWidth+buttonx()\txtpad[index]\right
              imgx + buttonx()\imgpad[index]\left
            ElseIf Not buttonx()\imgalign & #BUTTONEX_ALIGN_RIGHT Or buttonx()\txtalign & #BUTTONEX_ALIGN_RIGHT
              If otxtx = 50 And buttonx()\txtxpercent ; centred
                imgx = ((rc\right-rc\left)/2)-((ImgWidth+buttonx()\imgpad[index]\right+buttonx()\txtpad[index]\left+txtWidth)/2)
                If imgx < buttonx()\imgpad[index]\left
                  imgx = buttonx()\imgpad[index]\left
                EndIf
              EndIf
              txtx = imgx+ImgWidth+buttonx()\imgpad[index]\right
              txtx + buttonx()\txtpad[index]\left
            EndIf
            
          EndIf
        EndIf
      EndIf
      
      
      If buttonx()\fontcolour[index] = 0
        If buttonx()\disabled = #False
          SetTextColor_(dc, GetSysColor_(#COLOR_BTNTEXT))
        Else
          SetTextColor_(dc, GetSysColor_(#COLOR_GRAYTEXT))
        EndIf
      Else
        SetTextColor_(dc, buttonx()\fontcolour[index])
      EndIf
      
      If buttonx()\disabled = #True
        overideColour = #DT_OVERRIDECOLOUR
      EndIf
      
      If txtx < rc\left+buttonx()\txtpad[index]\left
        txtx = rc\left+buttonx()\txtpad[index]\left
      EndIf
      
      rec.RECT
      rec\left = txtx
      rec\top = txty
      rec\right = rc\right-buttonx()\txtpad[index]\right
      rec\bottom = txty+txtHeight
      renderText(dc, buttonx()\txt, rec, font, #TCX_TOP|#TCX_END_ELLIPSIS|overideColour)
      
      
      If ImageList_GetImageCount_(buttonx()\ImageLists[index]) > 0
        ImageList_Draw_(buttonx()\ImageLists[index], 0, dc, imgx, imgy, #ILD_NORMAL)
      Else
        If buttonx()\disabled = #False
          ImageList_Draw_(buttonx()\ImageLists[0], 0, dc, imgx, imgy, #ILD_NORMAL)
        Else
          ImageList_DrawEx_(buttonx()\ImageLists[0], 0, dc, imgx, imgy, 0, 0, 0, 0, #ILD_TRANSPARENT|#ILD_BLEND50)
        EndIf
      EndIf
      
    ; handle update skin notification
    Case #WM_UPDATESKIN
      
      ; respond to a request to update all skinned controls or controls using the skin specified in lParam
      If lParam = #False Or lParam = buttonx()\skin
        
        ; only update if our skin has SkinAutoUpdate set
        If GetSkinAutoUpdate(buttonx()\skin) = #True
          ;Static z
          ;debuglog("setting button skin "+Str(z)) : z + 1
          SetButtonExSkin(buttonx()\Handle, buttonx()\skin, "", #True)
        EndIf
          
      EndIf
      
  EndSelect
  
  ProcedureReturn Result
EndProcedure


ProcedureDLL SetButtonExSkin(ID.i, Skin.i, ComponentName.s, noRefresh.b) ; Sets a ButtonEx's skin
  
  macro_protectCommand()
  
  ;find buttonex
  ForEach buttonx()
    If buttonx()\handle = ID Or buttonx()\id = ID
      foundButtonx = #True
      Break
    EndIf
  Next
  
  ;find skin
  ForEach skin()
    If @skin() = Skin
      foundSkin = #True
      Break
    EndIf
  Next
  
  If foundButtonx = #True And foundSkin = #True
    
    If ComponentName = "" And buttonx()\componentname = ""
      ComponentName = "buttonex"
    ElseIf ComponentName = "" And buttonx()\componentname <> ""
      ComponentName = buttonx()\componentname
    EndIf
    
    For i = 0 To #buttonexstates-1
      
      bk = 0
      bkstyle = 0
      bkx = 0
      bky = 0
      obk = 0
      obkstyle = 0
      obkx = 0
      obky = 0
      bkimage = 0
      bkwidth = 0
      bkheight = 0
      obkimage = 0
      obkwidth = 0
      obkheight = 0
      border = 0
      mask = 0
      font = 0
      fontcolour = 0
      imgx = 0
      imgy = 0
      imgxpercent = 0
      imgypercent = 0
      imgAlign = 0
      txtx = 0
      txty = 0
      txtxpercent = 0
      txtypercent = 0
      txtAlign = 0
      borderstretch.RECT
      
      Select i
          Case 0
            state$ = "normal"
          Case 1
            state$ = "hot"
          Case 2
            state$ = "pressed"
          Case 3
            state$ = "disabled"
          Case 4
            state$ = "selected"
          Case 5
            state$ = "selected hot"
          Case 6
            state$ = "selected pressed"
          Case 7
            state$ = "inbetween"
          Case 8
            state$ = "inbetween hot"
          Case 9
            state$ = "inbetween pressed"
      EndSelect
      
      
      bk = -1
      
      bkimage = GetSkinPropertyData(skin, ComponentName, state$, "background image")
      If bkimage = 0
        bkimage = nullicon
      EndIf
      
      xpos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "x")
      If FindString(xpos, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_HPERCENT
      EndIf
      If xpos <> ""
        If xpos = "centre"
          bkstyle = bkstyle | #PNLX_CENTRE
        ElseIf xpos = "repeat"
          bkstyle = bkstyle | #PNLX_HREPEAT
        Else
          bkx = Val(xpos)
        EndIf
      EndIf
      
      ypos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "y")
      If FindString(ypos, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_VPERCENT
      EndIf
      If ypos <> ""
        If ypos = "centre"
          bkstyle = bkstyle | #PNLX_VCENTRE
        ElseIf ypos = "repeat"
          bkstyle = bkstyle | #PNLX_VREPEAT
        Else
          bky = Val(ypos)
        EndIf
      EndIf
      
      left.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "left")
      If FindString(left, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_HPERCENT
      EndIf
      If left <> ""
        If left = "centre"
          bkstyle = bkstyle | #PNLX_CENTRE
        ElseIf left = "repeat"
          bkstyle = bkstyle | #PNLX_HREPEAT
        Else
          bkx = Val(left)
        EndIf
      EndIf
      
      top.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "top")
      If FindString(top, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_VPERCENT
      EndIf
      If top <> ""
        If top = "centre"
          bkstyle = bkstyle | #PNLX_VCENTRE
        ElseIf top = "repeat"
          bkstyle = bkstyle | #PNLX_VREPEAT
        Else
          bky = Val(top)
        EndIf
      EndIf
      
      right.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "right")
      If FindString(right, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_HPERCENT
      EndIf
      If right <> ""
        If right = "centre"
          bkstyle = bkstyle | #PNLX_CENTRE
        ElseIf right = "repeat"
          bkstyle = bkstyle | #PNLX_HREPEAT
        Else
          bkx = Val(right)
          bkstyle = bkstyle | #PNLX_RIGHT
        EndIf
      EndIf
      
      bottom.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "bottom")
      If FindString(bottom, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_VPERCENT
      EndIf
      If bottom <> ""
        If bottom = "centre"
          bkstyle = bkstyle | #PNLX_VCENTRE
        ElseIf bottom = "repeat"
          bkstyle = bkstyle | #PNLX_VREPEAT
        Else
          bky = Val(bottom)
          bkstyle = bkstyle | #PNLX_BOTTOM
        EndIf
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "stretch") = "true"
        bkstyle = bkstyle | #PNLX_STRETCH
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "tile") = "true"
        bkstyle = bkstyle | #PNLX_TILE
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "masked") = "true"
        bkstyle = bkstyle | #PNLX_MASKED
      EndIf
      
      p.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background", "gradient")
      If p <> ""
        gradient = GetSkinPropertyData(skin, ComponentName, state$, "background")
        If gradient <> 0 And GetSkinPropertyDataSize(skin, ComponentName, state$, "background") <> 0
          bk = gradient
        EndIf
      Else
        c = GetSkinPropertyColour(skin, ComponentName, state$, "background")
        If c <> -1
          ; no alpha then remake colour with alpha
          If Alpha(c) = 0
            c = MakeColor(255, Red(c), Green(c), Blue(c))
          EndIf
          
          bk = CreateGradient(0, c, c)
          If bk <> 0
            SetSkinPropertyData(skin, ComponentName, state$, "background", bk)
            SetSkinPropertyDataSize(skin, ComponentName, state$, "background", SizeOf(bk))
          EndIf
        Else
          bk = Val(GetSkinPropertyp(skin, ComponentName, state$, "background"))
        EndIf
      EndIf
      
      ; border image
      border = GetSkinPropertyData(skin, ComponentName, state$, "border image")
      t = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "top"))
      l = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "left"))
      b = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "bottom"))
      r = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "right"))
      If border <> 0 And t > 0 And l > 0 And b > 0 And r > 0
        rc.RECT
        rc\top = t
        rc\left = l
        rc\bottom = b
        rc\right = r
        rectCreated = #True
      EndIf
      borderstretch$ = GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "stretch")
      If borderstretch$ <> ""
        borderstretch\top = #False
        borderstretch\left = #False
        borderstretch\bottom = #False
        borderstretch\right = #False
        If FindString(LCase(borderstretch$), "top") > 0
          borderstretch\top = #True
        EndIf
        If FindString(LCase(borderstretch$), "left") > 0
          borderstretch\left = #True
        EndIf
        If FindString(LCase(borderstretch$), "bottom") > 0
          borderstretch\bottom = #True
        EndIf
        If FindString(LCase(borderstretch$), "right") > 0
          borderstretch\right = #True
        EndIf
      EndIf
      mask = GetSkinPropertyData(skin, ComponentName, state$, "border mask")
      If mask = 0
        mask = Val(GetSkinPropertyp(skin, ComponentName, state$, "border mask"))
      EndIf
      
      ;If rectCreated = #False
        t = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "top"))
        l = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "left"))
        b = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "bottom"))
        r = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "right"))
        If mask <> 0 And t > 0 And l > 0 And b > 0 And r > 0
          rc.RECT
          rc\top = t
          rc\left = l
          rc\bottom = b
          rc\right = r
          rectCreated = #True
        EndIf
      ;EndIf
      
      ; overlay
      obkimage = GetSkinPropertyData(skin, ComponentName, state$, "overlay image")
      If obkimage = 0
        obkimage = nullicon
      EndIf
      
      oxpos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "x")
      If FindString(oxpos, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_HPERCENT
      EndIf
      If oxpos <> ""
        If oxpos = "centre"
          obkstyle = obkstyle | #PNLX_CENTRE
        ElseIf oxpos = "repeat"
          obkstyle = obkstyle | #PNLX_HREPEAT
        Else
          obkx = Val(oxpos)
        EndIf
      EndIf
      
      oypos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "y")
      If FindString(oypos, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_VPERCENT
      EndIf
      If oypos <> ""
        If oypos = "centre"
          obkstyle = obkstyle | #PNLX_VCENTRE
        ElseIf oypos = "repeat"
          obkstyle = obkstyle | #PNLX_VREPEAT
        Else
          obky = Val(oypos)
        EndIf
      EndIf
      
      left.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "left")
      If FindString(left, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_HPERCENT
      EndIf
      If left <> ""
        If left = "centre"
          obkstyle = obkstyle | #PNLX_CENTRE
        ElseIf left = "repeat"
          obkstyle = obkstyle | #PNLX_HREPEAT
        Else
          obkx = Val(left)
        EndIf
      EndIf
      
      top.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "top")
      If FindString(top, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_VPERCENT
      EndIf
      If top <> ""
        If top = "centre"
          obkstyle = obkstyle | #PNLX_VCENTRE
        ElseIf top = "repeat"
          obkstyle = obkstyle | #PNLX_VREPEAT
        Else
          obky = Val(top)
        EndIf
      EndIf
      
      right.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "right")
      If FindString(right, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_HPERCENT
      EndIf
      If right <> ""
        If right = "centre"
          obkstyle = obkstyle | #PNLX_CENTRE
        ElseIf right = "repeat"
          obkstyle = obkstyle | #PNLX_HREPEAT
        Else
          obkx = Val(right)
          obkstyle = obkstyle | #PNLX_RIGHT
        EndIf
      EndIf
      
      bottom.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "bottom")
      If FindString(bottom, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_VPERCENT
      EndIf
      If bottom <> ""
        If bottom = "centre"
          obkstyle = obkstyle | #PNLX_VCENTRE
        ElseIf bottom = "repeat"
          obkstyle = obkstyle | #PNLX_VREPEAT
        Else
          obky = Val(bottom)
          obkstyle = obkstyle | #PNLX_BOTTOM
        EndIf
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "stretch") = "true"
        obkstyle = obkstyle | #PNLX_STRETCH
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "tile") = "true"
        obkstyle = obkstyle | #PNLX_TILE
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "masked") = "true"
        obkstyle = obkstyle | #PNLX_MASKED
      EndIf
      
      p.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay", "gradient")
      If p <> ""
        gradient = GetSkinPropertyData(skin, ComponentName, state$, "overlay")
        If gradient <> 0 And GetSkinPropertyDataSize(skin, ComponentName, state$, "overlay") <> 0
          obk = gradient
        EndIf
      Else
        c = GetSkinPropertyColour(skin, ComponentName, state$, "overlay")
        If c <> -1
          ; no alpha then remake colour with alpha
          If Alpha(c) = 0
            c = MakeColor(255, Red(c), Green(c), Blue(c))
          EndIf
          
          obk = CreateGradient(0, c, c)
          If obk <> 0
            SetSkinPropertyData(skin, ComponentName, state$, "overlay", obk)
            SetSkinPropertyDataSize(skin, ComponentName, state$, "overlay", SizeOf(obk))
          EndIf
        Else
          If GetSkinPropertyp(skin, ComponentName, state$, "overlay") = ""
            obk = -1
          Else
            obk = Val(GetSkinPropertyp(skin, ComponentName, state$, "overlay"))
          EndIf
        EndIf
      EndIf
      
      
      ; image
      
      ; add image from skin if exists and no user specified image for state
      image = GetSkinPropertyData(skin, ComponentName, state$, "image")
      If image <> 0 ;And (ImageList_GetImageCount_(buttonx()\ImageLists[i]) = 0 Or ComponentName = "CheckButtonEx")
        GetImageDimensions(image, @imageWidth, @imageHeight)
        buttonx()\imgWidth = ImageWidth
        buttonx()\imgHeight = ImageHeight
        ImageList_Destroy_(buttonx()\ImageLists[i])
        buttonx()\ImageLists[i] = ImageList_Create_(imageWidth, imageHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
        ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[i], -1, image)
        If ret = -1
          ImageList_AddMasked_(buttonx()\ImageLists[i], image, RGB(0,255,0))
        EndIf
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "image", "noclip") = "true"
        bkstyle = bkstyle | #PNLX_NOCLIP
      EndIf
      
      imgxs.s = GetSkinPropertyParamp(skin, ComponentName, state$, "image position", "x")
      If FindString(imgxs, "%", 1) > 0
        imgxpercent = #True
      EndIf
      If imgxs <> ""
        If imgxs = "centre"
          imgxpercent = #True
          imgx = 50
        Else
          imgx = Val(imgxs)
        EndIf
      EndIf
      
      imgys.s = GetSkinPropertyParamp(skin, ComponentName, state$, "image position", "y")
      If FindString(imgys, "%", 1) > 0
        imgypercent = #True
      EndIf
      If imgys <> ""
        If imgys = "centre"
          imgypercent = #True
          imgy = 50
        Else
          imgy = Val(imgys)
        EndIf
      EndIf
      
      imgxs.s = GetSkinPropertyParamp(skin, ComponentName, state$, "image position", "left")
      If FindString(imgxs, "%", 1) > 0
        imgxpercent = #True
      EndIf
      If imgxs <> ""
        If imgxs = "centre"
          imgxpercent = #True
          imgx = 50
        Else
          imgx = Val(imgxs)
        EndIf
      EndIf
      
      imgys.s = GetSkinPropertyParamp(skin, ComponentName, state$, "image position", "top")
      If FindString(imgys, "%", 1) > 0
        imgypercent = #True
      EndIf
      If imgys <> ""
        If imgys = "centre"
          imgypercent = #True
          imgy = 50
        Else
          imgy = Val(imgys)
        EndIf
      EndIf
      
      imgys.s = GetSkinPropertyParamp(skin, ComponentName, state$, "image position", "bottom")
      If FindString(imgys, "%", 1) > 0
        imgypercent = #True
      EndIf
      If imgys <> ""
        If imgys = "centre"
          imgypercent = #True
          imgy = 50
        Else
          imgAlign = imgAlign | #BUTTONEX_ALIGN_BOTTOM
          imgy = Val(imgys)
        EndIf
      EndIf
      
      imgxs.s = GetSkinPropertyParamp(skin, ComponentName, state$, "image position", "right")
      If FindString(imgxs, "%", 1) > 0
        imgxpercent = #True
      EndIf
      If imgxs <> ""
        If imgxs = "centre"
          imgxpercent = #True
          imgx = 50
        Else
          imgAlign = imgAlign | #BUTTONEX_ALIGN_RIGHT
          imgx = Val(imgxs)
        EndIf
      EndIf
      
      imgpad.paddings
      imgpad\top = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "image padding", "top"))
      imgpad\left = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "image padding", "left"))
      imgpad\bottom = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "image padding", "bottom"))
      imgpad\right = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "image padding", "right"))
      
      
      ; text
      If CountSkinPropertySubParams(skin, ComponentName, state$, "text", "font") > 1
        font = FontID(GetSkinPropertyData(skin, ComponentName, state$, "text"))
      EndIf
      
      fontcolour = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "text", "colour"))
      
      
      txtxs.s = GetSkinPropertyParamp(skin, ComponentName, state$, "text position", "x")
      If FindString(txtxs, "%", 1) > 0
        txtxpercent = #True
      EndIf
      If txtxs <> ""
        If txtxs = "centre"
          txtxpercent = #True
          txtx = 50
        Else
          txtx = Val(txtxs)
        EndIf
      EndIf
      
      txtys.s = GetSkinPropertyParamp(skin, ComponentName, state$, "text position", "y")
      If FindString(txtys, "%", 1) > 0
        txtypercent = #True
      EndIf
      If txtys <> ""
        If txtys = "centre"
          txtypercent = #True
          txty = 50
        Else
          txty = Val(txtys)
        EndIf
      EndIf
      
      txtxs.s = GetSkinPropertyParamp(skin, ComponentName, state$, "text position", "left")
      If FindString(txtxs, "%", 1) > 0
        txtxpercent = #True
      EndIf
      If txtxs <> ""
        If txtxs = "centre"
          txtxpercent = #True
          txtx = 50
        Else
          txtx = Val(txtxs)
        EndIf
      EndIf
      
      txtys.s = GetSkinPropertyParamp(skin, ComponentName, state$, "text position", "top")
      If FindString(txtys, "%", 1) > 0
        txtypercent = #True
      EndIf
      If txtys <> ""
        If txtys = "centre"
          txtypercent = #True
          txty = 50
        Else
          txty = Val(txtys)
        EndIf
      EndIf
      
      txtys.s = GetSkinPropertyParamp(skin, ComponentName, state$, "text position", "bottom")
      If FindString(txtys, "%", 1) > 0
        txtypercent = #True
      EndIf
      If txtys <> ""
        If txtys = "centre"
          txtypercent = #True
          txty = 50
        Else
          txtAlign = txtAlign | #BUTTONEX_ALIGN_BOTTOM
          txty = Val(txtys)
        EndIf
      EndIf
      
      txtxs.s = GetSkinPropertyParamp(skin, ComponentName, state$, "text position", "right")
      If FindString(txtxs, "%", 1) > 0
        txtxpercent = #True
      EndIf
      If txtxs <> ""
        If txtxs = "centre"
          txtxpercent = #True
          txtx = 50
        Else
          txtAlign = txtAlign | #BUTTONEX_ALIGN_RIGHT
          txtx = Val(txtxs)
        EndIf
      EndIf
      
      txtpad.paddings
      txtpad\top = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "text padding", "top"))
      txtpad\left = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "text padding", "left"))
      txtpad\bottom = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "text padding", "bottom"))
      txtpad\right = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "text padding", "right"))
      
      If (i = 0 And buttonx()\selected = #False) Or (i = 4 And buttonx()\selected = #True) Or (i = 7 And buttonx()\selected = #BUTTONEX_INBETWEEN) Or (i = 3 And buttonx()\disabled = #True)
        SetPanelExPageBackground(buttonx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
        SetPanelExPageBackground(buttonx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
        If rectCreated = #True
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, rc.RECT, borderstretch, #True)
        Else
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, 0, borderstretch, #True)
        EndIf
      EndIf
      
      cursor$ = ReplaceString(UCase(GetSkinPropertyp(skin, ComponentName, state$, "cursor")), ";", "")
      Select cursor$
        Case "APPSTARTING"
          cursor = #IDC_APPSTARTING
        Case "ARROW"
          cursor = #IDC_ARROW
        Case "CROSS"
          cursor = #IDC_CROSS
        Case "HAND"
          cursor = #IDC_HAND
        Case "HELP"
          cursor = #IDC_HELP
        Case "IBEAM"
          cursor = #IDC_IBEAM
        Case "NO"
          cursor = #IDC_NO
        Case "SIZE"
          cursor = #IDC_SIZE
        Case "SIZEALL"
          cursor = #IDC_SIZEALL
        Case "SIZENESW"
          cursor = #IDC_SIZENESW
        Case "SIZENS"
          cursor = #IDC_SIZENS
        Case "SIZENWSE"
          cursor = #IDC_SIZENWSE
        Case "SIZEWE"
          cursor = #IDC_SIZEWE
        Case "UPARROW"
          cursor = #IDC_UPARROW
        Case "WAIT"
          cursor = #IDC_WAIT
        Default
          cursor = Val(cursor$)
      EndSelect
      If cursor <> 0
        buttonx()\cursor[i] = SetPanelExPageCursor(buttonx()\Handle, 0, cursor)
      EndIf
      
      buttonx()\bk[i] = bk
      buttonx()\bkstyle[i] = bkstyle
      buttonx()\bkx[i] = bkx
      buttonx()\bky[i] = bky
      buttonx()\obk[i] = obk
      buttonx()\obkstyle[i] = obkstyle
      buttonx()\obkx[i] = obkx
      buttonx()\obky[i] = obky
      buttonx()\bkimage[i] = bkimage
      buttonx()\bkwidth[i] = bkwidth
      buttonx()\bkheight[i] = bkheight
      buttonx()\obkimage[i] = obkimage
      buttonx()\obkwidth[i] = obkwidth
      buttonx()\obkheight[i] = obkheight
      buttonx()\border[i] = border
      If rectCreated = #True
        CopyStructure(rc, buttonx()\borderrect, RECT)
      EndIf
      buttonx()\mask[i] = mask
      buttonx()\font[i] = font
      buttonx()\fontcolour[i] = fontcolour
      buttonx()\imgx[i] = imgx
      buttonx()\imgy[i] = imgy
      buttonx()\imgxpercent[i] = imgxpercent
      buttonx()\imgypercent[i] = imgypercent
      buttonx()\imgalign[i] = imgAlign
      CopyStructure(imgpad, buttonx()\imgpad[i], paddings)
      buttonx()\txtx[i] = txtx
      buttonx()\txty[i] = txty
      buttonx()\txtxpercent[i] = txtxpercent
      buttonx()\txtypercent[i] = txtypercent
      buttonx()\txtalign[i] = txtAlign
      CopyStructure(txtpad, buttonx()\txtpad[i], paddings)
      
    Next
    
    buttonx()\componentname = ComponentName
    buttonx()\skin = skin
    
    If noRefresh = #False
      RefreshPanelEx(buttonx()\Handle)
    EndIf
    
    ProcedureReturn #True
    
  EndIf
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL GetButtonExSkin(ID.i) ; Gets a ButtonEx's skin
  
  macro_protectCommand()
  
  ;find buttonex
  ForEach buttonx()
    If buttonx()\handle = ID Or buttonx()\id = ID
      ProcedureReturn buttonx()\skin
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL ButtonEx(WindowID.i, buttonID.l, x.l, y.l, Width.l, Height.l, Text.s, normalImageID.i, hotImageID.i, pressedImageID.i, disabledImageID.i, skin.i) ; Creates an extended skinned button
  
  macro_protectCommand()
  
  ; make sure button control doesn't already exist
  If buttonID = #ProGUI_Any
    Repeat
      ; generate unique button id
      buttonID = generateUniqueID_wordUnsigned()
      ; check that same id doesnt already exist
      found = 0
      ForEach buttonx()
        If buttonx()\id = buttonID
          found = -1
          Break
        EndIf
      Next
    Until found = 0
    ProGUI_Any = #True
  Else
    ; make sure button id doesnt exist
    ForEach buttonx()
      If buttonx()\id = buttonID
        ProcedureReturn 0
      EndIf
    Next
  EndIf
  
  
  If normalImageID <> 0
    
    GetImageDimensions(normalImageID, @imageWidth, @imageHeight)
    
    If width = 0
      width = imageWidth
    EndIf
    
    If height = 0
      height = imageHeight
    EndIf
    
  EndIf
  
  backupCurrentPanelEx = currentPanelEx ; store the current panelex for backup after the button is created
  hwnd = PanelExID(CreatePanelEx(#ProGUI_Any, WindowID, x, y, width, height, @skinnedButtonExCallback()), -1)
  If hwnd <> 0
    
    page = AddPanelExImagePage(bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle|#PNLX_NOGADGETLIST)
    currentPanelEx = backupCurrentPanelEx
    If page = 0
      FreePanelEx(hwnd)
      ProcedureReturn #False
    EndIf
    
    LastElement(buttonx())
    AddElement(buttonx())
    buttonx()\id = buttonID
    buttonx()\Handle = hwnd
    buttonx()\pageHandle = page
    buttonx()\width = Width
    buttonx()\height = Height
    buttonx()\txt = Text
    buttonx()\imgWidth = ImageWidth
    buttonx()\imgHeight = ImageHeight
    
    buttonx()\ImageLists[0] = ImageList_Create_(imageWidth, imageHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
    ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[0], -1, normalImageID)
    If ret = -1
      ImageList_AddMasked_(buttonx()\ImageLists[0], normalImageID, RGB(0,255,0))
    EndIf
    
    buttonx()\ImageLists[1] = ImageList_Create_(imageWidth, imageHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
    ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[1], -1, hotImageID)
    If ret = -1
      ImageList_AddMasked_(buttonx()\ImageLists[1], hotImageID, RGB(0,255,0))
    EndIf
    
    buttonx()\ImageLists[2] = ImageList_Create_(imageWidth, imageHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
    ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[2], -1, pressedImageID)
    If ret = -1
      ImageList_AddMasked_(buttonx()\ImageLists[2], pressedImageID, RGB(0,255,0))
    EndIf
    
    buttonx()\ImageLists[3] = ImageList_Create_(imageWidth, imageHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
    ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[3], -1, disabledImageID)
    If ret = -1
      ImageList_AddMasked_(buttonx()\ImageLists[3], disabledImageID, RGB(0,255,0))
    EndIf
    
    If skin > 0
      If SetButtonExSkin(hwnd, skin, "", 0) = 0
        initDefaultSkin("sysbuttonskin")
        SetButtonExSkin(hwnd, sysButtonSkin, "", 0)
      EndIf
    ElseIf skin = 0
      initDefaultSkin("sysbuttonskin")
      SetButtonExSkin(hwnd, sysButtonSkin, "", 0)
    EndIf
    
    If ProGUI_Any = #True
      ProcedureReturn buttonID
    Else
      ProcedureReturn hwnd
    EndIf
    
  EndIf
  
  ProcedureReturn hwnd

EndProcedure

ProcedureDLL ImageButtonEx(WindowID.i, buttonID.l, x.l, y.l, imageWidth.l, imageHeight.l, normalImageID.i, hotImageID.i, pressedImageID.i, disabledImageID.i) ; Creates an extended image button
  
  macro_protectCommand()
  
  initDefaultSkin("imagebuttonskin")
  
  hwnd = ButtonEx(WindowID, buttonID, x, y, imageWidth, imageHeight, "", normalImageID, hotImageID, pressedImageID, disabledImageID, -1)
  If hwnd <> 0
    SetButtonExSkin(hwnd, imageButtonSkin, "imagebuttonex", 0)
  EndIf
  
  ProcedureReturn hwnd

EndProcedure

ProcedureDLL ToggleButtonEx(WindowID.i, buttonID.l, x.l, y.l, Width.l, Height.l, Text.s, normalImageID.i, hotImageID.i, pressedImageID.i, selectedImageID.i, hotSelectedImageID.i, pressedSelectedImageID.i, disabledImageID.i, skin.i) ; Creates an extended skinned toggle state button
  
  macro_protectCommand()
  
  If skin = #BUTTONEX_STICKYSKIN
    initDefaultSkin("sysstickybuttonskin")
    skin = sysStickyButtonSkin
  ElseIf skin = 0
    initDefaultSkin("systogglebuttonskin")
    skin = sysToggleButtonSkin
  EndIf
  
  hwnd = ButtonEx(WindowID.i, buttonID.l, x.l, y.l, Width.l, Height.l, Text.s, normalImageID.i, hotImageID.i, pressedImageID.i, disabledImageID.i, -1)
  If hwnd <> 0
    
    ; find new buttonex
    If buttonID = #ProGUI_Any
      ForEach buttonx()
        If buttonx()\id = hwnd
          Break
        EndIf
      Next
    Else
      ForEach buttonx()
        If buttonx()\Handle = hwnd
          Break
        EndIf
      Next
    EndIf
    
    If normalImageID <> 0
    
      GetImageDimensions(normalImageID, @bmWidth, @bmHeight)
      
      If imageWidth = 0
        imageWidth = bmWidth
      EndIf
      If imageHeight = 0
        imageHeight = bmHeight
      EndIf
      
    EndIf
    
    buttonx()\ImageLists[4] = ImageList_Create_(imageWidth, imageHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
    ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[4], -1, selectedImageID)
    If ret = -1
      ImageList_AddMasked_(buttonx()\ImageLists[4], selectedImageID, RGB(0,255,0))
    EndIf
    
    buttonx()\ImageLists[5] = ImageList_Create_(imageWidth, imageHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
    ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[5], -1, hotSelectedImageID)
    If ret = -1
      ImageList_AddMasked_(buttonx()\ImageLists[5], hotSelectedImageID, RGB(0,255,0))
    EndIf
    
    buttonx()\ImageLists[6] = ImageList_Create_(imageWidth, imageHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
    ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[6], -1, pressedSelectedImageID)
    If ret = -1
      ImageList_AddMasked_(buttonx()\ImageLists[6], pressedSelectedImageID, RGB(0,255,0))
    EndIf
    
    buttonx()\toggle = #True
    
    SetButtonExSkin(hwnd, skin, "togglebuttonex", 0)
    
  EndIf
  
  ProcedureReturn hwnd
  
EndProcedure

ProcedureDLL RadioButtonEx(WindowID.i, buttonID.l, x.l, y.l, Width.l, Height.l, Text.s, skin.i) ; Creates an extended skinned radio button or closes the current radio group if WindowID is null
  
  macro_protectCommand()
  
  If skin = 0
    initDefaultSkin("sysRadioButtonSkin")
    skin = sysRadioButtonSkin
  ElseIf IsSkin(skin) = 0
    initDefaultSkin("sysRadioButtonSkin")
    skin = sysRadioButtonSkin
  EndIf
  
  If WindowID <> 0
    hwnd = ToggleButtonEx(WindowID.i, buttonID.l, x.l, y.l, Width.l, Height.l, Text.s, 0, 0, 0, 0, 0, 0, 0, -1)
    If hwnd <> 0
      
      ; find new buttonex
      If buttonID = #ProGUI_Any
        ForEach buttonx()
          If buttonx()\id = hwnd
            Break
          EndIf
        Next
      Else
        ForEach buttonx()
          If buttonx()\Handle = hwnd
            Break
          EndIf
        Next
      EndIf
      
      buttonx()\radio = #True
      buttonx()\radioGroup = radioButtonExGroup
      
      SetButtonExSkin(hwnd, skin, "radiobuttonex", 0)
      
    EndIf
    
  Else
    radioButtonExGroup + 1
  EndIf
  
  ProcedureReturn hwnd
  
EndProcedure

ProcedureDLL CheckButtonEx(WindowID.i, buttonID.l, x.l, y.l, Width.l, Height.l, Text.s, skin.i) ; Creates an extended skinned check box button
  
  macro_protectCommand()
  
  If skin = 0
    initDefaultSkin("syscheckbuttonskin")
    skin = sysCheckButtonSkin
  ElseIf IsSkin(skin) = 0
    initDefaultSkin("syscheckbuttonskin")
    skin = sysCheckButtonSkin
  EndIf
  
  If IsWindow_(WindowID)
    hwnd = ToggleButtonEx(WindowID.i, buttonID.l, x.l, y.l, Width.l, Height.l, Text.s, 0, 0, 0, 0, 0, 0, 0, -1)
    If hwnd <> 0
      
      ; find new buttonex
      If buttonID = #ProGUI_Any
        ForEach buttonx()
          If buttonx()\id = hwnd
            Break
          EndIf
        Next
      Else
        ForEach buttonx()
          If buttonx()\Handle = hwnd
            Break
          EndIf
        Next
      EndIf
      buttonx()\check = #True
      SetButtonExSkin(hwnd, skin, "checkbuttonex", 0)
      
    EndIf
  EndIf
  
  ProcedureReturn hwnd
  
EndProcedure

ProcedureDLL ChangeButtonEx(id.i, normalImageID.i, hotImageID.i, pressedImageID.i, selectedImageID.i, hotSelectedImageID.i, pressedSelectedImageID.i, disabledImageID.i) ; Changes a ButtonEx's images
  
  macro_protectCommand()
  
  ForEach buttonx()
    If buttonx()\id = id Or buttonx()\Handle = id
      
      If normalImageID <> 0
        ImageList_Remove_(buttonx()\ImageLists[0], -1)
        ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[0], -1, normalImageID)
        If ret = -1
          ret = ImageList_AddMasked_(buttonx()\ImageLists[0], normalImageID, RGB(0,255,0))
          If ret = -1
            ProcedureReturn -1
          EndIf
        EndIf
      EndIf
      
      If hotImageID <> 0
        ImageList_Remove_(buttonx()\ImageLists[1], -1)
        ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[1], -1, hotImageID)
        If ret = -1
          ret = ImageList_AddMasked_(buttonx()\ImageLists[1], hotImageID, RGB(0,255,0))
          If ret = -1
            ProcedureReturn -2
          EndIf
        EndIf
      EndIf
      
      If pressedImageID <> 0
        ImageList_Remove_(buttonx()\ImageLists[2], -1)
        ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[2], -1, pressedImageID)
        If ret = -1
          ret = ImageList_AddMasked_(buttonx()\ImageLists[2], pressedImageID, RGB(0,255,0))
          If ret = -1
            ProcedureReturn -3
          EndIf
        EndIf
      EndIf
      
      If selectedImageID <> 0 And buttonx()\toggle = #True
        ImageList_Remove_(buttonx()\ImageLists[4], -1)
        ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[4], -1, selectedImageID)
        If ret = -1
          ret = ImageList_AddMasked_(buttonx()\ImageLists[4], selectedImageID, RGB(0,255,0))
          If ret = -1
            ProcedureReturn -5
          EndIf
        EndIf
      EndIf
      
      If hotSelectedImageID <> 0 And buttonx()\toggle = #True
        ImageList_Remove_(buttonx()\ImageLists[5], -1)
        ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[5], -1, hotSelectedImageID)
        If ret = -1
          ret = ImageList_AddMasked_(buttonx()\ImageLists[5], hotSelectedImageID, RGB(0,255,0))
          If ret = -1
            ProcedureReturn -6
          EndIf
        EndIf
      EndIf
      
      If pressedSelectedImageID <> 0 And buttonx()\toggle = #True
        ImageList_Remove_(buttonx()\ImageLists[6], -1)
        ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[6], -1, pressedSelectedImageID)
        If ret = -1
          ret = ImageList_AddMasked_(buttonx()\ImageLists[6], pressedSelectedImageID, RGB(0,255,0))
          If ret = -1
            ProcedureReturn -7
          EndIf
        EndIf
      EndIf
      
      If disabledImageID <> 0
        ImageList_Remove_(buttonx()\ImageLists[3], -1)
        ret.l = ImageList_ReplaceIcon_(buttonx()\ImageLists[3], -1, disabledImageID)
        If ret = -1
          ret = ImageList_AddMasked_(buttonx()\ImageLists[3], disabledImageID, RGB(0,255,0))
          If ret = -1
            ProcedureReturn -4
          EndIf
        EndIf
      EndIf
      
      ForEach panelexpage()
        If panelexpage()\Handle = GetParent_(buttonx()\Handle)
          inpanel = #True
          Break
        EndIf
      Next
      If inpanel = #True
        GetClientRect_(buttonx()\Handle, @rc.RECT)
        MapWindowPoints_(buttonx()\Handle, GetParent_(buttonx()\Handle), @rc, 2)
        RedrawWindow_(GetParent_(GetParent_(buttonx()\Handle)), rc, 0, #RDW_UPDATENOW|#RDW_INVALIDATE|#RDW_NOERASE)
      Else
        ;RedrawWindow_(buttonx()\Handle, 0, 0, #RDW_UPDATENOW|#RDW_INVALIDATE)
        
        GetClientRect_(buttonx()\Handle, @trc.RECT)
        MapWindowPoints_(buttonx()\Handle, GetAncestor_(buttonx()\Handle,#GA_ROOT), @trc, 2)
        thisdontdraw = buttonx()\dontdraw
        buttonx()\dontdraw = #True
        RedrawWindow_(GetAncestor_(buttonx()\Handle,#GA_ROOT), trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_FRAME|#RDW_ALLCHILDREN)
        buttonx()\dontdraw = thisdontdraw
        
      EndIf
      
      ProcedureReturn #True
      
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL SetButtonExText(id.i, text.s) ; Sets the text of a skinned ButtonEx
  
  ForEach buttonx()
    If buttonx()\id = id Or buttonx()\Handle = id
      
      buttonx()\txt = text
      hwnd = getRootPanelExPageHwnd(buttonx()\Handle)
      GetClientRect_(buttonx()\Handle, @rc.RECT)
      MapWindowPoints_(buttonx()\Handle, hwnd, @rc, 2)
      RedrawWindow_(hwnd, rc, 0, #RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ERASE)
      
      ProcedureReturn #True
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL.s GetButtonExText(id.i) ; Gets the text of a skinned ButtonEx
  
  ReturnString$ = ""
  
  ForEach buttonx()
    If buttonx()\id = id Or buttonx()\Handle = id
      
      ReturnString$ = buttonx()\txt
      
      Break
    EndIf
  Next
  
  ProcedureReturn ReturnString$
  
EndProcedure
      
ProcedureDLL ButtonExToolTip(id.i, text.s)
  
  macro_protectCommand()
  
  ForEach buttonx()
    If buttonx()\id = id Or buttonx()\Handle = id
      
      If buttonx()\tooltip = 0
        hwnd = CreateWindowEx_(0, "tooltips_class32", 0, #WS_POPUP, #CW_USEDEFAULT, #CW_USEDEFAULT, #CW_USEDEFAULT, #CW_USEDEFAULT, buttonx()\Handle, 0,  GetModuleHandle_(0), #Null)
        If hwnd <> 0
          
          buttonx()\tooltip = hwnd
          
          tool.TOOLINFO
          tool\cbSize = SizeOf(TOOLINFO)
          tool\hwnd = buttonx()\Handle
          tool\uFlags = #TTF_IDISHWND | #TTF_SUBCLASS
          tool\uId = buttonx()\pageHandle
          tool\lpszText = @text
          SendMessage_(hwnd, #TTM_ADDTOOL, 0, @tool)
          
          ProcedureReturn #True
        Else
          ProcedureReturn 0
        EndIf
      EndIf
      
      tool.TOOLINFO
      tool\cbSize = SizeOf(TOOLINFO)
      tool\hwnd = buttonx()\Handle
      tool\uFlags = #TTF_IDISHWND | #TTF_SUBCLASS
      tool\uId = buttonx()\pageHandle
      tool\lpszText = @text
      SendMessage_(buttonx()\tooltip, #TTM_UPDATETIPTEXT, 0, @tool)
      
      ProcedureReturn #True
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL GetButtonExState(id.i) ; Returns the state of a ToggleButtonEx, CheckButtonEx or RadioButtonEx
  
  ForEach buttonx()
    If buttonx()\id = id Or buttonx()\Handle = id
      If buttonx()\toggle = #True
        result = buttonx()\selected
      EndIf
      Break
    EndIf
  Next
  
  ProcedureReturn result
  
EndProcedure

ProcedureDLL SetButtonExState(id.i, state.b) ; Sets the state of a ToggleButtonEx, CheckButtonEx or RadioButtonEx
  
  If state = #False Or state = #True Or state = #BUTTONEX_INBETWEEN
    ForEach buttonx()
      If buttonx()\id = id Or buttonx()\Handle = id
        If buttonx()\toggle = #True
          
          ; if state = #BUTTONEX_INBETWEEN and not check button then exit
          If state = #BUTTONEX_INBETWEEN And buttonx()\check = #False
            Break
          EndIf
          
          ; radio button
          If buttonx()\radio = #True And buttonx()\selected = #False
            ; check all other radio buttons of same group and deselect active
            *thisButtonx = @buttonx()
            group = buttonx()\radioGroup
            ForEach buttonx()
              If buttonx()\radio = #True And buttonx()\radioGroup = group And buttonx()\selected = #True
                buttonx()\selected = #False
                buttonx()\index = 0
                
                i = buttonx()\index
                bk = buttonx()\bk[i]
                bkstyle = buttonx()\bkstyle[i]
                bkx = buttonx()\bkx[i]
                bky = buttonx()\bky[i]
                obk = buttonx()\obk[i]
                obkstyle = buttonx()\obkstyle[i]
                obkx = buttonx()\obkx[i]
                obky = buttonx()\obky[i]
                bkimage = buttonx()\bkimage[i]
                bkwidth = buttonx()\bkwidth[i]
                bkheight = buttonx()\bkheight[i]
                obkimage = buttonx()\obkimage[i]
                obkwidth = buttonx()\obkwidth[i]
                obkheight = buttonx()\obkheight[i]
                border = buttonx()\border[i]
                If buttonx()\borderrect[i]\left <> 0 And buttonx()\borderrect[i]\top <> 0 And buttonx()\borderrect[i]\bottom And buttonx()\borderrect[i]\right <> 0
                  CopyStructure(buttonx()\borderrect[i], @rc.RECT, RECT)
                  rectCreated = #True
                EndIf
                mask = buttonx()\mask[i]
                font = buttonx()\font[i]
                fontcolour = buttonx()\fontcolour[i]
                imgx = buttonx()\imgx[i]
                imgy = buttonx()\imgy[i]
                imgxpercent = buttonx()\imgxpercent[i]
                imgypercent = buttonx()\imgypercent[i]
                imgalign = buttonx()\imgalign[i]
                txtx = buttonx()\txtx[i]
                txty = buttonx()\txty[i]
                txtxpercent = buttonx()\txtxpercent[i]
                txtypercent = buttonx()\txtypercent[i]
                txtalign = buttonx()\txtalign[i]
                
                SetPanelExPageBackground(buttonx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
                SetPanelExPageBackground(buttonx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
                
                If rectCreated = #True
                  SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, rc.RECT, 0, #True)
                  rectCreated = #False
                Else
                  SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, 0, 0, #True)
                EndIf
                
                If buttonx()\cursor <> 0
                  SetPanelExPageCursor(buttonx()\Handle, 0, buttonx()\cursor[i])
                EndIf
                
                hwnd = getRootPanelExPageHwnd(buttonx()\Handle)
                GetClientRect_(buttonx()\Handle, @rc.RECT)
                MapWindowPoints_(buttonx()\Handle, hwnd, @rc, 2)
                RedrawWindow_(hwnd, rc, 0, #RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ERASE)
                Break
              EndIf
            Next
            ChangeCurrentElement(buttonx(), *thisButtonx)
            
          EndIf
          
          buttonx()\selected = state
          
          If buttonx()\selected = #False
            buttonx()\index = 0 ; normal
          ElseIf buttonx()\selected = #True
            buttonx()\index = 4 ; selected normal
          ElseIf buttonx()\selected = #BUTTONEX_INBETWEEN
            buttonx()\index = 7 ; selected normal
          EndIf
          
          i = buttonx()\index
          bk = buttonx()\bk[i]
          bkstyle = buttonx()\bkstyle[i]
          bkx = buttonx()\bkx[i]
          bky = buttonx()\bky[i]
          obk = buttonx()\obk[i]
          obkstyle = buttonx()\obkstyle[i]
          obkx = buttonx()\obkx[i]
          obky = buttonx()\obky[i]
          bkimage = buttonx()\bkimage[i]
          bkwidth = buttonx()\bkwidth[i]
          bkheight = buttonx()\bkheight[i]
          obkimage = buttonx()\obkimage[i]
          obkwidth = buttonx()\obkwidth[i]
          obkheight = buttonx()\obkheight[i]
          border = buttonx()\border[i]
          If buttonx()\borderrect[i]\left <> 0 And buttonx()\borderrect[i]\top <> 0 And buttonx()\borderrect[i]\bottom And buttonx()\borderrect[i]\right <> 0
            CopyStructure(buttonx()\borderrect[i], @rc.RECT, RECT)
            rectCreated = #True
          EndIf
          mask = buttonx()\mask[i]
          font = buttonx()\font[i]
          fontcolour = buttonx()\fontcolour[i]
          imgx = buttonx()\imgx[i]
          imgy = buttonx()\imgy[i]
          imgxpercent = buttonx()\imgxpercent[i]
          imgypercent = buttonx()\imgypercent[i]
          imgalign = buttonx()\imgalign[i]
          txtx = buttonx()\txtx[i]
          txty = buttonx()\txty[i]
          txtxpercent = buttonx()\txtxpercent[i]
          txtypercent = buttonx()\txtypercent[i]
          txtalign = buttonx()\txtalign[i]
          
          SetPanelExPageBackground(buttonx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
          SetPanelExPageBackground(buttonx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
          
          If rectCreated = #True
            SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, rc.RECT, 0, #True)
          Else
            SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, 0, 0, #True)
          EndIf
          
          If buttonx()\cursor <> 0
            SetPanelExPageCursor(buttonx()\Handle, 0, buttonx()\cursor[i])
          EndIf
          
          hwnd = getRootPanelExPageHwnd(buttonx()\pageHandle)
          GetClientRect_(buttonx()\pageHandle, @rc.RECT)
          MapWindowPoints_(buttonx()\pageHandle, hwnd, @rc, 2)
          RedrawWindow_(hwnd, rc, 0, #RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ERASE)
          
        EndIf
        Break
      EndIf
    Next
  EndIf
 
  ProcedureReturn result
  
EndProcedure

ProcedureDLL ButtonExID(id.l) ; Returns a handle to a ButtonEx's window
  
  ForEach buttonx()
    If buttonx()\id = id
      
      ProcedureReturn buttonx()\Handle
      
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL DisableButtonEx(id.i, disable.b) ; Disables/enables a ButtonEx, disable = True/False
  
  macro_protectCommand()
  
  ForEach buttonx()
    If buttonx()\id = id Or buttonx()\Handle = id
      
      If disable = 0
        buttonx()\disabled = #False
        
        i = 0
        bk = buttonx()\bk[i]
        obk = buttonx()\obk[i]
        bkimage = buttonx()\bkimage[i]
        obkimage = buttonx()\obkimage[i]
        border = buttonx()\border[i]
        mask = buttonx()\mask[i]
        ;buttonx()\borderrc = 
        font = buttonx()\font[i]
        fontcolour = buttonx()\fontcolour[i]
        imgx = buttonx()\imgx[i]
        imgy = buttonx()\imgy[i]
        imgxpercent = buttonx()\imgxpercent[i]
        imgypercent = buttonx()\imgypercent[i]
        imgalign = buttonx()\imgalign[i]
        txtx = buttonx()\txtx[i]
        txty = buttonx()\txty[i]
        txtxpercent = buttonx()\txtxpercent[i]
        txtypercent = buttonx()\txtypercent[i]
        txtalign = buttonx()\txtalign[i]
        
        SetPanelExPageBackground(buttonx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
        SetPanelExPageBackground(buttonx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
        
        If rectCreated = #True
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, rc.RECT, 0, #True)
        Else
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, 0, 0, #True)
        EndIf
        
        buttonx()\index = 0
        
      Else
        buttonx()\disabled = #True
        
        i = 3
        bk = buttonx()\bk[i]
        obk = buttonx()\obk[i]
        bkimage = buttonx()\bkimage[i]
        obkimage = buttonx()\obkimage[i]
        border = buttonx()\border[i]
        mask = buttonx()\mask[i]
        ;buttonx()\borderrc = 
        font = buttonx()\font[i]
        fontcolour = buttonx()\fontcolour[i]
        imgx = buttonx()\imgx[i]
        imgy = buttonx()\imgy[i]
        imgxpercent = buttonx()\imgxpercent[i]
        imgypercent = buttonx()\imgypercent[i]
        imgalign = buttonx()\imgalign[i]
        txtx = buttonx()\txtx[i]
        txty = buttonx()\txty[i]
        txtxpercent = buttonx()\txtxpercent[i]
        txtypercent = buttonx()\txtypercent[i]
        txtalign = buttonx()\txtalign[i]
        
        SetPanelExPageBackground(buttonx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
        SetPanelExPageBackground(buttonx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
        
        If rectCreated = #True
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, rc.RECT, 0, #True)
        Else
          SetPanelExPageBorder(buttonx()\Handle, 0, border, mask, 0, 0, #True)
        EndIf
        
        buttonx()\index = 3
        
      EndIf
      
      ForEach panelexpage()
        If panelexpage()\Handle = GetParent_(buttonx()\Handle)
          inpanel = #True
          Break
        EndIf
      Next
      If inpanel = #True
        GetClientRect_(buttonx()\Handle, @rc.RECT)
        MapWindowPoints_(buttonx()\Handle, GetParent_(buttonx()\Handle), @rc, 2)
        RedrawWindow_(GetParent_(GetParent_(buttonx()\Handle)), rc, 0, #RDW_UPDATENOW|#RDW_INVALIDATE|#RDW_NOERASE)
      Else
        ;RedrawWindow_(buttonx()\Handle, 0, 0, #RDW_UPDATENOW|#RDW_INVALIDATE)
        
        GetClientRect_(buttonx()\Handle, @trc.RECT)
        MapWindowPoints_(buttonx()\Handle, GetAncestor_(buttonx()\Handle,#GA_ROOT), @trc, 2)
        thisdontdraw = buttonx()\dontdraw
        buttonx()\dontdraw = #True
        RedrawWindow_(GetAncestor_(buttonx()\Handle,#GA_ROOT), trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_FRAME|#RDW_ALLCHILDREN)
        buttonx()\dontdraw = thisdontdraw
        
      EndIf
      
      ProcedureReturn #True
      
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL FreeButtonEx(id.i) ; Frees a ButtonEx from memory
  
  ForEach buttonx()
    If buttonx()\id = id Or buttonx()\Handle = id Or id = -1
      
      DestroyWindow_(buttonx()\tooltip)
      
      ImageList_Destroy_(buttonx()\ImageLists[0])
      ImageList_Destroy_(buttonx()\ImageLists[1])
      ImageList_Destroy_(buttonx()\ImageLists[2])
      ImageList_Destroy_(buttonx()\ImageLists[3])
      ImageList_Destroy_(buttonx()\ImageLists[4])
      ImageList_Destroy_(buttonx()\ImageLists[5])
      ImageList_Destroy_(buttonx()\ImageLists[6])
      
      FreePanelEx(buttonx()\Handle)
      
      DeleteElement(buttonx())
      
      If id <> -1
        ProcedureReturn #True
      EndIf
      
    EndIf
  Next
  
  If id = -1
    ProcedureReturn #True
  EndIf
  ProcedureReturn 0
  
EndProcedure


;--
;- SplitterEx
;--
Procedure updateSplitter(x, y)
  
  GetWindowRect_(splitterGrabberHwnd, @rc.RECT)
  GetClientRect_(GetParent_(splitterGrabberHwnd), @prc.RECT)
  MapWindowPoints_(0, GetParent_(splitterGrabberHwnd), @rc, 2)
  width = splitterGrabberWidth;rc\right-rc\left
  height = splitterGrabberHeight;rc\bottom-rc\top
  pwidth =  prc\right-prc\left
  pheight = prc\bottom-prc\top
  
  ; horizontal mode
  If splitterMode = 0
    
    If splitterDelta = -1
      splitterDelta = x-rc\left
    EndIf
    
    x = x - splitterDelta
    
    If splitterGrabberHeight = 0
      grabberheight = pheight
    Else
      grabberheight = height
    EndIf
    
    y = (pheight/2)-(grabberheight/2)
    
    If x < 0
      x = 0
    ElseIf x > pwidth-width
      x = pwidth-width
    EndIf
    
    ; make sure splitter doesn't go past min and max of first and second
    If x < splitterFirstMin
      x = splitterFirstMin
    EndIf
    If splitterFirstMax <> 0 And x > splitterFirstMax
      x = splitterFirstMax
    EndIf
    If splitterSecondMin <> 0 And x+width > pwidth-splitterSecondMin
      x = pwidth-splitterSecondMin-width
    EndIf
    If splitterSecondMax <> 0 And x+width < pwidth-splitterSecondMax
      x = pwidth-splitterSecondMax-width
    EndIf
    
    ; handle hidden states
    If splitterFirstHidden = #True
      x = 0 - width
      pwidth = pwidth + (x+width)
    ElseIf splitterSecondHidden = #True
      x = pwidth
    EndIf
    
    ; limit grabber height to splitter height
    If y < 0
      y = 0
      grabberheight = pheight
    EndIf
    
    hdwp = BeginDeferWindowPos_(3)
    DeferWindowPos_(hdwp, splitterGrabberHwnd, 0, x, y, width, grabberheight, #SWP_NOREDRAW)
    DeferWindowPos_(hdwp, splitterHwnd1, 0, splitterFirstPadding\left, splitterFirstPadding\top, x-(splitterFirstPadding\left+splitterFirstPadding\right), pheight-(splitterFirstPadding\top+splitterFirstPadding\bottom), #SWP_NOREDRAW)
    DeferWindowPos_(hdwp, splitterHwnd2, 0, x+width+splitterSecondPadding\left, splitterSecondPadding\top, pwidth-(x+width)-(splitterSecondPadding\left+splitterSecondPadding\right), pheight-(splitterSecondPadding\top+splitterSecondPadding\bottom), #SWP_NOREDRAW)
    EndDeferWindowPos_(hdwp)
    
  ; vertical mode
  Else
    
    If splitterDelta = -1
      splitterDelta = y-rc\top
    EndIf
    
    y = y - splitterDelta
    
    If splitterGrabberWidth = 0
      grabberWidth = pWidth
    Else
      grabberWidth = splitterGrabberWidth
    EndIf
    
    x = (pwidth/2)-(grabberwidth/2)
    
    If y < 0
      y = 0
    ElseIf y > pheight-height
      y = pheight-height
    EndIf
    
    ; make sure splitter doesn't go past min and max of first and second
    If y < splitterFirstMin
      y = splitterFirstMin
    EndIf
    If splitterFirstMax <> 0 And y > splitterFirstMax
      y = splitterFirstMax
    EndIf
    If splitterSecondMin <> 0 And y+height > pheight-splitterSecondMin
      y = pheight-splitterSecondMin-height
    EndIf
    If splitterSecondMax <> 0 And y+height < pheight-splitterSecondMax
      y = pheight-splitterSecondMax-height
    EndIf
    
    ; handle hidden states
    If splitterFirstHidden = #True
      y = 0 - height
      pheight = pheight + (y+height)
    ElseIf splitterSecondHidden = #True
      y = pheight
    EndIf
    
    ; limit grabber width to splitter width
    If x < 0
      x = 0
      grabberwidth = pwidth
    EndIf
    
    hdwp = BeginDeferWindowPos_(3)
    DeferWindowPos_(hdwp, splitterGrabberHwnd, 0, x, y, grabberwidth, splitterGrabberHeight, #SWP_NOREDRAW)
    DeferWindowPos_(hdwp, splitterHwnd1, 0, splitterFirstPadding\left, splitterFirstPadding\top, pwidth-(splitterFirstPadding\left+splitterFirstPadding\right), y-(splitterFirstPadding\top+splitterFirstPadding\bottom), #SWP_NOREDRAW)
    DeferWindowPos_(hdwp, splitterHwnd2, 0, splitterSecondPadding\left, y+splitterGrabberHeight+splitterSecondPadding\top, pwidth-(splitterSecondPadding\left+splitterSecondPadding\right), pheight-(y+splitterGrabberHeight)-(splitterSecondPadding\top+splitterSecondPadding\bottom), #SWP_NOREDRAW)
    EndDeferWindowPos_(hdwp)
    
  EndIf
 
  RefreshPanelEx(GetParent_(GetParent_(splitterGrabberHwnd)))
  
EndProcedure

Procedure splitterMouseHook(nCode, wParam, lParam)
  Static lx, ly
  
  *mouse.MSLLHOOKSTRUCT  = lparam
  MapWindowPoints_(0, GetParent_(splitterGrabberHwnd), *mouse\pt, 1)
  x = *mouse\pt\x
  y = *mouse\pt\y
  
  GetClientRect_(GetParent_(splitterGrabberHwnd), @rc.RECT)
  width = rc\right-rc\left
  height = rc\bottom-rc\top
  
  If x < 0
    x = 0
  ElseIf x > width
    x = width
  EndIf
  
  If y < 0
    y = 0
  ElseIf y > height
    y = height
  EndIf
  
  If (x <> lx And splitterMode = 0) Or (y <> ly And splitterMode <> 0)
    updateSplitter(x, y)
  EndIf
  
  lx = x
  ly = y
  
  ;debuglog("X: "+Str(x)+" Y: "+Str(y))
  If wParam = #WM_LBUTTONUP
    UnhookWindowsHookEx_(splitterHook)
    ReleaseCapture_()
    splitterHook = 0
    splitterDrag = -1
    pt.POINT
    GetCursorPos_(@pt)
    hwnd = WindowFromPoint_(PeekQ(pt))
    If hwnd <> splitterGrabberPageHwnd
      SendMessage_(splitterGrabberPageHwnd, #WM_MOUSELEAVE, 0, 0)
    EndIf
  EndIf
    
  ProcedureReturn CallNextHookEx_(0, nCode, wParam, lParam)
EndProcedure

Procedure splitterExCallback(Window, message, wParam, lParam)
 
  ; find associated splitterx
  ForEach splitterx()
    If splitterx()\Handle = Window
      found = #True
      Break
    EndIf
  Next
  
  If found = #False
    ProcedureReturn 0
  EndIf
  
  Select message
      
    Case #WM_SIZE
      
      width = LOWORD(lParam)
      height = HIWORD(lParam)
      
      
      ; horizontal mode
      If Not splitterx()\flags & #SPLITTEREX_VERTICAL
        
        GetWindowRect_(splitterx()\pageHandle, @prc.RECT)
        pwidth = prc\right-prc\left
        If pwidth < 1
          pwidth = 1
        EndIf
        
        gx = splitterx()\grabberRatio/(100/pwidth)
        gx = gx - (splitterx()\grabberwidth/2)
        
        If splitterx()\grabberheight = 0
          grabberheight = height
        Else
          grabberheight = splitterx()\grabberheight
        EndIf
        
        gy = (height/2)-(grabberheight/2)
        
        If gx < 0
          gx = 0
        ElseIf gx > width-splitterx()\grabberwidth
          gx = width-splitterx()\grabberwidth
        EndIf
        
        ; if locked then set gx to correct side pos
        If splitterx()\anchored = #SPLITTEREX_ANCHOREDLEFT
          gx = 0
        ElseIf splitterx()\anchored = #SPLITTEREX_ANCHOREDRIGHT
          gx = width-splitterx()\grabberwidth
        EndIf
        
        ; make sure splitter doesn't go past min and max of first and second
        If gx < splitterx()\firstmin
          gx = splitterx()\firstmin
        EndIf
        If splitterx()\firstmax <> 0 And gx > splitterx()\firstmax
          gx = splitterx()\firstmax
        EndIf
        If splitterx()\secondmin <> 0 And gx+splitterx()\grabberwidth > width-splitterx()\secondmin
          gx = width-splitterx()\secondmin-splitterx()\grabberwidth
        EndIf
        If splitterx()\secondmax <> 0 And gx+splitterx()\grabberwidth < width-splitterx()\secondmax
          gx = width-splitterx()\secondmax-splitterx()\grabberwidth
        EndIf
        
        ; handle hidden states
        If splitterx()\firsthidden = #True
          gx = 0 - splitterx()\grabberwidth
          width = width + (gx+splitterx()\grabberwidth)
        ElseIf splitterx()\secondhidden = #True
          gx = width
        EndIf
        
        ; limit grabber height to splitter height
        If gy < 0
          gy = 0
          grabberheight = height
        EndIf
        
        *thisSplitter = @splitterx()
        ;hwnd = getRootPanelExPageHwnd(GetParent_(splitterx()\grabberHandle))
        ;setAllChildRedraw(hwnd, #False)
        ;ChangeCurrentElement(splitterx(), *thisSplitter)
        hdwp = BeginDeferWindowPos_(3)
        DeferWindowPos_(hdwp, splitterx()\grabberHandle, 0, gx, gy, splitterx()\grabberwidth, grabberheight, #SWP_NOREDRAW)
        DeferWindowPos_(hdwp, splitterx()\hwnd1, 0, splitterx()\firstpadding\left, splitterx()\firstpadding\top, gx-(splitterx()\firstpadding\left+splitterx()\firstpadding\right), height-(splitterx()\firstpadding\top+splitterx()\firstpadding\bottom), #SWP_NOREDRAW)
        DeferWindowPos_(hdwp, splitterx()\hwnd2, 0, gx+splitterx()\grabberwidth+splitterx()\secondpadding\left, splitterx()\secondpadding\top, width-(gx+splitterx()\grabberwidth)-(splitterx()\secondpadding\left+splitterx()\secondpadding\right), height-(splitterx()\secondpadding\top+splitterx()\secondpadding\bottom), #SWP_NOREDRAW)
        EndDeferWindowPos_(hdwp)
        ;setAllChildRedraw(hwnd, #True)
        ChangeCurrentElement(splitterx(), *thisSplitter)
        
      ; vertical mode
      Else
        
        GetWindowRect_(splitterx()\pageHandle, @prc.RECT)
        pheight = prc\bottom-prc\top
        If pheight < 1
          pheight = 1
        EndIf
        
        gy = splitterx()\grabberRatio/(100/pheight)
        gy = gy - (splitterx()\grabbervheight/2)
        
        If splitterx()\grabbervwidth = 0
          grabberwidth = width
        Else
          grabberwidth = splitterx()\grabbervwidth
        EndIf
        
        gx = (width/2)-(grabberwidth/2)
        
        If gy < 0
          gy = 0
        ElseIf gy > height-splitterx()\grabbervheight
          gy = height-splitterx()\grabbervheight
        EndIf
        
        ; if locked then set gy to correct side pos
        If splitterx()\anchored = #SPLITTEREX_ANCHOREDTOP
          gy = 0
        ElseIf splitterx()\anchored = #SPLITTEREX_ANCHOREDBOTTOM
          gy = height-splitterx()\grabbervheight
        EndIf
        
        ; make sure splitter doesn't go past min and max of first and second
        If gy < splitterx()\firstmin
          gy = splitterx()\firstmin
        EndIf
        If splitterx()\firstmax <> 0 And gy > splitterx()\firstmax
          gy = splitterx()\firstmax
        EndIf
        If splitterx()\secondmin <> 0 And gy+splitterx()\grabbervheight > height-splitterx()\secondmin
          gy = height-splitterx()\secondmin-splitterx()\grabbervheight
        EndIf
        If splitterx()\secondmax <> 0 And gy+splitterx()\grabbervheight < height-splitterx()\secondmax
          gy = height-splitterx()\secondmax-splitterx()\grabbervheight
        EndIf
        
        ; handle hidden states
        If splitterx()\firsthidden = #True
          gy = 0 - splitterx()\grabbervheight
          height = height + (gy+splitterx()\grabbervheight)
        ElseIf splitterx()\secondhidden = #True
          gy = height
        EndIf
        
        ; limit grabber width to splitter width
        If gx < 0
          gx = 0
          grabberwidth = width
        EndIf
        
        *thisSplitter = @splitterx()
        hwnd = getRootPanelExPageHwnd(GetParent_(splitterx()\grabberHandle))
        ;setAllChildRedraw(hwnd, #False)
        ChangeCurrentElement(splitterx(), *thisSplitter)
        hdwp = BeginDeferWindowPos_(3)
        DeferWindowPos_(hdwp, splitterx()\grabberHandle, 0, gx, gy, grabberwidth, splitterx()\grabbervheight, #SWP_NOREDRAW)
        DeferWindowPos_(hdwp, splitterx()\hwnd1, 0, splitterx()\vfirstpadding\left, splitterx()\vfirstpadding\top, width-(splitterx()\vfirstpadding\left+splitterx()\vfirstpadding\right), gy-(splitterx()\vfirstpadding\top+splitterx()\vfirstpadding\bottom), #SWP_NOREDRAW)
        DeferWindowPos_(hdwp, splitterx()\hwnd2, 0, splitterx()\vsecondpadding\left, gy+splitterx()\grabbervheight+splitterx()\vsecondpadding\top, width-(splitterx()\vsecondpadding\left+splitterx()\vsecondpadding\right), height-(gy+splitterx()\grabbervheight)-(splitterx()\vsecondpadding\top+splitterx()\vsecondpadding\bottom), #SWP_NOREDRAW)
        EndDeferWindowPos_(hdwp)
        ;setAllChildRedraw(hwnd, #True)
        ChangeCurrentElement(splitterx(), *thisSplitter)
        
      EndIf
      
    ; handle update skin notification
    Case #WM_UPDATESKIN
      
      ; respond to a request to update all skinned controls or controls using the skin specified in lParam
      If lParam = #False Or lParam = splitterx()\skin
        
        ; only update if our skin has SkinAutoUpdate set
        If GetSkinAutoUpdate(splitterx()\skin) = #True
          SetSplitterExSkin(splitterx()\Handle, splitterx()\skin, "", #True)
        EndIf
          
      EndIf
    
  EndSelect
  
  ProcedureReturn Result
EndProcedure

Procedure splitterExGrabberCallback(Window, message, wParam, lParam)
  Static spt.POINT
  
  ; find associated splitterx
  ForEach splitterx()
    If splitterx()\grabberPageHandle = Window
      found = #True
      Break
    EndIf
  Next
  
  If found = #False
    ProcedureReturn 0
  EndIf
  
  Select message
      
    Case #WM_MOUSEMOVE
      
      If mouseCaptured = 0
        
        tm.TRACKMOUSEEVENT
        tm\cbSize = SizeOf(TRACKMOUSEEVENT)
        tm\dwFlags = #TME_LEAVE
        tm\hwndTrack = Window
        TrackMouseEvent_(@tm)
        
        mouseCaptured = #True
        
        splitterx()\index = 1
        
        If splitterDrag = 0
          
          ; send #SPLITTEREX_MOUSEHOVER notification message to apps main window
          root = GetAncestor_(WindowID, #GA_ROOT)
          PostMessage_(root, #SPLITTEREX_MOUSEHOVER, WindowID, #True)
          
          i = 1
          bk = splitterx()\gbk[i]
          bkstyle = splitterx()\gbkstyle[i]
          bkx = splitterx()\gbkx[i]
          bky = splitterx()\gbky[i]
          obk = splitterx()\gobk[i]
          obkstyle = splitterx()\gobkstyle[i]
          obkx = splitterx()\gobkx[i]
          obky = splitterx()\gobky[i]
          bkimage = splitterx()\gbkimage[i]
          bkwidth = splitterx()\gbkwidth[i]
          bkheight = splitterx()\gbkheight[i]
          obkimage = splitterx()\gobkimage[i]
          obkwidth = splitterx()\gobkwidth[i]
          obkheight = splitterx()\gobkheight[i]
          border = splitterx()\gborder[i]
          If splitterx()\gborderrect[i]\left <> 0 And splitterx()\gborderrect[i]\top <> 0 And splitterx()\gborderrect[i]\bottom And splitterx()\gborderrect[i]\right <> 0
            CopyStructure(splitterx()\gborderrect[i], @rc.RECT, RECT)
            rectCreated = #True
          EndIf
          mask = splitterx()\gmask[i]
          
          
          SetPanelExPageBackground(splitterx()\grabberHandle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
          SetPanelExPageBackground(splitterx()\grabberHandle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
          
          If rectCreated = #True
            SetPanelExPageBorder(splitterx()\grabberHandle, 0, border, mask, rc.RECT, 0, #True)
          Else
            SetPanelExPageBorder(splitterx()\grabberHandle, 0, border, mask, 0, 0, #True)
          EndIf
          
          
          
          hwnd = getRootPanelExPageHwnd(Window)
          GetClientRect_(Window, @rc.RECT)
          MapWindowPoints_(Window, hwnd, @rc, 2)
          RedrawWindow_(hwnd, rc, 0, #RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ERASE)
          
        EndIf
        
      EndIf
    
    Case #WM_MOUSELEAVE
      
    
      mouseCaptured = #False
      splitterx()\index = 0
      
      If splitterDrag = 0 Or splitterDrag = -1
        
        ; send #SPLITTEREX_MOUSEHOVER notification message to apps main window
        root = GetAncestor_(WindowID, #GA_ROOT)
        PostMessage_(root, #SPLITTEREX_MOUSEHOVER, WindowID, #False)
        
        i = 0
        bk = splitterx()\gbk[i]
        bkstyle = splitterx()\gbkstyle[i]
        bkx = splitterx()\gbkx[i]
        bky = splitterx()\gbky[i]
        obk = splitterx()\gobk[i]
        obkstyle = splitterx()\gobkstyle[i]
        obkx = splitterx()\gobkx[i]
        obky = splitterx()\gobky[i]
        bkimage = splitterx()\gbkimage[i]
        bkwidth = splitterx()\gbkwidth[i]
        bkheight = splitterx()\gbkheight[i]
        obkimage = splitterx()\gobkimage[i]
        obkwidth = splitterx()\gobkwidth[i]
        obkheight = splitterx()\gobkheight[i]
        border = splitterx()\gborder[i]
        If splitterx()\gborderrect[i]\left <> 0 And splitterx()\gborderrect[i]\top <> 0 And splitterx()\gborderrect[i]\bottom And splitterx()\gborderrect[i]\right <> 0
          CopyStructure(splitterx()\gborderrect[i], @rc.RECT, RECT)
          rectCreated = #True
        EndIf
        mask = splitterx()\gmask[i]
        
        
        SetPanelExPageBackground(splitterx()\grabberHandle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
        SetPanelExPageBackground(splitterx()\grabberHandle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
        
        If rectCreated = #True
          SetPanelExPageBorder(splitterx()\grabberHandle, 0, border, mask, rc.RECT, 0, #True)
        Else
          SetPanelExPageBorder(splitterx()\grabberHandle, 0, border, mask, 0, 0, #True)
        EndIf
        
        If splitterDrag = -1
          GetClientRect_(splitterx()\grabberHandle, @rc.RECT)
          MapWindowPoints_(splitterx()\grabberHandle, splitterx()\pageHandle, @rc, 2)
          GetWindowRect_(splitterx()\pageHandle, @prc.RECT)
          If splitterx()\flags & #SPLITTEREX_VERTICAL
            splitterx()\grabberRatio = (100/(prc\bottom-prc\top))*(rc\top+(splitterx()\grabbervheight/2))
            If rc\top = 0
              splitterx()\grabberRatio = 0
            ElseIf rc\bottom = prc\bottom-prc\top
              splitterx()\grabberRatio = 100
            EndIf
          Else
            splitterx()\grabberRatio = (100/(prc\right-prc\left))*(rc\left+(splitterx()\grabberwidth/2))
            If rc\left = 0
              splitterx()\grabberRatio = 0
            ElseIf rc\right = prc\right-prc\left
              splitterx()\grabberRatio = 100
            EndIf
          EndIf
          splitterDrag = 0
        EndIf
        
        hwnd = getRootPanelExPageHwnd(Window)
        GetClientRect_(Window, @rc.RECT)
        MapWindowPoints_(Window, hwnd, @rc, 2)
        RedrawWindow_(hwnd, rc, 0, #RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ERASE)
        
      EndIf
      
    Case #WM_LBUTTONDOWN
      
      ; exit if coords same as last time and reset stored coords - fixes a trackpad double tap drag problem with not sending a WM_LBUTTONUP
      GetCursorPos_(@pt.POINT)
      If (pt\x = spt\x And Not splitterx()\flags & #SPLITTEREX_VERTICAL) Or (pt\y = spt\y And splitterx()\flags & #SPLITTEREX_VERTICAL)
        spt\x = -1
        spt\y = -1
        ProcedureReturn 0
      EndIf
      
      GetCursorPos_(@spt) ; temp store start coords of mouse
      
      ; send #SPLITTEREX_MOUSEDOWN notification message to apps main window
      root = GetAncestor_(WindowID, #GA_ROOT)
      PostMessage_(root, #SPLITTEREX_MOUSEDOWN, WindowID, lParam)
      
      
      splitterx()\index = 2
      
      i = 2
      bk = splitterx()\gbk[i]
      bkstyle = splitterx()\gbkstyle[i]
      bkx = splitterx()\gbkx[i]
      bky = splitterx()\gbky[i]
      obk = splitterx()\gobk[i]
      obkstyle = splitterx()\gobkstyle[i]
      obkx = splitterx()\gobkx[i]
      obky = splitterx()\gobky[i]
      bkimage = splitterx()\gbkimage[i]
      bkwidth = splitterx()\gbkwidth[i]
      bkheight = splitterx()\gbkheight[i]
      obkimage = splitterx()\gobkimage[i]
      obkwidth = splitterx()\gobkwidth[i]
      obkheight = splitterx()\gobkheight[i]
      border = splitterx()\gborder[i]
      If splitterx()\gborderrect[i]\left <> 0 And splitterx()\gborderrect[i]\top <> 0 And splitterx()\gborderrect[i]\bottom And splitterx()\gborderrect[i]\right <> 0
        CopyStructure(splitterx()\gborderrect[i], @rc.RECT, RECT)
        rectCreated = #True
      EndIf
      mask = splitterx()\gmask[i]
      
      
      SetPanelExPageBackground(splitterx()\grabberHandle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
      SetPanelExPageBackground(splitterx()\grabberHandle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
      
      If rectCreated = #True
        SetPanelExPageBorder(splitterx()\grabberHandle, 0, border, mask, rc.RECT, 0, #True)
      Else
        SetPanelExPageBorder(splitterx()\grabberHandle, 0, border, mask, 0, 0, #True)
      EndIf
      
      If splitterHook = 0 And (splitterDrag = 0 Or splitterDrag = -1)
        
        splitterGrabberHwnd = splitterx()\grabberHandle
        splitterGrabberPageHwnd = splitterx()\grabberPageHandle
        splitterDelta = -1
        If splitterx()\flags & #SPLITTEREX_VERTICAL
          splitterMode = #SPLITTEREX_VERTICAL
        Else
          splitterMode = 0
        EndIf
        splitterHwnd1 = splitterx()\hwnd1
        splitterHwnd2 = splitterx()\hwnd2
        If splitterx()\flags & #SPLITTEREX_VERTICAL
          splitterGrabberWidth = splitterx()\grabbervwidth
          splitterGrabberHeight = splitterx()\grabbervheight
          splitterFirstPadding\left = splitterx()\vfirstpadding\left
          splitterFirstPadding\right = splitterx()\vfirstpadding\right
          splitterFirstPadding\top = splitterx()\vfirstpadding\top
          splitterFirstPadding\bottom = splitterx()\vfirstpadding\bottom
          splitterSecondPadding\left = splitterx()\vsecondpadding\left
          splitterSecondPadding\right = splitterx()\vsecondpadding\right
          splitterSecondPadding\top = splitterx()\vsecondpadding\top
          splitterSecondPadding\bottom = splitterx()\vsecondpadding\bottom
        Else
          splitterGrabberWidth = splitterx()\grabberwidth
          splitterGrabberHeight = splitterx()\grabberheight
          splitterFirstPadding\left = splitterx()\firstpadding\left
          splitterFirstPadding\right = splitterx()\firstpadding\right
          splitterFirstPadding\top = splitterx()\firstpadding\top
          splitterFirstPadding\bottom = splitterx()\firstpadding\bottom
          splitterSecondPadding\left = splitterx()\secondpadding\left
          splitterSecondPadding\right = splitterx()\secondpadding\right
          splitterSecondPadding\top = splitterx()\secondpadding\top
          splitterSecondPadding\bottom = splitterx()\secondpadding\bottom
        EndIf
        splitterFirstMin = splitterx()\firstmin
        splitterFirstMax = splitterx()\firstmax
        splitterSecondMin = splitterx()\secondmin
        splitterSecondMax = splitterx()\secondmax
        splitterFirstHidden = splitterx()\firsthidden
        splitterSecondHidden = splitterx()\secondhidden
        splitterDrag = #True
        
        SetCapture_(splitterGrabberHwnd)
        pt.POINT
        GetCursorPos_(@pt)
        MapWindowPoints_(0, splitterx()\pageHandle, @pt, 1)
        updateSplitter(pt\x, pt\y)
        splitterHook = SetWindowsHookEx_(#WH_MOUSE_LL, @splitterMouseHook(), GetModuleHandle_(0), 0)
        
      EndIf
      
      hwnd = getRootPanelExPageHwnd(Window)
      GetClientRect_(Window, @rc.RECT)
      MapWindowPoints_(Window, hwnd, @rc, 2)
      RedrawWindow_(hwnd, rc, 0, #RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ERASE)
      
    Case #WM_LBUTTONUP
      
      GetCursorPos_(@pt.POINT)
      
      ; handle anchoring if activated
      If splitterx()\anchor <> #False
        
        GetClientRect_(splitterx()\pageHandle, @rc.RECT)
        GetClientRect_(splitterx()\grabberHandle, @grc.RECT)
        MapWindowPoints_(splitterx()\grabberHandle, splitterx()\pageHandle, @grc, 2)
        splitterx()\anchored = #False
        If splitterx()\anchor = #SPLITTEREX_ANCHOREDLEFT
          If grc\left = 0 Or grc\left = splitterx()\firstmin
            splitterx()\anchored = #True
          EndIf
        ElseIf splitterx()\anchor = #SPLITTEREX_ANCHOREDTOP
          If grc\top = 0 Or grc\top = splitterx()\firstmin
            splitterx()\anchored = #True
          EndIf
        ElseIf splitterx()\anchor = #SPLITTEREX_ANCHOREDRIGHT
          If grc\right = rc\right Or grc\right = splitterx()\secondmin
            splitterx()\anchored = #True
          EndIf
        ElseIf splitterx()\anchor = #SPLITTEREX_ANCHOREDBOTTOM
          If grc\bottom = rc\bottom Or grc\bottom = splitterx()\secondmin
            splitterx()\anchored = #True
          EndIf
        EndIf
        
        ; if splitter not moved when clicked
        If (pt\x = spt\x And Not splitterx()\flags & #SPLITTEREX_VERTICAL) Or (pt\y = spt\y And splitterx()\flags & #SPLITTEREX_VERTICAL)
          ;Debug "click!"
          
          If splitterx()\anchored = #True ; splitterex is anchored
            
            splitterx()\anchored = #False
            *thisSplitterx = @splitterx()
            
            If splitterx()\storeDelta <> 0
              delta = splitterx()\storeDelta
              Debug delta
            EndIf
            
            If splitterx()\anchor = #SPLITTEREX_ANCHOREDLEFT Or splitterx()\anchor = #SPLITTEREX_ANCHOREDTOP
              If splitterx()\storeDelta = 0
                delta = splitterx()\firstmax
              EndIf
              SetSplitterExAttribute(splitterx()\handle, #SPLITTEREX_POSITION, delta)
            Else
              GetClientRect_(splitterx()\pagehandle, @rc.RECT)
              GetClientRect_(splitterx()\grabberHandle, @grc.RECT)
              If Not splitterx()\flags & #SPLITTEREX_VERTICAL
                If splitterx()\storeDelta = 0
                  delta = (splitterx()\secondmax+grc\right)
                EndIf
                SetSplitterExAttribute(splitterx()\handle, #SPLITTEREX_POSITION, (rc\right)-(delta+grc\right))
              Else
                If splitterx()\storeDelta = 0
                  delta = (splitterx()\secondmax+grc\bottom)
                EndIf
                Debug "good "+Str(delta)
                SetSplitterExAttribute(splitterx()\handle, #SPLITTEREX_POSITION, (rc\bottom)-(delta+grc\bottom))
              EndIf
            EndIf
            
            
            ChangeCurrentElement(splitterx(), *thisSplitterx)
          Else ; splitterex is not anchored
            
            splitterx()\anchored = #True
            *thisSplitterx = @splitterx()
            
            If splitterx()\storeDelta = 0
              GetClientRect_(splitterx()\pageHandle, @rc.RECT)
              GetClientRect_(splitterx()\grabberHandle, @grc.RECT)
              MapWindowPoints_(splitterx()\grabberHandle, splitterx()\pageHandle, @grc, 2)
              If splitterx()\flags & #SPLITTEREX_VERTICAL
                If splitterx()\anchor = #SPLITTEREX_ANCHOREDTOP
                  splitterx()\storeDelta = grc\top
                ElseIf splitterx()\anchor = #SPLITTEREX_ANCHOREDBOTTOM
                  splitterx()\storeDelta = rc\bottom-grc\bottom
                EndIf
              Else
                If splitterx()\anchor = #SPLITTEREX_ANCHOREDLEFT
                  splitterx()\storeDelta = grc\left
                ElseIf splitterx()\anchor = #SPLITTEREX_ANCHOREDRIGHT
                  splitterx()\storeDelta = rc\right-grc\right
                EndIf
              EndIf
            EndIf
            
            If splitterx()\anchor = #SPLITTEREX_ANCHOREDLEFT Or splitterx()\anchor = #SPLITTEREX_ANCHOREDTOP
              SetSplitterExAttribute(splitterx()\handle, #SPLITTEREX_POSITION, splitterx()\firstmin)
            Else
              GetClientRect_(splitterx()\handle, @rc.RECT)
              GetClientRect_(splitterx()\grabberHandle, @grc.RECT)
              If Not splitterx()\flags & #SPLITTEREX_VERTICAL
                SetSplitterExAttribute(splitterx()\handle, #SPLITTEREX_POSITION, (rc\right)-(splitterx()\secondmin+grc\right))
              Else
                SetSplitterExAttribute(splitterx()\handle, #SPLITTEREX_POSITION, (rc\bottom)-(splitterx()\secondmin+grc\bottom))
              EndIf
            EndIf
            
            ChangeCurrentElement(splitterx(), *thisSplitterx)
          EndIf
          
        ; splitter position changed then store new pos and make not anchored  
        ElseIf (pt\x <> spt\x And Not splitterx()\flags & #SPLITTEREX_VERTICAL) Or (pt\y <> spt\y And splitterx()\flags & #SPLITTEREX_VERTICAL)
          
          GetClientRect_(splitterx()\pageHandle, @rc.RECT)
          GetClientRect_(splitterx()\grabberHandle, @grc.RECT)
          MapWindowPoints_(splitterx()\grabberHandle, splitterx()\pageHandle, @grc, 2)
          If splitterx()\flags & #SPLITTEREX_VERTICAL
            If splitterx()\anchor = #SPLITTEREX_ANCHOREDTOP
              splitterx()\storeDelta = grc\top
            ElseIf splitterx()\anchor = #SPLITTEREX_ANCHOREDBOTTOM
              splitterx()\storeDelta = rc\bottom-grc\bottom
            EndIf
          Else
            If splitterx()\anchor = #SPLITTEREX_ANCHOREDLEFT
              splitterx()\storeDelta = grc\left
            ElseIf splitterx()\anchor = #SPLITTEREX_ANCHOREDRIGHT
              splitterx()\storeDelta = rc\right-grc\right
            EndIf
          EndIf
          splitterx()\anchored = #False
          ;Debug "store: "+Str(splitterx()\storeDelta)
          
        EndIf
      EndIf
      
      ; send #SPLITTEREX_MOUSEUP notification message to apps main window
      root = GetAncestor_(WindowID, #GA_ROOT)
      PostMessage_(root, #SPLITTEREX_MOUSEUP, WindowID, lParam)
      
      splitterx()\index = 1
      
      i = 1
      bk = splitterx()\gbk[i]
      bkstyle = splitterx()\gbkstyle[i]
      bkx = splitterx()\gbkx[i]
      bky = splitterx()\gbky[i]
      obk = splitterx()\gobk[i]
      obkstyle = splitterx()\gobkstyle[i]
      obkx = splitterx()\gobkx[i]
      obky = splitterx()\gobky[i]
      bkimage = splitterx()\gbkimage[i]
      bkwidth = splitterx()\gbkwidth[i]
      bkheight = splitterx()\gbkheight[i]
      obkimage = splitterx()\gobkimage[i]
      obkwidth = splitterx()\gobkwidth[i]
      obkheight = splitterx()\gobkheight[i]
      border = splitterx()\gborder[i]
      If splitterx()\gborderrect[i]\left <> 0 And splitterx()\gborderrect[i]\top <> 0 And splitterx()\gborderrect[i]\bottom And splitterx()\gborderrect[i]\right <> 0
        CopyStructure(splitterx()\gborderrect[i], @rc.RECT, RECT)
        rectCreated = #True
      EndIf
      mask = splitterx()\gmask[i]
      
      
      SetPanelExPageBackground(splitterx()\grabberHandle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
      SetPanelExPageBackground(splitterx()\grabberHandle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
      
      If rectCreated = #True
        SetPanelExPageBorder(splitterx()\grabberHandle, 0, border, mask, rc.RECT, 0, #True)
      Else
        SetPanelExPageBorder(splitterx()\grabberHandle, 0, border, mask, 0, 0, #True)
      EndIf
      
      hwnd = getRootPanelExPageHwnd(Window)
      GetClientRect_(Window, @rc.RECT)
      MapWindowPoints_(Window, hwnd, @rc, 2)
      RedrawWindow_(hwnd, rc, 0, #RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ERASE)
      
      splitterDrag = -1
      ReleaseCapture_()
      If splitterHook <> 0
        UnhookWindowsHookEx_(splitterHook)
        splitterHook = 0
      EndIf
      
    Case #WM_CAPTURECHANGED
      
      If mouseCaptured = #True
        mouseCaptured = #False
        splitterx()\index = 0
        
        If splitterDrag = 0
          
          i = 0
          bk = splitterx()\gbk[i]
          bkstyle = splitterx()\gbkstyle[i]
          bkx = splitterx()\gbkx[i]
          bky = splitterx()\gbky[i]
          obk = splitterx()\gobk[i]
          obkstyle = splitterx()\gobkstyle[i]
          obkx = splitterx()\gobkx[i]
          obky = splitterx()\gobky[i]
          bkimage = splitterx()\gbkimage[i]
          bkwidth = splitterx()\gbkwidth[i]
          bkheight = splitterx()\gbkheight[i]
          obkimage = splitterx()\gobkimage[i]
          obkwidth = splitterx()\gobkwidth[i]
          obkheight = splitterx()\gobkheight[i]
          border = splitterx()\gborder[i]
          If splitterx()\gborderrect[i]\left <> 0 And splitterx()\gborderrect[i]\top <> 0 And splitterx()\gborderrect[i]\bottom And splitterx()\gborderrect[i]\right <> 0
            CopyStructure(splitterx()\gborderrect[i], @rc.RECT, RECT)
            rectCreated = #True
          EndIf
          mask = splitterx()\gmask[i]
          
          
          SetPanelExPageBackground(splitterx()\grabberHandle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
          SetPanelExPageBackground(splitterx()\grabberHandle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
          
          If rectCreated = #True
            SetPanelExPageBorder(splitterx()\grabberHandle, 0, border, mask, rc.RECT, 0, #True)
          Else
            SetPanelExPageBorder(splitterx()\grabberHandle, 0, border, mask, 0, 0, #True)
          EndIf
          
          SetClassLongPtr_(splitterx()\grabberPageHandle, #GCLP_HCURSOR, normalMousePointer)
          
          hwnd = getRootPanelExPageHwnd(Window)
          GetClientRect_(Window, @rc.RECT)
          MapWindowPoints_(Window, hwnd, @rc, 2)
          RedrawWindow_(hwnd, rc, 0, #RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ERASE)
          
        EndIf
          
      EndIf
    
  EndSelect
  
  ProcedureReturn Result
EndProcedure

ProcedureDLL SetSplitterExSkin(ID.i, Skin.i, ComponentName.s, noRefresh.b) ; Sets a SplitterEx's skin
  
  macro_protectCommand()
  
  ;find splitterex
  ForEach splitterx()
    If splitterx()\handle = ID Or splitterx()\id = ID
      foundSplitterx = #True
      Break
    EndIf
  Next
  
  ;find skin
  ForEach skin()
    If @skin() = Skin
      foundSkin = #True
      Break
    EndIf
  Next
  
  If foundSplitterx = #True And foundSkin = #True
    
    If ComponentName = "" And splitterx()\componentname = ""
      ComponentName = "splitterex"
    ElseIf ComponentName = "" And splitterx()\componentname <> ""
      ComponentName = splitterx()\componentname
    EndIf
    
    If splitterx()\flags & #SPLITTEREX_VERTICAL
      vertical$ = " vertical"
      splitterx()\grabbervwidth = Val(GetSkinPropertyParamp(skin, ComponentName, "normal vertical", "gripper size", "width"))
      splitterx()\grabbervheight = Val(GetSkinPropertyParamp(skin, ComponentName, "normal vertical", "gripper size", "height"))
      
      splitterx()\vfirstpadding\left = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "first padding", "left"))
      splitterx()\vfirstpadding\right = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "first padding", "right"))
      splitterx()\vfirstpadding\top = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "first padding", "top"))
      splitterx()\vfirstpadding\bottom = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "first padding", "bottom"))
      splitterx()\vsecondpadding\left = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "second padding", "left"))
      splitterx()\vsecondpadding\right = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "second padding", "right"))
      splitterx()\vsecondpadding\top = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "second padding", "top"))
      splitterx()\vsecondpadding\bottom = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "second padding", "bottom"))
    Else
      splitterx()\grabberwidth = Val(GetSkinPropertyParamp(skin, ComponentName, "normal", "gripper size", "width"))
      splitterx()\grabberheight = Val(GetSkinPropertyParamp(skin, ComponentName, "normal", "gripper size", "height"))
      
      splitterx()\firstpadding\left = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "first padding", "left"))
      splitterx()\firstpadding\right = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "first padding", "right"))
      splitterx()\firstpadding\top = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "first padding", "top"))
      splitterx()\firstpadding\bottom = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "first padding", "bottom"))
      splitterx()\secondpadding\left = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "second padding", "left"))
      splitterx()\secondpadding\right = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "second padding", "right"))
      splitterx()\secondpadding\top = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "second padding", "top"))
      splitterx()\secondpadding\bottom = Val(GetSkinPropertyParamp(skin, ComponentName, "normal"+vertical$, "second padding", "bottom"))
    EndIf
    
    
    For i = 0 To #splitterexstates-1
      
      bk = 0
      bkstyle = 0
      bkx = 0
      bky = 0
      obk = 0
      obkstyle = 0
      obkx = 0
      obky = 0
      bkimage = 0
      bkwidth = 0
      bkheight = 0
      obkimage = 0
      obkwidth = 0
      obkheight = 0
      border = 0
      mask = 0
      
      Select i
          Case 0
            state$ = "normal"
          Case 1
            state$ = "hot"
          Case 2
            state$ = "pressed"
          Case 3
            state$ = "disabled"
      EndSelect
      
      If splitterx()\flags & #SPLITTEREX_VERTICAL
        state$ = state$ + " vertical"
      EndIf
      
      
      bk = -1
      
      
      bkimage = GetSkinPropertyData(skin, ComponentName, state$, "background image")
      If bkimage = 0
        bkimage = nullicon
      EndIf
      
      xpos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "x")
      If FindString(xpos, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_HPERCENT
      EndIf
      If xpos <> ""
        If xpos = "centre"
          bkstyle = bkstyle | #PNLX_CENTRE
        ElseIf xpos = "repeat"
          bkstyle = bkstyle | #PNLX_HREPEAT
        Else
          bkx = Val(xpos)
        EndIf
      EndIf
      
      ypos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "y")
      If FindString(ypos, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_VPERCENT
      EndIf
      If ypos <> ""
        If ypos = "centre"
          bkstyle = bkstyle | #PNLX_VCENTRE
        ElseIf ypos = "repeat"
          bkstyle = bkstyle | #PNLX_VREPEAT
        Else
          bky = Val(ypos)
        EndIf
      EndIf
      
      left.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "left")
      If FindString(left, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_HPERCENT
      EndIf
      If left <> ""
        If left = "centre"
          bkstyle = bkstyle | #PNLX_CENTRE
        ElseIf left = "repeat"
          bkstyle = bkstyle | #PNLX_HREPEAT
        Else
          bkx = Val(left)
        EndIf
      EndIf
      
      top.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "top")
      If FindString(top, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_VPERCENT
      EndIf
      If top <> ""
        If top = "centre"
          bkstyle = bkstyle | #PNLX_VCENTRE
        ElseIf top = "repeat"
          bkstyle = bkstyle | #PNLX_VREPEAT
        Else
          bky = Val(top)
        EndIf
      EndIf
      
      right.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "right")
      If FindString(right, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_HPERCENT
      EndIf
      If right <> ""
        If right = "centre"
          bkstyle = bkstyle | #PNLX_CENTRE
        ElseIf right = "repeat"
          bkstyle = bkstyle | #PNLX_HREPEAT
        Else
          bkx = Val(right)
          bkstyle = bkstyle | #PNLX_RIGHT
        EndIf
      EndIf
      
      bottom.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "bottom")
      If FindString(bottom, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_VPERCENT
      EndIf
      If bottom <> ""
        If bottom = "centre"
          bkstyle = bkstyle | #PNLX_VCENTRE
        ElseIf bottom = "repeat"
          bkstyle = bkstyle | #PNLX_VREPEAT
        Else
          bky = Val(bottom)
          bkstyle = bkstyle | #PNLX_BOTTOM
        EndIf
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "stretch") = "true"
        bkstyle = bkstyle | #PNLX_STRETCH
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "tile") = "true"
        bkstyle = bkstyle | #PNLX_TILE
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "masked") = "true"
        bkstyle = bkstyle | #PNLX_MASKED
      EndIf
      
      p.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background", "gradient")
      If p <> ""
        gradient = GetSkinPropertyData(skin, ComponentName, state$, "background")
        If gradient <> 0 And GetSkinPropertyDataSize(skin, ComponentName, state$, "background") <> 0
          bk = gradient
        EndIf
      Else
        c = GetSkinPropertyColour(skin, ComponentName, state$, "background")
        If c <> -1
          ; no alpha then remake colour with alpha
          If Alpha(c) = 0
            c = MakeColor(255, Red(c), Green(c), Blue(c))
          EndIf
          
          bk = CreateGradient(0, c, c)
          If bk <> 0
            SetSkinPropertyData(skin, ComponentName, state$, "background", bk)
            SetSkinPropertyDataSize(skin, ComponentName, state$, "background", SizeOf(bk))
          EndIf
        Else
          bk = Val(GetSkinPropertyp(skin, ComponentName, state$, "background"))
        EndIf
      EndIf
      
      ; border image
      border = GetSkinPropertyData(skin, ComponentName, state$, "border image")
      t = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "top"))
      l = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "left"))
      b = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "bottom"))
      r = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "right"))
      If border <> 0 And t > 0 And l > 0 And b > 0 And r > 0
        rc.RECT
        rc\top = t
        rc\left = l
        rc\bottom = b
        rc\right = r
        rectCreated = #True
      EndIf
      mask = GetSkinPropertyData(skin, ComponentName, state$, "border mask")
      If mask = 0
        mask = Val(GetSkinPropertyp(skin, ComponentName, state$, "border mask"))
      EndIf
      
      ;If rectCreated = #False
        t = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "top"))
        l = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "left"))
        b = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "bottom"))
        r = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "right"))
        If mask <> 0 And t > 0 And l > 0 And b > 0 And r > 0
          rc.RECT
          rc\top = t
          rc\left = l
          rc\bottom = b
          rc\right = r
          rectCreated = #True
        EndIf
      ;EndIf
      
      ; overlay
      obkimage = GetSkinPropertyData(skin, ComponentName, state$, "overlay image")
      If obkimage = 0
        obkimage = nullicon
      EndIf
      
      oxpos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "x")
      If FindString(oxpos, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_HPERCENT
      EndIf
      If oxpos <> ""
        If oxpos = "centre"
          obkstyle = obkstyle | #PNLX_CENTRE
        ElseIf oxpos = "repeat"
          obkstyle = obkstyle | #PNLX_HREPEAT
        Else
          obkx = Val(oxpos)
        EndIf
      EndIf
      
      oypos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "y")
      If FindString(oypos, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_VPERCENT
      EndIf
      If oypos <> ""
        If oypos = "centre"
          obkstyle = obkstyle | #PNLX_VCENTRE
        ElseIf oypos = "repeat"
          obkstyle = obkstyle | #PNLX_VREPEAT
        Else
          obky = Val(oypos)
        EndIf
      EndIf
      
      left.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "left")
      If FindString(left, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_HPERCENT
      EndIf
      If left <> ""
        If left = "centre"
          obkstyle = obkstyle | #PNLX_CENTRE
        ElseIf left = "repeat"
          obkstyle = obkstyle | #PNLX_HREPEAT
        Else
          obkx = Val(left)
        EndIf
      EndIf
      
      top.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "top")
      If FindString(top, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_VPERCENT
      EndIf
      If top <> ""
        If top = "centre"
          obkstyle = obkstyle | #PNLX_VCENTRE
        ElseIf top = "repeat"
          obkstyle = obkstyle | #PNLX_VREPEAT
        Else
          obky = Val(top)
        EndIf
      EndIf
      
      right.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "right")
      If FindString(right, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_HPERCENT
      EndIf
      If right <> ""
        If right = "centre"
          obkstyle = obkstyle | #PNLX_CENTRE
        ElseIf right = "repeat"
          obkstyle = obkstyle | #PNLX_HREPEAT
        Else
          obkx = Val(right)
          obkstyle = obkstyle | #PNLX_RIGHT
        EndIf
      EndIf
      
      bottom.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "bottom")
      If FindString(bottom, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_VPERCENT
      EndIf
      If bottom <> ""
        If bottom = "centre"
          obkstyle = obkstyle | #PNLX_VCENTRE
        ElseIf bottom = "repeat"
          obkstyle = obkstyle | #PNLX_VREPEAT
        Else
          obky = Val(bottom)
          obkstyle = obkstyle | #PNLX_BOTTOM
        EndIf
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "stretch") = "true"
        obkstyle = obkstyle | #PNLX_STRETCH
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "tile") = "true"
        obkstyle = obkstyle | #PNLX_TILE
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "masked") = "true"
        obkstyle = obkstyle | #PNLX_MASKED
      EndIf
      
      p.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay", "gradient")
      If p <> ""
        gradient = GetSkinPropertyData(skin, ComponentName, state$, "overlay")
        If gradient <> 0 And GetSkinPropertyDataSize(skin, ComponentName, state$, "overlay") <> 0
          obk = gradient
        EndIf
      Else
        c = GetSkinPropertyColour(skin, ComponentName, state$, "overlay")
        If c <> -1
          ; no alpha then remake colour with alpha
          If Alpha(c) = 0
            c = MakeColor(255, Red(c), Green(c), Blue(c))
          EndIf
          
          obk = CreateGradient(0, c, c)
          If obk <> 0
            SetSkinPropertyData(skin, ComponentName, state$, "overlay", obk)
            SetSkinPropertyDataSize(skin, ComponentName, state$, "overlay", SizeOf(obk))
          EndIf
        Else
          If GetSkinPropertyp(skin, ComponentName, state$, "overlay") = ""
            obk = -1
          Else
            obk = Val(GetSkinPropertyp(skin, ComponentName, state$, "overlay"))
          EndIf
        EndIf
      EndIf
      
      
      If i = 0
        SetPanelExPageBackground(splitterx()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
        SetPanelExPageBackground(splitterx()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
        If rectCreated = #True
          SetPanelExPageBorder(splitterx()\Handle, 0, border, mask, rc.RECT, 0, #True)
        Else
          SetPanelExPageBorder(splitterx()\Handle, 0, border, mask, 0, 0, #True)
        EndIf
      EndIf
      
      splitterx()\bk[i] = bk
      splitterx()\bkstyle[i] = bkstyle
      splitterx()\bkx[i] = bkx
      splitterx()\bky[i] = bky
      splitterx()\obk[i] = obk
      splitterx()\obkstyle[i] = obkstyle
      splitterx()\obkx[i] = obkx
      splitterx()\obky[i] = obky
      splitterx()\bkimage[i] = bkimage
      splitterx()\bkwidth[i] = bkwidth
      splitterx()\bkheight[i] = bkheight
      splitterx()\obkimage[i] = obkimage
      splitterx()\obkwidth[i] = obkwidth
      splitterx()\obkheight[i] = obkheight
      splitterx()\border[i] = border
      If rectCreated = #True
        CopyStructure(rc, splitterx()\borderrect, RECT)
      EndIf
      splitterx()\mask[i] = mask
      
      
      gbkstyle = 0
      gbkx = 0
      gbky = 0
      gobk = 0
      gobkstyle = 0
      gobkx = 0
      gobky = 0
      gbkimage = 0
      gbkwidth = 0
      gbkheight = 0
      gobkimage = 0
      gobkwidth = 0
      gobkheight = 0
      gborder = 0
      gmask = 0
      
      gbk = -1
      
      gbkimage = GetSkinPropertyData(skin, ComponentName, state$, "gripper background image")
      If gbkimage = 0
        gbkimage = nullicon
      EndIf
      
      gxpos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper background position", "x")
      If FindString(gxpos, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_HPERCENT
      EndIf
      If gxpos <> ""
        If gxpos = "centre"
          gbkstyle = gbkstyle | #PNLX_CENTRE
        ElseIf gxpos = "repeat"
          gbkstyle = gbkstyle | #PNLX_HREPEAT
        Else
          gbkx = Val(xpos)
        EndIf
      EndIf
      
      gypos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper background position", "y")
      If FindString(ypos, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_VPERCENT
      EndIf
      If gypos <> ""
        If gypos = "centre"
          gbkstyle = gbkstyle | #PNLX_VCENTRE
        ElseIf gypos = "repeat"
          gbkstyle = gbkstyle | #PNLX_VREPEAT
        Else
          gbky = Val(gypos)
        EndIf
      EndIf
      
      gleft.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper background position", "left")
      If FindString(gleft, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_HPERCENT
      EndIf
      If gleft <> ""
        If gleft = "centre"
          gbkstyle = gbkstyle | #PNLX_CENTRE
        ElseIf gleft = "repeat"
          gbkstyle = gbkstyle | #PNLX_HREPEAT
        Else
          gbkx = Val(gleft)
        EndIf
      EndIf
      
      gtop.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper background position", "top")
      If FindString(gtop, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_VPERCENT
      EndIf
      If gtop <> ""
        If gtop = "centre"
          gbkstyle = gbkstyle | #PNLX_VCENTRE
        ElseIf gtop = "repeat"
          gbkstyle = gbkstyle | #PNLX_VREPEAT
        Else
          gbky = Val(gtop)
        EndIf
      EndIf
      
      gright.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper background position", "right")
      If FindString(gright, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_HPERCENT
      EndIf
      If gright <> ""
        If gright = "centre"
          gbkstyle = gbkstyle | #PNLX_CENTRE
        ElseIf gright = "repeat"
          gbkstyle = gbkstyle | #PNLX_HREPEAT
        Else
          gbkx = Val(gright)
          gbkstyle = gbkstyle | #PNLX_RIGHT
        EndIf
      EndIf
      
      gbottom.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper background position", "bottom")
      If FindString(gbottom, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_VPERCENT
      EndIf
      If gbottom <> ""
        If gbottom = "centre"
          gbkstyle = gbkstyle | #PNLX_VCENTRE
        ElseIf gbottom = "repeat"
          gbkstyle = gbkstyle | #PNLX_VREPEAT
        Else
          gbky = Val(gbottom)
          gbkstyle = gbkstyle | #PNLX_BOTTOM
        EndIf
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "gripper background position", "stretch") = "true"
        gbkstyle = gbkstyle | #PNLX_STRETCH
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "gripper background position", "tile") = "true"
        gbkstyle = gbkstyle | #PNLX_TILE
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "gripper background position", "masked") = "true"
        gbkstyle = gbkstyle | #PNLX_MASKED
      EndIf
      
      gp.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper background", "gradient")
      If gp <> ""
        gradient = GetSkinPropertyData(skin, ComponentName, state$, "gripper background")
        If gradient <> 0 And GetSkinPropertyDataSize(skin, ComponentName, state$, "gripper background") <> 0
          gbk = gradient
        EndIf
      Else
        c = GetSkinPropertyColour(skin, ComponentName, state$, "gripper background")
        If c <> -1
          ; no alpha then remake colour with alpha
          If Alpha(c) = 0
            c = MakeColor(255, Red(c), Green(c), Blue(c))
          EndIf
          
          gbk = CreateGradient(0, c, c)
          If gbk <> 0
            SetSkinPropertyData(skin, ComponentName, state$, "gripper background", gbk)
            SetSkinPropertyDataSize(skin, ComponentName, state$, "gripper background", SizeOf(gbk))
          EndIf
        Else
          gbk = Val(GetSkinPropertyp(skin, ComponentName, state$, "gripper background"))
        EndIf
      EndIf
      
      ; border image
      gborder = GetSkinPropertyData(skin, ComponentName, state$, "gripper border image")
      t = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "gripper border image", "top"))
      l = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "gripper border image", "left"))
      b = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "gripper border image", "bottom"))
      r = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "gripper border image", "right"))
      If gborder <> 0 And t > 0 And l > 0 And b > 0 And r > 0
        rc.RECT
        rc\top = t
        rc\left = l
        rc\bottom = b
        rc\right = r
        rectCreated = #True
      EndIf
      gmask = GetSkinPropertyData(skin, ComponentName, state$, "gripper border mask")
      If gmask = 0
        gmask = Val(GetSkinPropertyp(skin, ComponentName, state$, "gripper border mask"))
      EndIf
      
      ;If rectCreated = #False
        t = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "gripper border mask", "top"))
        l = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "gripper border mask", "left"))
        b = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "gripper border mask", "bottom"))
        r = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "gripper border mask", "right"))
        If gmask <> 0 And t > 0 And l > 0 And b > 0 And r > 0
          rc.RECT
          rc\top = t
          rc\left = l
          rc\bottom = b
          rc\right = r
          rectCreated = #True
        EndIf
      ;EndIf
      
      ; overlay
      gobkimage = GetSkinPropertyData(skin, ComponentName, state$, "gripper overlay image")
      If gobkimage = 0
        gobkimage = nullicon
      EndIf
      
      goxpos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper overlay position", "x")
      If FindString(goxpos, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_HPERCENT
      EndIf
      If goxpos <> ""
        If goxpos = "centre"
          gobkstyle = gobkstyle | #PNLX_CENTRE
        ElseIf oxpos = "repeat"
          gobkstyle = gobkstyle | #PNLX_HREPEAT
        Else
          gobkx = Val(goxpos)
        EndIf
      EndIf
      
      goypos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper overlay position", "y")
      If FindString(goypos, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_VPERCENT
      EndIf
      If goypos <> ""
        If goypos = "centre"
          gobkstyle = gobkstyle | #PNLX_VCENTRE
        ElseIf goypos = "repeat"
          gobkstyle = gobkstyle | #PNLX_VREPEAT
        Else
          gobky = Val(goypos)
        EndIf
      EndIf
      
      gleft.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper overlay position", "left")
      If FindString(gleft, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_HPERCENT
      EndIf
      If gleft <> ""
        If gleft = "centre"
          gobkstyle = gobkstyle | #PNLX_CENTRE
        ElseIf gleft = "repeat"
          gobkstyle = gobkstyle | #PNLX_HREPEAT
        Else
          gobkx = Val(gleft)
        EndIf
      EndIf
      
      gtop.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper overlay position", "top")
      If FindString(gtop, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_VPERCENT
      EndIf
      If gtop <> ""
        If gtop = "centre"
          gobkstyle = gobkstyle | #PNLX_VCENTRE
        ElseIf gtop = "repeat"
          gobkstyle = gobkstyle | #PNLX_VREPEAT
        Else
          gobky = Val(gtop)
        EndIf
      EndIf
      
      gright.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper overlay position", "right")
      If FindString(gright, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_HPERCENT
      EndIf
      If gright <> ""
        If gright = "centre"
          gobkstyle = gobkstyle | #PNLX_CENTRE
        ElseIf gright = "repeat"
          gobkstyle = gobkstyle | #PNLX_HREPEAT
        Else
          gobkx = Val(gright)
          gobkstyle = gobkstyle | #PNLX_RIGHT
        EndIf
      EndIf
      
      gbottom.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper overlay position", "bottom")
      If FindString(gbottom, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_VPERCENT
      EndIf
      If gbottom <> ""
        If gbottom = "centre"
          gobkstyle = gobkstyle | #PNLX_VCENTRE
        ElseIf gbottom = "repeat"
          gobkstyle = gobkstyle | #PNLX_VREPEAT
        Else
          gobky = Val(gbottom)
          gobkstyle = gobkstyle | #PNLX_BOTTOM
        EndIf
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "gripper overlay position", "stretch") = "true"
        gobkstyle = gobkstyle | #PNLX_STRETCH
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "gripper overlay position", "tile") = "true"
        gobkstyle = gobkstyle | #PNLX_TILE
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "gripper overlay position", "masked") = "true"
        gobkstyle = gobkstyle | #PNLX_MASKED
      EndIf
      
      gp.s = GetSkinPropertyParamp(skin, ComponentName, state$, "gripper overlay", "gradient")
      If gp <> ""
        gradient = GetSkinPropertyData(skin, ComponentName, state$, "gripper overlay")
        If gradient <> 0 And GetSkinPropertyDataSize(skin, ComponentName, state$, "gripper overlay") <> 0
          gobk = gradient
        EndIf
      Else
        c = GetSkinPropertyColour(skin, ComponentName, state$, "gripper overlay")
        If c <> -1
          ; no alpha then remake colour with alpha
          If Alpha(c) = 0
            c = MakeColor(255, Red(c), Green(c), Blue(c))
          EndIf
          
          gobk = CreateGradient(0, c, c)
          If gobk <> 0
            SetSkinPropertyData(skin, ComponentName, state$, "gripper overlay", gobk)
            SetSkinPropertyDataSize(skin, ComponentName, state$, "gripper overlay", SizeOf(gobk))
          EndIf
        Else
          If GetSkinPropertyp(skin, ComponentName, state$, "gripper overlay") = ""
            gobk = -1
          Else
            gobk = Val(GetSkinPropertyp(skin, ComponentName, state$, "gripper overlay"))
          EndIf
        EndIf
      EndIf
      
      
      If i = 0
        SetPanelExPageBackground(splitterx()\grabberHandle, 0, gbk, gbkimage, gbkx, gbky, gbkwidth, gbkheight, gbkstyle, #True)
        SetPanelExPageBackground(splitterx()\grabberHandle, 0, gobk, gobkimage, gobkx, gobky, gobkwidth, gobkheight, gobkstyle | #PNLX_OVERLAY, #True)
        If rectCreated = #True
          SetPanelExPageBorder(splitterx()\grabberHandle, 0, gborder, gmask, rc.RECT, 0, #True)
        Else
          SetPanelExPageBorder(splitterx()\grabberHandle, 0, gborder, gmask, 0, 0, #True)
        EndIf
      EndIf
      
      splitterx()\gbk[i] = gbk
      splitterx()\gbkstyle[i] = gbkstyle
      splitterx()\gbkx[i] = gbkx
      splitterx()\gbky[i] = gbky
      splitterx()\gobk[i] = gobk
      splitterx()\gobkstyle[i] = gobkstyle
      splitterx()\gobkx[i] = gobkx
      splitterx()\gobky[i] = gobky
      splitterx()\gbkimage[i] = gbkimage
      splitterx()\gbkwidth[i] = gbkwidth
      splitterx()\gbkheight[i] = gbkheight
      splitterx()\gobkimage[i] = gobkimage
      splitterx()\gobkwidth[i] = gobkwidth
      splitterx()\gobkheight[i] = gobkheight
      splitterx()\gborder[i] = gborder
      If rectCreated = #True
        CopyStructure(rc, splitterx()\gborderrect, RECT)
      EndIf
      splitterx()\gmask[i] = gmask
      
    Next
    
    splitterx()\componentname = ComponentName
    splitterx()\skin = skin
    
    ; make splitterex update window positions
    GetClientRect_(splitterx()\Handle, @rc.RECT)
    splitterExCallback(splitterx()\Handle, #WM_SIZE, 0, MakeLong(rc\right-rc\left, rc\bottom-rc\top))
    
    ; redraw everything
    If noRefresh = #False
      RefreshPanelEx(splitterx()\Handle)
    EndIf
    
    ProcedureReturn #True
    
  EndIf
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL GetSplitterExSkin(ID.i) ; Gets a SplitterEx's skin
  
  macro_protectCommand()
  
  ;find splitterex
  ForEach splitterx()
    If splitterx()\handle = ID Or splitterx()\id = ID
      ProcedureReturn splitterx()\skin
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL SplitterEx(WindowID.i, SplitterID.l, x.l, y.l, Width.l, Height.l, WindowID1.i, WindowID2.i, Skin.i, Flags.i) ; Creates a skinned splitter control
  
  macro_protectCommand()
  
  ; make sure splitter control doesn't already exist
  If SplitterID = #ProGUI_Any
    Repeat
      ; generate unique splitter id
      SplitterID = generateUniqueID()
      ; check that same id doesnt already exist
      found = 0
      ForEach splitterx()
        If splitterx()\id = SplitterID
          found = -1
          Break
        EndIf
      Next
    Until found = 0
    ProGUI_Any = #True
  Else
    ; make sure splitter id doesnt exist
    ForEach splitterx()
      If splitterx()\id = SplitterID
        ProcedureReturn 0
      EndIf
    Next
  EndIf
  
  ; check that all passed window handles are valid
  If IsWindow_(WindowID) = 0 And IsWindow_(WindowID1) = 0 And IsWindow_(WindowID2) = 0
    ProcedureReturn 0
  EndIf
  
  backupCurrentPanelEx = currentPanelEx ; store the current panelex for backup after the splitter is created
  hwnd = PanelExID(CreatePanelEx(#ProGUI_Any, WindowID, 0, 0, 0, 0, @splitterExCallback()), -1)
  If hwnd <> 0
    
    page = AddPanelExImagePage(bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle|#PNLX_NOGADGETLIST)
    currentPanelEx = backupCurrentPanelEx
    If page = 0
      FreePanelEx(hwnd)
      ProcedureReturn #False
    EndIf
    
    grabberhwnd = PanelExID(CreatePanelEx(#ProGUI_Any, page, 0, 0, 0, 0, @splitterExGrabberCallback()), -1)
    If grabberhwnd <> 0
      
      grabberpage = AddPanelExImagePage(bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle|#PNLX_NOGADGETLIST)
      
      If grabberpage = 0
        FreePanelEx(grabberhwnd)
        ProcedureReturn #False
      EndIf
      
      If flags & #SPLITTEREX_VERTICAL
        SetPanelExPageCursor(grabberhwnd, 0, verticalResizeMousePointer)
      Else
        SetPanelExPageCursor(grabberhwnd, 0, hResizeMousePointer)
      EndIf
      
      LastElement(splitterx())
      AddElement(splitterx())
      splitterx()\id = SplitterID
      splitterx()\Handle = hwnd
      splitterx()\pageHandle = page
      splitterx()\grabberHandle = grabberhwnd
      splitterx()\grabberPageHandle = grabberpage
      splitterx()\hwnd1 = WindowID1
      splitterx()\hwnd2 = WindowID2
      splitterx()\grabberRatio = 50
      splitterx()\flags = flags
      
      If flags & #SPLITTEREX_ANCHOREDTOP
        splitterx()\anchor = #SPLITTEREX_ANCHOREDTOP
        If flags & #SPLITTEREX_ANCHOR
          splitterx()\grabberRatio = 0
        EndIf
      ElseIf flags & #SPLITTEREX_ANCHOREDLEFT
        splitterx()\anchor = #SPLITTEREX_ANCHOREDLEFT
        If flags & #SPLITTEREX_ANCHOR
          splitterx()\grabberRatio = 0
        EndIf
      ElseIf flags & #SPLITTEREX_ANCHOREDBOTTOM
        splitterx()\anchor = #SPLITTEREX_ANCHOREDBOTTOM
        If flags & #SPLITTEREX_ANCHOR
          splitterx()\grabberRatio = 100
        EndIf
      ElseIf flags & #SPLITTEREX_ANCHOREDRIGHT
        splitterx()\anchor = #SPLITTEREX_ANCHOREDRIGHT
        If flags & #SPLITTEREX_ANCHOR
          splitterx()\grabberRatio = 100
        EndIf
      EndIf
      
      SetParent_(WindowID1, page)
      SetParent_(WindowID2, page)
      
      If skin = #UISTYLE_OFFICE2007
        initDefaultSkin("office2007splitterskin")
        SetSplitterExSkin(hwnd, office2007SplitterSkin, "", 0)
      ElseIf skin = #SPLITTEREX_DEFAULTSKIN2
        initDefaultSkin("syssplitter2skin")
        SetSplitterExSkin(hwnd, sysSplitter2Skin, "", 0)
      ElseIf skin = 0
        initDefaultSkin("syssplitterskin")
        SetSplitterExSkin(hwnd, sysSplitterSkin, "", 0)
      Else
        SetSplitterExSkin(hwnd, skin, "", 0)
      EndIf
      
      MoveWindow_(hwnd, x, y, width, height, #True)
      
      If ProGUI_Any = #True
        ProcedureReturn SplitterID
      Else
        ProcedureReturn hwnd
      EndIf
      
    EndIf
    
  EndIf
  
  ProcedureReturn hwnd

EndProcedure

ProcedureDLL SetSplitterExAttribute(ID.i, Attribute.i, Value.i) ; Sets a SplitterEx's attributes
  
  macro_protectCommand()
  
  ;find splitterex
  ForEach splitterx()
    If splitterx()\handle = ID Or splitterx()\id = ID
      foundSplitterx = #True
      Break
    EndIf
  Next
  
  If foundSplitterx = #True
    
    Select Attribute
      Case #SPLITTEREX_FIRST
        
        If IsWindow_(Value)
          SetParent_(splitterx()\hwnd1, GetParent_(splitterx()\Handle))
          SetParent_(Value, splitterx()\pageHandle)
          splitterx()\hwnd1 = Value
          result = #True
        EndIf
        
      Case #SPLITTEREX_SECOND
        
        If IsWindow_(Value)
          SetParent_(splitterx()\hwnd2, GetParent_(splitterx()\Handle))
          SetParent_(Value, splitterx()\pageHandle)
          splitterx()\hwnd2 = Value
          result = #True
        EndIf
        
      Case #SPLITTEREX_FIRSTMAXIMUMSIZE
        
        splitterx()\firstmax = Value
        result = #True
        
      Case #SPLITTEREX_FIRSTMINIMUMSIZE
        
        splitterx()\firstmin = Value
        result = #True
        
      Case #SPLITTEREX_SECONDMAXIMUMSIZE
        
        splitterx()\secondmax = Value
        result = #True
        
      Case #SPLITTEREX_SECONDMINIMUMSIZE
         
        splitterx()\secondmin = Value
        result = #True
        
      Case #SPLITTEREX_HIDEFIRST
         
        If value = 0
          ShowWindow_(splitterx()\hwnd1, #SW_SHOW)
          splitterx()\firsthidden = #False
          result = #True
        Else
          ShowWindow_(splitterx()\hwnd1, #SW_HIDE)
          splitterx()\firsthidden = #True
          result = #True
        EndIf
        
        If splitterx()\firsthidden = #True Or splitterx()\firsthidden = #True
          ShowWindow_(splitterx()\grabberHandle, #SW_HIDE)
        ElseIf splitterx()\firsthidden = 0 And splitterx()\firsthidden = 0
          ShowWindow_(splitterx()\grabberHandle, #SW_SHOW)
        EndIf
        
      Case #SPLITTEREX_HIDESECOND
        
        If value = 0
          ShowWindow_(splitterx()\hwnd2, #SW_SHOW)
          splitterx()\secondhidden = #False
          result = #True
        Else
          ShowWindow_(splitterx()\hwnd2, #SW_HIDE)
          splitterx()\secondhidden = #True
          result = #True
        EndIf
        
      Case #SPLITTEREX_POSITION
        
        updatePos = #True
        result = #True
        
      Case #SPLITTEREX_VERTICAL
        
        If Value = #True
          splitterx()\flags = splitterx()\flags | #SPLITTEREX_VERTICAL
          result = #True
        Else
          splitterx()\flags = splitterx()\flags &~ #SPLITTEREX_VERTICAL
          result = #True
        EndIf
        
      Case #SPLITTEREX_ANCHORPOSITION
        
        If Value = #SPLITTEREX_ANCHOREDTOP
          splitterx()\anchor = #SPLITTEREX_ANCHOREDTOP
          result = #True
        ElseIf Value = #SPLITTEREX_ANCHOREDLEFT
          splitterx()\anchor = #SPLITTEREX_ANCHOREDLEFT
          result = #True
        ElseIf Value = #SPLITTEREX_ANCHOREDBOTTOM
          splitterx()\anchor = #SPLITTEREX_ANCHOREDBOTTOM
          result = #True
        ElseIf Value = #SPLITTEREX_ANCHOREDRIGHT
          splitterx()\anchor = #SPLITTEREX_ANCHOREDRIGHT
          result = #True
        EndIf
        
      Case #SPLITTEREX_ANCHORSIZETO
        
        splitterx()\storeDelta = Value
        ProcedureReturn #True
        
      ; any other value then refresh window positions
      Default
      
        result = #True
        
    EndSelect
    
  EndIf
  
  If result = #True
    
    splitterGrabberHwnd = splitterx()\grabberHandle
    splitterGrabberPageHwnd = splitterx()\grabberPageHandle
    splitterDelta = -1
    If splitterx()\flags & #SPLITTEREX_VERTICAL
      splitterMode = #SPLITTEREX_VERTICAL
    Else
      splitterMode = 0
    EndIf
    splitterHwnd1 = splitterx()\hwnd1
    splitterHwnd2 = splitterx()\hwnd2
    If splitterx()\flags & #SPLITTEREX_VERTICAL
      splitterGrabberWidth = splitterx()\grabbervwidth
      splitterGrabberHeight = splitterx()\grabbervheight
      splitterFirstPadding\left = splitterx()\vfirstpadding\left
      splitterFirstPadding\right = splitterx()\vfirstpadding\right
      splitterFirstPadding\top = splitterx()\vfirstpadding\top
      splitterFirstPadding\bottom = splitterx()\vfirstpadding\bottom
      splitterSecondPadding\left = splitterx()\vsecondpadding\left
      splitterSecondPadding\right = splitterx()\vsecondpadding\right
      splitterSecondPadding\top = splitterx()\vsecondpadding\top
      splitterSecondPadding\bottom = splitterx()\vsecondpadding\bottom
    Else
      splitterGrabberWidth = splitterx()\grabberwidth
      splitterGrabberHeight = splitterx()\grabberheight
      splitterFirstPadding\left = splitterx()\firstpadding\left
      splitterFirstPadding\right = splitterx()\firstpadding\right
      splitterFirstPadding\top = splitterx()\firstpadding\top
      splitterFirstPadding\bottom = splitterx()\firstpadding\bottom
      splitterSecondPadding\left = splitterx()\secondpadding\left
      splitterSecondPadding\right = splitterx()\secondpadding\right
      splitterSecondPadding\top = splitterx()\secondpadding\top
      splitterSecondPadding\bottom = splitterx()\secondpadding\bottom
    EndIf
    splitterFirstMin = splitterx()\firstmin
    splitterFirstMax = splitterx()\firstmax
    splitterSecondMin = splitterx()\secondmin
    splitterSecondMax = splitterx()\secondmax
    splitterFirstHidden = splitterx()\firsthidden
    splitterSecondHidden = splitterx()\secondhidden
    splitterDrag = #True
    splitterDelta = 0
    
    pt.POINT
    GetClientRect_(splitterx()\grabberHandle, @rc.RECT)
    MapWindowPoints_(splitterx()\grabberHandle, splitterx()\pageHandle, @rc, 2)
    If updatePos = #True
      If splitterx()\flags & #SPLITTEREX_VERTICAL
        pt\x = rc\left
        pt\y = Value
      Else
        pt\x = Value
        pt\y = rc\top
      EndIf
    Else
      pt\x = rc\left
      pt\y = rc\top
      
      GetWindowRect_(splitterx()\pageHandle, @prc.RECT)
      pwidth = prc\right-prc\left
      pheight = prc\bottom-prc\top
      If pwidth < 1
        pwidth = 1
      EndIf
      If pheight < 1
        pheight = 1
      EndIf
      
      If splitterx()\flags & #SPLITTEREX_VERTICAL
        pt\y = splitterx()\grabberRatio/(100/pheight)
        pt\y = pt\y - (splitterx()\grabbervheight/2)
      Else
        pt\x = splitterx()\grabberRatio/(100/pwidth)
        pt\x = pt\x - (splitterx()\grabberwidth/2)
      EndIf
      
    EndIf
    
    *thisSplitter = @splitterx()
    updateSplitter(pt\x, pt\y)
    ChangeCurrentElement(splitterx(), *thisSplitter)
    
    If splitterx()\firsthidden = 0 And splitterx()\secondhidden = 0
      
      GetClientRect_(splitterx()\grabberHandle, @rc.RECT)
      MapWindowPoints_(splitterx()\grabberHandle, splitterx()\pageHandle, @rc, 2)
      GetWindowRect_(splitterx()\pageHandle, @prc.RECT)
      If splitterx()\flags & #SPLITTEREX_VERTICAL
        splitterx()\grabberRatio = (100/(prc\bottom-prc\top))*(rc\top+(splitterx()\grabbervheight/2))
        If rc\top = 0
          splitterx()\grabberRatio = 0
        ElseIf rc\bottom = prc\bottom-prc\top
          splitterx()\grabberRatio = 100
        EndIf
      Else
        splitterx()\grabberRatio = (100/(prc\right-prc\left))*(rc\left+(splitterx()\grabberwidth/2))
        If rc\left = 0
          splitterx()\grabberRatio = 0
        ElseIf rc\right = prc\right-prc\left
          splitterx()\grabberRatio = 100
        EndIf
      EndIf
    EndIf
    
    splitterDrag = 0
    
  EndIf
  
  ProcedureReturn result
    
EndProcedure

ProcedureDLL GetSplitterExAttribute(ID.i, Attribute.i) ; Gets a SplitterEx's attribute
  
  macro_protectCommand()
  
  ;find splitterex
  ForEach splitterx()
    If splitterx()\handle = ID Or splitterx()\id = ID
      foundSplitterx = #True
      Break
    EndIf
  Next
  
  result = -1
  
  If foundSplitterx = #True
    
    Select Attribute
      Case #SPLITTEREX_FIRST
        
        result = splitterx()\hwnd1
        
      Case #SPLITTEREX_SECOND
        
        result = splitterx()\hwnd2
        
      Case #SPLITTEREX_FIRSTMAXIMUMSIZE
        
        result = splitterx()\firstmax
        
      Case #SPLITTEREX_FIRSTMINIMUMSIZE
        
        result = splitterx()\firstmin
        
      Case #SPLITTEREX_SECONDMAXIMUMSIZE
        
        result = splitterx()\secondmax
        
      Case #SPLITTEREX_SECONDMINIMUMSIZE
         
        result = splitterx()\secondmin
        
      Case #SPLITTEREX_HIDEFIRST
         
        result = splitterx()\firsthidden
        
      Case #SPLITTEREX_HIDESECOND
        
        result = splitterx()\secondhidden
        
      Case #SPLITTEREX_POSITION
        
        GetClientRect_(splitterx()\grabberHandle, @rc.RECT)
        MapWindowPoints_(splitterx()\grabberHandle, splitterx()\pageHandle, @rc, 2)
        If splitterx()\flags & #SPLITTEREX_VERTICAL
          result = rc\top
        Else
          result = rc\left
        EndIf
        
      Case #SPLITTEREX_VERTICAL
        
        If splitterx()\flags & #SPLITTEREX_VERTICAL
          result = #True
        EndIf
        
      Case #SPLITTEREX_ANCHORPOSITION
        
        result = splitterx()\anchor
        
      Case #SPLITTEREX_ANCHORSIZETO
        
        result = splitterx()\storeDelta
        
    EndSelect
    
  EndIf
  
  ProcedureReturn result
    
EndProcedure

ProcedureDLL SplitterExID(id.l) ; Returns a handle to a SplitterEx's window
  
  ForEach splitterx()
    If splitterx()\id = id
      
      ProcedureReturn splitterx()\Handle
      
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL FreeSplitterEx(id.i) ; Frees a SplitterEx from memory
  
  macro_protectCommand()
  
  ForEach splitterx()
    If splitterx()\id = id Or splitterx()\Handle = id Or id = -1
      
      SetParent_(splitterx()\hwnd1, GetParent_(splitterx()\handle))
      SetParent_(splitterx()\hwnd2, GetParent_(splitterx()\handle))
      FreePanelEx(splitterx()\grabberHandle)
      FreePanelEx(splitterx()\Handle)
      
      DeleteElement(splitterx(), 1)
      
      If id <> -1
        ProcedureReturn #True
      EndIf
      
    EndIf
  Next
  
  If id = -1
    ProcedureReturn #True
  EndIf
  ProcedureReturn 0
  
EndProcedure


;--
;- ExplorerBar
;--
Macro calcXbarGroupHeight()
  xbar()\groupMargin\top+xbar()\groupMargin\bottom+ListSize(xbar()\group()\item())*(xbar()\itemHeight+xbar()\itemPadding\top+xbar()\itemPadding\bottom)-xbar()\itemPadding\bottom
EndMacro

Procedure explorerBarCallback(Window, message, wParam, lParam)
 
  ; find associated explorerbar
  ForEach xbar()
    If xbar()\Handle = Window
      found = #True
      Break
    EndIf
  Next
  
  If found = #False
    ProcedureReturn 0
  EndIf
  
  Select message
      
    ; handle selection of header toggle buttons
    Case #WM_COMMAND
      
      If HWord(wParam) = 0 ; is an ID
          
        ID = LWord(wParam)
        found = #False
        ForEach xbar()\group()
          If xbar()\group()\headerID = ID
            found = #True
            Break
          EndIf
        Next
        
        If found = #True
          Debug "ID:"+Str(ID)
          If xbar()\group()\collapsed = #False
            Debug "collapse"
            
            GetClientRect_(xbar()\group()\group, srcRc.RECT)
            MapWindowPoints_(xbar()\group()\group, GetParent_(xbar()\group()\group), srcRc, 2)
            xbar()\group()\storedheight = xbar()\group()\height
            
            CopyStructure(srcRc, dstRc.RECT, RECT)
            dstRc\bottom = dstRc\top
            *anim.ANIMATION = AllocateMemory(SizeOf(ANIMATION))
            *anim\hwnd = xbar()\group()\group
            CopyStructure(srcRc, *anim\srcRc, RECT)
            CopyStructure(dstRc, *anim\dstRc, RECT)
            *anim\time = 200
            *anim\velocity = 4
            PostMessage_(animationThreadHwnd, #WM_ANIMATE, xbar()\group()\group, *anim)
            
            xbar()\group()\collapsed = #True
          Else
            Debug "uncollapse"
            
            GetClientRect_(xbar()\group()\group, srcRc.RECT)
            MapWindowPoints_(xbar()\group()\group, GetParent_(xbar()\group()\group), srcRc, 2)
            CopyStructure(srcRc, dstRc.RECT, RECT)
            dstRc\bottom = dstRc\top+calcXbarGroupHeight()
            *anim.ANIMATION = AllocateMemory(SizeOf(ANIMATION))
            *anim\hwnd = xbar()\group()\group
            CopyStructure(srcRc, *anim\srcRc, RECT)
            CopyStructure(dstRc, *anim\dstRc, RECT)
            *anim\time = 200
            *anim\velocity = 4
            PostMessage_(animationThreadHwnd, #WM_ANIMATE, xbar()\group()\group, *anim)
            
            xbar()\group()\collapsed = #False
          EndIf
          
          Result = 1 ; stop/block #WM_COMMAND message from being passed up PanelEx chain
          
        ; not a header button, check if item button and if so forward matching ID
        Else
          
          ForEach xbar()\group()
            ForEach xbar()\group()\item()
              If xbar()\group()\item()\realid = ID
                PostMessage_(GetParent_(Window), #WM_COMMAND, xbar()\group()\item()\id, 0)
                Result = 1 ; stop/block #WM_COMMAND message from being passed up PanelEx chain
                Break 2
              EndIf
            Next
          Next
          
        EndIf
        
      EndIf
      
    Case #WM_SIZE
      ;debuglog("cool")
      GetClientRect_(Window, @rc.RECT)
      width = rc\right-rc\left
      height = rc\bottom-rc\top
      
      ; make width of groups smaller to accomodate vertical scrollbar if visible
      If GetPanelExPageScrolling(xbar()\Handle, 0, #PNLX_VSCROLL) = #True
        GetClientRect_(GetPanelExPageScrolling(xbar()\Handle, 0, #PNLX_VSCROLLHANDLE), @rc.RECT)
        width = width - rc\right
      EndIf
      
      ; re-position all the group windows
      x = xbar()\margin\left+xbar()\groupPadding\left
      y = xbar()\margin\top
      ;SendMessage_(Window, #WM_SETREDRAW, 0, 0)
      
      hdwp = BeginDeferWindowPos_((ListSize(xbar()\group())*2)) ; 2 hwnd's for each group (header and container)
      ForEach xbar()\group()
        
        ; header
        y + xbar()\groupPadding\top
        DeferWindowPos_(hdwp, xbar()\group()\header, 0, x, y, width-(xbar()\margin\left+xbar()\margin\right+xbar()\groupPadding\left+xbar()\groupPadding\right), xbar()\headerHeight, #SWP_NOREDRAW)
        ; container
        y + xbar()\headerHeight
        GetClientRect_(xbar()\group()\group, rc.RECT)
        groupHeight = rc\bottom-rc\top
        DeferWindowPos_(hdwp, xbar()\group()\group, 0, x, y, width-(xbar()\margin\left+xbar()\margin\right+xbar()\groupPadding\left+xbar()\groupPadding\right), groupHeight, #SWP_NOREDRAW)
        y + groupHeight+xbar()\groupPadding\bottom
        
      Next
      EndDeferWindowPos_(hdwp)
      ;SendMessage_(Window, #WM_SETREDRAW, #True, 0)
      
    ; handle update skin notification
    Case #WM_UPDATESKIN
      
      ; respond to a request to update all skinned controls
      If lParam = #False
        
        ; only update if our skin has SkinAutoUpdate set
        If GetSkinAutoUpdate(xbar()\skin) = #True
          SetExplorerBarSkin(xbar()\Handle, xbar()\skin, "", 2) ; 2 = tells SetExplorerBarSkin not to update child ButtonEx's as these will automatically receive their own #WM_UPDATESKIN message
        EndIf
          
      ; respond to a request to update all controls using the specified skin handle in lParam
      ElseIf lParam <> #False And wParam = #False
        
        ; only update this control's skin if we are using the specified skin handle in lParam
        If xbar()\skin = lParam
          
          ; only update if our skin has SkinAutoUpdate set
          If GetSkinAutoUpdate(xbar()\skin) = #True
            SetExplorerBarSkin(xbar()\Handle, xbar()\skin, "", #True)
          EndIf
          
        EndIf
        
      ; respond to a request to update/replace the skin for this specific control using the specified skin handle in lParam
      ElseIf lParam <> #False And wParam = #True
        
        ; only update if our skin has SkinAutoUpdate set
        If GetSkinAutoUpdate(xbar()\skin) = #True
          SetExplorerBarSkin(xbar()\Handle, lParam, "", #True)
        EndIf
        
      EndIf
      
  EndSelect
  
  ProcedureReturn Result
EndProcedure

Procedure explorerBarGroupCallback(Window, message, wParam, lParam)
 
  ; find associated explorerbar
  ForEach xbar()
    ForEach xbar()\group()
      If xbar()\group()\group = Window
        found = #True
        Break 2
      EndIf
    Next
  Next
  
  If found = #False
    ProcedureReturn 0
  EndIf
  
  
  Select message
    Case #WM_SIZE
      
      If ListSize(xbar()\group()\item()) > 0
      
        GetClientRect_(Window, @rc.RECT)
        gwidth = rc\right-rc\left
        gheight = rc\bottom-rc\top
        
        ; re-position all the group windows
        ix = xbar()\groupMargin\left+xbar()\itemPadding\left
        iy = xbar()\groupMargin\top
        ;SendMessage_(Window, #WM_SETREDRAW, 0, 0)
        hdwp = BeginDeferWindowPos_(ListSize(xbar()\group()\item()))
;         ForEach xbar()\group()\item()
;           
;           ; item
;           iy + xbar()\itemPadding\top
;           DeferWindowPos_(hdwp, xbar()\group()\item()\hwnd, 0, ix, iy, gwidth-(xbar()\groupMargin\left+xbar()\groupMargin\right+xbar()\itemPadding\left+xbar()\itemPadding\right), xbar()\itemHeight, #SWP_NOREDRAW)
;           ; container
;           iy + xbar()\itemHeight
;           If ListSize(xbar()\group()\item())-1 <> ListIndex(xbar()\group()\item())
;             iy + xbar()\itemPadding\bottom
;           EndIf
;           
;         Next
        
        ix = xbar()\groupMargin\left+xbar()\itemPadding\left
        iy = gheight-xbar()\groupMargin\bottom
        LastElement(xbar()\group()\item())
        Repeat
          
          ; item
          If ListSize(xbar()\group()\item())-1 <> ListIndex(xbar()\group()\item())
            iy - xbar()\itemPadding\bottom
          EndIf
          iy - xbar()\itemHeight
          DeferWindowPos_(hdwp, xbar()\group()\item()\hwnd, 0, ix, iy, gwidth-(xbar()\groupMargin\left+xbar()\groupMargin\right+xbar()\itemPadding\left+xbar()\itemPadding\right), xbar()\itemHeight, #SWP_NOREDRAW)
          
        Until PreviousElement(xbar()\group()\item()) = 0
        
        EndDeferWindowPos_(hdwp)
        ;SendMessage_(Window, #WM_SETREDRAW, #True, 0)
      
      EndIf
      
  EndSelect
  
  ProcedureReturn Result
EndProcedure

ProcedureDLL SetExplorerBarSkin(ID.i, Skin.i, ComponentName.s, noRefresh.b) ; Sets an ExplorerBar's skin
  
  macro_protectCommand()
  
  ;find explorerbar
  ForEach xbar()
    If xbar()\handle = ID Or xbar()\id = ID
      foundxbar = #True
      Break
    EndIf
  Next
  
  ;find skin
  ForEach skin()
    If @skin() = Skin
      foundSkin = #True
      Break
    EndIf
  Next
  
  If foundxbar = #True And foundSkin = #True
    
      If ComponentName = "" And xbar()\componentname = ""
        ComponentName = "explorerbar"
      ElseIf ComponentName = "" And xbar()\componentname <> ""
        ComponentName = xbar()\componentname
      EndIf
    
      state$ = "normal"
      
      bk = -1
      
      xbarMargin.RECT
      xbarMargin\top = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "margin", "top"))
      xbarMargin\left = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "margin", "left"))
      xbarMargin\bottom = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "margin", "bottom"))
      xbarMargin\right = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "margin", "right"))
      
      groupPad.RECT
      groupPad\top = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group padding", "top"))
      groupPad\left = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group padding", "left"))
      groupPad\bottom = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group padding", "bottom"))
      groupPad\right = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group padding", "right"))
      
      groupMargin.RECT
      groupMargin\top = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group margin", "top"))
      groupMargin\left = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group margin", "left"))
      groupMargin\bottom = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group margin", "bottom"))
      groupMargin\right = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group margin", "right"))
      
      itemPad.RECT
      itemPad\top = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "item padding", "top"))
      itemPad\left = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "item padding", "left"))
      itemPad\bottom = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "item padding", "bottom"))
      itemPad\right = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "item padding", "right"))
      
      headerHeight = Val(GetSkinPropertyp(skin, ComponentName, state$, "header height"))
      If headerHeight = 0 ; makes sure the header is always visible when creating skins
        headerHeight = 25
      EndIf
      
      itemHeight = Val(GetSkinPropertyp(skin, ComponentName, state$, "item height"))
      If itemHeight = 0 ; makes sure the item is always visible when creating skins
        itemHeight = 22
      EndIf
      
      
      bkimage = GetSkinPropertyData(skin, ComponentName, state$, "background image")
      If bkimage = 0
        bkimage = nullicon
      EndIf
      
      xpos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "x")
      If FindString(xpos, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_HPERCENT
      EndIf
      If xpos <> ""
        If xpos = "centre"
          bkstyle = bkstyle | #PNLX_CENTRE
        ElseIf xpos = "repeat"
          bkstyle = bkstyle | #PNLX_HREPEAT
        Else
          bkx = Val(xpos)
        EndIf
      EndIf
      
      ypos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "y")
      If FindString(ypos, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_VPERCENT
      EndIf
      If ypos <> ""
        If ypos = "centre"
          bkstyle = bkstyle | #PNLX_VCENTRE
        ElseIf ypos = "repeat"
          bkstyle = bkstyle | #PNLX_VREPEAT
        Else
          bky = Val(ypos)
        EndIf
      EndIf
      
      left.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "left")
      If FindString(left, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_HPERCENT
      EndIf
      If left <> ""
        If left = "centre"
          bkstyle = bkstyle | #PNLX_CENTRE
        ElseIf left = "repeat"
          bkstyle = bkstyle | #PNLX_HREPEAT
        Else
          bkx = Val(left)
        EndIf
      EndIf
      
      top.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "top")
      If FindString(top, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_VPERCENT
      EndIf
      If top <> ""
        If top = "centre"
          bkstyle = bkstyle | #PNLX_VCENTRE
        ElseIf top = "repeat"
          bkstyle = bkstyle | #PNLX_VREPEAT
        Else
          bky = Val(top)
        EndIf
      EndIf
      
      right.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "right")
      If FindString(right, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_HPERCENT
      EndIf
      If right <> ""
        If right = "centre"
          bkstyle = bkstyle | #PNLX_CENTRE
        ElseIf right = "repeat"
          bkstyle = bkstyle | #PNLX_HREPEAT
        Else
          bkx = Val(right)
          bkstyle = bkstyle | #PNLX_RIGHT
        EndIf
      EndIf
      
      bottom.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "bottom")
      If FindString(bottom, "%", 1) > 0
        bkstyle = bkstyle | #PNLX_VPERCENT
      EndIf
      If bottom <> ""
        If bottom = "centre"
          bkstyle = bkstyle | #PNLX_VCENTRE
        ElseIf bottom = "repeat"
          bkstyle = bkstyle | #PNLX_VREPEAT
        Else
          bky = Val(bottom)
          bkstyle = bkstyle | #PNLX_BOTTOM
        EndIf
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "stretch") = "true"
        bkstyle = bkstyle | #PNLX_STRETCH
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "tile") = "true"
        bkstyle = bkstyle | #PNLX_TILE
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "background position", "masked") = "true"
        bkstyle = bkstyle | #PNLX_MASKED
      EndIf
      
      p.s = GetSkinPropertyParamp(skin, ComponentName, state$, "background", "gradient")
      If p <> ""
        gradient = GetSkinPropertyData(skin, ComponentName, state$, "background")
        If gradient <> 0 And GetSkinPropertyDataSize(skin, ComponentName, state$, "background") <> 0
          bk = gradient
        EndIf
      Else
        c = GetSkinPropertyColour(skin, ComponentName, state$, "background")
        If c <> -1
          ; no alpha then remake colour with alpha
          If Alpha(c) = 0
            c = MakeColor(255, Red(c), Green(c), Blue(c))
          EndIf
          
          bk = CreateGradient(0, c, c)
          If bk <> 0
            SetSkinPropertyData(skin, ComponentName, state$, "background", bk)
            SetSkinPropertyDataSize(skin, ComponentName, state$, "background", SizeOf(bk))
          EndIf
        Else
          bk = Val(GetSkinPropertyp(skin, ComponentName, state$, "background"))
        EndIf
      EndIf
      
      ; border image
      border = GetSkinPropertyData(skin, ComponentName, state$, "border image")
      t = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "top"))
      l = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "left"))
      b = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "bottom"))
      r = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border image", "right"))
      If border <> 0 And t > 0 And l > 0 And b > 0 And r > 0
        rc.RECT
        rc\top = t
        rc\left = l
        rc\bottom = b
        rc\right = r
        rectCreated = #True
      EndIf
      mask = GetSkinPropertyData(skin, ComponentName, state$, "border mask")
      If mask = 0
        mask = Val(GetSkinPropertyp(skin, ComponentName, state$, "border mask"))
      EndIf
      
      ;If rectCreated = #False
        t = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "top"))
        l = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "left"))
        b = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "bottom"))
        r = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "border mask", "right"))
        If mask <> 0 And t > 0 And l > 0 And b > 0 And r > 0
          rc.RECT
          rc\top = t
          rc\left = l
          rc\bottom = b
          rc\right = r
          rectCreated = #True
        EndIf
      ;EndIf
      
      ; overlay
      obkimage = GetSkinPropertyData(skin, ComponentName, state$, "overlay image")
      If obkimage = 0
        obkimage = nullicon
      EndIf
      
      oxpos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "x")
      If FindString(oxpos, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_HPERCENT
      EndIf
      If oxpos <> ""
        If oxpos = "centre"
          obkstyle = obkstyle | #PNLX_CENTRE
        ElseIf oxpos = "repeat"
          obkstyle = obkstyle | #PNLX_HREPEAT
        Else
          obkx = Val(oxpos)
        EndIf
      EndIf
      
      oypos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "y")
      If FindString(oypos, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_VPERCENT
      EndIf
      If oypos <> ""
        If oypos = "centre"
          obkstyle = obkstyle | #PNLX_VCENTRE
        ElseIf oypos = "repeat"
          obkstyle = obkstyle | #PNLX_VREPEAT
        Else
          obky = Val(oypos)
        EndIf
      EndIf
      
      left.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "left")
      If FindString(left, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_HPERCENT
      EndIf
      If left <> ""
        If left = "centre"
          obkstyle = obkstyle | #PNLX_CENTRE
        ElseIf left = "repeat"
          obkstyle = obkstyle | #PNLX_HREPEAT
        Else
          obkx = Val(left)
        EndIf
      EndIf
      
      top.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "top")
      If FindString(top, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_VPERCENT
      EndIf
      If top <> ""
        If top = "centre"
          obkstyle = obkstyle | #PNLX_VCENTRE
        ElseIf top = "repeat"
          obkstyle = obkstyle | #PNLX_VREPEAT
        Else
          obky = Val(top)
        EndIf
      EndIf
      
      right.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "right")
      If FindString(right, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_HPERCENT
      EndIf
      If right <> ""
        If right = "centre"
          obkstyle = obkstyle | #PNLX_CENTRE
        ElseIf right = "repeat"
          obkstyle = obkstyle | #PNLX_HREPEAT
        Else
          obkx = Val(right)
          obkstyle = obkstyle | #PNLX_RIGHT
        EndIf
      EndIf
      
      bottom.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "bottom")
      If FindString(bottom, "%", 1) > 0
        obkstyle = obkstyle | #PNLX_VPERCENT
      EndIf
      If bottom <> ""
        If bottom = "centre"
          obkstyle = obkstyle | #PNLX_VCENTRE
        ElseIf bottom = "repeat"
          obkstyle = obkstyle | #PNLX_VREPEAT
        Else
          obky = Val(bottom)
          obkstyle = obkstyle | #PNLX_BOTTOM
        EndIf
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "stretch") = "true"
        obkstyle = obkstyle | #PNLX_STRETCH
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "tile") = "true"
        obkstyle = obkstyle | #PNLX_TILE
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "overlay position", "masked") = "true"
        obkstyle = obkstyle | #PNLX_MASKED
      EndIf
      
      p.s = GetSkinPropertyParamp(skin, ComponentName, state$, "overlay", "gradient")
      If p <> ""
        gradient = GetSkinPropertyData(skin, ComponentName, state$, "overlay")
        If gradient <> 0 And GetSkinPropertyDataSize(skin, ComponentName, state$, "overlay") <> 0
          obk = gradient
        EndIf
      Else
        c = GetSkinPropertyColour(skin, ComponentName, state$, "overlay")
        If c <> -1
          ; no alpha then remake colour with alpha
          If Alpha(c) = 0
            c = MakeColor(255, Red(c), Green(c), Blue(c))
          EndIf
          
          obk = CreateGradient(0, c, c)
          If obk <> 0
            SetSkinPropertyData(skin, ComponentName, state$, "overlay", obk)
            SetSkinPropertyDataSize(skin, ComponentName, state$, "overlay", SizeOf(obk))
          EndIf
        Else
          If GetSkinPropertyp(skin, ComponentName, state$, "overlay") = ""
            obk = -1
          Else
            obk = Val(GetSkinPropertyp(skin, ComponentName, state$, "overlay"))
          EndIf
        EndIf
      EndIf
      
      
      If i = 0
        SetPanelExPageBackground(xbar()\Handle, 0, bk, bkimage, bkx, bky, bkwidth, bkheight, bkstyle, #True)
        SetPanelExPageBackground(xbar()\Handle, 0, obk, obkimage, obkx, obky, obkwidth, obkheight, obkstyle | #PNLX_OVERLAY, #True)
        If rectCreated = #True
          SetPanelExPageBorder(xbar()\Handle, 0, border, mask, rc.RECT, 0, #True)
        Else
          SetPanelExPageBorder(xbar()\Handle, 0, border, mask, 0, 0, #True)
        EndIf
      EndIf
      
      xbar()\bk[i] = bk
      xbar()\bkstyle[i] = bkstyle
      xbar()\bkx[i] = bkx
      xbar()\bky[i] = bky
      xbar()\obk[i] = obk
      xbar()\obkstyle[i] = obkstyle
      xbar()\obkx[i] = obkx
      xbar()\obky[i] = obky
      xbar()\bkimage[i] = bkimage
      xbar()\bkwidth[i] = bkwidth
      xbar()\bkheight[i] = bkheight
      xbar()\obkimage[i] = obkimage
      xbar()\obkwidth[i] = obkwidth
      xbar()\obkheight[i] = obkheight
      xbar()\border[i] = border
      If rectCreated = #True
        CopyStructure(rc, xbar()\borderrect, RECT)
      EndIf
      xbar()\mask[i] = mask
      
      CopyStructure(xbarMargin, xbar()\margin, RECT)
      CopyStructure(groupPad, xbar()\groupPadding, RECT)
      xbar()\headerHeight = headerHeight
      CopyStructure(groupMargin, xbar()\groupMargin, RECT)
      CopyStructure(itemPad, xbar()\itemPadding, RECT)
      xbar()\itemHeight = itemHeight
      ;xbar()\font[i] = font
      ;xbar()\fontcolour[i] = fontcolour
      ;xbar()\imgx[i] = imgx
      ;xbar()\imgy[i] = imgy
      ;xbar()\imgpercent[i] = imgpercent
      ;xbar()\imgalign[i] = imgAlign
      ;CopyStructure(imgpad, xbar()\imgpad[i], paddings)
      ;xbar()\txtx[i] = txtx
      ;xbar()\txty[i] = txty
      ;xbar()\txtpercent[i] = txtpercent
      ;xbar()\txtalign[i] = txtAlign
      ;CopyStructure(txtpad, xbar()\txtpad[i], paddings)
      
      ; group properties
      
      gbk = -1
      rectCreated = #False
    
      gbkimage = GetSkinPropertyData(skin, ComponentName, state$, "group background image")
      If gbkimage = 0
        gbkimage = nullicon
      EndIf
      
      xpos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group background position", "x")
      If FindString(xpos, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_HPERCENT
      EndIf
      If xpos <> ""
        If xpos = "centre"
          gbkstyle = gbkstyle | #PNLX_CENTRE
        ElseIf xpos = "repeat"
          gbkstyle = gbkstyle | #PNLX_HREPEAT
        Else
          gbkx = Val(xpos)
        EndIf
      EndIf
      
      ypos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group background position", "y")
      If FindString(ypos, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_VPERCENT
      EndIf
      If ypos <> ""
        If ypos = "centre"
          gbkstyle = gbkstyle | #PNLX_VCENTRE
        ElseIf ypos = "repeat"
          gbkstyle = gbkstyle | #PNLX_VREPEAT
        Else
          gbky = Val(ypos)
        EndIf
      EndIf
      
      left.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group background position", "left")
      If FindString(left, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_HPERCENT
      EndIf
      If left <> ""
        If left = "centre"
          gbkstyle = gbkstyle | #PNLX_CENTRE
        ElseIf left = "repeat"
          gbkstyle = gbkstyle | #PNLX_HREPEAT
        Else
          gbkx = Val(left)
        EndIf
      EndIf
      
      top.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group background position", "top")
      If FindString(top, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_VPERCENT
      EndIf
      If top <> ""
        If top = "centre"
          gbkstyle = gbkstyle | #PNLX_VCENTRE
        ElseIf top = "repeat"
          gbkstyle = gbkstyle | #PNLX_VREPEAT
        Else
          gbky = Val(top)
        EndIf
      EndIf
      
      right.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group background position", "right")
      If FindString(right, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_HPERCENT
      EndIf
      If right <> ""
        If right = "centre"
          gbkstyle = gbkstyle | #PNLX_CENTRE
        ElseIf right = "repeat"
          gbkstyle = gbkstyle | #PNLX_HREPEAT
        Else
          gbkx = Val(right)
          gbkstyle = gbkstyle | #PNLX_RIGHT
        EndIf
      EndIf
      
      bottom.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group background position", "bottom")
      If FindString(bottom, "%", 1) > 0
        gbkstyle = gbkstyle | #PNLX_VPERCENT
      EndIf
      If bottom <> ""
        If bottom = "centre"
          gbkstyle = gbkstyle | #PNLX_VCENTRE
        ElseIf bottom = "repeat"
          gbkstyle = gbkstyle | #PNLX_VREPEAT
        Else
          gbky = Val(bottom)
          gbkstyle = gbkstyle | #PNLX_BOTTOM
        EndIf
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "group background position", "stretch") = "true"
        gbkstyle = gbkstyle | #PNLX_STRETCH
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "group background position", "tile") = "true"
        gbkstyle = gbkstyle | #PNLX_TILE
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "group background position", "masked") = "true"
        gbkstyle = gbkstyle | #PNLX_MASKED
      EndIf
      
      p.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group background", "gradient")
      If p <> ""
        gradient = GetSkinPropertyData(skin, ComponentName, state$, "group background")
        If gradient <> 0 And GetSkinPropertyDataSize(skin, ComponentName, state$, "group background") <> 0
          gbk = gradient
        EndIf
      Else
        c = GetSkinPropertyColour(skin, ComponentName, state$, "group background")
        If c <> -1
          ; no alpha then remake colour with alpha
          If Alpha(c) = 0
            c = MakeColor(255, Red(c), Green(c), Blue(c))
          EndIf
          
          gbk = CreateGradient(0, c, c)
          If gbk <> 0
            SetSkinPropertyData(skin, ComponentName, state$, "group background", gbk)
            SetSkinPropertyDataSize(skin, ComponentName, state$, "group background", SizeOf(gbk))
          EndIf
        Else
          gbk = Val(GetSkinPropertyp(skin, ComponentName, state$, "group background"))
        EndIf
      EndIf
      
      ; border image
      border = GetSkinPropertyData(skin, ComponentName, state$, "group border image")
      t = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group border image", "top"))
      l = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group border image", "left"))
      b = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group border image", "bottom"))
      r = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group border image", "right"))
      If border <> 0 And t > 0 And l > 0 And b > 0 And r > 0
        rc.RECT
        rc\top = t
        rc\left = l
        rc\bottom = b
        rc\right = r
        rectCreated = #True
      EndIf
      gmask = GetSkinPropertyData(skin, ComponentName, state$, "group border mask")
      If gmask = 0
        gmask = Val(GetSkinPropertyp(skin, ComponentName, state$, "group border mask"))
      EndIf
      
      ;If rectCreated = #False
        t = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group border mask", "top"))
        l = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group border mask", "left"))
        b = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group border mask", "bottom"))
        r = Val(GetSkinPropertyParamp(skin, ComponentName, state$, "group border mask", "right"))
        If mask <> 0 And t > 0 And l > 0 And b > 0 And r > 0
          rc.RECT
          rc\top = t
          rc\left = l
          rc\bottom = b
          rc\right = r
          rectCreated = #True
        EndIf
      ;EndIf
      
      ; overlay
      gobkimage = GetSkinPropertyData(skin, ComponentName, state$, "group overlay image")
      If gobkimage = 0
        gobkimage = nullicon
      EndIf
      
      oxpos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group overlay position", "x")
      If FindString(oxpos, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_HPERCENT
      EndIf
      If oxpos <> ""
        If oxpos = "centre"
          gobkstyle = gobkstyle | #PNLX_CENTRE
        ElseIf oxpos = "repeat"
          gobkstyle = gobkstyle | #PNLX_HREPEAT
        Else
          gobkx = Val(oxpos)
        EndIf
      EndIf
      
      oypos.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group overlay position", "y")
      If FindString(oypos, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_VPERCENT
      EndIf
      If oypos <> ""
        If oypos = "centre"
          gobkstyle = gobkstyle | #PNLX_VCENTRE
        ElseIf oypos = "repeat"
          gobkstyle = gobkstyle | #PNLX_VREPEAT
        Else
          gobky = Val(oypos)
        EndIf
      EndIf
      
      left.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group overlay position", "left")
      If FindString(left, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_HPERCENT
      EndIf
      If left <> ""
        If left = "centre"
          gobkstyle = gobkstyle | #PNLX_CENTRE
        ElseIf left = "repeat"
          gobkstyle = gobkstyle | #PNLX_HREPEAT
        Else
          gobkx = Val(left)
        EndIf
      EndIf
      
      top.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group overlay position", "top")
      If FindString(top, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_VPERCENT
      EndIf
      If top <> ""
        If top = "centre"
          gobkstyle = gobkstyle | #PNLX_VCENTRE
        ElseIf top = "repeat"
          gobkstyle = gobkstyle | #PNLX_VREPEAT
        Else
          gobky = Val(top)
        EndIf
      EndIf
      
      right.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group overlay position", "right")
      If FindString(right, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_HPERCENT
      EndIf
      If right <> ""
        If right = "centre"
          gobkstyle = gobkstyle | #PNLX_CENTRE
        ElseIf right = "repeat"
          gobkstyle = gobkstyle | #PNLX_HREPEAT
        Else
          gobkx = Val(right)
          gobkstyle = gobkstyle | #PNLX_RIGHT
        EndIf
      EndIf
      
      bottom.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group overlay position", "bottom")
      If FindString(bottom, "%", 1) > 0
        gobkstyle = gobkstyle | #PNLX_VPERCENT
      EndIf
      If bottom <> ""
        If bottom = "centre"
          gobkstyle = gobkstyle | #PNLX_VCENTRE
        ElseIf bottom = "repeat"
          gobkstyle = gobkstyle | #PNLX_VREPEAT
        Else
          gobky = Val(bottom)
          gobkstyle = gobkstyle | #PNLX_BOTTOM
        EndIf
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "group overlay position", "stretch") = "true"
        gobkstyle = gobkstyle | #PNLX_STRETCH
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "group overlay position", "tile") = "true"
        gobkstyle = gobkstyle | #PNLX_TILE
      EndIf
      
      If GetSkinPropertyParamp(skin, ComponentName, state$, "group overlay position", "masked") = "true"
        gobkstyle = gobkstyle | #PNLX_MASKED
      EndIf
      
      p.s = GetSkinPropertyParamp(skin, ComponentName, state$, "group overlay", "gradient")
      If p <> ""
        gradient = GetSkinPropertyData(skin, ComponentName, state$, "group overlay")
        If gradient <> 0 And GetSkinPropertyDataSize(skin, ComponentName, state$, "group overlay") <> 0
          gobk = gradient
        EndIf
      Else
        c = GetSkinPropertyColour(skin, ComponentName, state$, "group overlay")
        If c <> -1
          ; no alpha then remake colour with alpha
          If Alpha(c) = 0
            c = MakeColor(255, Red(c), Green(c), Blue(c))
          EndIf
          
          gobk = CreateGradient(0, c, c)
          If gobk <> 0
            SetSkinPropertyData(skin, ComponentName, state$, "group overlay", gobk)
            SetSkinPropertyDataSize(skin, ComponentName, state$, "group overlay", SizeOf(gobk))
          EndIf
        Else
          If GetSkinPropertyp(skin, ComponentName, state$, "group overlay") = ""
            gobk = -1
          Else
            gobk = Val(GetSkinPropertyp(skin, ComponentName, state$, "group overlay"))
          EndIf
        EndIf
      EndIf
      
      
      ForEach xbar()\group()
        
        If i = 0
          SetPanelExPageBackground(xbar()\group()\group, 0, gbk, gbkimage, gbkx, gbky, gbkwidth, gbkheight, gbkstyle, #True)
          SetPanelExPageBackground(xbar()\group()\group, 0, gobk, gobkimage, gobkx, gobky, gobkwidth, gobkheight, gobkstyle | #PNLX_OVERLAY, #True)
          If rectCreated = #True
            SetPanelExPageBorder(xbar()\group()\group, 0, border, gmask, rc.RECT, 0, #True)
          Else
            SetPanelExPageBorder(xbar()\group()\group, 0, border, gmask, 0, 0, #True)
          EndIf
        EndIf
        
        ; if this is not from a #WM_UPDATESKIN message then update all child buttonex skins
        ; this is because the #WM_UPDATESKIN message automatically updates all buttonex skins and therefor this routine would set twice
        If noRefresh <> 2
          ; set new header skin
          SetButtonExSkin(xbar()\group()\header, skin, "explorerbar group header", #True)
          
          ForEach xbar()\group()\item()
            ; set new item skin
            SetButtonExSkin(xbar()\group()\item()\hwnd, skin, "explorerbar group item", #True)
          Next
        EndIf
        
      Next
      
      
      xbar()\gbk[i] = gbk
      xbar()\gbkstyle[i] = gbkstyle
      xbar()\gbkx[i] = gbkx
      xbar()\gbky[i] = gbky
      xbar()\gobk[i] = gobk
      xbar()\gobkstyle[i] = gobkstyle
      xbar()\gobkx[i] = gobkx
      xbar()\gobky[i] = gobky
      xbar()\gbkimage[i] = gbkimage
      xbar()\gbkwidth[i] = gbkwidth
      xbar()\gbkheight[i] = gbkheight
      xbar()\gobkimage[i] = gobkimage
      xbar()\gobkwidth[i] = gobkwidth
      xbar()\gobkheight[i] = gobkheight
      xbar()\gborder[i] = gborder
      If rectCreated = #True
        CopyStructure(rc, xbar()\gborderrect, RECT)
      EndIf
      xbar()\gmask[i] = gmask
      
    
    xbar()\skin = skin
    
    If noRefresh = #False
      RefreshPanelEx(xbar()\Handle)
    EndIf
    
    ProcedureReturn #True
    
  EndIf
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL GetExplorerBarSkin(ID.i) ; Gets an ExplorerBar's skin
  
  macro_protectCommand()
  
  ;find explorerbar
  ForEach xbar()
    If xbar()\handle = ID Or xbar()\id = ID
      ProcedureReturn xbar()\skin
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL CreateExplorerBar(WindowID.i, ExplorerBarID.l, x.l, y.l, Width.l, Height.l, Skin.i) ; Creates an empty skinned ExplorerBar control
  
  macro_protectCommand()
  
  ; make sure explorerbar control doesn't already exist
  If ExplorerBarID = #ProGUI_Any
    Repeat
      ; generate unique explorerbar id
      ExplorerBarID = generateUniqueID()
      ; check that same id doesnt already exist
      found = 0
      ForEach xbar()
        If xbar()\id = ExplorerBarID
          found = -1
          Break
        EndIf
      Next
    Until found = 0
    ProGUI_Any = #True
  Else
    ; make sure explorerbar id doesnt exist
    ForEach xbar()
      If xbar()\id = ExplorerBarID
        ProcedureReturn 0
      EndIf
    Next
  EndIf
  
  ; check that passed window handle is valid
  If IsWindow_(WindowID) = 0
    ProcedureReturn 0
  EndIf
  
  If skin = 0
    initDefaultSkin("sysxbarskin")
    skin = sysXBarSkin
  ElseIf skin = #UISTYLE_OFFICE2007
    initDefaultSkin("office2007xbarskin")
    skin = office2007XBarSkin
  ElseIf IsSkin(skin) = 0
    initDefaultSkin("sysxbarskin")
    skin = sysXBarSkin
  EndIf
  
  backupCurrentPanelEx = currentPanelEx ; store the current panelex for backup after the explorerbar is created
  hwnd = PanelExID(CreatePanelEx(#ProGUI_Any, WindowID, x, y, Width, Height, @explorerBarCallback()), -1)
  If hwnd <> 0
    
    page = AddPanelExImagePage(0, 0, 0, 0, 0, 0, #PNLX_NOGADGETLIST)
    currentPanelEx = backupCurrentPanelEx
    If page = 0
      FreePanelEx(hwnd)
      ProcedureReturn #False
    EndIf
    
    SetPanelExPageScrolling(hwnd, 0, #PNLX_AUTOSCROLL|#PNLX_AUTOSCROLL_NOHORIZONTAL, #True)
    
    LastElement(xbar())
    AddElement(xbar())
    xbar()\id = ExplorerBarID
    xbar()\Handle = hwnd
    xbar()\pageHandle = page
    xbar()\flags = flags
    xbar()\skin = skin
    
    currentExplorerBar = @xbar()
    
    If skin > 0
      If SetExplorerBarSkin(hwnd, skin, "", 0) = 0
        initDefaultSkin("sysxbarskin")
        SetExplorerBarSkin(hwnd, sysXBarSkin, "", 0)
      EndIf
    ElseIf skin = 0
      initDefaultSkin("sysxbarskin")
      SetExplorerBarSkin(hwnd, sysXBarSkin, "", 0)
    EndIf
    ;MoveWindow_(hwnd, x, y, width, height, #True)
   
    If ProGUI_Any = #True
      ProcedureReturn ExplorerBarID
    Else
      ProcedureReturn hwnd
    EndIf
   
  EndIf
  
  ProcedureReturn hwnd

EndProcedure

ProcedureDLL AddExplorerBarImageGroup(Title.s, normalImageID.i, hotImageID.i, pressedImageID.i, selectedImageID.i, hotSelectedImageID.i, pressedSelectedImageID.i, disabledImageID.i, isCollapsed.b) ; Adds a new group with header icon/image to the current previously created ExplorerBar control
  
  macro_protectCommand()
  
;   ForEach xbar()
;     If xbar()\id = ExplorerBarID Or xbar()\Handle = ExplorerBarID
;       found = #True
;       Break
;     EndIf
;   Next

 
  If currentExplorerBar <> 0 And ListSize(xbar()) > 0
    ChangeCurrentElement(xbar(), currentExplorerBar)
    
    ; create group PanelEx that will contain items
    backupCurrentPanelEx = currentPanelEx ; store the current panelex for backup after the group is created
    hwnd = PanelExID(CreatePanelEx(#ProGUI_Any, xbar()\pageHandle, 0, 0, 0, 0, @explorerBarGroupCallback()), -1)
    If hwnd <> 0
      
      page = AddPanelExImagePage(0, 0, 0, 0, 0, 0, #PNLX_NOGADGETLIST)
      currentPanelEx = backupCurrentPanelEx
      If page = 0
        FreePanelEx(hwnd)
        ProcedureReturn #False
      EndIf
      
      ; create group header toggle button
      header = ToggleButtonEx(xbar()\pageHandle, #ProGUI_Any, 0, 0, 0, 0, Title, normalImageID, hotImageID, pressedImageID, selectedImageID, hotSelectedImageID, pressedSelectedImageID, disabledImageID, -1)
      If header <> 0
        
        LastElement(xbar()\group())
        AddElement(xbar()\group())
        xbar()\group()\header = ButtonExID(header)
        xbar()\group()\headerID = header
        xbar()\group()\group = hwnd
        xbar()\group()\groupPage = page
        xbar()\group()\title = Title
        
        groupHeight = calcXbarGroupHeight()
        If groupHeight < xbar()\headerHeight
          groupHeight = xbar()\headerHeight
        EndIf
        
        If isCollapsed <> #False
          xbar()\group()\collapsed = #True
          xbar()\group()\storedheight = groupHeight
          groupHeight = 0
          SetButtonExState(header, #True)
        EndIf
        
        currentExplorerBarGroup = @xbar()\group()
        
        SetExplorerBarSkin(xbar()\Handle, xbar()\skin, "", 0)
        SetButtonExSkin(header, xbar()\skin, "explorerbar group header", 0)
        
        xbar = xbar()\Handle
        MoveWindow_(xbar()\group()\group, 0, 0, 0, groupHeight, #False)
        SendMessage_(xbar, #WM_SIZE, 0, 0)
        
        ProcedureReturn header
          
      EndIf
      
    EndIf
    
  EndIf
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL AddExplorerBarGroup(Title.s, isCollapsed.b) ; Adds a new group to the current previously created ExplorerBar control
  ProcedureReturn AddExplorerBarImageGroup(Title, 0, 0, 0, 0, 0, 0, 0, isCollapsed)
EndProcedure

ProcedureDLL SetExplorerBarGroupState(ID.i, Index.i, Collapse.b) ; Sets the ExplorerBar group's collapsed state, true/false. 
  
  ForEach xbar()
    If xbar()\id = ID Or xbar()\Handle = ID
      
      i = 0
      ForEach xbar()\group()
        If i = Index
          found = #True
          Break
        EndIf
        i+1
      Next
      Break
      
    EndIf
  Next
  
  If found = #True
    
    If Collapse <> #False
      
      If xbar()\group()\collapsed = #False
        GetClientRect_(xbar()\group()\group, srcRc.RECT)
        MapWindowPoints_(xbar()\group()\group, GetParent_(xbar()\group()\group), srcRc, 2)
        xbar()\group()\storedheight = xbar()\group()\height
        
        CopyStructure(srcRc, dstRc.RECT, RECT)
        dstRc\bottom = dstRc\top
        *anim.ANIMATION = AllocateMemory(SizeOf(ANIMATION))
        *anim\hwnd = xbar()\group()\group
        CopyStructure(srcRc, *anim\srcRc, RECT)
        CopyStructure(dstRc, *anim\dstRc, RECT)
        *anim\time = 200
        *anim\velocity = 4
        PostMessage_(animationThreadHwnd, #WM_ANIMATE, xbar()\group()\group, *anim)
        
        xbar()\group()\collapsed = #True
        
        SetButtonExState(xbar()\group()\header, #True)
      EndIf
      
    Else
      
      If xbar()\group()\collapsed = #True
        GetClientRect_(xbar()\group()\group, srcRc.RECT)
        MapWindowPoints_(xbar()\group()\group, GetParent_(xbar()\group()\group), srcRc, 2)
        CopyStructure(srcRc, dstRc.RECT, RECT)
        dstRc\bottom = dstRc\top+calcXbarGroupHeight()
        *anim.ANIMATION = AllocateMemory(SizeOf(ANIMATION))
        *anim\hwnd = xbar()\group()\group
        CopyStructure(srcRc, *anim\srcRc, RECT)
        CopyStructure(dstRc, *anim\dstRc, RECT)
        *anim\time = 200
        *anim\velocity = 4
        PostMessage_(animationThreadHwnd, #WM_ANIMATE, xbar()\group()\group, *anim)
        
        xbar()\group()\collapsed = #False
        
        SetButtonExState(xbar()\group()\header, #False)
      EndIf
      
    EndIf
    
    ProcedureReturn #True
    
  EndIf
  
  ProcedureReturn #False
  
EndProcedure

ProcedureDLL GetExplorerBarGroupState(ID.i, Index.i) ; Returns true if the specified ExplorerBar group is collapsed, false otherwise. 
  
  ForEach xbar()
    If xbar()\id = ID Or xbar()\Handle = ID
      
      i = 0
      ForEach xbar()\group()
        If i = Index
          found = #True
          Break
        EndIf
        i+1
      Next
      Break
      
    EndIf
  Next
  
  If found = #True
    
    ProcedureReturn xbar()\group()\collapsed
    
  EndIf
  
  ProcedureReturn #False
  
EndProcedure

ProcedureDLL ExplorerBarImageItem(ItemID.l, Text.s, normalImageID.i, hotImageID.i, pressedImageID.i, disabledImageID.i) ; Adds a new item with icon/image to the current previously created ExplorerBar group.
  
  macro_protectCommand()
  
;   ForEach xbar()
;     If xbar()\id = ExplorerBarID Or xbar()\Handle = ExplorerBarID
;       found = #True
;       Break
;     EndIf
;   Next

  ; make sure explorerbar item doesn't already exist
  If ItemID = #ProGUI_Any
    Repeat
      ; generate unique item id
      ItemID = generateUniqueID()
      ; check that same id doesnt already exist
      found = 0
      ForEach xbar()\group()\item()
        If xbar()\group()\item()\id = ItemID
          found = -1
          Break
        EndIf
      Next
    Until found = 0
    ProGUI_Any = #True
  Else
    ; make sure explorerbar item id doesnt exist
    ForEach xbar()\group()\item()
      If xbar()\group()\item()\id = ItemID
        ProcedureReturn 0
      EndIf
    Next
  EndIf
 
  If currentExplorerBar <> 0 And currentExplorerBarGroup <> 0 And ListSize(xbar()) > 0 And ListSize(xbar()\group()) > 0
    ChangeCurrentElement(xbar(), currentExplorerBar)
    ChangeCurrentElement(xbar()\group(), currentExplorerBarGroup)
    
    ; create item toggle button
    realid = ButtonEx(xbar()\group()\groupPage, #ProGUI_Any, 0, 0, 0, 0, Text, normalImageID, hotImageID, pressedImageID, disabledImageID, -1)
    item = ButtonExID(realid)
    If item <> 0
      
      LastElement(xbar()\group()\item())
      AddElement(xbar()\group()\item())
      xbar()\group()\item()\hwnd = item
      xbar()\group()\item()\realid = realid
      xbar()\group()\item()\id = ItemID
      
      groupHeight = calcXbarGroupHeight()
      If groupHeight < xbar()\headerHeight
        groupHeight = xbar()\headerHeight
      EndIf
      
      If xbar()\group()\collapsed = #True
        xbar()\group()\storedheight = groupHeight
        groupHeight = 0
      EndIf
      
      SetButtonExSkin(item, xbar()\skin, "explorerbar group item", 0)
      
      MoveWindow_(xbar()\group()\group, 0, 0, 0, groupHeight, #False)
      SendMessage_(xbar()\Handle, #WM_SIZE, 0, 0)
      
      If ProGUI_Any = #True
        ProcedureReturn ItemID
      Else
        ProcedureReturn item
      EndIf
     
    EndIf
    
  EndIf
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL ExplorerBarItem(ItemID.l, Text.s) ; Adds a new item to the current previously created ExplorerBar group.
  ProcedureReturn ExplorerBarImageItem(ItemID.l, Text.s, 0, 0, 0, 0)
EndProcedure

ProcedureDLL ExplorerBarID(id.l) ; Returns a handle to an ExplorerBar's window (HWND)
  
  ForEach xbar()
    If xbar()\id = id
      
      ProcedureReturn xbar()\Handle
      
    EndIf
  Next
  
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL FreeExplorerBar(id.i) ; Frees an ExplorerBar from memory
  
  ForEach xbar()
    If xbar()\id = id Or xbar()\Handle = id Or id = -1
      
      *thisxbar = xbar()
      ForEach xbar()\group()
        
        *thisgroup = xbar()\group()
        ForEach xbar()\group()\item()
          
          *thisitem = xbar()\group()\item()
          FreeButtonEx(xbar()\group()\item()\hwnd)
          ChangeCurrentElement(xbar()\group()\item(), *thisitem)
          
        Next
        ChangeCurrentElement(xbar()\group(), *thisgroup)
        
        FreeButtonEx(xbar()\group()\header)
        ChangeCurrentElement(xbar()\group(), *thisgroup)
        FreePanelEx(xbar()\group()\group)
        ChangeCurrentElement(xbar()\group(), *thisgroup)
        
      Next
      ChangeCurrentElement(xbar(), *thisxbar)
      
      FreePanelEx(xbar()\Handle)
      ChangeCurrentElement(xbar(), *thisxbar)
      RedrawWindow_(GetParent_(xbar()\Handle), 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_ERASENOW|#RDW_UPDATENOW)
      ChangeCurrentElement(xbar(), *thisxbar)
      DeleteElement(xbar(), 1)
      
      If id <> -1
        ProcedureReturn #True
      EndIf
      
    EndIf
  Next
  
  If id = -1
    ProcedureReturn #True
  EndIf
  ProcedureReturn 0
  
EndProcedure

CompilerIf #DISABLEPROTECTION = 0
 CompilerIf #LIBRARY = 0
   macro_hash()
 CompilerEndIf
CompilerEndIf


