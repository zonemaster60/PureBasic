; procedure returns a colour brush based on a style and index determined by windows theme
Procedure getMenuColour(style, index)
  
  If UIColourMode = #UICOLOURMODE_DEFAULT Or UIColourMode = #UICOLOURMODE_CUSTOM
    
    If hTheme <> 0
      
      r = Red(XPthemeColour)
      g = Green(XPthemeColour)
      b = Blue(XPthemeColour)
      
      ;debuglog("colors: "+Str(r)+" "+Str(g)+" "+Str(b))
      
      ;Whidbey style colours
      If style = #UISTYLE_WHIDBEY
        ; 3 different colour highlight styles depending on theme colour
        ; colour is more silver/grey
        If r >= 200 And g >= 200 And b >= 200
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIWhidbeyColours(index)\Silver
          Else
            colour = UIWhidbeyColours(index)\CustomSilver
          EndIf
          
          ; colour is more blue
        ElseIf r < 200 And g < 200 And b >= 200
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIWhidbeyColours(index)\Blue
          Else
            colour = UIWhidbeyColours(index)\CustomBlue
          EndIf
          
          ; colour is more green
        ElseIf r >= 200 And g >= 200 And b < 200
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIWhidbeyColours(index)\Olive
          Else
            colour = UIWhidbeyColours(index)\CustomOlive
          EndIf
          
          ; any other colour combination, default to clasic grey
        Else
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIWhidbeyColours(index)\Grey
          Else
            colour = UIWhidbeyColours(index)\CustomGrey
          EndIf
          
        EndIf
      EndIf
      
    Else ; couldn't open theme
      ;Whidbey style colours
      If style = #UISTYLE_WHIDBEY
        
        If index < 0
          ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
        EndIf
        
        If UIColourMode = #UICOLOURMODE_DEFAULT
          colour = UIWhidbeyColours(index)\Grey
        Else
          colour = UIWhidbeyColours(index)\CustomGrey
        EndIf
        
      EndIf
    EndIf
    ; overide automatic colour scheme selection
  Else
    Select UIColourMode
      Case #UICOLOURMODE_DEFAULT_BLUE
        
        If index < 0
          ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
        EndIf
        
        ;Whidbey style colours
        If style = #UISTYLE_WHIDBEY
          colour = UIWhidbeyColours(index)\Blue
        EndIf
        
      Case #UICOLOURMODE_DEFAULT_OLIVE
        
        If index < 0
          ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
        EndIf
        
        ;Whidbey style colours
        If style = #UISTYLE_WHIDBEY
          colour = UIWhidbeyColours(index)\Olive
        EndIf  
        
      Case #UICOLOURMODE_DEFAULT_SILVER
        
        If index < 0
          ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
        EndIf
        
        ;Whidbey style colours
        If style = #UISTYLE_WHIDBEY
          colour = UIWhidbeyColours(index)\Silver
        EndIf  
        
      Case #UICOLOURMODE_DEFAULT_GREY
        
        If index < 0
          ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
        EndIf
        
        ;Whidbey style colours
        If style = #UISTYLE_WHIDBEY
          colour = UIWhidbeyColours(index)\Grey
        EndIf  
        
      Case #UICOLOURMODE_CUSTOM_BLUE
        
        If index < 0
          ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
        EndIf
        
        ;Whidbey style colours
        If style = #UISTYLE_WHIDBEY
          colour = UIWhidbeyColours(index)\CustomBlue
        EndIf
        
      Case #UICOLOURMODE_CUSTOM_OLIVE
        
        If index < 0
          ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
        EndIf
        
        ;Whidbey style colours
        If style = #UISTYLE_WHIDBEY
          colour = UIWhidbeyColours(index)\CustomOlive
        EndIf
        
      Case #UICOLOURMODE_CUSTOM_SILVER
        
        If index < 0
          ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
        EndIf
        
        ;Whidbey style colours
        If style = #UISTYLE_WHIDBEY
          colour = UIWhidbeyColours(index)\CustomSilver
        EndIf
        
      Case #UICOLOURMODE_CUSTOM_GREY
        
        If index < 0
          ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
        EndIf
        
        ;Whidbey style colours
        If style = #UISTYLE_WHIDBEY
          colour = UIWhidbeyColours(index)\CustomGrey
        EndIf
        
    EndSelect
  EndIf
  
  If index <> #menuTextColor And index <> #disabledColor And index <> #menuTitleTextColor And index <> #menuTitleInactiveTextColor And index <> #menuTitleHotTextColor And index <> #menuTitleHeldTextColor And index <> #selectedTextColor And index <> #menuDropShadow ; exceptions for colours!
    
    ; create cached brush for component if does not exist or colour changed
    If brushHandle(index)\Handle = 0 Or brushHandle(index)\colour <> colour
      DeleteObject_(brushHandle(index)\Handle)
      brushHandle(index)\Handle = CreateSolidBrush_(colour)
      brushHandle(index)\colour = colour
    EndIf
    
    ProcedureReturn brushHandle(index)\Handle
   
  EndIf
  ProcedureReturn colour
EndProcedure

; procedure returns a colour based on a style and index determined by windows theme
Procedure getMenuColourEx(style, index, mode)
  
  ;/ Automatic theme based colour scheme slection
  If UIColourMode = #UICOLOURMODE_DEFAULT Or UIColourMode = #UICOLOURMODE_CUSTOM
    
    If hTheme <> 0
      
      r = Red(XPthemeColour)
      g = Green(XPthemeColour)
      b = Blue(XPthemeColour)
      
      ;debuglog("colors: "+Str(r)+" "+Str(g)+" "+Str(b))
      
      ;/ 2003 style colours
      If style = 6 Or style = #UISTYLE_OFFICE2003
        
        ; 3 different colour highlight styles depending on theme colour
        ; colour is more silver/grey
        If r >= 200 And g >= 200 And b >= 200
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIOffice2003Colours(index)\Silver
          Else
            colour = UIOffice2003Colours(index)\CustomSilver
          EndIf
  
        ; colour is more blue
        ElseIf r < 200 And g < 200 And b >= 200
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIOffice2003Colours(index)\Blue
          Else
            colour = UIOffice2003Colours(index)\CustomBlue
          EndIf
  
        ; colour is more green
        ElseIf r >= 200 And g >= 200 And b < 200
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIOffice2003Colours(index)\Olive
          Else
            colour = UIOffice2003Colours(index)\CustomOlive
          EndIf
          
        ; any other colour combination, default to clasic grey
        Else
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIOffice2003Colours(index)\Grey
          Else
            colour = UIOffice2003Colours(index)\CustomGrey
          EndIf
          
        EndIf
        
      ;/ 2007 style colours
      ElseIf style = #UISTYLE_OFFICE2007
      
        ; 3 different colour highlight styles depending on theme colour
        ; colour is more silver/grey
        If r >= 200 And g >= 200 And b >= 200
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIOffice2007Colours(index)\Silver
          Else
            colour = UIOffice2007Colours(index)\CustomSilver
          EndIf
  
        ; colour is more blue
        ElseIf r < 200 And g < 200 And b >= 200
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIOffice2007Colours(index)\Blue
          Else
            colour = UIOffice2007Colours(index)\CustomBlue
          EndIf
  
        ; colour is more green
        ElseIf r >= 200 And g >= 200 And b < 200
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIOffice2007Colours(index)\Olive
          Else
            colour = UIOffice2007Colours(index)\CustomOlive
          EndIf
          
        ; any other colour combination, default to clasic grey
        Else
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
          EndIf
          
          If UIColourMode = #UICOLOURMODE_DEFAULT
            colour = UIOffice2007Colours(index)\Grey
          Else
            colour = UIOffice2007Colours(index)\CustomGrey
          EndIf
          
        EndIf
        
      EndIf
    
    Else ; couldn't open theme
      
      ;/ 2003 style colours
      If style = 6 Or style = #UISTYLE_OFFICE2003
        
        If index < 0
          ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
        EndIf
        
        If UIColourMode = #UICOLOURMODE_DEFAULT
          colour = UIOffice2003Colours(index)\Grey
        Else
          colour = UIOffice2003Colours(index)\CustomGrey
        EndIf
        
      ;/ 2007 style colours
      ElseIf style = #UISTYLE_OFFICE2007
        
        If index < 0
          ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
        EndIf
        
        If UIColourMode = #UICOLOURMODE_DEFAULT
          colour = UIOffice2007Colours(index)\Grey
        Else
          colour = UIOffice2007Colours(index)\CustomGrey
        EndIf
        
      EndIf
      
    EndIf
    
  ;/ overide automatic colour scheme selection
  Else
  
    ;/ 2003 style colours
    If style = 6 Or style = #UISTYLE_OFFICE2003
      
      Select UIColourMode
        Case #UICOLOURMODE_DEFAULT_BLUE
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
          EndIf
          
          colour = UIOffice2003Colours(index)\Blue
          
        Case #UICOLOURMODE_DEFAULT_OLIVE
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
          EndIf
            
          colour = UIOffice2003Colours(index)\Olive
            
        Case #UICOLOURMODE_DEFAULT_SILVER
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
          EndIf
          
          colour = UIOffice2003Colours(index)\Silver
            
        Case #UICOLOURMODE_DEFAULT_GREY
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
          EndIf
          
          colour = UIOffice2003Colours(index)\Grey
            
        Case #UICOLOURMODE_CUSTOM_BLUE
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
          EndIf
          
          colour = UIOffice2003Colours(index)\CustomBlue
          
        Case #UICOLOURMODE_CUSTOM_OLIVE
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
          EndIf
          
          colour = UIOffice2003Colours(index)\CustomOlive
          
        Case #UICOLOURMODE_CUSTOM_SILVER
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
          EndIf
          
          colour = UIOffice2003Colours(index)\CustomSilver
          
        Case #UICOLOURMODE_CUSTOM_GREY
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
          EndIf
          
          colour = UIOffice2003Colours(index)\CustomGrey
          
      EndSelect
      
    ;/ 2007 style colours
    ElseIf style = #UISTYLE_OFFICE2007
    
      Select UIColourMode
        Case #UICOLOURMODE_DEFAULT_BLUE
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
          EndIf
          
          colour = UIOffice2007Colours(index)\Blue
          
        Case #UICOLOURMODE_DEFAULT_OLIVE
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
          EndIf
            
          colour = UIOffice2007Colours(index)\Olive
            
        Case #UICOLOURMODE_DEFAULT_SILVER
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
          EndIf
          
          colour = UIOffice2007Colours(index)\Silver
            
        Case #UICOLOURMODE_DEFAULT_GREY
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
          EndIf
          
          colour = UIOffice2007Colours(index)\Grey
            
        Case #UICOLOURMODE_CUSTOM_BLUE
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_BLUE
          EndIf
          
          colour = UIOffice2007Colours(index)\CustomBlue
          
        Case #UICOLOURMODE_CUSTOM_OLIVE
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_OLIVE
          EndIf
          
          colour = UIOffice2007Colours(index)\CustomOlive
          
        Case #UICOLOURMODE_CUSTOM_SILVER
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_SILVER
          EndIf
          
          colour = UIOffice2007Colours(index)\CustomSilver
          
        Case #UICOLOURMODE_CUSTOM_GREY
          
          If index < 0
            ProcedureReturn #UICOLOURMODE_CUSTOM_GREY
          EndIf
          
          colour = UIOffice2007Colours(index)\CustomGrey
          
      EndSelect
    EndIf
  EndIf

  If mode & #returnColour
    ProcedureReturn colour
  ElseIf mode & #returnRGBColour
    If PeekB(@colour+3)&$FF <> 0 ; check that the colour isn't made with makecolor, if so then return propper rgb
      colour = RGB(Blue(colour), Green(colour), Red(colour))
    EndIf
    ProcedureReturn colour
  Else
    
    If PeekB(@colour+3)&$FF <> 0 ; check that the colour isn't made with makecolor, if so then return propper rgb
      colour = RGB(Blue(colour), Green(colour), Red(colour))
    EndIf
    
    ; create cached brush for component if does not exist or colour changed
    If brushHandle(index)\Handle = 0 Or brushHandle(index)\colour <> colour
      DeleteObject_(brushHandle(index)\Handle)
      brushHandle(index)\Handle = CreateSolidBrush_(colour)
      brushHandle(index)\colour = colour
    EndIf
    
    ProcedureReturn brushHandle(index)\Handle
  EndIf
EndProcedure

Procedure defaultDisabledImage(normalImage, style)
  
  ;If style > 0 And style < #UISTYLE_WHIDBEY
  ;  ProcedureReturn ImgBlend(normalImage, 255, 0, 0, RGB(200,200,200), 140, #ImgBlend_Greyscale|#ImgBlend_ReturnIcon)
  If style = #UISTYLE_WHIDBEY
    ProcedureReturn ImgBlend(normalImage, 80, 0, 0, 0, 0, #ImgBlend_ReturnIcon)
  ElseIf style = 6 Or style = #UISTYLE_OFFICE2003
    ProcedureReturn ImgHueBlend(normalImage, 255, getMenuColourEx(style, #toolstripBackground4, #returnRGBColour), 0, 0.64, RGB(210,210,210), 110, #ImgBlend_ReturnIcon)
  ElseIf style = #UISTYLE_OFFICE2007
    ProcedureReturn ImgHueBlend(normalImage, 190, getMenuColourEx(style, #menuHeldGradientColor2, #returnRGBColour), -0.1, 0.49, getMenuColourEx(style, #menuHeldGradientColor1, #returnRGBColour), 80, #ImgBlend_ReturnIcon)
  Else
    ProcedureReturn ImgBlend(normalImage, 120, 0, 0, 0, 0, #ImgBlend_Greyscale|#ImgBlend_ReturnIcon)
  EndIf
  
EndProcedure

; mode = 0: update all, mode = 1: update items in handle (menuex), mode = 2: update items in handle (hmenu)
; mode = 3: update all ToolBarEx buttons, mode = 4: update ToolBarEx buttons by handle(toolbarEx()\id)
Procedure updateDefaultDisabledImages(handle.i, mode)
  
  ; iterate through all menu items and update disabled state icons if no custom icon specified
  If ListSize(itemex()) > 0 And mode < 3
    *thisItemEx = @itemex()
    ForEach itemex()
      If itemex()\normal = -1 And itemex()\disabled = 0  ; normal icon exists and no custom disabled state icon
        
        action = #False
        
        If mode = 0 ; update all items in every menuex
          action = #True
          ;debuglog("mode 0")
        ElseIf mode = 1 ; only update items in specified menuex handle
          If itemex()\menuex = handle
            *thisMenuEx = @menuex()
            ChangeCurrentElement(menuex(), itemex()\menuex)
            If itemex()\defDisabledStyle <> menuex()\style
              action = #True
              ;debuglog("mode 1")
            EndIf
            ChangeCurrentElement(menuex(), *thisMenuEx)
          EndIf
        ElseIf mode = 2 ; only update items in specified hmenu handle
          If itemex()\popupid = handle
            *thisMenuEx = @menuex()
            ChangeCurrentElement(menuex(), itemex()\menuex)
            If itemex()\defDisabledStyle <> menuex()\style
              action = #True
              ;debuglog("mode 2 "+Str(Random(10000)))
            EndIf
            ChangeCurrentElement(menuex(), *thisMenuEx)
          EndIf
        EndIf
        
        If action = #True
          *thisMenuEx = @menuex()
          ChangeCurrentElement(menuex(), itemex()\menuex)
          normalIcon = ImageList_GetIcon_(itemex()\ImageList, 0, 0)
          disabledIcon = defaultDisabledImage(normalIcon, menuex()\style)
          error.l = ImageList_ReplaceIcon_(itemex()\ImageList, 2, disabledIcon)
          DestroyIcon_(disabledIcon)
          DestroyIcon_(normalIcon)
          itemex()\defDisabledStyle = menuex()\style
          ;debuglog("updated icon!")
          ChangeCurrentElement(menuex(), *thisMenuEx)
        EndIf
        
      EndIf
    Next
    ChangeCurrentElement(itemex(), *thisItemEx)
  EndIf
  
  ; update all ToolBarEx disabled images
  If mode = 0 Or mode >= 3
    ; iterate through all ToolBarEx buttons and update disabled state icons if no custom icon specified
    If ListSize(toolbarExButton()) > 0
      
      *thistoolbarExButton = @toolbarExButton()
      ForEach toolbarExButton()
        
        If mode = 0 Or mode = 3 Or (mode = 4 And toolbarExButton()\toolbarID = handle)
          
          If toolbarExButton()\defDisabledImage = #True
            
            *thistoolbarEx = @toolbarEx()
            ChangeCurrentElement(toolbarEx(), toolbarExButton()\toolbarEx)
            
            If mode = 4 And toolbarEx()\UIStyle = toolbarExButton()\defDisabledStyle
              ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
              Continue
            EndIf
            
            If toolbarEx()\normalImageList <> -1
              
              index = SendMessage_(toolbarEx()\Handle, #TB_COMMANDTOINDEX, toolbarExButton()\id, 0)
              
              normalIcon = ImageList_GetIcon_(toolbarEx()\normalImageList, index, 0)
              If normalIcon <> nullicon
                
                disabledIcon = defaultDisabledImage(normalIcon, toolbarEx()\UIStyle)
                ImageList_ReplaceIcon_(toolbarEx()\disabledImageList, index, disabledIcon)
                DestroyIcon_(disabledIcon)
                toolbarExButton()\defDisabledStyle = toolbarEx()\UIStyle
                
              EndIf
              DestroyIcon_(normalIcon)
              
            EndIf
            
            ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
            
          EndIf
          
        EndIf
        
      Next
      ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
    EndIf
  EndIf
  
EndProcedure

; send WM_SETREDRAW false to all top level child windows
Procedure EnumChildWMSetRedraw(hwnd, lParam)
 
  If lParam <> 0 And GetWindowLongPtr_(hwnd, #GWL_STYLE) & #WS_VISIBLE
    If GetParent_(hwnd) = lParam
      AddElement(skinHwndRedraw())
      skinHwndRedraw() = hwnd
      SendMessage_(hwnd, #WM_SETREDRAW, #False, 0)
    EndIf
  EndIf
  
  ProcedureReturn #True
EndProcedure
Procedure EnumWindowsSetRedraw(hwnd, lParam)
  
  GetWindowThreadProcessId_(hwnd, @processID)
  If processID = lParam
    
    ClearList(skinHwndRedraw())
    If GetWindowLongPtr_(hwnd, #GWL_STYLE) & #WS_VISIBLE
      redrawHwnd = hwnd
    Else
      redrawHwnd = 0
    EndIf
    EnumChildWindows_(hwnd, @EnumChildWMSetRedraw(), redrawHwnd)
    
    ForEach skinHwndRedraw()
      SendMessage_(skinHwndRedraw(), #WM_SETREDRAW, #True, 0)
    Next
    
  EndIf
  
  ProcedureReturn #True
EndProcedure

ProcedureDLL SetUIColourMode(mode.l)
  
  macro_protectCommand()
  
  name.s = ""
  Select mode
    Case #UICOLOURMODE_DEFAULT
      UIColourMode = mode
      found = #True
    Case #UICOLOURMODE_DEFAULT_BLUE
      UIColourMode = mode
      found = #True
      name = "blue"
    Case #UICOLOURMODE_DEFAULT_OLIVE
      UIColourMode = mode
      found = #True
      name = "olive"
    Case #UICOLOURMODE_DEFAULT_SILVER
      UIColourMode = mode
      found = #True
      name = "silver"
    Case #UICOLOURMODE_DEFAULT_GREY
      UIColourMode = mode
      found = #True
      name = "grey"
    Case #UICOLOURMODE_CUSTOM
      UIColourMode = mode
      found = #True
    Case #UICOLOURMODE_CUSTOM_BLUE
      UIColourMode = mode
      found = #True
      name = "blue"
    Case #UICOLOURMODE_CUSTOM_OLIVE
      UIColourMode = mode
      found = #True
      name = "olive"
    Case #UICOLOURMODE_CUSTOM_SILVER
      UIColourMode = mode
      found = #True
      name = "silver"
    Case #UICOLOURMODE_CUSTOM_GREY
      UIColourMode = mode
      found = #True
      name = "grey"
  EndSelect
  
  If found = #True
    
    EnumWindows_(@EnumWindowsSetRedraw(), GetCurrentProcessId_())
    
    blitExFlush()
    
    ; re-render any styled rebar backgrounds with new theme
    RenderRebarBackgrounds(#True)
    
    updateDefaultDisabledImages(0, 0)
    
    ;ForEach menuCallback()
    ;  If menuCallback()\WindowID <> 0
    ;    RedrawWindow_(menuCallback()\WindowID, 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
    ;  EndIf
    ;Next
    
    ForEach menuex()
      menuex()\bufferWidth = 0
      menuex()\bufferHeight = 0
    Next
    
    SetGlobalSkinColourTheme(name)
    
  EndIf
  
  ProcedureReturn found
EndProcedure

ProcedureDLL GetUIColourMode() ; Returns the current user interface colour mode
  
  macro_protectCommand()
  
  ProcedureReturn UIColourMode
  
EndProcedure

ProcedureDLL GetCurrentColourScheme() ; Returns the current active colour scheme
  
  macro_protectCommand()
  
  If UIColourMode = #UICOLOURMODE_CUSTOM
    ProcedureReturn getMenuColourEx(#UISTYLE_OFFICE2003, -1, 0)
  Else
    ProcedureReturn getMenuColourEx(#UISTYLE_OFFICE2003, -1, 0)-5
  EndIf
  
EndProcedure

ProcedureDLL GetUIColour(style.l, component.l, colourScheme.l) ; returns the colour of a UI style component
  
  macro_protectCommand()
  
  ; make sure component isn't out of bounds!
  If component < 0 Or component >= #MaxUIComponents
    ProcedureReturn #False
  EndIf
  
  If style = #UISTYLE_WHIDBEY
    
    ; returns the current automatically selected colourscheme
    If colourScheme = 0
      colourScheme = getMenuColourEx(#UISTYLE_OFFICE2003, -1, 0)
    EndIf
    
    Select colourScheme
      Case #UICOLOURMODE_DEFAULT_BLUE
        colour = UIWhidbeyColours(component)\Blue
      Case #UICOLOURMODE_DEFAULT_SILVER
        colour = UIWhidbeyColours(component)\Silver
      Case #UICOLOURMODE_DEFAULT_OLIVE
        colour = UIWhidbeyColours(component)\Olive
      Case #UICOLOURMODE_DEFAULT_GREY
        colour = UIWhidbeyColours(component)\Grey
      Case #UICOLOURMODE_CUSTOM_BLUE
        colour = UIWhidbeyColours(component)\CustomBlue
      Case #UICOLOURMODE_CUSTOM_SILVER
        colour = UIWhidbeyColours(component)\CustomSilver
      Case #UICOLOURMODE_CUSTOM_OLIVE
        colour = UIWhidbeyColours(component)\CustomOlive
      Case #UICOLOURMODE_CUSTOM_GREY
        colour = UIWhidbeyColours(component)\CustomGrey
    EndSelect
  
  ElseIf style = #UISTYLE_OFFICE2003

    Select colourScheme
      Case #UICOLOURMODE_DEFAULT_BLUE
        colour = UIOffice2003Colours(component)\Blue
      Case #UICOLOURMODE_DEFAULT_SILVER
        colour = UIOffice2003Colours(component)\Silver
      Case #UICOLOURMODE_DEFAULT_OLIVE
        colour = UIOffice2003Colours(component)\Olive
      Case #UICOLOURMODE_DEFAULT_GREY
        colour = UIOffice2003Colours(component)\Grey
      Case #UICOLOURMODE_CUSTOM_BLUE
        colour = UIOffice2003Colours(component)\CustomBlue
      Case #UICOLOURMODE_CUSTOM_SILVER
        colour = UIOffice2003Colours(component)\CustomSilver
      Case #UICOLOURMODE_CUSTOM_OLIVE
        colour = UIOffice2003Colours(component)\CustomOlive
      Case #UICOLOURMODE_CUSTOM_GREY
        colour = UIOffice2003Colours(component)\CustomGrey
      Default
        colour = getMenuColourEx(#UISTYLE_OFFICE2003, component, #returnColour)
    EndSelect
    
  ElseIf style = #UISTYLE_OFFICE2007
    
    Select colourScheme
      Case #UICOLOURMODE_DEFAULT_BLUE
        colour = UIOffice2007Colours(component)\Blue
      Case #UICOLOURMODE_DEFAULT_SILVER
        colour = UIOffice2007Colours(component)\Silver
      Case #UICOLOURMODE_DEFAULT_OLIVE
        colour = UIOffice2007Colours(component)\Olive
      Case #UICOLOURMODE_DEFAULT_GREY
        colour = UIOffice2007Colours(component)\Grey
      Case #UICOLOURMODE_CUSTOM_BLUE
        colour = UIOffice2007Colours(component)\CustomBlue
      Case #UICOLOURMODE_CUSTOM_SILVER
        colour = UIOffice2007Colours(component)\CustomSilver
      Case #UICOLOURMODE_CUSTOM_OLIVE
        colour = UIOffice2007Colours(component)\CustomOlive
      Case #UICOLOURMODE_CUSTOM_GREY
        colour = UIOffice2007Colours(component)\CustomGrey
      Default
        colour = getMenuColourEx(#UISTYLE_OFFICE2007, component, #returnColour)
    EndSelect
    
  EndIf
  
  ; colour format is makecolor return rgb format
  Select component
    Case #menuHotColor
    Case #menuHotBorder
    Case #menuHeldColor
    Case #menuHeldBorder
    Case #menuBarColor
    Case #separatorBar
    Case #selectedColor
    Case #selectedBorder
    Case #background
    Case #gripperSolid
    Case #gripperShadow
    Case #menuCheckboxBackground
    Case #menuCheckboxBorder
    Case #menuCheckboxSelectedBackground
    Case #menuCheckboxSelectedBorder
    Case #menuCheckboxDisabledBackground
    Case #menuCheckboxDisabledBorder
    Case #toolbarButtonTextColor
    Case #toolbarButtonHotTextColor
    Case #toolbarButtonDisabledTextColor
    Case #toolbarSeparator
    Case #toolbarSeparatorShadow
    Default
      colour = RGB(Blue(colour), Green(colour), Red(colour))
  EndSelect
  
  ProcedureReturn colour
EndProcedure

ProcedureDLL SetUIColour(style.l, component.l, colour.l, colourScheme.l, noUpdate.b) ; sets the colour of a UI style component
  
  macro_protectCommand()
  
  ; make sure colourScheme is a custom colour slot
  If colourScheme < #UICOLOURMODE_CUSTOM
    colourScheme = colourScheme + #UICOLOURMODE_CUSTOM
  EndIf
  
  ; make sure colourScheme is within possible values
  If colourScheme < #UICOLOURMODE_CUSTOM
    ProcedureReturn #False
  ElseIf colourScheme > #UICOLOURMODE_CUSTOM_GREY
    ProcedureReturn #False
  EndIf
  
  ; make sure component isn't out of bounds!
  If component < 0 Or component >= #MaxUIComponents
    ProcedureReturn #False
  EndIf
  
  ; returns the current automatically selected colourscheme
  If colourScheme = #UICOLOURMODE_CUSTOM
    colourScheme = getMenuColourEx(style, -1, 0)
  EndIf
  
  ; colour format exceptions
  Select component
    Case #menuHotColor
    Case #menuHotBorder
    Case #menuHeldColor
    Case #menuHeldBorder
    Case #menuBarColor
    Case #separatorBar
    Case #selectedColor
    Case #selectedBorder
    Case #background
    Case #gripperSolid
    Case #gripperShadow
    Case #menuCheckboxBackground
    Case #menuCheckboxBorder
    Case #menuCheckboxSelectedBackground
    Case #menuCheckboxSelectedBorder
    Case #menuCheckboxDisabledBackground
    Case #menuCheckboxDisabledBorder
    Case #toolbarButtonTextColor
    Case #toolbarButtonHotTextColor
    Case #toolbarButtonDisabledTextColor
    Case #toolbarSeparator
    Case #toolbarSeparatorShadow
    Default
      colour = MakeColor(255, Red(colour), Green(colour), Blue(colour))
  EndSelect
  
  If style = #UISTYLE_WHIDBEY
    
    Select colourScheme
      Case #UICOLOURMODE_CUSTOM_BLUE
        UIWhidbeyColours(component)\CustomBlue = colour
      Case #UICOLOURMODE_CUSTOM_SILVER
        UIWhidbeyColours(component)\CustomSilver = colour
      Case #UICOLOURMODE_CUSTOM_OLIVE
        UIWhidbeyColours(component)\CustomOlive = colour
      Case #UICOLOURMODE_CUSTOM_GREY
        UIWhidbeyColours(component)\CustomGrey = colour
    EndSelect
    
    result = #True
  
  ElseIf style = #UISTYLE_OFFICE2003

    Select colourScheme
      Case #UICOLOURMODE_CUSTOM_BLUE
        UIOffice2003Colours(component)\CustomBlue = colour
      Case #UICOLOURMODE_CUSTOM_SILVER
        UIOffice2003Colours(component)\CustomSilver = colour
      Case #UICOLOURMODE_CUSTOM_OLIVE
        UIOffice2003Colours(component)\CustomOlive = colour
      Case #UICOLOURMODE_CUSTOM_GREY
        UIOffice2003Colours(component)\CustomGrey = colour
    EndSelect
    
    result = #True
    
  ElseIf style = #UISTYLE_OFFICE2007
    
    Select colourScheme
      Case #UICOLOURMODE_CUSTOM_BLUE
        UIOffice2007Colours(component)\CustomBlue = colour
      Case #UICOLOURMODE_CUSTOM_SILVER
        UIOffice2007Colours(component)\CustomSilver = colour
      Case #UICOLOURMODE_CUSTOM_OLIVE
        UIOffice2007Colours(component)\CustomOlive = colour
      Case #UICOLOURMODE_CUSTOM_GREY
        UIOffice2007Colours(component)\CustomGrey = colour
    EndSelect
    
    result = #True
    
  EndIf
  
  If result = #True And noUpdate = #False
    blitExFlush()
      
    ; re-render any styled rebar backgrounds with new theme
    RenderRebarBackgrounds(#True)
    
    updateDefaultDisabledImages(0, 0)
    
    ForEach menuCallback()
      If menuCallback()\WindowID <> 0
        RedrawWindow_(menuCallback()\WindowID, 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
      EndIf
    Next
    
    ForEach menuex()
      menuex()\bufferWidth = 0
      menuex()\bufferHeight = 0
    Next
  EndIf
  
  ProcedureReturn result
EndProcedure

; returns color value extracted from string if detected
Procedure checkColourValue(txt.s)
  
  txt = LCase(txt)
  
  If FindString(txt, "rgba", 1) > 0 And FindString(txt, ")", 1) > FindString(txt, "(", 1)
    txt = ReplaceString(txt, " ", "")
    txt = ReplaceString(txt, "rgba", "")
    txt = ReplaceString(txt, "(", "")
    txt = ReplaceString(txt, ")", "")
    txt = ReplaceString(txt, ";", "")
    r = Val(StringField(txt, 1, ","))
    g = Val(StringField(txt, 2, ","))
    b = Val(StringField(txt, 3, ","))
    a$ = StringField(txt, 4, ",")
    If FindString(a$, ".", 1) > 0
      a = ValF(a$)*255
    Else
      a = Val(a$)
    EndIf
    If a = 0
      a = 1
    EndIf
    ProcedureReturn MakeColor(a, r, g, b)
  ElseIf FindString(txt, "rgb", 1) > 0 And FindString(txt, ")", 1) > FindString(txt, "(", 1)
    txt = ReplaceString(txt, " ", "")
    txt = ReplaceString(txt, "rgb", "")
    txt = ReplaceString(txt, "(", "")
    txt = ReplaceString(txt, ")", "")
    txt = ReplaceString(txt, ";", "")
    r = Val(StringField(txt, 1, ","))
    g = Val(StringField(txt, 2, ","))
    b = Val(StringField(txt, 3, ","))
    ProcedureReturn RGB(r, g, b)
  ElseIf FindString(txt, "getuicolour", 1) > 0 And FindString(txt, ")", 1) > FindString(txt, "(", 1)
    
    txt = ReplaceString(txt, " ", "")
    txt = ReplaceString(txt, "#", "")
    txt = ReplaceString(txt, "getuicolour", "")
    txt = ReplaceString(txt, "(", "")
    txt = ReplaceString(txt, ")", "")
    txt = ReplaceString(txt, ";", "")
    style$ = UCase(StringField(txt, 1, ","))
    component$ = StringField(txt, 2, ",")
    colourScheme$ = UCase(StringField(txt, 3, ","))
    
    Select style$
      Case "UISTYLE_WHIDBEY"
        style = #UISTYLE_WHIDBEY
      Case "UISTYLE_OFFICE2003"
        style = #UISTYLE_OFFICE2003
      Case "UISTYLE_OFFICE2007"
        style = #UISTYLE_OFFICE2007
    EndSelect
    
    Select component$
      Case "menutitletextcolor"
        component = #menuTitleTextColor
      Case "menutitlehottextcolor"
        component = #menuTitleHotTextColor
      Case "menutitleheldtextcolor"
        component = #menuTitleHeldTextColor
      Case "menutitleinactivetextcolor"
        component = #menuTitleInactiveTextColor
      Case "menutextcolor"
        component = #menuTextColor
      Case "menuhotcolor"
        component = #menuHotColor
      Case "menuhotgradientcolor1"
        component = #menuHotGradientColor1
      Case "menuhotgradientcolor2"
        component = #menuHotGradientColor2
      Case "menuhotborder"
        component = #menuHotBorder
      Case "menuheldcolor"
        component = #menuHeldColor
      Case "menuheldgradientcolor1"
        component = #menuHeldGradientColor1
      Case "menuheldgradientcolor2"
        component = #menuHeldGradientColor2
      Case "menuheldborder"
        component = #menuHeldBorder
      Case "menubarcolor"
        component = #menuBarColor
      Case "menucheckboxbackground"
        component = #menuCheckboxBackground
      Case "menucheckboxborder"
        component = #menuCheckboxBorder
      Case "menucheckboxselectedbackground"
        component = #menuCheckboxSelectedBackground
      Case "menucheckboxselectedborder"
        component = #menuCheckboxSelectedBorder
      Case "menucheckboxdisabledbackground"
        component = #menuCheckboxDisabledBackground
      Case "menucheckboxdisabledborder"
        component = #menuCheckboxDisabledBorder
      Case "menudropshadow"
        component = #menuDropShadow
      Case "bargradientcolor1"
        component = #barGradientColor1
      Case "bargradientcolor2"
        component = #barGradientColor2
      Case "bargradientcolor3"
        component = #barGradientColor3
      Case "bargradientcolor4"
        component = #barGradientColor4
      Case "separatorbar"
        component = #separatorBar
      Case "selectedcolor"
        component = #selectedColor
      Case "selectedtextcolor"
        component = #selectedTextColor
      Case "selectedborder"
        component = #selectedBorder
      Case "disabledcolor"
        component = #disabledColor
      Case "background"
        component = #background
      Case "rebarbackground1"
        component = #rebarBackground1
      Case "rebarbackground2"
        component = #rebarBackground2
      Case "toolstripbackground1"
        component = #toolstripBackground1
      Case "toolstripbackground2"
        component = #toolstripBackground2
      Case "toolstripbackground3"
        component = #toolstripBackground3
      Case "toolstripbackground4"
        component = #toolstripBackground4
      Case "toolstripdropdowngradient1"
        component = #toolstripDropdownGradient1
      Case "toolstripdropdowngradient2"
        component = #toolstripDropdownGradient2
      Case "toolstripdropdowngradient3"
        component = #toolstripDropdownGradient3
      Case "toolstripdropdowngradient4"
        component = #toolstripDropdownGradient4
      Case "toolstripshadow"
        component = #toolstripShadow
      Case "grippersolid"
        component = #gripperSolid
      Case "grippershadow"
        component = #gripperShadow
      Case "selectgradientcolor1"
        component = #SelectGradientColor1
      Case "selectgradientcolor2"
        component = #SelectGradientColor2
      Case "stickyselectgradientcolor1"
        component = #StickySelectGradientColor1
      Case "stickyselectgradientcolor2"
        component = #StickySelectGradientColor2
      Case "stickyselectbordercolor"
        component = #StickySelectBorderColor
      Case "toolbarbuttontextcolor"
        component = #toolbarButtonTextColor
      Case "toolbarbuttonhottextcolor"
        component = #toolbarButtonHotTextColor
      Case "toolbarbuttondisabledtextcolor"
        component = #toolbarButtonDisabledTextColor
      Case "toolbarhotgradientcolor1"
        component = #toolbarHotGradientColor1
      Case "toolbarhotgradientcolor2"
        component = #toolbarHotGradientColor2
      Case "toolbarseparator"
        component = #toolbarSeparator
      Case "toolbarseparatorshadow"
        component = #toolbarSeparatorShadow
    EndSelect
    
    Select colourScheme$
      Case "UICOLOURMODE_DEFAULT"
        colourScheme = #UICOLOURMODE_DEFAULT
      Case "UICOLOURMODE_DEFAULT_BLUE"
        colourScheme = #UICOLOURMODE_DEFAULT_BLUE
      Case "UICOLOURMODE_DEFAULT_GREY"
        colourScheme = #UICOLOURMODE_DEFAULT_GREY
      Case "UICOLOURMODE_DEFAULT_OLIVE"
        colourScheme = #UICOLOURMODE_DEFAULT_OLIVE
      Case "UICOLOURMODE_DEFAULT_SILVER"
        colourScheme = #UICOLOURMODE_DEFAULT_SILVER
      Case "UICOLOURMODE_CUSTOM"
        colourScheme = #UICOLOURMODE_CUSTOM
      Case "UICOLOURMODE_CUSTOM_BLUE"
        colourScheme = #UICOLOURMODE_CUSTOM_BLUE
      Case "UICOLOURMODE_CUSTOM_GREY"
        colourScheme = #UICOLOURMODE_CUSTOM_GREY
      Case "UICOLOURMODE_CUSTOM_OLIVE"
        colourScheme = #UICOLOURMODE_CUSTOM_OLIVE
      Case "UICOLOURMODE_CUSTOM_SILVER"
        colourScheme = #UICOLOURMODE_CUSTOM_SILVER
    EndSelect
    
    ProcedureReturn GetUIColour(style, component, colourScheme)
    
  ElseIf FindString(txt, "#", 1) > 0
    pos = FindString(txt, "#", 1) + 1
    p = pos
    Repeat
      If (Asc(Mid(txt, p, 1)) >= 48 And Asc(Mid(txt, p, 1)) <= 57) Or (Asc(Mid(txt, p, 1)) >= 97 And Asc(Mid(txt, p, 1)) <= 102)
        found = found + 1
      Else
        Break
      EndIf
      p = p + 1
    Until p > Len(txt) Or p-pos > 6
    If found = 6
      c = Val("$"+Mid(txt, pos, 6))
      ProcedureReturn RGB(Blue(c), Green(c), Red(c))
    EndIf
  Else
    
    txt = Trim(txt)
    txt = ReplaceString(txt, ";", "")
    
    ; check special system colour constants
    txtu.s = UCase(txt)
    col = -1
    Select txtu
      Case "COLOR_3DDKSHADOW"
        col = GetSysColor_(#COLOR_3DDKSHADOW)
      Case "COLOR_3DFACE"
        col = GetSysColor_(#COLOR_3DFACE)
      Case "COLOR_3DHIGHLIGHT"
        col = GetSysColor_(#COLOR_3DHIGHLIGHT)
      Case "COLOR_3DLIGHT"
        col = GetSysColor_(#COLOR_3DLIGHT)
      Case "COLOR_3DSHADOW"
        col = GetSysColor_(#COLOR_3DSHADOW)
      Case "COLOR_ACTIVEBORDER"
        col = GetSysColor_(#COLOR_ACTIVEBORDER)
      Case "COLOR_ACTIVECAPTION"
        col = GetSysColor_(#COLOR_ACTIVECAPTION)
      Case "COLOR_APPWORKSPACE"
        col = GetSysColor_(#COLOR_APPWORKSPACE)
      Case "COLOR_BACKGROUND"
        col = GetSysColor_(#COLOR_BACKGROUND)
      Case "COLOR_BTNFACE"
        col = GetSysColor_(#COLOR_BTNFACE)
      Case "COLOR_BTNHIGHLIGHT"
        col = GetSysColor_(#COLOR_BTNHIGHLIGHT)
      Case "COLOR_BTNHILIGHT"
        col = GetSysColor_(#COLOR_BTNHILIGHT)
      Case "COLOR_BTNSHADOW"
        col = GetSysColor_(#COLOR_BTNSHADOW)
      Case "COLOR_BTNTEXT"
        col = GetSysColor_(#COLOR_BTNTEXT)
      Case "COLOR_CAPTIONTEXT"
        col = GetSysColor_(#COLOR_CAPTIONTEXT)
      Case "COLOR_DESKTOP"
        col = GetSysColor_(#COLOR_DESKTOP)
      Case "COLOR_GRADIENTACTIVECAPTION"
        col = GetSysColor_(#COLOR_GRADIENTACTIVECAPTION)
      Case "COLOR_GRADIENTINACTIVECAPTION"
        col = GetSysColor_(#COLOR_GRADIENTINACTIVECAPTION)
      Case "COLOR_GRAYTEXT"
        col = GetSysColor_(#COLOR_GRAYTEXT)
      Case "COLOR_HIGHLIGHT"
        col = GetSysColor_(#COLOR_HIGHLIGHT)
      Case "COLOR_HIGHLIGHTTEXT"
        col = GetSysColor_(#COLOR_HIGHLIGHTTEXT)
      Case "COLOR_HOTLIGHT"
        col = GetSysColor_(#COLOR_HOTLIGHT)
      Case "COLOR_INACTIVEBORDER"
        col = GetSysColor_(#COLOR_INACTIVEBORDER)
      Case "COLOR_INACTIVECAPTION"
        col = GetSysColor_(#COLOR_INACTIVECAPTION)
      Case "COLOR_INACTIVECAPTIONTEXT"
        col = GetSysColor_(#COLOR_INACTIVECAPTIONTEXT)
      Case "COLOR_INFOBK"
        col = GetSysColor_(#COLOR_INFOBK)
      Case "COLOR_INFOTEXT"
        col = GetSysColor_(#COLOR_INFOTEXT)
      Case "COLOR_MENU"
        col = GetSysColor_(#COLOR_MENU)
      Case "COLOR_MENUHILIGHT"
        col = GetSysColor_(#COLOR_MENUHILIGHT)
      Case "COLOR_MENUBAR"
        col = GetSysColor_(#COLOR_MENUBAR)
      Case "COLOR_MENUTEXT"
        col = GetSysColor_(#COLOR_MENUTEXT)
      Case "COLOR_SCROLLBAR"
        col = GetSysColor_(#COLOR_SCROLLBAR)
      Case "COLOR_WINDOW"
        col = GetSysColor_(#COLOR_WINDOW)
      Case "COLOR_WINDOWFRAME"
        col = GetSysColor_(#COLOR_WINDOWFRAME)
      Case "COLOR_WINDOWTEXT"
        col = GetSysColor_(#COLOR_WINDOWTEXT)
    EndSelect
      
    If col <> -1
      ProcedureReturn col
    EndIf

    If FindMapElement(colour(), txt)
      
      ProcedureReturn RGB(Blue(colour()), Green(colour()), Red(colour()))
            
    EndIf
    
  EndIf
  
  ProcedureReturn -1
  
EndProcedure

Procedure blitExFlush()
  
  For n = 0 To #MaxUIComponents
    
    ; flush #UISTYLE_OFFICE2003 cache
    If UIOffice2003Colours(n)\hdc <> 0
      DeleteObject_(UIOffice2003Colours(n)\bitmap)
      DeleteDC_(UIOffice2003Colours(n)\hdc)
      UIOffice2003Colours(n)\hdc = 0
      UIOffice2003Colours(n)\bitmap = 0
      UIOffice2003Colours(n)\width = 0
      UIOffice2003Colours(n)\height = 0
    EndIf
    ForEach UIOffice2003Colours(n)\dBlitEx()
      If UIOffice2003Colours(n)\dBlitEx()\hdc <> 0
        DeleteObject_(UIOffice2003Colours(n)\dBlitEx()\bitmap)
        DeleteDC_(UIOffice2003Colours(n)\dBlitEx()\hdc)
        UIOffice2003Colours(n)\dBlitEx()\hdc = 0
        UIOffice2003Colours(n)\dBlitEx()\bitmap = 0
        UIOffice2003Colours(n)\dBlitEx()\width = 0
        UIOffice2003Colours(n)\dBlitEx()\height = 0
      EndIf
    Next
    
    ; flush #UISTYLE_OFFICE2007 cache
    If UIOffice2007Colours(n)\hdc <> 0
      DeleteObject_(UIOffice2007Colours(n)\bitmap)
      DeleteDC_(UIOffice2007Colours(n)\hdc)
      UIOffice2007Colours(n)\hdc = 0
      UIOffice2007Colours(n)\bitmap = 0
      UIOffice2007Colours(n)\width = 0
      UIOffice2007Colours(n)\height = 0
    EndIf
    ForEach UIOffice2007Colours(n)\dBlitEx()
      If UIOffice2007Colours(n)\dBlitEx()\hdc <> 0
        DeleteObject_(UIOffice2007Colours(n)\dBlitEx()\bitmap)
        DeleteDC_(UIOffice2007Colours(n)\dBlitEx()\hdc)
        UIOffice2007Colours(n)\dBlitEx()\hdc = 0
        UIOffice2007Colours(n)\dBlitEx()\bitmap = 0
        UIOffice2007Colours(n)\dBlitEx()\width = 0
        UIOffice2007Colours(n)\dBlitEx()\height = 0
      EndIf
    Next
    
  Next
  
EndProcedure

; used for cacheing complex fixed size & dynamic sized rendered components as bitmaps
Procedure blitEx(hdc.i, style.l, component.l, *rec.RECT, mode.l)
  
  ; get the width and height of the component to be rendered
  width = *rec\right-*rec\left
  height = *rec\bottom-*rec\top
  
  ;debuglog("Width: "+Str(width)+" Height: "+Str(height))
  
  If mode & #DynamicBlitEx
    mode = mode &~ #DynamicBlitEx
    Dynamic = #True
  EndIf
  
  ;/ Office 2003 Style
  If style = 6 Or style = #UISTYLE_OFFICE2003

    If Dynamic = #False
      
      ; decide if to re-cache and redraw
      If UIOffice2003Colours(component)\hdc = 0
        redraw = #True
      Else
        If mode = 0
          If width > UIOffice2003Colours(component)\width Or height > UIOffice2003Colours(component)\height
            redraw = #True
          EndIf
        ElseIf mode = #ForceHorizontalRedraw And (UIOffice2003Colours(component)\width <> width Or height > UIOffice2003Colours(component)\height)
          redraw = #True
        ElseIf mode = #ForceVerticalRedraw And (UIOffice2003Colours(component)\height <> height Or width > UIOffice2003Colours(component)\width)
          redraw = #True
        ElseIf mode = #ForceRedraw And (UIOffice2003Colours(component)\width <> width Or UIOffice2003Colours(component)\height <> height)
          redraw = #True
        EndIf
      EndIf
      
      If redraw = #True
        ; free old bitmap cache if exists
        If UIOffice2003Colours(component)\hdc <> 0
          DeleteObject_(UIOffice2003Colours(component)\bitmap)
          DeleteDC_(UIOffice2003Colours(component)\hdc)
        EndIf
        
        ; create new bitmap cache
        UIOffice2003Colours(component)\hdc = CreateCompatibleDC_(hdc)
        UIOffice2003Colours(component)\bitmap = CreateCompatibleBitmap_(hdc, width, height)
        UIOffice2003Colours(component)\width = width
        UIOffice2003Colours(component)\height = height
        
        SelectObject_(UIOffice2003Colours(component)\hdc, UIOffice2003Colours(component)\bitmap)

      EndIf
      
      chdc = UIOffice2003Colours(component)\hdc
      cbitmap = UIOffice2003Colours(component)\bitmap
    
    Else
      
      new = #True
      ForEach UIOffice2003Colours(component)\dBlitEx()
        If mode = 0 And UIOffice2003Colours(component)\dBlitEx()\width = width And UIOffice2003Colours(component)\dBlitEx()\height = height
          new = #False
          Break
        ElseIf mode = #ForceHorizontalRedraw And UIOffice2003Colours(component)\dBlitEx()\width = width
          new = #False
          If height > UIOffice2003Colours(component)\dBlitEx()\height
            redraw = #True
          EndIf
          Break
        ElseIf mode = #ForceVerticalRedraw And UIOffice2003Colours(component)\dBlitEx()\height = height
          new = #False
          If width > UIOffice2003Colours(component)\dBlitEx()\width
            redraw = #True
          EndIf
          Break
        EndIf
      Next
      
      If new = #True Or redraw = #True
        
        If new = #True
          AddElement(UIOffice2003Colours(component)\dBlitEx())
          redraw = #True
        EndIf
        
        ; free old bitmap cache if exists
        If UIOffice2003Colours(component)\dBlitEx()\hdc <> 0
          DeleteObject_(UIOffice2003Colours(component)\dBlitEx()\bitmap)
          DeleteDC_(UIOffice2003Colours(component)\dBlitEx()\hdc)
        EndIf
        
        ; create new bitmap cache
        UIOffice2003Colours(component)\dBlitEx()\hdc = CreateCompatibleDC_(hdc)
        UIOffice2003Colours(component)\dBlitEx()\bitmap = CreateCompatibleBitmap_(hdc, width, height)
        UIOffice2003Colours(component)\dBlitEx()\width = width
        UIOffice2003Colours(component)\dBlitEx()\height = height
        
        SelectObject_(UIOffice2003Colours(component)\dBlitEx()\hdc, UIOffice2003Colours(component)\dBlitEx()\bitmap)
      EndIf
      
      chdc = UIOffice2003Colours(component)\dBlitEx()\hdc
      cbitmap = UIOffice2003Colours(component)\dBlitEx()\bitmap
      cwidth = UIOffice2003Colours(component)\dBlitEx()\width
      cheight = UIOffice2003Colours(component)\dBlitEx()\height
      
    EndIf
    
    If redraw = #True
      
      ;/ render the component onto cache bitmap
      Select component
        Case #menuHotGradientColor1
          
          If InitGDIPlus() <> 0
            p1.POINT
            p1\x = 0
            p1\y = 0
            p2.POINT
            p2\x = 0
            p2\y = height-1
            
            CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
            CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #menuHotGradientColor1, #returnColour),getMenuColourEx(6, #menuHotGradientColor2, #returnColour),1,@colour)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
            CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
            CallFunctionFast(*GdipDeleteBrush,colour)  
          EndIf
          
        Case #menuHeldGradientColor1
          
          If InitGDIPlus() <> 0
            p1.POINT
            p1\x = 0
            p1\y = 0
            p2.POINT
            p2\x = 0
            p2\y = height-1
            
            CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
            CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #menuHeldGradientColor1, #returnColour),getMenuColourEx(6, #menuHeldGradientColor2, #returnColour),1,@colour)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
            CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
            CallFunctionFast(*GdipDeleteBrush,colour)  
          EndIf
          
        Case #menuBarColor  ; render gradient bar
          
          If InitGDIPlus() <> 0
            p1.POINT
            p1\x = 0
            p1\y = 0
            p2.POINT
            p2\x = (width/2)-1
            p2\y = 0
            
            p3.POINT
            p3\x = (width/2)
            p3\y = 0
            p4.POINT
            p4\x = width-1
            p4\y = 0
            
            CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
            CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #barGradientColor1, #returnColour),getMenuColourEx(6, #barGradientColor2, #returnColour),1,@colour)
            CallFunctionFast(*GdipCreateLineBrushI,p3,p4,getMenuColourEx(6, #barGradientColor3, #returnColour),getMenuColourEx(6, #barGradientColor4, #returnColour),1,@colour2)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width/2,height)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour2,width/2,0,(width/2)+1,height)
            CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
            CallFunctionFast(*GdipDeleteBrush,colour)
            CallFunctionFast(*GdipDeleteBrush,colour2)
          EndIf
          
        Case #menuCheckboxBorder  ; render checkbox
          
          colour = getMenuColourEx(menuex()\style, #menuCheckboxBackground, 0)
          border = getMenuColourEx(menuex()\style, #menuCheckboxBorder, 0)
          
          rc.RECT
          rc\right = width
          rc\bottom = height
          FrameRect_(chdc, rc, border)
          rc\left = rc\left+1
          rc\right = rc\right-1
          rc\top = rc\top+1
          rc\bottom = rc\bottom-1
          FillRect_(chdc, rc, colour)
          
        Case #menuCheckboxSelectedBorder  ; render selected checkbox
          
          colour = getMenuColourEx(menuex()\style, #menuCheckboxSelectedBackground, 0)
          border = getMenuColourEx(menuex()\style, #menuCheckboxSelectedBorder, 0)
          
          rc.RECT
          rc\right = width
          rc\bottom = height
          FrameRect_(chdc, rc, border)
          rc\left = rc\left+1
          rc\right = rc\right-1
          rc\top = rc\top+1
          rc\bottom = rc\bottom-1
          FillRect_(chdc, rc, colour)
          
        Case #toolstripBackground1  ; render toolstrip background
          
          p1.POINT
          p1\x = 0
          p1\y = 0
          p2.POINT
          p2\x = 0
          p2\y = height/2
          CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
          CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #toolstripBackground1, #returnColour),getMenuColourEx(6, #toolstripBackground2, #returnColour),1,@colour)
          CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,(height/2)+1)
          
          p1.POINT
          p1\x = 0
          p1\y = (height/2)+1
          p2.POINT
          p2\x = 0
          p2\y = height-2
          CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #toolstripBackground3, #returnColour),getMenuColourEx(6, #toolstripBackground4, #returnColour),1,@colour2)
          CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour2,0,(height/2)+1,width,(height/2)-1)
          
          ; draw bottom shadow line
          shadow = getMenuColourEx(6, #toolstripShadow, #returnColour)
          CallFunctionFast(*GdipCreateSolidFill,shadow,@colour3)
          CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour3,0,height-1,width,1)
          
          CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
          CallFunctionFast(*GdipDeleteBrush,colour)
          CallFunctionFast(*GdipDeleteBrush,colour2)
          CallFunctionFast(*GdipDeleteBrush,colour3)
          
        Case #SelectGradientColor1
          
          If InitGDIPlus() <> 0
            p1.POINT
            p1\x = 0
            p1\y = 0
            p2.POINT
            p2\x = 0
            p2\y = height-1
            
            CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
            CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #SelectGradientColor1, #returnColour),getMenuColourEx(6, #SelectGradientColor2, #returnColour),1,@colour)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
            CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
            CallFunctionFast(*GdipDeleteBrush,colour)  
          EndIf
          
        Case #toolbarHotGradientColor1
          
          If InitGDIPlus() <> 0
            p1.POINT
            p1\x = 0
            p1\y = 0
            p2.POINT
            p2\x = 0
            p2\y = height-1
            
            CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
            CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #toolbarHotGradientColor1, #returnColour),getMenuColourEx(6, #toolbarHotGradientColor2, #returnColour),1,@colour)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
            CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
            CallFunctionFast(*GdipDeleteBrush,colour)  
          EndIf

      EndSelect
      
      debuglog("Created new #UISTYLE_OFFICE2003 blitCache: "+Str(component)+" Width: "+Str(width)+" Height: "+Str(height))
      
    EndIf
    
  ;/ Office 2007 Style
  ElseIf style = #UISTYLE_OFFICE2007
    
    If Dynamic = #False
      
      ; decide if to re-cache and redraw
      If UIOffice2007Colours(component)\hdc = 0
        redraw = #True
      Else
        If mode = 0
          If width > UIOffice2007Colours(component)\width Or height > UIOffice2007Colours(component)\height
            redraw = #True
          EndIf
        ElseIf mode = #ForceHorizontalRedraw And (UIOffice2007Colours(component)\width <> width Or height > UIOffice2007Colours(component)\height)
          redraw = #True
        ElseIf mode = #ForceVerticalRedraw And (UIOffice2007Colours(component)\height <> height Or width > UIOffice2007Colours(component)\width)
          redraw = #True
        ElseIf mode = #ForceRedraw And (UIOffice2007Colours(component)\width <> width Or UIOffice2007Colours(component)\height <> height)
          redraw = #True
        EndIf
      EndIf
      
      If redraw = #True
        ; free old bitmap cache if exists
        If UIOffice2007Colours(component)\hdc <> 0
          DeleteObject_(UIOffice2007Colours(component)\bitmap)
          DeleteDC_(UIOffice2007Colours(component)\hdc)
        EndIf
        
        ; create new bitmap cache
        UIOffice2007Colours(component)\hdc = CreateCompatibleDC_(hdc)
        UIOffice2007Colours(component)\bitmap = CreateCompatibleBitmap_(hdc, width, height)
        UIOffice2007Colours(component)\width = width
        UIOffice2007Colours(component)\height = height
        
        SelectObject_(UIOffice2007Colours(component)\hdc, UIOffice2007Colours(component)\bitmap)

      EndIf
      
      chdc = UIOffice2007Colours(component)\hdc
      cbitmap = UIOffice2007Colours(component)\bitmap
    
    Else
      
      new = #True
      ForEach UIOffice2007Colours(component)\dBlitEx()
        If mode = 0 And UIOffice2007Colours(component)\dBlitEx()\width = width And UIOffice2007Colours(component)\dBlitEx()\height = height
          new = #False
          Break
        ElseIf mode = #ForceHorizontalRedraw And UIOffice2007Colours(component)\dBlitEx()\width = width
          new = #False
          If height > UIOffice2007Colours(component)\dBlitEx()\height
            redraw = #True
          EndIf
          Break
        ElseIf mode = #ForceVerticalRedraw And UIOffice2007Colours(component)\dBlitEx()\height = height
          new = #False
          If width > UIOffice2007Colours(component)\dBlitEx()\width
            redraw = #True
          EndIf
          Break
        EndIf
      Next
      
      If new = #True Or redraw = #True
        
        If new = #True
          AddElement(UIOffice2007Colours(component)\dBlitEx())
          redraw = #True
        EndIf
        
        ; free old bitmap cache if exists
        If UIOffice2007Colours(component)\dBlitEx()\hdc <> 0
          DeleteObject_(UIOffice2007Colours(component)\dBlitEx()\bitmap)
          DeleteDC_(UIOffice2007Colours(component)\dBlitEx()\hdc)
        EndIf
        
        ; create new bitmap cache
        UIOffice2007Colours(component)\dBlitEx()\hdc = CreateCompatibleDC_(hdc)
        UIOffice2007Colours(component)\dBlitEx()\bitmap = CreateCompatibleBitmap_(hdc, width, height)
        UIOffice2007Colours(component)\dBlitEx()\width = width
        UIOffice2007Colours(component)\dBlitEx()\height = height
        
        SelectObject_(UIOffice2007Colours(component)\dBlitEx()\hdc, UIOffice2007Colours(component)\dBlitEx()\bitmap)
      EndIf
      
      chdc = UIOffice2007Colours(component)\dBlitEx()\hdc
      cbitmap = UIOffice2007Colours(component)\dBlitEx()\bitmap
      cwidth = UIOffice2007Colours(component)\dBlitEx()\width
      cheight = UIOffice2007Colours(component)\dBlitEx()\height
      
    EndIf
    
    If redraw = #True
      
      ;/ render the component onto cache bitmap
      Select component
        Case #menuHotGradientColor1
          
          If InitGDIPlus() <> 0
            p1.POINT
            p1\x = 0
            p1\y = 0
            p2.POINT
            p2\x = 0
            p2\y = height-1
            
            CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
            CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #menuHotGradientColor1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #menuHotGradientColor2, #returnColour),1,@colour)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
            CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
            CallFunctionFast(*GdipDeleteBrush,colour)  
          EndIf
          
        Case #menuHeldGradientColor1
          
          If InitGDIPlus() <> 0
            p1.POINT
            p1\x = 0
            p1\y = 0
            p2.POINT
            p2\x = 0
            p2\y = height-1
            
            CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
            CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #menuHeldGradientColor1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #menuHeldGradientColor2, #returnColour),1,@colour)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
            CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
            CallFunctionFast(*GdipDeleteBrush,colour)  
          EndIf
          
        Case #menuBarColor  ; render gradient bar
          
          If InitGDIPlus() <> 0
            p1.POINT
            p1\x = 0
            p1\y = 0
            p2.POINT
            p2\x = (width/2)-1
            p2\y = 0
            
            p3.POINT
            p3\x = (width/2)
            p3\y = 0
            p4.POINT
            p4\x = width-1
            p4\y = 0
            
            CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
            CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #barGradientColor1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #barGradientColor2, #returnColour),1,@colour)
            CallFunctionFast(*GdipCreateLineBrushI,p3,p4,getMenuColourEx(#UISTYLE_OFFICE2007, #barGradientColor3, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #barGradientColor4, #returnColour),1,@colour2)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width/2,height)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour2,width/2,0,(width/2)+1,height)
            CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
            CallFunctionFast(*GdipDeleteBrush,colour)
            CallFunctionFast(*GdipDeleteBrush,colour2)
          EndIf
          
        Case #menuCheckboxBorder  ; render checkbox
          
          colour = getMenuColourEx(menuex()\style, #menuCheckboxBackground, 0)
          border = getMenuColourEx(menuex()\style, #menuCheckboxBorder, 0)
          
          rc.RECT
          rc\right = width
          rc\bottom = height
          FrameRect_(chdc, rc, border)
          rc\left = rc\left+1
          rc\right = rc\right-1
          rc\top = rc\top+1
          rc\bottom = rc\bottom-1
          FillRect_(chdc, rc, colour)
          
        Case #menuCheckboxSelectedBorder  ; render selected checkbox
          
          colour = getMenuColourEx(menuex()\style, #menuCheckboxSelectedBackground, 0)
          border = getMenuColourEx(menuex()\style, #menuCheckboxSelectedBorder, 0)
          
          rc.RECT
          rc\right = width
          rc\bottom = height
          FrameRect_(chdc, rc, border)
          rc\left = rc\left+1
          rc\right = rc\right-1
          rc\top = rc\top+1
          rc\bottom = rc\bottom-1
          FillRect_(chdc, rc, colour)
          
        Case #toolstripBackground1  ; render toolstrip background
          
          p1.POINT
          p1\x = 0
          p1\y = 0
          p2.POINT
          p2\x = 0
          p2\y = height/2
          CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
          CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #toolstripBackground1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #toolstripBackground2, #returnColour),1,@colour)
          CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,(height/2)+1)
          
          p1.POINT
          p1\x = 0
          p1\y = (height/2)+1
          p2.POINT
          p2\x = 0
          p2\y = height-2
          CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #toolstripBackground3, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #toolstripBackground4, #returnColour),1,@colour2)
          CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour2,0,(height/2)+1,width,(height/2)-1)
          
          ; draw bottom shadow line
          shadow = getMenuColourEx(#UISTYLE_OFFICE2007, #toolstripShadow, #returnColour)
          CallFunctionFast(*GdipCreateSolidFill,shadow,@colour3)
          CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour3,0,height-1,width,1)
          
          CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
          CallFunctionFast(*GdipDeleteBrush,colour)
          CallFunctionFast(*GdipDeleteBrush,colour2)
          CallFunctionFast(*GdipDeleteBrush,colour3)
          
        Case #SelectGradientColor1
          
          If InitGDIPlus() <> 0
            p1.POINT
            p1\x = 0
            p1\y = 0
            p2.POINT
            p2\x = 0
            p2\y = height-1
            
            CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
            CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #SelectGradientColor1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #SelectGradientColor2, #returnColour),1,@colour)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
            CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
            CallFunctionFast(*GdipDeleteBrush,colour)  
          EndIf
          
        Case #toolbarHotGradientColor1
          
          If InitGDIPlus() <> 0
            p1.POINT
            p1\x = 0
            p1\y = 0
            p2.POINT
            p2\x = 0
            p2\y = height-1
            
            CallFunctionFast(*GdipCreateFromHDC, chdc, @GraphicObject)
            CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(#UISTYLE_OFFICE2007, #toolbarHotGradientColor1, #returnColour),getMenuColourEx(#UISTYLE_OFFICE2007, #toolbarHotGradientColor2, #returnColour),1,@colour)
            CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,0,0,width,height)
            CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
            CallFunctionFast(*GdipDeleteBrush,colour)  
          EndIf
          
      EndSelect
      
      debuglog("Created new #UISTYLE_OFFICE2007 blitCache: "+Str(component)+" Width: "+Str(width)+" Height: "+Str(height))
      
    EndIf

  EndIf
  
  ; render the cached component
  SelectObject_(chdc, cbitmap)
  If Dynamic = #False
    BitBlt_(hdc, *rec\left, *rec\top, width, height, chdc, 0, 0, #SRCCOPY)
  Else
    
    ;hRgn = CreateRectRgn_(*rec\left, *rec\top, *rec\right, *rec\bottom)
    ;hRgn = CreateRectRgn_(*rec\left, *rec\top, *rec\left+width, *rec\top+height)
    ;selectClipRgn_(hdc, hRgn)
    
    ;debuglog("this works: "+Str(*rec\left)+" "+Str(*rec\top)+" "+Str(width)+" "+Str(height)+" "+Str(chdc))
    BitBlt_(hdc, *rec\left, *rec\top, width, height, chdc, 0, 0, #SRCCOPY)
    
    ;SelectClipRgn_(hdc, 0)
    ;DeleteObject_(hRgn)
    
  EndIf
  
EndProcedure

;- Title shadow macros
Macro addTitleDropShadow()
  ; add drop shadows to menu title
  pnt.POINT
  pnt2.POINT
  AddElement(titleShadow())
  titleShadow()\hwnd = *nmhdr\hwndFrom
  titleShadow()\x = *nmTBCust\rc\left
  titleShadow()\y = *nmTBCust\rc\top
  If menuTitleVOffset <> -1
    pnt\x =*nmTBCust\rc\right
    pnt\y =*nmTBCust\rc\top+4
    pnt2\x =*nmTBCust\rc\left
    pnt2\y =*nmTBCust\rc\bottom
    MapWindowPoints_(*nmhdr\hwndFrom, 0, @pnt, 1)
    MapWindowPoints_(*nmhdr\hwndFrom, 0, @pnt2, 1)
    ; find nearest display monitor to edge of title
    prc.RECT
    prc\left = menuWindowXpos
    prc\top = pnt\y
    prc\right = prc\left
    prc\bottom = prc\top
    hmonitor = MonitorFromRect_(@prc, #MONITOR_DEFAULTTONEAREST)
    minfo.MONITORINFO
    minfo\cbSize = SizeOf(MONITORINFO)
    GetMonitorInfo_(hmonitor, @minfo)
    
    ; handle drawing of shadow either side of button when inbetween screens
    If pnt\x > minfo\rcWork\right
      titleShadow()\bottomShadow = dropShadow(minfo\rcWork\right, pnt2\y, (pnt\x-minfo\rcWork\right)+4, 5, colour, Alpha, #DropShadowEnd)
      pxl = 1
    ElseIf pnt2\x < menuWindowXpos
      titleShadow()\bottomShadow = dropShadow(pnt2\x+4, pnt2\y, (menuWindowXpos-pnt2\x)-4, 5, colour, Alpha, #DropShadowStart)
    EndIf
    
    titleShadow()\rightShadow = dropShadow(pnt\x, pnt\y, 5, (*nmTBCust\rc\bottom-*nmTBCust\rc\top)-5+pxl, colour, Alpha, #DropShadowVertical|#DropShadowStart)
  Else
    pnt\x =*nmTBCust\rc\right
    pnt\y =*nmTBCust\rc\top
    MapWindowPoints_(*nmhdr\hwndFrom, 0, @pnt, 1)
    titleShadow()\rightShadow = dropShadow(pnt\x, pnt\y-1, 5, (*nmTBCust\rc\bottom-*nmTBCust\rc\top)+1, colour, Alpha, #DropShadowVertical|#DropShadowStart)
    pnt\x =*nmTBCust\rc\left+4
    pnt\y =*nmTBCust\rc\bottom
    MapWindowPoints_(*nmhdr\hwndFrom, 0, @pnt, 1)
    titleShadow()\bottomShadow = dropShadow(pnt\x, pnt\y, (*nmTBCust\rc\right-*nmTBCust\rc\left), 5, colour, Alpha, 0)
  EndIf
EndMacro

Macro destroyTitleShadows()
  ; destroy title dropshadows if exists
  If ListSize(titleShadow()) > 0
    ForEach titleShadow()
      If titleShadow()\hwnd = *nmhdr\hwndFrom And titleShadow()\x = *nmTBCust\rc\left And titleShadow()\y = *nmTBCust\rc\top
        DestroyWindow_(titleShadow()\rightShadow)
        DestroyWindow_(titleShadow()\bottomShadow)
        DeleteElement(titleShadow())
        Break
      EndIf
    Next
  EndIf
EndMacro

;- render item text macro
Macro renderItemText(flags)
  
  text.s = itemex()\text
  p = FindString(text, #ShortcutCode, 1)
  If p <> 0
    Repeat
      If Mid(text, n, 1) = #ShortcutCode And Mid(text, n+1, 1) = #ShortcutCode
        text = Mid(text, 1, n)+Mid(text, n+2, Len(text))
      ElseIf Mid(text, n, 1) = #ShortcutCode And Mid(text, n+1, 1) <> #ShortcutCode
        foundShortcut = #True
        p = n
        Break
      EndIf
      n = n + 1
    Until n >= Len(text)
  EndIf
  
  If foundShortcut = #True
    txt.s = Mid(text, 1, p-1)
    shortcut.s = Mid(text, p+1)
    renderText(*item\hdc, txt, @rec, currentMenuEXFont, flags)
    rec\left = 0
    renderText(*item\hdc, shortcut, @rec, currentMenuEXFont, #DT_CALCRECT)
    width = rec\right
    rec\left = *item\rcItem\right-width-GetSystemMetrics_(#SM_CXMENUCHECK)-6
    rec\right = rec\left+width
    rec\top = *item\rcItem\top
    rec\bottom = *item\rcItem\bottom-1
    renderText(*item\hdc, shortcut, @rec, currentMenuEXFont, flags)
  Else
    renderText(*item\hdc, text, @rec, currentMenuEXFont, flags)
  EndIf
EndMacro

;- render item submenu arrow
Macro renderSubArrow()
  
  mnfo.MENUITEMINFO_Fixed
  mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
  mnfo\fMask = #MIIM_SUBMENU
  GetMenuItemInfo_(*item\hwndItem, itemex()\pos, #True, @mnfo)
  
  ; if this item is a submenu draw black arrow icon
  If mnfo\hSubMenu <> 0
    width = GetSystemMetrics_(#SM_CXMENUCHECK)+2
    height = (*item\rcItem\bottom-3)-(*item\rcItem\top+3)
    
    arrowDC = CreateCompatibleDC_(*item\hdc)
    arrowBitmap = CreateCompatibleBitmap_(*item\hdc, width, height)
    SelectObject_(arrowDC, arrowBitmap)
    rc.RECT
    rc\left = 0
    rc\right = width
    rc\top = 0
    rc\bottom = height
    
    DrawFrameControl_(arrowDC, rc, #DFC_MENU, #DFCS_MENUARROW)
    TransparentBlt_(*item\hdc, *item\rcItem\right-width, *item\rcItem\top+3, width, height, arrowDC, 0, 0, width, height, RGB(255,255,255))
    DeleteDC_(arrowDC)
    DeleteObject_(arrowBitmap)
    
    ExcludeClipRect_(*item\hdc, *item\rcItem\right-width,*item\rcItem\top, *item\rcItem\right, *item\rcItem\bottom-1)
  EndIf
EndMacro

Macro renderSubArrowColour(colour)
  
  mnfo.MENUITEMINFO_Fixed
  mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
  mnfo\fMask = #MIIM_SUBMENU
  GetMenuItemInfo_(itemex()\popupid, *item\itemID, 0, @mnfo)
  
  ; if this item is a submenu draw black arrow icon
  If mnfo\hSubMenu <> 0
    width = GetSystemMetrics_(#SM_CXMENUCHECK)+2
    height = (*item\rcItem\bottom-3)-(*item\rcItem\top+3)
    arrowDC = CreateCompatibleDC_(*item\hdc)
    arrowBitmap = CreateCompatibleBitmap_(*item\hdc, width, height)
    SelectObject_(arrowDC, arrowBitmap)
    rc.RECT
    rc\left = 0
    rc\right = width
    rc\top = 0
    rc\bottom = height
    
    DrawFrameControl_(arrowDC, rc, #DFC_MENU, #DFCS_MENUARROW)
    TransparentBlt_(*item\hdc, *item\rcItem\right-width, *item\rcItem\top+3, width, height, arrowDC, 0, 0, width, height, RGB(255,255,255))
    c = CreateSolidBrush_(colour)
    oldBrush = SelectObject_(*item\hdc, c)
    ExtFloodFill_(*item\hdc, *item\rcItem\right-width+(width/2)-1, *item\rcItem\top+3+(height/2)-1, 0, #FLOODFILLSURFACE)
    SelectObject_(*item\hdc, oldBrush)
    DeleteObject_(c)
    DeleteDC_(arrowDC)
    DeleteObject_(arrowBitmap)
    ExcludeClipRect_(*item\hdc, *item\rcItem\right-width,*item\rcItem\top, *item\rcItem\right, *item\rcItem\bottom-1)
  EndIf
EndMacro

Procedure drawDropDownGlyph(hdc, x, y, width, height, color)
  
  pen = CreatePen_(#PS_SOLID, 0, color)
  fill = CreateSolidBrush_(color)
  oldpen = SelectObject_(hdc, pen)
  oldfill = SelectObject_(hdc, fill)
  
  width = width - 1
  height = height - 1
  
  Dim pnt.POINT(3)
  pnt(0)\x = x+width/2
  pnt(0)\y = y+height
  pnt(1)\x = x
  pnt(1)\y = y
  pnt(2)\x = x+width
  pnt(2)\y = y
  
  Polygon_(hdc, @pnt(), 3)
  
  SelectObject_(hdc, oldpen)
  SelectObject_(hdc, oldfill)
  DeleteObject_(fill)
  DeleteObject_(pen)
  
EndProcedure



Procedure backupHDCAlpha(hdc, *area.RECT)
  Static alphaImage
  
  bitmap = GetCurrentObject_(hdc, #OBJ_BITMAP)
  
  LockMutex(panelMutex)
  *thisPanelEx = @panelex()
  *thisPage = @panelexpage()
  ForEach panelex()
    If panelex()\backgroundBitmap <> 0 And ImageID(panelex()\backgroundBitmap) = bitmap
      ;found = panelex()\backgroundBitmap
      ;hwnd = panelex()\handle
      ;Break
    EndIf
    If panelex()\alphaBitmap <> 0 And ImageID(panelex()\alphaBitmap) = bitmap
      found = panelex()\alphaBitmap
      hwnd = panelex()\handle
      Break
    EndIf
  Next
  If found <> 0 And panelex()\displayedPage <> 0
    ChangeCurrentElement(panelexpage(), panelex()\displayedPage)
    page = panelexpage()\Handle
  EndIf
  ChangeCurrentElement(panelex(), *thisPanelEx)
  ChangeCurrentElement(panelexpage(), *thisPage)
  UnlockMutex(panelMutex)
  
  If found <> 0
    
    CopyStructure(*area, rc.RECT, RECT)
    GetWindowOrgEx_(hdc, @p.POINT)
    ;Debug "px:"+Str(p\x)+" py:"+Str(p\y)
    rc\left - p\x
    rc\right - p\x
    rc\top - p\y
    rc\bottom - p\y
    
    If alphaImage = 0
      alphaImage = CreateImage(#PB_Any, rc\right-rc\left, rc\bottom-rc\top, 32)
      textdc = StartDrawing(ImageOutput(alphaImage))
      DrawingMode(#PB_2DDrawing_AllChannels)
      trc.RECT
      trc\right = width
      trc\bottom = height
      Box(trc\left, trc\top, trc\right-trc\left, trc\bottom-trc\top, RGBA(0,0,0,255))
      
      ;rendertext(textdc, txt, trc, thisFont, style)
      
      
  ;     For x = 0 To width-1
  ;       For y = 0 To height-1
  ;         c = Point(x,y)
  ;         If Alpha(c) = 0
  ;           Debug Red(c)
  ;           Plot(x,y,RGBA(0,0,0,255))
  ;         Else
  ;           ;If Alpha(c) <> 255
  ;           ;  Debug Alpha(c)
  ;           ;EndIf
  ;           Plot(x,y,RGBA(0,0,0,0))
  ;         EndIf
  ;       Next
  ;     Next
  
    
    ;Box(trc\left, trc\top, trc\right-trc\left, trc\bottom-trc\top, RGBA(0,0,0,255))
    StopDrawing()
    ProcedureReturn 0
    EndIf
    
    StartDrawing(ImageOutput(found))
    
    If alphaImage = 0
      DrawingMode(#PB_2DDrawing_AllChannels)
      ;Box(rc\left, rc\top, rc\right-rc\left, rc\bottom-rc\top, RGBA(255,0,0,255))
      ;alphaImage = GrabDrawingImage(#PB_Any, rc\left, rc\top, rc\right-rc\left, rc\bottom-rc\top)
      
      
      
    Else
      DrawingMode(#PB_2DDrawing_AlphaChannel)
      DrawImage(ImageID(alphaImage), rc\left, rc\top)
      FreeImage(alphaImage)
      alphaImage = 0
    EndIf

    ;Box(rc\left, rc\top, rc\right-rc\left, rc\bottom-rc\top, RGBA(255,0,0,255))
    ;refAlpha = Point(*area\left, *area\top)
    ;Debug "alpha: "+Str(Alpha(refAlpha))
    StopDrawing()
  EndIf
    
EndProcedure

Macro FastRed(Color)
  
  Color & 255
  
EndMacro 

Macro FastGreen(Color)
  
  (Color & 65535) >> 8
  
EndMacro 

Macro FastBlue(Color)
  
  (Color & 16777215) >> 16
  
EndMacro

Macro FastAlpha(Color)
  
  ;(Color & 4294967295) >> 24
  Alpha(Color)
  
EndMacro

Macro FastRGBA(r,g,b,a)
  
  r|g<<8|b<<16|a<<24
  
EndMacro

Global alphaTextWidth
Global alphaTextHeight
Global alphaTextRgn
Procedure FilterCallback(x, y, s, t)
  Static tAlpha
  alpha = FastAlpha(t)
  
  If x < alphaTextWidth And y < alphaTextHeight

    If PtInRegion_(alphaTextRgn, x, y)
      
      alphaS = FastAlpha(s)
      If alphaS = 255
        tAlpha = alpha
      EndIf
      
      uAlpha = FastBlue(s)
      iAlpha = 255-uAlpha
      ;u32_Pix_A = (u32_Inv * u32_Pix_A + u32_Alpha * 255 ) / 255
      ;r = (iAlpha * Red(t) + uAlpha * Red(t)) / 255
      ;g = (iAlpha * Green(t) + uAlpha * Green(t)) / 255
      ;b = (iAlpha * Blue(t) + uAlpha * Blue(t)) / 255
      alpha = (iAlpha * tAlpha + uAlpha * 255) / 255
      
      If alphaS = 255 And alpha = 0
        alpha = 0
      EndIf
      
      If alphaS = 0 And tAlpha = 0
        alpha = (iAlpha * 0 + uAlpha * 255) / 355
      EndIf
      
    EndIf
    
  EndIf
  
  ProcedureReturn FastRGBA(FastRed(t), FastGreen(t), FastBlue(t), alpha)
EndProcedure

Procedure ConvertToAlpha(Image, transcolor, intensity)

  Structure BGRA
    blue.a
    green.a
    red.a
    alpha.a
  EndStructure

;   GetObject_(bitmap, SizeOf(BITMAP), bmp.BITMAP)
;   *bits.BGRA = bmp\bmBits
;   For i=0 To bmp\bmHeight-1
;     For j=0 To bmp\bmWidthBytes-1 Step 4
;       *px.BGRA = *bits + bmp\bmWidthBytes * i + j
;       If *px\blue=Blue(transcolor) And *px\green=Green(transcolor) And *px\red=Red(transcolor)
;         *px\alpha = 0
;       Else
;         *px\alpha = intensity
;       EndIf
;     Next
;   Next

  GetObject_(Image, SizeOf(BITMAP), bmp.BITMAP)
  *bits.BGRA = bmp\bmBits
  For i=0 To bmp\bmHeight-1
    For j=0 To bmp\bmWidthBytes-1 Step 4
      *px.BGRA = *bits + bmp\bmWidthBytes * i + j
;       If *px\blue=Blue(transcolor) And *px\green=Green(transcolor) And *px\red=Red(transcolor)
;         *px\alpha = 0
;       Else
;         *px\alpha = intensity
;       EndIf
       *px\alpha = (*px\red+*px\green+*px\blue)
    Next
  Next

;   GetObject_(Image, SizeOf(BITMAP), bmp.BITMAP)
;   *bits.BGRA = bmp\bmBits
;   For i=0 To bmp\bmHeight-1
;     For j=0 To bmp\bmWidthBytes-1 Step 4
;       *px.BGRA = *bits + bmp\bmWidthBytes * i + j
; ;       If *px\blue=Blue(transcolor) And *px\green=Green(transcolor) And *px\red=Red(transcolor)
; ;         *px\alpha = 0
; ;       Else
; ;         *px\alpha = intensity
; ;       EndIf
;       If *px\alpha = 0
;         *px\alpha = intensity
;       Else
;         *px\alpha = 0
;       EndIf
;     Next
;   Next
  
EndProcedure


Procedure alphaText(hdc, txt.s, *rc.RECT, thisFont, style)
  Static textImage
  
  bitmap = GetCurrentObject_(hdc, #OBJ_BITMAP)
  
  LockMutex(panelMutex)
  If ListSize(panelex()) > 0 And ListSize(panelexpage()) > 0
    *thisPanelEx = @panelex()
    *thisPage = @panelexpage()
    ForEach panelex()
      If panelex()\alphaBitmap <> 0 And ImageID(panelex()\alphaBitmap) = bitmap
        found = panelex()\alphaBitmap
        hwnd = panelex()\handle
        Break
      EndIf
    Next
    If found <> 0 And panelex()\displayedPage <> 0
      ChangeCurrentElement(panelexpage(), panelex()\displayedPage)
      page = panelexpage()\Handle
    EndIf
    ChangeCurrentElement(panelex(), *thisPanelEx)
    ChangeCurrentElement(panelexpage(), *thisPage)
  EndIf
  UnlockMutex(panelMutex)

  
  If found <> 0
    
    CopyStructure(*rc, rc.RECT, RECT)
    width = rc\right-rc\left
    height = rc\bottom-rc\top
    If width > 0 And height > 0
      
      width + 2
      
      GetWindowOrgEx_(hdc, @p.POINT)
      rc\left - p\x
      rc\right - p\x
      rc\top - p\y
      rc\bottom - p\y
      rc\left-2
      If textImage = 0 Or ImageWidth(textImage) < width Or ImageHeight(textImage) < height
        If textImage <> 0
          FreeImage(textImage)
        EndIf
        textImage = CreateImage(#PB_Any, width, height, 32)
      EndIf
      textdc = StartDrawing(ImageOutput(textImage))
      DrawingMode(#PB_2DDrawing_AllChannels)
      trc.RECT
      trc\left+2
      trc\right = width
      trc\bottom = height
      Box(0, 0, width, height, RGBA(0,0,0,255))
      SetTextColor_(textdc, RGB(255,255,255))
      rendertext(textdc, txt, trc, thisFont, style|#DT_OVERRIDECOLOUR)
      StopDrawing()
      
      alphaTextWidth = rc\left+width
      alphaTextHeight = rc\top+height
      alphaTextRgn = CreateRectRgn_(rc\left,rc\top,rc\right,rc\bottom)
      GetClipRgn_(hdc, alphaTextRgn)
      
      StartDrawing(ImageOutput(found))
      DrawingMode(#PB_2DDrawing_AllChannels)
      CustomFilterCallback(@FilterCallback())
      DrawingMode(#PB_2DDrawing_CustomFilter)
      
      DrawImage(ImageID(textImage), rc\left, rc\top)
      
      StopDrawing()
      DeleteObject_(alphaTextRgn)
    EndIf
    
  EndIf
  
  
EndProcedure



Procedure.s renderText(hdc.i, txt.s, *rc.RECT, thisFont.i, style.l)
  Static inAlphaText
  
  ; used to limit text within window
  maxRight = *rc\right
  maxBottom = *rc\bottom
  
  If style & #RTXT_PROCESS_LINKS
    processLinks = #True
    ; clear hyperlink list
    ClearList(txtcontrol()\link())
  EndIf
  
  If style & #DT_CALCRECT
    calcRect = #True
  ElseIf style & #DT_OVERRIDECOLOUR
    overrideColour = #True
  EndIf
  
  
  If style & #TCX_TOP
    flags = #DT_TOP | #DT_SINGLELINE | #DT_LEFT | #DT_EXPANDTABS | #DT_NOCLIP
  ElseIf style & #TCX_CENTRE And style & #TCX_VCENTRE
    singleLineVCentre = #True
    singleLineCentre = #True
    flags = #DT_VCENTER | #DT_CENTER | #DT_SINGLELINE | #DT_LEFT | #DT_EXPANDTABS | #DT_NOCLIP
  Else
    singleLineVCentre = #True
    flags = #DT_VCENTER | #DT_SINGLELINE | #DT_LEFT | #DT_EXPANDTABS | #DT_NOCLIP
  EndIf
  
  If style & #TCX_END_ELLIPSIS
    flags = flags | #DT_END_ELLIPSIS
  EndIf
  
  If style & #TCX_PATH_ELLIPSIS
    flags = flags | #DT_PATH_ELLIPSIS
  EndIf
  
  If style & #TCX_DISABLE_ESCAPECODES
    disableEscapeCodes = #True
  EndIf
  
  If style & #RTXT_RETURNSTRING
    returnString = #True
    retstr.s = ""
  EndIf
  
  If thisFont = 0
    thisFont = GetCurrentObject_(hdc, #OBJ_FONT)
    oldFont = thisFont
  Else
    oldFont = SelectObject_(hdc, thisFont)
  EndIf
  
  GetObject_(thisFont, SizeOf(LOGFONT), @fontnfo.LOGFONT)
  
  thisColour = GetTextColor_(hdc)
  
  SetBkMode_(hdc, #TRANSPARENT)
  
  ; are there any escape codes in this txt
  If disableEscapeCodes = #False And FindString(txt, "\", 1) > 0
    
    l = GetTextFace_(hdc, 0, 0)
    CompilerIf #PB_Compiler_Unicode
      l = l*2
    CompilerEndIf
    *mem = AllocateMemory(l+2)
    GetTextFace_(hdc, l, *mem)
    fontName.s = PeekS(*mem)
    FreeMemory(*mem)
    
    met.TEXTMETRIC
    GetTextMetrics_(hdc, @met)
    
    ; check if multiple lines
    If FindString(txt, "\|", 1) > 0
      linePadding = renderTextLinePadding
    EndIf

    ; scan txt for control codes
    p = 1
    lp = 1
    Repeat
      p = FindString(txt, "\", p)
      
      ; find block of backspace escape codes first, e.g. a file path
      If p <> 0 And Mid(txt, p, 2) = "\\"
        p = p + 2
        blockFound = #True
        Continue
      EndIf
        
      ; other escape code found
      If p <> 0

        c.s = LCase(Mid(txt, p+1, 1))
        
        thisTxt.s = Mid(txt, lp, (p-lp))
        If blockFound = #True
          thisTxt = ReplaceString(thisTxt, "\\", "\") ; if block of backspace escape codes then make single
          blockFound = #False
        EndIf
        rec.RECT
        rec\left = 0
        rec\right = 0
        rec\top = 0
        rec\bottom = 0
        DrawText_(hdc, thisTxt, Len(thisTxt), @rec, #DT_EXPANDTABS|#DT_CALCRECT)
        thisWidth = rec\right
        If thisTxt = ""
          DrawText_(hdc, " ", 1, @rec, #DT_EXPANDTABS|#DT_CALCRECT)
        EndIf
        thisHeight = rec\bottom+linePadding
        
        ; not calculating rect then render
        If calcRect = 0
          rec\top = *rc\top+ypos
          rec\left = *rc\left+xpos
          rec\right = *rc\left+xpos+thisWidth
          If rec\right > maxRight ; limit inside width of window
            flags = flags &~ #DT_NOCLIP
            rec\right = maxRight
            If flags & #DT_END_ELLIPSIS And Len(thistxt) = 1
              thistxt = "..."
            EndIf
          EndIf
          If singleLineVCentre = #True
            rec\bottom = *rc\bottom
          Else
            rec\bottom = rec\top+rec\bottom
          EndIf
          If rec\bottom > maxBottom ; limit inside height of window
            flags = flags &~ #DT_NOCLIP
            rec\bottom = maxBottom
          EndIf
          
          DrawText_(hdc, thisTxt, Len(thisTxt), @rec, flags)
        EndIf
        
        If returnString = #True
          retstr.s = retstr + thisTxt
        EndIf
        
        If xpos+thisWidth > totalWidth
          totalWidth = xpos+thisWidth
        EndIf
        If ypos+thisHeight > totalHeight
          totalHeight = ypos+thisHeight
        EndIf
        xpos = xpos + thisWidth
        
        If c = "b"  ; bold
          
          SelectObject_(hdc, thisFont)
          DeleteObject_(font)
          If met\tmWeight = 700
            met\tmWeight = 400
          Else
            met\tmWeight = 700
          EndIf
          font = CreateFont_(met\tmHeight, met\tmAveCharWidth, 0, 0, met\tmWeight, met\tmItalic, met\tmUnderlined, met\tmStruckOut, met\tmCharSet, 0, 0, fontnfo\lfQuality, met\tmPitchAndFamily, @fontName)
          SelectObject_(hdc, font)
          lp = p+2
          
        ElseIf c = "u"  ; underline
          
          SelectObject_(hdc, thisFont)
          DeleteObject_(font)
          If met\tmUnderlined = #True
            met\tmUnderlined = #False
          Else
            met\tmUnderlined = #True
          EndIf
          font = CreateFont_(met\tmHeight, met\tmAveCharWidth, 0, 0, met\tmWeight, met\tmItalic, met\tmUnderlined, met\tmStruckOut, met\tmCharSet, 0, 0, fontnfo\lfQuality, met\tmPitchAndFamily, @fontName)
          SelectObject_(hdc, font)
          lp = p+2
          
        ElseIf c = "s"  ; strike out
          
          SelectObject_(hdc, thisFont)
          DeleteObject_(font)
          If met\tmStruckOut = #True
            met\tmStruckOut = #False
          Else
            met\tmStruckOut = #True
          EndIf
          font = CreateFont_(met\tmHeight, met\tmAveCharWidth, 0, 0, met\tmWeight, met\tmItalic, met\tmUnderlined, met\tmStruckOut, met\tmCharSet, 0, 0, fontnfo\lfQuality, met\tmPitchAndFamily, @fontName)
          SelectObject_(hdc, font)
          lp = p+2
          
        ElseIf c = "i"  ; italic
          
          SelectObject_(hdc, thisFont)
          DeleteObject_(font)
          If met\tmItalic = #True
            met\tmItalic = #False
          Else
            met\tmItalic = #True
          EndIf
          font = CreateFont_(met\tmHeight, met\tmAveCharWidth, 0, 0, met\tmWeight, met\tmItalic, met\tmUnderlined, met\tmStruckOut, met\tmCharSet, 0, 0, fontnfo\lfQuality, met\tmPitchAndFamily, @fontName)
          SelectObject_(hdc, font)
          lp = p+2
          
        ElseIf c = "n"
          
          SelectObject_(hdc, thisFont)
          DeleteObject_(font)
          met.TEXTMETRIC
          GetTextMetrics_(hdc, @met)
          SetTextColor_(hdc, thisColour)
          lp = p+2
          
        ElseIf c = "c"  ; colour
          
          hx.s = Mid(txt, p+2, 6)
          r = Val("$"+Mid(hx, 1, 2))
          g = Val("$"+Mid(hx, 3, 2))
          b = Val("$"+Mid(hx, 5, 2))
          If overrideColour = #False
            SetTextColor_(hdc, RGB(r,g,b))
          EndIf
          lp = p+8
          
        ElseIf c = "l"  ; hyperlink
          
          lp = p+2
          
          ; see if beggining of link
          If Asc(Mid(txt, lp, 1)) >= 48 And Asc(Mid(txt, lp, 1)) <= 57
            ; get id
            n = lp-1
            Repeat
              n = n + 1
            Until n > Len(txt) Or (Asc(Mid(txt, n, 1)) < 48 Or Asc(Mid(txt, n, 1)) > 57)
            linkID = Val(Mid(txt, lp, n-lp))
            lp = n
            
            linkpos = lp
            linkX = *rc\left+xpos
            linkY = *rc\top+ypos
            
          ; end of link
          Else
            
            thisTxt.s = Mid(txt, linkpos, (lp-2)-linkpos)
            rec.RECT
            rec\left = 0
            rec\right = 0
            rec\top = 0
            rec\bottom = 0
            
            ; remove any control codes from thisTxt
            thisTxt = RemoveString(thisTxt, "\u")
            thisTxt = RemoveString(thisTxt, "\b")
            thisTxt = RemoveString(thisTxt, "\i")
            thisTxt = RemoveString(thisTxt, "\s")
            thisTxt = RemoveString(thisTxt, "\n")
            thisTxt = ReplaceString(thisTxt, "\\", "\")
            Repeat
              tp = FindString(LCase(thisTxt), "\c", 1)
              If tp <> 0
                thisTxt = Mid(thisTxt, tp+8)
              EndIf
            Until tp = 0
            
            DrawText_(hdc, thisTxt, Len(thisTxt), @rec, #DT_EXPANDTABS|#DT_CALCRECT)
            
            If processLinks = #True ; only store the link location if processLinks is set to true
              AddElement(txtcontrol()\link())
              txtcontrol()\link()\id = linkID
              txtcontrol()\link()\rc\left = linkX
              txtcontrol()\link()\rc\top = linkY
              txtcontrol()\link()\rc\right = linkX+rec\right
              txtcontrol()\link()\rc\bottom = linkY+rec\bottom
            EndIf
            
            lp = p+2
          EndIf
          
          
        ElseIf c = "|"  ; new line
          
          lp = p+2
          
          xpos = 0
          ypos = ypos+thisHeight
          
        ElseIf c = "\"  ; detected double backslash escape code, display single backslash
          lp = p+1
          p = p + 1
        Else  ; no recognisable escape code, ignore backslash
          lp = p+1
        EndIf
        p = p + 1
      EndIf
    Until p = 0
    
    If lp > 0 And lp <= Len(txt)
      thisTxt.s = Mid(txt, lp)
      
      If blockFound = #True
        thisTxt = ReplaceString(thisTxt, "\\", "\") ; if block of backspace escape codes then make single
        blockFound = #False
      EndIf
      
      rec.RECT
      rec\left = 0
      rec\right = 0
      rec\top = 0
      rec\bottom = 0
      DrawText_(hdc, thisTxt, Len(thisTxt), @rec, #DT_EXPANDTABS|#DT_CALCRECT)
      thisWidth = rec\right
      If thisTxt = ""
        DrawText_(hdc, " ", 1, @rec, #DT_EXPANDTABS|#DT_CALCRECT)
      EndIf
      thisHeight = rec\bottom
      
      ; not calculating rect then render
      If calcRect = 0
        rec\top = *rc\top+ypos
        rec\left = *rc\left+xpos
        rec\right = *rc\left+xpos+thisWidth
        If rec\right > maxRight ; limit inside width of window
          flags = flags &~ #DT_NOCLIP
          rec\right = maxRight
          If flags & #DT_END_ELLIPSIS And Len(thistxt) = 1
            thistxt = "..."
          EndIf
        EndIf
        If singleLineVCentre = #True
          rec\bottom = *rc\bottom
        Else
          rec\bottom = rec\top+rec\bottom
        EndIf
        If rec\bottom > maxBottom ; limit inside height of window
          flags = flags &~ #DT_NOCLIP
          rec\bottom = maxBottom
        EndIf
        DrawText_(hdc, thisTxt, Len(thisTxt), @rec, flags)
      EndIf
      
      If returnString = #True
        retstr.s = retstr + thisTxt
      EndIf
      
    EndIf
    
    ; draw complete txt string without formating
  Else
    If calcRect = 0
      DrawText_(hdc, txt, Len(txt), *rc, flags)
      If returnString = #True
        retstr.s = txt
      EndIf
    Else
      DrawText_(hdc, txt, Len(txt), *rc, #DT_EXPANDTABS|#DT_CALCRECT)
      If returnString = #True
        retstr.s = txt
        ProcedureReturn retstr
      EndIf
      ProcedureReturn ""
    EndIf
  EndIf
  
  SelectObject_(hdc, oldFont)
  DeleteObject_(font)
  
  If lp <= Len(txt) ; don't add totalwidth if escape code on end of txt
    If xpos+thisWidth > totalWidth
      totalWidth = xpos+thisWidth
    EndIf
    If ypos+thisHeight > totalHeight
      totalHeight = ypos+thisHeight
    EndIf
  EndIf
  
  If calcRect = #True
    *rc\top = 0
    *rc\left = 0
    *rc\right = totalWidth
    *rc\bottom = totalHeight
  Else
    If inAlphaText = #False
      inAlphaText = #True
      alphaText(hdc, txt, *rc, thisFont, style) ; if in alpha panelex page then adds alpha channel data
      inAlphaText = #False
    EndIf
  EndIf
  
  If returnString = #True
    ProcedureReturn retstr.s
  EndIf
  
  ProcedureReturn ""
  
EndProcedure


Procedure resizeToolbar(toolbarID)
  
  ; loop through menuex items and resize accordingly
  ForEach menuex()
    If menuex()\singleMenu = 0 And menuex()\toolbarID = toolbarID
      
      ; change our current menuex font to the new menu font
      hdc = CreateCompatibleDC_(0)
      SelectObject_(hdc, currentMenuEXFont)
      
      ; get old height of toolbar
      oldheight = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)
      oldheight = (oldheight>>16)
      
      ; re-calc the toolbar button dimensions with the new font
      buttontxt.s = ""
      bufflen = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, 0)
      If bufflen > 0
        CompilerIf #PB_Compiler_Unicode
          bufflen = bufflen * 2
        CompilerEndIf
        *mem = AllocateMemory(bufflen+2)
        SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, *mem)
        buttontxt = PeekS(*mem, bufflen)
        FreeMemory(*mem)
      EndIf
      
      DrawText_(hdc, buttontxt, Len(buttontxt), @rec.RECT, #DT_SINGLELINE | #DT_CALCRECT)
      
      DeleteDC_(hdc)
      
      buttoni.TBBUTTONINFO
      buttoni\cbSize = SizeOf(TBBUTTONINFO)
      buttoni\dwMask = #TBIF_SIZE
      buttoni\cx = rec\right+#MENUEXPADX
      
      ; reset menu bar height if font too small
      If rec\bottom+#MENUEXPADY < #MENUEXMINHEIGHT
        rec\bottom = #MENUEXMINHEIGHT - #MENUEXPADY
      EndIf
      
      ; 2003 style
      If menuex()\style = 6
        buttoni\cx = buttoni\cx - 2
        rec\bottom = rec\bottom - 3
      ; 2007 style
      ElseIf menuex()\style = #UISTYLE_OFFICE2007
        buttoni\cx = buttoni\cx - 2
        rec\bottom = rec\bottom - 2
      EndIf
      
      SendMessage_(menuex()\toolbarID, #TB_SETBUTTONSIZE, 0, MakeLong(0, rec\bottom+#MENUEXPADY))
      SendMessage_(menuex()\toolbarID, #TB_SETBUTTONINFO, menuex()\buttonID, @buttoni)
      
      ; check if the toolbar is in a rebar
      ForEach rebarGadget()
        If GetParent_(menuex()\toolbarID) = rebarGadget()\Handle
          
          ; find bar that our toolbar is contained in
          max = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0,0)
          For n = 0 To max
            band.REBARBANDINFO
            band\cbSize = SizeOf(REBARBANDINFO)
            band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
            SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, n, @band)
            
            dwBtnSize = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)>>16
            If band\hwndChild = menuex()\toolbarID
              
              ; calc old height delta between toolbar and band
              hdelta = band\cyMinChild-oldheight
              
              ; set rebar band's new height
              band\fMask = #RBBIM_CHILDSIZE
              band\cyMinChild = dwBtnSize+hdelta
              SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, n, @band)
              
              Break
            EndIf
          Next
          
          Break
        EndIf
      Next
      
    EndIf
  Next
  
EndProcedure

Procedure GetScreenDPI(horiz.b=#False)
  ; Get screen dots per inch vertically (default) or horizontally
  Protected hdc, dpi
  hdc = GetDC_(0) ; Desktop device context
  If horiz
    dpi = GetDeviceCaps_(hdc, #LOGPIXELSX)
  Else
    dpi = GetDeviceCaps_(hdc, #LOGPIXELSY)
  EndIf
  ReleaseDC_(0, hdc)
  ProcedureReturn dpi
EndProcedure 

Procedure calcSidebarPadding(pntSize)
  
  If pntSize >= 10
    
    t.f = Round(pntSize/5, #PB_Round_Down)
    i = t-2
    t = t*5
    z = 10
    For n = t To pntSize-1
      z = z + 2
    Next
    
    ProcedureReturn (z+(i*8))
    
  EndIf
  
  ProcedureReturn 8
EndProcedure

ProcedureDLL LoadFontEx(Name.s, PointSize.l, Flags.i) ; loads a font and returns a handle to it
  
  macro_protectCommand()
  
  PointSize = -MulDiv_(PointSize, GetScreenDPI(), 72)
  
  If flags & #Font_Antialiased
    quality = #ANTIALIASED_QUALITY
    flags = flags &~ #ANTIALIASED_QUALITY
  ElseIf flags & #Font_NonAntialiased
    quality = #NONANTIALIASED_QUALITY
    flags = flags &~ #NONANTIALIASED_QUALITY
  ElseIf flags & #Font_Cleartype
    quality = #CLEARTYPE_QUALITY
    flags = flags &~ #CLEARTYPE_QUALITY
  ElseIf flags & #Font_Draft
    qaulity = #DRAFT_QUALITY
    flags = flags &~ #DRAFT_QUALITY
  EndIf
  
  If flags >= #FW_BOLD And flags <= #FW_BOLD+#Font_StrikeOut
    weight = #FW_BOLD
    flags = flags &~ #FW_BOLD
  EndIf
  
  If flags & #Font_Bold
    weight = #FW_BOLD
    flags = flags &~ #Font_Bold
  EndIf
  
  If flags & #Font_Italic
    italic = #True
    flags = flags &~ #Font_Italic
  EndIf
  
  If flags & #Font_Underline
    underline = #True
    flags = flags &~ #Font_Underline
  EndIf
  
  If flags & #Font_StrikeOut
    strikeout = #True
    flags = flags &~ #Font_StrikeOut
  EndIf
  
  If flags = 400
    flags = 0
  EndIf
  
  If flags & #PB_Font_Bold
    weight = #FW_BOLD
  EndIf
  If flags & #PB_Font_Italic
    italic = #True
  EndIf
  
  ProcedureReturn CreateFont_(PointSize, 0, 0, 0, weight, italic, underline, strikeout, #DEFAULT_CHARSET, #OUT_DEFAULT_PRECIS, #CLIP_DEFAULT_PRECIS, quality, #VARIABLE_PITCH, Name)
  
EndProcedure

ProcedureDLL FreeFontEx(Font.i) ; Removes a font from memory
  ProcedureReturn DeleteObject_(Font)
EndProcedure

ProcedureDLL SetWindowFont(Hwnd.i, Font.i)
  ProcedureReturn SendMessage_(Hwnd, #WM_SETFONT, Font, #True)
EndProcedure

ProcedureDLL GetFontSize(fontID.i)  ; returns the point size of a font
  
  macro_protectCommand()
  
  CompilerIf #LIBRARY = 1
    If IsFont(fontID)
      fontID = FontID(fontID)
    EndIf
  CompilerEndIf
  
  If GetObject_(fontID, SizeOf(LOGFONT), @fontnfo.LOGFONT) <> 0
    fheight = fontnfo\lfHeight
    fheight = fontnfo\lfHeight: If fheight<0: fheight = -fheight: EndIf
    fheight*72.0/GetScreenDPI()
    ProcedureReturn fheight
  EndIf
  
  ProcedureReturn #False
  
EndProcedure

ProcedureDLL.s GetFontName(fontID.i)  ; returns the face name of a font
  
  macro_protectCommand()
  
  ReturnString$ = GetFontNamep(fontID.i)
  
  ProcedureReturn ReturnString$
  
EndProcedure

Procedure.s GetFontNamep(fontID.i)  ; private returns the face name of a font
  
  CompilerIf #LIBRARY = 1
    If IsFont(fontID)
      fontID = FontID(fontID)
    EndIf
  CompilerEndIf
  
  If GetObject_(fontID, SizeOf(LOGFONT), @fontnfo.LOGFONT) <> 0
    ReturnString$ = PeekS(@fontnfo\lfFaceName)
    ProcedureReturn ReturnString$
  EndIf
  
  ReturnString$ = ""
  
  ProcedureReturn ReturnString$
  
EndProcedure

;--
;- Processing/Custom Draw of
;- MenuEx, ToolBarEx and Rebar
;--
Procedure menuExScroll(direction.i) ; 0 = down | 1 = up | 2 = bottom | 3 = top
  
  mnfo.MENUITEMINFO_Fixed
  mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)

  WindowID = menuScrollWindow
  
  speed = 3
  
  ; flick to top
  If direction = 3
    
    menuScrolling = #True
    
    SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
    
    count = GetMenuItemCount_(menuScrollHandle)-1
    
    ; clear all current items
    For n = 0 To count
      RemoveMenuItemEx(menuScrollHandle, 0, #True)
    Next
    
    ; populate menu with items from original
    menuScrollFillerHeight = 7
    InsertMenuItemEx(menuScrollHandle, 0, #MENUSCROLLDOWNID, "", 0, 0, 0, -1)
    InsertMenuItemEx(menuScrollHandle, 0, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
    menuScrollPos = 0
    Repeat
      mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
      If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      ImageList = itemex()\ImageList
      normal = itemex()\normal
      hot = itemex()\hot
      disabled = itemex()\disabled
      InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
      mnfo\fMask = #MIIM_STATE
      SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
      If normal <> 0
        itemex()\ImageList = ImageList_Duplicate_(ImageList)
        itemex()\normal = normal
        itemex()\hot = hot
        itemex()\disabled = disabled
      EndIf
      menuScrollPos = menuScrollPos + 1
    Until CalcMenuItemHeight(menuScrollHandle) > menuScrollHeight
    RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True)
    
    ; check if we need to increase filler
    height = CalcMenuItemHeight(menuScrollHandle)
    If height < menuScrollHeight
      
      menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
      RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
      InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
      
    ElseIf height > menuScrollHeight
      
      menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
      RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
      InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
    EndIf
    
    menuScrolling = #False
    
    SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
    RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_UPDATENOW)
    
    ProcedureReturn 0
    
  ; flick to bottom
  ElseIf direction = 2
    
    menuScrolling = #True
    
    SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
    
    count = GetMenuItemCount_(menuScrollHandle)-1
    
    ; clear all current items
    For n = 0 To count
      RemoveMenuItemEx(menuScrollHandle, 0, #True)
    Next
    
    ; populate menu with items from original
    menuScrollFillerHeight = 7
    InsertMenuItemEx(menuScrollHandle, 0, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
    InsertMenuItemEx(menuScrollHandle, 0, #MENUSCROLLUPID, "", 0, 0, 0, -2)
    menuScrollPos = GetMenuItemCount_(originalScrollMenu)-1
    pos = 0
    Repeat
      mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
      If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      ImageList = itemex()\ImageList
      normal = itemex()\normal
      hot = itemex()\hot
      disabled = itemex()\disabled
      InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-pos, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
      mnfo\fMask = #MIIM_STATE
      SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
      If normal <> 0
        itemex()\ImageList = ImageList_Duplicate_(ImageList)
        itemex()\normal = normal
        itemex()\hot = hot
        itemex()\disabled = disabled
      EndIf
      menuScrollPos = menuScrollPos - 1
      pos = pos + 1
    Until CalcMenuItemHeight(menuScrollHandle) > menuScrollHeight
    RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-(pos), #True)
    
    ; check if we need to increase or decrease filler
    height = CalcMenuItemHeight(menuScrollHandle)
    If height < menuScrollHeight
      
      menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
      RemoveMenuItemEx(menuScrollHandle, 1, #True)
      InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
      
    ElseIf height > menuScrollHeight
      
      menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
      RemoveMenuItemEx(menuScrollHandle, 1, #True)
      InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
    EndIf
    
    menuScrolling = #False
    
    SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
    RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_UPDATENOW)
    
    ProcedureReturn 0
  
  EndIf
  
  
  Repeat
  
  SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
  RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_UPDATENOW)
  

  SetCapture_(WindowID)
  
  menuScrolling = #True
  
  ;Delay(500)
  
  mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
  
  ;-/ scroll down
  If direction = 0
    
    ; have we just started scrolling down
    If GetMenuItemInfo_(menuScrollHandle, 0, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
    EndIf
    hdc = GetWindowDC_(WindowID)
    If itemex()\scroll = 0
      
      menuScrollPos = GetMenuItemCount_(menuScrollHandle)-2
      menuScrollEndPos = 1
      If GetMenuItemInfo_(menuScrollHandle, 0, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      
      height = measureMenuItemHeight(hdc, @itemex())-menuScrollFillerHeight
      
      SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
      
      ; add to top up button
      InsertMenuItemEx(menuScrollHandle, 0, #MENUSCROLLUPID, "", 0, 0, 0, -2)
      RemoveMenuItemEx(menuScrollHandle, 1, #True)
      
      menuScrolling = #False
      SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
      RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_NOERASE|#RDW_UPDATENOW)
      menuScrolling = #True
      
      s = -speed
      GetClientRect_(WindowID, @rc.RECT)
      rc\top = menuScrollButtonHeight+menuScrollFillerHeight-5
      rc\bottom = (rc\bottom - menuScrollButtonHeight)+5
      
      frames = height/speed
      For n = 0 To frames-1
        ScrollWindow_(WindowID, 0, s, rc, 0)
        Delay(10)
      Next
      
      SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
      
      ; remove filler from bottom and add to top
      RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
      InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
      
      ; if 2nd item to remove is separator then remove
      If GetMenuItemInfo_(menuScrollHandle, 2, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      If itemex()\text = ""
        separator = #True
        RemoveMenuItemEx(menuScrollHandle, 2, #True)
        menuScrollEndPos = menuScrollEndPos + 1
      EndIf
      
    Else
      
      If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      If itemex()\scroll = -3
        height = menuScrollButtonHeight-menuScrollFillerHeight
      Else
        height = menuScrollButtonHeight
      EndIf
      
      s = -speed
      GetClientRect_(WindowID, @rc.RECT)
      rc\top = menuScrollButtonHeight+menuScrollFillerHeight+1
      rc\bottom = (rc\bottom - menuScrollButtonHeight)+5
      ;frames.f = Round(height/speed, #PB_ROUND_DOWN)
      frames = height/speed
      For n = 0 To frames-1
        ScrollWindow_(WindowID, 0, s, rc, 0)
        Delay(10)
      Next
      
      menuScrollPos = menuScrollPos + 1
      
    EndIf
    ReleaseDC_(WindowID, hdc) 
    
    SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
    
    ; check if filler is at bottom and if so prepare for scroll down
    If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
    EndIf
    If itemex()\scroll = -3
      
      RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
      menuScrollFillerHeight = 7
      InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
      t = menuScrollPos
      menuScrollPos = menuScrollEndPos+1
      menuScrollEndPos = t-1

    Else
      ; remove filler
      If GetMenuItemInfo_(menuScrollHandle, 1, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      If itemex()\scroll = -3
        RemoveMenuItemEx(menuScrollHandle, 1, #True)
        menuScrollFillerHeight = 7
        InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
      EndIf
    EndIf
    
    
    ; if 1st item to remove is separator then remove
    If GetMenuItemInfo_(menuScrollHandle, 2, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
    EndIf
    If itemex()\text = ""
      separator = #True
      RemoveMenuItemEx(menuScrollHandle, 2, #True)
      menuScrollEndPos = menuScrollEndPos + 1
    EndIf
    
    RemoveMenuItemEx(menuScrollHandle, 2, #True)
    menuScrollEndPos = menuScrollEndPos + 1
    
    ; if 2nd item to remove is separator then remove
    If GetMenuItemInfo_(menuScrollHandle, 2, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
    EndIf
    If itemex()\text = ""
      separator = #True
      RemoveMenuItemEx(menuScrollHandle, 2, #True)
      menuScrollEndPos = menuScrollEndPos + 1
    EndIf
    
    If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
    EndIf
    ImageList = itemex()\ImageList
    normal = itemex()\normal
    hot = itemex()\hot
    disabled = itemex()\disabled
    InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
    mnfo\fMask = #MIIM_STATE
    SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
    If normal <> 0
      itemex()\ImageList = ImageList_Duplicate_(ImageList)
      itemex()\normal = normal
      itemex()\hot = hot
      itemex()\disabled = disabled
    EndIf
    
    
    height = CalcMenuItemHeight(menuScrollHandle)
    If height < menuScrollHeight
      menuScrollPos = menuScrollPos + 1
      mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
      If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      ImageList = itemex()\ImageList
      normal = itemex()\normal
      hot = itemex()\hot
      disabled = itemex()\disabled
      InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
      mnfo\fMask = #MIIM_STATE
      SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
      If normal <> 0
        itemex()\ImageList = ImageList_Duplicate_(ImageList)
        itemex()\normal = normal
        itemex()\hot = hot
        itemex()\disabled = disabled
      EndIf
      
      ; check if we need to increase filler
      height = CalcMenuItemHeight(menuScrollHandle)
      If height < menuScrollHeight
        menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
        RemoveMenuItemEx(menuScrollHandle, 1, #True)
        InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
      EndIf
    EndIf
    
    
    ; check if we need to decrease filler
    height = CalcMenuItemHeight(menuScrollHandle)
    If height > menuScrollHeight

      menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
      
      ; check height again and if still too big then remove previous item and increase filler
      ;height = CalcMenuItemHeight(menuScrollHandle)
      If menuScrollFillerHeight < 0
        menuScrollPos = menuScrollPos - 1
        RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
        menuScrollFillerHeight = 0
        height = CalcMenuItemHeight(menuScrollHandle)
        menuScrollFillerHeight = menuScrollHeight-height
      EndIf
      
      RemoveMenuItemEx(menuScrollHandle, 1, #True)
      InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
    EndIf
    
    
    ; check if we're near the end and if the last few items will fit in the filler+button space
    If menuScrollPos >= GetMenuItemCount_(originalScrollMenu)-4
      height = 0
      hdc = GetWindowDC_(WindowID)
      pos = menuScrollPos+1
      For n = pos To GetMenuItemCount_(originalScrollMenu)-1
        mnfo\fMask = #MIIM_DATA
        If GetMenuItemInfo_(originalScrollMenu, n, #True, @mnfo) <> 0
          ChangeCurrentElement(itemex(), mnfo\dwItemData)
          height = height + measureMenuItemHeight(hdc, @itemex())
        EndIf
      Next
      
      ; the end will fit
      If height <= menuScrollButtonHeight+menuScrollFillerHeight
        ; remove bottom button
        RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #True)
        For n = pos To GetMenuItemCount_(originalScrollMenu)-1
          mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
          If GetMenuItemInfo_(originalScrollMenu, n, #True, @mnfo) <> 0
            ChangeCurrentElement(itemex(), mnfo\dwItemData)
            ImageList = itemex()\ImageList
            normal = itemex()\normal
            hot = itemex()\hot
            disabled = itemex()\disabled
            InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle), mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
            mnfo\fMask = #MIIM_STATE
            SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
            If normal <> 0
              itemex()\ImageList = ImageList_Duplicate_(ImageList)
              itemex()\normal = normal
              itemex()\hot = hot
              itemex()\disabled = disabled
            EndIf
            
          EndIf
        Next
        
        ; check if we need to increase or decrease filler
        height = CalcMenuItemHeight(menuScrollHandle)
        If height < menuScrollHeight
          
          menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
          RemoveMenuItemEx(menuScrollHandle, 1, #True)
          InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
          
        ElseIf height > menuScrollHeight
          
          menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
          RemoveMenuItemEx(menuScrollHandle, 1, #True)
          InsertMenuItemEx(menuScrollHandle, 1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
        EndIf
        
        menuScrollEnd = #True
      EndIf
      ReleaseDC_(WindowID, hdc)
    EndIf
    
    menuScrolling = #False
    SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
    RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_UPDATENOW);|#RDW_ERASE)
    
    ;-/ scroll up  
  Else
    
    ; have we just started scrolling up and bottom button is missing
    If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
    EndIf
    hdc = GetWindowDC_(WindowID)
    If itemex()\scroll = 0
      
      menuScrollPos = (GetMenuItemCount_(originalScrollMenu)-1) - (GetMenuItemCount_(menuScrollHandle)-2)
      menuScrollEndPos = GetMenuItemCount_(originalScrollMenu)-2
      If GetMenuItemInfo_(menuScrollHandle, 0, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      
      height = measureMenuItemHeight(hdc, @itemex())-menuScrollFillerHeight
      
      SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
      
      ; add to bottom down button
      InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle), #MENUSCROLLDOWNID, "", 0, 0, 0, -1)
      RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
      
      menuScrolling = #False
      SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
      RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_NOERASE|#RDW_UPDATENOW)
      menuScrolling = #True
      
      s = speed
      GetClientRect_(WindowID, @rc.RECT)
      rc\top = menuScrollButtonHeight-5
      rc\bottom = (rc\bottom - menuScrollButtonHeight)-1
      
      frames = height/speed
      For n = 0 To frames-1
        ScrollWindow_(WindowID, 0, s, rc, 0)
        Delay(10)
      Next
      
      SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
      
      ; remove filler from top and add to bottom
      RemoveMenuItemEx(menuScrollHandle, 1, #True)
      menuScrollFillerHeight = 7
      InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
      
      ; if 2nd item to remove is separator then remove
      If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      If itemex()\text = ""
        separator = #True
        RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True)
        menuScrollEndPos = menuScrollEndPos - 1
      EndIf
      
    Else
      
      If GetMenuItemInfo_(menuScrollHandle, 1, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      If itemex()\scroll = -3
        height = menuScrollButtonHeight-menuScrollFillerHeight
      Else
        height = menuScrollButtonHeight
      EndIf
      
      s = speed
      GetClientRect_(WindowID, @rc.RECT)
      rc\top = menuScrollButtonHeight-5
      rc\bottom = (rc\bottom - menuScrollButtonHeight)-1
      frames = height/speed
      For n = 0 To frames-1
        ScrollWindow_(WindowID, 0, s, rc, 0)
        Delay(10)
      Next
      
      menuScrollPos = menuScrollPos - 1
      
    EndIf
    ReleaseDC_(WindowID, hdc) 
    
    SendMessage_(WindowID, #WM_SETREDRAW, #False, 0)
    
    ; check if filler is at top and if so prepare for scroll up
    If GetMenuItemInfo_(menuScrollHandle, 1, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
    EndIf
    If itemex()\scroll = -3
      
      RemoveMenuItemEx(menuScrollHandle, 1, #True)
      menuScrollFillerHeight = 7
      InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
      t = menuScrollPos
      menuScrollPos = menuScrollEndPos-1
      menuScrollEndPos = t+1
      
    Else
      ; remove filler
      If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      If itemex()\scroll = -3
        RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
        menuScrollFillerHeight = 7
        InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
      EndIf
    EndIf
    
    ; if 1st item to remove is separator then remove
    If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
    EndIf
    If itemex()\text = ""
      separator = #True
      RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True)
      menuScrollEndPos = menuScrollEndPos - 1
    EndIf
    
    RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True)
    menuScrollEndPos = menuScrollEndPos - 1
    
    ; if 2nd item to remove is separator then remove
    If GetMenuItemInfo_(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
    EndIf
    If itemex()\text = ""
      separator = #True
      RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-3, #True)
      menuScrollEndPos = menuScrollEndPos - 1
    EndIf
    
    If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
    EndIf
    ImageList = itemex()\ImageList
    normal = itemex()\normal
    hot = itemex()\hot
    disabled = itemex()\disabled
    InsertMenuItemEx(menuScrollHandle, 1, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
    mnfo\fMask = #MIIM_STATE
    SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
    If normal <> 0
      itemex()\ImageList = ImageList_Duplicate_(ImageList)
      itemex()\normal = normal
      itemex()\hot = hot
      itemex()\disabled = disabled
    EndIf
    
    
    height = CalcMenuItemHeight(menuScrollHandle)
    If height < menuScrollHeight
      menuScrollPos = menuScrollPos - 1
      mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
      If GetMenuItemInfo_(originalScrollMenu, menuScrollPos, #True, @mnfo) <> 0
        ChangeCurrentElement(itemex(), mnfo\dwItemData)
      EndIf
      ImageList = itemex()\ImageList
      normal = itemex()\normal
      hot = itemex()\hot
      disabled = itemex()\disabled
      InsertMenuItemEx(menuScrollHandle, 1, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
      mnfo\fMask = #MIIM_STATE
      SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
      If normal <> 0
        itemex()\ImageList = ImageList_Duplicate_(ImageList)
        itemex()\normal = normal
        itemex()\hot = hot
        itemex()\disabled = disabled
      EndIf
      
      ; check if we need to increase filler
      height = CalcMenuItemHeight(menuScrollHandle)
      If height < menuScrollHeight
        menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
        RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
        InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
      EndIf
    EndIf
    
    
    ; check if we need to decrease filler
    height = CalcMenuItemHeight(menuScrollHandle)
    If height > menuScrollHeight
      
      menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
      
      ; check height again and if still too big then remove previous item and increase filler
      ;height = CalcMenuItemHeight(menuScrollHandle)
      If menuScrollFillerHeight < 0
        menuScrollPos = menuScrollPos + 1
        RemoveMenuItemEx(menuScrollHandle, 1, #True)
        menuScrollFillerHeight = 0
        height = CalcMenuItemHeight(menuScrollHandle)
        menuScrollFillerHeight = menuScrollHeight-height
      EndIf
      
      RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
      InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
    EndIf
    
    
    ; check if we're near the top and if the last few items will fit in the filler+button space
    If menuScrollPos <= 3
      height = 0
      hdc = GetWindowDC_(WindowID)
      pos = menuScrollPos-1
      For n = pos To 0 Step -1
        mnfo\fMask = #MIIM_DATA
        If GetMenuItemInfo_(originalScrollMenu, n, #True, @mnfo) <> 0
          ChangeCurrentElement(itemex(), mnfo\dwItemData)
          height = height + measureMenuItemHeight(hdc, @itemex())
        EndIf
      Next
      
      ; top will fit
      If height <= menuScrollButtonHeight+menuScrollFillerHeight
        
        ; remove top button
        RemoveMenuItemEx(menuScrollHandle, 0, #True)
        For n = pos To 0 Step -1
          mnfo\fMask = #MIIM_DATA|#MIIM_SUBMENU|#MIIM_ID|#MIIM_STATE
          If GetMenuItemInfo_(originalScrollMenu, n, #True, @mnfo) <> 0
            ChangeCurrentElement(itemex(), mnfo\dwItemData)
            ImageList = itemex()\ImageList
            normal = itemex()\normal
            hot = itemex()\hot
            disabled = itemex()\disabled
            InsertMenuItemEx(menuScrollHandle, 0, mnfo\wID, itemex()\text, 0, 0, 0, mnfo\hSubMenu)
            mnfo\fMask = #MIIM_STATE
            SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
            If normal <> 0
              itemex()\ImageList = ImageList_Duplicate_(ImageList)
              itemex()\normal = normal
              itemex()\hot = hot
              itemex()\disabled = disabled
            EndIf
            
          EndIf
        Next
        
        ; check if we need to increase filler
        height = CalcMenuItemHeight(menuScrollHandle)
        If height < menuScrollHeight
        
          menuScrollFillerHeight = menuScrollFillerHeight + (menuScrollHeight-height)
          RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
          InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
          
        ElseIf height > menuScrollHeight
          
          menuScrollFillerHeight = menuScrollFillerHeight-(height-menuScrollHeight)
          RemoveMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-2, #True)
          InsertMenuItemEx(menuScrollHandle, GetMenuItemCount_(menuScrollHandle)-1, #MENUSCROLLFILLERID, "", 0, 0, 0, -3)
        EndIf
        
        menuScrollEnd = #True
      EndIf
      ReleaseDC_(WindowID, hdc)
    EndIf
    
    menuScrolling = #False
    SendMessage_(WindowID, #WM_SETREDRAW, #True, 0)
    RedrawWindow_(WindowID, 0, 0, #RDW_INVALIDATE|#RDW_INTERNALPAINT|#RDW_UPDATENOW);|#RDW_ERASE)
    
  EndIf
  
  menuScrolling = #False
  
  ReleaseCapture_()
  
  
  ;- scroll end
Until menuScrollActive = #False Or menuScrollEnd = #True

menuScrollThread = 0
menuScrollEnd = #False

EndProcedure

;- createScrollMenu macro
Macro createScrollMenu()
  
  menuex()\active = -1
  *realMenuEx = @menuex()
 
  originalScrollMenu = menuex()\popupid
  style = menuex()\style
  toolbarID = menuex()\toolbarID
  buttonID = menuex()\buttonID
  win = menuex()\WindowID
  
  menuScrollHandle = CreatePopupMenuEx(#ProGUI_Any, style)
  menuex()\toolbarID = toolbarID
  menuex()\buttonID = buttonID
  menuex()\WindowID = win
  
  count = GetMenuItemCount_(originalScrollMenu)
  mnfo.MENUITEMINFO_Fixed
  mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
  For n = 0 To count-1
    mnfo\fMask = #MIIM_DATA|#MIIM_ID|#MIIM_SUBMENU|#MIIM_STATE
    If GetMenuItemInfo_(originalScrollMenu, n, #True, @mnfo) <> 0
      ChangeCurrentElement(itemex(), mnfo\dwItemData)
      
      ; grab item height into menuScrollButtonHeight and set menusidebarpadding
      If itemHeight = 0 And itemex()\text <> ""
        hdc = CreateCompatibleDC_(0)
        menuScrollButtonHeight = measureMenuItemHeight(hdc, mnfo\dwItemData)
        GetObject_(currentMenuEXFont, SizeOf(LOGFONT), @fontnfo.LOGFONT)
        fheight = fontnfo\lfHeight
        fheight = fontnfo\lfHeight: If fheight<0: fheight = -fheight: EndIf
        fheight*72.0/GetScreenDPI()
        menuSideBarPadding = calcSidebarPadding(fheight)-2
        DeleteDC_(hdc)
      EndIf
      
      ImageList = itemex()\ImageList
      normal = itemex()\normal
      hot = itemex()\hot
      disabled = itemex()\disabled
      text.s = itemex()\text
      
      ; add hotkey
      p = FindString(itemex()\text, "&", 1)
      If p > 0
        h.s = Mid(itemex()\text, p+1, 1)
        AddElement(menuScrollHotKey())
        menuScrollHotKey()\hotkey = UCase(h)
        menuScrollHotKey()\id = mnfo\wID
      EndIf
      
      MenuItemEx(mnfo\wID, text, 0, 0, 0, mnfo\hSubMenu)
      mnfo\fMask = #MIIM_STATE
      SetMenuItemInfo_(menuScrollHandle, mnfo\wID, 0, @mnfo)
      If normal <> 0
        itemex()\ImageList = ImageList_Duplicate_(ImageList)
        itemex()\normal = normal
        itemex()\hot = hot
        itemex()\disabled = disabled
      EndIf
    Else
      Break
    EndIf
  Next
  
  ; remove items from menu until fits
  count = n
  Repeat
    n = GetMenuItemCount_(menuex()\popupid)-1
    RemoveMenuItemEx(menuScrollHandle, n, #True)
    height = CalcMenuItemHeight(menuex()\popupid)
    If rect\bottom+height+7+menuScrollButtonHeight < minfo\rcWork\bottom-2
      menuTitleVOffset = 0
      Break
    ElseIf (rect\top+vertoffset)-(height+7+menuScrollButtonHeight) > minfo\rcWork\top
      menuTitleVOffset = -1
      Break
    EndIf
  ForEver
  
  menuScrollFillerHeight = 7
  MenuItemEx(#MENUSCROLLFILLERID, "", 0, 0, 0, 0)
  itemex()\scroll = -3 ; filler
  MenuItemEx(#MENUSCROLLDOWNID, "", 0, 0, 0, 0)
  itemex()\scroll = -1 ; scroll down button
  
  
  menuScrollWidth = width-GetSystemMetrics_(#SM_CXMENUCHECK)
  menuScrollHeight = CalcMenuItemHeight(menuScrollHandle)
  height = menuScrollHeight
  
EndMacro

Structure menuErase
  Buffer.i
  hdc.i
  rc.RECT
  vrc.RECT
EndStructure

Procedure doMenuTrackBufferedErase(toolbar.i, *brc.RECT)
  Static menuErase.menuErase
  
  ; copy menu tracked area into buffer
  If toolbar > 0 Or toolbar < -2
    
    thisMenuEx = @menuex()
    thisItemEx = @itemex()
    
    ; calculate required buffer size to fit entire possible menu track area
    count = SendMessage_(toolbar, #TB_BUTTONCOUNT, 0, 0)-1
    For p = 0 To count
      SendMessage_(toolbar, #TB_GETITEMRECT, p, @rc.RECT)
      MapWindowPoints_(toolbar, 0, @rc, 2)
      SendMessage_(toolbar, #TB_GETBUTTON, p, @bnfo.TBBUTTON)
      If p = 0
        left = rc\left
        right = rc\right
        top = rc\top
        bottom = rc\bottom
      EndIf
      
      ForEach menuex()
        If menuex()\toolbarID = toolbar And menuex()\buttonID = bnfo\idCommand
          height = CalcMenuItemHeight(menuex()\popupid)
          width = CalcMenuItemWidth(menuex()\popupid)
          If rc\top-height < top
            top = rc\top-height
          EndIf
          If rc\bottom+height > bottom
            bottom = rc\bottom+height
          EndIf
          If rc\left+width > right
            right = rc\left+width
          EndIf
          Break
        EndIf
      Next
      
    Next
    
    width = right-left
    debuglog("width:"+Str(width))
    height = bottom-top
    
    dhwnd = GetDesktopWindow_()
    dhdc = GetDC_(dhwnd)
    ;dhdc = GetDC_(0)
    
    ; setup buffer if not already created
    If menuErase\hdc = 0
      menuErase\hdc = CreateCompatibleDC_(dhdc)
      menuErase\Buffer = CreateCompatibleBitmap_(dhdc, width, height)
      SelectObject_(menuErase\hdc, menuErase\Buffer)
      debuglog("create")
    Else
      ; check if the buffer needs to grow
      If width > menuErase\rc\right-menuErase\rc\left Or height > menuErase\rc\bottom-menuErase\rc\top
        DeleteObject_(menuErase\Buffer)
        menuErase\Buffer = CreateCompatibleBitmap_(dhdc, width, height)
        SelectObject_(menuErase\hdc, menuErase\Buffer)
        debuglog("bigger")
      EndIf
    EndIf
    
    ; copy menu tracked area of screen into buffer
    ;debuglog("copying screen area")
    menuEraseBufferInvalid = 0
    menuErase\rc\top = top
    menuErase\rc\bottom = bottom
    menuErase\rc\left = left
    menuErase\rc\right = right
    
    menuErase\vrc\top = 0
    menuErase\vrc\left = 0
    menuErase\vrc\bottom = 0
    menuErase\vrc\right = 0
    ;BitBlt_(menuErase\hdc, 0, 0, width, height, dhdc, left, top, #SRCCOPY)
    
    ReleaseDC_(dhwnd, dhdc)
    
    ChangeCurrentElement(itemex(), thisItemEx)
    ChangeCurrentElement(menuex(), thisMenuEx)
  
  ; do blit of buffer to screen using *brc coords
  ElseIf toolbar = 0
    If *brc <> 0
      
      ;*brc\top = *brc\top+1
      ;*brc\bottom = *brc\bottom+1
      dhdc = GetDC_(0)
      BitBlt_(dhdc, *brc\left, *brc\top, *brc\right-*brc\left, *brc\bottom-*brc\top, menuErase\hdc, *brc\left-menuErase\rc\left, *brc\top-menuErase\rc\top, #SRCCOPY)
      ReleaseDC_(0, dhdc)
      
    EndIf
  ; update buffer with area in *brc
  ElseIf toolbar = -1
    If *brc <> 0
      
      dhdc = GetDC_(0)
      
      If IntersectRect_(@nrec.RECT, *brc, menuErase\vrc) <> 0
        
        If *brc\left < menuErase\vrc\left Or *brc\right > menuErase\vrc\right Or *brc\top < menuErase\vrc\top Or *brc\bottom > menuErase\vrc\bottom ;EqualRect_(nrec, *brc) = 0
          
          If *brc\right > menuErase\vrc\right
            CopyRect_(@rc.RECT, *brc)
            rc\left = menuErase\vrc\right
            BitBlt_(menuErase\hdc, rc\left-menuErase\rc\left, rc\top-menuErase\rc\top, rc\right-rc\left, rc\bottom-rc\top, dhdc, rc\left, rc\top, #SRCCOPY)
          EndIf
          
          If *brc\left < menuErase\vrc\left
            CopyRect_(@rc.RECT, *brc)
            rc\right = menuErase\vrc\left
            BitBlt_(menuErase\hdc, rc\left-menuErase\rc\left, rc\top-menuErase\rc\top, rc\right-rc\left, rc\bottom-rc\top, dhdc, rc\left, rc\top, #SRCCOPY)
          EndIf
          
          If *brc\top < menuErase\vrc\top
            CopyRect_(@rc.RECT, *brc)
            rc\bottom = menuErase\vrc\top
            ;rc\left = menuErase\vrc\left
            ;rc\right = menuErase\vrc\right
            BitBlt_(menuErase\hdc, rc\left-menuErase\rc\left, rc\top-menuErase\rc\top, rc\right-rc\left, rc\bottom-rc\top, dhdc, rc\left, rc\top, #SRCCOPY)
          EndIf
          
          If *brc\bottom > menuErase\vrc\bottom
            CopyRect_(@rc.RECT, *brc)
            rc\top = menuErase\vrc\bottom
            ;rc\left = menuErase\vrc\left
            ;rc\right = menuErase\vrc\right
            BitBlt_(menuErase\hdc, rc\left-menuErase\rc\left, rc\top-menuErase\rc\top, rc\right-rc\left, rc\bottom-rc\top, dhdc, rc\left, rc\top, #SRCCOPY)
          EndIf
          
          CopyRect_(menuErase\vrc, *brc)
          
        EndIf
        
      Else
        CopyRect_(menuErase\vrc, *brc)
        BitBlt_(menuErase\hdc, *brc\left-menuErase\rc\left, *brc\top-menuErase\rc\top, *brc\right-*brc\left, *brc\bottom-*brc\top, dhdc, *brc\left, *brc\top, #SRCCOPY)
      EndIf
      
      
      ;BitBlt_(menuErase\hdc, *brc\left-menuErase\rc\left, *brc\top-menuErase\rc\top, *brc\right-*brc\left, *brc\bottom-*brc\top, dhdc, *brc\left, *brc\top, #SRCCOPY)
      
      ;BitBlt_(menuErase\hdc, 0, 0, *brc\left-menuErase\rc\left, menuErase\rc\bottom-menuErase\rc\top, dhdc, menuErase\rc\left, menuErase\rc\top, #SRCCOPY)
      ;debuglog(Str(*brc\right-menuErase\rc\left))
      ;BitBlt_(menuErase\hdc, *brc\right-menuErase\rc\left, 0, menuErase\rc\right-*brc\right, menuErase\rc\bottom-menuErase\rc\top, dhdc, *brc\right, menuErase\rc\top, #SRCCOPY)
      ;trc.RECT
      ;trc\left = *brc\right
      ;trc\right = menuErase\rc\right
      ;trc\top = 0
      ;trc\bottom = menuErase\rc\bottom
      ;FillRect_(dhdc, trc, CreateSolidBrush_(RGB(255,0,0)))
      ReleaseDC_(0, dhdc)
      
    EndIf
    
  ElseIf toolbar = -2
    If *brc <> 0
      dhdc = GetDC_(0)
      BitBlt_(menuErase\hdc, *brc\left-menuErase\rc\left, *brc\top-menuErase\rc\top, *brc\right-*brc\left, *brc\bottom-*brc\top, dhdc, *brc\left, *brc\top, #SRCCOPY)
      ReleaseDC_(0, dhdc)
    EndIf
  EndIf
  
  
EndProcedure

Structure enumInvalidate
  excludeHwnd.i
  found.l
  rec.RECT
EndStructure

Procedure enumInvalidateWinProc(hwnd, lParam)
  
  *enum.enumInvalidate = lParam
  
  If *enum\excludeHwnd = hwnd Or *enum\excludeHwnd = 0
    *enum\found = #True
  EndIf
  
  If *enum\excludeHwnd <> hwnd And *enum\found = #True And IsWindowVisible_(hwnd) <> 0
    GetWindowRect_(hwnd, @rc.RECT)
    If IntersectRect_(@urec.RECT, *enum\rec, rc) <> 0

      CopyRect_(@mrec.RECT, urec)
      MapWindowPoints_(0, hwnd, @mrec, 2)
      
      
      ; little hack to get rid of none erasure of edge of desktop when app maximised on next monitor
;       prc.RECT
;       prc\left = urec\right-4
;       prc\top = urec\top
;       prc\right = prc\left
;       prc\bottom = prc\top
;       hmonitor = MonitorFromRect_(@prc, #MONITOR_DEFAULTTONEAREST)
;       minfo.MONITORINFO
;       minfo\cbSize = SizeOf(MONITORINFO)
;       GetMonitorInfo_(hmonitor, @minfo)
;       If urec\right >= minfo\rcMonitor\right-4
;         mrec\right = mrec\right + 4
;       EndIf
      
      RedrawWindow_(hwnd, mrec, 0, #RDW_INVALIDATE|#RDW_FRAME|#RDW_ERASE|#RDW_ALLCHILDREN|#RDW_ERASENOW|#RDW_INTERNALPAINT|#RDW_UPDATENOW)
      
      If *enum\rec\left = urec\left And *enum\rec\right = urec\right And *enum\rec\top = urec\top And *enum\rec\bottom = urec\bottom
        ProcedureReturn 0
      EndIf
      
      SubtractRect_(@nrec.RECT, *enum\rec, urec)
      CopyRect_(*enum\rec, nrec)
      
    EndIf
  EndIf
  
  ProcedureReturn #True
EndProcedure

Procedure invalidateScrnRec(*rec.RECT, excludeHwnd)
  
  enum.enumInvalidate
  enum\excludeHwnd = excludeHwnd
  CopyRect_(@enum\rec, *rec)
  EnumWindows_(@enumInvalidateWinProc(), @enum)
  
EndProcedure

Procedure doMenuTrackErase(WindowID)
  
  If menuex()\active <> 0 And menuScrolling = #False And menuScrollActive = #False And lastMenuWidth <> 0
    GetWindowRect_(WindowID, @rec.RECT)
    
    If lastMenuX = rec\left And lastMenuY = rec\top
      ProcedureReturn 0
    EndIf
    
    rc.RECT
    rc\left = lastMenuX
    rc\right = lastMenuX+lastMenuWidth
    rc\top = lastMenuY
    rc\bottom = lastMenuY+lastMenuHeight
    If IntersectRect_(@nrec.RECT, rc, rec) = 0
      
      If lastMenuY < rec\top And lastMenuX < rec\left
        rc\bottom = rc\bottom-1
      ElseIf lastMenuY > rec\top And lastMenuX < rec\left
        rc\top = rc\top+1
      EndIf
      
      invalidateScrnRec(@rc, WindowID)
      lastMenuX = 0
      lastMenuY = 0
      lastMenuWidth = 0
      lastMenuHeight = 0
      ProcedureReturn 0
    EndIf
    
    
    If lastMenuX < rec\left
      
      rc.RECT
      rc\left = lastMenuX
      rc\right = rec\left
      rc\top = lastMenuY
      rc\bottom = lastMenuY+lastMenuHeight

      If menuEraseBufferInvalid = #True Or menuEraseBuffered = #False
        invalidateScrnRec(@rc, WindowID)
        If menuEraseBuffered = #True
          doMenuTrackBufferedErase(-2, @rc)
        EndIf
      Else
        doMenuTrackBufferedErase(0, @rc)
      EndIf
      
    EndIf
    
    If lastMenuX+lastMenuWidth > rec\right
      
      rc.RECT
      rc\left = rec\right
      rc\right = lastMenuX+lastMenuWidth
      rc\top = lastMenuY
      rc\bottom = lastMenuY+lastMenuHeight
      
      If menuEraseBufferInvalid = #True Or menuEraseBuffered = #False
        invalidateScrnRec(@rc, WindowID)
        If menuEraseBuffered = #True
          doMenuTrackBufferedErase(-2, @rc)
        EndIf
      Else
        doMenuTrackBufferedErase(0, @rc)
      EndIf

    EndIf
    
    If lastMenuY+lastMenuHeight > rec\bottom
      
      rc.RECT
      rc\left = lastMenuX
      rc\right = lastMenuX+lastMenuWidth
      rc\top = rec\bottom
      rc\bottom = lastMenuY+lastMenuHeight
      
      If menuEraseBufferInvalid = #True Or menuEraseBuffered = #False
        invalidateScrnRec(@rc, WindowID)
        If menuEraseBuffered = #True
          doMenuTrackBufferedErase(-2, @rc)
        EndIf
      Else
        doMenuTrackBufferedErase(0, @rc)
      EndIf
      
    EndIf
    
    If lastMenuY < rec\top
      
      rc.RECT
      rc\left = lastMenuX
      rc\right = lastMenuX+lastMenuWidth
      rc\top = lastMenuY
      rc\bottom = rec\top
      
      If menuEraseBufferInvalid = #True Or menuEraseBuffered = #False
        invalidateScrnRec(@rc, WindowID)
        If menuEraseBuffered = #True
          doMenuTrackBufferedErase(-2, @rc)
        EndIf
      Else
        doMenuTrackBufferedErase(0, @rc)
      EndIf
      
    EndIf
    
    lastMenuX = 0
    lastMenuY = 0
    lastMenuWidth = 0
    lastMenuHeight = 0
    
  EndIf
  
EndProcedure

Procedure eraseLastMenu()
  
  rc.RECT
  rc\left = lastMenuX
  rc\right = lastMenuX+lastMenuWidth
  rc\top = lastMenuY
  rc\bottom = lastMenuY+lastMenuHeight
  invalidateScrnRec(@rc, 0)
  
  lastMenuX = 0
  lastMenuY = 0
  lastMenuWidth = 0
  lastMenuHeight = 0
  
EndProcedure



Global redrawWait = 0
Procedure MyWindowCallback(WindowID,message,wParam,lParam)
  Static mouseCaptured
  ;/ *** stealth protection make the process become slowly unstable if HaltProGUI detected
  Static HaltElapsed
  If HaltProGUI = #True And HaltElapsed = 0
    HaltElapsed = ElapsedMilliseconds()
  EndIf
  If HaltElapsed > 0 And ElapsedMilliseconds() > HaltElapsed+60000 ; after minute
    If Random(500) = 0
      *mem = AllocateMemory(100)
      For n = 0 To Random(1000)
        PokeB(*mem+n, Random(255))
      Next
    EndIf
  EndIf
  ;/^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
  
  ; find old callback for window id
  ForEach menuCallback()
    If menuCallback()\WindowID = WindowID
      ProGUIOldCallBack = menuCallback()\oldCallback
      Result = CallWindowProc_(ProGUIOldCallBack,WindowID,message,wParam,lParam)
      Break
    EndIf
  Next
  
  
  ;debuglog("message: "+Hex(message))
  Select message
    

    ;Case #WM_PAINT
      
      ;ProcedureReturn 0
      
    ;Case #WM_ERASEBKGND
      
    ;  ProcedureReturn result
    ;  Result = 1
    
    
    ;/ handle styled combobox gadget in toolbarex states, i.e dropdown etc...
    Case #WM_COMMAND
      
      If HIWORD(wParam) = #CBN_DROPDOWN
        
        ; makesure combobox is in a toolbarEx
        If ListSize(toolbarExButton()) > 0
          *thistoolbarExButton = @toolbarExButton()
          found = 0
          ForEach toolbarExButton()
            If toolbarExButton()\gadget = lParam And toolbarExButton()\gadgetStyled <> 0
              
              toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState | #TOOLBAREXGADGET_DROPDOWN
              
              GetClientRect_(toolbarExButton()\gadget, @trc.RECT)
              MapWindowPoints_(toolbarExButton()\gadget, toolbarExButton()\toolbarExHandle, @trc, 2)
              RedrawWindow_(toolbarExButton()\toolbarExHandle, trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ALLCHILDREN)
              
              Break
            EndIf
          Next
          ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
        EndIf
        
      ElseIf HIWORD(wParam) = #CBN_CLOSEUP
        
        ; makesure combobox is in a toolbarEx
        If ListSize(toolbarExButton()) > 0
          *thistoolbarExButton = @toolbarExButton()
          found = 0
          ForEach toolbarExButton()
            If toolbarExButton()\gadget = lParam And toolbarExButton()\gadgetStyled <> 0
              
              toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState &~ #TOOLBAREXGADGET_DROPDOWN
              
              pt.POINT
              GetCursorPos_(@pt)
              hwnd = WindowFromPoint_(PeekQ(pt))
              If hwnd <> toolbarExButton()\gadget And GetParent_(hwnd) <> toolbarExButton()\gadget
                toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState &~ #TOOLBAREXGADGET_HOVER
              EndIf
              
              GetClientRect_(toolbarExButton()\gadget, @trc.RECT)
              MapWindowPoints_(toolbarExButton()\gadget, toolbarExButton()\toolbarExHandle, @trc, 2)
              RedrawWindow_(toolbarExButton()\toolbarExHandle, trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ALLCHILDREN)
              
              Break
            EndIf
          Next
          ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
        EndIf
        
;       ElseIf HIWORD(wParam) = #CBN_SETFOCUS
;         
;         ; makesure combobox is in a toolbarEx
;         If ListSize(toolbarExButton()) > 0
;           *thistoolbarExButton = @toolbarExButton()
;           found = 0
;           ForEach toolbarExButton()
;             If toolbarExButton()\gadget = lParam And toolbarExButton()\gadgetStyled <> 0
;               
;               toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState | #TOOLBAREXGADGET_FOCUS
;               
;               GetClientRect_(toolbarExButton()\gadget, @trc.RECT)
;               MapWindowPoints_(toolbarExButton()\gadget, toolbarExButton()\toolbarExHandle, @trc, 2)
;               RedrawWindow_(toolbarExButton()\toolbarExHandle, trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ALLCHILDREN)
;               
;               Break
;             EndIf
;           Next
;           ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
;         EndIf
;         
;       ElseIf HIWORD(wParam) = #CBN_KILLFOCUS
;         
;         ; makesure combobox is in a toolbarEx
;         If ListSize(toolbarExButton()) > 0
;           *thistoolbarExButton = @toolbarExButton()
;           found = 0
;           ForEach toolbarExButton()
;             If toolbarExButton()\gadget = lParam And toolbarExButton()\gadgetStyled <> 0
;               
;               toolbarExButton()\gadgetStyledState = toolbarExButton()\gadgetStyledState &~ #TOOLBAREXGADGET_FOCUS
;               
;               GetClientRect_(toolbarExButton()\gadget, @trc.RECT)
;               MapWindowPoints_(toolbarExButton()\gadget, toolbarExButton()\toolbarExHandle, @trc, 2)
;               RedrawWindow_(toolbarExButton()\toolbarExHandle, trc, 0, #RDW_UPDATENOW|#RDW_ERASE|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ALLCHILDREN)
;               
;               Break
;             EndIf
;           Next
;           ChangeCurrentElement(toolbarExButton(), *thistoolbarExButton)
;         EndIf
        
      EndIf
  
    ;/ detect if windows theme has changed
    Case #WM_THEMECHANGED
      
      If XPthemeActive <> 0
        
        CallFunctionFast(*CloseThemeData, hTheme)
        Window = GetForegroundWindow_()
        hTheme = *OpenThemeData(Window, "scrollbar")
        If hTheme <> 0
          XPthemeColour = CallFunctionFast(*GetThemeSysColor, hTheme, 2)
          SetDefaultGlobalSkinColourTheme(XPthemeColour)
        EndIf
        *tmem = AllocateMemory(255)
        CallFunction(XPthemeActive, "GetCurrentThemeName", *tmem, 100, 0, 0, 0, 0)
        name.s = PeekS(*tmem, -1, #PB_Unicode)
        FreeMemory(*tmem)
        If name <> ""
          ThemesEnabled = #True
        Else
          ThemesEnabled = 0
        EndIf
        
        If hTheme <> 0
          CallFunctionFast(*CloseThemeData, hThemeExplorerbar)
          CallFunctionFast(*CloseThemeData, hThemeRebar)
          CallFunctionFast(*CloseThemeData, hThemeTab)
          CallFunctionFast(*CloseThemeData, hThemeToolbar)
          CallFunctionFast(*CloseThemeData, hThemeMenu)
          CallFunctionFast(*CloseThemeData, hThemeButton)
        EndIf
        
        hThemeExplorerbar = *OpenThemeData(Window, "explorerbar")
        hThemeRebar = *OpenThemeData(Window, "rebar")
        hThemeTab = *OpenThemeData(Window, "tab")
        hThemeToolbar = *OpenThemeData(Window, "toolbar")
        hThemeMenu = *OpenThemeData(Window, "menu")
        hThemeButton = *OpenThemeData(Window, "button")
        
      Else
        ThemesEnabled = 0
        hTheme = 0
      EndIf
      
      If Dwmapi <> 0
        CallFunctionFast(*DwmIsCompositionEnabled, @CompositionEnabled)
      EndIf
      
      ; flush blitEx cache
      blitExFlush()
      
      ; flag cached menu buffer for re-draw
      LockMutex(menuMutex)
      ForEach menuex()
        menuex()\bufferWidth = 0
        menuex()\bufferHeight = 0
      Next
      UnlockMutex(menuMutex)
      
      ; re-render any styled rebar backgrounds with new theme
      RenderRebarBackgrounds(#True)
      
    ;/ detect desktop composition (Aero) state changed
    Case #WM_DWMCOMPOSITIONCHANGED
    
      If Dwmapi <> 0
        CallFunctionFast(*DwmIsCompositionEnabled, @CompositionEnabled)
      EndIf
    
    ;/ detect if menu window gains/looses focus
    Case #WM_ACTIVATE
      
      LockMutex(menuMutex)
      
      ;scan menues for window that matches this event
      temptoolbarid = -1
      ForEach menuex()
        
        If menuex()\WindowID = WindowID
          
          ; grey out menu title
          If PeekB(@wParam) = #WA_INACTIVE
            menuex()\greyed = -1
            
            ; destroy all title dropshadows if exists
            If ListSize(titleShadow()) > 0
              ForEach titleShadow()
                DestroyWindow_(titleShadow()\rightShadow)
                DestroyWindow_(titleShadow()\bottomShadow)
                DeleteElement(titleShadow())
              Next
            EndIf
            
          Else
            menuex()\greyed = 0
          EndIf
          
          If temptoolbarid <> menuex()\toolbarID
            RedrawWindow_(menuex()\toolbarID, 0, 0, 7)
            temptoolbarid = menuex()\toolbarID
          EndIf
          
        EndIf
        
      Next
      
      UnlockMutex(menuMutex)
      
      Result = 0
      
    Case #WM_SIZING

      resizing = -1
      
      ; hack to change toolbar to clip children while dragging, removes flickering of child gadgets
      If ListSize(toolbarEx()) > 0
        *thistoolbarEx = @toolbarEx()
        ForEach toolbarEx()
          If GetParent_(GetParent_(toolbarEx()\Handle)) = WindowID
            
            SetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE, GetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE) | #WS_CLIPCHILDREN)
            
          EndIf
        Next
        ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
      EndIf
      
    Case #WM_EXITSIZEMOVE
      
      ; hack to change toolbar to clip children while dragging, removes flickering of child gadgets
      If ListSize(toolbarEx()) > 0
        *thistoolbarEx = @toolbarEx()
        ForEach toolbarEx()
          If GetParent_(GetParent_(toolbarEx()\Handle)) = WindowID
            
            SetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE, GetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE) &~ #WS_CLIPCHILDREN)
            RedrawWindow_(toolbarEx()\Handle, 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
            
          EndIf
        Next
        ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
      EndIf
      
      resizing = 0
    
    Case #WM_SIZE

      If wParam = #SIZE_MAXIMIZED And resizeMaximized = 0
        resizeMaximized = -1
      ElseIf wParam <> #SIZE_MAXIMIZED And resizeMaximized <> 0
        resizeMaximized = 0
      EndIf
      
      ;/ resize any rebars
      ForEach rebarGadget()
        
        If rebarGadget()\WindowID = WindowID
          If rebarGadget()\dbtoggle = 0
            If rebarGadget()\doublebuffer = -1
              SetWindowLongPtr_(rebarGadget()\Handle, #GWL_EXSTYLE, #WS_EX_TOOLWINDOW|#WS_EX_COMPOSITED)
            EndIf
            rebarGadget()\dbtoggle = -1
          EndIf

          height = SendMessage_(rebarGadget()\Handle, #RB_GETBARHEIGHT, 0,0)
          
          SendMessage_(rebarGadget()\Handle, #WM_SETREDRAW, #False, 0)
          ;SetWindowPos_(rebarGadget()\Handle, 0, 0, 0, LOWORD(lParam), height, #SWP_NOMOVE|#SWP_NOOWNERZORDER|#SWP_NOACTIVATE|#SWP_NOREDRAW|#SWP_NOZORDER)
          MoveWindow_(rebargadget()\Handle, 0, 0, LOWORD(lParam), height, #False)
          updateRebar(WindowID)
          SendMessage_(rebarGadget()\Handle, #WM_SETREDRAW, #True, 0)
          
          *thisRebarGadget = @rebarGadget()
          ;GetUpdateRect_(rebarGadget()\Handle, @rc.RECT, 0)
          ;RedrawWindow_(rebarGadget()\Handle,rc,0,#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_ERASE|#RDW_ERASENOW|#RDW_UPDATENOW|#RDW_ALLCHILDREN)
          
          
          GetUpdateRect_(rebarGadget()\Handle, @rc.RECT, 0)
          ;GetClientRect_(rebarGadget()\Handle, @rc.RECT)
          rc\top = rc\top - 2       ; windows 7 rendering glitch fix
          rc\bottom = rc\bottom + 2 ; ^
          rgn = CreateRectRgnIndirect_(rc)
          rtype = GetUpdateRgn_(rebarGadget()\Handle, @rgn, 0)
          
          If resizing = -1
            RedrawWindow_(rebarGadget()\Handle,0,rgn,#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_ERASE|#RDW_ERASENOW|#RDW_UPDATENOW|#RDW_ALLCHILDREN)
          Else
            RedrawWindow_(rebarGadget()\Handle,0,0,#RDW_FRAME|#RDW_INVALIDATE|#RDW_ERASE|#RDW_ERASENOW|#RDW_UPDATENOW|#RDW_ALLCHILDREN)
          EndIf
          DeleteObject_(rgn)
          
          
          ;RedrawWindow_(rebarGadget()\Handle, 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_NOERASE|#RDW_UPDATENOW)
          ChangeCurrentElement(rebarGadget(), *thisRebarGadget)
          
          If rebarGadget()\doublebuffer = 0
            ForEach toolbarEx()
              
              ; handle #TBSTYLE_WRAPABLE toolbars in rebar when rebar resized and no SIZE_MINIMIZED/maximized etc
              If wParam = 0 And rebarGadget()\handle = GetParent_(toolbarEx()\handle)
                
                rows = SendMessage_(toolbarEx()\handle, #TB_GETROWS, 0, 0)
                If rows <> toolbarEx()\lastRowCount
                  
                  ; find band that our toolbar is contained in
                  max = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0,0)
                  For n = 0 To max
                    
                    band.REBARBANDINFO
                    band\cbSize = SizeOf(REBARBANDINFO)
                    band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
                    SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, n, @band)
                    If band\hwndChild = toolbarEx()\handle
                      
                      dwBtnSize = SendMessage_(toolbarEx()\handle, #TB_GETBUTTONSIZE, 0,0)>>16
                      pad = toolbarEx()\lastRowCount * dwBtnSize
                      
                      toolbarEx()\lastRowCount = rows

                      pad = band\cyMinChild-pad
                      
                      dwBtnSize = (dwBtnSize * rows)+pad
                      
                      ; set rebar band's new height
                      band\fMask = #RBBIM_CHILDSIZE
                      band\cyMinChild = dwBtnSize;+hdelta
                      SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, n, @band)
                      
                      
                      handle = rebarGadget()\Handle
                      *this = @rebarGadget()
                      height = RebarHeight(handle)
                      ChangeCurrentElement(rebarGadget(), *this)
                      
                      Break
                    EndIf
                      
                  Next

                EndIf
                
              EndIf
                
              
              If GetParent_(GetParent_(toolbarEx()\Handle)) = WindowID
                RedrawWindow_(toolbarEx()\Handle, 0, 0, #RDW_NOERASE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
              EndIf
              
            Next
          EndIf
          
        EndIf

      Next
      
      ;-/ resize any commandbars
      ForEach cmdbar()
        GetClientRect_(cmdbar()\Handle, @rc.RECT)
        
        If cmdbar()\style & #CMDBAR_LEFT
          SetWindowPos_(cmdbar()\Handle, 0, 0, 0, rc\right, HIWORD(lParam), #SWP_NOOWNERZORDER|#SWP_NOACTIVATE|#SWP_NOZORDER)
        ElseIf cmdbar()\style & #CMDBAR_RIGHT
          SetWindowPos_(cmdbar()\Handle, 0, LOWORD(lParam)-rc\right, 0, rc\right, HIWORD(lParam), #SWP_NOOWNERZORDER|#SWP_NOACTIVATE|#SWP_NOZORDER)
        ElseIf cmdbar()\style & #CMDBAR_BOTTOM
          SetWindowPos_(cmdbar()\Handle, 0, 0, HIWORD(lParam)-rc\bottom, LOWORD(lParam), rc\bottom, #SWP_NOOWNERZORDER|#SWP_NOACTIVATE|#SWP_NOZORDER)
        Else ; default top behaviour
          SetWindowPos_(cmdbar()\Handle, 0, 0, 0, LOWORD(lParam), rc\bottom, #SWP_NOOWNERZORDER|#SWP_NOACTIVATE|#SWP_NOZORDER)
        EndIf
      Next
      
      
      Result = 0
      
    ;Case #WM_EXITSIZEMOVE

      ; ForEach rebarGadget()
        ; If rebarGadget()\WindowID = WindowID
          ; If rebarGadget()\dbtoggle = -1
            ; If rebarGadget()\doublebuffer = -1
              ; SetWindowLongPtr_(rebarGadget()\Handle, #GWL_EXSTYLE, #WS_EX_TOOLWINDOW)
            ; EndIf
            ; rebarGadget()\dbtoggle = 0
          ; EndIf
          ; 
          ; ;RedrawWindow_(rebarGadget()\WindowID,0,0,#RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
          ; ;RedrawWindow_(rebarGadget()\Handle,0,0,#RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_NOERASE|#RDW_UPDATENOW)
          ; 
          ; debuglog("cool")
          ; GetUpdateRect_(rebarGadget()\Handle, @rc.RECT, #False)
          ; RedrawWindow_(rebarGadget()\Handle,0,0,#RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_FRAME|#RDW_UPDATENOW)
          ; 
          ; ;If resizing = -1
            ; ;SendMessage_(rebarGadget()\WindowID, #WM_SETREDRAW, #True, 0)
            ; ;MoveWindow_(rebarGadget()\WindowID, lastResizeRect\left, lastResizeRect\top, lastResizeRect\right-lastResizeRect\left, lastResizeRect\bottom-lastResizeRect\top, #True)
            ; resizing = 0
            ; ;lastResizeRect\top = 0
            ; ;lastResizeRect\left = 0
            ; ;lastResizeRect\right = 0
            ; ;lastResizeRect\bottom = 0
          ; ;EndIf
        ; EndIf
      ; Next
      
      ;/ detect if windows system settings changed
    Case #WM_SETTINGCHANGE
      
      ; detect if windows changes system menu font
      If wParam = #SPI_SETNONCLIENTMETRICS
        
        ; flush blitEx cache
        blitExFlush()
        
        LockMutex(menuMutex)
        
        ; flag cached menu buffer for re-draw
        ForEach menuex()
          menuex()\bufferWidth = 0
          menuex()\bufferHeight = 0
        Next
        
        ; loop through menuex items and resize accordingly
        ForEach menuex()
          If menuex()\singleMenu = 0
            
            ; change our current menuex font to the new menu font
            hdc = CreateCompatibleDC_(0)
            
            metrics.NONCLIENTMETRICS
            metrics\cbSize = SizeOf(NONCLIENTMETRICS)
            
            SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
            DeleteObject_(currentMenuEXFont)
            currentMenuEXFont = CreateFontIndirect_(metrics\lfMenuFont)
            SelectObject_(hdc, currentMenuEXFont)
            
            ; get old height of toolbar
            oldheight.l = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)
            oldheight = (oldheight>>16)
            
            ; re-calc the toolbar button dimensions with the new font
            buttontxt.s = ""
            bufflen = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, 0)
            If bufflen > 0
              CompilerIf #PB_Compiler_Unicode
                bufflen = bufflen * 2
              CompilerEndIf
              *mem = AllocateMemory(bufflen+2)
              SendMessage_(menuex()\toolbarID, #TB_GETBUTTONTEXT, menuex()\buttonID, *mem)
              buttontxt = PeekS(*mem, bufflen)
              FreeMemory(*mem)
            EndIf
            
            DrawText_(hdc, buttontxt, Len(buttontxt), @rec.RECT, #DT_SINGLELINE | #DT_CALCRECT)
            
            DeleteDC_(hdc)
            
            buttoni.TBBUTTONINFO
            buttoni\cbSize = SizeOf(TBBUTTONINFO)
            buttoni\dwMask = #TBIF_SIZE
            buttoni\cx = rec\right+#MENUEXPADX
            
            ; reset menu bar height if font too small
            If rec\bottom+#MENUEXPADY < #MENUEXMINHEIGHT
              rec\bottom = #MENUEXMINHEIGHT - #MENUEXPADY
            EndIf
            
            ; 2003 style
            If menuex()\style = 6
              buttoni\cx = buttoni\cx - 2
              rec\bottom = rec\bottom - 3
            ; 2007 style
            ElseIf menuex()\style = #UISTYLE_OFFICE2007
              buttoni\cx = buttoni\cx - 2
              rec\bottom = rec\bottom - 2
            EndIf
            
            SendMessage_(menuex()\toolbarID, #TB_SETBUTTONSIZE, 0, MakeLong(0, rec\bottom+#MENUEXPADY))
            SendMessage_(menuex()\toolbarID, #TB_SETBUTTONINFO, menuex()\buttonID, @buttoni)
            
            ; check if the toolbar is in a rebar
            ForEach rebarGadget()
              If GetParent_(menuex()\toolbarID) = rebarGadget()\Handle
                
                ; find bar that our toolbar is contained in
                max = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0,0)
                For n = 0 To max
                  band.REBARBANDINFO
                  band\cbSize = SizeOf(REBARBANDINFO)
                  band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
                  SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, n, @band)
                  
                  dwBtnSize = SendMessage_(menuex()\toolbarID, #TB_GETBUTTONSIZE, 0,0)>>16
                  If band\hwndChild = menuex()\toolbarID
                    
                    ; calc old height delta between toolbar and band
                    hdelta = band\cyMinChild-oldheight
                    
                    ; set rebar band's new height
                    band\fMask = #RBBIM_CHILDSIZE
                    band\cyMinChild = dwBtnSize+hdelta
                    SendMessage_(rebarGadget()\Handle, #RB_SETBANDINFO, n, @band)
                    
                    Break
                  EndIf
                Next
                
                Break
              EndIf
            Next
            
          EndIf
        Next
        
        UnlockMutex(menuMutex)
        
        Result = 0
      EndIf
      
      ; detect if system drop-shadows enabled status has been changed
      If wParam = #SPI_SETDROPSHADOW
        SystemParametersInfo_(#SPI_GETDROPSHADOW, 0, @systemDropShadowsEnabled, 0)  ; get system menu drop shadow status
      EndIf
    
    Case #WM_NOTIFY
      *nmhdr.NMHDR = lParam

      ;- toolbar tooltips
      If *nmhdr\code = #TTN_GETDISPINFOW Or *nmhdr\code = #TTN_GETDISPINFOA
        
        *tip.NMTTDISPINFO = lParam
        
        ForEach toolbartip()
          If toolbartip()\id = *tip\hdr\idFrom
            If #LIBRARY = 1 Or *nmhdr\code = #TTN_GETDISPINFOW
              *tip\lpszText = @toolbartip()\text
            ElseIf *nmhdr\code = #TTN_GETDISPINFOA
              If toolbartip()\asciiBuff <> 0
                FreeMemory(toolbartip()\asciiBuff)
              EndIf
              toolbartip()\asciiBuff = AllocateMemory(Len(toolbartip()\text)+1)
              PokeS(toolbartip()\asciiBuff, toolbartip()\text, Len(toolbartip()\text), #PB_Ascii)
              *tip\lpszText = toolbartip()\asciiBuff
            EndIf
            Break
          EndIf
        Next
        
      EndIf
      
      ;/ rebar child size
;       If *nmhdr\code = #RBN_CHILDSIZE
;         
;         *cs.NMREBARCHILDSIZE = lParam
;         
;         band.REBARBANDINFO
;         band\cbSize = SizeOf(REBARBANDINFO)
;         band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
;         SendMessage_(*cs\hdr\hwndFrom, #RB_GETBANDINFO, *cs\uBand, @band)
;         
;         ForEach toolbarEx()
;           If toolbarEx()\handle = band\hwndChild
;             
;             rows = SendMessage_(toolbarEx()\handle, #TB_GETROWS, 0, 0)
;             debuglog(Str(rows)+"  : "+Str(toolbarEx()\handle))
;             If rows <> toolbarEx()\lastRowCount
;               
;               dwBtnSize = SendMessage_(toolbarEx()\handle, #TB_GETBUTTONSIZE, 0,0)>>16
;               pad = toolbarEx()\lastRowCount * dwBtnSize
;               
;               toolbarEx()\lastRowCount = rows
;             
;               pad = band\cyMinChild-pad
;               ;debuglog(Str(pad))
;               
;               dwBtnSize = (dwBtnSize * rows)+pad
;               
;               ; set rebar band's new height
;               band\fMask = #RBBIM_CHILDSIZE
;               band\cyMinChild = dwBtnSize;+hdelta
;               SendMessage_(*cs\hdr\hwndFrom, #RB_SETBANDINFO, *cs\uBand, @band)
;               
;               ; send rebar update message to apps main window
;               root = GetAncestor_(*cs\hdr\hwndFrom, #GA_ROOT)
;               PostMessage_(root, #REBAR_UPDATED, RebarHeight(*cs\hdr\hwndFrom), *cs\hdr\hwndFrom)
;               root = GetAncestor_(*cs\hdr\hwndFrom, #GA_PARENT)
;               PostMessage_(root, #REBAR_UPDATED, RebarHeight(*cs\hdr\hwndFrom), *cs\hdr\hwndFrom)
;                   
;             EndIf
;             
;             Break
;           EndIf
;         Next
;         
;       EndIf
      
      ;-/ handle rebar layout change
      If *nmhdr\code = #RBN_LAYOUTCHANGED
        
        SendMessage_(*nmhdr\hwndFrom, #WM_SETREDRAW, #False, 0)
        updateRebar(WindowID)
        SendMessage_(*nmhdr\hwndFrom, #WM_SETREDRAW, #True, 0)
        
        ForEach rebarGadget()
          If rebarGadget()\WindowID = WindowID

            GetUpdateRect_(rebarGadget()\Handle, @rc.RECT, #False)
            RedrawWindow_(rebarGadget()\Handle,rc,0,#RDW_NOERASE|#RDW_UPDATENOW)
            
          EndIf
        Next
        
      EndIf
      
 
      
      ;-rebar drag
      If *nmhdr\code = #RBN_BEGINDRAG
        currentDragRebar = *nmhdr\hwndFrom
        *nmrebar.NMREBAR = lParam
        currentDragBandID = *nmrebar\wID
        currentDragBand = *nmrebar\uBand
        currentDragRebarParent = WindowID
        
        ForEach rebarGadget()
          If rebarGadget()\Handle = *nmhdr\hwndFrom
            currentDragRebarBuffered = rebarGadget()\doublebuffer
            Break
          EndIf
        Next
        
        threadId = GetWindowThreadProcessId_(*nmhdr\hwndFrom, 0)
        rebarHook = SetWindowsHookEx_(#WH_MOUSE, @rebarHook(), 0, threadId)
        
        ; hack to change toolbar to clip children while dragging, removes flickering of child gadgets
        If ListSize(toolbarEx()) > 0
          *thistoolbarEx = @toolbarEx()
          ForEach toolbarEx()
            If GetParent_(toolbarEx()\Handle) = *nmhdr\hwndFrom
              
              SetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE, GetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE) | #WS_CLIPCHILDREN)
              
            EndIf
          Next
          ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
        EndIf
        
        
      EndIf
      
      If *nmhdr\code = #RBN_ENDDRAG
        UnhookWindowsHookEx_(rebarHook)
        currentDragRebar = 0
        SetCursor_(normalMousePointer)
        
        ; hack to change toolbar back from clip children, stops fucked up windows7/vista button fade (fucking useless microsoft engineers)
        If ListSize(toolbarEx()) > 0
          *thistoolbarEx = @toolbarEx()
          ForEach toolbarEx()
            If GetParent_(toolbarEx()\Handle) = *nmhdr\hwndFrom
              
              SetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE, GetWindowLongPtr_(toolbarEx()\Handle, #GWL_EXSTYLE) &~ #WS_CLIPCHILDREN)
              RedrawWindow_(toolbarEx()\Handle, 0, 0, #RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
              
            EndIf
          Next
          ChangeCurrentElement(toolbarEx(), *thistoolbarEx)
        EndIf
        
      EndIf

      ;/ handle chevrons in the rebar
      If *nmhdr\code = #RBN_CHEVRONPUSHED
        
        If chevronState = 0
          *rebar.NMREBARCHEVRON = lParam
          
          binfo.REBARBANDINFO
          binfo\cbSize = SizeOf(REBARBANDINFO)
          binfo\fMask = #RBBIM_CHILD
          SendMessage_(*nmhdr\hwndFrom, #RB_GETRECT, *rebar\uBand,@rec.RECT)
          MapWindowPoints_(*nmhdr\hwndFrom, 0, @rec, 2)
          MapWindowPoints_(*nmhdr\hwndFrom, 0, @*rebar\rc, 2)
          
          chevronRECT\left = *rebar\rc\left
          chevronRECT\right = *rebar\rc\right
          chevronRECT\top = *rebar\rc\top
          chevronRECT\bottom = *rebar\rc\bottom
          
          SendMessage_(*nmhdr\hwndFrom, #RB_GETBANDINFO, *rebar\uBand, @binfo)
          buttoncount = SendMessage_(binfo\hwndChild, #TB_BUTTONCOUNT, 0, 0)
          ImageList = SendMessage_(binfo\hwndChild, #TB_GETIMAGELIST, 0, 0)
          
          menuToolbar = binfo\hwndChild
          
          LockMutex(menuMutex)
          
          ; see if this toolbar belongs to menuex
          found = 0
          ForEach menuex()
            If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\singleMenu = 0
              found = #True
              Break
            EndIf
          Next
          
          UnlockMutex(menuMutex)
          
          chevronPopup = CreatePopupMenuEx(#ProGUI_Any, 0)
          If chevronPopup <> 0
            
            ; scan through all buttons on toolbar
            For n = 0 To buttoncount-1
              SendMessage_(binfo\hwndChild, #TB_GETITEMRECT, n, @rec2.RECT)
              rec2\right = rec2\right + 21
              MapWindowPoints_(binfo\hwndChild, 0, @rec2, 2)
              ;IntersectRect_(@irec.RECT, @rec, @rec2)
              
              ;Debug EqualRect_(@rec2, @irec)
              If rec2\right > rec\right
                ;If EqualRect_(@rec2, @irec) = #False
                ;Debug "button "+Str(n)+" is hidden!"
                
                SendMessage_(binfo\hwndChild, #TB_GETBUTTON, n, @button.TBBUTTON)
                If button\fsStyle <> #BTNS_SEP
                  
                  buttontxt.s = ""
                  ;SendMessage_(binfo\hwndChild, #TB_GETBUTTONTEXT, button\idCommand, @buttontxt)
                  bufflen = SendMessage_(binfo\hwndChild, #TB_GETBUTTONTEXT, button\idCommand, 0)
                  If bufflen > 0
                    CompilerIf #PB_Compiler_Unicode
                      bufflen = bufflen * 2
                    CompilerEndIf
                    *mem = AllocateMemory(bufflen+2)
                    SendMessage_(binfo\hwndChild, #TB_GETBUTTONTEXT, button\idCommand, *mem)
                    buttontxt = PeekS(*mem, bufflen)
                    FreeMemory(*mem)
                  EndIf
                  
                  If button\iBitmap = #I_IMAGENONE
                    icon = 0
                    SetMenuExImageSize(16, 16)
                    If found = #True
                      ;icon = menuex()
                      info.MENUITEMINFO_Fixed
                      info\cbSize = SizeOf(MENUITEMINFO_Fixed)
                      info\fMask = #MIIM_DATA|#MIIM_STATE
                      If GetMenuItemInfo_(chevronPopup, n, #True, @info) = 0
                        ProcedureReturn #False
                      EndIf
                      LockMutex(menuMutex)
                      ChangeCurrentElement(itemex(), info\dwItemData)
                      icon = itemex()\normal
                      hot = itemex()\hot
                      disabled = itemex()\disabled
                      UnlockMutex(menuMutex)
                    EndIf
                  Else
                    If buttontxt = ""
                      buttontxt = " "
                    EndIf
                    icon = ImageList_GetIcon_(ImageList, n, #ILD_TRANSPARENT)
                    ImageList_GetIconSize_(ImageList, @width, @height)
                    SetMenuExImageSize(width, height)
                  EndIf
                  
                  ; if button is a dropdown then add its menu as submenu
                  If button\fsStyle & #BTNS_DROPDOWN Or button\fsStyle & #BTNS_WHOLEDROPDOWN
                    ;find menu for button
                    LockMutex(menuMutex)
                    ForEach menuex()
                      If menuex()\buttonID = button\idCommand
                        
                        submenu = menuex()\popupid
                        
                        Break
                      EndIf
                    Next
                    UnlockMutex(menuMutex)
                  EndIf
                  
                  MenuItemEx(button\idCommand, buttontxt, icon, hot, disabled, submenu)
                  If icon <> 0
                    DestroyIcon_(icon)
                  EndIf
                  submenu = 0
                  
                  ; if button is disabled then disable menu item
                  If button\fsState & #TBSTATE_ENABLED = #False
                    DisableMenuItemEx(chevronPopup, button\idCommand, 1)
                  EndIf
                  
                Else
                  MenuBarEx()
                EndIf
                
              EndIf
              
            Next
            
            threadId = GetWindowThreadProcessId_(binfo\hwndChild, 0)
            chevHook = SetWindowsHookEx_(#WH_MSGFILTER, @ChevronMsgHook(), 0, threadId)
            
            tpm.TPMPARAMS
            tpm\cbSize = SizeOf(TPMPARAMS)
            tpm\rcExclude\left = *rebar\rc\left
            tpm\rcExclude\right = *rebar\rc\right
            tpm\rcExclude\top = *rebar\rc\top
            tpm\rcExclude\bottom = *rebar\rc\bottom
            chevronState = 0
            
            ; find nearest display monitor to window
            hmonitor = MonitorFromRect_(*rebar\rc, #MONITOR_DEFAULTTONEAREST)
            minfo.MONITORINFO
            minfo\cbSize = SizeOf(MONITORINFO)
            GetMonitorInfo_(hmonitor, @minfo)
            
            If *rebar\rc\left < minfo\rcWork\left
              *rebar\rc\left = minfo\rcWork\left
            EndIf
            
            ; get menu dimensions
            width = CalcMenuItemWidth(chevronPopup)
            If *rebar\rc\left+width > minfo\rcWork\right
              *rebar\rc\left = minfo\rcWork\right
            EndIf
            
            ;TrackPopupMenuEx_(chevronPopup, #TPM_VERTICAL, *rebar\rc\left, *rebar\rc\bottom, *nmhdr\hwndFrom, @tpm)
            DisplayPopupMenuEx(chevronPopup, *nmhdr\hwndFrom, *rebar\rc\left, *rebar\rc\bottom)
            UnhookWindowsHookEx_(chevHook)
            
            ; detach any submenus we attached earlier
            items = GetMenuItemCount_(chevronPopup)
            If items <> -1
              For n = 0 To items-1
                submenu = GetSubMenu_(chevronPopup, n)
                If submenu <> 0
                  RemoveMenu_(chevronPopup, n, #MF_BYPOSITION)
                  n = n - 1
                EndIf
              Next
            EndIf
            
            FreeMenuEx(chevronPopup)
            
          EndIf
          
          
        Else
          chevronState = 0
        EndIf
      EndIf
      
      ;- menu code
      ;/ handle toolbar menu logic
      If *nmhdr\code = #TBN_DROPDOWN
        *nmTB.NMTOOLBAR = lParam
        menuToolbar = *nmhdr\hwndFrom
        
        LockMutex(menuMutex)

        ; search for a menu match and correct button
        found = 0
        ForEach menuex()
          If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\buttonID = *nmTB\iItem
            If menuex()\dropdownMenuex > 0
              
              dropdownMenuex = menuex()\dropdownMenuex
              ChangeCurrentElement(menuex(), dropdownMenuex)
              
            ElseIf menuex()\dropdownMenuex = -1 ; dropdown menu not initialised then exit
              Break
            EndIf
            
            found = -1
            Break
          EndIf
        Next
        

        ; a menu toolbar item has been selected
        If found = -1
          
          If menuItemOver <> -1
            menuItemOver = -1
            If menuOldFocus <> 0
              SetFocus_(menuOldFocus)
              menuOldFocus = 0
            EndIf
            menuActive = 0
            eraseLastMenu()
            SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
            GetUpdateRect_(menuToolbar, @rc.RECT, #False)
            UnlockMutex(menuMutex)
            RedrawWindow_(menuToolbar,rc,0,#RDW_ERASENOW|#RDW_UPDATENOW)
            ProcedureReturn #TBDDRET_DEFAULT
          EndIf

          If menuKeyboardActive <> #True And menuHotItemNext = -1
            menuOldFocus = GetFocus_()
          EndIf

          menuHotItem = SendMessage_(*nmhdr\hwndFrom, #TB_GETHOTITEM, 0, 0)

          menuWindow = 0
          menuHotItemNext = -1
          
          menuOriginItem = menuHotItem
          
          menuTitleOffset = 0
          menuTitleVOffset = 0
          
          subMenuActive = 0
          lastSubMenu = 0

          SendMessage_(*nmhdr\hwndFrom, #TB_GETRECT, *nmTB\iItem, @rect.RECT)
          If menuex()\singleMenu = 0
            menuTitleWidth = rect\right-rect\left ; set menuTitleWidth to width of toolbar button
            menuActive = -1 ; let our callwndproc know that this is a menubar
          Else  ; for drop down buttons
            
            If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2007
              menuTitleWidth = rect\right-rect\left
              rect\bottom = rect\bottom - 2
            EndIf
            If menuex()\style = 5
              menuTitleWidth = rect\right-rect\left+4
              rect\bottom = rect\bottom-1
            EndIf
            
            dropdownActive = #True
            
          EndIf
          menuTitleHeight = rect\bottom-rect\top
          
          MapWindowPoints_(*nmhdr\hwndFrom, 0, @rect, 2)
          menuTitleXpos = rect\left
          menuTitleYpos = rect\bottom
          
          If menuex()\singleMenu = 0
            threadId = GetWindowThreadProcessId_(*nmhdr\hwndFrom, 0)
            menuHook = SetWindowsHookEx_(#WH_MSGFILTER, @MsgHook(), 0, threadId)
          EndIf
          
          ; find nearest display monitor to window
          hmonitor = MonitorFromRect_(rect, #MONITOR_DEFAULTTONEAREST)
          minfo.MONITORINFO
          minfo\cbSize = SizeOf(MONITORINFO)
          GetMonitorInfo_(hmonitor, @minfo)
          
          If rect\left < minfo\rcWork\left
            menuTitleOffset = -(minfo\rcWork\left-rect\left)
            rect\left = minfo\rcWork\left
          EndIf
          

          ; position popupmenu further up if office style
          If menuex()\style = 5
            vertoffset = 1
          Else
            vertoffset = 0
          EndIf
          
          ; upsidedown offset for office2003 style
          If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003
            upsideDownOffset = 4
          ElseIf menuex()\style = #UISTYLE_WHIDBEY
            upsideDownOffset = 3
          Else
            upsideDownOffset = 0
          EndIf
          
          menuTitleVOffset = rect\bottom-(1+vertoffset)
          
          ;- get menu dimensions
          width = CalcMenuItemWidth(menuex()\popupid)
          menuWindowXpos = rect\left  ; store the predicted x pos of menu window for use with title dropshadow 
          If rect\left+width > minfo\rcWork\right
            If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003 Or menuex()\style = #UISTYLE_OFFICE2007
              menuTitleOffset = (rect\left+width)-minfo\rcWork\right+4
            Else
              menuTitleOffset = (rect\left+width)-minfo\rcWork\right+2
            EndIf
            menuWindowXpos = (minfo\rcWork\right-width)  ; store the predicted x pos of menu window for use with title dropshadow
          EndIf
          menuPositionOffset = 0
          If rect\left+width+5 > minfo\rcWork\right
            menuPositionOffset = (rect\left+width)-minfo\rcWork\right+6
            rect\left = (minfo\rcWork\right-width)-5
          EndIf
          height = CalcMenuItemHeight(menuex()\popupid)
          If rect\bottom+height >= minfo\rcWork\bottom+vertoffset-1
            menuTitleVOffset = -1
          EndIf
          
          ; detect if menu too large to fit on screen, create scroll menu if so
          If menuTitleVOffset = -1 And (rect\top+1+vertoffset)-height < minfo\rcWork\top
            createScrollMenu()
          EndIf
          
          ; menu won't fit bellow but will fit above then make sure track popup displays above title
          If menuTitleVOffset = -1
            rect\bottom = (rect\top-height)+2+vertoffset
            If menuex()\style < 5
              rect\bottom = rect\bottom - 1
            EndIf
            
            ; drop-down and 2003/2007 style move down extra pixels so aligns properly
            If menuex()\singleMenu <> 0
              If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003
                rect\bottom = rect\bottom + 2
              ElseIf menuex()\style = #UISTYLE_OFFICE2007
                rect\bottom = rect\bottom + 2
              EndIf
            EndIf
            
          EndIf

          menuWindowWidth = width
          menuex()\measuredWidth = width
          menuex()\measuredHeight = height
          
          menuex()\active = -1
          menuex()\root = #True
          
          thisMenuEx = @menuex()
          SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
          SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
          GetUpdateRect_(menuToolbar, @rc.RECT, #False)
          UnlockMutex(menuMutex)
          RedrawWindow_(menuToolbar,rc,0,#RDW_ERASENOW|#RDW_UPDATENOW)
          
          ; need this with scroll menu due to TB_SETHOTITEM changing menuex
          LockMutex(menuMutex)
          ChangeCurrentElement(menuex(), thisMenuEx)
           
          menuHandle = menuex()\popupid
          menuExHandle = @menuex()
          
          If menuKeyboardActive = #True
            keybd_event_(#VK_DOWN, 0, 0, 0)
          EndIf
          
          ; detect whether slide animation effect is enabled on system and disable animation if so
          SystemParametersInfo_(#SPI_GETMENUFADE, 0, @fade.l, 0)
          If fade = #False
            noAnimation = #TPM_NOANIMATION
          EndIf
          
          If CompositionEnabled = #False And menuEraseBuffered = #True
            doMenuTrackBufferedErase(menuToolbar, 0)
          EndIf
          
          ; save toolbarex's menu held colour
          If dropdownActive = #True
            ForEach toolbarEx()
              If toolbarEx()\handle = menuToolbar
                Break
              EndIf
            Next
            
            dropdownHeldColour = getMenuColourEx(toolbarEx()\UIStyle, #menuHeldBorder, 0)
            
          EndIf
          
          popupid = menuex()\popupid
          
          UnlockMutex(menuMutex)
          TrackPopupMenuEx_(popupid, #TPM_VERTICAL|noAnimation, rect\left, rect\bottom-(1+vertoffset), *nmhdr\hwndFrom, 0)
          LockMutex(menuMutex)
          ChangeCurrentElement(menuex(), thisMenuEx)
          
          menuHandle = 0
          menuex()\active = 0
          menuActive = 0
          dropdownActive = 0
          menuDraw = 0
          menuex()\root = #False
          
          
          ; if the tracked menu was a scroll menu then free up
          If menuScrollHandle <> 0
            ; If menuScrollThread <> 0
              ; SendMessage_(menuScrollHandle, #WM_SETREDRAW, #True, 0)
              ; KillThread(menuScrollThread)
              ; menuScrollThread = 0
            ; EndIf
            menuex()\toolbarID = -1
            FreeMenuEx(menuScrollHandle)
            menuDraw = 0
            ChangeCurrentElement(menuex(), *realMenuEx)
            menuex()\active = 0
            menuScrollHandle = 0
            menuScrollWindow = 0
            menuScrolling = 0
            menuScrollActive = 0
            ClearList(menuScrollHotKey())
          EndIf
          
          If menuex()\singleMenu = 0
            UnhookWindowsHookEx_(menuHook)
            
            ; deselect the menu toolbar button
            If menuHotItemNext = -1 And menuKeyboardActive <> -2
              
              SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
              menuItemOver = -1
              menuKeyboardActive = #False
              If menuOldFocus <> 0
                SetFocus_(menuOldFocus)
                menuOldFocus = 0
              EndIf
              eraseLastMenu()
              SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
              GetUpdateRect_(menuToolbar, @rc.RECT, #False)
              UnlockMutex(menuMutex)
              RedrawWindow_(menuToolbar,rc,0,#RDW_NOERASE|#RDW_UPDATENOW)
              LockMutex(menuMutex)
              ChangeCurrentElement(menuex(), thisMenuEx)
            EndIf
            
            ; this code solves bug with clicking on same selected menu title when key nav by alt or f10, disables re-activation of dropdown next time round
            If altActivated = -2
              menuItemOver = -2
              altActivated = #False
            EndIf
            
          Else
            
            eraseLastMenu()
            
          EndIf
          
          If menuKeyboardActive = -2
            menuKeyboardActive = #True
          EndIf
          
          Result = #TBDDRET_DEFAULT
        EndIf
        
        UnlockMutex(menuMutex)
      EndIf
      
      If *nmhdr\code = #TBN_HOTITEMCHANGE
        *nmTB.NMTOOLBAR = lParam
        *nmTBHot.NMTBHOTITEM = lParam
        
        
        If menuHotItemNext <> -1
          
          ;debuglog(Str(*nmTBHot\idNew))
          
          LockMutex(menuMutex)
          
          found = 0
          ForEach menuex()
            If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\singleMenu = 0
              found2 = -1
            EndIf
            
            If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\singleMenu = 0 And menuex()\buttonID = *nmTBHot\idNew
              menuHotItem = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBHot\idNew, 0)
              menuHotItemNext = -1
              found = -1
              Break
            EndIf
          Next
          
          ; if goes off button before it registers
          If *nmTBHot\idNew = 0 Or found2 = 0
            ;debuglog("ok")
            SendMessage_(menuToolbar, #TB_SETHOTITEM, menuHotItemNext, 0)
            UnlockMutex(menuMutex)
            ProcedureReturn #TBDDRET_DEFAULT
          EndIf
          
          
          If found = -1
            
            menuWindow = 0
            menuTitleOffset = 0
            menuTitleVOffset = 0
            
            subMenuActive = 0
            lastSubMenu = 0
            
            SendMessage_(*nmhdr\hwndFrom, #TB_GETRECT, menuex()\buttonID, @rect.RECT)
            menuTitleWidth = rect\right-rect\left
            menuTitleHeight = rect\bottom-rect\top
            
            MapWindowPoints_(*nmhdr\hwndFrom, 0, @rect, 2)
            menuTitleXpos = rect\left
            
            threadId = GetWindowThreadProcessId_(*nmhdr\hwndFrom, 0)
            menuHook = SetWindowsHookEx_(#WH_MSGFILTER, @MsgHook(), 0, threadId)
            
            ; find nearest display monitor to window
            hmonitor = MonitorFromRect_(rect, #MONITOR_DEFAULTTONEAREST)
            minfo.MONITORINFO
            minfo\cbSize = SizeOf(MONITORINFO)
            GetMonitorInfo_(hmonitor, @minfo)
            
            If rect\left < minfo\rcWork\left
              menuTitleOffset = -(minfo\rcWork\left-rect\left)
              rect\left = minfo\rcWork\left
            EndIf
            
            ; position popupmenu further up if office style
            If menuex()\style = 5
              vertoffset = 1
            Else
              vertoffset = 0
            EndIf
            
            ; upsidedown offset for office2003 style
            If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003
              upsideDownOffset = 4
            ElseIf menuex()\style = #UISTYLE_WHIDBEY
              upsideDownOffset = 3
            Else
              upsideDownOffset = 0
            EndIf
            
            
            ; get menu dimensions
            width = CalcMenuItemWidth(menuex()\popupid)
            menuWindowXpos = rect\left  ; store the predicted x pos of menu window for use with title dropshadow 
            If rect\left+width > minfo\rcWork\right
              If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003 Or menuex()\style = #UISTYLE_OFFICE2007
                menuTitleOffset = (rect\left+width)-minfo\rcWork\right+4
              Else
                menuTitleOffset = (rect\left+width)-minfo\rcWork\right+2
              EndIf
              menuWindowXpos = (minfo\rcWork\right-width)  ; store the predicted x pos of menu window for use with title dropshadow
            EndIf
            menuPositionOffset = 0
            If rect\left+width+5 > minfo\rcWork\right
              menuPositionOffset = (rect\left+width)-minfo\rcWork\right+6
              rect\left = (minfo\rcWork\right-width)-5
            EndIf
            
            height = CalcMenuItemHeight(menuex()\popupid)
            If rect\bottom+height >= minfo\rcWork\bottom+vertoffset-1
              menuTitleVOffset = -1
            EndIf
            
            ; detect if menu too large to fit on screen, create scroll menu if so
            If menuTitleVOffset = -1 And (rect\top+1+vertoffset)-height < minfo\rcWork\top
              createScrollMenu()
            EndIf
            
            ; menu won't fit bellow but will fit above then make sure track popup displays above title
            If menuTitleVOffset = -1
              rect\bottom = (rect\top-height)+2+vertoffset
              If menuex()\style < 5
                rect\bottom = rect\bottom - 1
              EndIf
            EndIf
            
            
            menuWindowWidth = width
            menuex()\measuredWidth = width
            menuex()\measuredHeight = height
            
            menuex()\active = -1
            menuex()\root = #True
            menuActive = -1
            menuHandle = menuex()\popupid
            menuExHandle = @menuex()
            tbButtonChange = #True
            
            
            *thisMenuEx = @menuex()
            popupid = menuex()\popupid
            UnlockMutex(menuMutex)
            TrackPopupMenuEx_(popupid, #TPM_VERTICAL|#TPM_NOANIMATION, rect\left, rect\bottom-(1+vertoffset), *nmhdr\hwndFrom, 0)
            LockMutex(menuMutex)
            ChangeCurrentElement(menuex(), *thisMenuEx)
            menuHandle = 0
            menuex()\active = 0
            menuActive = 0
            menuDraw = 0
            UnhookWindowsHookEx_(menuHook)
            
            menuex()\root = #False
            
            tbButtonChange = #False
            
            ; if the tracked menu was a scroll menu then free up
            If menuScrollHandle <> 0
              ; If menuScrollThread <> 0
                ; SendMessage_(menuScrollHandle, #WM_SETREDRAW, #True, 0)
                ; KillThread(menuScrollThread)
                ; menuScrollThread = 0
              ; EndIf
              menuex()\toolbarID = -1
              FreeMenuEx(menuScrollHandle)
              menuDraw = 0
              ChangeCurrentElement(menuex(), *realMenuEx)
              menuex()\active = 0
              menuScrollHandle = 0
              menuScrollWindow = 0
              menuScrolling = 0
              menuScrollActive = 0
              ClearList(menuScrollHotKey())
            EndIf
            
            ; menu hot tracking finnished
            If menuItemOver = -1 And menuHotItemNext = -1
              
              eraseLastMenu()
              SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
              SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
              GetUpdateRect_(menuToolbar, @rc.RECT, #False)
              UnlockMutex(menuMutex)
              RedrawWindow_(menuToolbar,rc,0,#RDW_NOERASE|#RDW_UPDATENOW)
              ProcedureReturn #TBDDRET_TREATPRESSED
              
            EndIf
            
          EndIf
          
          UnlockMutex(menuMutex)
          
        EndIf

        Result = #TBDDRET_DEFAULT
      EndIf  
      
      
      ;-/handle custom draw of menu titles, rebars and toolbars
      If *nmhdr\code = #NM_CUSTOMDRAW
        
        *custTB.NMTBCUSTOMDRAW = lParam
        *nmTBCust.NMCUSTOMDRAW = *custTB\nmcd
   
        
        ;/ handle custom draw of rebar and toolbar UI styles
        ; check if ownerdraw msg is for rebar or toolbar and if rebar/containing rebar has extended UI style
        foundbar = 0
        foundToolBarEx = 0
        ForEach toolbarEx()
          If toolbarEx()\Handle = *nmhdr\hwndFrom
            parent = GetParent_(*nmhdr\hwndFrom)
            ForEach rebarGadget()
              If rebarGadget()\Handle = parent And rebarGadget()\UIStyle <> 0
                foundbar = rebarGadget()\UIStyle
                Break
              EndIf
            Next
            Result = #CDRF_NOTIFYITEMDRAW
            foundToolBarEx = #True
            Break
          EndIf
        Next
        
        If foundbar = 0
          ForEach rebarGadget()
            If rebarGadget()\Handle = *nmhdr\hwndFrom And rebarGadget()\UIStyle <> 0
              foundbar = rebarGadget()\UIStyle
              Result = #CDRF_NOTIFYITEMDRAW
              Break
            EndIf
          Next
        EndIf
        
       ;FillRect_(*nmTBCust\hdc, *nmTBCust\rc, CreateSolidBrush_(RGB(Random(255),0,0)))
        If *nmTBCust\dwDrawStage = #CDDS_PREPAINT

          If foundbar = #UISTYLE_OFFICE2003 Or foundbar = #UISTYLE_OFFICE2007
            
            
            
            ; is this a menu toolbar item
            LockMutex(menuMutex)
            found = 0
            ForEach menuex()
              If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\singleMenu = 0
                found = -1
                Break
              EndIf
            Next
            UnlockMutex(menuMutex)
            
            ; find largest desktop width if not already found
            If LargestDesktopWidth = 0
              desktops = ExamineDesktops()
              For n = 0 To desktops
                width = DesktopWidth(n)
                If LargestDesktopWidth < width
                  LargestDesktopWidth = width
                EndIf
              Next
            EndIf

            If InitGDIPlus() <> 0
             
              If foundToolBarEx = #True And toolbarEx()\Handle = *nmhdr\hwndFrom And found = 0
                ;- draw toolstrip background
                If toolbarEx()\UIStyle = #UISTYLE_OFFICE2003 Or toolbarEx()\UIStyle = #UISTYLE_OFFICE2007
                  
                  ; get width of toolbar
                  SendMessage_(toolbarEx()\Handle, #TB_GETMAXSIZE, 0, @sz.SIZE)
                  right = sz\cx
                  height = sz\cy
                  
                  ; add 2 pixels on to width of toolstrip for default rounded end
                  right = right + 2
                  
                  ; if band width is less than right then set right to band width
                  If *nmTBCust\rc\right < right
                    right = *nmTBCust\rc\right
                  EndIf
                  
                  ;/ draw toolstrip
                  ; get top round corner pixels
                  topleftPixelSrc = GetPixel_(*nmTBCust\hdc, right-1,0)
                  
                  ; get bottom round corner pixels
                  bPixelSrc = GetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\bottom-1)
                  
                  ; draw toolstrip background
                  rc.RECT
                  rc\left = *nmTBCust\rc\left
                  If rc\left > right
                    rc\left = right
                  EndIf
                  rc\right = rc\left + right
                  If rc\right > right
                    rc\right = right
                  EndIf
                  rc\top = 0;*nmTBCust\rc\top
                  rc\bottom = height;rc\top + height
                  ;debuglog(Str(rc\left)+" "+Str(rc\right)+" "+Str(rc\top)+" "+Str(rc\bottom))
                  blitEx(*nmTBCust\hdc, toolbarEx()\UIStyle, #toolstripBackground1, @rc, #ForceVerticalRedraw|#DynamicBlitEx)
                
                    
                  ;br = CreateSolidBrush_(RGB(255,0,0))
                  ;FillRect_(*nmTBCust\hdc, rc, br)
                  ;deleteobject_(br)
                  
                  pt.POINT
                  pt\x = *nmTBCust\rc\right-1
                  pt\y = *nmTBCust\rc\top
                  If SendMessage_(*nmhdr\hwndFrom, #TB_HITTEST, 0, @pt) < 0 ; make sure not drawing button background
                    ; draw top end rounded corner
                    topleftPixel = GetPixel_(*nmTBCust\hdc, right-1,0)
                    topleftPixel = AlphaBlend (topleftPixelSrc , topleftPixel , 135)
                    SetPixel_(*nmTBCust\hdc, right-1,0, topleftPixelSrc)
                    SetPixel_(*nmTBCust\hdc, right-2,0, topleftPixel)
                    SetPixel_(*nmTBCust\hdc, right-1,1, topleftPixel)
                    
                    ; draw bottom end rounded corner
                    bpixel = GetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\bottom-1)
                    bpixel = AlphaBlend (bPixelSrc , bpixel , 135)
                    SetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\bottom-1, bPixelSrc)
                    SetPixel_(*nmTBCust\hdc, right-2,*nmTBCust\rc\bottom-1, bpixel)
                    SetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\bottom-2, bpixel)
                  EndIf

                  ; ;/ draw toolstrip dropdown
                  ; dropWidth = 11
                  ; 
                  ; ; get bottom round drop corner pixels
                  ; bPixelSrc = GetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\bottom-1)
                  ; 
                  ; ; get top round drop corner pixels
                  ; topleftPixelSrc = GetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\top)
                  ; 
                  ; CallFunctionFast(*GdipCreateFromHDC, *nmTBCust\hdc, @GraphicObject)
                  ; p1.POINT
                  ; p1\x = 0
                  ; p1\y = *nmTBCust\rc\top
                  ; p2.POINT
                  ; p2\x = 0
                  ; p2\y = (*nmTBCust\rc\bottom/2)+1
                  ; CallFunctionFast(*GdipCreateFromHDC, *nmTBCust\hdc, @GraphicObject)
                  ; CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #toolstripDropdownGradient1, #returnColour),getMenuColourEx(6, #toolstripDropdownGradient2, #returnColour),1,@colour)
                  ; CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,right,*nmTBCust\rc\top,dropWidth,(*nmTBCust\rc\bottom/2)+1)
                  ; 
                  ; p1.POINT
                  ; p1\x = 0
                  ; p1\y = (*nmTBCust\rc\bottom/2)+1
                  ; p2.POINT
                  ; p2\x = 0
                  ; p2\y = *nmTBCust\rc\bottom-1
                  ; CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #toolstripDropdownGradient3, #returnColour),getMenuColourEx(6, #toolstripDropdownGradient4, #returnColour),1,@colour2)
                  ; CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour2,right,(*nmTBCust\rc\bottom/2)+1,dropWidth,(*nmTBCust\rc\bottom/2))
; 
                  ; CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                  ; CallFunctionFast(*GdipDeleteBrush,colour)
                  ; CallFunctionFast(*GdipDeleteBrush,colour2)
                  ; 
                  ; ; draw dropdown glyph
                  ; ImageList_Draw_(toolstripDropdownGlyph, 0, *nmTBCust\hdc, *nmTBCust\rc\left+right+((dropWidth/2)-3), *nmTBCust\rc\top+((*nmTBCust\rc\bottom/2)-7), #ILD_NORMAL)
                  ; 
                  ; ; draw top end drop rounded corner
                  ; topleftPixel = GetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\top)
                  ; SetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\top, topleftPixel)
                  ; topleftPixel = AlphaBlend (topleftPixelSrc , topleftPixel , 145)
                  ; SetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\top, topleftPixelSrc)
                  ; SetPixel_(*nmTBCust\hdc, right+dropWidth-2,*nmTBCust\rc\top+1, topleftPixel)
                  ; topleftPixel = AlphaBlend (topleftPixelSrc , topleftPixel , 115)
                  ; SetPixel_(*nmTBCust\hdc, right+dropWidth-2,*nmTBCust\rc\top, topleftPixel)
                  ; SetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\top+1, topleftPixel)
                  ; 
                  ; ; draw bottom end drop rounded corner
                  ; bpixel = GetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\bottom-1)
                  ; SetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\bottom-1, bpixel)
                  ; bpixel = AlphaBlend (bPixelSrc , bpixel , 135)
                  ; SetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\bottom-1, bPixelSrc)
                  ; SetPixel_(*nmTBCust\hdc, right+dropWidth-2,*nmTBCust\rc\bottom-1, bpixel)
                  ; SetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\bottom-2, bpixel)
                  ; 
                ; Else  ; if toolbar hasn't UISTYLE_OFFICE2003 set then draw rebar background
                  ; CallFunctionFast(*GdipCreateFromHDC, *nmTBCust\hdc, @GraphicObject)
                  ; CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #rebarBackground1, #returnColour),getMenuColourEx(6, #rebarBackground2, #returnColour),1,@colour)
                  ; CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,*nmTBCust\rc\left,*nmTBCust\rc\top,left+(LargestDesktopWidth/2),*nmTBCust\rc\bottom)
                  ; CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                  ; CallFunctionFast(*GdipDeleteBrush,colour)
                  ; rc\left = (LargestDesktopWidth/2)+left
                  ; rc\right = rc\left+(*nmTBCust\rc\right-((LargestDesktopWidth/2)+left))
                  ; rc\top = *nmTBCust\rc\top
                  ; rc\bottom = *nmTBCust\rc\bottom
                  ; FillRect_(*nmTBCust\hdc, rc, getMenuColourEx(6, #rebarBackground2, 0))
                EndIf
              EndIf
              

            EndIf
            
          EndIf
        EndIf

        
        ;- Custom draw rebar chevron
        If (foundbar = #UISTYLE_OFFICE2003 Or foundbar = #UISTYLE_OFFICE2007) And *nmTBCust\rc\right-*nmTBCust\rc\left = 17
          
          ;FillRect_(*nmTBCust\hdc, *nmTBCust\rc, CreateSolidBrush_(RGB(Random(255),0,0)))
          
          ; ;/ draw toolstrip dropdown
          ; dropWidth = 11
          ; 
          ; ; get bottom round drop corner pixels
          ; bPixelSrc = GetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\bottom-1)
          ; 
          ; ; get top round drop corner pixels
          ; topleftPixelSrc = GetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\top)
          ; 
          ; CallFunctionFast(*GdipCreateFromHDC, *nmTBCust\hdc, @GraphicObject)
          ; p1.POINT
          ; p1\x = 0
          ; p1\y = *nmTBCust\rc\top
          ; p2.POINT
          ; p2\x = 0
          ; p2\y = (*nmTBCust\rc\bottom/2)+1
          ; CallFunctionFast(*GdipCreateFromHDC, *nmTBCust\hdc, @GraphicObject)
          ; CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #toolstripDropdownGradient1, #returnColour),getMenuColourEx(6, #toolstripDropdownGradient2, #returnColour),1,@colour)
          ; CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,right,*nmTBCust\rc\top,dropWidth,(*nmTBCust\rc\bottom/2)+1)
          ; 
          ; p1.POINT
          ; p1\x = 0
          ; p1\y = (*nmTBCust\rc\bottom/2)+1
          ; p2.POINT
          ; p2\x = 0
          ; p2\y = *nmTBCust\rc\bottom-1
          ; CallFunctionFast(*GdipCreateLineBrushI,p1,p2,getMenuColourEx(6, #toolstripDropdownGradient3, #returnColour),getMenuColourEx(6, #toolstripDropdownGradient4, #returnColour),1,@colour2)
          ; CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour2,right,(*nmTBCust\rc\bottom/2)+1,dropWidth,(*nmTBCust\rc\bottom/2))
          ; 
          ; CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
          ; CallFunctionFast(*GdipDeleteBrush,colour)
          ; CallFunctionFast(*GdipDeleteBrush,colour2)
          ; 
          ; ; draw dropdown glyph
          ; ImageList_Draw_(toolstripDropdownGlyph, 0, *nmTBCust\hdc, *nmTBCust\rc\left+right+((dropWidth/2)-3), *nmTBCust\rc\top+((*nmTBCust\rc\bottom/2)-7), #ILD_NORMAL)
          ; 
          ; ; draw top end drop rounded corner
          ; topleftPixel = GetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\top)
          ; SetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\top, topleftPixel)
          ; topleftPixel = AlphaBlend (topleftPixelSrc , topleftPixel , 145)
          ; SetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\top, topleftPixelSrc)
          ; SetPixel_(*nmTBCust\hdc, right+dropWidth-2,*nmTBCust\rc\top+1, topleftPixel)
          ; topleftPixel = AlphaBlend (topleftPixelSrc , topleftPixel , 115)
          ; SetPixel_(*nmTBCust\hdc, right+dropWidth-2,*nmTBCust\rc\top, topleftPixel)
          ; SetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\top+1, topleftPixel)
          ; 
          ; ; draw bottom end drop rounded corner
          ; bpixel = GetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\bottom-1)
          ; SetPixel_(*nmTBCust\hdc, right-1,*nmTBCust\rc\bottom-1, bpixel)
          ; bpixel = AlphaBlend (bPixelSrc , bpixel , 135)
          ; SetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\bottom-1, bPixelSrc)
          ; SetPixel_(*nmTBCust\hdc, right+dropWidth-2,*nmTBCust\rc\bottom-1, bpixel)
          ; SetPixel_(*nmTBCust\hdc, right+dropWidth-1,*nmTBCust\rc\bottom-2, bpixel)
          ; 
          
          ProcedureReturn #CDRF_SKIPDEFAULT
        EndIf
        
        If *nmTBCust\dwDrawStage = #CDDS_ITEMPREPAINT
          
          ;- custom draw gripper UISTYLE_OFFICE2003/UISTYLE_OFFICE2007
          ; if size of band is same as gripper
          If (foundbar = #UISTYLE_OFFICE2003 Or foundbar = #UISTYLE_OFFICE2007) And *nmTBCust\rc\right-*nmTBCust\rc\left >= 8 And *nmTBCust\rc\right-*nmTBCust\rc\left <= 11
            
            foundrebar = foundbar
            
            ; see if gripper rebar band contains toolbar with UISTYLE_OFFICE2003/UISTYLE_OFFICE2007
            bhit.RBHITTESTINFO
            bhit\pt\x = *nmTBCust\rc\left+1
            bhit\pt\y = *nmTBCust\rc\top+1
            i = SendMessage_(*nmhdr\hwndFrom, #RB_HITTEST, 0, @bhit)
            If i <> -1
              
              rbinfo.REBARBANDINFO
              rbinfo\cbSize = SizeOf(REBARBANDINFO)
              rbinfo\fMask = #RBBIM_CHILD
              SendMessage_(*nmhdr\hwndFrom, #RB_GETBANDINFO, i, @rbinfo)
              foundbar = 0
              ForEach toolbarEx()
                If toolbarEx()\Handle = rbinfo\hwndChild
                  If toolbarEx()\UIStyle = #UISTYLE_OFFICE2003
                    foundbar = #UISTYLE_OFFICE2003
                    Break
                  ElseIf toolbarEx()\UIStyle = #UISTYLE_OFFICE2007
                    foundbar = #UISTYLE_OFFICE2007
                    Break
                  EndIf
                EndIf
              Next
              If foundbar = #UISTYLE_OFFICE2003 Or foundbar = #UISTYLE_OFFICE2007
                
                ; get height of toolbar
                SendMessage_(toolbarEx()\Handle, #TB_GETMAXSIZE, 0, @sz.SIZE)
                height = sz\cy
                ; centre toolstrip vertically in band
                bandHeight = (*nmTBCust\rc\bottom-*nmTBCust\rc\top)
                ;If band
                *nmTBCust\rc\top = Round(*nmTBCust\rc\top+(bandHeight/2)-(height/2), #PB_Round_Down)
                *nmTBCust\rc\bottom = *nmTBCust\rc\top+height
                
                ; offset start of toolstrip
                *nmTBCust\rc\left = *nmTBCust\rc\left + 2
                
                ; get top round corner pixels
                topleftPixel = GetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left,*nmTBCust\rc\top)
                bottomPixelSrc = GetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left,*nmTBCust\rc\top+1)
                
                ; get bottom round corner pixels
                bPixelSrc = GetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left,*nmTBCust\rc\bottom-1)
                
                ; draw toolstrip background
                blitEx(*nmTBCust\hdc, foundbar, #toolstripBackground1, *nmTBCust\rc, #ForceVerticalRedraw|#DynamicBlitEx)
                
                ; AlphaBlend pixels into toolstrip background
                bottomPixel = GetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left,*nmTBCust\rc\top+1)
                bpixel = GetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left,*nmTBCust\rc\bottom-2)
                bDetailPixel = GetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left,*nmTBCust\rc\bottom-1)
                bDetailPixel = pMask(7, bpixel)
                bottomPixel = AlphaBlend (bottomPixelSrc , bottomPixel , 135)
                bpixel = AlphaBlend (bPixelSrc , bpixel , 135)
                
                ; set top round corner pixels
                SetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left,*nmTBCust\rc\top, topleftPixel)
                SetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left,*nmTBCust\rc\top+1, bottomPixel)
                SetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left+1,*nmTBCust\rc\top, bottomPixel)
                
                ; set bottom round corner pixels
                SetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left,*nmTBCust\rc\bottom-1, bPixelSrc)
                SetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left+1,*nmTBCust\rc\bottom-1, bPixelSrc)
                SetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left,*nmTBCust\rc\bottom-2, bPixelSrc)
                SetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left,*nmTBCust\rc\bottom-3, bpixel)
                SetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left+1,*nmTBCust\rc\bottom-2, bpixel)
                SetPixel_(*nmTBCust\hdc, *nmTBCust\rc\left+1,*nmTBCust\rc\bottom-3, bDetailPixel)
                
              EndIf
            EndIf
            
            solid = getMenuColourEx(foundrebar, #gripperSolid, 0)
            shadow = getMenuColourEx(foundrebar, #gripperShadow, 0)

            Size = 2 ; size of gripper square
            count = (*nmTBCust\rc\bottom-*nmTBCust\rc\top)/(Size*4)
            If count > 3
              count = 3
            EndIf
            y = *nmTBCust\rc\top+((*nmTBCust\rc\bottom-*nmTBCust\rc\top)/2)-((count*(Size*2))/2)
            
            ; is this a gripper in menu toolbar
            LockMutex(menuMutex)
            found = 0
            ForEach menuex()
              If menuex()\toolbarID = rbinfo\hwndChild And menuex()\singleMenu = 0
                If (*nmTBCust\rc\bottom-*nmTBCust\rc\top) <= 26
                  count = 2
                  y = y + 1
                EndIf
                Break
              EndIf
            Next
            UnlockMutex(menuMutex)
            
            For n = 0 To count
              rc.RECT
              rc\left = *nmTBCust\rc\left + ((*nmTBCust\rc\right-*nmTBCust\rc\left)/2)-(Size/2)+1
              rc\right = rc\left + Size
              rc\top = y+(n*(Size*2))-2
              rc\bottom = rc\top+Size
              rcs.RECT
              rcs\left = rc\left+1
              rcs\right = rc\right+1
              rcs\top = rc\top+1
              rcs\bottom = rc\bottom+1
              FillRect_(*nmTBCust\hdc, rcs, shadow)
              FillRect_(*nmTBCust\hdc, rc, solid)
            Next
           
            ProcedureReturn #CDRF_SKIPDEFAULT
          EndIf
          

          ; is this a menu toolbar item
          LockMutex(menuMutex)
          found = 0
          ForEach menuex()
            If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\buttonID = *nmTBCust\dwItemSpec And menuex()\singleMenu = 0
              found = -1
              Break
            EndIf
          Next
          UnlockMutex(menuMutex)
          
          ;is this a toolbar button separator with default style? draw normal separator bar
          If foundToolBarEx = #True And found = 0 And foundbar = 0 And toolbarEx()\Handle = *nmhdr\hwndFrom
            index = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBCust\dwItemSpec, 0)
            If SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTON, index, @button.TBBUTTON)
              If button\fsStyle = 0
                ChangeCurrentElement(toolbarExButton(), button\dwData)
                If toolbarExButton()\separator = #True
                  
                  If ThemesEnabled = #True
                    
                    CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 5, 1, *nmTBCust\rc, 0)
                    
                  Else

                    separator = getMenuColour(#UISTYLE_WHIDBEY, #separatorBar)
                    shadow = CreateSolidBrush_(RGB(255,255,255))
                    
                    width = *nmTBCust\rc\right - *nmTBCust\rc\left
                    rc.RECT
                    rc\left = *nmTBCust\rc\left + (width/2)-1
                    rc\right = rc\left+1
                    rc\top = *nmTBCust\rc\top+3
                    rc\bottom = *nmTBCust\rc\bottom-4
                    src.RECT
                    src\left = rc\left+1
                    src\right = src\left+1
                    src\top = rc\top+1
                    src\bottom = rc\bottom+1
                    
                    FillRect_(*nmTBCust\hdc, rc, separator)
                    FillRect_(*nmTBCust\hdc, src, shadow)
                    DeleteObject_(shadow)
                    
                  EndIf
                  
                  ProcedureReturn #CDRF_SKIPDEFAULT
                EndIf
              EndIf
            EndIf
          EndIf
          
          
          
          ;- custom draw toolbar if style <= #UISTYLE_WHIDBEY
          If ThemesEnabled = #True And foundToolBarEx = #True And found = 0 And foundbar <= #UISTYLE_WHIDBEY And toolbarEx()\UIStyle <> #UISTYLE_IMAGE; And dont = 1
            

            If toolbarEx()\Handle = *nmhdr\hwndFrom
              index = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBCust\dwItemSpec, 0)
              If SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTON, index, @button.TBBUTTON)
                
                If button\fsStyle = -112
                  wholeDropdown = #True
                ElseIf button\fsStyle = 24
                  Dropdown = #True
                EndIf
                
              EndIf
            EndIf
            
            
            If Dropdown = 0
              Select *nmTBCust\uItemState
  
                Case #CDIS_HOT
                  
                  CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 1, 2, *nmTBCust\rc, 0)
                  
                Case 65 ; pressed
                  
                  CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 1, 3, *nmTBCust\rc, 0)
                  
                Case 8 ; sticky selected
                  
                  CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 1, 5, *nmTBCust\rc, 0)
                  
                Case 72 ; sticky selected hot
                  
                  CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 1, 6, *nmTBCust\rc, 0)
                  
                Case 73 ; sticky selected pressed
                  
                  CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 1, 3, *nmTBCust\rc, 0)
              EndSelect
            EndIf
            
            ;If dropdownActive = #True
            ;  
            ;  Alpha = 40
            ;  colour = 0
            ;  addTitleDropShadow()
            ;  
            ;Else
            ;  If Dropdown = #True Or wholeDropdown = #True
            ;    destroyTitleShadows()
            ;  EndIf
            ;EndIf
            
            ;oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
            
            metrics.NONCLIENTMETRICS
            metrics\cbSize = SizeOf(NONCLIENTMETRICS)
            SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
            font = CreateFontIndirect_(metrics\lfMessageFont)
            oldFont = SelectObject_(*nmTBCust\hdc, font)
            
            SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_BTNTEXT))
            SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
            
            index = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBCust\dwItemSpec, 0)
            ImageList_GetImageInfo_(toolbarEx()\hotImageList, index, @imf.IMAGEINFO)
            height = imf\rcImage\bottom-imf\rcImage\top
            width = imf\rcImage\right-imf\rcImage\left
            
            bufflen = SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTONTEXT, *nmTBCust\dwItemSpec, 0)
            If bufflen > 0
              CompilerIf #PB_Compiler_Unicode
                bufflen = bufflen * 2
              CompilerEndIf
              *mem = AllocateMemory(bufflen+2)
              SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTONTEXT, *nmTBCust\dwItemSpec, *mem)
              txtbuff.s = PeekS(*mem, bufflen)
              FreeMemory(*mem)
            Else
              txtbuff = ""
            EndIf
            ;-unicode check here
            
            rec.RECT
            txtheight = DrawText_(*nmTBCust\hdc, txtbuff, Len(txtbuff), @rec, #DT_CALCRECT)
            txtwidth = rec\right
            txtHeightPad = 2
            
            ; if button is #TBSTYLE_LIST style
            If toolbarEx()\style & #TBSTYLE_LIST
              xpos = *nmTBCust\rc\left+3
              ypos = *nmTBCust\rc\top+3
              If txtbuff = ""
                ypos = ypos + 1
              EndIf
              
              rec\left = *nmTBCust\rc\left+width
              rec\top = *nmTBCust\rc\top+((*nmTBCust\rc\bottom-*nmTBCust\rc\top)/2)-((txtheight+txtHeightPad)/2)
            Else
              xposf.f = Round(*nmTBCust\rc\left+((*nmTBCust\rc\right-*nmTBCust\rc\left)/2)-(width/2), #PB_Round_Down)
              yposf.f = Round(*nmTBCust\rc\top+((*nmTBCust\rc\bottom-*nmTBCust\rc\top)/2)-((height+txtheight+txtHeightPad)/2), #PB_Round_Up)
              xpos = xposf
              ypos = yposf + 1
              
              rec\left = *nmTBCust\rc\left
              rec\top = ypos+height+txtHeightPad-1
            EndIf
            
            If wholeDropdown = #True
              xpos = xpos - 3
              If txtbuff <> ""
                xpos = xpos - 1
                grc.RECT
                grc\left = xpos+width
                grc\top = *nmTBCust\rc\top
                grc\right = *nmTBCust\rc\right
                grc\bottom = grc\top+height
              Else
                grc.RECT
                grc\left = xpos+width-4
                grc\top = *nmTBCust\rc\top
                grc\right = *nmTBCust\rc\right
                grc\bottom = grc\top+height
              EndIf
              
              If Not *nmTBCust\uItemState & #ODS_DISABLED
                CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 4, 1, grc, 0)
              Else
                CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 4, 4, grc, 0)
              EndIf

            EndIf
            
            If Dropdown = #True
              
              If txtbuff <> ""
                xposf.f = Round(*nmTBCust\rc\left+(((*nmTBCust\rc\right-*nmTBCust\rc\left)-11)/2)-(width/2), #PB_Round_Down)
                xpos = xposf
                rec\left = rec\left - 11
                rec\right = rec\right - 11
              Else
                xpos = xpos - 5
              EndIf
              
              yposf.f = Round(ypos+((height+txtheight+txtHeightPad)/2)-2, #PB_Round_Up)
              y = yposf
              x = *nmTBCust\rc\left+(*nmTBCust\rc\right-*nmTBCust\rc\left)-9
              
              
              If *nmTBCust\uItemState = #CDIS_HOT
                tright = *nmTBCust\rc\right
                *nmTBCust\rc\right = *nmTBCust\rc\right - 13
                CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 3, 2, *nmTBCust\rc, 0)
                *nmTBCust\rc\right = tright
                *nmTBCust\rc\left = *nmTBCust\rc\right - 13
                If dropdownActive = 0
                  CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 4, 2, *nmTBCust\rc, 0)
                Else
                  CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 4, 3, *nmTBCust\rc, 0)
                EndIf
              ElseIf *nmTBCust\uItemState & #ODS_DISABLED
                tright = *nmTBCust\rc\right
                *nmTBCust\rc\right = *nmTBCust\rc\right - 13
                CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 3, 4, *nmTBCust\rc, 0)
                *nmTBCust\rc\right = tright
                *nmTBCust\rc\left = *nmTBCust\rc\right - 13
                CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 4, 4, *nmTBCust\rc, 0)
              ElseIf *nmTBCust\uItemState = 65 ; pressed
                tright = *nmTBCust\rc\right
                *nmTBCust\rc\right = *nmTBCust\rc\right - 13
                CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 3, 3, *nmTBCust\rc, 0)
                *nmTBCust\rc\right = tright
                *nmTBCust\rc\left = *nmTBCust\rc\right - 13
                CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 4, 3, *nmTBCust\rc, 0)
              Else  ; normal
                tright = *nmTBCust\rc\right
                *nmTBCust\rc\right = *nmTBCust\rc\right - 13
                CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 3, 1, *nmTBCust\rc, 0)
                *nmTBCust\rc\right = tright
                *nmTBCust\rc\left = *nmTBCust\rc\right - 13
                CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 4, 1, *nmTBCust\rc, 0)
              EndIf
             
            EndIf

            rec\right = *nmTBCust\rc\right
            rec\bottom = rec\top+txtheight
            
            ; disabled state
            If *nmTBCust\uItemState & #ODS_DISABLED
              SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_GRAYTEXT))
              ImageList_Draw_(toolbarEx()\disabledImageList, index, *nmTBCust\hdc, xpos, ypos, #ILD_TRANSPARENT)
              overrideColor = #DT_OVERRIDECOLOUR
            ElseIf *nmTBCust\uItemState = 65 Or *nmTBCust\uItemState = 8 Or *nmTBCust\uItemState = 72 Or *nmTBCust\uItemState = 73; pressed
              ImageList_Draw_(toolbarEx()\normalImageList, index, *nmTBCust\hdc, xpos+1, ypos, #ILD_TRANSPARENT)
            ; hot
            ElseIf *nmTBCust\uItemState & #CDIS_HOT
              ImageList_Draw_(toolbarEx()\hotImageList, index, *nmTBCust\hdc, xpos, ypos, #ILD_TRANSPARENT)
            ; normal
            Else
              ImageList_Draw_(toolbarEx()\normalImageList, index, *nmTBCust\hdc, xpos, ypos, #ILD_TRANSPARENT)
            EndIf
            
            If txtbuff <> ""
              
              index = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBCust\dwItemSpec, 0)
              SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTON, index, @button.TBBUTTON)
              ChangeCurrentElement(toolbarExButton(), button\dwData)
              txtbuff = toolbarExButton()\text
              rec\left = rec\left + (((rec\right-rec\left)/2) - (txtwidth/2))
              RenderText(*nmTBCust\hdc, txtbuff, @rec, 0, overrideColor | #TCX_VCENTRE)
              
            EndIf
              
            SelectObject_(*nmTBCust\hdc, oldFont)
            DeleteObject_(font)

            ProcedureReturn #CDRF_SKIPDEFAULT
            
          EndIf
          

          ;- custom draw toolbar UISTYLE_OFFICE2003/UISTYLE_OFFICE2007 if in rebar
          If foundToolBarEx = #True And found = 0 And (foundbar = #UISTYLE_OFFICE2003 Or foundbar = #UISTYLE_OFFICE2007)
            
            ;is this a toolbar button separator
            If toolbarEx()\Handle = *nmhdr\hwndFrom
              index = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBCust\dwItemSpec, 0)
              If SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTON, index, @button.TBBUTTON)
                ;debuglog(Str(button\fsStyle))
                ;debuglog(Str(index))

                If button\fsStyle = 0
                  ChangeCurrentElement(toolbarExButton(), button\dwData)
                  If toolbarExButton()\separator = #True
                    
                    separator = getMenuColourEx(foundbar, #toolbarSeparator, 0)
                    shadow = getMenuColourEx(foundbar, #toolbarSeparatorShadow, 0)
                    
                    width = *nmTBCust\rc\right - *nmTBCust\rc\left
                    rc.RECT
                    rc\left = *nmTBCust\rc\left + (width/2)-1
                    rc\right = rc\left+1
                    rc\top = *nmTBCust\rc\top+5
                    rc\bottom = *nmTBCust\rc\bottom-6
                    src.RECT
                    src\left = rc\left+1
                    src\right = src\left+1
                    src\top = rc\top+1
                    src\bottom = rc\bottom+1
                    
                    FillRect_(*nmTBCust\hdc, rc, separator)
                    FillRect_(*nmTBCust\hdc, src, shadow)
                    
                    ProcedureReturn #CDRF_SKIPDEFAULT
                  EndIf
                EndIf
              EndIf
            EndIf
            
            If toolbarEx()\Handle = *nmhdr\hwndFrom
              index = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBCust\dwItemSpec, 0)
              If SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTON, index, @button.TBBUTTON)
                
                If button\fsStyle = -112
                  wholeDropdown = #True
                ElseIf button\fsStyle = 24
                  Dropdown = #True
                EndIf
                
              EndIf
            EndIf
            
            Select *nmTBCust\uItemState
              Case #CDIS_HOT
                col1 = getMenuColourEx(foundbar, #toolbarHotGradientColor1, #returnColour)
                col2 = getMenuColourEx(foundbar, #toolbarHotGradientColor2, #returnColour)
                If dropdownActive = #True
                  col1 = getMenuColourEx(foundbar, #menuHeldGradientColor1, #returnColour)
                  col2 = getMenuColourEx(foundbar, #menuHeldGradientColor2, #returnColour)
                EndIf
              Case 65 ; pressed
                If wholeDropdown = #True
                  col1 = getMenuColourEx(foundbar, #menuHeldGradientColor1, #returnColour)
                  col2 = getMenuColourEx(foundbar, #menuHeldGradientColor2, #returnColour)
                Else
                  col1 = getMenuColourEx(foundbar, #SelectGradientColor1, #returnColour)
                  col2 = getMenuColourEx(foundbar, #SelectGradientColor2, #returnColour)
                EndIf
              Case 8 ; sticky selected
                col1 = getMenuColourEx(foundbar, #StickySelectGradientColor1, #returnColour)
                col2 = getMenuColourEx(foundbar, #StickySelectGradientColor2, #returnColour)
              Case 72 ; sticky selected hot
                col1 = getMenuColourEx(foundbar, #SelectGradientColor1, #returnColour)
                col2 = getMenuColourEx(foundbar, #SelectGradientColor2, #returnColour)
              Case 73 ; sticky selected pressed
                col1 = getMenuColourEx(foundbar, #SelectGradientColor1, #returnColour)
                col2 = getMenuColourEx(foundbar, #SelectGradientColor2, #returnColour)
            EndSelect
            
            ; disabled state glyph color
            If *nmTBCust\uItemState & #ODS_DISABLED
              glyphColor = getMenuColourEx(foundbar, #toolbarButtonDisabledTextColor, #returnColour)
            ; normal state glyph color
            Else
              glyphColor = 0
            EndIf
            glyphWidth = 5: glyphHeight = 3
            
            
            ; if toolbar is UISTYLE_OFFICE2003/UISTYLE_OFFICE2007 then add padding to top & bottom of buttons
            If toolbarEx()\UIStyle = #UISTYLE_OFFICE2003 Or toolbarEx()\UIStyle = #UISTYLE_OFFICE2007
              *nmTBCust\rc\top = *nmTBCust\rc\top + 1
              *nmTBCust\rc\bottom = *nmTBCust\rc\bottom - 2
            EndIf
            
            If col1 <> 0
              If InitGDIPlus() <> 0
                p1.POINT
                p1\x = 0
                p1\y = 1
                p2.POINT
                p2\x = 0
                p2\y = *nmTBCust\rc\bottom-2
                
                CallFunctionFast(*GdipCreateFromHDC, *nmTBCust\hdc, @GraphicObject)
                CallFunctionFast(*GdipCreateLineBrushI,p1,p2,col1,col2,1,@colour)
                CallFunctionFast(*GdipFillRectangleI,GraphicObject,colour,*nmTBCust\rc\left,*nmTBCust\rc\top+1,*nmTBCust\rc\right-*nmTBCust\rc\left,*nmTBCust\rc\bottom-2)
                CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
                CallFunctionFast(*GdipDeleteBrush,colour)  
              EndIf
            
              
              If Dropdown = #True Or wholeDropdown = #True
                If dropdownActive = #True
                  border = getMenuColourEx(foundbar, #menuHeldBorder, 0)
                  
                  colour = getMenuColourEx(foundbar, #menuDropShadow, #returnColour)
                  Alpha = PeekB(@colour+3)&$FF
                  colour = RGB(Blue(colour), Green(colour), Red(colour))
                  addTitleDropShadow()
                Else
                  border = getMenuColourEx(foundbar, #menuHotBorder, 0)
                EndIf
              Else
                If *nmTBCust\uItemState = 8 ; sticky selected
                  border = getMenuColourEx(foundbar, #StickySelectBorderColor, 0)
                Else
                  border = getMenuColourEx(foundbar, #menuHotBorder, 0)
                EndIf
              EndIf
              
              FrameRect_(*nmTBCust\hdc, *nmTBCust\rc, border)
              
            Else
              If Dropdown = #True Or wholeDropdown = #True
                destroyTitleShadows()
              EndIf
            EndIf  
              ;oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
              
              metrics.NONCLIENTMETRICS
              metrics\cbSize = SizeOf(NONCLIENTMETRICS)
              SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
              font = CreateFontIndirect_(metrics\lfMessageFont)
              oldFont = SelectObject_(*nmTBCust\hdc, font)
              
              SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_BTNTEXT))
              SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
              
              index = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBCust\dwItemSpec, 0)
              ImageList_GetImageInfo_(toolbarEx()\hotImageList, index, @imf.IMAGEINFO)
              height = imf\rcImage\bottom-imf\rcImage\top
              width = imf\rcImage\right-imf\rcImage\left
              
              bufflen = SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTONTEXT, *nmTBCust\dwItemSpec, 0)
              CompilerIf #PB_Compiler_Unicode
                bufflen = bufflen * 2
              CompilerEndIf
              If bufflen > 0
                *mem = AllocateMemory(bufflen+2)
                SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTONTEXT, *nmTBCust\dwItemSpec, *mem)
                txtbuff.s = PeekS(*mem, bufflen)
                FreeMemory(*mem)
              Else
                txtbuff = ""
              EndIf
              ;-unicode check here
              
              rec.RECT
              txtheight = DrawText_(*nmTBCust\hdc, txtbuff, Len(txtbuff), @rec, #DT_CALCRECT)
              txtwidth = rec\right
              txtHeightPad = 2
              
              ; if button is #TBSTYLE_LIST style
              If toolbarEx()\style & #TBSTYLE_LIST
                xpos = *nmTBCust\rc\left+3
                ypos = *nmTBCust\rc\top+3
                If txtbuff = ""
                  ypos = ypos + 1
                EndIf
                
                rec\left = *nmTBCust\rc\left+width
                rec\top = *nmTBCust\rc\top+((*nmTBCust\rc\bottom-*nmTBCust\rc\top)/2)-((txtheight+txtHeightPad)/2)
              Else
                xposf.f = Round(*nmTBCust\rc\left+((*nmTBCust\rc\right-*nmTBCust\rc\left)/2)-(width/2), #PB_Round_Down)
                yposf.f = Round(*nmTBCust\rc\top+((*nmTBCust\rc\bottom-*nmTBCust\rc\top)/2)-((height+txtheight+txtHeightPad)/2), #PB_Round_Up)
                xpos = xposf
                ypos = yposf + 1
                
                rec\left = *nmTBCust\rc\left
                rec\top = ypos+height+txtHeightPad-1
              EndIf
              
              If wholeDropdown = #True
                xpos = xpos - 3
                If txtbuff <> ""
                  xpos = xpos - 1
                  ; draw dropdown arrow glyph
                  drawDropDownGlyph(*nmTBCust\hdc, xpos+width+4, ((*nmTBCust\rc\bottom-*nmTBCust\rc\top)/2)-8, glyphWidth, glyphHeight, glyphColor)
                Else
                  ; draw dropdown arrow glyph
                  drawDropDownGlyph(*nmTBCust\hdc, *nmTBCust\rc\left+(*nmTBCust\rc\right-*nmTBCust\rc\left)-8, ((*nmTBCust\rc\bottom-*nmTBCust\rc\top)/2)+1, glyphWidth, glyphHeight, glyphColor)
                EndIf
              EndIf
              
              If Dropdown = #True
                
                If txtbuff <> ""
                  ;xpos = xpos - 6
                  xposf.f = Round(*nmTBCust\rc\left+(((*nmTBCust\rc\right-*nmTBCust\rc\left)-11)/2)-(width/2), #PB_Round_Down)
                  xpos = xposf
                  rec\left = rec\left - 11
                  rec\right = rec\right - 11
                Else
                  xpos = xpos - 5
                EndIf
                
                ;yposf.f = Round(((*nmTBCust\rc\bottom-*nmTBCust\rc\top))/2, #PB_ROUND_DOWN)
                ;yposf.f = ypos+((height+txtheight+txtHeightPad)/2)-2
                yposf.f = Round(ypos+((height+txtheight+txtHeightPad)/2)-2, #PB_Round_Up)
                y = yposf
                x = *nmTBCust\rc\left+(*nmTBCust\rc\right-*nmTBCust\rc\left)-9
                
                ; draw dropdown arrow glyph
                drawDropDownGlyph(*nmTBCust\hdc, x, y, glyphWidth, glyphHeight, glyphColor)

                If col1 <> 0 And dropdownActive = #False
                  border = getMenuColourEx(foundbar, #menuHotBorder, 0)
                  *nmTBCust\rc\left = *nmTBCust\rc\right - 13
                  FrameRect_(*nmTBCust\hdc, *nmTBCust\rc, border)
                EndIf
               
              EndIf

              rec\right = *nmTBCust\rc\right
              rec\bottom = rec\top+txtheight
              
              ; disabled state
              If *nmTBCust\uItemState & #ODS_DISABLED
                SetTextColor_(*nmTBCust\hdc, getMenuColourEx(toolbarex()\UIStyle, #toolbarButtonDisabledTextColor, #returnColour))
                ImageList_Draw_(toolbarEx()\disabledImageList, index, *nmTBCust\hdc, xpos, ypos, #ILD_TRANSPARENT)
                overrideColor = #DT_OVERRIDECOLOUR
              ; hot
              ElseIf *nmTBCust\uItemState & #CDIS_HOT
                SetTextColor_(*nmTBCust\hdc, getMenuColourEx(toolbarex()\UIstyle, #toolbarButtonHotTextColor, #returnColour))
                ImageList_Draw_(toolbarEx()\hotImageList, index, *nmTBCust\hdc, xpos, ypos, #ILD_TRANSPARENT)
              ; normal
              Else
                SetTextColor_(*nmTBCust\hdc, getMenuColourEx(toolbarex()\UIstyle, #toolbarButtonTextColor, #returnColour))
                ImageList_Draw_(toolbarEx()\normalImageList, index, *nmTBCust\hdc, xpos, ypos, #ILD_TRANSPARENT)
              EndIf
              
              If txtbuff <> ""
                
                index = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBCust\dwItemSpec, 0)
                SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTON, index, @button.TBBUTTON)
                ChangeCurrentElement(toolbarExButton(), button\dwData)
                txtbuff = toolbarExButton()\text
                rec\left = rec\left + (((rec\right-rec\left)/2) - (txtwidth/2))
                RenderText(*nmTBCust\hdc, txtbuff, @rec, 0, overrideColor | #TCX_VCENTRE)
                
              EndIf
                
              SelectObject_(*nmTBCust\hdc, oldFont)
              DeleteObject_(font)
  
              ProcedureReturn #CDRF_SKIPDEFAULT
            ;EndIf
          EndIf
          
          
          
          ;- Image style
          If foundToolBarEx = #True And found = 0 And toolbarEx()\Handle = *nmhdr\hwndFrom And toolbarEx()\UIStyle = #UISTYLE_IMAGE
            
            index = SendMessage_(*nmhdr\hwndFrom, #TB_COMMANDTOINDEX, *nmTBCust\dwItemSpec, 0)
            ImageList_GetImageInfo_(toolbarEx()\hotImageList, index, @imf.IMAGEINFO)
            height = imf\rcImage\bottom-imf\rcImage\top
            width = imf\rcImage\right-imf\rcImage\left
            
            rec\right = *nmTBCust\rc\right
            rec\bottom = rec\top+txtheight
            y = *nmTBCust\rc\top
            
            Select *nmTBCust\uItemState
              Case #CDIS_HOT
                ImageList_Draw_(toolbarEx()\hotImageList, index, *nmTBCust\hdc, *nmTBCust\rc\left, y, #ILD_TRANSPARENT)
              Case 65 ; pressed
                ImageList_Draw_(toolbarEx()\disabledImageList, index, *nmTBCust\hdc, *nmTBCust\rc\left, y, #ILD_TRANSPARENT)
              Case 8 ; sticky selected
                ImageList_Draw_(toolbarEx()\disabledImageList, index, *nmTBCust\hdc, *nmTBCust\rc\left, y, #ILD_TRANSPARENT)
              Case 72 ; sticky selected hot
                ImageList_Draw_(toolbarEx()\disabledImageList, index, *nmTBCust\hdc, *nmTBCust\rc\left, y, #ILD_TRANSPARENT)
              Case 73 ; sticky selected pressed
                ImageList_Draw_(toolbarEx()\disabledImageList, index, *nmTBCust\hdc, *nmTBCust\rc\left, y, #ILD_TRANSPARENT)
              Default
                ImageList_Draw_(toolbarEx()\normalImageList, index, *nmTBCust\hdc, *nmTBCust\rc\left, y, #ILD_TRANSPARENT)
            EndSelect
            
            ProcedureReturn #CDRF_SKIPDEFAULT
            
          EndIf
          
          ; is this a menu toolbar item
          LockMutex(menuMutex)
          found = 0
          ForEach menuex()
            If menuex()\toolbarID = *nmhdr\hwndFrom And menuex()\buttonID = *nmTBCust\dwItemSpec And menuex()\singleMenu = 0
              found = -1
              Break
            EndIf
          Next
          
          ;- normal draw display of menu item
          If *nmTBCust\uItemState <> #CDIS_HOT And found = -1
            
            buttontxt.s = ""
            bufflen = SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTONTEXT, *nmTBCust\dwItemSpec, 0)
            CompilerIf #PB_Compiler_Unicode
              bufflen = bufflen * 2
            CompilerEndIf
            If bufflen > 0
              *mem = AllocateMemory(bufflen+2)
              SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTONTEXT, *nmTBCust\dwItemSpec, *mem)
              buttontxt = PeekS(*mem, bufflen)
              FreeMemory(*mem)
            EndIf
            
            ; destroy title dropshadows if exists
            destroyTitleShadows()
            
            ;/ Button Style
            If menuex()\style = 0
              
              oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
              
              If menuex()\greyed = 0
                SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_MENUTEXT))
              Else
                SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_GRAYTEXT))
              EndIf
              SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
              
              *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right
              DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
              
              SelectObject_(*nmTBCust\hdc, oldFont)
              
              Result = #CDRF_SKIPDEFAULT
              
            ;/ Internet Explorer Style
            ElseIf menuex()\style = 1
              
              oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
              
              If menuex()\greyed = 0
                SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_MENUTEXT))
              Else
                SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_GRAYTEXT))
              EndIf
              SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
              
              *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right
              DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
              
              SelectObject_(*nmTBCust\hdc, oldFont)
              
              Result = #CDRF_SKIPDEFAULT
            EndIf
            
            ;/ Mozilla Firefox Style
            If menuex()\style = 2
              
              oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
              
              SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_MENUTEXT))
              SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
              
              *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right
              DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
              
              SelectObject_(*nmTBCust\hdc, oldFont)
              
              Result = #CDRF_SKIPDEFAULT
            EndIf
            
            ;/ Bevel Style
            If menuex()\style = 3 Or menuex()\style = 4
              
              oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
              
              SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_MENUTEXT))
              SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
              
              *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right
              DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
              
              SelectObject_(*nmTBCust\hdc, oldFont)
              
              Result = #CDRF_SKIPDEFAULT
            EndIf
            
            ;/ office xp whidbey Style
            If menuex()\style = 5
              
              oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
              
              If menuex()\greyed = 0
                SetTextColor_(*nmTBCust\hdc, getMenuColour(5, #menuTitleTextColor))
              Else
                SetTextColor_(*nmTBCust\hdc, getMenuColour(5, #menuTitleInactiveTextColor))
              EndIf
              SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
              
              *nmTBCust\rc\right = *nmTBCust\rc\right - 4
              DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
              
              SelectObject_(*nmTBCust\hdc, oldFont)
              
              Result = #CDRF_SKIPDEFAULT
            EndIf
            
            ;/ office 2003 Style
            If menuex()\style = 6
              
              oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
              
              If menuex()\greyed = 0
                SetTextColor_(*nmTBCust\hdc, getMenuColourEx(6, #menuTitleTextColor, #returnColour))
              Else
                border = getMenuColourEx(6, #menuTitleInactiveTextColor, #returnColour)
                SetTextColor_(*nmTBCust\hdc, border)
              EndIf
              
              SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
              
              DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
              
              SelectObject_(*nmTBCust\hdc, oldFont)
              
              Result = #CDRF_SKIPDEFAULT
            EndIf
            
            ;/ office 2007 Style
            If menuex()\style = #UISTYLE_OFFICE2007
              
              oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
              
              If menuex()\greyed = 0
                SetTextColor_(*nmTBCust\hdc, getMenuColourEx(#UISTYLE_OFFICE2007, #menuTitleTextColor, #returnColour))
              Else
                border = getMenuColourEx(#UISTYLE_OFFICE2007, #menuTitleInactiveTextColor, #returnColour)
                SetTextColor_(*nmTBCust\hdc, border)
              EndIf
              
              SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
              
              DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
              
              SelectObject_(*nmTBCust\hdc, oldFont)
              
              Result = #CDRF_SKIPDEFAULT
            EndIf

          EndIf
          
          
          
          ;- hot draw display of menu item
          If *nmTBCust\uItemState = #CDIS_HOT
            
            If found = -1
              buttontxt.s = ""
              bufflen = SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTONTEXT, *nmTBCust\dwItemSpec, 0)
              If bufflen > 0
                CompilerIf #PB_Compiler_Unicode
                  bufflen = bufflen * 2
                CompilerEndIf
                *mem = AllocateMemory(bufflen+2)
                SendMessage_(*nmhdr\hwndFrom, #TB_GETBUTTONTEXT, *nmTBCust\dwItemSpec, *mem)
                buttontxt = PeekS(*mem, bufflen)
                FreeMemory(*mem)
              EndIf
              
              ; destroy title dropshadows if exists
              destroyTitleShadows()
              
              ;/ Button Style
              If menuex()\style = 0
                
                If menuex()\active = 0
                  If ThemesEnabled = #True
                    CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 1, 2, *nmTBCust\rc, 0)
                  Else
                    *nmTBCust\rc\bottom = *nmTBCust\rc\bottom - 1
                    FillRect_(*nmTBCust\hdc, *nmTBCust\rc, GetSysColorBrush_(#COLOR_BTNFACE))
                    DrawEdge_(*nmTBCust\hdc, *nmTBCust\rc, #BDR_RAISEDINNER, #BF_RECT)
                    *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right
                    *nmTBCust\rc\bottom = *nmTBCust\rc\bottom + 1
                  EndIf
                ;draw held state
                Else
                  If ThemesEnabled = #True
                    CallFunctionFast(*DrawThemeBackground, hThemeToolbar, *nmTBCust\hdc, 1, 3, *nmTBCust\rc, 0)
                  Else
                    *nmTBCust\rc\bottom = *nmTBCust\rc\bottom - 1
                    FillRect_(*nmTBCust\hdc, *nmTBCust\rc, GetSysColorBrush_(#COLOR_BTNFACE))
                    DrawEdge_(*nmTBCust\hdc, *nmTBCust\rc, #BDR_SUNKENOUTER, #BF_RECT)
                    *nmTBCust\rc\top = *nmTBCust\rc\top + 1
                    *nmTBCust\rc\left = *nmTBCust\rc\left + 1
                    *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right+1
                    *nmTBCust\rc\bottom = *nmTBCust\rc\bottom + 2
                  EndIf
                EndIf
                  
                oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
                
                SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_MENUTEXT))
                SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
                
                *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right
                DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
                
                SelectObject_(*nmTBCust\hdc, oldFont)
                
                Result = #CDRF_SKIPDEFAULT
                
              ;/ Internet Explorer Style
              ElseIf menuex()\style = 1
                brHighlight = GetSysColorBrush_(#COLOR_HIGHLIGHT)
                brMenuHilight = GetSysColorBrush_(#COLOR_HIGHLIGHT)
                *nmTBCust\rc\bottom = *nmTBCust\rc\bottom - 1
                FillRect_(*nmTBCust\hdc, *nmTBCust\rc, brMenuHilight)
                ;FrameRect_(*nmTBCust\hdc, *nmTBCust\rc, brHighlight)
                
                oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
                
                SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_HIGHLIGHTTEXT))
                SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
                
                *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right
                *nmTBCust\rc\bottom = *nmTBCust\rc\bottom + 1
                DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
                
                SelectObject_(*nmTBCust\hdc, oldFont)
                
                Result = #CDRF_SKIPDEFAULT
              EndIf
              
              ;/ Mozilla Firefox Style
              If menuex()\style = 2
                *nmTBCust\rc\bottom = *nmTBCust\rc\bottom - 1
                
                oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
                
                SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_MENUTEXT))
                SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
                
                FillRect_(*nmTBCust\hdc, *nmTBCust\rc, GetSysColorBrush_(#COLOR_BTNFACE))
                
                If menuex()\active = 0
                  DrawEdge_(*nmTBCust\hdc, *nmTBCust\rc, #BDR_RAISEDINNER, #BF_RECT)
                  *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right
                  *nmTBCust\rc\bottom = *nmTBCust\rc\bottom + 1
                Else
                  DrawEdge_(*nmTBCust\hdc, *nmTBCust\rc, #BDR_SUNKENOUTER, #BF_RECT)
                  *nmTBCust\rc\top = *nmTBCust\rc\top + 1
                  *nmTBCust\rc\left = *nmTBCust\rc\left + 1
                  *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right+1
                  *nmTBCust\rc\bottom = *nmTBCust\rc\bottom + 1+1
                EndIf

                DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
                
                SelectObject_(*nmTBCust\hdc, oldFont)
                
                Result = #CDRF_SKIPDEFAULT
              EndIf
              
              ;/ Bevel Style
              If menuex()\style = 3 Or menuex()\style = 4
                
                *nmTBCust\rc\bottom = *nmTBCust\rc\bottom - 1
                
                oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
                
                SetTextColor_(*nmTBCust\hdc, GetSysColor_(#COLOR_MENUTEXT))
                SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
                
                If menuex()\active = 0
                  DrawEdge_(*nmTBCust\hdc, *nmTBCust\rc, #EDGE_ETCHED, #BF_RECT)
                  *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right
                  *nmTBCust\rc\bottom = *nmTBCust\rc\bottom + 1
                Else
                  If menuex()\style = 3
                    DrawEdge_(*nmTBCust\hdc, *nmTBCust\rc, #EDGE_ETCHED, #BF_RECT)
                    *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right
                    *nmTBCust\rc\bottom = *nmTBCust\rc\bottom + 1
                  ElseIf menuex()\style = 4
                    DrawEdge_(*nmTBCust\hdc, *nmTBCust\rc, #EDGE_SUNKEN, #BF_RECT)
                    *nmTBCust\rc\top = *nmTBCust\rc\top + 1
                    *nmTBCust\rc\left = *nmTBCust\rc\left + 1
                    *nmTBCust\rc\right = *nmTBCust\rc\left + *custTB\rcText\right+1
                    *nmTBCust\rc\bottom = *nmTBCust\rc\bottom + 1+1
                  EndIf
                EndIf
                
                DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
                
                SelectObject_(*nmTBCust\hdc, oldFont)
                
                Result = #CDRF_SKIPDEFAULT
              EndIf
              
              ;/ office xp whidbey Style
              If menuex()\style = 5
                
                *nmTBCust\rc\bottom = *nmTBCust\rc\bottom - 1
                *nmTBCust\rc\right = *nmTBCust\rc\right - 4

                If menuex()\active = 0
                  
                  colour = getMenuColour(menuex()\style, #menuHotColor)
                  border = getMenuColour(menuex()\style, #menuHotBorder)
                  
                  FillRect_(*nmTBCust\hdc, *nmTBCust\rc, colour)
                  FrameRect_(*nmTBCust\hdc, *nmTBCust\rc, border)

                Else
                  ; draw selected menu held state
                  
                  colour = getMenuColour(menuex()\style, #menuHeldColor)
                  border = getMenuColour(menuex()\style, #menuHeldBorder)
                  
                  FillRect_(*nmTBCust\hdc, *nmTBCust\rc, colour)
                  FrameRect_(*nmTBCust\hdc, *nmTBCust\rc, border)
                  
                  ; draw background line where menu join is going to be inorder to stop flickering of seam and smother fade
                  If menuWindowXpos > menuTitleXpos
                    rec\left = *nmTBCust\rc\left+(menuWindowXpos-menuTitleXpos)
                    rec\right = rec\left+(menuTitleWidth-(menuWindowXpos-menuTitleXpos))-1
                    rec\top = *nmTBCust\rc\bottom-1
                    rec\bottom = rec\top+1
                  ElseIf menuTitleXpos+menuTitleWidth > menuWindowXpos+menuWindowWidth
                    rec\left = *nmTBCust\rc\left+1
                    rec\right = rec\left+menuTitleWidth-((menuTitleXpos+menuTitleWidth)-(menuWindowXpos+menuWindowWidth))-1
                    rec\top = *nmTBCust\rc\bottom-1
                    rec\bottom = rec\top+1
                  Else
                    rec\left = *nmTBCust\rc\left+1
                    rec\right = *nmTBCust\rc\right-1
                    rec\top = *nmTBCust\rc\bottom-1
                    rec\bottom = rec\top+1
                  EndIf
                  If menuTitleVOffset = -1
                    rec\top = *nmTBCust\rc\top
                    rec\bottom = rec\top+1
                  EndIf
                  FillRect_(*nmTBCust\hdc, rec, getMenuColour(menuex()\style, #menuHeldColor))
                  
                  colour = getMenuColour(5, #menuDropShadow)
                  Alpha = PeekB(@colour+3)&$FF
                  colour = RGB(Blue(colour), Green(colour), Red(colour))
                  
                  addTitleDropShadow()

                EndIf
                
                oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
                
                If menuex()\active = 0
                  SetTextColor_(*nmTBCust\hdc, getMenuColour(5, #menuTitleHotTextColor))
                Else
                  SetTextColor_(*nmTBCust\hdc, getMenuColour(5, #menuTitleHeldTextColor))
                EndIf
                SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)

                *nmTBCust\rc\bottom = *nmTBCust\rc\bottom + 1
                DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
                
                SelectObject_(*nmTBCust\hdc, oldFont)
                
                Result = #CDRF_SKIPDEFAULT
              EndIf
              
              ;- office 2003 Style
              If menuex()\style = 6
                      
                If menuex()\active = 0
                  
                  rec.RECT
                  rec\left = *nmTBCust\rc\left+1
                  rec\right = *nmTBCust\rc\right-1
                  rec\top = *nmTBCust\rc\top+1
                  rec\bottom = *nmTBCust\rc\bottom-1
                  blitEx(*nmTBCust\hdc, #UISTYLE_OFFICE2003, #menuHotGradientColor1, @rec, #ForceVerticalRedraw)
                  
                  border = getMenuColourEx(6, #menuHotBorder, 0)
                  FrameRect_(*nmTBCust\hdc, *nmTBCust\rc, border)
                  
                Else
                  ;- draw selected menu held state
                  
                  border = getMenuColourEx(6, #menuHeldBorder, 0)
                  
                  ;If tbButtonChange = #True
                  ;*nmTBCust\rc\bottom = *nmTBCust\rc\bottom-1
                  FrameRect_(*nmTBCust\hdc, *nmTBCust\rc, border)
                  
                  ; draw background line where menu join is going to be inorder to stop flickering of seam and smother fade
                  If menuWindowXpos > menuTitleXpos
                    rec\left = *nmTBCust\rc\left+(menuWindowXpos-menuTitleXpos)
                    rec\right = rec\left+(menuTitleWidth-(menuWindowXpos-menuTitleXpos))-1
                    rec\top = *nmTBCust\rc\bottom-1
                    rec\bottom = rec\top+1
                  ElseIf menuTitleXpos+menuTitleWidth > menuWindowXpos+menuWindowWidth
                    rec\left = *nmTBCust\rc\left+1
                    rec\right = rec\left+menuTitleWidth-((menuTitleXpos+menuTitleWidth)-(menuWindowXpos+menuWindowWidth))-1
                    rec\top = *nmTBCust\rc\bottom-1
                    rec\bottom = rec\top+1
                  Else
                    rec\left = *nmTBCust\rc\left+1
                    rec\right = *nmTBCust\rc\right-1
                    rec\top = *nmTBCust\rc\bottom-1
                    rec\bottom = rec\top+1
                  EndIf
                  If menuTitleVOffset = -1
                    rec\top = *nmTBCust\rc\top
                    rec\bottom = rec\top+1
                  EndIf
                  FillRect_(*nmTBCust\hdc, rec, getMenuColourEx(6, #menuHeldGradientColor2, 0))
                  
                  rec.RECT
                  rec\left = *nmTBCust\rc\left+1
                  rec\right = *nmTBCust\rc\right-1
                  rec\top = *nmTBCust\rc\top+1
                  rec\bottom = *nmTBCust\rc\bottom-1
                  blitEx(*nmTBCust\hdc, #UISTYLE_OFFICE2003, #menuHeldGradientColor1, @rec, #ForceVerticalRedraw)
                  ;*nmTBCust\rc\bottom = *nmTBCust\rc\bottom+1
                  
                  colour = getMenuColourEx(6, #menuDropShadow, #returnColour)
                  Alpha = PeekB(@colour+3)&$FF
                  colour = RGB(Blue(colour), Green(colour), Red(colour))
                  
                  addTitleDropShadow()
                  
                EndIf
                
                oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
                
                If menuex()\active = 0
                  SetTextColor_(*nmTBCust\hdc, getMenuColourEx(6, #menuTitleHotTextColor, #returnColour))
                Else
                  SetTextColor_(*nmTBCust\hdc, getMenuColourEx(6, #menuTitleHeldTextColor, #returnColour))
                EndIf
                SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
                
                ;*nmTBCust\rc\bottom = *nmTBCust\rc\bottom + 1
                DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
                
                SelectObject_(*nmTBCust\hdc, oldFont)
                
                Result = #CDRF_SKIPDEFAULT
              EndIf
              
              ;- office 2007 Style
              If menuex()\style = #UISTYLE_OFFICE2007

                If menuex()\active = 0
                  
                  rec.RECT
                  rec\left = *nmTBCust\rc\left+1
                  rec\right = *nmTBCust\rc\right-1
                  rec\top = *nmTBCust\rc\top+1
                  rec\bottom = *nmTBCust\rc\bottom-1
                  blitEx(*nmTBCust\hdc, #UISTYLE_OFFICE2007, #menuHotGradientColor1, @rec, #ForceVerticalRedraw)
                  
                  border = getMenuColourEx(#UISTYLE_OFFICE2007, #menuHotBorder, 0)
                  FrameRect_(*nmTBCust\hdc, *nmTBCust\rc, border)
                  
                Else
                  ;- draw selected menu held state
                  
                  border = getMenuColourEx(#UISTYLE_OFFICE2007, #menuHeldBorder, 0)
                  
                  ;If tbButtonChange = #True
                  ;*nmTBCust\rc\bottom = *nmTBCust\rc\bottom-1
                  FrameRect_(*nmTBCust\hdc, *nmTBCust\rc, border)
                  
                  ; draw background line where menu join is going to be inorder to stop flickering of seam and smother fade
                  If menuWindowXpos > menuTitleXpos
                    rec\left = *nmTBCust\rc\left+(menuWindowXpos-menuTitleXpos)
                    rec\right = rec\left+(menuTitleWidth-(menuWindowXpos-menuTitleXpos))-1
                    rec\top = *nmTBCust\rc\bottom-1
                    rec\bottom = rec\top+1
                  ElseIf menuTitleXpos+menuTitleWidth > menuWindowXpos+menuWindowWidth
                    rec\left = *nmTBCust\rc\left+1
                    rec\right = rec\left+menuTitleWidth-((menuTitleXpos+menuTitleWidth)-(menuWindowXpos+menuWindowWidth))-1
                    rec\top = *nmTBCust\rc\bottom-1
                    rec\bottom = rec\top+1
                  Else
                    rec\left = *nmTBCust\rc\left+1
                    rec\right = *nmTBCust\rc\right-1
                    rec\top = *nmTBCust\rc\bottom-1
                    rec\bottom = rec\top+1
                  EndIf
                  If menuTitleVOffset = -1
                    rec\top = *nmTBCust\rc\top
                    rec\bottom = rec\top+1
                  EndIf
                  FillRect_(*nmTBCust\hdc, rec, getMenuColourEx(#UISTYLE_OFFICE2007, #menuHeldGradientColor2, 0))
                  
                  rec.RECT
                  rec\left = *nmTBCust\rc\left+1
                  rec\right = *nmTBCust\rc\right-1
                  rec\top = *nmTBCust\rc\top+1
                  rec\bottom = *nmTBCust\rc\bottom-1
                  blitEx(*nmTBCust\hdc, #UISTYLE_OFFICE2007, #menuHeldGradientColor1, @rec, #ForceVerticalRedraw)
                  ;*nmTBCust\rc\bottom = *nmTBCust\rc\bottom+1
                  
                  colour = getMenuColourEx(#UISTYLE_OFFICE2007, #menuDropShadow, #returnColour)
                  Alpha = PeekB(@colour+3)&$FF
                  colour = RGB(Blue(colour), Green(colour), Red(colour))
                  
                  addTitleDropShadow()
                  
                EndIf
                
                oldFont = SelectObject_(*nmTBCust\hdc, currentMenuEXFont)
                
                If menuex()\active = 0
                  SetTextColor_(*nmTBCust\hdc, getMenuColourEx(#UISTYLE_OFFICE2007, #menuTitleHotTextColor, #returnColour))
                Else
                  SetTextColor_(*nmTBCust\hdc, getMenuColourEx(#UISTYLE_OFFICE2007, #menuTitleHeldTextColor, #returnColour))
                EndIf
                SetBkMode_(*nmTBCust\hdc, #TRANSPARENT)
                
                ;*nmTBCust\rc\bottom = *nmTBCust\rc\bottom + 1
                DrawText_(*nmTBCust\hdc, buttontxt, Len(buttontxt), *nmTBCust\rc, #DT_VCENTER | #DT_SINGLELINE | #DT_CENTER)
                
                SelectObject_(*nmTBCust\hdc, oldFont)
                
                Result = #CDRF_SKIPDEFAULT
              EndIf 
              
            Else
              Result = #CDRF_DODEFAULT
            EndIf
          EndIf
          
          UnlockMutex(menuMutex)
          
        EndIf
        
      EndIf

      
      ;- handle drawing of menu items
    Case #WM_MEASUREITEM
      
      *mitem.MEASUREITEMSTRUCT = lParam
      If *mitem\CtlType = #ODT_MENU

        hdc = CreateCompatibleDC_(0)
        
        *mitem\itemHeight = measureMenuItemHeight(hdc, *mitem\itemData)
        
        GetObject_(currentMenuEXFont, SizeOf(LOGFONT), @fontnfo.LOGFONT)
        fheight = fontnfo\lfHeight
        fheight = fontnfo\lfHeight: If fheight<0: fheight = -fheight: EndIf
        fheight*72.0/GetScreenDPI()
        
        DeleteDC_(hdc)
        
        If menuScrollHandle <> 0
          *mitem\itemWidth = menuScrollWidth
          If subMenuActive = #True
            menuSideBarPadding = calcSidebarPadding(fheight)-2
            *mitem\itemWidth = measureMenuWidth(*mitem\itemData)
          EndIf
        Else
          menuSideBarPadding = calcSidebarPadding(fheight)-2
          *mitem\itemWidth = measureMenuWidth(*mitem\itemData)
        EndIf

      EndIf
      

    Case #WM_DRAWITEM

      *item.DRAWITEMSTRUCT = lParam
      
      If *item\CtlType = #ODT_MENU And *item\itemData <> 0
        
        ; stop drawing when scrolling active
        If menuScrolling = #True Or menuActive = #True
          ProcedureReturn 0
        EndIf
        
        LockMutex(menuMutex)
        
        ChangeCurrentElement(itemex(), *item\itemData)
        
        found = 0
        ForEach menuex()
          If itemex()\menuex = @menuex()
            found = -1
            Break
          EndIf
        Next

        ; activate item background erasing once menu has been displayed
        If menuDraw = -1
          menuDraw = #True
        EndIf
        If menuDraw = 0 And itemex()\pos = GetMenuItemCount_(menuex()\popupid)-1
          menuDraw = -1
        EndIf
        
        If menuWholeBuffered = #True And itemex()\pos = 0 And *item\itemState & #ODS_SELECTED
          menuSelectedNoBuffer = #True
        ElseIf menuWholeBuffered = #True And itemex()\pos = 0 And Not *item\itemState & #ODS_SELECTED
          menuSelectedNoBuffer = #False
        EndIf
        
        If menuWholeBuffered = #True And menuex()\bufferWidth = menuex()\measuredWidth And menuex()\bufferHeight = menuex()\measuredHeight And Not *item\itemState & #ODS_SELECTED
          If (menuDraw = 0 Or menuDraw = -1) And menuex()\hdc <> 0 And itemex()\pos = 0
            If menuDraw = -1
              menuDraw = #True
            EndIf
            width = GetSystemMetrics_(#SM_CXMENUCHECK)+2
            ExcludeClipRect_(*item\hdc, *item\rcItem\right-width,*item\rcItem\top, *item\rcItem\right, *item\rcItem\bottom-1)
            UnlockMutex(menuMutex)
            ProcedureReturn 0
          ElseIf (menuDraw = 0 Or menuDraw = -1) And menuex()\hdc <> 0
            If menuDraw = -1
              menuDraw = #True
            EndIf
            width = GetSystemMetrics_(#SM_CXMENUCHECK)+2
            ExcludeClipRect_(*item\hdc, *item\rcItem\right-width,*item\rcItem\top, *item\rcItem\right, *item\rcItem\bottom-1)
            UnlockMutex(menuMutex)
            ProcedureReturn 0
          EndIf
        EndIf

        borderwidth = itemex()\imageWidth+menuSideBarPadding
        
        ; add 5 pixels to borderwidth for classic styles vista/windows 7
        If menuex()\style < #UISTYLE_WHIDBEY
          borderwidth = borderwidth + 5
        ; add 2 pixels to borderwidth for 2007 style
        ElseIf menuex()\style = #UISTYLE_OFFICE2007
          borderwidth = borderwidth + 2
        EndIf
        
        If menuex()\root = #True
          If menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2003 Or menuex()\style = #UISTYLE_OFFICE2007
            *item\rcItem\right = menuex()\measuredWidth-4
          Else
            *item\rcItem\right = menuex()\measuredWidth-6
          EndIf
        EndIf
        
        ;debuglog(Str(*item\itemState))
        
        ;- draw selected item
        If *item\itemState & #ODS_SELECTED And Not *item\itemState & #ODS_DISABLED And *item\itemState <> 7 ;Or *item\itemState = 7
        
          ;/ office xp whibey Style
          If menuex()\style = 5
            
            top = *item\rcItem\top  ; used with separator key nav skipping
            
            ; activate double buffering if the whole menu has been rendered once
            If menuDraw = #True
              ; set up double buffering
              iX = *item\rcItem\left
              iY = *item\rcItem\top
              iWidth = *item\rcItem\right - *item\rcItem\left
              iHeight = *item\rcItem\bottom - *item\rcItem\top
              iHDC = *item\hdc
              Buffer = CreateCompatibleDC_(*item\hdc)
              BufferBitmap = CreateCompatibleBitmap_(*item\hdc, iWidth, iHeight)
              SelectObject_(Buffer, BufferBitmap)
              *item\rcItem\left = 0
              *item\rcItem\right = iWidth
              *item\rcItem\top = 0
              *item\rcItem\bottom = iHeight
              *item\hdc = Buffer
            EndIf
            
            ; item is a special scroll button
            If itemex()\scroll < 0
              
              
              ; fill background to right of bar
              rec.RECT
              rec\left = *item\rcItem\left+borderwidth+1
              rec\right = *item\rcItem\right
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom
              colour = getMenuColour(menuex()\style, #background)
              FillRect_(*item\hdc, rec, colour)
              
              ; draw bar
              rec.RECT
              rec\left = *item\rcItem\left
              rec\right = *item\rcItem\left+borderwidth+1
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom
              colour = getMenuColour(menuex()\style, #menuBarColor)
              FillRect_(*item\hdc, rec, colour)
              
              
              If itemex()\scroll <> -3  ; if not filler draw up/down triangle
                w.f = Round((GetSystemMetrics_(#SM_CXMENUCHECK)/2)/2, #PB_Round_Down)
                width = w*2
                height = Round(width*0.5, #PB_Round_Up)
                
                pen = CreatePen_(#PS_SOLID, 0, RGB(0,0,0))
                fill = CreateSolidBrush_(RGB(0,0,0))
                oldpen = SelectObject_(*item\hdc, pen)
                oldfill = SelectObject_(*item\hdc, fill)
                
                Dim pnt.POINT(3)
                x = Round((*item\rcItem\right/2)-(width/2), #PB_Round_Down)
                y = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(height/2)
                
                If itemex()\scroll = -2
                  y = y + 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y
                  pnt(1)\x = x
                  pnt(1)\y = y+height
                  pnt(2)\x = x+width
                  pnt(2)\y = y+height
                ElseIf itemex()\scroll = -1
                  y = y - 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y+height
                  pnt(1)\x = x
                  pnt(1)\y = y
                  pnt(2)\x = x+width
                  pnt(2)\y = y
                EndIf
                Polygon_(*item\hdc, @pnt(), 3)
                
                SelectObject_(*item\hdc, oldpen)
                SelectObject_(*item\hdc, oldfill)
                DeleteObject_(fill)
                DeleteObject_(pen)
              
              EndIf
              
              ; if entire menu has been drawn once then doublebuffer blit
              If menuDraw = #True
                BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
              EndIf
            
            ; menu item is a separator bar
            ElseIf itemex()\text = ""
              
              ; inject keyboard up/down for selection to skip separator bar
              If lastMenuKeyboard = #True
                If top < lastMenuYPos
                  keybd_event_(#VK_UP, 0, 0, 0) 
                Else
                  keybd_event_(#VK_DOWN, 0, 0, 0) 
                EndIf
              EndIf
              lastMenuYPos = top
            
            Else
            ; selected menu style
 
              ; draw line of background bellow selection box
              rec.RECT
              rec\left = *item\rcItem\left+borderwidth+1
              rec\right = *item\rcItem\right
              rec\top = *item\rcItem\bottom-1
              rec\bottom = *item\rcItem\bottom
              colour = getMenuColour(menuex()\style, #background)
              FillRect_(*item\hdc, rec, colour)
              
              ; draw selected box
              rec.RECT
              rec\left = *item\rcItem\left
              rec\right = *item\rcItem\right
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom-1
              colour = getMenuColour(menuex()\style, #selectedColor)
              border = getMenuColour(menuex()\style, #selectedBorder)
              FrameRect_(*item\hdc, rec, border)
              rec\left = *item\rcItem\left+1
              rec\right = *item\rcItem\right-1
              rec\top = *item\rcItem\top+1
              rec\bottom = *item\rcItem\bottom-2
              FillRect_(*item\hdc, rec, colour)

              ; draw the text
              rec.RECT
              rec\left = *item\rcItem\left+borderwidth+9
              rec\right = *item\rcItem\right+borderwidth+9
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom-1
              SetTextColor_(*item\hdc, getMenuColour(menuex()\style, #selectedTextColor))
              renderItemText(0)
              
              ; draw 1 pixel line bar fill below
              rec.RECT
              rec\left = *item\rcItem\left
              rec\right = *item\rcItem\left+borderwidth+1
              rec\top = *item\rcItem\bottom-1
              rec\bottom = *item\rcItem\bottom
              colour = getMenuColour(menuex()\style, #menuBarColor)
              FillRect_(*item\hdc, rec, colour)
              
              ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)+1 
              
              ; does this item have a checkmark
              If *item\itemState & #ODS_CHECKED
                
                borderwidth = borderwidth+1
                boxsize = itemex()\imageWidth+4
                
                If itemex()\radiocheck = #True And itemex()\checkIcon = #False
                  ImageList_Draw_(bulleticon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(7/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), #ILD_TRANSPARENT)
                Else
                  rc.RECT
                  rc\left = *item\rcItem\left+(borderwidth/2)-(boxsize/2)
                  rc\top = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(boxsize/2)
                  rc\right = rc\left+boxsize
                  rc\bottom = rc\top + boxsize
                  
                  colour = getMenuColour(menuex()\style, #menuCheckboxSelectedBackground)
                  border = getMenuColour(menuex()\style, #menuCheckboxSelectedBorder)
                  
                  FrameRect_(*item\hdc, rc, border)
                  rc\left = rc\left+1
                  rc\right = rc\right-1
                  rc\top = rc\top+1
                  rc\bottom = rc\bottom-1
                  FillRect_(*item\hdc, rc, colour)
                  
                  If itemex()\checkIcon = #True
                    If itemex()\hot = -1
                      ImageList_Draw_(itemex()\ImageList, 1, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos-1, #ILD_TRANSPARENT)
                    ElseIf itemex()\normal = -1
                      ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos-1, #ILD_TRANSPARENT)
                    EndIf
                  Else
                    ImageList_Draw_(tickicon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(8/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2)-1, #ILD_TRANSPARENT) 
                  EndIf
                EndIf
                
              Else
                If itemex()\hot = -1
                  ImageList_Draw_(itemex()\ImageList, 1, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos-2, #ILD_TRANSPARENT)
                ElseIf itemex()\normal = -1
                  ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos-2, #ILD_TRANSPARENT)
                EndIf
              EndIf
              
              ; if entire menu has been drawn once then doublebuffer blit
              If menuDraw = #True
                BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
                *item\hdc = iHDC
                *item\rcItem\left = iX
                *item\rcItem\right = iX+iWidth
                *item\rcItem\top = iY
                *item\rcItem\bottom = iY+iHeight
              EndIf
              
              lastMenuYPos = top
              
              ; if this item is a submenu draw black arrow icon
              renderSubArrow()
              
            EndIf
            
            ; free double buffer resources
            If menuDraw = #True
              DeleteDC_(Buffer)
              DeleteObject_(BufferBitmap)
            EndIf
          
          ;/ office 2003/2007 style
          ElseIf menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2007
            
            top = *item\rcItem\top  ; used with separator key nav skipping
            
            ; activate double buffering if the whole menu has been rendered once
            If menuDraw = #True
              ; set up double buffering
              iX = *item\rcItem\left+1
              iY = *item\rcItem\top
              iWidth = *item\rcItem\right - *item\rcItem\left
              iHeight = *item\rcItem\bottom - *item\rcItem\top-1
              iHDC = *item\hdc
              Buffer = CreateCompatibleDC_(*item\hdc)
              BufferBitmap = CreateCompatibleBitmap_(*item\hdc, iWidth, iHeight)
              SelectObject_(Buffer, BufferBitmap)
              *item\rcItem\left = 0
              *item\rcItem\right = iWidth
              *item\rcItem\top = 0
              *item\rcItem\bottom = iHeight+1
              *item\hdc = Buffer
            Else
              *item\rcItem\left = *item\rcItem\left + 1
              *item\rcItem\right = *item\rcItem\right + 1
            EndIf
            
            ; item is a special scroll button
            If itemex()\scroll < 0
              
              If menuDraw = #True
                ; fill background to right of bar
                rec.RECT
                rec\left = *item\rcItem\left+borderwidth+1
                rec\right = *item\rcItem\right
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                colour = getMenuColourEx(menuex()\style, #background, 0)
                FillRect_(*item\hdc, rec, colour)
                
                ; draw bar
                rec.RECT
                rec\left = *item\rcItem\left-1
                rec\right = *item\rcItem\left+borderwidth+1
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                blitEx(*item\hdc, menuex()\style, #menuBarColor, @rec, #ForceHorizontalRedraw)
              EndIf
              
              If itemex()\scroll <> -3  ; if not filler draw up/down triangle
                w.f = Round((GetSystemMetrics_(#SM_CXMENUCHECK)/2)/2, #PB_Round_Down)
                width = w*2
                height = Round(width*0.5, #PB_Round_Up)
                
                pen = CreatePen_(#PS_SOLID, 0, RGB(0,0,0))
                fill = CreateSolidBrush_(RGB(0,0,0))
                oldpen = SelectObject_(*item\hdc, pen)
                oldfill = SelectObject_(*item\hdc, fill)
                
                If menuDraw = #True
                  *item\rcItem\right = *item\rcItem\right - 1
                EndIf
                
                Dim pnt.POINT(3)
                x = Round((*item\rcItem\right/2)-(width/2), #PB_Round_Down)
                y = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(height/2)
                
                If itemex()\scroll = -2
                  y = y + 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y
                  pnt(1)\x = x
                  pnt(1)\y = y+height
                  pnt(2)\x = x+width
                  pnt(2)\y = y+height
                ElseIf itemex()\scroll = -1
                  y = y - 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y+height
                  pnt(1)\x = x
                  pnt(1)\y = y
                  pnt(2)\x = x+width
                  pnt(2)\y = y
                EndIf
                Polygon_(*item\hdc, @pnt(), 3)
                
                SelectObject_(*item\hdc, oldpen)
                SelectObject_(*item\hdc, oldfill)
                DeleteObject_(fill)
                DeleteObject_(pen)
             
              EndIf
              
              ; if entire menu has been drawn once then doublebuffer blit
              If menuDraw = #True
                BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
              EndIf
            
            ; menu item is a separator bar
            ElseIf itemex()\text = ""
              
              ; inject keyboard up/down for selection to skip separator bar
              If lastMenuKeyboard = #True
                If top < lastMenuYPos
                  keybd_event_(#VK_UP, 0, 0, 0) 
                Else
                  keybd_event_(#VK_DOWN, 0, 0, 0) 
                EndIf
              EndIf
              lastMenuYPos = top
              
            Else
              ;selected menu style

              ; draw selection box
              rec.RECT
              rec\left = *item\rcItem\left
              rec\right = *item\rcItem\right
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom-1
              
              colour = getMenuColourEx(menuex()\style, #selectedColor, 0)
              border = getMenuColourEx(menuex()\style, #selectedBorder, 0)
              
              FrameRect_(*item\hdc, rec, border)
              rec\left = rec\left+1
              rec\right = rec\right-1
              rec\top = rec\top+1
              rec\bottom = rec\bottom-1
              FillRect_(*item\hdc, rec, colour)
              
              ; draw text
              SetTextColor_(*item\hdc, getMenuColourEx(menuex()\style, #selectedTextColor, #returnColour))
              rec.RECT
              rec\left = *item\rcItem\left+borderwidth+9
              rec\right = *item\rcItem\right+borderwidth+9
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom-1
              renderItemText(0)
              
              ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)

              ; does this item have a checkmark
              If *item\itemState & #ODS_CHECKED
                
                borderwidth = borderwidth+1
                boxsize = itemex()\imageWidth+4
                
                If itemex()\radiocheck = #True And itemex()\checkIcon = #False
                  ImageList_Draw_(bulleticon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(7/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), #ILD_TRANSPARENT)
                Else
                  rc.RECT
                  rc\left = *item\rcItem\left+(borderwidth/2)-(boxsize/2)
                  rc\top = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(boxsize/2)
                  rc\right = rc\left+boxsize
                  rc\bottom = rc\top + boxsize
                  blitEx(*item\hdc, menuex()\style, #menuCheckboxSelectedBorder, @rc, #ForceRedraw)
                  
                  If itemex()\checkIcon = #True
                    If itemex()\hot = -1
                      ImageList_Draw_(itemex()\ImageList, 1, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos, #ILD_TRANSPARENT)
                    ElseIf itemex()\normal = -1
                      ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos, #ILD_TRANSPARENT)
                    EndIf
                  Else
                    ImageList_Draw_(tickicon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(8/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2)-1, #ILD_TRANSPARENT) 
                  EndIf
                EndIf
                
              Else
                If itemex()\hot = -1
                  ImageList_Draw_(itemex()\ImageList, 1, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos, #ILD_TRANSPARENT)
                ElseIf itemex()\normal = -1
                  ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos, #ILD_TRANSPARENT)
                EndIf
              EndIf
              
              ; if entire menu has been drawn once then doublebuffer blit
              If menuDraw = #True
                BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
                *item\hdc = iHDC
                *item\rcItem\left = iX
                *item\rcItem\right = iX+iWidth
                *item\rcItem\top = iY
                *item\rcItem\bottom = iY+iHeight+1
              EndIf
              
              lastMenuYPos = top
              
              ; if this item is a submenu draw black arrow icon
              renderSubArrow()
              
            EndIf
            
            ; free double buffer resources
            If menuDraw = #True
              DeleteDC_(Buffer)
              DeleteObject_(BufferBitmap)
            EndIf

          ;/ classic styles
          Else
            
            ; item is a special scroll button
            If itemex()\scroll < 0
              
              FillRect_(*item\hdc, *item\rcItem, GetSysColorBrush_(#COLOR_MENU))
              
              If itemex()\scroll <> -3  ; if not filler draw up/down triangle
                w.f = Round((GetSystemMetrics_(#SM_CXMENUCHECK)/2)/2, #PB_Round_Down)
                width = w*2
                height = Round(width*0.5, #PB_Round_Up)
                
                pen = CreatePen_(#PS_SOLID, 0, RGB(0,0,0))
                fill = CreateSolidBrush_(RGB(0,0,0))
                oldpen = SelectObject_(*item\hdc, pen)
                oldfill = SelectObject_(*item\hdc, fill)
                
                Dim pnt.POINT(3)
                x = Round((*item\rcItem\right/2)-(width/2), #PB_Round_Down)
                y = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(height/2)
                
                If itemex()\scroll = -2
                  y = y + 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y
                  pnt(1)\x = x
                  pnt(1)\y = y+height
                  pnt(2)\x = x+width
                  pnt(2)\y = y+height
                ElseIf itemex()\scroll = -1
                  y = y - 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y+height
                  pnt(1)\x = x
                  pnt(1)\y = y
                  pnt(2)\x = x+width
                  pnt(2)\y = y
                EndIf
                Polygon_(*item\hdc, @pnt(), 3)
                
                SelectObject_(*item\hdc, oldpen)
                SelectObject_(*item\hdc, oldfill)
                DeleteObject_(fill)
                DeleteObject_(pen)
                
              EndIf
              
            
            ; menu item is a separator bar
            ElseIf itemex()\text = ""
              
              ; inject keyboard up/down for selection to skip separator bar
              If lastMenuKeyboard = #True
                If *item\rcItem\top < lastMenuYPos
                  keybd_event_(#VK_UP, 0, 0, 0) 
                Else
                  keybd_event_(#VK_DOWN, 0, 0, 0) 
                EndIf
              EndIf
              lastMenuYPos = *item\rcItem\top
              
            Else  ; normal
              
              ; vista/windows 7 classic style
              If ThemesEnabled = #True And (Comctl32MajorVersion > 6 Or (Comctl32MajorVersion = 6 And Comctl32MinorVersion > 0))
                CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 9, 1, *item\rcItem, 0)
                
                ; draw bar
                rec.RECT
                rec\left = *item\rcItem\left
                rec\right = *item\rcItem\left+borderwidth+1
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 13, 1, rec, 0)
                
                ; draw selection
                CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 14, 2, *item\rcItem, 0)
                
                ;draw text
                rec\left = *item\rcItem\left+borderwidth+6
                rec\right = *item\rcItem\right+borderwidth+6
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom-1
                SetTextColor_(*item\hdc, GetSysColor_(#COLOR_MENUTEXT))
                renderItemText(0)
                
                ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)
                
                ; does this item have a checkmark
                If *item\itemState & #ODS_CHECKED
                  
                  rc.RECT
                  rc\left = *item\rcItem\left
                  rc\top = *item\rcItem\top
                  rc\right = *item\rcItem\bottom-*item\rcItem\top
                  rc\bottom = *item\rcItem\bottom
                  CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 12, 2, rc, 0)
                  
                  If itemex()\radiocheck = #True And itemex()\checkIcon = #False
                    CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 11, 3, rc, 0)
                  Else
                    If itemex()\checkIcon = #True
                      If itemex()\hot = -1
                        ImageList_Draw_(itemex()\ImageList, 1, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_TRANSPARENT)
                      ElseIf itemex()\normal = -1
                        ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_TRANSPARENT)
                      EndIf
                    Else
                      CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 11, 1, rc, 0)
                    EndIf
                  EndIf
                  
                  ; draw normal icon image
                Else
                  If itemex()\hot = -1
                    ImageList_Draw_(itemex()\ImageList, 1, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_TRANSPARENT)
                  ElseIf itemex()\normal = -1
                    ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_TRANSPARENT)
                  EndIf
                EndIf
                
              Else
                
                brMenuHilight = GetSysColorBrush_(#COLOR_HIGHLIGHT)
                FillRect_(*item\hdc, *item\rcItem, brMenuHilight)
                
                rec.RECT
                rec\left = *item\rcItem\left+itemex()\imageWidth+#MENUITEMIMAGEPADX+#MENUEXITEMPADX+3
                rec\right = *item\rcItem\right+itemex()\imageWidth+#MENUITEMIMAGEPADX+#MENUEXITEMPADX+3
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                SetTextColor_(*item\hdc, GetSysColor_(#COLOR_HIGHLIGHTTEXT))
                renderItemText(0)
                
                ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)
                
                ; does this item have a checkmark
                If *item\itemState & #ODS_CHECKED
                  
                  borderwidth = itemex()\imageWidth+#MENUITEMIMAGEPADX+#MENUEXITEMPADX+1
                  
                  If itemex()\radiocheck = #True
                    ImageList_Draw_(bulleticon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(7/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), #ILD_TRANSPARENT)
                  Else
                    ImageList_Draw_(tickicon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(8/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), #ILD_TRANSPARENT) 
                  EndIf
                  
                  ; draw normal icon image
                Else
                  If itemex()\hot = -1
                    ImageList_Draw_(itemex()\ImageList, 1, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_BLEND25)
                  ElseIf itemex()\normal = -1
                    ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_BLEND25)
                  EndIf
                EndIf
                
              EndIf

              lastMenuYPos = *item\rcItem\top
              
              ; vista/windows 7 style
              If ThemesEnabled = #True And (Comctl32MajorVersion > 6 Or (Comctl32MajorVersion = 6 And Comctl32MinorVersion > 0))
                mnfo.MENUITEMINFO_Fixed
                mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
                mnfo\fMask = #MIIM_SUBMENU
                GetMenuItemInfo_(*item\hwndItem, itemex()\pos, #True, @mnfo)
                
                ; if this item is a submenu draw black arrow icon
                If mnfo\hSubMenu <> 0
                  width = GetSystemMetrics_(#SM_CXMENUCHECK)+7
                  height = (*item\rcItem\bottom-3)-(*item\rcItem\top+3)

                  rc.RECT
                  rc\left = *item\rcItem\right-width
                  rc\right = rc\left+width
                  rc\top = *item\rcItem\top+3
                  rc\bottom = rc\top+height
                  CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 16, 1, rc, 0)
                  
                  ExcludeClipRect_(*item\hdc, *item\rcItem\right-width,*item\rcItem\top, *item\rcItem\right, *item\rcItem\bottom-1)
                EndIf
              Else
                ; if this item is a submenu draw white arrow icon
                renderSubArrowColour(RGB(255,255,255))
              EndIf
              
            EndIf
          EndIf
            
        ;- draw disabled state
        ElseIf *item\itemState & #ODS_DISABLED Or *item\itemState = 7
          
          ;/ office xp whidbey Style
          If menuex()\style = 5
            
            ; activate double buffering if the whole menu has been rendered once
            If menuDraw = #True
              ; set up double buffering
              iX = *item\rcItem\left
              iY = *item\rcItem\top
              iWidth = *item\rcItem\right - *item\rcItem\left
              iHeight = *item\rcItem\bottom - *item\rcItem\top
              iHDC = *item\hdc
              Buffer = CreateCompatibleDC_(*item\hdc)
              BufferBitmap = CreateCompatibleBitmap_(*item\hdc, iWidth, iHeight)
              SelectObject_(Buffer, BufferBitmap)
              *item\rcItem\left = 0
              *item\rcItem\right = iWidth
              *item\rcItem\top = 0
              *item\rcItem\bottom = iHeight
              *item\hdc = Buffer
            EndIf

            ; fill background to right of bar
            rec.RECT
            rec\left = *item\rcItem\left+borderwidth+1
            rec\right = *item\rcItem\right
            rec\top = *item\rcItem\top
            rec\bottom = *item\rcItem\bottom
            colour = getMenuColour(menuex()\style, #background)
            FillRect_(*item\hdc, rec, colour)
            
            ; draw bar
            rec.RECT
            rec\left = *item\rcItem\left
            rec\right = *item\rcItem\left+borderwidth+1
            rec\top = *item\rcItem\top
            rec\bottom = *item\rcItem\bottom
            colour = getMenuColour(menuex()\style, #menuBarColor)
            FillRect_(*item\hdc, rec, colour)
            
            ; if keyboard navigation is enabled then draw as disabled selected
            If *item\itemState & #ODS_SELECTED And menuDisabledKeyboard = #True
              ; draw selection box
              rec.RECT
              rec\left = *item\rcItem\left
              rec\right = *item\rcItem\right
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom-1
              
              colour = getMenuColour(5, #background)
              border = getMenuColour(5, #selectedBorder)
              
              FrameRect_(*item\hdc, rec, border)
              rec\left = rec\left+1
              rec\right = rec\right-1
              rec\top = rec\top+1
              rec\bottom = rec\bottom-1
              FillRect_(*item\hdc, rec, colour)
            EndIf
            
            ; draw text
            rec\left = *item\rcItem\left+borderwidth+9
            rec\right = *item\rcItem\right+borderwidth+9
            rec\top = *item\rcItem\top
            rec\bottom = *item\rcItem\bottom-1
            SetTextColor_(*item\hdc, getMenuColour(menuex()\style, #disabledColor))
            renderItemText(#DT_OVERRIDECOLOUR)
            
            ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)
            
            ; does this item have a checkmark
            If *item\itemState & #ODS_CHECKED
              
              borderwidth = borderwidth+1
              boxsize = itemex()\imageWidth+4
              
              If itemex()\radiocheck = #True And itemex()\checkIcon = #False
                ImageList_DrawEx_(bulleticon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(7/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), 0, 0, #CLR_NONE, #CLR_NONE, #ILD_BLEND)
              Else
                rc.RECT
                rc\left = *item\rcItem\left+(borderwidth/2)-(boxsize/2)
                rc\top = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(boxsize/2)
                rc\right = rc\left+boxsize
                rc\bottom = rc\top + boxsize
                
                colour = getMenuColour(menuex()\style, #menuCheckboxDisabledBackground)
                border = getMenuColour(menuex()\style, #menuCheckboxDisabledBorder)
                
                FrameRect_(*item\hdc, rc, border)
                rc\left = rc\left+1
                rc\right = rc\right-1
                rc\top = rc\top+1
                rc\bottom = rc\bottom-1
                FillRect_(*item\hdc, rc, colour)
                
                If itemex()\checkIcon = #True
                  If itemex()\normal = -1
                    ImageList_Draw_(itemex()\ImageList, 2, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos-1, #ILD_TRANSPARENT)
                  EndIf
                Else
                  ImageList_DrawEx_(tickicon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(8/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2)-1, 0, 0, #CLR_NONE, #CLR_NONE, #ILD_BLEND)
                EndIf
              EndIf
              
            Else  ; draw disabled icon image
              If itemex()\normal = -1
                ImageList_Draw_(itemex()\ImageList, 2, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2))+1, ypos, #ILD_TRANSPARENT)
              EndIf
            EndIf
            
            ; if entire menu has been drawn once then doublebuffer blit
            If menuDraw = #True
              BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
              DeleteDC_(Buffer)
              DeleteObject_(BufferBitmap)
              *item\hdc = iHDC
              *item\rcItem\left = iX
              *item\rcItem\right = iX+iWidth
              *item\rcItem\top = iY
              *item\rcItem\bottom = iY+iHeight
            EndIf
            
            ; if this item is a submenu draw disabled greyed arrow icon
            renderSubArrowColour(getMenuColour(#UISTYLE_WHIDBEY, #disabledColor))
            
            If menuDraw = #True
              lastMenuYPos = *item\rcItem\top
            EndIf
          
          ;/ office 2003/2007 style
          ElseIf menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2007
            
            ; activate double buffering if the whole menu has been rendered once
            If menuDraw = #True
              ; set up double buffering
              iX = *item\rcItem\left+1
              iY = *item\rcItem\top
              iWidth = (*item\rcItem\right - *item\rcItem\left)+1
              iHeight = *item\rcItem\bottom - *item\rcItem\top; -1
              iHDC = *item\hdc
              Buffer = CreateCompatibleDC_(*item\hdc)
              BufferBitmap = CreateCompatibleBitmap_(*item\hdc, iWidth, iHeight)
              SelectObject_(Buffer, BufferBitmap)
              *item\rcItem\left = 0
              *item\rcItem\right = iWidth
              *item\rcItem\top = 0
              *item\rcItem\bottom = iHeight+1
              *item\hdc = Buffer
            Else
              *item\rcItem\left = *item\rcItem\left + 1
              *item\rcItem\right = *item\rcItem\right + 1
              *item\rcItem\bottom = *item\rcItem\bottom + 1
            EndIf
            
            If menuDraw = #True
              
              ; fill background to right of bar
              rec.RECT
              rec\left = *item\rcItem\left+borderwidth+1
              rec\right = *item\rcItem\right
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom
              Color = getMenuColourEx(menuex()\style, #background, 0)
              FillRect_(*item\hdc, rec, Color)
              
              ; draw bar
              rec.RECT
              rec\left = *item\rcItem\left-1
              rec\right = *item\rcItem\left+borderwidth+1
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom
              blitEx(*item\hdc, menuex()\style, #menuBarColor, @rec, #ForceHorizontalRedraw)
              
              *item\rcItem\right = *item\rcItem\right - 1
            EndIf
            *item\rcItem\bottom = *item\rcItem\bottom - 1
            
            ; if keyboard navigation is enabled then draw as disabled selected
            If *item\itemState & #ODS_SELECTED And menuDisabledKeyboard = #True
              ; draw selection box
              rec.RECT
              rec\left = *item\rcItem\left
              rec\right = *item\rcItem\right
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom-1
              
              colour = getMenuColourEx(menuex()\style, #background, 0)
              border = getMenuColourEx(menuex()\style, #selectedBorder, 0)
              
              FrameRect_(*item\hdc, rec, border)
              rec\left = rec\left+1
              rec\right = rec\right-1
              rec\top = rec\top+1
              rec\bottom = rec\bottom-1
              FillRect_(*item\hdc, rec, colour)
            EndIf

            ; draw text
            rec\left = *item\rcItem\left+borderwidth+9
            rec\right = *item\rcItem\right+borderwidth+9
            rec\top = *item\rcItem\top
            rec\bottom = *item\rcItem\bottom-1
            SetTextColor_(*item\hdc, getMenuColourEx(menuex()\style, #disabledColor, #returnColour))
            renderItemText(#DT_OVERRIDECOLOUR)
            
            ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)
            
            ; does this item have a checkmark
            If *item\itemState & #ODS_CHECKED
              
              borderwidth = borderwidth+1
              boxsize = itemex()\imageWidth+4
              
              If itemex()\radiocheck = #True And itemex()\checkIcon = #False
                ImageList_DrawEx_(bulleticon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(7/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), 0, 0, #CLR_NONE, #CLR_NONE, #ILD_BLEND)
              Else
                
                rc.RECT
                rc\left = *item\rcItem\left+(borderwidth/2)-(boxsize/2)
                rc\top = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(boxsize/2)
                rc\right = rc\left+boxsize
                rc\bottom = rc\top + boxsize
                border = getMenuColourEx(menuex()\style, #menuCheckboxDisabledBorder, 0)
                FrameRect_(*item\hdc, rc, border)
                
                If itemex()\checkIcon = #True
                  If itemex()\normal = -1
                    ImageList_Draw_(itemex()\ImageList, 2, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos-1, #ILD_TRANSPARENT)
                  EndIf
                Else
                  ImageList_DrawEx_(tickicon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(8/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2)-1, 0, 0, #CLR_NONE, #CLR_NONE, #ILD_BLEND)
                EndIf
              EndIf
              
            Else  ; draw disabled icon image
              If itemex()\normal = -1
                ImageList_Draw_(itemex()\ImageList, 2, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos, #ILD_TRANSPARENT)
              EndIf
            EndIf
            
            
            ; if entire menu has been drawn once then doublebuffer blit
            If menuDraw = #True
              BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
              DeleteDC_(Buffer)
              DeleteObject_(BufferBitmap)
              *item\hdc = iHDC
              *item\rcItem\left = iX
              *item\rcItem\right = iX+iWidth-1
              *item\rcItem\top = iY
              *item\rcItem\bottom = iY+iHeight+1
            EndIf
            
            ; if this item is a submenu draw disabled greyed arrow icon
            renderSubArrowColour(getMenuColourEx(menuex()\style, #disabledColor, #returnRGBColour))

            If menuDraw = #True
              lastMenuYPos = *item\rcItem\top
            EndIf
          
          ;/ classic styles
          Else
            
            ; activate double buffering if the whole menu has been rendered once
            If menuDraw = #True
              ; set up double buffering
              iX = *item\rcItem\left
              iY = *item\rcItem\top
              iWidth = *item\rcItem\right - *item\rcItem\left
              iHeight = *item\rcItem\bottom - *item\rcItem\top
              iHDC = *item\hdc
              Buffer = CreateCompatibleDC_(*item\hdc)
              BufferBitmap = CreateCompatibleBitmap_(*item\hdc, iWidth, iHeight)
              SelectObject_(Buffer, BufferBitmap)
              *item\rcItem\left = 0
              *item\rcItem\right = iWidth
              *item\rcItem\top = 0
              *item\rcItem\bottom = iHeight
              *item\hdc = Buffer
            EndIf
            
            ; vista/windows 7 style
            If ThemesEnabled = #True And (Comctl32MajorVersion > 6 Or (Comctl32MajorVersion = 6 And Comctl32MinorVersion > 0))
              CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 9, 1, *item\rcItem, 0)
              
              ; draw bar
              rec.RECT
              rec\left = *item\rcItem\left
              rec\right = *item\rcItem\left+borderwidth+1
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom
              CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 13, 1, rec, 0)
              
              If *item\itemState & #ODS_SELECTED
                ; draw selection box
                CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 14, 4, *item\rcItem, 0)
              EndIf
              
              ;draw text
              rec\left = *item\rcItem\left+borderwidth+6
              rec\right = *item\rcItem\right+borderwidth+6
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom-1
              SetTextColor_(*item\hdc, GetSysColor_(#COLOR_GRAYTEXT))
              renderItemText(#DT_OVERRIDECOLOUR)
              
              ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)
              
              ; does this item have a checkmark
              If *item\itemState & #ODS_CHECKED
                
                rc.RECT
                rc\left = *item\rcItem\left
                rc\top = *item\rcItem\top
                rc\right = *item\rcItem\bottom-*item\rcItem\top
                rc\bottom = *item\rcItem\bottom
                CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 12, 1, rc, 0)
                
                If itemex()\radiocheck = #True And itemex()\checkIcon = #False
                  CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 11, 4, rc, 0)
                Else
                  If itemex()\checkIcon = #True
                    If itemex()\normal = -1
                      ImageList_Draw_(itemex()\ImageList, 2, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_TRANSPARENT)
                    EndIf
                  Else
                    CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 11, 2, rc, 0)
                  EndIf
                EndIf
                
              ; draw disabled icon image
              Else
                If itemex()\normal = -1                  
                    ImageList_Draw_(itemex()\ImageList, 2, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_TRANSPARENT)
                EndIf
              EndIf

            Else
              FillRect_(*item\hdc, *item\rcItem, GetSysColorBrush_(#COLOR_MENU))
              
              ; if keyboard navigation is enabled then draw as disabled selected
              If *item\itemState & #ODS_SELECTED And menuDisabledKeyboard = #True
                ; draw selection box
                FrameRect_(*item\hdc, *item\rcItem, GetSysColorBrush_(#COLOR_MENUHILIGHT))
              EndIf
              
              rec.RECT
              rec\left = *item\rcItem\left+itemex()\imageWidth+#MENUITEMIMAGEPADX+#MENUEXITEMPADX+3+1
              rec\right = *item\rcItem\right+itemex()\imageWidth+#MENUITEMIMAGEPADX+#MENUEXITEMPADX+3+1
              rec\top = *item\rcItem\top+1
              rec\bottom = *item\rcItem\bottom+1
              SetTextColor_(*item\hdc, GetSysColor_(#COLOR_3DHIGHLIGHT))
              renderItemText(#DT_OVERRIDECOLOUR)
              rec\left = *item\rcItem\left+itemex()\imageWidth+#MENUITEMIMAGEPADX+#MENUEXITEMPADX+3
              rec\right = *item\rcItem\right+itemex()\imageWidth+#MENUITEMIMAGEPADX+#MENUEXITEMPADX+3
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom
              SetTextColor_(*item\hdc, GetSysColor_(#COLOR_GRAYTEXT))
              renderItemText(#DT_OVERRIDECOLOUR)
              
              ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)
              
              ; does this item have a checkmark
              If *item\itemState & #ODS_CHECKED
                
                borderwidth = itemex()\imageWidth+#MENUITEMIMAGEPADX+#MENUEXITEMPADX+1
                
                If itemex()\radiocheck = #True
                  ImageList_DrawEx_(bulleticon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(8/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), 0, 0, #CLR_NONE, #CLR_NONE, #ILD_BLEND)
                Else
                  ImageList_DrawEx_(tickicon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(8/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), 0, 0, #CLR_NONE, #CLR_NONE, #ILD_BLEND)
                EndIf
                
              ; draw disabled icon image
              Else
                If itemex()\normal = -1
                  ImageList_Draw_(itemex()\ImageList, 2, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_TRANSPARENT)
                EndIf
              EndIf
              
              
            EndIf

            
            ; if entire menu has been drawn once then doublebuffer blit
            If menuDraw = #True
              BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
              DeleteDC_(Buffer)
              DeleteObject_(BufferBitmap)
              *item\hdc = iHDC
              *item\rcItem\left = iX
              *item\rcItem\right = iX+iWidth
              *item\rcItem\top = iY
              *item\rcItem\bottom = iY+iHeight
            EndIf
            
            ; if this item is a submenu draw disabled greyed arrow icon
            renderSubArrowColour(GetSysColor_(#COLOR_GRAYTEXT))
            
            If menuDraw = #True
              lastMenuYPos = *item\rcItem\top
            EndIf
            
          EndIf
            
        ;- draw whole unselected item
        Else
          
          ;/ office xp whidbey Style
          If menuex()\style = 5
            
            ; activate double buffering if the whole menu has been rendered once
            If menuDraw = #True
              ; set up double buffering
              iX = *item\rcItem\left
              iY = *item\rcItem\top
              iWidth = *item\rcItem\right - *item\rcItem\left
              iHeight = *item\rcItem\bottom - *item\rcItem\top
              iHDC = *item\hdc
              Buffer = CreateCompatibleDC_(*item\hdc)
              BufferBitmap = CreateCompatibleBitmap_(*item\hdc, iWidth, iHeight)
              SelectObject_(Buffer, BufferBitmap)
              *item\rcItem\left = 0
              *item\rcItem\right = iWidth
              *item\rcItem\top = 0
              *item\rcItem\bottom = iHeight
              *item\hdc = Buffer
            EndIf
            
            ; item is a special scroll button
            If itemex()\scroll < 0
              
              
              ; fill background to right of bar
              rec.RECT
              rec\left = *item\rcItem\left+borderwidth+1
              rec\right = *item\rcItem\right
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom
              colour = getMenuColour(menuex()\style, #background)
              FillRect_(*item\hdc, rec, colour)
              
              ; draw bar
              rec.RECT
              rec\left = *item\rcItem\left
              rec\right = *item\rcItem\left+borderwidth+1
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom
              colour = getMenuColour(menuex()\style, #menuBarColor)
              FillRect_(*item\hdc, rec, colour)
              
              
              If itemex()\scroll <> -3  ; if not filler draw up/down triangle
                w.f = Round((GetSystemMetrics_(#SM_CXMENUCHECK)/2)/2, #PB_Round_Down)
                width = w*2
                height = Round(width*0.5, #PB_Round_Up)
                
                pen = CreatePen_(#PS_SOLID, 0, RGB(0,0,0))
                fill = CreateSolidBrush_(RGB(0,0,0))
                oldpen = SelectObject_(*item\hdc, pen)
                oldfill = SelectObject_(*item\hdc, fill)
                
                Dim pnt.POINT(3)
                x = Round((*item\rcItem\right/2)-(width/2), #PB_Round_Down)
                y = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(height/2)
                
                If itemex()\scroll = -2
                  y = y + 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y
                  pnt(1)\x = x
                  pnt(1)\y = y+height
                  pnt(2)\x = x+width
                  pnt(2)\y = y+height
                ElseIf itemex()\scroll = -1
                  y = y - 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y+height
                  pnt(1)\x = x
                  pnt(1)\y = y
                  pnt(2)\x = x+width
                  pnt(2)\y = y
                EndIf
                Polygon_(*item\hdc, @pnt(), 3)
                
                SelectObject_(*item\hdc, oldpen)
                SelectObject_(*item\hdc, oldfill)
                DeleteObject_(fill)
                DeleteObject_(pen)
                
              EndIf
              
              ; if entire menu has been drawn once then doublebuffer blit
              If menuDraw = #True
                BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
              EndIf
            
            ; menu item is a separator bar
            ElseIf itemex()\text = ""
              
              ; fill left of separator with background
              rec.RECT
              rec\left = *item\rcItem\left+borderwidth+1
              rec\right = *item\rcItem\left+borderwidth+9
              rec\top = *item\rcItem\top
              rec\bottom = rec\top+1
              colour = getMenuColour(menuex()\style, #background)
              FillRect_(*item\hdc, rec, colour)
              ; fill 1 pixel at right of separator with background
              rec\left = *item\rcItem\right-1
              rec\right = rec\left+1
              FillRect_(*item\hdc, rec, colour)
              ; fill line below separator with background
              rec\left = *item\rcItem\left+borderwidth+1
              rec\right = *item\rcItem\right
              rec\top = *item\rcItem\top+1
              rec\bottom = rec\top+1
              FillRect_(*item\hdc, rec, colour)
              
              ; draw left bar
              rec.RECT
              rec\left = *item\rcItem\left
              rec\right = *item\rcItem\left+borderwidth+1
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom
              colour = getMenuColour(menuex()\style, #menuBarColor)
              FillRect_(*item\hdc, rec, colour)
              
              ; draw separator
              rec.RECT
              rec\left = *item\rcItem\left+borderwidth+9
              rec\right = *item\rcItem\right-1
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\top+1
              colour = getMenuColour(menuex()\style, #separatorBar)
              FillRect_(*item\hdc, rec, colour)
              
              If menuDraw = #True
                BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
              EndIf
              
            Else
              ; menu item is a normal item
              
              ; fill background to right of bar
              rec.RECT
              rec\left = *item\rcItem\left+borderwidth+1
              rec\right = *item\rcItem\right
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom
              colour = getMenuColour(menuex()\style, #background)
              FillRect_(*item\hdc, rec, colour)
              
              ; draw bar
              rec.RECT
              rec\left = *item\rcItem\left
              rec\right = *item\rcItem\left+borderwidth+1
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom
              colour = getMenuColour(menuex()\style, #menuBarColor)
              FillRect_(*item\hdc, rec, colour)
              
              ;draw text
              rec\left = *item\rcItem\left+borderwidth+9
              rec\right = *item\rcItem\right+borderwidth+9
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom-1
              SetTextColor_(*item\hdc, getMenuColour(menuex()\style, #menuTextColor))
              renderItemText(0)
              
              ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)+1
              
              ; does this item have a checkmark
              If *item\itemState & #ODS_CHECKED
                
                borderwidth = borderwidth+1
                boxsize = itemex()\imageWidth+4
                
                If itemex()\radiocheck = #True And itemex()\checkIcon = #False
                  ImageList_Draw_(bulleticon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(7/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), #ILD_TRANSPARENT)
                Else
                  rc.RECT
                  rc\left = *item\rcItem\left+(borderwidth/2)-(boxsize/2)
                  rc\top = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(boxsize/2)
                  rc\right = rc\left+boxsize
                  rc\bottom = rc\top + boxsize
                  
                  colour = getMenuColour(menuex()\style, #menuCheckboxBackground)
                  border = getMenuColour(menuex()\style, #menuCheckboxBorder)
                  
                  FrameRect_(*item\hdc, rc, border)
                  rc\left = rc\left+1
                  rc\right = rc\right-1
                  rc\top = rc\top+1
                  rc\bottom = rc\bottom-1
                  FillRect_(*item\hdc, rc, colour)
                  
                  If itemex()\checkIcon = #True
                    If itemex()\normal = -1
                      ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos-1, #ILD_TRANSPARENT)
                    EndIf
                  Else
                    ImageList_Draw_(tickicon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(8/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2)-1, #ILD_TRANSPARENT) 
                  EndIf
                EndIf
                
              ; draw normal icon image
              Else
                If itemex()\normal = -1
                  ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2))+1, ypos-1, #ILD_TRANSPARENT)
                EndIf
              EndIf
              
              ; if entire menu has been drawn once then doublebuffer blit
              If menuDraw = #True
                BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
                *item\hdc = iHDC
                *item\rcItem\left = iX
                *item\rcItem\right = iX+iWidth
                *item\rcItem\top = iY
                *item\rcItem\bottom = iY+iHeight
              EndIf
              
              ; if this item is a submenu draw black arrow icon
              renderSubArrow()
              
            EndIf
            
            ; free doublebuffer
            If menuDraw = #True
              DeleteDC_(Buffer)
              DeleteObject_(BufferBitmap)
            EndIf
            
          ;/ office 2003/2007 style
          ElseIf menuex()\style = 6 Or menuex()\style = #UISTYLE_OFFICE2007
            
            ; activate double buffering if the whole menu has been rendered once
            If menuDraw = #True
              ; set up double buffering
              iX = *item\rcItem\left+1
              iY = *item\rcItem\top
              iWidth = (*item\rcItem\right - *item\rcItem\left)+1
              iHeight = *item\rcItem\bottom - *item\rcItem\top; -1
              iHDC = *item\hdc
              Buffer = CreateCompatibleDC_(*item\hdc)
              BufferBitmap = CreateCompatibleBitmap_(*item\hdc, iWidth, iHeight)
              SelectObject_(Buffer, BufferBitmap)
              *item\rcItem\left = 0
              *item\rcItem\right = iWidth
              *item\rcItem\top = 0
              *item\rcItem\bottom = iHeight+1
              *item\hdc = Buffer
            Else
              *item\rcItem\left = *item\rcItem\left + 1
              *item\rcItem\right = *item\rcItem\right + 1
              *item\rcItem\bottom = *item\rcItem\bottom + 1
            EndIf
            
            ; item is a special scroll button
            If itemex()\scroll < 0
              
              If menuDraw = #True
                ; fill background to right of bar
                rec.RECT
                rec\left = *item\rcItem\left+borderwidth+1
                rec\right = *item\rcItem\right
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                colour = getMenuColourEx(menuex()\style, #background, 0)
                FillRect_(*item\hdc, rec, colour)
                
                ; draw bar
                rec.RECT
                rec\left = *item\rcItem\left-1
                rec\right = *item\rcItem\left+borderwidth+1
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                blitEx(*item\hdc, menuex()\style, #menuBarColor, @rec, #ForceHorizontalRedraw)
                
                *item\rcItem\right = *item\rcItem\right - 1
                
              EndIf

              If itemex()\scroll <> -3  ; if not filler draw up/down triangle
                w.f = Round((GetSystemMetrics_(#SM_CXMENUCHECK)/2)/2, #PB_Round_Down)
                width = w*2
                height = Round(width*0.5, #PB_Round_Up)
                
                pen = CreatePen_(#PS_SOLID, 0, RGB(0,0,0))
                fill = CreateSolidBrush_(RGB(0,0,0))
                oldpen = SelectObject_(*item\hdc, pen)
                oldfill = SelectObject_(*item\hdc, fill)
                
                If menuDraw = #True
                  *item\rcItem\right = *item\rcItem\right - 1
                EndIf
                
                
                Dim pnt.POINT(3)
                x = Round((*item\rcItem\right/2)-(width/2), #PB_Round_Down)
                y = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(height/2)

                y = y - 1
                If itemex()\scroll = -2
                  y = y + 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y
                  pnt(1)\x = x
                  pnt(1)\y = y+height
                  pnt(2)\x = x+width
                  pnt(2)\y = y+height
                ElseIf itemex()\scroll = -1
                  y = y - 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y+height
                  pnt(1)\x = x
                  pnt(1)\y = y
                  pnt(2)\x = x+width
                  pnt(2)\y = y
                EndIf
                Polygon_(*item\hdc, @pnt(), 3)
                
                SelectObject_(*item\hdc, oldpen)
                SelectObject_(*item\hdc, oldfill)
                DeleteObject_(fill)
                DeleteObject_(pen)
              
              EndIf
              
              ; if entire menu has been drawn once then doublebuffer blit
              If menuDraw = #True
                BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
              EndIf
              
            ; menu item is a separator bar
            ElseIf itemex()\text = ""
              
              If menuDraw = #True
                ; fill background to right of bar
                rec.RECT
                rec\left = *item\rcItem\left+borderwidth+1
                rec\right = *item\rcItem\right
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                colour = getMenuColourEx(menuex()\style, #background, 0)
                FillRect_(*item\hdc, rec, colour)
                
                ; draw bar
                rec.RECT
                rec\left = *item\rcItem\left-1
                rec\right = *item\rcItem\left+borderwidth+1
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                blitEx(*item\hdc, menuex()\style, #menuBarColor, @rec, #ForceHorizontalRedraw)
                
              EndIf
              
              ; draw separator
              rec.RECT
              rec\left = *item\rcItem\left+borderwidth+9
              rec\right = *item\rcItem\right+1
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\top+1
              colour = getMenuColourEx(menuex()\style, #separatorBar, 0)
              FillRect_(*item\hdc, rec, colour)
              
              ; if entire menu has been drawn once then doublebuffer blit
              If menuDraw = #True
                BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
              EndIf
              
            Else
              ; menu item is a normal item

              If menuDraw = #True
                
                ; fill background to right of bar
                rec.RECT
                rec\left = *item\rcItem\left+borderwidth+1
                rec\right = *item\rcItem\right
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                colour = getMenuColourEx(menuex()\style, #background, 0)
                FillRect_(*item\hdc, rec, colour)
              
                ; draw bar
                rec.RECT
                rec\left = *item\rcItem\left-1
                rec\right = *item\rcItem\left+borderwidth+1
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                blitEx(*item\hdc, menuex()\style, #menuBarColor, @rec, #ForceHorizontalRedraw)
                *item\rcItem\right = *item\rcItem\right - 1
              EndIf
              *item\rcItem\bottom = *item\rcItem\bottom - 1
              
              
              ; draw text
              rec\left = *item\rcItem\left+borderwidth+9
              rec\right = *item\rcItem\right+borderwidth+9
              rec\top = *item\rcItem\top
              rec\bottom = *item\rcItem\bottom-1
              SetTextColor_(*item\hdc, getMenuColourEx(menuex()\style, #menuTextColor, #returnRGBColour))
              renderItemText(0)
              
              ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)+1
              
              ; does this item have a checkmark
              If *item\itemState & #ODS_CHECKED
                
                borderwidth = borderwidth+1
                boxsize = itemex()\imageWidth+4
                
                If itemex()\radiocheck = #True And itemex()\checkIcon = #False
                  ImageList_Draw_(bulleticon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(7/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), #ILD_TRANSPARENT)
                Else
                  
                  rc.RECT
                  rc\left = *item\rcItem\left+(borderwidth/2)-(boxsize/2)
                  rc\top = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(boxsize/2)
                  rc\right = rc\left+boxsize
                  rc\bottom = rc\top + boxsize
                  blitEx(*item\hdc, menuex()\style, #menuCheckboxBorder, @rc, #ForceRedraw)
                  
                  If itemex()\checkIcon = #True
                    If itemex()\normal = -1
                      ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos-1, #ILD_TRANSPARENT)
                    EndIf
                  Else
                    ImageList_Draw_(tickicon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(8/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2)-1, #ILD_TRANSPARENT) 
                  EndIf
                EndIf
                
                ; draw normal icon image
              Else
                If itemex()\normal = -1
                  ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+((borderwidth/2)-(itemex()\imageWidth/2)), ypos-1, #ILD_TRANSPARENT)
                EndIf
              EndIf
              
              ; if entire menu has been drawn once then doublebuffer blit
              If menuDraw = #True
                BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
                *item\hdc = iHDC
                *item\rcItem\left = iX
                *item\rcItem\right = iX+iWidth-1
                *item\rcItem\top = iY
                *item\rcItem\bottom = iY+iHeight+1
              EndIf
              
              ; if this item is a submenu draw black arrow icon
              renderSubArrow()
 
            EndIf
            
            ; free doublebuffering
            If menuDraw = #True
              DeleteDC_(Buffer)
              DeleteObject_(BufferBitmap)
            EndIf
          
          ;/ classic styles
          Else
            
            ; activate double buffering if the whole menu has been rendered once
            If menuDraw = #True
              ; set up double buffering
              iX = *item\rcItem\left
              iY = *item\rcItem\top
              iWidth = *item\rcItem\right - *item\rcItem\left
              iHeight = *item\rcItem\bottom - *item\rcItem\top
              iHDC = *item\hdc
              Buffer = CreateCompatibleDC_(*item\hdc)
              BufferBitmap = CreateCompatibleBitmap_(*item\hdc, iWidth, iHeight)
              SelectObject_(Buffer, BufferBitmap)
              *item\rcItem\left = 0
              *item\rcItem\right = iWidth
              *item\rcItem\top = 0
              *item\rcItem\bottom = iHeight
              *item\hdc = Buffer
            EndIf
            
            ; item is a special scroll button
            If itemex()\scroll < 0
              
              FillRect_(*item\hdc, *item\rcItem, GetSysColorBrush_(#COLOR_MENU))
              
              If itemex()\scroll <> -3  ; if not filler draw up/down triangle
                w.f = Round((GetSystemMetrics_(#SM_CXMENUCHECK)/2)/2, #PB_Round_Down)
                width = w*2
                height = Round(width*0.5, #PB_Round_Up)
                
                pen = CreatePen_(#PS_SOLID, 0, RGB(0,0,0))
                fill = CreateSolidBrush_(RGB(0,0,0))
                oldpen = SelectObject_(*item\hdc, pen)
                oldfill = SelectObject_(*item\hdc, fill)
                
                Dim pnt.POINT(3)
                x = Round((*item\rcItem\right/2)-(width/2), #PB_Round_Down)
                y = *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(height/2)
                
                If itemex()\scroll = -2
                  y = y + 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y
                  pnt(1)\x = x
                  pnt(1)\y = y+height
                  pnt(2)\x = x+width
                  pnt(2)\y = y+height
                ElseIf itemex()\scroll = -1
                  y = y - 1
                  pnt(0)\x = x+width/2
                  pnt(0)\y = y+height
                  pnt(1)\x = x
                  pnt(1)\y = y
                  pnt(2)\x = x+width
                  pnt(2)\y = y
                EndIf
                Polygon_(*item\hdc, @pnt(), 3)
                
                SelectObject_(*item\hdc, oldpen)
                SelectObject_(*item\hdc, oldfill)
                DeleteObject_(fill)
                DeleteObject_(pen)
                
              EndIf
              
              ; if entire menu has been drawn once then doublebuffer blit
              If menuDraw = #True
                BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
              EndIf
              
            
            ; menu item is a separator bar
            ElseIf itemex()\text = ""
              
              ; vista/windows 7 style
              If ThemesEnabled = #True And (Comctl32MajorVersion > 6 Or (Comctl32MajorVersion = 6 And Comctl32MinorVersion > 0))
                CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 9, 1, *item\rcItem, 0)
                
                ; draw bar
                rec.RECT
                rec\left = *item\rcItem\left
                rec\right = *item\rcItem\left+borderwidth+1
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 13, 1, rec, 0)
                
                ;draw separator
                rec\left = *item\rcItem\left+borderwidth+1
                rec\right = *item\rcItem\right
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom-1
                CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 15, 1, rec, 0)
                
              Else
                FillRect_(*item\hdc, *item\rcItem, GetSysColorBrush_(#COLOR_MENU))
                
                rec.RECT
                rec\left = *item\rcItem\left+2
                rec\right = *item\rcItem\right-2
                rec\top = *item\rcItem\top+3
                rec\bottom = rec\top+1
                
                FillRect_(*item\hdc, rec, GetSysColorBrush_(#COLOR_GRAYTEXT))
                rec\top = rec\top + 1
                rec\bottom = rec\bottom + 1
                FillRect_(*item\hdc, rec, GetSysColorBrush_(#COLOR_3DHIGHLIGHT))
              EndIf
              
            Else  ; normal
              
              ; vista/windows 7 style
              If ThemesEnabled = #True And (Comctl32MajorVersion > 6 Or (Comctl32MajorVersion = 6 And Comctl32MinorVersion > 0))
                CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 9, 1, *item\rcItem, 0)

                ; draw bar
                rec.RECT
                rec\left = *item\rcItem\left
                rec\right = *item\rcItem\left+borderwidth+1
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 13, 1, rec, 0)
                
                ;draw text
                rec\left = *item\rcItem\left+borderwidth+6
                rec\right = *item\rcItem\right+borderwidth+6
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom-1
                SetTextColor_(*item\hdc, GetSysColor_(#COLOR_MENUTEXT))
                renderItemText(0)
                
                ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)
                
                ; does this item have a checkmark
                If *item\itemState & #ODS_CHECKED
                  
                  rc.RECT
                  rc\left = *item\rcItem\left
                  rc\top = *item\rcItem\top
                  rc\right = *item\rcItem\bottom-*item\rcItem\top
                  rc\bottom = *item\rcItem\bottom
                  CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 12, 2, rc, 0)
                  
                  If itemex()\radiocheck = #True And itemex()\checkIcon = #False
                    CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 11, 3, rc, 0)
                  Else
                    If itemex()\checkIcon = #True
                      If itemex()\normal = -1
                        ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_TRANSPARENT)
                      EndIf
                    Else
                      CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 11, 1, rc, 0)
                    EndIf
                  EndIf
                  
                  ; draw normal icon image
                Else
                  If itemex()\normal = -1
                    ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_NORMAL)
                  EndIf
                EndIf
                
              Else
                FillRect_(*item\hdc, *item\rcItem, GetSysColorBrush_(#COLOR_MENU))
              
                rec.RECT
                rec\left = *item\rcItem\left+itemex()\imageWidth+#MENUITEMIMAGEPADX+#MENUEXITEMPADX+3
                rec\right = *item\rcItem\right+itemex()\imageWidth+#MENUITEMIMAGEPADX+#MENUEXITEMPADX+3
                rec\top = *item\rcItem\top
                rec\bottom = *item\rcItem\bottom
                SetTextColor_(*item\hdc, GetSysColor_(#COLOR_MENUTEXT))
                renderItemText(0)
                
                ypos = *item\rcItem\top+(((*item\rcItem\bottom-*item\rcItem\top)-itemex()\imageHeight)/2)
                
                ; does this item have a checkmark
                If *item\itemState & #ODS_CHECKED
                  
                  borderwidth = itemex()\imageWidth+#MENUITEMIMAGEPADX+#MENUEXITEMPADX+1
                  
                  If itemex()\radiocheck = #True
                    ImageList_Draw_(bulleticon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(7/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), #ILD_TRANSPARENT)
                  Else
                    ImageList_Draw_(tickicon, 0, *item\hdc, *item\rcItem\left+(borderwidth/2)-(8/2), *item\rcItem\top+((*item\rcItem\bottom-*item\rcItem\top)/2)-(7/2), #ILD_TRANSPARENT) 
                  EndIf
                  
                  ; draw normal icon image
                Else
                  If itemex()\normal = -1
                    ImageList_Draw_(itemex()\ImageList, 0, *item\hdc, *item\rcItem\left+#MENUITEMIMAGEPADX+2, ypos, #ILD_TRANSPARENT)
                  EndIf
                EndIf
                
              EndIf

              
            EndIf
            
            ; if entire menu has been drawn once then doublebuffer blit
            If menuDraw = #True
              BitBlt_(iHDC, iX, iY, iWidth, iHeight, Buffer, 0, 0, #SRCCOPY)
              *item\hdc = iHDC
              *item\rcItem\left = iX
              *item\rcItem\right = iX+iWidth
              *item\rcItem\top = iY
              *item\rcItem\bottom = iY+iHeight
            EndIf
            
            ; vista/windows 7 style
            If ThemesEnabled = #True And (Comctl32MajorVersion > 6 Or (Comctl32MajorVersion = 6 And Comctl32MinorVersion > 0))
              mnfo.MENUITEMINFO_Fixed
              mnfo\cbSize = SizeOf(MENUITEMINFO_Fixed)
              mnfo\fMask = #MIIM_SUBMENU
              GetMenuItemInfo_(*item\hwndItem, itemex()\pos, #True, @mnfo)
              
              ; if this item is a submenu draw black arrow icon
              If mnfo\hSubMenu <> 0
                width = GetSystemMetrics_(#SM_CXMENUCHECK)+7
                height = (*item\rcItem\bottom-3)-(*item\rcItem\top+3)
                
                rc.RECT
                rc\left = *item\rcItem\right-width
                rc\right = rc\left+width
                rc\top = *item\rcItem\top+3
                rc\bottom = rc\top+height
                CallFunctionFast(*DrawThemeBackground, hThemeMenu, *item\hdc, 16, 1, rc, 0)
                
                ExcludeClipRect_(*item\hdc, *item\rcItem\right-width,*item\rcItem\top, *item\rcItem\right, *item\rcItem\bottom-1)
              EndIf
            Else
              ; if this item is a submenu draw black arrow icon
              renderSubArrow()
            EndIf
            
            ; free doublebuffering
            If menuDraw = #True
              DeleteDC_(Buffer)
              DeleteObject_(BufferBitmap)
            EndIf
            
          EndIf
          
        EndIf
        
        If menuWholeBuffered = #True And menuSelectedNoBuffer = #False
          If menuDraw = -1 And menuex()\active = -1 And menuex()\singleMenu = 0 And menuScrollHandle = 0
            If menuex()\hdc = 0 Or menuex()\bufferWidth <> menuex()\measuredWidth Or menuex()\bufferHeight <> menuex()\measuredHeight
              ;debuglog("menu buffered")
              If menuex()\hdc <> 0
                DeleteObject_(menuex()\Buffer)
                DeleteDC_(menuex()\hdc)
              EndIf
              menuex()\bufferWidth = menuex()\measuredWidth
              menuex()\bufferHeight = menuex()\measuredHeight
              ;debuglog("buffer w "+Str(menuex()\bufferWidth))
              ;debuglog("buffer h "+Str(menuex()\bufferHeight))
              menuex()\hdc = CreateCompatibleDC_(*item\hdc)
              menuex()\Buffer = CreateCompatibleBitmap_(*item\hdc, menuex()\bufferWidth, menuex()\bufferHeight)
              SelectObject_(menuex()\hdc, menuex()\Buffer)
              BitBlt_(menuex()\hdc, 0, 0, menuex()\bufferWidth, menuex()\bufferHeight, *item\hdc, 0, 0, #SRCCOPY)
            EndIf
          EndIf
        EndIf
        
        UnlockMutex(menuMutex)
        
      EndIf
      
  EndSelect

  ;-end of callback

  
  ProcedureReturn Result
EndProcedure


Procedure MsgHook(nCode, wParam, lParam)
  Static lx, ly, submenuSelect, submenuSelectMenu, tx, ty, scrollKeyboard
  Static subOpen
  
  If HaltProGUI = #True
    ProcedureReturn CallNextHookEx_(0, nCode, wParam, lParam)
  EndIf

  Select nCode
    Case  #MSGF_MENU

      *menuMsg.MSG = lParam
      
      If menuScrollEnd = #True
        ProcedureReturn CallNextHookEx_(0, nCode, wParam, lParam)
      EndIf
      
      If *menuMsg\message = #WM_MOUSEMOVE
        
        x.w = LOWORD(*menuMsg\lParam)
        y.w = HIWORD(*menuMsg\lParam)
        
        If x <> lx Or y <> ly
          
          menuDisabledKeyboard = #False

          p.POINT
          p\x = x
          p\y = y
          
          pt.POINT
          pt\x = x
          pt\y = y
          
          ScreenToClient_(menuToolbar, @p)
          
          If inMenuWindow = #False
            
            hwnd = WindowFromPoint_(PeekQ(pt))
            class.s = Space(255)
            GetClassName_(hwnd, @class, 255)
            If class <> "#32768" ; if mouse not in menu window
              menuHotItemNext = SendMessage_(menuToolbar, #TB_HITTEST, 0, @p)
            EndIf
            
          EndIf

          menuItemOver = menuHotItemNext
          
          iCount = SendMessage_(menuToolbar, #TB_BUTTONCOUNT, 0, 0)
          
          If menuItemOver < 0 Or menuItemOver >= iCount
            menuItemOver = -1
          EndIf
          
          If menuHotItemNext >= 0 And menuHotItemNext < iCount And menuHotItemNext <> menuHotItem
            ;debuglog("end")
            subMenuActive = 0
            subOpen = 0
            
            If menuScrollThread <> 0
              menuScrollEnd = #True
              ProcedureReturn CallNextHookEx_(0, nCode, wParam, lParam)
            EndIf
            
            EndMenu_()  ; move onto next popup menu
            
            ; significantly reduces menu tracking flickering in desktop composited mode
            If Dwmapi <> 0 And CompositionEnabled = #True
              ;CreateThread(@test(), 6)
              ;Delay(6)
              CallFunctionFast(*DwmFlush)
              ;CallFunctionFast(*DwmFlush)
              ;CallFunctionFast(*DwmFlush)
              ;CallFunctionFast(*DwmFlush)
            EndIf
            
          Else
            menuHotItemNext = -1
          EndIf
          
          lx = x
          ly = y
          lastMenuKeyboard = #False
        EndIf

      ElseIf *menuMsg\message = #WM_KEYDOWN
        
        If *menuMsg\wParam = #VK_DOWN Or *menuMsg\wParam = #VK_UP
          menuKeyboardActive = #True
          menuDisabledKeyboard = #True
          scrollKeyboard = *menuMsg\wParam
        EndIf

        If *menuMsg\wParam = #VK_LEFT And menuKeyboardActive <> -2 ; left
          
          menuKeyboardActive = #True
          
          ; check if submenu is open
          For n = 0 To GetMenuItemCount_(menuHandle)-1
            ret = GetSubMenu_(menuHandle, n)
            ret = GetMenuItemRect_(0, ret, 0, @rc.RECT)
            If ret = 1
              Break
            EndIf
          Next

          If ret <> 1
            If menuHotItem <> -1
              SendMessage_(menuToolbar, #TB_SETHOTITEM, menuHotItem, 0)
            EndIf
            menuHotItemNext = menuHotItem - 1
            If menuHotItemNext < 0
              menuHotItemNext = SendMessage_(menuToolbar, #TB_BUTTONCOUNT, 0, 0) - 1
            EndIf
            subMenuActive = #False
            subOpen = #False
            SendMessage_(menuToolbar, #TB_SETHOTITEM, menuHotItem, 0)

            If menuScrollThread <> 0
              menuScrollActive = 0
            EndIf
            
            EndMenu_()
            SetFocus_(menuToolbar)
            keybd_event_(#VK_LEFT, 0, 0, 0)
            keybd_event_(#VK_DOWN, 0, 0, 0)
            menuKeyboardActive = -2
            
            ; significantly reduces menu tracking flickering in desktop composited mode
            If Dwmapi <> 0 And CompositionEnabled = #True
              Delay(5)
              CallFunctionFast(*DwmFlush)
            EndIf
           
          Else
            subOpen = subOpen - 1
          EndIf
        ElseIf *menuMsg\wParam = #VK_RIGHT And menuKeyboardActive <> -2 ; right
          menuKeyboardActive = #True
          If submenuSelect <> 400
            If menuHotItem <> -1
              SendMessage_(menuToolbar, #TB_SETHOTITEM, menuHotItem, 0)
            EndIf
            menuHotItemNext = menuHotItem + 1
            If menuHotItemNext >= SendMessage_(menuToolbar, #TB_BUTTONCOUNT, 0, 0)
              menuHotItemNext = 0
            EndIf
            subMenuActive = #False
            subOpen = #False
            
            If menuScrollThread <> 0
              menuScrollActive = 0
            EndIf
            
            EndMenu_()
            SetFocus_(menuToolbar)
            keybd_event_(#VK_RIGHT, 0, 0, 0)
            keybd_event_(#VK_DOWN, 0, 0, 0)
            menuKeyboardActive = -2
            
            ; significantly reduces menu tracking flickering in desktop composited mode
            If Dwmapi <> 0 And CompositionEnabled = #True
              Delay(5)
              CallFunctionFast(*DwmFlush)
            EndIf
            
          Else  ; right cursor key activated submenu
            subMenuActive = #True
            subOpen = subOpen + 1
            lastSubMenu = submenuSelectMenu
          EndIf
        ElseIf *menuMsg\wParam = #VK_ESCAPE Or *menuMsg\wParam = #VK_RETURN
          
          ; if submenu then don't end menu until escape on root
          If *menuMsg\wParam = #VK_ESCAPE And subOpen > 0
            subOpen = subOpen - 1
            ProcedureReturn 0
          EndIf
          
          SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
          SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
          GetUpdateRect_(menuToolbar, @rc.RECT, #False)
          RedrawWindow_(menuToolbar,rc,0,#RDW_NOERASE|#RDW_UPDATENOW)
          UpdateWindow_(menuToolbar)
          SetFocus_(menuOldFocus)
          menuKeyboardActive = #False
          menuHotItemNext = -1
          menuItemOver = -1
          menuHotItem = -1
          
          If menuScrollThread <> 0
            menuScrollActive = 0
          EndIf
          
          EndMenu_()
        EndIf
        
        lastMenuKeyboard = #True
      
        
      ElseIf *menuMsg\message = #WM_SYSKEYDOWN
        
        If *menuMsg\wParam = 18
          EndMenu_()
          SendMessage_(menuToolbar, #TB_SETHOTITEM, -1, 0)
          SendMessage_(menuToolbar, #WM_SETREDRAW, #True, 0)
          GetUpdateRect_(menuToolbar, @rc.RECT, #False)
          RedrawWindow_(menuToolbar,rc,0,#RDW_NOERASE|#RDW_UPDATENOW)
          UpdateWindow_(menuToolbar)
          SetFocus_(menuOldFocus)
          menuKeyboardActive = #False
          menuHotItemNext = -1
          menuItemOver = -1
          menuHotItem = -2
        EndIf
        
      ElseIf *menuMsg\message = #WM_MENUSELECT

        ;submenuSelect = PeekW(@*menuMsg\wParam+2)
        submenuSelect = *menuMsg\wParam>> 16 & $FFFF
        If currentSub = 0
          currentSub = menuHandle
        EndIf
        ;submenuSelectMenu = GetSubMenu_(currentSub, PeekW(@*menuMsg\wParam))
        submenuSelectMenu = GetSubMenu_(currentSub, *menuMsg\wParam&$FFFF)
        If submenuSelectMenu <> 0
          subMenuActive = #True
        Else
          subMenuActive = #False
        EndIf
        
        ;selectedItem = PeekW(@*menuMsg\wParam)
        selectedItem = *menuMsg\wParam&$FFFF
        
        
        ; keynav when scrolling
        If menuScrollHandle <> 0 And scrollKeyboard <> #False
          
          count = GetMenuItemCount_(menuHandle)
          If scrollKeyboard = #VK_DOWN And selectedItem = #MENUSCROLLUPID And GetMenuItemID_(menuHandle, count-1) <> #MENUSCROLLDOWNID
            menuExScroll(3)
            SendMessage_(menuWindow, 485, 0, 0)
          ElseIf scrollKeyboard = #VK_UP And selectedItem = #MENUSCROLLDOWNID And GetMenuItemID_(menuHandle, 0) <> #MENUSCROLLUPID
            menuExScroll(2)
            SendMessage_(menuWindow, 485, GetMenuItemCount_(menuHandle)-1, 0)
          ElseIf scrollKeyboard = #VK_UP And selectedItem = #MENUSCROLLFILLERID
            menuScrollActive = #False
            menuExScroll(1)
            SendMessage_(menuWindow, 485, 1, 0)
          ElseIf scrollKeyboard = #VK_UP And selectedItem = #MENUSCROLLUPID
            menuScrollActive = #False
            menuExScroll(1)
            SendMessage_(menuWindow, 485, 1, 0)
          ElseIf scrollKeyboard = #VK_DOWN And selectedItem = #MENUSCROLLFILLERID
            menuScrollActive = #False
            menuExScroll(0)
            SendMessage_(menuWindow, 485, GetMenuItemCount_(menuHandle)-2, 0)
          ElseIf scrollKeyboard = #VK_DOWN And selectedItem = #MENUSCROLLDOWNID
            menuScrollActive = #False
            menuExScroll(0)
            SendMessage_(menuWindow, 485, GetMenuItemCount_(menuHandle)-2, 0)
          EndIf
          
          scrollKeyboard = #False
        
        EndIf
      
      ElseIf *menuMsg\message = #WM_RBUTTONDOWN Or *menuMsg\message = #WM_LBUTTONDOWN
        
        SetFocus_(menuOldFocus)
        menuKeyboardActive = #False
  
      EndIf

  EndSelect
  
  ProcedureReturn CallNextHookEx_(0, nCode, wParam, lParam)
EndProcedure


Procedure miniMsgHook(nCode, wParam, lParam)
  Static lx, ly, submenuSelect, submenuSelectMenu
  
  If HaltProGUI = #True
    ProcedureReturn CallNextHookEx_(0, nCode, wParam, lParam)
  EndIf
  
  Select nCode
    Case  #MSGF_MENU
      
      *menuMsg.MSG = lParam
      
      If *menuMsg\message = #WM_MOUSEMOVE

        x.w = LOWORD(*menuMsg\lParam)
        y.w = HIWORD(*menuMsg\lParam)
        
        If x <> lx Or y <> ly
          
          menuDisabledKeyboard = #False

          lx = x
          ly = y
          lastMenuKeyboard = #False
        EndIf
        
      ElseIf *menuMsg\message = #WM_KEYDOWN
        
        If *menuMsg\wParam = #VK_DOWN Or *menuMsg\wParam = #VK_UP
          menuKeyboardActive = #True
          menuDisabledKeyboard = #True
        EndIf
        
        If *menuMsg\wParam = #VK_LEFT And menuKeyboardActive <> -2 ; left
          
          menuKeyboardActive = #True
          
        ElseIf *menuMsg\wParam = #VK_RIGHT And menuKeyboardActive <> -2 ; right
          menuKeyboardActive = #True
          If submenuSelect = 400  ; right cursor key activated submenu
            subMenuActive = #True
            lastSubMenu = submenuSelectMenu
          EndIf
        EndIf
        
        lastMenuKeyboard = #True
        
      ElseIf *menuMsg\message = #WM_MENUSELECT
        
        ;submenuSelect = PeekW(@*menuMsg\wParam+2)
        submenuSelect = *menuMsg\wParam>> 16 & $FFFF
        If currentSub = 0
          currentSub = menuHandle
        EndIf
        ;submenuSelectMenu = GetSubMenu_(currentSub, PeekW(@*menuMsg\wParam))
        submenuSelectMenu = GetSubMenu_(currentSub, *menuMsg\wParam&$FFFF)
        If submenuSelectMenu <> 0
          subMenuActive = #True
        Else
          subMenuActive = #False
        EndIf
        
      ElseIf *menuMsg\message = #WM_RBUTTONDOWN Or *menuMsg\message = #WM_LBUTTONDOWN
        
        SetFocus_(menuOldFocus)
        menuKeyboardActive = #False
        
      EndIf
      
  EndSelect
  
  ProcedureReturn CallNextHookEx_(0, nCode, wParam, lParam)
EndProcedure

Procedure miniMouseHook(nCode, wParam, lParam)
  
  *mouse.MSLLHOOKSTRUCT  = lparam
  x = *mouse\pt\x
  y = *mouse\pt\y
  GetWindowRect_(miniMenuWindow, @rc.RECT)
  ;debuglog("X: "+Str(x)+" Y: "+Str(y))
  If x < rc\left Or x > rc\right Or y < rc\top Or y > rc\bottom
    If wParam = #WM_LBUTTONUP Or wParam = #WM_RBUTTONUP
      EndMenu_()
    EndIf
  EndIf
  
  ProcedureReturn CallNextHookEx_(0, nCode, wParam, lParam)
EndProcedure

Procedure ChevronMsgHook(nCode, wParam, lParam)

  Select nCode
    Case  #MSGF_MENU
      
      *menuMsg.MSG = lParam
      
      If *menuMsg\message = #WM_LBUTTONDOWN
        chevronState = 0
        ;x = PeekW(@*menuMsg\lParam)
        ;y = PeekW(@*menuMsg\lParam+2)
        x = *menuMsg\lParam&$FFFF
        y = *menuMsg\lParam>> 16 & $FFFF
        If x >= chevronRECT\left And x <= chevronRECT\right
          If y >= chevronRECT\top And y <= chevronRECT\bottom
            chevronState = -1
          EndIf
        EndIf
      EndIf
      
  EndSelect
  
  CallNextHookEx_(0, nCode, wParam, lParam)
EndProcedure

CompilerIf Defined(CWPRETSTRUCT, #PB_Structure) = #False
  Structure CWPRETSTRUCT
    LRESULT.l
    lParam.l
    wParam.l
    message.l
    hwnd.i
  EndStructure
CompilerEndIf

; mouse pointer image hook
Procedure mousePointerHook(nCode, wParam, lParam)
  
  *cwp.CWPRETSTRUCT = lParam
  If *cwp\message = #WM_SETCURSOR
    If rebarResizableMousepointer = -1
      SetCursor_(verticalResizeMousePointer)
    ElseIf rebarResizableMousepointer = -2
      SetCursor_(verticalDragMousePointer)
    Else
      SetCursor_(normalMousePointer)
      rebarResizableMousepointer = 0
    EndIf
  EndIf
  
  CallNextHookEx_(0, nCode, wParam, lParam)
EndProcedure


Procedure calcRebarVertResize(rebar, band, mode, y)
  
  ; get band rect
  SendMessage_(rebar, #RB_GETRECT, band, rc.RECT)
  
  ; get minimum height of band
  count = SendMessage_(rebar, #RB_GETBANDCOUNT, 0, 0)
  For n = 0 To count
    If n <> band
      SendMessage_(rebar, #RB_GETRECT, n, rc2.RECT)
      
      binfo2.REBARBANDINFO
      binfo2\cbSize = SizeOf(REBARBANDINFO)
      binfo2\fMask = #RBBIM_CHILDSIZE|#RBBIM_STYLE
      SendMessage_(rebar, #RB_GETBANDINFO, n, @binfo2)

      If rc2\top = rc\top 
        If binfo2\fStyle & #RBBS_SIZEABLE = 0 And binfo2\fStyle & #RBBS_VERTICALRESIZEABLE = 0
          If binfo2\cyMinChild > minheight
            minheight = binfo2\cyMinChild
            found = -1 
          EndIf
        EndIf
      EndIf

    EndIf
  Next
  
  If found = 0
    minheight = 0
  EndIf


  ; if top of bar selected
  If mode = 0
    
    ; get band below rect
    If band-1 >= 0
      For n = band-1 To 0 Step -1
        SendMessage_(rebar, #RB_GETRECT, n, rc2.RECT)
        
        binfo2.REBARBANDINFO
        binfo2\cbSize = SizeOf(REBARBANDINFO)
        binfo2\fMask = #RBBIM_CHILDSIZE|#RBBIM_STYLE
        SendMessage_(rebar, #RB_GETBANDINFO, n, @binfo2)
        
        If rc2\top < rc\top
          Break
        EndIf
      Next
    Else
      n = -1
    EndIf

    ; get band info
    binfo.REBARBANDINFO
    binfo\cbSize = SizeOf(REBARBANDINFO)
    binfo\fMask = #RBBIM_CHILDSIZE
    SendMessage_(rebar, #RB_GETBANDINFO, band, @binfo)
    
    ; get band below info
    binfo2.REBARBANDINFO
    If n <> -1
      binfo2\cbSize = SizeOf(REBARBANDINFO)
      binfo2\fMask = #RBBIM_CHILDSIZE|#RBBIM_STYLE
      SendMessage_(rebar, #RB_GETBANDINFO, n, @binfo2)
    Else
      binfo2\fStyle = 0
    EndIf

    ; is the band before below it and a rezisbale type
    If binfo2\fStyle & #RBBS_SIZEABLE Or binfo2\fStyle & #RBBS_VERTICALRESIZEABLE
      
      ; make sure we cant resize the bar below its height
      If y < rc2\top+6
        y = rc2\top+6
      EndIf
 
      ydelta = rc\top-y
      
      ; makesure band doenst resize below minheight
      If ((rc\bottom-rc\top)-4)+ydelta < minheight
        
        z = ydelta
        ydelta = 0
        For j = z To 0
          If ((rc\bottom-rc\top)-4)+j = minheight
            ydelta = j
            Break
          EndIf
        Next
        
      EndIf
      
      binfo\cyMinChild = binfo\cyMinChild + ydelta
      binfo2\cyMinChild = binfo2\cyMinChild - ydelta
      
      SendMessage_(rebar, #WM_SETREDRAW, #False, 0)
      SendMessage_(rebar, #RB_SETBANDINFO, band, @binfo)
      SendMessage_(rebar, #RB_SETBANDINFO, n, @binfo2)
      SendMessage_(rebar, #WM_SETREDRAW, #True, 0)
    
    ; normal band below it
    Else
      
      ; makesure window not maximized
      If IsZoomed_(currentDragRebarParent) = 0
        
        ydelta = rc\top-y
        
        ; makesure band doenst resize below minheight
        If ((rc\bottom-rc\top)-4)+ydelta < minheight
          
          z = ydelta
          ydelta = 0
          For j = z To 0
            If ((rc\bottom-rc\top)-4)+j = minheight
              ydelta = j
              Break
            EndIf
          Next
          
        EndIf
  
        resizing = -1
        GetWindowRect_(currentDragRebarParent, @rc3.RECT)
        
        ; make sure window doesnt go over top of desktop window
        If rc3\top-ydelta < 0
          n = ydelta
          ydelta = 0
          
          For n = n To 0 Step -1
            If rc3\top-n = 0
              ydelta = n
              Break
            EndIf
          Next
        
          
        EndIf
        
        If lastResizeRect\top = 0 And lastResizeRect\left = 0 And lastResizeRect\right = 0 And lastResizeRect\bottom = 0
          lastResizeRect\top = rc3\top
          lastResizeRect\left = rc3\left
          lastResizeRect\right = rc3\right
          lastResizeRect\bottom = rc3\bottom
        EndIf
        
        resizeRECT\top = lastResizeRect\top
        resizeRECT\left = lastResizeRect\left
        resizeRECT\right = lastResizeRect\right
        resizeRECT\bottom = lastResizeRect\bottom
        
        lastResizeRect\top = rc3\top-ydelta
        lastResizeRect\left = rc3\left
        lastResizeRect\right = rc3\right
        lastResizeRect\bottom = rc3\bottom+ydelta
        
        ;SendMessage_(currentDragRebarParent, #WM_SETREDRAW, #False, 0)
        binfo\cyMinChild = binfo\cyMinChild + ydelta
        SendMessage_(rebar, #RB_SETBANDINFO, band, @binfo)
        MoveWindow_(currentDragRebarParent, rc3\left, rc3\top-ydelta, rc3\right-rc3\left, (rc3\bottom-rc3\top)+ydelta, #True)

      EndIf
    EndIf

  ; bottom of bar selected
  Else
    
    ; get band below rect
    If band+1 <= count-1
      For n = band+1 To count
        SendMessage_(rebar, #RB_GETRECT, n, rc2.RECT)
        
        binfo2.REBARBANDINFO
        binfo2\cbSize = SizeOf(REBARBANDINFO)
        binfo2\fMask = #RBBIM_CHILDSIZE|#RBBIM_STYLE
        SendMessage_(rebar, #RB_GETBANDINFO, n, @binfo2)
        
        If rc2\top > rc\top
          Break
        EndIf
      Next
    Else
      n = -1
    EndIf
    
    If rc2\top = rc\top
      n = -1
    EndIf  
    
    ; get band info
    binfo.REBARBANDINFO
    binfo\cbSize = SizeOf(REBARBANDINFO)
    binfo\fMask = #RBBIM_CHILDSIZE
    SendMessage_(rebar, #RB_GETBANDINFO, band, @binfo)
    
    ; get band below info
    binfo2.REBARBANDINFO
    If n <> -1
      binfo2\cbSize = SizeOf(REBARBANDINFO)
      binfo2\fMask = #RBBIM_CHILDSIZE|#RBBIM_STYLE
      SendMessage_(rebar, #RB_GETBANDINFO, n, @binfo2)
    Else
      binfo2\fStyle = 0
    EndIf
    
    ; is the band before below it and a rezisbale type
    If binfo2\fStyle & #RBBS_SIZEABLE Or binfo2\fStyle & #RBBS_VERTICALRESIZEABLE
      
      ; make sure we cant resize the bar below its height
      If y > rc2\bottom-6
        y = rc2\bottom-6
      EndIf
      
      ydelta = -(rc\bottom-y)
      
      ; makesure band doenst resize below minheight
      If ((rc\bottom-rc\top)-4)+ydelta < minheight
        
        z = ydelta
        ydelta = 0
        For j = z To 0
          If ((rc\bottom-rc\top)-4)+j = minheight
            ydelta = j
            Break
          EndIf
        Next
        
      EndIf
      
      binfo\cyMinChild = binfo\cyMinChild + ydelta
      binfo2\cyMinChild = binfo2\cyMinChild - ydelta
      
      SendMessage_(rebar, #WM_SETREDRAW, #False, 0)
      SendMessage_(rebar, #RB_SETBANDINFO, band, @binfo)
      SendMessage_(rebar, #RB_SETBANDINFO, n, @binfo2)
      SendMessage_(rebar, #WM_SETREDRAW, #True, 0)
      
    ; normal band below it
    Else
      
      ; makesure window not maximized
      If IsZoomed_(currentDragRebarParent) = 0
      
        ydelta = -(rc\bottom-y)
        
        ; makesure band doenst resize below minheight
        If ((rc\bottom-rc\top)-4)+ydelta < minheight
          
          z = ydelta
          ydelta = 0
          For j = z To 0
            If ((rc\bottom-rc\top)-4)+j = minheight
              ydelta = j
              Break
            EndIf
          Next
          
        EndIf
        
        resizing = -1
        GetWindowRect_(currentDragRebarParent, @rc3.RECT)
        
        ; make sure window doesnt go over top of desktop window
        ;SystemParametersInfo_(#SPI_GETWORKAREA, 0, @drc.RECT, 0)
        desktop = GetDesktopWindow_()
        GetClientRect_(desktop, @drc.RECT)
        
        If rc3\bottom+ydelta > drc\bottom
          n = ydelta
          ydelta = 0
  
          For n = n To 0 Step -1
            If rc3\bottom+n = drc\bottom
              ydelta = n
              Break
            EndIf
          Next
  
        EndIf
        
        If lastResizeRect\top = 0 And lastResizeRect\left = 0 And lastResizeRect\right = 0 And lastResizeRect\bottom = 0
          lastResizeRect\top = rc3\top
          lastResizeRect\left = rc3\left
          lastResizeRect\right = rc3\right
          lastResizeRect\bottom = rc3\bottom
        EndIf
        
        resizeRECT\top = lastResizeRect\top
        resizeRECT\left = lastResizeRect\left
        resizeRECT\right = lastResizeRect\right
        resizeRECT\bottom = lastResizeRect\bottom
        
        lastResizeRect\top = rc3\top
        lastResizeRect\left = rc3\left
        lastResizeRect\right = rc3\right
        lastResizeRect\bottom = rc3\bottom+ydelta
        
        ;SendMessage_(currentDragRebarParent, #WM_SETREDRAW, #False, 0)
        binfo\cyMinChild = binfo\cyMinChild + ydelta
        SendMessage_(rebar, #RB_SETBANDINFO, band, @binfo)
        MoveWindow_(currentDragRebarParent, rc3\left, rc3\top, rc3\right-rc3\left, (rc3\bottom-rc3\top)+ydelta, #True)
        
      EndIf
    EndIf

  EndIf
  
  ;GetUpdateRect_(rebar, regen.RECT, #False)
  ;RedrawWindow_(rebar, @regen,0,#RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
  
EndProcedure



Procedure rebarMouseMoveHook(nCode, wParam, lParam)
  
  If currentDragRebar = 0
  
    *ms.MOUSEHOOKSTRUCT = lParam
    
    spacer = 2
  
    If rebarVerticalResizeDrag = -1 And resizing = 0
      ForEach rebarGadget()
        
        If rebarGadget()\WindowID = GetAncestor_(*ms\hwnd, $2)

          pt.POINT
          pt\x = *ms\pt\x
          pt\y = *ms\pt\y
          MapWindowPoints_(0, rebarGadget()\WindowID, @pt, 1)
          
          ; get band count
          count = SendMessage_(rebarGadget()\Handle, #RB_GETBANDCOUNT, 0, 0)
          
          ; scan through bands and see which ones are sizable or vertically resizable
          found = 0
          For z = 0 To count-1
            binfo.REBARBANDINFO
            binfo\cbSize = SizeOf(REBARBANDINFO)
            binfo\fMask = #RBBIM_STYLE|#RBBIM_ID|#RBBIM_CHILDSIZE|#RBBIM_LPARAM
            SendMessage_(rebarGadget()\Handle, #RB_GETBANDINFO, z, @binfo)
            
            ChangeCurrentElement(rebarBand(), binfo\lParam) 

            ; found a verticalsizable band
            If rebarBand()\visible = -1 And binfo\fStyle & #RBBS_VERTICALRESIZEABLE
      
              ; see if our mouse coords are at the top or bottom of the band
              SendMessage_(rebarGadget()\Handle, #RB_GETRECT, z, rc.RECT)
              
              ; mouse at top of bar
              If pt\y >= rc\top-spacer And pt\y <= rc\top+spacer
                If mousePointerHook = 0
                  threadId = GetWindowThreadProcessId_(rebarGadget()\WindowID, 0)
                  mousePointerHook = SetWindowsHookEx_(12, @mousePointerHook(), 0, threadId)
                  rebarResizableMousepointer = -1
                EndIf
                
                ; started mouse drag
                If wParam = #WM_LBUTTONDOWN Or wParam = #WM_NCLBUTTONDOWN
                  
                  If GetForegroundWindow_() <> rebarGadget()\WindowID
                    SetForegroundWindow_(rebarGadget()\WindowID)
                  EndIf
                  
                  SetCursor_(verticalDragMousePointer)
                  rebarResizableMousepointer = -2
                  rebarVerticalResizeDrag = z
                  currentDragBand = rebarGadget()\Handle
                  currentDragBandID = 0
                  currentDragRebarParent = rebarGadget()\WindowID
                  SetCapture_(rebarGadget()\WindowID)
                EndIf
    
              ; mouse at bottom of bar
              ElseIf pt\y >= rc\bottom-spacer And pt\y <= rc\bottom+spacer
                If mousePointerHook = 0
                  threadId = GetWindowThreadProcessId_(rebarGadget()\WindowID, 0)
                  mousePointerHook = SetWindowsHookEx_(12, @mousePointerHook(), 0, threadId)
                  rebarResizableMousepointer = -1
                EndIf
                
                ; started mouse drag
                If wParam = #WM_LBUTTONDOWN Or wParam = #WM_NCLBUTTONDOWN
                  
                  If GetForegroundWindow_() <> rebarGadget()\WindowID
                    SetForegroundWindow_(rebarGadget()\WindowID)
                  EndIf
                  
                  SetCursor_(verticalDragMousePointer)
                  rebarResizableMousepointer = -2
                  rebarVerticalResizeDrag = z
                  currentDragBand = rebarGadget()\Handle
                  currentDragBandID = -1
                  currentDragRebarParent = rebarGadget()\WindowID
                  SetCapture_(rebarGadget()\Handle)
                EndIf
                
              Else
                If mousePointerHook <> 0
                  UnhookWindowsHookEx_(mousePointerHook)
                  SetCursor_(normalMousePointer)
                  rebarResizableMousepointer = 0
                  mousePointerHook = 0
                EndIf
              EndIf
              
            EndIf
            
          Next
        
        Else
          
          If mousePointerHook <> 0
            UnhookWindowsHookEx_(mousePointerHook)
            SetCursor_(normalMousePointer)
            rebarResizableMousepointer = 0
            mousePointerHook = 0
          EndIf
          
        EndIf
      Next
    EndIf
    
    ; if dragging
    If rebarVerticalResizeDrag <> -1
      
      If wParam = #WM_MOUSEMOVE
        pt.POINT
        pt\x = *ms\pt\x
        pt\y = *ms\pt\y
        MapWindowPoints_(0, currentDragRebarParent, @pt, 1)
        
        If lastRebarVertResizePos <> pt\y
          calcRebarVertResize(currentDragBand, rebarVerticalResizeDrag, currentDragBandID, pt\y)
          lastRebarVertResizePos = pt\y
        EndIf
      EndIf
        
      ; if mouse is released
      If wParam = #WM_LBUTTONUP Or wParam = #WM_NCLBUTTONUP
        If mousePointerHook <> 0
          UnhookWindowsHookEx_(mousePointerHook)
        EndIf
        mousePointerHook = 0
        rebarResizableMousepointer = 0
        rebarVerticalResizeDrag = -1
        ReleaseCapture_()
        
        If resizing = -1
          SendMessage_(currentDragRebarParent, #WM_SETREDRAW, #True, 0)
          GetWindowRect_(currentDragRebarParent, @rc.RECT)
          MoveWindow_(currentDragRebarParent, rc\left, rc\top, rc\right-rc\left, rc\bottom-rc\top, #True)
          RedrawWindow_(currentDragRebarParent,0,0,#RDW_INVALIDATE|#RDW_ALLCHILDREN|#RDW_FRAME|#RDW_ERASE|#RDW_UPDATENOW)
          resizing = 0
          lastResizeRect\top = 0
          lastResizeRect\left = 0
          lastResizeRect\right = 0
          lastResizeRect\bottom = 0
        EndIf
        
        
      EndIf
      
    EndIf

    
  EndIf
  
  CallNextHookEx_(0, nCode, wParam, lParam)

EndProcedure


; handles resize update when dragging bands
Procedure rebarHook(nCode, wParam, lParam)
  
  *ms.MOUSEHOOKSTRUCT = lParam

  index = SendMessage_(currentDragRebar, #RB_IDTOINDEX, currentDragBandID, 0)
  Rows =  SendMessage_(currentDragRebar, #RB_GETROWCOUNT, 0, 0)
  
  ; update rebar and redraw when band moved rows
  If index <> currentDragBand Or currentDragRows <> Rows
    
    SendMessage_(currentDragRebar, #WM_SETREDRAW, #False, 0)
    updateRebar(currentDragRebarParent)
    SendMessage_(currentDragRebar, #WM_SETREDRAW, #True, 0)
    
    currentDragBand = index
    currentDragRows = Rows
         
  EndIf
  
  ; handle #TBSTYLE_WRAPABLE toolbars in rebar when dragging bands
  ForEach toolbarEx()
    If currentDragRebar = GetParent_(toolbarEx()\handle)
      
      rows = SendMessage_(toolbarEx()\handle, #TB_GETROWS, 0, 0)
      If rows <> toolbarEx()\lastRowCount
        
        ; find band that our toolbar is contained in
        max = SendMessage_(currentDragRebar, #RB_GETBANDCOUNT, 0,0)
        For n = 0 To max
          
          band.REBARBANDINFO
          band\cbSize = SizeOf(REBARBANDINFO)
          band\fMask = #RBBIM_CHILD|#RBBIM_CHILDSIZE
          SendMessage_(currentDragRebar, #RB_GETBANDINFO, n, @band)
          If band\hwndChild = toolbarEx()\handle
            
            dwBtnSize = SendMessage_(toolbarEx()\handle, #TB_GETBUTTONSIZE, 0,0)>>16
            pad = toolbarEx()\lastRowCount * dwBtnSize
            
            toolbarEx()\lastRowCount = rows
  
            pad = band\cyMinChild-pad
            
            dwBtnSize = (dwBtnSize * rows)+pad
            
            ; set rebar band's new height
            band\fMask = #RBBIM_CHILDSIZE
            band\cyMinChild = dwBtnSize;+hdelta
            SendMessage_(currentDragRebar, #RB_SETBANDINFO, n, @band)
            
            
            handle = currentDragRebar
            *this = @rebarGadget()
            height = RebarHeight(handle)
            ChangeCurrentElement(rebarGadget(), *this)
            
            Break
          EndIf
            
        Next
  
      EndIf
      
    EndIf
  Next

  
  CallNextHookEx_(0, nCode, wParam, lParam)
EndProcedure

Structure wobscure
  shwnd.i
  hwnd.i
  p.POINT
  obscured.i
EndStructure

Procedure isWindowObscured(hwnd, *w.wobscure)
  
  ;GetWindowRect_(lparam, @rc.RECT)
  GetClientRect_(hwnd, @rc2.RECT)
  MapWindowPoints_(hwnd, 0, @rc2, 2)
  
  If hwnd <> *w\shwnd
    Debug Str(hwnd)+" | "+Str(rc2\left)+" "+Str(rc2\top)+" "+Str(rc2\right)+" "+Str(rc2\bottom)
    
    
    If *w\hwnd <> hwnd And *w\p\x >= rc2\left And *w\p\x <= rc2\right And *w\p\y >= rc2\top And *w\p\y <= rc2\bottom
      ;FindMapElement(trackWin(),Str(hwnd))
      ;If trackWin()\windowType <> #WINDOWTYPE_PANELEX And trackWin()\windowType <> #WINDOWTYPE_PANELEXPAGE
        ;Debug Str(*w\hwnd)+" | "+Str(*w\p\x)+" "+Str(*w\p\y)
        ;Debug Str(hwnd)+" | "+Str(rc2\left)+" "+Str(rc2\right)+" "+Str(rc2\top)+" "+Str(rc2\bottom)
        ;Debug "obscured by "+Str(hwnd)
        If *w\obscured <> 0
          ;Debug "obscured"
          ;SetWindowLongPtr_(hwnd, #GWL_STYLE, GetWindowLongPtr_(hwnd, #GWL_STYLE) | #WS_DISABLED)
        EndIf
        ;*w\obscured = hwnd
        
        ;ProcedureReturn #False
        ;EndIf
        
    ElseIf *w\hwnd <> hwnd
        ;Debug "not obscured"
        ;SetWindowLongPtr_(hwnd, #GWL_STYLE, GetWindowLongPtr_(hwnd, #GWL_STYLE) &~ #WS_DISABLED)
    EndIf
  EndIf
  
  ProcedureReturn #True
    
EndProcedure


Procedure generateUniqueID()

  ID = PB_Object_GetOrAllocateID(PB_Gadget_Objects, #PB_Any)
  
  ProcedureReturn ID
EndProcedure

Procedure.u generateUniqueID_wordUnsigned()
  Static uniqueID.u = $FFFF
  
  uniqueID = uniqueID - 1
  
  ProcedureReturn uniqueID
EndProcedure


;--
;- PanelEx
;--
Procedure updatePanelExPageScrolling(x, y)
  
  ; delete cached back brushes for static controls
  ForEach backbrush()
    ;If backbrush()\Window = panelexpage()\Handle
      DeleteObject_(backbrush()\hBrush)
      DeleteElement(backbrush())
    ;EndIf
  Next
  
  areaWidth = panelexpage()\area\right-panelexpage()\area\left
  areaHeight = panelexpage()\area\bottom-panelexpage()\area\top
  GetClientRect_(panelexpage()\handle, @prc.RECT)
  MapWindowPoints_(panelexpage()\handle, panelexpage()\containerHandle, @prc, 2)
  GetClientRect_(panelexpage()\containerHandle, @crc.RECT)
  If areaWidth < crc\right
    areaWidth = crc\right
  EndIf
  If areaHeight < crc\bottom
    areaHeight = crc\bottom
  EndIf
  
  SetWindowPos_(panelexpage()\handle, 0, prc\left+x, prc\top+y, areaWidth+1, areaHeight+1, #SWP_NOACTIVATE|#SWP_NOOWNERZORDER|#SWP_NOZORDER|#SWP_NOCOPYBITS|#SWP_NOREDRAW)
  
  ;GetClientRect_(panelexpage()\handle, @rc.RECT)
  ;Debug "width: "+Str(rc\right)
  
EndProcedure

;returns root panelex page hwnd from child hwnd
Procedure getRootPanelExPageHwnd(hwnd)
  
  FindMapElement(trackWin(),Str(hwnd))
  If trackWin()\windowType = #WINDOWTYPE_PANELEXPAGE
    root = hwnd
  EndIf
  root = hwnd
  Repeat
    parent = GetParent_(hwnd)
    FindMapElement(trackWin(),Str(parent))
    If trackWin()\windowType = #WINDOWTYPE_PANELEXPAGE
      root = parent
    EndIf
    hwnd = parent
  Until parent = 0
  
  ProcedureReturn root
  
EndProcedure

; sets rect that doesn't clip any parent panelex windows
Procedure setPanelExClippedRect(*rc.RECT, hwnd, root)
  
  If root = 0
    root = GetParent_(getRootPanelExPageHwnd(hwnd))
  EndIf
  
  Repeat
    parent = GetParent_(hwnd)
    FindMapElement(trackWin(),Str(parent))
    If trackWin()\windowType = #WINDOWTYPE_PANELEX
      GetClientRect_(parent, @prc.RECT)
      MapWindowPoints_(parent, root, @prc, 2)
      
      IntersectRect_(*rc, *rc, prc)
      
    EndIf
    hwnd = parent
  Until hwnd = 0
  
EndProcedure

; used to enumerate all progress bars in parent window and validate each rect
; this is because the Windows progress bars flicker on redraw when in PanelEx
Procedure validateProgressbarsRect(hwnd, parenthwnd)
  
  
  FindMapElement(trackWin(),Str(hwnd))
  If trackWin()\windowType <> #WINDOWTYPE_PANELEX And trackWin()\windowType <> #WINDOWTYPE_PANELEXPAGE And trackWin()\windowType <> #WINDOWTYPE_SYSPROGRESSBAR And GetWindowLongPtr_(hwnd, #GWL_STYLE) & #WS_VISIBLE
    ;And trackWin()\windowType <> #WINDOWTYPE_SYSTAB
    ;GetClientRect_(hwnd, @rc.RECT)
    ;InvalidateRect_(hwnd, 0, 0)
    
    ;wnd = hwnd
    ;Repeat
    ;  wnd = GetParent_(wnd)
    ;  tclass.s = Space(255)
    ;  GetClassName_(wnd, @tclass, 255)
    ;  If tclass = "SysTabControl32"
    ;    Debug "found"
    ;    found = #True
    ;    Break
    ;  EndIf
    ;Until wnd = 0
    ;If found = 0
    
;       tclass.s = Space(255)
;       wnd = hwnd
;       Repeat
;         wnd = GetParent_(wnd)
;         GetClassName_(wnd, @tclass, 255)
;         If tclass = "SysTabControl32"
;           ;GetWindowRect_(hwnd, @rc.RECT)
;           ;*xwin\parenthwnd = getRootPanelExPageHwnd(hwnd)
;           ;MapWindowPoints_(0, *xwin\parenthwnd, @rc, 2)
;           ;setPanelExClippedRect(@rc, hwnd, *xwin\parenthwnd)
;           ;ExcludeClipRect_(*xwin\hdc, rc\left, rc\top, rc\right, rc\bottom)
;           ;Debug "found : "+Str(hwnd)
;           found = #True
;           Break
;         EndIf
;       Until wnd = 0

    
      
      gwlStyle = GetWindowLongPtr_(hwnd, #GWL_STYLE)
      If trackWin()\windowType <> #WINDOWTYPE_SYSTAB
        SetWindowLongPtr_(hwnd, #GWL_STYLE, gwlStyle | #WS_CLIPSIBLINGS | #WS_CLIPCHILDREN)
      EndIf
      UnlockMutex(trackWinMutex)
      ;If found = 0
      RedrawWindow_(hwnd,0,0,#RDW_FRAME|#RDW_INVALIDATE|#RDW_ERASE) ; #RDW_ALLCHILDREN - taken away = significant speed up
      ;EndIf
      SetWindowLongPtr_(hwnd, #GWL_STYLE, gwlStyle)
      LockMutex(trackWinMutex)
      FindMapElement(trackWin(),Str(hwnd))
      
     ;EndIf 
    ;GetClientRect_(hwnd, @rc.RECT)
    ;InvalidateRect_(hwnd, rc, 0)
    ;MapWindowPoints_(hwnd, parenthwnd, @rc, 2)
    ;ValidateRect_(parenthwnd, rc)
    
    ;GetWindowRect_(hwnd, @rc.RECT)
    ;MapWindowPoints_(0, hwnd, @rc, 2)
    ;InvalidateRect_(hwnd, rc, 0)
    ;MapWindowPoints_(hwnd, parenthwnd, @rc, 2)
    ;ValidateRect_(parenthwnd, rc)
  EndIf
  
  If trackwin()\windowType = #WINDOWTYPE_PANELEX
    If ListSize(panelexpage()) > 0
      *this = panelexpage()
      ForEach panelexpage()
        If panelexpage()\containerHandle = hwnd And panelexpage()\displayed <> 0
          If GetWindowLongPtr_(panelexpage()\scrollBarBox, #GWL_STYLE) & #WS_VISIBLE
            
            GetClientRect_(panelexpage()\scrollBarBox, @rc.RECT)
            InvalidateRect_(panelexpage()\scrollBarBox, rc, 0)
            root = GetParent_(getRootPanelExPageHwnd(panelexpage()\scrollBarBox))
            MapWindowPoints_(panelexpage()\scrollBarBox, root, @rc, 2)
            
            setPanelExClippedRect(@rc, panelexpage()\scrollBarBox, root)
            
            ValidateRect_(GetParent_(getRootPanelExPageHwnd(panelexpage()\scrollBarBox)), rc)
          EndIf
          Break
        EndIf
      Next
      ChangeCurrentElement(panelexpage(), *this)
    EndIf
  EndIf
  ;RedrawWindow_(hwnd,0,0,#RDW_NOERASE|#RDW_FRAME|#RDW_INVALIDATE|#RDW_UPDATENOW|#RDW_ALLCHILDREN)
  ;GetClientRect_(hwnd, @rc.RECT)
  ;InvalidateRect_(hwnd, rc, 0)
  If trackWin()\windowType = #WINDOWTYPE_SYSPROGRESSBAR; Or trackWin()\windowType = #WINDOWTYPE_SYSTAB
    GetClientRect_(hwnd, @rc.RECT)
    InvalidateRect_(hwnd, rc, 0)
    ;GetWindowRect_(hwnd, @rc.RECT)
    root = GetParent_(getRootPanelExPageHwnd(hwnd))
    MapWindowPoints_(hwnd, root, @rc, 2)
    setPanelExClippedRect(@rc, hwnd, root)
    ValidateRect_(root, rc)
  EndIf
  
  
  ProcedureReturn #True
  
EndProcedure
; call this command to invalidate parent window and validate any progress bars
Procedure validateProgressbars(parenthwnd)
  
  LockMutex(trackWinMutex)
  
  rootpage = getRootPanelExPageHwnd(parenthwnd)
  root = GetParent_(rootpage)
  containerhwnd = GetParent_(parenthwnd)
  GetClientRect_(containerhwnd, @rc.RECT)
  MapWindowPoints_(containerhwnd, root, @rc, 2)

  If panelexpage()\vScrollVisible
    GetClientRect_(panelexpage()\vScrollBar, @trc.RECT)
    rc\right = rc\right - trc\right
  EndIf
  If panelexpage()\hScrollVisible
    GetClientRect_(panelexpage()\hScrollBar, @trc.RECT)
    rc\bottom = rc\bottom - trc\bottom
  EndIf
  InvalidateRect_(root, rc, 0)
  
  If GetWindowLongPtr_(panelexpage()\scrollBarBox, #GWL_STYLE) & #WS_VISIBLE
    InvalidateRect_(panelexpage()\scrollBarBox, 0, 0)
  EndIf
  ;GetClientRect_(parenthwnd, @rc.RECT)
  ;InvalidateRect_(parenthwnd, rc, 0)
  EnumChildWindows_(parenthwnd, @validateProgressbarsRect(), parenthwnd)
  
  UnlockMutex(trackWinMutex)
  ProcedureReturn rootpage
  
EndProcedure


Procedure PanelExCallback(Window, message, wParam, lParam)
  
  LockMutex(panelMutex)
  
  ; find associated panel
  ForEach panelex()
    If panelex()\Handle = Window
      found = #True
      Break
    EndIf
  Next
  
  If found = 0
    UnlockMutex(panelMutex)
    ProcedureReturn DefWindowProc_(Window, message, wParam, lParam)
  EndIf
  
  
  Select message
      
    Case #WM_THEMECHANGED
      
      If XPthemeActive <> 0
        
        CallFunctionFast(*CloseThemeData, hThemeExplorerbar)
        CallFunctionFast(*CloseThemeData, hThemeRebar)
        CallFunctionFast(*CloseThemeData, hThemeTab)
        Window = GetForegroundWindow_()
        hThemeExplorerbar = *OpenThemeData(Window, "explorerbar")
        hThemeRebar = *OpenThemeData(Window, "rebar")
        hThemeTab = *OpenThemeData(Window, "tab")
        
      Else
        hThemeExplorerbar = 0
        hThemeRebar = 0
        hThemeTab = 0
      EndIf
      
    Case #WM_PAINT
      
      ;getclientrect_(panelexpage()\containerHandle, @rc.RECT)
      ;ValidateRect_(GetParent_(panelexpage()\containerHandle), @rc)
      
      BeginPaint_(Window, @ps.PAINTSTRUCT)
      ps\fErase = 0
      ps\rcPaint\top = 0
      ps\rcPaint\left = 0
      ps\rcPaint\right = 0
      ps\rcPaint\bottom = 0
      EndPaint_(Window, @ps)
      
      ;Result  = DefWindowProc_(Window, message, wParam, lParam)
      
      UnlockMutex(panelMutex)
      ;ProcedureReturn 0
      ProcedureReturn 1
      
    Case #WM_ERASEBKGND
      
      UnlockMutex(panelMutex)
      ProcedureReturn 1
      
    Case #WM_SIZE
      
      ;SendMessage_(panelex()\Handle, #WM_SETREDRAW, #False, 0)
      
      ; resize panelex page windows
      ForEach panelexpage()
        If panelexpage()\containerHandle = Window
          
          If panelexpage()\autoScroll = #False
            GetClientRect_(Window, @rc.RECT)
            *thispanel = @panelex()
            *thispage = @panelexpage()
            handle = panelexpage()\handle
            UnlockMutex(panelMutex)
            
            MoveWindow_(handle, 0, 0, rc\right-rc\left, rc\bottom-rc\top, #False)
            
            LockMutex(panelMutex)
            ChangeCurrentElement(panelex(), *thispanel)
            ChangeCurrentElement(panelexpage(), *thispage)
          Else
            updatePanelExPageScrolling(0, 0)
          EndIf

          If panelexpage()\displayed = -1
            displayed = panelexpage()\Handle
            container = panelexpage()\containerHandle
            *thisPanelExPage = @panelexpage()
          EndIf
          
        EndIf
      Next
      
      
      If displayed <> 0
        
        ChangeCurrentElement(panelexpage(), *thisPanelExPage)
        
        If panelexpage()\autoScroll = #True
          handlePanelExPageAutoScroll()
        EndIf
        updatePanelExPageScrollbars()
        
        If panelexpage()\hScrollVisible = #True And panelexpage()\vScrollVisible = #True
          RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
          RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
          RedrawWindow_(panelexpage()\scrollBarBox,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
        ElseIf panelexpage()\hScrollVisible = #True
          RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
        ElseIf panelexpage()\vScrollVisible = #True
          RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
        EndIf
        
        If panelex()\usercallback <> 0
          ret = CallWindowProc_(panelex()\usercallback, Window, message, wParam, lParam)
          If ret <> 0
            UnlockMutex(panelMutex)
            ProcedureReturn ret
          EndIf
        EndIf
        
        If ret = 0
          root = getRootPanelExPageHwnd(displayed)
          If root = displayed
            ;Debug "displayed: "+Str(displayed)
            
            validateProgressbars(displayed) ; invalidates panelex hwnd and validates any sys progress bars inside
            *thispanel = @panelex()
            *thispage = @panelexpage()
            UnlockMutex(panelMutex)
            RedrawWindow_(displayed,0,0,#RDW_UPDATENOW);|#RDW_ALLCHILDREN)
            LockMutex(panelMutex)
            ChangeCurrentElement(panelex(), *thispanel)
            ChangeCurrentElement(panelexpage(), *thispage)
            
          Else
            ;Debug "not"
          EndIf
        EndIf
        
        ForEach toolbarEx()
          If GetParent_(toolbarEx()\Handle) = displayed
            RedrawWindow_(toolbarEx()\Handle, 0, 0, #RDW_NOERASE|#RDW_ALLCHILDREN|#RDW_UPDATENOW)
          EndIf
        Next
        
      EndIf
      
    Case #WM_UPDATE
      
      ; resize panelex page windows
      ForEach panelexpage()
        If panelexpage()\containerHandle = Window
          
          If panelexpage()\displayed = -1
            displayed = panelexpage()\Handle
            container = panelexpage()\containerHandle
            *thisPanelExPage = @panelexpage()
            Break
          EndIf
          
        EndIf
      Next
      
      If displayed <> 0
        
        ChangeCurrentElement(panelexpage(), *thisPanelExPage)
        root = validateProgressbars(displayed) ; invalidates panelex hwnd and validates any sys progress bars inside
        *thispanel = @panelex()
        *thispage = @panelexpage()
        UnlockMutex(panelMutex)
        GetClientRect_(displayed, rc.RECT)
        MapWindowPoints_(displayed, root, rc, 2)
        RedrawWindow_(displayed, rc, 0, #RDW_UPDATENOW|#RDW_NOCHILDREN|#RDW_NOERASE)
        LockMutex(panelMutex)
        ChangeCurrentElement(panelex(), *thispanel)
        ChangeCurrentElement(panelexpage(), *thispage)
        
      EndIf
      
    Case #WM_WINDOWPOSCHANGING
      
      If panelex()\usercallback <> 0
        ret = CallWindowProc_(panelex()\usercallback, Window, message, wParam, lParam)
        If ret <> 0
          UnlockMutex(panelMutex)
          ProcedureReturn ret
        EndIf
      EndIf

    Case #WM_NOTIFY
      
      ;Result = CallWindowProc_(GetParent_(window), window, message, wParam, lParam)
      ;Result = CallWindowProc_(GetWindowLongPtr_(GetParent_(window), #GWLP_WNDPROC),window,message,wParam,lParam)
      Result = SendMessage_(GetParent_(Window),message,wParam,lParam)
      
    Case #WM_NCHITTEST
      
      Result = #HTTRANSPARENT
      
    Case #WM_HSCROLL
      
      ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
      *previousPanelExPage = @panelexpage()
      
      ChangeCurrentElement(panelexpage(), panelex()\displayedPage)

      If lParam = panelexpage()\hScrollBar And panelexpage()\autoScroll = #True
        
        ;/ scroll bar thumb moved
        If LOWORD(wParam) = #SB_THUMBPOSITION Or LOWORD(wParam) = #SB_THUMBTRACK
          
          pos = HIWORD(wParam)  ; get position of thumb in scrollbar
          
          ; scroll page by x offset
          updatePanelExPageScrolling(panelexpage()\lastHscrollPos - pos, 0)
          
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS
          scinfo\nPos = pos
          SetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo, #True)
          
          panelexpage()\lastHscrollPos = pos
          
        ;/ left scrollbar arrow button pressed
        ElseIf LOWORD(wParam) = #SB_LINELEFT
          
          If panelexpage()\hScrollLineAmount = 0
            amount = #HSCROLL_LINEAMOUNT
          Else
            amount = panelexpage()\hScrollLineAmount
          EndIf
          
          ; make sure amount doesn't negative passed min scrollbar range
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS|#SIF_RANGE
          GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
          If scinfo\nPos-amount < scinfo\nMin
            amount = amount - Abs(scinfo\nPos-amount)
          EndIf
          
          If amount > 0
            
            ; scroll page by x offset
            updatePanelExPageScrolling(amount, 0)
            
            panelexpage()\lastHscrollPos = panelexpage()\lastHscrollPos - amount
            scinfo\fMask = #SIF_POS
            scinfo\nPos = panelexpage()\lastHscrollPos
            SetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo, #True)
            
          EndIf
          
        ;/ right scrollbar arrow button pressed
        ElseIf LOWORD(wParam) = #SB_LINERIGHT
          
          If panelexpage()\hScrollLineAmount = 0
            amount = #HSCROLL_LINEAMOUNT
          Else
            amount = panelexpage()\hScrollLineAmount
          EndIf
          
          ; make sure amount doesn't go passed scrollbar max range
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS|#SIF_RANGE
          GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
          pos = scinfo\nPos
          
          scinfo\fMask = #SIF_POS
          scinfo\nPos = pos + amount
          SetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo, #True)
          GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
          amount = scinfo\nPos-pos
          
          If amount > 0
            
            ; scroll page by x offset
            updatePanelExPageScrolling(-amount, 0)
            
            panelexpage()\lastHscrollPos = panelexpage()\lastHscrollPos + amount
            
          EndIf
          
        ;/ scroll to left edge
        ElseIf LOWORD(wParam) = #SB_LEFT
          
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_RANGE
          GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
          
          scinfo\fMask = #SIF_POS
          scinfo\nPos = scinfo\nMin
          SetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo, #True)
          amount = panelexpage()\lastHscrollPos-scinfo\nMin
          
          If amount > 0
            
            ; scroll page by x offset
            updatePanelExPageScrolling(amount, 0)
            
            panelexpage()\lastHscrollPos = scinfo\nMin
            
          EndIf
          
        ;/ scroll to right edge
        ElseIf LOWORD(wParam) = #SB_RIGHT
          
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS|#SIF_RANGE
          GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
          pos = scinfo\nPos
          
          scinfo\fMask = #SIF_POS
          scinfo\nPos = scinfo\nMax
          SetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo, #True)
          GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
          amount = scinfo\nPos-pos
          
          If amount > 0
            
            ; scroll page by x offset
            updatePanelExPageScrolling(-amount, 0)
            
            panelexpage()\lastHscrollPos = scinfo\nPos
            
          EndIf
          
        ;/ scroll page left
        ElseIf LOWORD(wParam) = #SB_PAGELEFT
          
          ; make sure amount doesn't negative passed min scrollbar range
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS|#SIF_RANGE|#SIF_PAGE
          GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
          amount = scinfo\nPage
          If scinfo\nPos-amount < scinfo\nMin
            amount = amount - Abs(scinfo\nPos-amount)
          EndIf
          
          If amount > 0
            
            ; scroll page by x offset
            updatePanelExPageScrolling(amount, 0)
            
            panelexpage()\lastHscrollPos = panelexpage()\lastHscrollPos - amount
            scinfo\fMask = #SIF_POS
            scinfo\nPos = panelexpage()\lastHscrollPos
            SetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo, #True)
            
          EndIf
          
        ;/ scroll page right
        ElseIf LOWORD(wParam) = #SB_PAGERIGHT
          
          ; make sure amount doesn't go passed scrollbar max range
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS|#SIF_RANGE|#SIF_PAGE
          GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
          pos = scinfo\nPos
          amount = scinfo\nPage
          
          scinfo\fMask = #SIF_POS
          scinfo\nPos = pos + amount
          SetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo, #True)
          GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
          amount = scinfo\nPos-pos
          
          If amount > 0
            
            ; scroll page by x offset
            updatePanelExPageScrolling(-amount, 0)
            
            panelexpage()\lastHscrollPos = panelexpage()\lastHscrollPos + amount
            
          EndIf
          
        EndIf
        
        validateProgressbars(panelexpage()\Handle) ; invalidates panelex hwnd and validates any sys progress bars inside
        *thispanel = @panelex()
        *thispage = @panelexpage()
        handle = panelexpage()\Handle
        UnlockMutex(panelMutex)
        RedrawWindow_(handle,0,0,#RDW_ERASE|#RDW_ERASENOW|#RDW_UPDATENOW);|#RDW_ALLCHILDREN)
        LockMutex(panelMutex)
        ChangeCurrentElement(panelex(), *thispanel)
        ChangeCurrentElement(panelexpage(), *thispage)
        
      EndIf
      
      ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
      ChangeCurrentElement(panelexpage(), *previousPanelExPage)
      
      Result = 0
      
    Case #WM_VSCROLL
      
      ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
      *previousPanelExPage = @panelexpage()
      
      ChangeCurrentElement(panelexpage(), panelex()\displayedPage)
      
      If lParam = panelexpage()\vScrollBar And panelexpage()\autoScroll = #True
        
        ;/ scroll bar thumb moved
        If LOWORD(wParam) = #SB_THUMBPOSITION Or LOWORD(wParam) = #SB_THUMBTRACK
          
          pos = HIWORD(wParam)  ; get position of thumb in scrollbar
          
          ; scroll page by y offset
          updatePanelExPageScrolling(0, panelexpage()\lastVscrollPos - pos)
          
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS
          scinfo\nPos = pos
          SetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo, #True)
          
          panelexpage()\lastVscrollPos = pos
          
        ;/ top scrollbar arrow button pressed
        ElseIf LOWORD(wParam) = #SB_LINEUP
          
          If panelexpage()\vScrollLineAmount = 0
            amount = #VSCROLL_LINEAMOUNT
          Else
            amount = panelexpage()\vScrollLineAmount
          EndIf
          
          ; make sure amount doesn't negative passed min scrollbar range
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS|#SIF_RANGE
          GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
          If scinfo\nPos-amount < scinfo\nMin
            amount = amount - Abs(scinfo\nPos-amount)
          EndIf
          
          If amount > 0
            
            ; scroll page by y offset
            updatePanelExPageScrolling(0, amount)
            
            panelexpage()\lastVscrollPos = panelexpage()\lastVscrollPos - amount
            scinfo\fMask = #SIF_POS
            scinfo\nPos = panelexpage()\lastVscrollPos
            SetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo, #True)
            
          EndIf
          
        ;/ bottom scrollbar arrow button pressed
        ElseIf LOWORD(wParam) = #SB_LINEDOWN
          
          If panelexpage()\vScrollLineAmount = 0
            amount = #VSCROLL_LINEAMOUNT
          Else
            amount = panelexpage()\vScrollLineAmount
          EndIf
          
          ; make sure amount doesn't go passed scrollbar max range
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS|#SIF_RANGE
          GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
          pos = scinfo\nPos
          
          scinfo\fMask = #SIF_POS
          scinfo\nPos = pos + amount
          SetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo, #True)
          GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
          amount = scinfo\nPos-pos
          
          If amount > 0
            
            ; scroll page by y offset
            updatePanelExPageScrolling(0, -amount)
            
            panelexpage()\lastVscrollPos = panelexpage()\lastVscrollPos + amount
            
          EndIf
          
        ;/ scroll to top edge
        ElseIf LOWORD(wParam) = #SB_TOP
          
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_RANGE
          GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
          
          scinfo\fMask = #SIF_POS
          scinfo\nPos = scinfo\nMin
          SetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo, #True)
          amount = panelexpage()\lastVscrollPos-scinfo\nMin
          
          If amount > 0
            
            ; scroll page by y offset
            updatePanelExPageScrolling(0, amount)
            
            panelexpage()\lastVscrollPos = scinfo\nMin
            
          EndIf
          
        ;/ scroll to bottom edge
        ElseIf LOWORD(wParam) = #SB_BOTTOM
          
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS|#SIF_RANGE
          GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
          pos = scinfo\nPos
          
          scinfo\fMask = #SIF_POS
          scinfo\nPos = scinfo\nMax
          SetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo, #True)
          GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
          amount = scinfo\nPos-pos
          
          If amount > 0
            
            ; scroll page by y offset
            updatePanelExPageScrolling(0, -amount)
            
            panelexpage()\lastVscrollPos = scinfo\nPos
            
          EndIf
          
        ;/ scroll page up
        ElseIf LOWORD(wParam) = #SB_PAGEUP
          
          ; make sure amount doesn't negative passed min scrollbar range
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS|#SIF_RANGE|#SIF_PAGE
          GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
          amount = scinfo\nPage
          If scinfo\nPos-amount < scinfo\nMin
            amount = amount - Abs(scinfo\nPos-amount)
          EndIf
          
          If amount > 0
            
            ; scroll page by y offset
            updatePanelExPageScrolling(0, amount)
            
            panelexpage()\lastVscrollPos = panelexpage()\lastVscrollPos - amount
            scinfo\fMask = #SIF_POS
            scinfo\nPos = panelexpage()\lastVscrollPos
            SetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo, #True)
            
          EndIf
          
        ;/ scroll page down
        ElseIf LOWORD(wParam) = #SB_PAGEDOWN
          
          ; make sure amount doesn't go passed scrollbar max range
          scinfo.SCROLLINFO
          scinfo\cbSize = SizeOf(SCROLLINFO)
          scinfo\fMask = #SIF_POS|#SIF_RANGE|#SIF_PAGE
          GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
          pos = scinfo\nPos
          amount = scinfo\nPage
          
          scinfo\fMask = #SIF_POS
          scinfo\nPos = pos + amount
          SetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo, #True)
          GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
          amount = scinfo\nPos-pos
          
          If amount > 0
            
            ; scroll page by y offset
            updatePanelExPageScrolling(0, -amount)
            
            panelexpage()\lastVscrollPos = panelexpage()\lastVscrollPos + amount
            
          EndIf
          
        EndIf
        
        page = validateProgressbars(panelexpage()\Handle) ; invalidates root panelex hwnd and validates any sys progress bars inside passed hwnd
        *thispanel = @panelex()
        *thispage = @panelexpage()
        UnlockMutex(panelMutex)
        RedrawWindow_(page,0,0,#RDW_UPDATENOW)
        LockMutex(panelMutex)
        ChangeCurrentElement(panelex(), *thispanel)
        ChangeCurrentElement(panelexpage(), *thispage)
        
      EndIf
      
      ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
      ChangeCurrentElement(panelexpage(), *previousPanelExPage)
      
      Result = 0
      
   
    Default
      
      Result  = DefWindowProc_(Window, message, wParam, lParam)
      
  EndSelect
  
  UnlockMutex(panelMutex)
  ProcedureReturn Result
  
EndProcedure

; used for checking whether a RECT is visible in a panelex's scrolling viewport, returns true if so
Procedure rectVisibleInPanelEx(*rc.RECT, window)
  
  GetClientRect_(GetParent_(window), crc.RECT)
  MapWindowPoints_(GetParent_(window), window, @crc, 2)
  If IntersectRect_(@trc.RECT, *rc, crc) <> 0
    ProcedureReturn #True
  EndIf
  
  ProcedureReturn 0
  
EndProcedure


#PixelFormat32bppARGB = $26200A ; private
#PixelFormat32bppPARGB = 925707 ; private
Procedure.i gBufferImage(*ImageID)
  Protected *bitmap, bmp.BITMAP, pixelformat

  If InitGDIPlus() <> 0

    If IsImage(*ImageID) : *ImageID = ImageID(*ImageID) : EndIf
    If GetObject_(*ImageID,SizeOf(BITMAP),@bmp)
      
      If bmp\bmBitsPixel = 32
        CallFunctionFast(*GdipCreateBitmapFromScan0, bmp\bmWidth, bmp\bmHeight, 4*bmp\bmWidth, #PixelFormat32bppARGB, bmp\bmBits, @*bitmap)
      Else
        CallFunctionFast(*GdipCreateBitmapFromHBITMAP, *ImageID, 0, @*bitmap)
      EndIf
      
      If *bitmap
          CallFunctionFast(*GdipImageRotateFlip,*bitmap,6)
      
          ProcedureReturn *bitmap
      
      EndIf
    EndIf
      
  EndIf
  
EndProcedure

Procedure Get32BitColors(pBitmap) 

  GetObject_(pBitmap, SizeOf(BITMAP), @bmp.BITMAP) 
  *bmi.BITMAPINFO = AllocateMemory(SizeOf(BITMAPINFO)+SizeOf(RGBQUAD)*255)
  With *bmi\bmiHeader
    \biSize         = SizeOf(BITMAPINFOHEADER) 
    \biWidth        = bmp\bmWidth 
    \biHeight       = -bmp\bmHeight 
    \biPlanes       = 1 
    \biBitCount     = 32 
  EndWith 
  hDC = GetWindowDC_(#Null) 
  GetDIBits_(hDC, pBitmap, 0, bmp\bmHeight, #Null, *bmi, #DIB_RGB_COLORS)
  *pPixels = AllocateMemory(*bmi\bmiHeader\biSizeImage)
  iRes = GetDIBits_(hDC, pBitmap, 0, bmp\bmHeight, *pPixels, *bmi, #DIB_RGB_COLORS) 
  ReleaseDC_(#Null, hDC) 
  FreeMemory(*bmi)
  ProcedureReturn *pPixels 
  
EndProcedure 

Structure FrameRate
  TargetFPS.f
  TimeFactor.f
  SpeedFactor.f ; used when moving objects, i.e x + speed * SpeedFactor
  CurrentTicks.q
  LastTicks.q
  
  timePf.q ; time per frame
  nextTime.q ; the time when the next frame should be due
EndStructure

Procedure deltaTime(*FL.FrameRate)
  
  If QueryPerformanceCounter_(@ticks.q)
    *FL\CurrentTicks = ticks
    ;If *FL\TimeFactor = 0
    QueryPerformanceFrequency_(@freq.q)
    Debug freq
      *FL\TimeFactor = 1.0/freq
      ;*FL\TimeFactor = (60.0/frq);**FL\TargetFPS
      *FL\timePf = freq/*FL\TargetFPS
    ;EndIf
  Else
  ;  *FL\CurrentTicks = ElapsedMilliseconds();timeGetTime_()
  ;  If *FL\TimeFactor = 0
  ;    ;timeGetDevCaps_(@tc.TIMECAPS, SizeOf(TIMECAPS))
  ;    ;freq.d = tc\wPeriodMin
  ;    *FL\TimeFactor = 0.001
  ;    *FL\timePf = 1000/*FL\TargetFPS
  ;    Debug freq
  ;    Debug *FL\TargetFPS
  ;    Debug "timePf: "+Str(*FL\timePf)
  ;  EndIf
  EndIf
  
  If *FL\LastTicks = 0
    *FL\LastTicks = *FL\CurrentTicks
    *FL\nextTime = *FL\CurrentTicks
  EndIf
  
  *FL\SpeedFactor = (*FL\CurrentTicks - *FL\LastTicks) * *FL\TimeFactor
  *FL\LastTicks = *FL\CurrentTicks
  
EndProcedure

;-
;- animationThread
#WM_ANIMATE = #WM_APP+1337 ; private
Structure ANIMATION
  
  ; passed message parameters
  hwnd.i ; handle of window to animate
  srcRc.RECT ; source window rect position/dimensions
  dstRc.RECT ; destination window rect position/dimensions
  time.i ; number of millisecs to play animation
  velocity.f ; initial velocity
  acceleration.f ; acceleration value
  alpha.f ; alpha transparency value
  
  ; animation thread internal
  sx.f
  sy.f
  sx2.f
  sy2.f
  dx.f
  dy.f
  dx2.f
  dy2.f
  update.b
  finished.b
   
EndStructure

Procedure animationWindowCallback(window, message, wParam, lParam)

  ProcedureReturn DefWindowProc_(window, message, wParam, lParam)
  
EndProcedure

Procedure animationThread(*dummy)
   
  debuglog("Animation thread started...")
  
  windowClass.s = #AppName+"_Animation Thread"
  wc.WNDCLASSEX
  wc\cbSize  = SizeOf(WNDCLASSEX)
  wc\style = 0
  wc\lpfnWndProc  = @animationWindowCallback()
  wc\lpszClassName  = @windowClass
  RegisterClassEx_(@wc)
  
  SetThreadAffinityMask_(GetCurrentThread_(), 1) ; make sure this thread runs on one core only, due to possible timing problems with queryperformance
  ;SetThreadPriority_(GetCurrentThread_(), #THREAD_PRIORITY_TIME_CRITICAL)
  
  ;timeGetDevCaps_(@tc.TIMECAPS, SizeOf(TIMECAPS))
  ;timeBeginPeriod_(tc\wPeriodMin)
  
;   IDD.IDirectDraw7                 
; 
;   If OpenLibrary(0,"ddraw.dll")
;     If CallFunction(0,"DirectDrawCreateEx",0,@IDD.IDirectDraw7,?IID_IDirectDraw7,0) <> 0
;       MessageRequester("Warning:","Couldn't init DirectDraw",0)
;       End
;     Else 
;       bopen = #True 
;     EndIf
;   Else
;     MessageRequester("Warning:","ProGUI Couldn't init DirectDraw",0)
;     End
;   EndIf 
;   
;   DataSection
;     IID_IDirectDraw7:
;       Data.l $15e65ec0
;       Data.w $3b9c, $11d2
;       Data.b $b9, $2f, $00, $60, $97, $97, $ea, $5b
;   EndDataSection 
    
  FL.FrameRate
  ;ExamineDesktops()
  FL\TargetFPS = 60;DesktopFrequency(0) ; set desired frames per second
  
  ;speed.d = 4
  
  ; create message only window
  animationThreadHwnd = CreateWindowEx_(0, windowClass, #Null, 0, 0, 0, 0, 0, #HWND_MESSAGE, #Null,  GetModuleHandle_(0), #Null)
  If animationThreadHwnd <> 0
    
    msg.MSG ; message structure for receiving window messages
    
    NewList anim.ANIMATION()
    
    ; main animation loop
    Repeat
      
      ; process all pending messages
      Repeat
        
        Event = 0
        If ListSize(anim()) = 0
          If GetMessage_(@msg, animationThreadHwnd, 0, 0) <> -1
            Event = msg\message
          EndIf
        Else
          If PeekMessage_(@msg, animationThreadHwnd, 0, 0, #PM_REMOVE) <> 0
            Event = msg\message
          EndIf
        EndIf
        
        If Event <> 0 And msg\hwnd = animationThreadHwnd
          
          lparam = msg\lParam
          
          Select Event
              
            Case #WM_ANIMATE
              
              Debug "animWin: Animate!"
              
              ; make sure lparam contains pointer
              If lparam <> 0
                
                *anim.ANIMATION = lparam
                Debug "hwnd: "+Str(*anim\hwnd)
                ; see if this window is already animating
                found = 0
                ForEach anim()
                  If anim()\hwnd = *anim\hwnd
                    found = #True
                    Break
                  EndIf
                Next
                If found = #False
                  AddElement(anim())
                EndIf
                ; create/update animation tracking info for this window
                CopyStructure(*anim, anim(), ANIMATION)
                FreeMemory(*anim)
                
                anim()\sx = anim()\srcRc\left
                anim()\sy = anim()\srcRc\top
                anim()\sx2 = anim()\srcRc\right
                anim()\sy2 = anim()\srcRc\bottom
                
                ;Debug "src left: "+Str(anim()\sx)+" top: "+Str(anim()\sy)+" right: "+Str(anim()\sx2)+" bottom: "+Str(anim()\sy2)
                
                anim()\dx = anim()\dstRc\left
                anim()\dy = anim()\dstRc\top
                anim()\dx2 = anim()\dstRc\right
                anim()\dy2 = anim()\dstRc\bottom
                
                ;Debug "dst left: "+Str(anim()\dx)+" top: "+Str(anim()\dy)+" right: "+Str(anim()\dx2)+" bottom: "+Str(anim()\dy2)
                
                distance.d = Abs(anim()\sy2-anim()\dy2)
                anim()\velocity = 2.0;distance/40;anim()\time
                
                anim()\update = #True
                
              EndIf
              
            Default
              
              Debug "animWin: "+Str(Event)
              
          EndSelect
          
        EndIf
      Until Event = 0 Or Event = #WM_QUIT Or Event = #WM_CLOSE Or Event = #WM_DESTROY
      
      
      
      ; do animations here
      If ListSize(anim()) > 0
        
        If FL\LastTicks = 0
          
          If QueryPerformanceCounter_(@ticks.q)
            
            FL\CurrentTicks = ticks
            QueryPerformanceFrequency_(@freq.q)
            frq.f = freq
            FL\TimeFactor = 1.0/frq
            FL\timePf = freq/FL\TargetFPS
            FL\nextTime = FL\CurrentTicks
            FL\LastTicks = FL\CurrentTicks
          Else
          
          EndIf
          
          update = #True
        EndIf
        
        
        If update = #True; Or update = 0
        
        hdwp = BeginDeferWindowPos_(ListSize(anim()))
        
        ForEach anim()
          
          ;If anim()\update = #True
          
            ; expanding
            If anim()\sy2 < anim()\dy2
              anim()\sy2 + anim()\velocity; * FL\SpeedFactor
              ratio.d = 255.0/distance
              anim()\alpha = 255-Abs(anim()\sy2 - anim()\dy2)*ratio
              If anim()\sy2 >= anim()\dy2
                anim()\sy2 = anim()\dy2
                anim()\alpha = 255
                anim()\finished = #True
              EndIf
            ; collapsing
            Else
              anim()\sy2 - anim()\velocity; * FL\SpeedFactor
              ratio.d = 255.0/distance
              anim()\alpha = (Abs(anim()\sy2 - anim()\dy2)*ratio)
              If anim()\sy2 <= anim()\dy2
                anim()\sy2 = anim()\dy2
                anim()\alpha = 0
                anim()\finished = #True
              EndIf
              collapsing = #True
            EndIf
            
            anim()\velocity = Abs(anim()\sy2 - anim()\dy2)/8
            If anim()\velocity < 1
              anim()\velocity = 1
            EndIf
            
            
            DeferWindowPos_(hdwp, anim()\hwnd, 0, Int(anim()\sx), Int(anim()\sy), Int(anim()\sx2-anim()\sx), Int(anim()\sy2-anim()\sy), #SWP_NOREDRAW)
            
            ;anim()\update = #False
            
          
          ;EndIf
          
        Next
        EndDeferWindowPos_(hdwp)
        
        update = #False
        EndIf
        
        ;deltaTime(FL)
        
        If QueryPerformanceCounter_(@ticks.q)
          
          FL\CurrentTicks = ticks
          ;FL\SpeedFactor = (FL\CurrentTicks - FL\LastTicks) * FL\TimeFactor
          ;Debug FL\SpeedFactor
          
          frq.f =freq
          FL\SpeedFactor = (FL\CurrentTicks - FL\LastTicks) / (frq / FL\TargetFPS);
          If FL\SpeedFactor <= 0  
            FL\SpeedFactor = FL\TargetFPS*(1.0/frq)
          EndIf
          
          FL\LastTicks = FL\CurrentTicks
          
        Else
        
        EndIf
        
        If FL\CurrentTicks > FL\nextTime
          
          ForEach anim()
            
            ;MoveWindow_(anim()\hwnd, anim()\sx, anim()\sy, anim()\sx2-anim()\sx, anim()\sy2-anim()\sy, #False)
            
            ;alpha.d = (Abs(anim()\sy2 - anim()\dy2)/8)
            ;If alpha = 0
            ;  alpha = 1
            ;EndIf
            ;alpha = 255.0/alpha
            
            
            SetPanelExPageAlpha(anim()\hwnd, 0, anim()\alpha, #True)
            
            SendMessage_(GetParent_(GetParent_(anim()\hwnd)), #WM_SIZE, 0, 0)
            SendMessage_(GetParent_(GetParent_(anim()\hwnd)), #WM_UPDATE, 0, 0)
            
            
            
            anim()\update = #True
            
            If anim()\finished = #True
              DeleteElement(anim())
            EndIf
            
          Next
          update = #True
          
          ; set time for next frame
          FL\nextTime + FL\timePf
          
          ; if we get more than a frame ahead, allow us To drop one
          ; otherwise, we will never catch up if we let the error
          ; accumulate, and message handling will suffer
          If FL\nextTime < FL\CurrentTicks
            FL\nextTime = FL\CurrentTicks + FL\timePf
            Debuglog("dropped")
          EndIf
          
        EndIf
        
        
      EndIf
      
      ;deltaTime(FL)
      
      ; reset framedelay if no animations - ready for setting next time anim is playing
      If ListSize(anim()) = 0
        FL\LastTicks = 0
      EndIf
      
      ;If update = #False
        ;If Abs(FL\CurrentTicks-FL\nextTime)/fl\timePf*10 > 1
        ;  Debug Abs(FL\CurrentTicks-FL\nextTime)/fl\timePf*10
        ;EndIf
        ;Delay(Abs(FL\CurrentTicks-FL\nextTime)/fl\timePf*10)
        ;Delay(10)
        ;IDD\WaitForVerticalBlank(4, 0)
        
        ;EndIf
        
        
      
    Until Event = #WM_QUIT Or Event = #WM_CLOSE Or Event = #WM_DESTROY
    
    DestroyWindow_(animationThreadHwnd)
    
  EndIf
  
  ;timeEndPeriod_(tc\wPeriodMin)
  
  
  debuglog("Animation thread closed.")
  LockMutex(animationMutex)
  animationThreadHwnd = 0
  UnlockMutex(animationMutex)
  
  ProcedureReturn 1337
  
EndProcedure

Procedure fillAlphaChannel(hdc, bitmap, Alpha.a)
  
  GetObject_(bitmap, SizeOf(BITMAP), @BM.BITMAP)
  width = BM\bmWidth
  height = BM\bmHeight
  
  If width > 0 And height > 0
    
    bitcount = BM\bmBitsPixel
    extrabytesperrow = (4 - (width * bitcount / 8) % 4) % 4
    sizeheaders = SizeOf(BITMAPFILEHEADER) + SizeOf(BITMAPINFOHEADER)
    sizeimage = (width * bitcount / 8 + extrabytesperrow) * height
    *bitmap = AllocateMemory(sizeheaders + sizeimage)
    
    *bitmapfile.BITMAPFILEHEADER = *bitmap
    *bitmapfile\bfType = Asc("B") + Asc("M") << 8
    *bitmapfile\bfSize = sizeheaders +sizeimage
    *bitmapfile\bfOffBits = sizeheaders
    *bitmapinfo.BITMAPINFOHEADER = *bitmap + SizeOf(BITMAPFILEHEADER)
    *bitmapinfo\biSize = SizeOf(BITMAPINFOHEADER)
    *bitmapinfo\biWidth = width
    *bitmapinfo\biHeight = height
    *bitmapinfo\biPlanes = 1
    *bitmapinfo\biBitCount = bitcount
    *bitmapinfo\biCompression = 0
    *bitmapinfo\biSizeImage = sizeimage
    
    *bitmapdata = *bitmap + sizeheaders
    
    *bitmapdatapos = *bitmapdata
    
    GetDIBits_(hdc, bitmap, 0, height, *bitmap+sizeheaders, *bitmapinfo, #DIB_RGB_COLORS)
    
    For y = 0 To height - 1
      For x = 0 To width - 1
        
        a.a = PeekB(*bitmapdatapos + 3)
        If a = 0
          PokeB(*bitmapdatapos + 3, Alpha)
        EndIf
        
        *bitmapdatapos + bitcount / 8
      Next
      *bitmapdatapos + extrabytesperrow
    Next
    
    SetDIBits_(hdc, bitmap, 0, height, *bitmap+sizeheaders, *bitmapinfo, #DIB_RGB_COLORS)
    
    FreeMemory(*bitmap)
    
  EndIf
  
EndProcedure

Structure wmprintEnumStruct
  pageHwnd.i
  divertedWindow.i ; this is the root panelex page or the actual page if alpha transparent
  dc.i
  inAlpha.b ; flags whether the page is semi-transparent
EndStructure
Procedure wmprintEnumChildProc(hwnd, *enumStruct.wmprintEnumStruct)
  Static dc, bitmap, dcWidth, dcHeight
  
  ; is control child of this panelex page
  If GetParent_(hwnd) = *enumStruct\pageHwnd
    
    class.s = Space(255)
    GetClassName_(hwnd, @class, 255)
    
    ; if control a button class
    If class = "Button"
      
      style = GetWindowLongPtr_(hwnd, #GWL_STYLE)
      *callback = GetWindowLongPtr_(hwnd, #GWL_WNDPROC)
      
      ; check if groupbox
      If (style & #BS_GROUPBOX = #BS_GROUPBOX)
 
        GetWindowRect_(hwnd, rec.RECT)
        MapWindowPoints_(0, *enumStruct\divertedWindow, rec, 2)
        
        ShowWindow_(hwnd, #SW_HIDE)

        If dc = 0 Or rec\right-rec\left > dcWidth Or rec\bottom-rec\top > dcHeight
          
          If rec\right-rec\left > dcWidth
            dcWidth = rec\right-rec\left
          EndIf
          
          If rec\bottom-rec\top > dcHeight
            dcHeight = rec\bottom-rec\top
          EndIf
          
          If dc <> 0
            DeleteDC_(dc)
            DeleteObject_(bitmap)
          EndIf
          
          dc = CreateCompatibleDC_(*enumStruct\dc)
          bitmap = CreateCompatibleBitmap_(*enumStruct\dc, dcWidth, dcHeight)
          SelectObject_(dc, bitmap)
          
        EndIf

        BitBlt_(dc, 0, 0, rec\right-rec\left, rec\bottom-rec\top, *enumStruct\dc, rec\left, rec\top, #SRCCOPY)
        CallWindowProc_(*callback, hwnd, #WM_PRINT, dc, #PRF_CLIENT|#PRF_OWNED|#PRF_CHILDREN|#PRF_NONCLIENT)
        If *enumStruct\inAlpha
          fillAlphaChannel(dc, bitmap, 255) ; fills in any zero alpha areas, bloody windows destroying alpha when text drawn grrr! not perfect but the best work-around
        EndIf  
        BitBlt_(*enumStruct\dc, rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top, dc, 0, 0, #SRCCOPY)

      EndIf
      
    EndIf
    
  EndIf
    
  ProcedureReturn #True
  
EndProcedure

;- drawPanelPage
Procedure drawPanelPage(dc, Window, divertedWindow, inAlpha)
  Static z
  ; if dontdraw is set to false then check that were not in a panelex
  ; and set to true if so and exit - dont want to set up un-needed buffers and extra drawing
  If panelexpage()\dontdraw = 0
    *thispanel = @panelex()
    
    ForEach panelex()
      If panelex()\Handle = GetParent_(GetParent_(panelexpage()\containerHandle))
        debuglog("dontdraw false and in panelex: "+Str(panelex()\Handle))
        
        ; check if any buffers have already been allocated and free if so (don't need them if in nested panelex)
        ; this might happen if a panelex is moved into a panelex!
        ChangeCurrentElement(panelex(), panelexpage()\panelex)
        If panelex()\backgroundBitmap <> 0 ;panelex()\backgroundDC <> 0
          debuglog("free un-used buffers! panelex: "+Str(panelex()\Handle))
          FreeImage(panelex()\backgroundBitmap)
          DeleteDC_(panelex()\backgroundDC)
          panelex()\backgroundDC = 0
          panelex()\backgroundBitmap = 0
        EndIf
        
        ChangeCurrentElement(panelex(), *thispanel)
        panelexpage()\dontdraw = #True
        ProcedureReturn 0
      EndIf
    Next
    
    ChangeCurrentElement(panelex(), *thispanel)
  EndIf
  
  ; if we don't need to divert drawing then set divertedWindow to this window
  If divertedWindow = 0
    
    topPanelEx = #True ; this is the top most PanelEx
    divertedWindow = Window
    
    ;Debug "frame "+Str(z)+" handle: "+Str(Window)
    ;z=z+1
    
  EndIf
  
  originaldc = dc
  thisdc = dc
  
  ; set the window to the panelex container window to use container rect coords/dimensions
  containerHwnd = GetParent_(Window)
  GetClientRect_(containerHwnd, @rec.RECT)
  
  ;MapWindowPoints_(containerHwnd, GetParent_(divertedWindow), @rec, 2)
  ; subtract scrollbars from rect if visible
  If panelexpage()\vScrollVisible
    GetClientRect_(panelexpage()\vScrollBar, @trc.RECT)
    rec\right = rec\right - trc\right
  EndIf
  If panelexpage()\hScrollVisible
    GetClientRect_(panelexpage()\hScrollBar, @trc.RECT)
    rec\bottom = rec\bottom - trc\bottom
  EndIf
  If topPanelEx = #True; Or panelexpage()\alpha < 255
    MapWindowPoints_(containerHwnd, Window, @rec, 2)
  EndIf
  Window = containerHwnd
  
  
  ; get page's container
  ChangeCurrentElement(panelex(), panelexpage()\panelex)

  If panelexpage()\dontdraw = 0

    ; setup background buffer
    If panelex()\backgroundBitmap = 0 Or (rec\right-rec\left) > panelex()\backgroundWidth Or (rec\bottom-rec\top) > panelex()\backgroundHeight
      
      debuglog("setting up panelex buffer in : "+Str(panelexpage()\containerHandle))
      
      If panelex()\backgroundBitmap <> 0
        FreeImage(panelex()\backgroundBitmap)
        DeleteDC_(panelex()\backgroundDC)
      EndIf
      
      If (rec\right-rec\left) > panelex()\backgroundWidth
        panelex()\backgroundWidth = (rec\right-rec\left)*1.1;6
      EndIf
      
      If (rec\bottom-rec\top) > panelex()\backgroundHeight
        panelex()\backgroundHeight = (rec\bottom-rec\top)*1.1;6
      EndIf
      
      panelex()\backgroundBitmap = CreateImage(#PB_Any, panelex()\backgroundWidth, panelex()\backgroundHeight, 32)
      StartDrawing(ImageOutput(panelex()\backgroundBitmap))
      DrawingMode(#PB_2DDrawing_AllChannels)
      Box(0, 0, panelex()\backgroundWidth, panelex()\backgroundHeight, RGBA(0, 0, 0, 255))
      StopDrawing()
      panelex()\backgroundDC = CreateCompatibleDC_(dc)
      SelectObject_(panelex()\backgroundDC, ImageID(panelex()\backgroundBitmap))
      
    EndIf
    
    dc = panelex()\backgroundDC
  
  ElseIf panelexpage()\dontdraw = 2
    
    MapWindowPoints_(Window, divertedWindow, @rec, 2)
    
  EndIf
  
  ; if this is the top-most PanelEx then offset the buffer dc origin to the page scroll offset
  If topPanelEx = #True
    SetWindowOrgEx_(dc, rec\left, rec\top, 0)
  EndIf
  
  pageWidth = rec\right-rec\left
  pageHeight = rec\bottom-rec\top
  
  ; if page has alpha value then setup
  If panelexpage()\alpha < 255
    
    ; setup alpha buffer
    If panelex()\alphaBitmap = 0 Or (rec\right-rec\left) > panelex()\alphaWidth Or (rec\bottom-rec\top) > panelex()\alphaHeight
      
      debuglog("setting up panelex alpha buffer in : "+Str(panelexpage()\containerHandle))
      
      If panelex()\alphaBitmap <> 0
        FreeImage(panelex()\alphaBitmap)
        DeleteDC_(panelex()\alphaDC)
      EndIf
      
      If (rec\right-rec\left) > panelex()\alphaWidth
        panelex()\alphaWidth = (rec\right-rec\left)*1.1;6
      EndIf
      
      If (rec\bottom-rec\top) > panelex()\alphaHeight
        panelex()\alphaHeight = (rec\bottom-rec\top)*1.1;6
      EndIf
      
      panelex()\alphaBitmap = CreateImage(#PB_Any, panelex()\alphaWidth, panelex()\alphaHeight, 32)
      StartDrawing(ImageOutput(panelex()\alphaBitmap))
      DrawingMode(#PB_2DDrawing_AllChannels)
      Box(0, 0, panelex()\alphaWidth, panelex()\alphaHeight, RGBA(0, 0, 0, 0))
      StopDrawing()
      panelex()\alphaDC = CreateCompatibleDC_(dc)
      SelectObject_(panelex()\alphaDC, ImageID(panelex()\alphaBitmap))
      
      debuglog("width: "+Str(panelex()\alphaWidth)+" height: "+Str(panelex()\alphaHeight))
      
    EndIf
    
    dc = panelex()\alphaDC
    
    divertedWindow = Window
    
    thisAlpha = #True
    inAlpha = #True
    ax = rec\left
    ay = rec\top
    rec\left = 0
    rec\top = 0
    rec\right = pageWidth
    rec\bottom = pageHeight
    
  EndIf
  
  ; check if background is a gradient
  If panelexpage()\background <> -1
      
    ForEach Gradient()
      If panelexpage()\background = @Gradient()
        foundGradient = #True
        
        ; check if the gradient is alpha transparent
        If PeekB(@Gradient()\colour1+3)&$FF <> 255
          alphaGradient = #True
        ElseIf PeekB(@Gradient()\colour2+3)&$FF <> 255
          alphaGradient = #True
        ElseIf ListSize(Gradient()\colours()) > 0
          ForEach Gradient()\colours()
            If PeekB(@Gradient()\colours()+3)&$FF <> 255
              alphaGradient = #True
              Break
            EndIf
          Next
        EndIf
        
        Break
      EndIf
    Next
    
  EndIf
  
  ; draw parent window background if top PanelEx and in certain situation i.e background is '-1' or has semi-transparency
  If topPanelEx = #True And ((panelexpage()\background = -1) Or (panelexpage()\background >= 8 And panelexpage()\background <= 11) Or panelexpage()\background = 4 Or panelexpage()\background = 6 Or alphaGradient = #True Or panelexpage()\alpha < 255)
    tdc = dc
    If panelexpage()\alpha < 255
      dc = panelex()\backgroundDC
    EndIf
    GetClientRect_(GetParent_(panelex()\handle), @trc.RECT)
    MapWindowPoints_(GetParent_(panelex()\handle), panelexpage()\Handle, @trc, 2)
    brush = GetClassLongPtr_(GetParent_(panelex()\handle), -10); #GCLP_HBRBACKGROUND
    SetBrushOrgEx_(dc, trc\left, trc\top, @pt.POINT)
    FillRect_(dc, trc, brush)
    SetBrushOrgEx_(dc, pt\x, pt\y, @pt.POINT)
    If *DrawThemeParentBackground <> 0
      CallFunctionFast(*DrawThemeParentBackground, GetParent_(panelex()\Handle), dc, 0)
    EndIf
    dc = tdc
  EndIf

  If ThemesEnabled = #True
    If panelexpage()\background = 8 ; system button normal state
      CallFunctionFast(*DrawThemeBackground, hThemeButton, dc, 1, 0, @rec, 0)
    ElseIf panelexpage()\background = 9 ; system button hot state
      CallFunctionFast(*DrawThemeBackground, hThemeButton, dc, 1, 2, @rec, 0)
    ElseIf panelexpage()\background = 10 ; system button pressed state
      CallFunctionFast(*DrawThemeBackground, hThemeButton, dc, 1, 3, @rec, 0)
    ElseIf panelexpage()\background = 11 ; system button disabled state
      CallFunctionFast(*DrawThemeBackground, hThemeButton, dc, 1, 4, @rec, 0)
    ElseIf panelexpage()\background = 0
      CallFunctionFast(*DrawThemeBackground, hThemeTab, dc, 9, 0, @rec, 0)
    EndIf
  EndIf
  
  ; if border active then setup offscreen buffer for composition
  hMask = getBorderRgn(panelexpage()\borderHandle, rec)
  If ThemesEnabled = #True
    If hMask = 0 And panelexpage()\background = 8
      hMask = getBorderRgn(themeButtonBorder, rec)
    ElseIf hMask = 0 And panelexpage()\background = 9
      hMask = getBorderRgn(themeButtonHotBorder, rec)
    ElseIf hMask = 0 And panelexpage()\background = 10
      hMask = getBorderRgn(themeButtonPressedBorder, rec)
    ElseIf hMask = 0 And panelexpage()\background = 11
      hMask = getBorderRgn(themeButtonDisabledBorder, rec)
    ElseIf hMask = 0 And panelexpage()\background = 0
      hMask = getBorderRgn(themeTabBorder, rec)
    EndIf
  EndIf
  If hMask <> 0
    
    If thisAlpha = #False
      
      GetClientRect_(containerHwnd, @rrc.RECT)
      If inAlpha = #False
        MapWindowPoints_(containerHwnd, GetParent_(divertedWindow), @rrc, 2)
      Else
        MapWindowPoints_(containerHwnd, divertedWindow, @rrc, 2)
      EndIf
      OffsetRgn_(hMask, rrc\left, rrc\top)
      rgn = CreateRectRgn_(rrc\left,rrc\top,rrc\right,rrc\bottom)
      GetClipRgn_(dc, rgn)
      ExtSelectClipRgn_(dc, hMask, #RGN_AND)
      OffsetRgn_(hMask, -rrc\left, -rrc\top)
      
    Else
      
      GetClientRect_(Window, @rrc.RECT)
      rgn = CreateRectRgn_(rrc\left, rrc\top, rrc\right, rrc\bottom)
      GetClipRgn_(dc, rgn)
      ExtSelectClipRgn_(dc, hMask, #RGN_AND)
    
    EndIf
    
  Else
    originaldc = dc
  EndIf
  
  If panelexpage()\background <> -1
      
    If foundGradient = #True
      If InitGDIPlus() <> 0
        
        p1.POINT
        p1\x = rec\left
        p1\y = rec\top
        p2.POINT
        If Gradient()\style = 0
          p2\x = rec\right
          p2\y = rec\top
        ElseIf Gradient()\style = #VerticalGRADIENT
          p2\x = rec\left
          p2\y = rec\bottom
        EndIf
        
        CallFunctionFast(*GdipCreateFromHDC, dc, @GraphicObject)
        CallFunctionFast(*GdipSetCompositingMode, GraphicObject, 0)
        CallFunctionFast(*GdipSetCompositingQuality, GraphicObject, 1) ; CompositingQualityHighSpeed
        CallFunctionFast(*GdipSetPixelOffsetMode, GraphicObject, 3) ; PixelOffsetModeNone
        CallFunctionFast(*GdipSetSmoothingMode, GraphicObject, 3) ; SmoothingModeNone

        If Gradient()\style <= #VerticalGRADIENT
          
          CallFunctionFast(*GdipCreateLineBrushI,p1,p2,Gradient()\colour1,Gradient()\colour2,1,@BrushObject)
          
          extraColours = ListSize(Gradient()\colours())
          If extraColours > 0
            Dim cols.l(extraColours+3)
            Dim cpos.f(extraColours+3)
            cols(0) = Gradient()\colour1
            cpos(0) = 0
            n = 1
            ForEach Gradient()\colours()
              cols(n) = Gradient()\colours()\colour
              cpos(n) = Gradient()\colours()\pos
              n = n + 1
            Next
            cols(n) = Gradient()\colour2
            cpos(n) = 1
            CallFunctionFast(*GdipSetLinePresetBlend, BrushObject, cols(), cpos(), extraColours+2)
          EndIf
          
          CallFunctionFast(*GdipFillRectangleI,GraphicObject,BrushObject,rec\left,rec\top,rec\right-rec\left,rec\bottom-rec\top) ; x,y width,height
;         DrawGradient(dc, Gradient(), rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top)  
          

        ElseIf Gradient()\style = #RectangleGRADIENT
          
          Dim p.POINT(3)
          p(0)\x = rec\left :p(0)\y = rec\top
          p(1)\x = rec\right : p(1)\y = rec\top
          p(2)\x = rec\right : p(2)\y = rec\bottom
          p(3)\x = rec\left : p(3)\y = rec\bottom
          
          CallFunctionFast(*GdipCreatePathGradientI,@p(),4,0,@BrushObject)
          
          pt.POINT
          pt\x = rec\left+((rec\right-rec\left)/2)
          pt\y = rec\top+((rec\bottom-rec\top)/2)
          CallFunctionFast(*GdipSetPathGradientCenterPointI, BrushObject, pt)
          
          extraColours = ListSize(Gradient()\colours())
          Dim cols.l(extraColours+3)
          Dim cpos.f(extraColours+3)
          cols(0) = Gradient()\colour1
          cpos(0) = 0
          n = 1
          ForEach Gradient()\colours()
            cols(n) = Gradient()\colours()\colour
            cpos(n) = Gradient()\colours()\pos
            n = n + 1
          Next
          cols(n) = Gradient()\colour2
          cpos(n) = 1
          CallFunctionFast(*GdipSetLinePresetBlend, BrushObject, cols(), cpos(), extraColours+2)
        
          
          CallFunctionFast(*GdipFillRectangleI,GraphicObject,BrushObject,rec\left,rec\top,rec\right-rec\left,rec\bottom-rec\top) ; x,y width,height
          
        ElseIf Gradient()\style = #EllipseGRADIENT
          
          CallFunctionFast(*GdipCreatePath, 0, @PathObject)
          CallFunctionFast(*GdipAddPathEllipseI, PathObject, rec\left, rec\top, rec\right-rec\left,rec\bottom-rec\top)
          CallFunctionFast(*GdipCreatePathGradientFromPath, PathObject, @BrushObject)
          
          p.POINT
          p\x = rec\left+((rec\right-rec\left)/2)
          p\y = rec\top+((rec\bottom-rec\top)/2)
          CallFunctionFast(*GdipSetPathGradientCenterPointI, BrushObject, p)
          
          extraColours = ListSize(Gradient()\colours())
          Dim cols.l(extraColours+3)
          Dim cpos.f(extraColours+3)
          cols(0) = Gradient()\colour1
          cpos(0) = 0
          n = 1
          ForEach Gradient()\colours()
            cols(n) = Gradient()\colours()\colour
            cpos(n) = Gradient()\colours()\pos
            n = n + 1
          Next
          cols(n) = Gradient()\colour2
          cpos(n) = 1
          CallFunctionFast(*GdipSetLinePresetBlend, BrushObject, cols(), cpos(), extraColours+2)
        
          
          CallFunctionFast(*GdipFillRectangleI,GraphicObject,BrushObject,rec\left,rec\top,rec\right-rec\left,rec\bottom-rec\top) ; x,y width,height
          CallFunctionFast(*GdipDeletePath, PathObject)
          
        EndIf
        
        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
        CallFunctionFast(*GdipDeleteBrush,BrushObject) 
        
      EndIf
    Else
      If ThemesEnabled = #True
        If panelexpage()\background = 1 ; explorer bar background
          ;CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 0, 0, @rec, 0)
          
          If osVersion > #PB_OS_Windows_XP
            CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 0, 0, @rec, 0)
          Else
            ; add missing alpha channel to explorerbar background if running on xp
            timage = CreateImage(#PB_Any, rec\right-rec\left, rec\bottom-rec\top, 32)
            tdc = StartDrawing(ImageOutput(timage))
              trc.RECT
              trc\left = 0
              trc\top = 0
              trc\right = rec\right-rec\left
              trc\bottom = rec\bottom-rec\top
              CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, tdc, 0, 0, @trc, 0)
              DrawingMode(#PB_2DDrawing_AlphaChannel)
              Box(0, 0, rec\right-rec\left, rec\bottom-rec\top, RGBA(0, 0, 0, 255))
              BitBlt_(dc, rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top, tdc, 0, 0, #SRCCOPY)
            StopDrawing()
            FreeImage(timage)
          EndIf
          
        ElseIf panelexpage()\background = 2
          CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 1, 0, @rec, 0)
        ElseIf panelexpage()\background = 3 ; explorer bar group background
          
          If osVersion > #PB_OS_Windows_XP
            CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 5, 0, @rec, 0)
          Else
            ; add missing alpha channel to explorerbar group background if running on xp
            timage = CreateImage(#PB_Any, rec\right-rec\left, rec\bottom-rec\top, 32)
            tdc = StartDrawing(ImageOutput(timage))
              trc.RECT
              trc\left = 0
              trc\top = 0
              trc\right = rec\right-rec\left
              trc\bottom = rec\bottom-rec\top
              CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, tdc, 5, 0, @trc, 0)
              DrawingMode(#PB_2DDrawing_AlphaChannel)
              Box(0, 0, rec\right-rec\left, rec\bottom-rec\top, RGBA(0, 0, 0, 255))
              BitBlt_(dc, rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top, tdc, 0, 0, #SRCCOPY)
            StopDrawing()
            FreeImage(timage)
          EndIf
          
        ElseIf panelexpage()\background = 4 ; explorer bar group header
          ;CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 8, 0, @rec, 0)
          
          If osVersion > #PB_OS_Windows_XP
            CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 8, 0, @rec, 0)
          Else
            ; add missing alpha channel to explorerbar group header if running on xp
            backupHDCAlpha(dc, rec)
            CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 8, 0, @rec, 0)
            backupHDCAlpha(dc, rec)
          EndIf
          
        ElseIf panelexpage()\background = 5
          CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 9, 0, @rec, 0)
        ElseIf panelexpage()\background = 6
          CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 12, 0, @rec, 0)
        ElseIf panelexpage()\background = 7
          CallFunctionFast(*DrawThemeBackground, hThemeRebar, dc, 0, 0, @rec, 0)
        ElseIf panelexpage()\background = 8
          ; do nothing, drawn earlier before mask
        ElseIf panelexpage()\background = 9
          ; do nothing, drawn earlier before mask
        ElseIf panelexpage()\background = 10
          ; do nothing, drawn earlier before mask
        ElseIf panelexpage()\background = 11
          ; do nothing, drawn earlier before mask
        Else
          ;CallFunctionFast(*DrawThemeBackground, hThemeTab, dc, 9, 0, @rec, 0)
        EndIf
      ; render system classic styles in place of missing themes
      Else
        If panelexpage()\background = 4 ; explorer bar group header
          
          timage = CreateImage(#PB_Any, rec\right-rec\left, rec\bottom-rec\top, 32)
          tdc = StartDrawing(ImageOutput(timage))
            DrawingMode(#PB_2DDrawing_AllChannels)
            col = GetSysColor_(#COLOR_BTNFACE)
            Box(0, 0, rec\right-rec\left, rec\bottom-rec\top, RGBA(Red(col), Green(col), Blue(col), 255))
            BitBlt_(dc, rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top, tdc, 0, 0, #SRCCOPY)
          StopDrawing()
          FreeImage(timage)
          
        ElseIf panelexpage()\background = 1 ; explorer bar background
          
          timage = CreateImage(#PB_Any, rec\right-rec\left, rec\bottom-rec\top, 32)
          tdc = StartDrawing(ImageOutput(timage))
            DrawingMode(#PB_2DDrawing_AllChannels)
            col = GetSysColor_(#COLOR_HIGHLIGHTTEXT)
            Box(0, 0, rec\right-rec\left, rec\bottom-rec\top, RGBA(Red(col), Green(col), Blue(col), 255))
            BitBlt_(dc, rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top, tdc, 0, 0, #SRCCOPY)
          StopDrawing()
          FreeImage(timage)
          
        ElseIf panelexpage()\background = 3 ; explorer bar group background

          timage = CreateImage(#PB_Any, rec\right-rec\left, rec\bottom-rec\top, 32)
          tdc = StartDrawing(ImageOutput(timage))
            DrawingMode(#PB_2DDrawing_AllChannels)
            col = GetSysColor_(#COLOR_BTNFACE)
            Box(0, 0, rec\right-rec\left, rec\bottom-rec\top, RGBA(Red(col), Green(col), Blue(col), 255))
            col = GetSysColor_(#COLOR_HIGHLIGHTTEXT)
            Box(1, 0, rec\right-rec\left-2, rec\bottom-rec\top-1, RGBA(Red(col), Green(col), Blue(col), 255))
            BitBlt_(dc, rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top, tdc, 0, 0, #SRCCOPY)
          StopDrawing()
          FreeImage(timage)
          
        ElseIf panelexpage()\background = 8 ; system button normal state
          
          timage = CreateImage(#PB_Any, rec\right-rec\left, rec\bottom-rec\top, 32)
          tdc = StartDrawing(ImageOutput(timage))
            trc.RECT
            trc\left = 0
            trc\top = 0
            trc\right = rec\right-rec\left
            trc\bottom = rec\bottom-rec\top
            DrawFrameControl_(tdc, trc, #DFC_BUTTON, #DFCS_BUTTONPUSH)
            DrawingMode(#PB_2DDrawing_AlphaChannel)
            Box(0, 0, rec\right-rec\left, rec\bottom-rec\top, RGBA(0, 0, 0, 255))
            BitBlt_(dc, rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top, tdc, 0, 0, #SRCCOPY)
          StopDrawing()
          FreeImage(timage)
          
        ElseIf panelexpage()\background = 9 ; system button hot state
          
          timage = CreateImage(#PB_Any, rec\right-rec\left, rec\bottom-rec\top, 32)
          tdc = StartDrawing(ImageOutput(timage))
            trc.RECT
            trc\left = 0
            trc\top = 0
            trc\right = rec\right-rec\left
            trc\bottom = rec\bottom-rec\top
            DrawFrameControl_(tdc, trc, #DFC_BUTTON, #DFCS_BUTTONPUSH)
            DrawingMode(#PB_2DDrawing_AlphaChannel)
            Box(0, 0, rec\right-rec\left, rec\bottom-rec\top, RGBA(0, 0, 0, 255))
            BitBlt_(dc, rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top, tdc, 0, 0, #SRCCOPY)
          StopDrawing()
          FreeImage(timage)
          
        ElseIf panelexpage()\background = 10 ; system button pressed state
          
          timage = CreateImage(#PB_Any, rec\right-rec\left, rec\bottom-rec\top, 32)
          tdc = StartDrawing(ImageOutput(timage))
            trc.RECT
            trc\left = 0
            trc\top = 0
            trc\right = rec\right-rec\left
            trc\bottom = rec\bottom-rec\top
            DrawFrameControl_(tdc, trc, #DFC_BUTTON, #DFCS_BUTTONPUSH|#DFCS_PUSHED)
            DrawingMode(#PB_2DDrawing_AlphaChannel)
            Box(0, 0, rec\right-rec\left, rec\bottom-rec\top, RGBA(0, 0, 0, 255))
            BitBlt_(dc, rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top, tdc, 0, 0, #SRCCOPY)
          StopDrawing()
          FreeImage(timage)
          
        ElseIf panelexpage()\background = 11 ; system button disabled state
          
          timage = CreateImage(#PB_Any, rec\right-rec\left, rec\bottom-rec\top, 32)
          tdc = StartDrawing(ImageOutput(timage))
            trc.RECT
            trc\left = 0
            trc\top = 0
            trc\right = rec\right-rec\left
            trc\bottom = rec\bottom-rec\top
            DrawFrameControl_(tdc, trc, #DFC_BUTTON, #DFCS_BUTTONPUSH|#DFCS_INACTIVE)
            DrawingMode(#PB_2DDrawing_AlphaChannel)
            Box(0, 0, rec\right-rec\left, rec\bottom-rec\top, RGBA(0, 0, 0, 255))
            BitBlt_(dc, rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top, tdc, 0, 0, #SRCCOPY)
          StopDrawing()
          FreeImage(timage)
          
        Else
          hBrush = GetSysColorBrush_(#COLOR_3DFACE)
          FillRect_(dc, @rec, hBrush)
        EndIf
      EndIf
    EndIf
  ElseIf panelexpage()\background = -1
    ; do nothing
  EndIf
  
  
  If panelexpage()\backgroundImg <> 0
    
    imageX = panelexpage()\imageX
    imageY = panelexpage()\imageY
    
    If panelexpage()\style & #PNLX_HPERCENT
      imageX = (((rec\right-rec\left)/100.0)*panelexpage()\imageX)-(panelexpage()\imageWidth/2)
    EndIf
    If panelexpage()\style & #PNLX_VPERCENT
      imageY = (((rec\bottom-rec\top)/100.0)*panelexpage()\imageY)-(panelexpage()\imageHeight/2)
    EndIf
    
    If panelexpage()\style & #PNLX_RIGHT
      imageX = ((rec\right-rec\left)-panelexpage()\imageWidth)-imageX
    EndIf
    If panelexpage()\style & #PNLX_BOTTOM
      imageY = ((rec\bottom-rec\top)-panelexpage()\imageHeight)-imageY
    EndIf
    
    If panelexpage()\style & #PNLX_CENTRE
      imageX = ((rec\right-rec\left)/2)-(panelexpage()\imageWidth/2)
    EndIf
    If panelexpage()\style & #PNLX_VCENTRE
      imageY = ((rec\bottom-rec\top)/2)-(panelexpage()\imageHeight/2)
    EndIf
    
    If panelexpage()\style & #PNLX_STRETCH
   
      ImageList_GetImageInfo_(panelexpage()\backgroundImg, 0, imgInfo.IMAGEINFO)
      CallFunctionFast(*GdipCreateFromHDC, dc, @GraphicObject)
      CallFunctionFast(*GdipSetCompositingMode, GraphicObject, 0)
      CallFunctionFast(*GdipSetCompositingQuality, GraphicObject, 1) ; CompositingQualityHighSpeed
      CallFunctionFast(*GdipSetPixelOffsetMode, GraphicObject, 3) ; PixelOffsetModeNone
      CallFunctionFast(*GdipSetSmoothingMode, GraphicObject, 3) ; SmoothingModeNone
      
      gbitmap = gBufferImage(imgInfo\hbmImage)
      
      ; destination coords and dimensions first
      CallFunctionFast(*GdipDrawImageRectRectI, GraphicObject, gbitmap, rec\left, rec\top, rec\right-rec\left,rec\bottom-rec\top, 0, 0, imgInfo\rcImage\right, imgInfo\rcImage\bottom, #UnitPixel, 0, #Null, #Null)

      CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
      CallFunctionFast(*GdipDisposeImage, gbitmap)
      
;       blend = $1000000 | 200<<16
;       imgdc = CreateCompatibleDC_(dc)
;       oldbitmap = SelectObject_(imgdc, imgInfo\hbmImage)
;       debuglog(Str(imgInfo\rcImage\right))
;       GdiAlphaBlend_(dc, rec\left, rec\top, rec\right-rec\left,rec\bottom-rec\top, imgdc, 0, 0, imgInfo\rcImage\right, imgInfo\rcImage\bottom, blend); $ 1FF0000
;       SelectObject_(imgdc, oldbitmap)
;       ;DeleteObject_(imgInfo\hbmImage)
;       DeleteDC_(imgdc)
      
    ElseIf panelexpage()\style & #PNLX_HREPEAT And panelexpage()\style & #PNLX_VREPEAT
      y = rec\top
      Repeat
        x = rec\left
        Repeat
          ImageList_DrawEx_(panelexpage()\backgroundImg, 0, dc, x, y, panelexpage()\imageWidth, panelexpage()\imageHeight, #CLR_NONE, #CLR_NONE, #ILD_NORMAL)
          x = x + panelexpage()\imageWidth
        Until x >= rec\right
        y = y + panelexpage()\imageHeight
      Until y >= rec\bottom And x >= rec\right
    ElseIf panelexpage()\style & #PNLX_HREPEAT
      x = rec\left
      Repeat
        ImageList_DrawEx_(panelexpage()\backgroundImg, 0, dc, x, rec\top+imageY, panelexpage()\imageWidth, panelexpage()\imageHeight, #CLR_NONE, #CLR_NONE, #ILD_NORMAL)
        x = x + panelexpage()\imageWidth
      Until x >= rec\right
    ElseIf panelexpage()\style & #PNLX_VREPEAT
      y = rec\top
      Repeat
        ImageList_DrawEx_(panelexpage()\backgroundImg, 0, dc, rec\left+imageX, y, panelexpage()\imageWidth, panelexpage()\imageHeight, #CLR_NONE, #CLR_NONE, #ILD_NORMAL)
        y = y + panelexpage()\imageHeight
      Until y >= rec\bottom
    Else
      
      ImageList_DrawEx_(panelexpage()\backgroundImg, 0, dc, rec\left+imageX, rec\top+imageY, panelexpage()\imageWidth, panelexpage()\imageHeight, #CLR_NONE, #CLR_NONE, #ILD_NORMAL)
      
    EndIf
    
  EndIf
  
  ;/ Overlay background
  If panelexpage()\background2 <> -1
    
    ; check if background is a gradient
    foundGradient = #False
    ForEach Gradient()
      If panelexpage()\background2 = @Gradient()
        foundGradient = #True
        Break
      EndIf
    Next
    
    If foundGradient = #True
      If InitGDIPlus() <> 0
        p1.POINT
        p1\x = rec\left
        p1\y = rec\top
        p2.POINT
        If Gradient()\style = 0
          p2\x = rec\right
          p2\y = rec\top
        Else
          p2\x = rec\left
          p2\y = rec\bottom
        EndIf
        
        CallFunctionFast(*GdipCreateFromHDC, dc, @GraphicObject)
        CallFunctionFast(*GdipCreateLineBrushI,p1,p2,Gradient()\colour1,Gradient()\colour2,1,@BrushObject)
        CallFunctionFast(*GdipFillRectangleI,GraphicObject,BrushObject,rec\left,rec\top,rec\right-rec\left,rec\bottom-rec\top) ; x,y width,height
        CallFunctionFast(*GdipDeleteGraphics,GraphicObject)
        CallFunctionFast(*GdipDeleteBrush,BrushObject)
        
        ;DrawGradient(dc, Gradient(), rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top)  
        
      EndIf
    ElseIf foundGradient = 0 And hThemeTab <> 0
      If panelexpage()\background2 = 1
        CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 0, 0, @rec, 0)
      ElseIf panelexpage()\background2 = 2
        CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 1, 0, @rec, 0)
      ElseIf panelexpage()\background2 = 3
        CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 5, 0, @rec, 0)
      ElseIf panelexpage()\background2 = 4
        CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 8, 0, @rec, 0)
      ElseIf panelexpage()\background2 = 5
        CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 9, 0, @rec, 0)
      ElseIf panelexpage()\background2 = 6
        CallFunctionFast(*DrawThemeBackground, hThemeExplorerbar, dc, 12, 0, @rec, 0)
      ElseIf panelexpage()\background2 = 7
        CallFunctionFast(*DrawThemeBackground, hThemeRebar, dc, 0, 0, @rec, 0)
      ElseIf panelexpage()\background2 = 8
        ; do nothing, drawn earlier before mask
      ElseIf panelexpage()\background2 = 9
        ; do nothing, drawn earlier before mask
      ElseIf panelexpage()\background2 = 10
        ; do nothing, drawn earlier before mask
      ElseIf panelexpage()\background2 = 11
        ; do nothing, drawn earlier before mask
      Else
        CallFunctionFast(*DrawThemeBackground, hThemeTab, dc, 9, 0, @rec, 0)
      EndIf
    EndIf
    
  EndIf
  
  ;/ overlay background image
  If panelexpage()\backgroundImg2 <> 0
    
    imageX = panelexpage()\imageX2
    imageY = panelexpage()\imageY2
    
    If panelexpage()\style2 & #PNLX_HPERCENT
      imageX = (((rec\right-rec\left)/100.0)*panelexpage()\imageX2)-(panelexpage()\imageWidth2/2)
    EndIf
    If panelexpage()\style2 & #PNLX_VPERCENT
      imageY = (((rec\bottom-rec\top)/100.0)*panelexpage()\imageY2)-(panelexpage()\imageHeight2/2)
    EndIf
    
    If panelexpage()\style2 & #PNLX_RIGHT
      imageX = ((rec\right-rec\left)-panelexpage()\imageWidth2)-imageX
    EndIf
    If panelexpage()\style2 & #PNLX_BOTTOM
      imageY = ((rec\bottom-rec\top)-panelexpage()\imageHeight2)-imageY
    EndIf
    
    If panelexpage()\style2 & #PNLX_CENTRE
      imageX = ((rec\right-rec\left)/2)-(panelexpage()\imageWidth2/2)
    EndIf
    If panelexpage()\style2 & #PNLX_VCENTRE
      imageY = ((rec\bottom-rec\top)/2)-(panelexpage()\imageHeight2/2)
    EndIf
    
    If panelexpage()\style2 & #PNLX_STRETCH
      ImageList_DrawEx_(panelexpage()\backgroundImg2, 0, dc, rec\left, rec\top, rec\right-rec\left, rec\bottom-rec\top, #CLR_NONE, #CLR_NONE, #ILD_NORMAL) ; x,y width,height
    ElseIf panelexpage()\style2 & #PNLX_HREPEAT And panelexpage()\style2 & #PNLX_VREPEAT
      y = rec\top
      Repeat
        x = rec\left
        Repeat
          ImageList_DrawEx_(panelexpage()\backgroundImg2, 0, dc, x, y, panelexpage()\imageWidth2, panelexpage()\imageHeight2, #CLR_NONE, #CLR_NONE, #ILD_NORMAL)
          x = x + panelexpage()\imageWidth2
        Until x >= rec\right
        y = y + panelexpage()\imageHeight2
      Until y >= rec\bottom And x >= rec\right
    ElseIf panelexpage()\style2 & #PNLX_HREPEAT
      x = rec\left
      Repeat
        ImageList_DrawEx_(panelexpage()\backgroundImg2, 0, dc, x, rec\top+imageY, panelexpage()\imageWidth2, panelexpage()\imageHeight2, #CLR_NONE, #CLR_NONE, #ILD_NORMAL)
        x = x + panelexpage()\imageWidth2
      Until x >= rec\right
    ElseIf panelexpage()\style2 & #PNLX_VREPEAT
      y = rec\top
      Repeat
        ImageList_DrawEx_(panelexpage()\backgroundImg2, 0, dc, rec\left+imageX, y, panelexpage()\imageWidth2, panelexpage()\imageHeight2, #CLR_NONE, #CLR_NONE, #ILD_NORMAL)
        y = y + panelexpage()\imageHeight2
      Until y >= rec\bottom
    Else
      ImageList_DrawEx_(panelexpage()\backgroundImg2, 0, dc, rec\left+imageX, rec\top+imageY, panelexpage()\imageWidth2, panelexpage()\imageHeight2, #CLR_NONE, #CLR_NONE, #ILD_NORMAL)
    EndIf
    
  EndIf
  
  ; allow user callback to draw background if set
  If panelex()\usercallback <> 0
   
    OffsetWindowOrgEx_(dc, -rec\left, -rec\top, 0)
    CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, #WM_ERASEBKGND, dc, panelex()\handle)
    OffsetWindowOrgEx_(dc, rec\left, rec\top, 0)
    
  EndIf
  
  
  ; draw any groupbox (PureBasic Frame3DGadget) controls directly onto buffer
  enumStruct.wmprintEnumStruct
  enumStruct\pageHwnd = panelexpage()\Handle
  enumStruct\dc = dc
  enumStruct\divertedWindow = divertedWindow
  enumStruct\inAlpha = inAlpha
  EnumChildWindows_(panelexpage()\Handle, @wmprintEnumChildProc(), enumStruct)
  
  
  ; check if any visible panelexs in this page and divert rendering to panelex buffer
  *thishandle = @panelexpage()
  *thispanel = @panelex()
  thisPanelExPageHandle = panelexpage()\Handle
  ForEach panelex()
    
    If GetParent_(panelex()\Handle) = thisPanelExPageHandle And GetWindowLongPtr_(panelex()\Handle, #GWL_STYLE) & #WS_VISIBLE
      ChangeCurrentElement(panelexpage(),panelex()\displayedPage)
      ; make sure the panelex is visible inside this page
      GetClientRect_(panelex()\Handle, @rc.RECT)
      MapWindowPoints_(panelex()\Handle, divertedWindow, @rc, 2)
      If rectVisibleInPanelEx(@rc, divertedWindow)
        GetClientRect_(panelex()\Handle, @rc.RECT)
        MapWindowPoints_(panelex()\Handle, thisPanelExPageHandle, @rc, 2)
        If rectVisibleInPanelEx(@rc, thisPanelExPageHandle)
        
          panelexpage()\dontdraw = 2
          *thisFoundPanelPageEx = @panelexpage()
          *thisFoundPanelEx = @panelex()
          GetClientRect_(panelex()\Handle, @rc.RECT)
          MapWindowPoints_(panelex()\Handle, divertedWindow, @rc, 2)
          
          sdc = SaveDC_(dc) ; so as not to fuck up any nested clipping
          
            If Not panelexpage()\style & #PNLX_NOCLIP
              rRgn = IntersectClipRect_(dc, rc\left, rc\top, rc\right, rc\bottom)
            EndIf
            drawPanelPage(dc, panelexpage()\Handle, divertedWindow, inAlpha)
          
          RestoreDC_(dc, sdc) ; previous dc states restored, e.g. clipping
          
          ChangeCurrentElement(panelexpage(),*thisFoundPanelPageEx)
          ChangeCurrentElement(panelex(), *thisFoundPanelEx)
          panelexpage()\dontdraw = #True
          
        EndIf
      EndIf
    EndIf
    
  Next
  ChangeCurrentElement(panelexpage(), *thishandle)
  ChangeCurrentElement(panelex(), *thispanel)
  
  
  If hMask <> 0
     SelectClipRgn_(dc, rgn)
  EndIf
  
  If thisAlpha = #False
    drawBorder(originaldc, panelexpage()\borderHandle, rec)
  Else
    drawBorder(dc, panelexpage()\borderHandle, rec)
  EndIf
  
  
  ; allow user callback to draw foreground if set
  If panelex()\usercallback <> 0
    OffsetWindowOrgEx_(dc, -rec\left, -rec\top, 0)
    CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, #WM_PAINT, dc, panelex()\handle)
    OffsetWindowOrgEx_(dc, rec\left, rec\top, 0)
  EndIf
  
  
  If panelexpage()\dontdraw = 0
    
    If panelexpage()\alpha = 255

      GetClipBox_(dc, @rc.RECT)  
      BitBlt_(thisdc, rc\left, rc\top, rc\right-rc\left, rc\bottom-rc\top, panelex()\backgroundDC, rc\left, rc\top, #SRCCOPY)
      
      ;blend = $1000000 | 255<<16
      ;GdiAlphaBlend_(thisdc, rc\left, rc\top, rc\right-rc\left, rc\bottom-rc\top, panelex()\backgroundDC, rc\left, rc\top, rc\right-rc\left, rc\bottom-rc\top, blend); $ 1FF0000
    
      
    EndIf
    
  EndIf
  
  If panelexpage()\alpha < 255 And panelexpage()\alpha <> 0
    GetClipBox_(dc, @rc.RECT)
   
    If topPanelEx = #False
      rdc = thisdc
    Else
      rdc = panelex()\backgroundDC
    EndIf
    
    blend = $1000000 | panelexpage()\alpha<<16
    GdiAlphaBlend_(rdc, ax, ay, rec\right-rec\left, rec\bottom-rec\top, panelex()\alphaDC, 0, 0, rec\right-rec\left, rec\bottom-rec\top, blend); $ 1FF0000
    
    ; clear buffer alpha, ready for next refresh
    StartDrawing(ImageOutput(panelex()\alphaBitmap))
    DrawingMode(#PB_2DDrawing_AllChannels)
    Box(0, 0, rec\right-rec\left, rec\bottom-rec\top, RGBA(0, 0, 0, 0))
    StopDrawing()
    
    If topPanelEx = #True
      GetClipBox_(thisdc, @rc.RECT)  
      BitBlt_(thisdc, rc\left, rc\top, rc\right-rc\left, rc\bottom-rc\top, panelex()\backgroundDC, rc\left, rc\top, #SRCCOPY)
    EndIf
    
  EndIf
  
  
  SelectClipRgn_(dc, 0)
  
  If rgn <> 0
    DeleteObject_(rgn)
  EndIf
  
  
EndProcedure

Procedure ScrollbarBoxCallback(Window, message, wParam, lParam)

  If message = #WM_PAINT
    BeginPaint_(Window, @ps.PAINTSTRUCT)
    GetClientRect_(Window, @rc.RECT)
    FillRect_(ps\hdc, rc, GetSysColorBrush_(#COLOR_3DFACE))
    EndPaint_(Window, @ps)
    ProcedureReturn 0
  EndIf
  
  ProcedureReturn DefWindowProc_(Window, message, wParam, lParam)
  
EndProcedure

ProcedureDLL createScrollbarBox(Window.i, x.l, y.l, visible.l)
  
  If visible <> #False
    visible = #WS_VISIBLE
  EndIf
  
  If scrollbarBoxClass = ""
    scrollbarBoxClass = #AppName+"_ScrollbarBox"
    wc.WNDCLASSEX
    wc\cbSize  = SizeOf(WNDCLASSEX)
    wc\style = #CS_PARENTDC
    wc\lpfnWndProc  = @ScrollbarBoxCallback()
    wc\hCursor  = LoadCursor_(0, #IDC_ARROW)
    wc\lpszClassName  = @scrollbarBoxClass
    RegisterClassEx_(@wc)
  EndIf
  
  width = GetSystemMetrics_(#SM_CXHTHUMB)
  height = GetSystemMetrics_(#SM_CYVTHUMB)
  hwnd = CreateWindowEx_(0, scrollbarBoxClass, #Null, #WS_CHILD | visible | #WS_CLIPSIBLINGS | #WS_CLIPCHILDREN, x, y, width, height, Window, #Null,  GetModuleHandle_(0), #Null)
  
  ProcedureReturn hwnd
EndProcedure



Procedure ScrollingChildWindowsEnumProc(hwnd.i, *area.ScrollingChildWindows)
  
  ; make sure child is direct descendant of parent window and not hidden
  If GetParent_(hwnd) = *area\Window And (GetWindowLongPtr_(hwnd, #GWL_STYLE) & #WS_VISIBLE)
    
    ;/ calc child windows area mode
    If *area\mode = #CHILDSCROLLING_AREA
      GetWindowRect_(hwnd, @rc.RECT)
      MapWindowPoints_(0, *area\Window, @rc, 2)
      ;debuglog(Str(hwnd)+"  left: "+Str(rc\left)+" top: "+Str(rc\top)+" right: "+Str(rc\right)+" bottom: "+Str(rc\bottom))
      
      If rc\left < *area\rc\left
        *area\rc\left = rc\left
      EndIf
      If rc\top < *area\rc\top
        *area\rc\top = rc\top
      EndIf
      If rc\right > *area\rc\right
        *area\rc\right = rc\right
      EndIf
      If rc\bottom > *area\rc\bottom
        *area\rc\bottom = rc\bottom
      EndIf
      
    ;/ scroll the child windows mode
    ElseIf *area\mode = #CHILDSCROLLING_SCROLL
      
      GetWindowRect_(hwnd, @rc.RECT)
      MapWindowPoints_(0, *area\Window, @rc, 2)
      ; use *area\rc\top and *area\rc\left to store x,y choords offset to scroll
      SetWindowPos_(hwnd, 0, rc\left+*area\rc\left, rc\top+*area\rc\top, 0, 0, #SWP_NOZORDER|#SWP_NOOWNERZORDER|#SWP_NOSIZE|#SWP_NOACTIVATE|#SWP_NOREDRAW|#SWP_NOCOPYBITS|#SWP_NOSENDCHANGING)
      
    EndIf
    
  EndIf
    
  ProcedureReturn #True
  
EndProcedure


Procedure handlePanelExPageAutoScroll_()
  
  ; calculate the max area of all child windows into areaWidth and areaHeight
  area.ScrollingChildWindows
  area\Window = panelexpage()\Handle
  EnumChildWindows_(area\Window, @ScrollingChildWindowsEnumProc(), @area)
  areaWidth = area\rc\right-area\rc\left
  areaHeight = area\rc\bottom-area\rc\top
  
  ;debuglog("areaWidth: "+Str(areaWidth))
  ;debuglog("areaHeight: "+Str(areaHeight))
  
  GetClientRect_(panelexpage()\Handle, @rc.RECT)
  iHThumb = GetSystemMetrics_(#SM_CXHTHUMB)
  iVThumb = GetSystemMetrics_(#SM_CYVTHUMB)
  
  ; takes into account any empty space at left of child windows area
  scinfo.SCROLLINFO
  scinfo\cbSize = SizeOf(SCROLLINFO)
  scinfo\fMask = #SIF_POS
  GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
  areaWidth = areaWidth + scinfo\nPos + area\rc\left
  
  ; takes into account any empty space at top of child windows area
  scinfo.SCROLLINFO
  scinfo\cbSize = SizeOf(SCROLLINFO)
  scinfo\fMask = #SIF_POS
  GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
  areaHeight = areaHeight + scinfo\nPos + area\rc\top
  
  If areaWidth >= rc\right Or (panelexpage()\vScrollVisible = #True And areaWidth >= rc\right-iHThumb)
    If panelexpage()\hScrollVisible = #False
      ShowWindow_(panelexpage()\hScrollBar, #SW_SHOW)
      panelexpage()\hScrollVisible = #True
    EndIf
  Else
    If panelexpage()\hScrollVisible = #True
      
      scinfo.SCROLLINFO
      scinfo\cbSize = SizeOf(SCROLLINFO)
      scinfo\fMask = #SIF_POS
      scinfo\nPos = 0
      SetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo, #False)
      
      ; scroll all child windows by x offset
      area.ScrollingChildWindows
      area\Window = panelexpage()\Handle
      area\mode = #CHILDSCROLLING_SCROLL
      area\rc\left = panelexpage()\lastHscrollPos
      area\rc\top = 0
      EnumChildWindows_(area\Window, @ScrollingChildWindowsEnumProc(), @area)
      
      panelexpage()\lastHscrollPos = 0
      
      ShowWindow_(panelexpage()\hScrollBar, #SW_HIDE)
      panelexpage()\hScrollVisible = #False
    EndIf
  EndIf
  
  If areaHeight >= rc\bottom Or (panelexpage()\hScrollVisible = #True And areaHeight >= rc\bottom-iVThumb)
    If panelexpage()\vScrollVisible = #False
      ShowWindow_(panelexpage()\vScrollBar, #SW_SHOW)
      panelexpage()\vScrollVisible = #True
    EndIf
  Else
    If panelexpage()\vScrollVisible = #True
      
      scinfo.SCROLLINFO
      scinfo\cbSize = SizeOf(SCROLLINFO)
      scinfo\fMask = #SIF_POS
      scinfo\nPos = 0
      SetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo, #False)
      
      ; scroll all child windows by y offset
      area.ScrollingChildWindows
      area\Window = panelexpage()\Handle
      area\mode = #CHILDSCROLLING_SCROLL
      area\rc\left = 0
      area\rc\top = panelexpage()\lastVscrollPos
      EnumChildWindows_(area\Window, @ScrollingChildWindowsEnumProc(), @area)
      
      panelexpage()\lastVscrollPos = 0
      
      ShowWindow_(panelexpage()\vScrollBar, #SW_HIDE)
      panelexpage()\vScrollVisible = #False
    EndIf
  EndIf
  
  
  ;/ calculate whether we need to display horizontal/vertical scrollbars and update ranges
  ; horizontal scrollbar
  If panelexpage()\hScrollVisible = #True
    ;debuglog("h bigger")
    
    If panelexpage()\vScrollVisible = #True
      hThumb = iHThumb
    EndIf
    
    scinfo.SCROLLINFO
    scinfo\cbSize = SizeOf(SCROLLINFO)
    scinfo\fMask = #SIF_PAGE|#SIF_RANGE
    scinfo\nMin = 0
    scinfo\nMax = areaWidth
    scinfo\nPage = rc\right-hThumb
    SetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo, #False)
    
    scinfo\fMask = #SIF_POS
    GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
    pos = scinfo\nPos
    
    ; scroll all child windows by x offset
    area.ScrollingChildWindows
    area\Window = panelexpage()\Handle
    area\mode = #CHILDSCROLLING_SCROLL
    area\rc\left = panelexpage()\lastHscrollPos - pos
    area\rc\top = 0
    EnumChildWindows_(area\Window, @ScrollingChildWindowsEnumProc(), @area)
    
    panelexpage()\lastHscrollPos = pos
    
  EndIf
  
  ; vertical scrollbar
  If panelexpage()\vScrollVisible = #True
    ;debuglog("v bigger")
    
    If panelexpage()\hScrollVisible = #True
      vThumb = iVThumb
    EndIf
    
    scinfo.SCROLLINFO
    scinfo\cbSize = SizeOf(SCROLLINFO)
    scinfo\fMask = #SIF_PAGE|#SIF_RANGE
    scinfo\nMin = 0
    scinfo\nMax = areaHeight
    scinfo\nPage = rc\bottom-vThumb
    SetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo, #False)
    
    scinfo\fMask = #SIF_POS
    GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
    pos = scinfo\nPos
    
    ; scroll all child windows by y offset
    area.ScrollingChildWindows
    area\Window = panelexpage()\Handle
    area\mode = #CHILDSCROLLING_SCROLL
    area\rc\left = 0
    area\rc\top = panelexpage()\lastVscrollPos - pos
    EnumChildWindows_(area\Window, @ScrollingChildWindowsEnumProc(), @area)
    
    panelexpage()\lastVscrollPos = pos
    
  EndIf
  
EndProcedure

Procedure handlePanelExPageAutoScroll()
  
  If panelexpage()\autoScroll = #False
    ProcedureReturn 0
  EndIf
 
  areaWidth = panelexpage()\area\right - panelexpage()\area\left
  areaHeight = panelexpage()\area\bottom - panelexpage()\area\top
  
  ;debuglog("areaWidth: "+Str(areaWidth))
  ;debuglog("areaHeight: "+Str(areaHeight))
  
  GetClientRect_(panelexpage()\containerHandle, @rc.RECT)
  iHThumb = GetSystemMetrics_(#SM_CXHTHUMB)
  iVThumb = GetSystemMetrics_(#SM_CYVTHUMB)
  
  If areaWidth >= rc\right Or (panelexpage()\vScrollVisible = #True And areaWidth >= rc\right-iHThumb)
    If panelexpage()\hScrollVisible = #False; And panelexpage()\displayed <> 0
      If panelexpage()\noHorizontal = #False
        ShowWindow_(panelexpage()\hScrollBar, #SW_SHOW)
        panelexpage()\hScrollVisible = #True
      EndIf
    EndIf
  Else
    If panelexpage()\hScrollVisible = #True
      
      scinfo.SCROLLINFO
      scinfo\cbSize = SizeOf(SCROLLINFO)
      scinfo\fMask = #SIF_POS
      scinfo\nPos = 0
      SetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo, #False)
      
      ; scroll by x offset
      updatePanelExPageScrolling(panelexpage()\lastHscrollPos, 0)
      
      panelexpage()\lastHscrollPos = 0
      
      ShowWindow_(panelexpage()\hScrollBar, #SW_HIDE)
      panelexpage()\hScrollVisible = #False
    EndIf
  EndIf
  
  
  If areaHeight >= rc\bottom Or (panelexpage()\hScrollVisible = #True And areaHeight >= rc\bottom-iVThumb)
    If panelexpage()\vScrollVisible = #False; And panelexpage()\displayed <> 0
      If panelexpage()\noVertical = #False
        ShowWindow_(panelexpage()\vScrollBar, #SW_SHOW)
        panelexpage()\vScrollVisible = #True
      EndIf
    EndIf
  Else
    If panelexpage()\vScrollVisible = #True
      
      scinfo.SCROLLINFO
      scinfo\cbSize = SizeOf(SCROLLINFO)
      scinfo\fMask = #SIF_POS
      scinfo\nPos = 0
      SetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo, #False)
      
      ; scroll by y offset
      updatePanelExPageScrolling(0, panelexpage()\lastVscrollPos)
      
      panelexpage()\lastVscrollPos = 0
      
      ShowWindow_(panelexpage()\vScrollBar, #SW_HIDE)
      panelexpage()\vScrollVisible = #False
    EndIf
  EndIf
  
  
  ;/ calculate whether we need to display horizontal/vertical scrollbars and update ranges
  ; horizontal scrollbar
  If panelexpage()\hScrollVisible = #True
    
    If panelexpage()\vScrollVisible = #True
      hThumb = iHThumb
    EndIf
    
    scinfo.SCROLLINFO
    scinfo\cbSize = SizeOf(SCROLLINFO)
    scinfo\fMask = #SIF_PAGE|#SIF_RANGE
    scinfo\nMin = 0
    scinfo\nMax = areaWidth
    scinfo\nPage = rc\right-hThumb
    SetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo, #False)
    
    scinfo\fMask = #SIF_POS
    GetScrollInfo_(panelexpage()\hScrollBar, #SB_CTL, @scinfo)
    pos = scinfo\nPos
    
    ; scroll by x offset
    updatePanelExPageScrolling(panelexpage()\lastHscrollPos - pos, 0)
    
    panelexpage()\lastHscrollPos = pos
    
  EndIf
  
  ; vertical scrollbar
  If panelexpage()\vScrollVisible = #True
    
    If panelexpage()\hScrollVisible = #True
      vThumb = iVThumb
    EndIf
    
    scinfo.SCROLLINFO
    scinfo\cbSize = SizeOf(SCROLLINFO)
    scinfo\fMask = #SIF_PAGE|#SIF_RANGE
    scinfo\nMin = 0
    scinfo\nMax = areaHeight
    scinfo\nPage = rc\bottom-vThumb
    SetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo, #False)
    
    scinfo\fMask = #SIF_POS
    GetScrollInfo_(panelexpage()\vScrollBar, #SB_CTL, @scinfo)
    pos = scinfo\nPos
    
    ; scroll by y offset
    updatePanelExPageScrolling(0, panelexpage()\lastVscrollPos - pos)
    
    panelexpage()\lastVscrollPos = pos
    
  EndIf
  
EndProcedure

Procedure updatePanelExPageScrollbars()
  
  If panelexpage()\hScrollVisible = #True And panelexpage()\vScrollVisible = #False
    GetClientRect_(panelexpage()\containerHandle, @rc.RECT)
    iVThumb = GetSystemMetrics_(#SM_CYVTHUMB)
    SetWindowPos_(panelexpage()\hScrollBar, #HWND_TOP, 0, rc\bottom-iVThumb, rc\right, iVThumb, #SWP_NOREDRAW);#SWP_NOCOPYBITS)
    If GetWindowLongPtr_(panelexpage()\scrollBarBox, #GWL_STYLE) & #WS_VISIBLE
      ShowWindow_(panelexpage()\scrollBarBox, #SW_HIDE)
    EndIf
  ElseIf panelexpage()\hScrollVisible = #False And panelexpage()\vScrollVisible = #True
    GetClientRect_(panelexpage()\containerHandle, @rc.RECT)
    iHThumb = GetSystemMetrics_(#SM_CXHTHUMB)
    SetWindowPos_(panelexpage()\vScrollBar, #HWND_TOP, rc\right-iHThumb, 0, iHThumb, rc\bottom, #SWP_NOREDRAW);#SWP_NOCOPYBITS)
    If GetWindowLongPtr_(panelexpage()\scrollBarBox, #GWL_STYLE) & #WS_VISIBLE
      ShowWindow_(panelexpage()\scrollBarBox, #SW_HIDE)
    EndIf
  ElseIf panelexpage()\hScrollVisible = #True And panelexpage()\vScrollVisible = #True
    GetClientRect_(panelexpage()\containerHandle, @rc.RECT)
    iHThumb = GetSystemMetrics_(#SM_CXHTHUMB)
    iVThumb = GetSystemMetrics_(#SM_CYVTHUMB)
    
    hdwp = BeginDeferWindowPos_(3)
    hdwp = DeferWindowPos_(hdwp, panelexpage()\hScrollBar, #HWND_TOP, 0, rc\bottom-iVThumb, rc\right-iHThumb, iVThumb, #SWP_NOREDRAW);#SWP_NOCOPYBITS)
    hdwp = DeferWindowPos_(hdwp, panelexpage()\vScrollBar, #HWND_TOP, rc\right-iHThumb, 0, iHThumb, rc\bottom-iVThumb, #SWP_NOREDRAW);#SWP_NOCOPYBITS)
    If Not GetWindowLongPtr_(panelexpage()\scrollBarBox, #GWL_STYLE) & #WS_VISIBLE
      ShowWindow_(panelexpage()\scrollBarBox, #SW_SHOWNA)
    EndIf
    hdwp = DeferWindowPos_(hdwp, panelexpage()\scrollBarBox, #HWND_TOP, rc\right-iHThumb, rc\bottom-iVThumb, iHThumb, iVThumb, #SWP_NOREDRAW);#SWP_NOCOPYBITS)
    EndDeferWindowPos_(hdwp)
  Else
    If panelexpage()\scrollBarBox <> 0 And (GetWindowLongPtr_(panelexpage()\scrollBarBox, #GWL_STYLE) & #WS_VISIBLE)
      ShowWindow_(panelexpage()\scrollBarBox, #SW_HIDE)
    EndIf
  EndIf
  
EndProcedure

Procedure PanelExPageCallback(Window, message, wParam, lParam)
  Static lastwindow, lastmsg, lastwparam, lastlparam
  
  LockMutex(panelMutex)
  
  If ListSize(panelexpage()) > 0
    ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
    *previousPanelExPage = @panelexpage()
  EndIf
  
  ; find panelexpage
  ForEach panelexpage()
    If panelexpage()\Handle = Window
      panelExPageFound = #True
      ; get page's panelex
      ChangeCurrentElement(panelex(), panelexpage()\panelex)
      Break
    EndIf
  Next
  
 
  ;debuglog(Str(message)+" "+Str(wParam)+" "+Str(lParam))
  
  
  Select message
      
    Case #WM_UPDATESKIN
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        CallWindowProc_(panelex()\usercallback, panelex()\Handle, message, wParam, lParam)
        CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      
    Case #WM_THEMECHANGED
      
      ; delete cached back brushes for static controls
      ForEach backbrush()
        ;If backbrush()\Window = Window
          DeleteObject_(backbrush()\hBrush)
          DeleteElement(backbrush())
        ;EndIf
      Next
      
    Case #WM_CTLCOLORSTATIC
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        Result = CallWindowProc_(panelex()\usercallback, panelex()\Handle, message, wParam, lParam)
      EndIf
      
      If Result = 0
      
        ; make sure window class is not a button, input, dropdown etc.. otherwise ugly black pixels at corners
        class.s = Space(255)
        GetClassName_(lParam, @class, 255)
        If class = "Edit" Or class = "Button" Or class = "ComboBox"
          
          If class = "Button"
            style = GetWindowLongPtr_(lParam, #GWL_STYLE)
            If (style & #BS_PUSHBUTTON Or style & #BS_DEFPUSHBUTTON) And Not style & #BS_GROUPBOX And Not style & #BS_CHECKBOX And Not style & #BS_3STATE And Not style & #BS_AUTO3STATE And Not style & #BS_AUTOCHECKBOX And Not style & #BS_RADIOBUTTON And Not style & #BS_AUTORADIOBUTTON 
              ProcedureReturn 0
            EndIf
          Else
            ProcedureReturn 0
          EndIf
          
        EndIf
        
        found = 0
        ForEach backbrush()
          If backbrush()\Window = Window And backbrush()\Control = lParam
            found = -1
            Break
          EndIf
        Next
        
        If found = 0
          
          If panelExPageFound = #True
            
            GetClientRect_(Window, @rec.RECT)
            GetClientRect_(lParam, @rc.RECT)
            
            thisPanelexPageWindow = panelexpage()\handle
            LockMutex(trackWinMutex)
            root = getRootPanelExPageHwnd(panelexpage()\handle)
            UnlockMutex(trackWinMutex)
            *thisPanelExPage = @panelexpage()
            ForEach panelexpage()
              If panelexpage()\handle = root
                Break
              EndIf
            Next
            ChangeCurrentElement(panelex(), panelexpage()\panelex)
            ; if dc is not initialised yet then draw panel page
            If panelex()\backgroundDC = 0
              drawPanelPage(wparam, Window, 0, 0)
            EndIf
            dc = panelex()\backgroundDC
            ChangeCurrentElement(panelexpage(), *thisPanelExPage)
            ChangeCurrentElement(panelex(), panelexpage()\panelex)
            
            If panelexpage()\alpha < 255
              root = window
              dc = panelex()\alphaDC
            EndIf
            
            width = rc\right-rc\left
            height = rc\bottom-rc\top
            MapWindowPoints_(lParam, root, @rc, 2)
            
            hdc = CreateCompatibleDC_(wParam)
            bitmap = CreateCompatibleBitmap_(wParam, width, height)
            SelectObject_(hdc, bitmap)
            BitBlt_(hdc, 0 , 0, width, height, dc, rc\left, rc\top, #SRCCOPY)
            
            hBrush = CreatePatternBrush_(bitmap)
            
            DeleteObject_(bitmap)
            DeleteDC_(hdc)
            
            LastElement(backbrush())
            AddElement(backbrush())
            backbrush()\Window = Window
            backbrush()\Control = lParam
            backbrush()\hBrush = hBrush
          EndIf
          
        Else
          hBrush = backbrush()\hBrush
        EndIf
      
        SetBkMode_(wParam, #TRANSPARENT)
        
        Result = hBrush
        
      EndIf
        
    Case #WM_PAINT
      
      dc = BeginPaint_(Window, @ps.PAINTSTRUCT)
      ps\fErase = 0
      
      If panelexpage()\dontdraw <> #True
        If panelExPageFound = #True
        
          drawPanelPage(dc, Window, lParam, 0)
          
          ChangeCurrentElement(panelexpage(), *previousPanelExPage)
        EndIf
      EndIf
        
      EndPaint_(Window, @ps)
      
      UnlockMutex(panelMutex)
      ProcedureReturn 1

    Case #WM_ERASEBKGND 

      If panelExPageFound = #True
        ChangeCurrentElement(panelexpage(), *previousPanelExPage)
      EndIf
      
      UnlockMutex(panelMutex)
      ProcedureReturn 1
      
    Case #WM_COMMAND
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        Result = CallWindowProc_(panelex()\usercallback, panelex()\Handle, message, wParam, lParam)
      EndIf
      If Result = 0
        Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam)
      EndIf
    
    Case #WM_MOUSEMOVE
      
      pt.POINT
      GetCursorPos_(@pt)
      hwnd = WindowFromPoint_(PeekQ(pt))
      If hwnd = window
        If panelexpage()\cursor > 0
          SetCursor_(panelexpage()\cursor)
        ElseIf panelexpage()\cursor = 0
          SetCursor_(normalMousePointer)
        EndIf
      EndIf
      
      ; make sure WM_ message isn't 32, 132, 512
      found = #False
      If message = 32
        If wParam = panelexpage()\lwparam[0] And lParam = panelexpage()\llparam[0]
          found = #True
        Else
          panelexpage()\lwparam[0] = wParam
          panelexpage()\llparam[0] = lParam
        EndIf
      ElseIf message = 132
        If wParam = panelexpage()\lwparam[1] And lParam = panelexpage()\llparam[1]
          found = #True
        Else
          panelexpage()\lwparam[1] = wParam
          panelexpage()\llparam[1] = lParam
        EndIf
      ElseIf message = 512
        If wParam = panelexpage()\lwparam[2] And lParam = panelexpage()\llparam[2]
          found = #True
        Else
          panelexpage()\lwparam[2] = wParam
          panelexpage()\llparam[2] = lParam
        EndIf
      EndIf
      
      If found = #False
        If panelExPageFound = #True And panelex()\usercallback <> 0
         CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
       EndIf
      EndIf
      Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam)
    
    Case #WM_MOUSELEAVE
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam)
      
    Case #WM_LBUTTONUP
      
      pt.POINT
      GetCursorPos_(@pt)
      hwnd = WindowFromPoint_(PeekQ(pt))
      If hwnd = window
        If panelexpage()\cursor > 0
          SetCursor_(panelexpage()\cursor)
        ElseIf panelexpage()\cursor = 0
          SetCursor_(normalMousePointer)
        EndIf
      EndIf
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam)
    
    Case #WM_LBUTTONDOWN
      
      pt.POINT
      GetCursorPos_(@pt)
      hwnd = WindowFromPoint_(PeekQ(pt))
      If hwnd = window
        If panelexpage()\cursor > 0
          SetCursor_(panelexpage()\cursor)
        ElseIf panelexpage()\cursor = 0
          SetCursor_(normalMousePointer)
        EndIf
      EndIf
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam)
      
    Case #WM_LBUTTONDBLCLK
      
      pt.POINT
      GetCursorPos_(@pt)
      hwnd = WindowFromPoint_(PeekQ(pt))
      If hwnd = window
        If panelexpage()\cursor > 0
          SetCursor_(panelexpage()\cursor)
        ElseIf panelexpage()\cursor = 0
          SetCursor_(normalMousePointer)
        EndIf
      EndIf
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam)
      
    Case #WM_RBUTTONUP
      
      pt.POINT
      GetCursorPos_(@pt)
      hwnd = WindowFromPoint_(PeekQ(pt))
      If hwnd = window
        If panelexpage()\cursor > 0
          SetCursor_(panelexpage()\cursor)
        ElseIf panelexpage()\cursor = 0
          SetCursor_(normalMousePointer)
        EndIf
      EndIf
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam)
      
    Case #WM_RBUTTONDOWN
      
      pt.POINT
      GetCursorPos_(@pt)
      hwnd = WindowFromPoint_(PeekQ(pt))
      If hwnd = window
        If panelexpage()\cursor > 0
          SetCursor_(panelexpage()\cursor)
        ElseIf panelexpage()\cursor = 0
          SetCursor_(normalMousePointer)
        EndIf
      EndIf
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam)
      
    Case #WM_RBUTTONDBLCLK
      
      pt.POINT
      GetCursorPos_(@pt)
      hwnd = WindowFromPoint_(PeekQ(pt))
      If hwnd = window
        If panelexpage()\cursor > 0
          SetCursor_(panelexpage()\cursor)
        ElseIf panelexpage()\cursor = 0
          SetCursor_(normalMousePointer)
        EndIf
      EndIf
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam)
      
    Case #WM_NOTIFY
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        Result = CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      
      ; don't forward message if for a toolbarex as custom drawing is handled by maincallback attached to this callback
      *nm.NMHDR = lParam
      found = 0
      ForEach toolbarex()
        If toolbarex()\Handle = *nm\hwndFrom
          found = #True
          Break
        EndIf
      Next
      If found = #False
        Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam)
      EndIf
      
    Case #REBAR_UPDATED
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam) 
    Case #TCX_LINK_HOVER
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam) 
      
    Case #TCX_LINK_CLICK
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        CallWindowProc_(panelex()\usercallback, panelexpage()\Handle, message, wParam, lParam)
      EndIf
      Result = SendMessage_(GetParent_(GetParent_(Window)),message,wParam,lParam) 
      
    Case #WM_SIZE
      
      ;GetClientRect_(panelexpage()\Handle, @rc.RECT)
      ;panelexpage()\width = rc\right-rc\left
      ;panelexpage()\height = rc\bottom-rc\top
      
      ; delete cached back brushes for static controls
      ForEach backbrush()
        ;If backbrush()\Window = Window
          DeleteObject_(backbrush()\hBrush)
          DeleteElement(backbrush())
        ;EndIf
      Next
      
      ForEach rebarGadget()
        
        If rebarGadget()\WindowID = Window
          If rebarGadget()\dbtoggle = 0
            If rebarGadget()\doublebuffer = -1
              SetWindowLongPtr_(rebarGadget()\Handle, #GWL_EXSTYLE, #WS_EX_TOOLWINDOW|#WS_EX_COMPOSITED)
            EndIf
            rebarGadget()\dbtoggle = -1
          EndIf
          
          height = SendMessage_(rebarGadget()\Handle, #RB_GETBARHEIGHT, 0,0)
          
          GetClientRect_(Window, @rc.RECT)
          MoveWindow_(rebarGadget()\Handle, 0, 0, rc\right-rc\left, height, #False)
          
          updateRebar(Window)
          
          If rebarGadget()\doublebuffer = 0
            
            RedrawWindow_(rebarGadget()\Handle,0,0,#RDW_INVALIDATE|#RDW_ERASE|#RDW_UPDATENOW)
            
          EndIf
          
        EndIf
        
      Next
      
    Case #WM_NCHITTEST
      
      If panelExPageFound = #True And panelexpage()\style & #PNLX_TRANSPARENT
        
        Result = #HTTRANSPARENT
        
      Else
        
        Result = DefWindowProc_(Window, message, wParam, lParam)
        
      EndIf
    
    Default
      ;CallWindowProc_(panelExPBCallback,window,message,wParam,lParam)
      
      If panelExPageFound = #True And panelex()\usercallback <> 0
        
        ; make sure WM_ message isn't 32, 132, 512
        found = #False
        If message = 32
          If wParam = panelexpage()\lwparam[0] And lParam = panelexpage()\llparam[0]
            found = #True
          Else
            panelexpage()\lwparam[0] = wParam
            panelexpage()\llparam[0] = lParam
          EndIf
        ElseIf message = 132
          If wParam = panelexpage()\lwparam[1] And lParam = panelexpage()\llparam[1]
            found = #True
          Else
            panelexpage()\lwparam[1] = wParam
            panelexpage()\llparam[1] = lParam
          EndIf
        ElseIf message = 512
          If wParam = panelexpage()\lwparam[2] And lParam = panelexpage()\llparam[2]
            found = #True
          Else
            panelexpage()\lwparam[2] = wParam
            panelexpage()\llparam[2] = lParam
          EndIf
        EndIf
        
        If found = #False
          Result = CallWindowProc_(panelex()\usercallback, panelexpage()\handle, message, wParam, lParam)
        EndIf
        
      EndIf
      If Result = 0 
        Result  = DefWindowProc_(Window, message, wParam, lParam)
      EndIf
      ;Result = SendMessage_(GetParent_(GetParent_(window)),message,wParam,lParam)
      ;Result = CallWindowProc_(panelExPBCallback,window,message,wParam,lParam)
      
  EndSelect

  ;SendMessage_(GetParent_(GetParent_(window)),message,wParam,lParam)
  ;Result = CallWindowProc_(panelExPBCallback,window,message,wParam,lParam)
  ;Result  = DefWindowProc_(window, message, wParam, lParam)
  
  ;Result = CallWindowProc_(GetWindowLongPtr_(GetParent_(GetParent_(window)), #GWLP_WNDPROC),window,message,wParam,lParam)
  ;Result = CallWindowProc_(GetWindowLongPtr_(GetParent_(window), #GWLP_WNDPROC),window,message,wParam,lParam)
  
  ; ensures that the panelExPage list handling doesn't fuck up any previous command that examines/alters the list
  If *previousPanelExPage <> 0
    ChangeCurrentElement(panelexpage(), *previousPanelExPage)
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn Result
  
EndProcedure

ProcedureDLL CreatePanelEx(PanelID.l, parent.i, x.l, y.l, width.l, height.l, usercallback.i)
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; make sure panelex control doesn't already exist
  If PanelID = #ProGUI_Any
    ProGUI_Any = #True
    Repeat
      ; generate unique toolbar id so as not to conflict with user toolbars
      PanelID = generateUniqueID()
      ; check that same id doesnt already exist
      found = 0
      ForEach panelex()
        If panelex()\id = PanelID
          found = -1
          Break
        EndIf
      Next
    Until found = 0
    
  Else
    ; make sure panelex id doesnt exist
    ForEach panelex()
      If panelex()\id = PanelID
        UnlockMutex(panelMutex)
        ProcedureReturn 0
      EndIf
    Next
  EndIf
  
  
  If panelExContainerClass = ""
    panelExContainerClass = #AppName+"_PanelEx"
    wc.WNDCLASSEX
    wc\cbSize  = SizeOf(WNDCLASSEX)
    wc\style = 0;#CS_PARENTDC
    wc\lpfnWndProc  = @PanelExCallback()
    wc\lpszClassName  = @panelExContainerClass
    RegisterClassEx_(@wc)
  EndIf
  
  
  UnlockMutex(panelMutex)
  hwnd = CreateWindowEx_(0, panelExContainerClass, #Null, #WS_CHILD | #WS_VISIBLE, x, y, width, height, parent, #Null,  GetModuleHandle_(0), #Null)
  LockMutex(panelMutex)
  
  If hwnd <> 0
    
    initPanelexThemes()
    
    LastElement(panelex())
    AddElement(panelex())
    panelex()\id = PanelID
    panelex()\Handle = hwnd
    panelex()\width = width
    panelex()\height = height
    panelex()\usercallback = usercallback
    
    currentPanelEx = hwnd
    
    If ProGUI_Any = #True
      UnlockMutex(panelMutex)
      ProcedureReturn PanelID
    Else
      UnlockMutex(panelMutex)
      ProcedureReturn hwnd
    EndIf
    
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0   
EndProcedure

ProcedureDLL AddPanelExPage(background.i)
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; make sure there is a current panelex
  found = 0
  If currentPanelEx <> 0
    ; find current panelex
    ForEach panelex()
      If panelex()\Handle = currentPanelEx
        found = -1
        Break
      EndIf
    Next
  EndIf
  
  If found = 0
    UnlockMutex(panelMutex)
    ProcedureReturn 0
  EndIf
  
  If panelExPageClass = ""
    panelExPageClass = #AppName+"_PanelExPage"
    wc.WNDCLASSEX
    wc\cbSize  = SizeOf(WNDCLASSEX)
    wc\style = #CS_PARENTDC
    wc\lpfnWndProc  = @PanelExPageCallback()
    wc\lpszClassName  = @panelExPageClass
    RegisterClassEx_(@wc)
  EndIf
  
  If panelex()\displayedPage = 0
    visible = #WS_VISIBLE
  Else
    visible = 0
  EndIf
 
  
  *thisPanelEx = @panelex()
  UnlockMutex(panelMutex)
  hwnd = CreateWindowEx_(#WS_EX_TRANSPARENT, panelExPageClass, #Null, #WS_CHILD | visible | #WS_CLIPSIBLINGS| #WS_CLIPCHILDREN, 0, 0, panelex()\width, panelex()\height, panelex()\Handle, #Null,  GetModuleHandle_(0), #Null)
  LockMutex(panelMutex)
  ChangeCurrentElement(panelex(), *thisPanelEx)
  
  
  If hwnd <> 0
    
    If panelExPageInsert = #False
      LastElement(panelexpage())
      AddElement(panelexpage())
    Else
      ChangeCurrentElement(panelexpage(), panelExPageInsert)
      InsertElement(panelexpage())
    EndIf
    panelexpage()\index = panelex()\lastPageIndex
    panelexpage()\Handle = hwnd
    panelexpage()\containerHandle = panelex()\Handle
    panelexpage()\panelex = @panelex()
    panelexpage()\background = background
    panelexpage()\background2 = -1
    panelexpage()\borderHandle = createBorder()
    panelexpage()\width = panelex()\width
    panelexpage()\height = panelex()\height
    panelexpage()\alpha = 255
    panelex()\lastPageIndex = panelex()\lastPageIndex + 1
    
    If panelex()\displayedPage = 0
      panelex()\displayedPage = @panelexpage()
      panelexpage()\displayed = -1
    EndIf
    
    UseGadgetList(hwnd)
    
    UnlockMutex(panelMutex)
    ProcedureReturn hwnd
    
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0   
EndProcedure

ProcedureDLL AddPanelExImagePage(background.i, backgroundImg.i, imageX.l, imageY.l, imageWidth.l, imageHeight.l, style.l)
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; make sure there is a current panelex
  found = 0
  If currentPanelEx <> 0
    ; find current panelex
    ForEach panelex()
      If panelex()\Handle = currentPanelEx
        found = -1
        Break
      EndIf
    Next
  EndIf
  
  If found = 0
    UnlockMutex(panelMutex)
    ProcedureReturn 0
  EndIf
  
  If panelExPageClass = ""
    panelExPageClass = #AppName+"_PanelExPage"
    wc.WNDCLASSEX
    wc\cbSize  = SizeOf(WNDCLASSEX)
    wc\style = #CS_PARENTDC
    wc\lpfnWndProc  = @PanelExPageCallback()
    wc\lpszClassName  = @panelExPageClass
    RegisterClassEx_(@wc)
  EndIf
  
  If panelex()\displayedPage = 0
    visible = #WS_VISIBLE
  Else
    visible = 0
  EndIf
  
  *thisPanelEx = @panelex()
  UnlockMutex(panelMutex)
  hwnd = CreateWindowEx_(#WS_EX_TRANSPARENT, panelExPageClass, #Null, #WS_CHILD | visible | #WS_CLIPSIBLINGS| #WS_CLIPCHILDREN, 0, 0, panelex()\width, panelex()\height, panelex()\Handle, #Null,  GetModuleHandle_(0), #Null)
  LockMutex(panelMutex)
  ChangeCurrentElement(panelex(), *thisPanelEx)
  
  If hwnd <> 0
    
    If panelExPageInsert = #False
      LastElement(panelexpage())
      AddElement(panelexpage())
    Else
      ChangeCurrentElement(panelexpage(), panelExPageInsert)
      InsertElement(panelexpage())
    EndIf
    
    panelexpage()\index = panelex()\lastPageIndex
    panelexpage()\Handle = hwnd
    panelexpage()\containerHandle = panelex()\Handle
    panelexpage()\panelex = @panelex()
    panelexpage()\background = background
    panelexpage()\background2 = -1
    panelexpage()\borderHandle = createBorder()
    panelexpage()\width = panelex()\width
    panelexpage()\height = panelex()\height
    panelexpage()\alpha = 255
    panelexpage()\style = style
    panelex()\lastPageIndex = panelex()\lastPageIndex + 1
    
    If backgroundImg <> 0
      
      GetImageDimensions(backgroundImg, @bmWidth, @bmHeight)
      
      If imageWidth = 0
        imageWidth = bmWidth
      EndIf
      If imageHeight = 0
        imageHeight = bmHeight
      EndIf
      
      panelexpage()\backgroundImg = ImageList_Create_(imageWidth, imageHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
      If panelexpage()\backgroundImg <> 0
        ret.l = ImageList_ReplaceIcon_(panelexpage()\backgroundImg, -1, backgroundImg)
        If ret = -1
          
          If style & #PNLX_MASKED
            ImageList_AddMasked_(panelexpage()\backgroundImg, backgroundImg, RGB(255,255,255))
          Else
            ImageList_Add_(panelexpage()\backgroundImg, backgroundImg, 0)
          EndIf

        EndIf
        
        panelexpage()\imageWidth = imageWidth
        panelexpage()\imageHeight = imageHeight
        panelexpage()\imageX = imageX
        panelexpage()\imageY = imageY
        
      EndIf
    EndIf
    
    If panelex()\displayedPage = 0
      panelex()\displayedPage = @panelexpage()
      panelexpage()\displayed = -1
    EndIf
    
    If Not style & #PNLX_NOGADGETLIST
      UseGadgetList(hwnd)
    EndIf
    
    UnlockMutex(panelMutex)
    ProcedureReturn hwnd
    
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0   
EndProcedure

ProcedureDLL InsertPanelExPage(Panel.i, page.i, background.i) ; Inserts a PanelEx page into a PanelEx.
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    ; find panel page index
    If page <> -1
      found = 0
      displayed = -1
      ForEach panelexpage()
        If panelexpage()\containerHandle = panelex()\Handle And (panelexpage()\index = page Or panelexpage()\Handle = page)
          found = -1
          Break
        EndIf
      Next
    EndIf
    
    If found = -1 Or page = -1
      
      If page <> -1
        panelExPageInsert = @panelexpage()
      EndIf
      currentPanelEx = panelex()\Handle
      *thisPanelEx = @panelex()
      *thisPanelExPage = @panelexpage()
      UnlockMutex(panelMutex)
      ret = AddPanelExPage(background)
      LockMutex(panelMutex)
      ChangeCurrentElement(panelex(), *thisPanelEx)
      ChangeCurrentElement(panelexpage(), *thisPanelExPage)
      panelExPageInsert = #False
      
      ; update page indexes
      index = 0
      ForEach panelexpage()
        If panelexpage()\containerHandle = panelex()\Handle
          panelexpage()\index = index
          index = index + 1
        EndIf
      Next
      panelex()\lastPageIndex = index+1
      
      UnlockMutex(panelMutex)
      ProcedureReturn ret
    EndIf
    
    UnlockMutex(panelMutex)
    ProcedureReturn 0
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL InsertPanelExImagePage(Panel.i, page.i, background.i, backgroundImg.i, imageX.l, imageY.l, imageWidth.l, imageHeight.l, style.l) ; Inserts a PanelEx image page into a PanelEx.
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    ; find panel page index
    If page <> -1
      found = 0
      ForEach panelexpage()
        If panelexpage()\containerHandle = panelex()\Handle And (panelexpage()\index = page Or panelexpage()\Handle = page)
          found = -1
          Break
        EndIf
      Next
    EndIf
    
    If found = -1 Or page = -1
      
      If page <> -1
        panelExPageInsert = @panelexpage()
      EndIf
      currentPanelEx = panelex()\Handle
      *thisPanelEx = @panelex()
      *thisPanelExPage = @panelexpage()
      UnlockMutex(panelMutex)
      ret = AddPanelExImagePage(background, backgroundImg, imageX, imageY, imageWidth, imageHeight, style)
      LockMutex(panelMutex)
      ChangeCurrentElement(panelex(), *thisPanelEx)
      ChangeCurrentElement(panelexpage(), *thisPanelExPage)
      panelExPageInsert = #False
      
      ; update page indexes
      index = 0
      ForEach panelexpage()
        If panelexpage()\containerHandle = panelex()\Handle
          panelexpage()\index = index
          index = index + 1
        EndIf
      Next
      panelex()\lastPageIndex = index+1
      
      UnlockMutex(panelMutex)
      ProcedureReturn ret
    EndIf
    
    UnlockMutex(panelMutex)
    ProcedureReturn 0
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0
  
EndProcedure

Procedure updatePanelExPage()
  
  ; delete cached back brushes for static controls
  ForEach backbrush()
      DeleteObject_(backbrush()\hBrush)
      DeleteElement(backbrush())
  Next
  
  hwnd = panelexpage()\handle
  page = validateProgressbars(panelexpage()\Handle) ; invalidates root panelex hwnd and validates any sys progress bars inside passed hwnd
  *thispanel = @panelex()
  *thispage = @panelexpage()
  UnlockMutex(panelMutex)
  GetClientRect_(hwnd, @rc.RECT)
  MapWindowPoints_(hwnd, page, @rc, 2)
  RedrawWindow_(page, rc, 0, #RDW_UPDATENOW)
  LockMutex(panelMutex)
  ChangeCurrentElement(panelex(), *thispanel)
  ChangeCurrentElement(panelexpage(), *thispage)

EndProcedure

ProcedureDLL SetPanelExPageBorder(Panel.i, index.i, BorderImage.i, BorderMask.i, *BorderRect.RECT, *BorderAutoStretch.RECT, noRefresh.b) ; Sets a PanelEx's page border.
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      
      ; find panel page index
      ForEach panelexpage()
        If panelexpage()\containerHandle = panelex()\Handle And (panelexpage()\index = index Or panelexpage()\handle = index)
          
          setBorder(panelexpage()\borderHandle, BorderImage, BorderMask, *BorderRect, *BorderAutoStretch)
          
          If noRefresh = #False
            updatePanelExPage()
          EndIf
          
          UnlockMutex(panelMutex)
          ProcedureReturn #True
        EndIf
      Next
      
      Break
    EndIf
  Next
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL SetPanelExPageBackground(Panel.i, page.i, background.i, backgroundImg.i, imageX.l, imageY.l, imageWidth.l, imageHeight.l, style.l, noRefresh.b) ; Sets a PanelEx's page background.
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    ; find panel page index
    found = 0
    ForEach panelexpage()
      If panelexpage()\containerHandle = panelex()\Handle And (panelexpage()\index = page Or panelexpage()\Handle = page)
        found = -1
        Break
      EndIf
    Next
    
    If found = -1
      
      If background <> #PNLX_IGNORE
        If Not style & #PNLX_OVERLAY
          panelexpage()\background = background
        Else
          panelexpage()\background2 = background
        EndIf
      EndIf
      If imageX <> #PNLX_IGNORE
        If Not style & #PNLX_OVERLAY
          panelexpage()\imageX = imageX
        Else
          panelexpage()\imageX2 = imageX
        EndIf
      EndIf
      If imageY <> #PNLX_IGNORE
        If Not style & #PNLX_OVERLAY
          panelexpage()\imageY = imageY
        Else
          panelexpage()\imageY2 = imageY
        EndIf
      EndIf
      If style <> #PNLX_IGNORE
        If Not style & #PNLX_OVERLAY
          panelexpage()\style = style
        Else
          panelexpage()\style2 = style
        EndIf
      EndIf
      
      If backgroundImg <> #PNLX_IGNORE And backgroundImg <> 0
        
        GetImageDimensions(backgroundImg, @bmWidth, @bmHeight)
        
        If imageWidth = 0 Or imageWidth = #PNLX_IGNORE
          imageWidth = bmWidth
        EndIf
        If imageHeight = 0 Or imageHeight = #PNLX_IGNORE
          imageHeight = bmHeight
        EndIf
        
        ; delete existing imagelist if already created
        If Not style & #PNLX_OVERLAY
          If panelexpage()\backgroundImg <> 0
            ImageList_Destroy_(panelexpage()\backgroundImg)
          EndIf
        Else
          If panelexpage()\backgroundImg2 <> 0
            ImageList_Destroy_(panelexpage()\backgroundImg2)
          EndIf
        EndIf

        new = ImageList_Create_(imageWidth, imageHeight, #ILC_MASK | #ILC_COLOR32, 0, 0)
        If new <> 0
          
          ret.l = ImageList_ReplaceIcon_(new, -1, backgroundImg)
          If ret = -1
            
            If style & #PNLX_MASKED
              ; why the fuck does ImageList_AddMasked_ change the original image's masked colour to black?? fucking retards @ microsoft
              ; so now we need to create a temp copy of the original image due to the genius behind said command - more memory bloat and cpu
              ; but wait, theres no API to copy a bitmap, well done MS! ;) - rant over :)
              tbitmap = ImgBlend(backgroundImg, 255, 0, 0, 0, 0, 0)
              ImageList_AddMasked_(new, tbitmap, RGB(255,255,255))
              DeleteObject_(tbitmap)
            Else
              ImageList_Add_(new, backgroundImg, 0)
            EndIf
            
          EndIf
          
          If Not style & #PNLX_OVERLAY
            panelexpage()\backgroundImg = new
            panelexpage()\imageWidth = imageWidth
            panelexpage()\imageHeight = imageHeight
          Else
            panelexpage()\backgroundImg2 = new
            panelexpage()\imageWidth2 = imageWidth
            panelexpage()\imageHeight2 = imageHeight
          EndIf

        EndIf
      
      ; width or height changed but no new image
      ElseIf backgroundImg = #PNLX_IGNORE And (imageWidth <> 0 Or imageHeight <> 0)
        
        If imageWidth = #PNLX_IGNORE
          If Not style & #PNLX_OVERLAY
            imageWidth = panelexpage()\imageWidth
          Else
            imageWidth = panelexpage()\imageWidth2
          EndIf
        EndIf
        
        If imageHeight = #PNLX_IGNORE
          If Not style & #PNLX_OVERLAY
            imageHeight = panelexpage()\imageHeight
          Else
            imageHeight = panelexpage()\imageHeight2
          EndIf
        EndIf

        If Not style & #PNLX_OVERLAY
          panelexpage()\imageWidth = imageWidth
          panelexpage()\imageHeight = imageHeight
        Else
          panelexpage()\imageWidth2 = imageWidth
          panelexpage()\imageHeight2 = imageHeight
        EndIf
        
      EndIf

      If noRefresh = #False
        updatePanelExPage()
      EndIf
      
      UnlockMutex(panelMutex)
      ProcedureReturn #True
    EndIf
    
    UnlockMutex(panelMutex)
    ProcedureReturn 0
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL SetPanelExPageAlpha(Panel.i, Page.i, Alpha.c, noRefresh.b) ; Sets a PanelEx page's alpha transparency, 0 = fully transparent, 255 = opaque.
  
  ;LockMutex(trackWinMutex)
  LockMutex(panelMutex)
  If ListSize(panelex()) > 0
    *thisPanelEx = @panelex()
    If ListSize(panelexpage()) > 0
      *thisPanelExPage = @panelexpage()
    EndIf
  EndIf
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    ; find panel page index
    found = 0
    ForEach panelexpage()
      If panelexpage()\containerHandle = panelex()\Handle And (panelexpage()\index = page Or panelexpage()\Handle = page)
        found = -1
        Break
      EndIf
    Next
    
    If found = -1
      
      panelexpage()\alpha = Alpha

      If noRefresh = #False
        updatePanelExPage()
      EndIf
      
      retval = #True
      
    EndIf
    
  EndIf
  
  If ListSize(panelex()) > 0
    ChangeCurrentElement(panelex(), *thisPanelEx)
    If ListSize(panelexpage()) > 0
      ChangeCurrentElement(panelexpage(), *thisPanelExPage)
    EndIf
  EndIf
  ;UnlockMutex(trackWinMutex)
  UnlockMutex(panelMutex)
  ProcedureReturn retval
  
EndProcedure

ProcedureDLL SetPanelExUserCallback(Panel.i, *UserCallback) ; Sets a PanelEx's usercallback.
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      
      panelex()\usercallback = *UserCallback
      
      result = #True
      
      Break
    EndIf
  Next
  
  UnlockMutex(panelMutex)
  ProcedureReturn result
  
EndProcedure

ProcedureDLL GetPanelExUserCallback(Panel.i) ; Gets a PanelEx's usercallback procedure address.
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      
      *UserCallback = panelex()\usercallback
      
      Break
    EndIf
  Next
  
  UnlockMutex(panelMutex)
  ProcedureReturn *UserCallback
  
EndProcedure

ProcedureDLL GetPanelExBitmap(Panel.i) ; Gets a PanelEx's image buffer.
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      
      *buffer = panelex()\backgroundBitmap
      
      Break
    EndIf
  Next
  
  UnlockMutex(panelMutex)
  ProcedureReturn *buffer
  
EndProcedure

ProcedureDLL GetPanelExDC(Panel.i) ; Gets a PanelEx's image buffer device context.
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      
      dc = panelex()\backgroundDC
      
      Break
    EndIf
  Next
  
  UnlockMutex(panelMutex)
  ProcedureReturn dc
  
EndProcedure

ProcedureDLL RefreshPanelEx(Panel.i)
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = #True
      Break
    EndIf
  Next
  
  If found = #True
    ChangeCurrentElement(panelexpage(), panelex()\displayedPage)
    
    If panelexpage()\autoScroll = #True
    	updatePanelExPageScrolling(0, 0)
      handlePanelExPageAutoScroll()
      updatePanelExPageScrollbars()
      If panelexpage()\hScrollVisible = #True And panelexpage()\vScrollVisible = #True
        RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
        RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
        RedrawWindow_(panelexpage()\scrollBarBox,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
      ElseIf panelexpage()\hScrollVisible = #True
        RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
      ElseIf panelexpage()\vScrollVisible = #True
        RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE)
      EndIf
    EndIf
    
    updatePanelExPage()
    
    UnlockMutex(panelMutex)
    ProcedureReturn #True
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL SetPanelExPageScrolling(Panel.i, index.i, flags.l, Value.l) ; Sets a PanelEx's page scrolling properties
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    ; find panel page index
    found = 0
    ForEach panelexpage()
      If panelexpage()\containerHandle = panelex()\Handle And (panelexpage()\index = index Or panelexpage()\Handle = index)
        found = -1
        Break
      EndIf
    Next
    
    If found = -1
      
      ;/ check flags for valid constants
      
      If flags & #PNLX_HSCROLL And Value = #True
        debuglog("hscroll true")
        hscroll = #True
        visible = #WS_VISIBLE
      ElseIf flags & #PNLX_HSCROLL And Value = #False
        debuglog("hscroll false")
        hscroll = -1
      EndIf
      
      If flags & #PNLX_VSCROLL And Value = #True
        debuglog("vscroll true")
        vscroll = #True
        visible = #WS_VISIBLE
      ElseIf flags & #PNLX_VSCROLL And Value = #False
        debuglog("vscroll false")
        vscroll = -1
      EndIf
      
      If flags & #PNLX_AUTOSCROLL_NOHORIZONTAL And Value = #True
        debuglog("AUTOSCROLL_NOHORIZONTAL true")
        panelexpage()\noHorizontal = #True
      ElseIf flags & #PNLX_AUTOSCROLL_NOHORIZONTAL And Value = #False
        debuglog("AUTOSCROLL_NOHORIZONTAL false")
        panelexpage()\noHorizontal = #False
      EndIf
      
      If flags & #PNLX_AUTOSCROLL_NOVERTICAL And Value = #True
        debuglog("AUTOSCROLL_NOVERTICAL true")
        panelexpage()\noVertical = #True
      ElseIf flags & #PNLX_AUTOSCROLL_NOVERTICAL And Value = #False
        debuglog("AUTOSCROLL_NOVERTICAL false")
        panelexpage()\noVertical = #False
      EndIf
      
      If flags & #PNLX_AUTOSCROLL And Value = #True
        debuglog("autoscroll true")
        hscroll = #True
        vscroll = #True
        panelexpage()\autoScroll = #True
       
        ; create hook to handle keyboard navigation
        If KeyboardHook = 0
          threadId = GetWindowThreadProcessId_(panelexpage()\Handle, 0)
          KeyboardHook = SetWindowsHookEx_(#WH_KEYBOARD, @KeyboardHook(), 0, threadId)
        EndIf
        
      ElseIf flags & #PNLX_AUTOSCROLL And Value = #False
        debuglog("autoscroll false")
        panelexpage()\autoScroll = #False
      EndIf
      
      If flags & #PNLX_SCROLLBARS_OUTSIDE And Value = #True
        debuglog("scroll bars outside of content true")
        panelexpage()\scrollbarsOutside = #True
      ElseIf flags & #PNLX_SCROLLBARS_OUTSIDE And Value = #False
        debuglog("scroll bars outside of content false")
        panelexpage()\scrollbarsOutside = #False
      EndIf
      
      If panelexpage()\displayed = 0
        visible = 0
      EndIf
      
      ;/ create horizontal/vertical scrollbar/s if not already created
      If hscroll = #True And panelexpage()\hScrollBar = 0 And vscroll = #True And panelexpage()\vScrollBar = 0
        
        iHThumb = GetSystemMetrics_(#SM_CXHTHUMB)
        iVThumb = GetSystemMetrics_(#SM_CYVTHUMB)
        GetClientRect_(panelexpage()\Handle, @rc.RECT)
        
        panelexpage()\hScrollBar = CreateWindowEx_(0, "SCROLLBAR", 0, #WS_CHILD | #SBS_HORZ | visible | #SBS_BOTTOMALIGN | #WS_CLIPSIBLINGS | #WS_CLIPCHILDREN, 0, 0, rc\right-iHThumb, rc\bottom, panelexpage()\containerHandle, 0, GetModuleHandle_(0),0)
        panelexpage()\vScrollBar = CreateWindowEx_(0, "SCROLLBAR", 0, #WS_CHILD | #SBS_VERT | visible | #SBS_RIGHTALIGN | #WS_CLIPSIBLINGS | #WS_CLIPCHILDREN, 0, 0, rc\right, rc\bottom-iVThumb, panelexpage()\containerHandle, 0, GetModuleHandle_(0),0)
        
        ; create scrollbar box
        panelexpage()\scrollBarBox = createScrollbarBox(panelexpage()\containerHandle, rc\right-iHThumb, rc\bottom-iVThumb, visible)
        
        debuglog("created both")
        
        calcarea.ScrollingChildWindows
        calcarea\Window = panelexpage()\Handle
        EnumChildWindows_(calcarea\Window, @ScrollingChildWindowsEnumProc(), @calcarea)
        panelexpage()\area\right = calcarea\rc\right
        panelexpage()\area\bottom = calcarea\rc\bottom
        handlePanelExPageAutoScroll()
        updatePanelExPageScrolling(0, 0)
        updatePanelExPageScrollbars()
        
      ElseIf hscroll = #True And panelexpage()\hScrollBar = 0
        
        GetClientRect_(panelexpage()\Handle, @rc.RECT)
        
        ; create scrollbar box
        If panelexpage()\scrollBarBox = 0
          iHThumb = GetSystemMetrics_(#SM_CXHTHUMB)
          iVThumb = GetSystemMetrics_(#SM_CYVTHUMB)
          panelexpage()\scrollBarBox = createScrollbarBox(panelexpage()\Handle, rc\right-iHThumb, rc\bottom-iVThumb, #False)
        EndIf

        panelexpage()\hScrollBar = CreateWindowEx_(0, "SCROLLBAR", 0, #WS_CHILD | #SBS_HORZ | visible | #SBS_BOTTOMALIGN, 0, 0, rc\right, rc\bottom, panelexpage()\Handle, 0, GetModuleHandle_(0),0)
        panelexpage()\hScrollVisible = #True

        debuglog("created h")
        
      ElseIf vscroll = #True And panelexpage()\vScrollBar = 0
        
        GetClientRect_(panelexpage()\Handle, @rc.RECT)
        
        ; create scrollbar box
        If panelexpage()\scrollBarBox = 0
          iHThumb = GetSystemMetrics_(#SM_CXHTHUMB)
          iVThumb = GetSystemMetrics_(#SM_CYVTHUMB)
          panelexpage()\scrollBarBox = createScrollbarBox(panelexpage()\Handle, rc\right-iHThumb, rc\bottom-iVThumb, #False)
        EndIf
        
        panelexpage()\vScrollBar = CreateWindowEx_(0, "SCROLLBAR", 0, #WS_CHILD | #SBS_VERT | visible | #SBS_RIGHTALIGN, 0, 0, rc\right, rc\bottom, panelexpage()\Handle, 0, GetModuleHandle_(0),0)
        panelexpage()\vScrollVisible = #True
        debuglog("created v")
      
      ;/ if scrollbars already created
      Else  
        
        ; show horizontal scrollbar if already created
        If hscroll = #True And panelexpage()\hScrollBar <> 0
          
          ShowWindow_(panelexpage()\hScrollBar, #SW_SHOWNA) ; show scrollbar window
          panelexpage()\hScrollVisible = #True
          debuglog("show h")
        
        ; hide horizontal scrollbar if already created
        ElseIf hscroll = -1 And panelexpage()\hScrollBar <> 0

          ShowWindow_(panelexpage()\hScrollBar, #SW_HIDE) ; hide scrollbar window
          panelexpage()\hScrollVisible = #False
          
        EndIf
        
        ; show vertical scrollbar if already created
        If vscroll = #True And panelexpage()\vScrollBar <> 0
          
          ShowWindow_(panelexpage()\vScrollBar, #SW_SHOWNA) ; show scrollbar window
          panelexpage()\vScrollVisible = #True
          debuglog("show v")
          
        ; hide vertical scroll bar if already created
        ElseIf vscroll = -1 And panelexpage()\vScrollBar <> 0
          
          ShowWindow_(panelexpage()\vScrollBar, #SW_HIDE) ; hide scrollbar window
          panelexpage()\vScrollVisible = #False
          
        EndIf
        
        If panelexpage()\hScrollVisible = #False And panelexpage()\vScrollVisible = #False
          ShowWindow_(panelexpage()\scrollBarBox, #SW_HIDE)
        EndIf
        
      EndIf
      
      
      updatePanelExPageScrollbars()
      
      ;If panelexpage()\autoScroll = #True
      ;  updatePanelExPageScrolling(0, 0)
      ;  handlePanelExPageAutoScroll()
      ;EndIf
      
;       If panelexpage()\hScrollVisible = #True Or panelexpage()\vScrollVisible = #True
;         
;         ;updatePanelExPageScrollbars()
;         
;         If panelexpage()\hScrollVisible = #True And panelexpage()\vScrollVisible = #True
;           Debug "yar"
;           RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
;           RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
;           RedrawWindow_(panelexpage()\scrollBarBox,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
;         ElseIf panelexpage()\hScrollVisible = #True
;           RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
;         ElseIf panelexpage()\vScrollVisible = #True
;           RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
;         EndIf
;         
;       EndIf
      
      
      UnlockMutex(panelMutex)    
      ProcedureReturn #True
    EndIf
    
    UnlockMutex(panelMutex)
    ProcedureReturn 0
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL GetPanelExPageScrolling(Panel.i, index.i, flag.l) ; Returns a PanelEx page's scrolling property value specified by flag.
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    ; find panel page index
    found = 0
    ForEach panelexpage()
      If panelexpage()\containerHandle = panelex()\Handle And (panelexpage()\index = index Or panelexpage()\Handle = index)
        found = -1
        Break
      EndIf
    Next
    
    If found = -1
      
      ;/ check flags for valid constants
      
      Select flag
        Case #PNLX_HSCROLL
          retval = panelexpage()\hScrollVisible
        Case #PNLX_VSCROLL
          retval = panelexpage()\vScrollVisible
        Case #PNLX_HSCROLLHANDLE
          retval = panelexpage()\hScrollBar
        Case #PNLX_VSCROLLHANDLE
          retval = panelexpage()\vScrollBar
        Case #PNLX_AUTOSCROLL
          retval = panelexpage()\autoScroll 
      EndSelect
      
    EndIf
    
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn retval
  
EndProcedure

ProcedureDLL SetPanelExPageCursor(Panel.i, index.i, *Cursor) ; Sets a PanelEx page's mouse cursor
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    ; find panel page index
    found = 0
    ForEach panelexpage()
      If panelexpage()\containerHandle = panelex()\Handle And (panelexpage()\index = index Or panelexpage()\Handle = index)
        found = -1
        Break
      EndIf
    Next
    
    If found = -1
      
      ; if system cursor constant passed then load system cursor
      If *Cursor >= #IDC_ARROW And *Cursor <= #IDC_HELP
        *Cursor = LoadCursor_(0, *Cursor)
      EndIf
      panelexpage()\cursor = *Cursor
      
      pt.POINT
      GetCursorPos_(@pt)
      hwnd = WindowFromPoint_(PeekQ(pt))
      If hwnd = panelexpage()\Handle
        If panelexpage()\cursor > 0
          SetCursor_(panelexpage()\cursor)
        ElseIf panelexpage()\cursor = 0
          SetCursor_(normalMousePointer)
        EndIf
      EndIf
      
      UnlockMutex(panelMutex)    
      ProcedureReturn *Cursor
    EndIf
    
    UnlockMutex(panelMutex)
    ProcedureReturn 0
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL ShowPanelExPage(Panel, index)
  
  macro_protectCommand()
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    ; find panel page index
    found = 0
    ForEach panelexpage()
      If panelexpage()\containerHandle = panelex()\Handle And panelexpage()\index = index
        found = -1
        Break
      EndIf
    Next
    ; if index not found then search by handle
    If found = 0
      ForEach panelexpage()
        If panelexpage()\containerHandle = panelex()\Handle And panelexpage()\Handle = index
          found = -1
          Break
        EndIf
      Next
    EndIf
    
    If found = -1
      new = @panelexpage()
      ChangeCurrentElement(panelexpage(), panelex()\displayedPage)
      ShowWindow_(panelexpage()\Handle, #SW_HIDE)
      
      ; hide scrollbars if any
      If GetWindowLongPtr_(panelexpage()\hScrollBar, #GWL_STYLE) & #WS_VISIBLE
        ShowWindow_(panelexpage()\hScrollBar, #SW_HIDE)
      EndIf
      If GetWindowLongPtr_(panelexpage()\vScrollBar, #GWL_STYLE) & #WS_VISIBLE
        ShowWindow_(panelexpage()\vScrollBar, #SW_HIDE)
      EndIf
      If panelexpage()\scrollBarBox <> 0 And GetWindowLongPtr_(panelexpage()\scrollBarBox, #GWL_STYLE) & #WS_VISIBLE
        ShowWindow_(panelexpage()\scrollBarBox, #SW_HIDE)
      EndIf
      
      panelexpage()\displayed = 0
      panelex()\displayedPage = new
      ChangeCurrentElement(panelexpage(), panelex()\displayedPage)
      GetClientRect_(panelexpage()\Handle, @rc.RECT)
      SendMessage_(panelexpage()\Handle, #WM_SETREDRAW, #False, 0)
      ShowWindow_(panelexpage()\Handle, #SW_SHOW)
      SendMessage_(panelexpage()\Handle, #WM_SETREDRAW, #True, 0)
      
      ; show scrollbars if any
      If panelexpage()\hScrollVisible = #True
        ShowWindow_(panelexpage()\hScrollBar, #SW_SHOW)
      EndIf
      If panelexpage()\vScrollVisible = #True
        ShowWindow_(panelexpage()\vScrollBar, #SW_SHOW)
      EndIf
      
      If panelexpage()\autoScroll = #True
        updatePanelExPageScrolling(0, 0)
        handlePanelExPageAutoScroll()
      EndIf
      
      If panelexpage()\hScrollVisible = #True Or panelexpage()\vScrollVisible = #True
        
        updatePanelExPageScrollbars()
        
        If panelexpage()\hScrollVisible = #True And panelexpage()\vScrollVisible = #True
          RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
          RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
          RedrawWindow_(panelexpage()\scrollBarBox,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
        ElseIf panelexpage()\hScrollVisible = #True
          RedrawWindow_(panelexpage()\hScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
        ElseIf panelexpage()\vScrollVisible = #True
          RedrawWindow_(panelexpage()\vScrollBar,0,0,#RDW_NOERASE|#RDW_NOFRAME|#RDW_INVALIDATE|#RDW_UPDATENOW)
        EndIf
        
      EndIf
      
      panelex()\currentPageIndex = panelexpage()\index
      panelexpage()\displayed = -1
      
      validateProgressbars(panelexpage()\Handle) ; invalidates panelex hwnd and validates any sys progress bars inside
      handle = panelexpage()\handle
      UnlockMutex(panelMutex)
      RedrawWindow_(handle,0,0,#RDW_ERASE|#RDW_ERASENOW|#RDW_UPDATENOW);|#RDW_ALLCHILDREN)
      
      ProcedureReturn -1
    EndIf
    
    UnlockMutex(panelMutex)
    ProcedureReturn 0
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL PanelExID(Panel, index) ; returns the HWND of a PanelEx Page or if index = -1, the PanelEx HWND
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    If index < 0
      handle = panelex()\handle
      UnlockMutex(panelMutex)
      ProcedureReturn handle
    EndIf
    
    ; find panel page index
    found = 0
    ForEach panelexpage()
      If panelexpage()\containerHandle = panelex()\Handle And panelexpage()\index = index
        found = -1
        Break
      EndIf
    Next
    
    If found = -1
      handle = panelexpage()\handle
      UnlockMutex(panelMutex)
      ProcedureReturn handle
    EndIf
    
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0
  
EndProcedure


ProcedureDLL PanelExPageIndex(Panel)
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  ; if not found then check for page handle
  If found = 0
    ForEach panelexpage()
      If panelexpage()\Handle = Panel
        found = -2
        Break
      EndIf
    Next
  EndIf
  
  If found = -1
    
    index = panelex()\currentPageIndex
    UnlockMutex(panelMutex)
    ProcedureReturn index
    
  ElseIf found -2
    
    index = panelexpage()\index
    UnlockMutex(panelMutex)
    ProcedureReturn index
    
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn -1
  
EndProcedure

Procedure panelEnumChildReParent(hwnd, parent)
  
  SetParent_(hwnd, parent)
  ProcedureReturn #True
  
EndProcedure

ProcedureDLL FreePanelEx(id.i)  ; Frees a PanelEx from memory.
  
  LockMutex(panelMutex)
  
  ; make sure panel id doesn't already exist
  ForEach panelex()
    If panelex()\id = id Or panelex()\Handle = id Or id = -1
      
      ForEach panelexpage()
        If panelexpage()\containerHandle = panelex()\Handle
          
          *thisPanelEx = @panelex()
          *thisPanelExPage = @panelexpage()
          handle = panelexpage()\Handle
          UnlockMutex(panelMutex)
          EnumChildWindows_(panelexpage()\Handle, @panelEnumChildReParent(), GetParent_(GetParent_(handle)))
          DestroyWindow_(handle)
          LockMutex(panelMutex)
          ChangeCurrentElement(panelex(), *thisPanelEx)
          ChangeCurrentElement(panelexpage(), *thisPanelExPage)
          If panelexpage()\backgroundImg <> 0
            ImageList_Destroy_(panelexpage()\backgroundImg)
          EndIf
          If panelexpage()\backgroundImg2 <> 0
            ImageList_Destroy_(panelexpage()\backgroundImg2)
          EndIf
          
          freeBorder(panelexpage()\borderHandle)
          
          DeleteElement(panelexpage(), 1)
          
        EndIf
      Next
      
      *thisPanelEx = @panelex()
      handle = panelex()\Handle
      UnlockMutex(panelMutex)
      DestroyWindow_(handle)
      LockMutex(panelMutex)
      ChangeCurrentElement(panelex(), *thisPanelEx)
      
      If panelex()\backgroundBitmap <> #Null And IsImage(panelex()\backgroundBitmap)
        FreeImage(panelex()\backgroundBitmap)
        DeleteDC_(panelex()\backgroundDC)
      EndIf
      
      If panelex()\alphaBitmap <> #Null And IsImage(panelex()\alphaBitmap)
        FreeImage(panelex()\alphaBitmap)
        DeleteDC_(panelex()\alphaDC)
      EndIf
      
      If currentPanelEx = panelex()\Handle
        currentPanelEx = 0
      EndIf
      
      DeleteElement(panelex(), 1)
      
      If id <> -1
        UnlockMutex(panelMutex)
        ProcedureReturn #True
      EndIf
      
    EndIf
  Next
  
  If id = -1
    UnlockMutex(panelMutex)
    ProcedureReturn #True
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL FreePanelExPage(id.i, index.l) ; Removes a PanelExPage from PanelEx.
  
  LockMutex(panelMutex)
  
  displayed = -1
  ForEach panelex()
    If panelex()\id = id Or panelex()\Handle = id
      found = #True
      ForEach panelexpage()
        If panelexpage()\containerHandle = panelex()\Handle And (panelexpage()\index = index Or index = -1)
          
          EnumChildWindows_(panelexpage()\Handle, @panelEnumChildReParent(), GetParent_(panelex()\Handle))
          
          *thisPanelEx = @panelex()
          *thisPanelExPage = @panelexpage()
          handle = panelexpage()\Handle
          UnlockMutex(panelMutex)
          EnumChildWindows_(panelexpage()\Handle, @panelEnumChildReParent(), GetParent_(GetParent_(handle)))
          DestroyWindow_(panelexpage()\Handle)
          LockMutex(panelMutex)
          ChangeCurrentElement(panelex(), *thisPanelEx)
          ChangeCurrentElement(panelexpage(), *thisPanelExPage)
          If panelexpage()\backgroundImg <> 0
            ImageList_Destroy_(panelexpage()\backgroundImg)
          EndIf
          If panelexpage()\backgroundImg2 <> 0
            ImageList_Destroy_(panelexpage()\backgroundImg2)
          EndIf
          
          freeBorder(panelexpage()\borderHandle)
          
          If panelex()\displayedPage = @panelexpage()
            displayed = panelexpage()\index
          EndIf
          
          DeleteElement(panelexpage())
          If index <> -1
            found = -1
            Break
          EndIf
        EndIf
      Next
      
      ; adjust page numbers
      page = 0
      ForEach panelexpage()
        If panelexpage()\containerHandle = panelex()\Handle
          If (displayed > 0 And panelexpage()\index = displayed-1) Or (displayed = 0 And panelexpage()\index = displayed+1)
            panelexpage()\displayed = -1
            panelex()\displayedPage = @panelexpage()
            displayed = page
          EndIf
          panelexpage()\index = page
          page = page + 1
        EndIf
      Next
      panelex()\lastPageIndex = page + 1
          
      Break
    EndIf
  Next
  
  If displayed <> -1
    handle = panelex()\handle
    UnlockMutex(panelMutex)
    ShowPanelExPage(handle, displayed)
  EndIf
  
  If (found = #True And index = -1) Or found = -1
    UnlockMutex(panelMutex)
    ProcedureReturn #True
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn 0
  
EndProcedure

ProcedureDLL PanelExWidth(Panel) ; Returns width of PanelEx in pixels
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    rc.RECT
    GetWindowRect_(panelex()\Handle, @rc)
    UnlockMutex(panelMutex)
    ProcedureReturn rc\right-rc\left
    
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn -1
  
EndProcedure

ProcedureDLL PanelExHeight(Panel) ; Returns height of PanelEx in pixels
  
  LockMutex(panelMutex)
  
  ; find panel by id or handle
  found = 0
  ForEach panelex()
    If panelex()\Handle = Panel Or panelex()\id = Panel
      found = -1
      Break
    EndIf
  Next
  
  If found = -1
    
    rc.RECT
    GetWindowRect_(panelex()\Handle, @rc)
    UnlockMutex(panelMutex)
    ProcedureReturn rc\bottom-rc\top
    
  EndIf
  
  UnlockMutex(panelMutex)
  ProcedureReturn -1
  
EndProcedure

;--
;- Skins
;--
; this internal function finds or creates the specified property in the current skin and makes sure all the correct lists are
; currently selected and initialised
Procedure selectSkinProperty(Component.s, State.s, Property.s)
  
  ; find or create specified component
  found = #False
  ForEach skin()\component()
    If skin()\component()\name = Component
      found = #True
      Break
    EndIf
  Next
  If found = #False
    AddElement(skin()\component())
    skin()\component()\name = Component
  EndIf
  
  ; find or create specified state
  found = #False
  ForEach skin()\component()\state()
    If skin()\component()\state()\name = State
      found = #True
      Break
    EndIf
  Next
  If found = #False
    AddElement(skin()\component()\state())
    skin()\component()\state()\name = State
  EndIf
  
  ; find or create specified property
  found = #False
  ForEach skin()\component()\state()\property()
    If skin()\component()\state()\property()\name = Property
      found = #True
      Break
    EndIf
  Next
  If found = #False
    AddElement(skin()\component()\state()\property())
    skin()\component()\state()\property()\name = Property
  EndIf
  
EndProcedure

Procedure selectSkinPropertyBySkin(*Skin.skins, Component.s, State.s, Property.s)
  
  If ListSize(skin()) > 0
    *thisSkin = @skin()
  EndIf
  
  ChangeCurrentElement(skin(), *Skin)
  selectSkinProperty(Component, State, Property)
  
  If ListSize(skin()) > 0
    ChangeCurrentElement(skin(), *thisSkin)
  EndIf
  
EndProcedure

; this internal function returns true if the component, state and property exist in the current skin
Procedure isSkinProperty(Component.s, State.s, Property.s)
  
  Component = LCase(Component)
  State = LCase(State)
  Property = LCase(Property)
  
  found = #False
  ForEach skin()\component()
    If skin()\component()\name = Component
      
      ForEach skin()\component()\state()
        If skin()\component()\state()\name = State
          
          ForEach skin()\component()\state()\property()
            If skin()\component()\state()\property()\name = Property
              found = #True
              Break
            EndIf
          Next
          
          Break
        EndIf
      Next
      
      Break
    EndIf
  Next
  
  ProcedureReturn found
  
EndProcedure

; returns a string with skin component formatted with colour theme if exists
Procedure.s componentColourTheme(Component.s, State.s, Property.s)
  
  ; check Component for optional colon separated colour theme name
  If FindString(Component, ":", 1) > 0
    colourTheme.s = Trim(StringField(Component, 2, ":"))
    Component = Trim(StringField(Component, 1, ":"))+":"+colourTheme
    
    ; the property for component with colour theme doesn't exist return just component part
    If isSkinProperty(Component, State, Property) = #False
      Component = Trim(StringField(Component, 1, ":"))
    EndIf
          
  Else
    If GlobalSkinColourTheme <> ""
      colourTheme.s = GlobalSkinColourTheme
    Else
      colourTheme.s = DefaultGlobalSkinColourTheme
    EndIf
    Component = Trim(Component)+":"+colourTheme
    
    ; the property for component with colour theme doesn't exist return just component part
    If isSkinProperty(Component, State, Property) = #False
      Component = Trim(StringField(Component, 1, ":"))
    EndIf
    
  EndIf
  
  ProcedureReturn Component
      
EndProcedure

; returns skin property value as string without any parameters
Procedure.s getSkinValueNoParams(value.s)
  
  If StringField(value, 1, ";") <> ""
    value = StringField(value, 1, ";")
  EndIf
  
  ProcedureReturn Trim(value)
  
EndProcedure

; extracts parameters from skin property value and puts them in array of SkinValueParams
; returns #true if value contains parameters
Structure SkinValueParam
  name.s
  var.s
EndStructure
Procedure getSkinValueParams(value.s, Array param.SkinValueParam(1))
  
  ;Debug "-----"
  i = 1
  n = 0
  Repeat
    p.s = StringField(value, i, ";")
    If p <> ""
      name.s = Trim(StringField(p, 1, ":"))
      var.s = Trim(StringField(p, 2, ":"))
      If name <> ""
        ReDim param.SkinValueParam(n+1)
        param(n)\name = name
        If var = ""
          param(n)\var = "true"
        Else
          param(n)\var = var
        EndIf
        ;Debug "param:"+name+" val:"+var
        n = n + 1
        found = #True
      EndIf
    EndIf
    i = i + 1
  Until p = ""
  
  ProcedureReturn found
  
EndProcedure

Procedure isFontWebSafe(fontname.s) ; returns true if specified font name is a standard web-safe font
  
  safefont.s = ""
  safefont + "Arial, Helvetica,"
  safefont + "Arial Black,"
  safefont + "Comic Sans MS,"
  safefont + "Courier New, Courier,"
  safefont + "Georgia,"
  safefont + "Impact, Charcoal,"
  safefont + "Lucida Console, Monaco,"
  safefont + "Lucida Sans Unicode, Lucida Grande,"
  safefont + "Palatino Linotype, Book Antiqua, Palatino,"
  safefont + "Tahoma, Geneva,"
  safefont + "Times New Roman, Times,"
  safefont + "Trebuchet MS,"
  safefont + "Verdana,"
  safefont + "Symbol,"
  safefont + "Webdings,"
  safefont + "Wingdings, Zapf Dingbats,"
  safefont + "MS Sans Serif,"
  safefont + "MS Serif, New York,"
  safefont + "Serif, Sans-serif, monospace, cursive,"
  
  fontname = Trim(LCase(StringField(fontname, 1, ".")))
  safefont = LCase(safefont)
  
  If FindString(safefont, fontname) > 0
    ProcedureReturn #True
  EndIf
  
  ProcedureReturn #False
  
EndProcedure

Procedure isPathSkinResource(Path.s)
  
  Path = getSkinValueNoParams(Path)
  
  Path2.s = skin()\name+"\"+GetFilePart(Path)
  
  If FindString(Path, ".", 1) > 0 And StringField(Trim(Path), 1, ".") <> "" And StringField(Trim(Path), 2, ".") <> ""
    If IsNumeric(Path) = #False And CheckFilename(GetFilePart(Path)) = #True
      
      If SkinPath <> ""
        SkinLastCurrentDir = GetCurrentDirectory()
        SetCurrentDirectory(SkinPath)
      EndIf

      If FileSize(Path) > 0
        ret = #True
      Else
        If FileSize(Path2) > 0
          ret =#True
        Else
          ret = -1
        EndIf
      EndIf
      
      If ret <> #True And GetPathPart(Path) = "" And FileSize(skin()\name+".sknz") > 0
        pack = OpenPack(1, skin()\name+".sknz")
        If pack <> 0
          If ExaminePack(1)
          
            While NextPackEntry(1)
              name.s = PackEntryName(1)
              If name = Path
                ret = #True
                Break
              EndIf
            Wend
            
          EndIf
          ClosePack(1)
        EndIf
      EndIf
      
      If SkinPath <> ""
        SetCurrentDirectory(SkinLastCurrentDir)
      EndIf
      
    EndIf
  EndIf
  
  ProcedureReturn ret
  
EndProcedure

Procedure loadSkinResource(Value.s)
  
  Path.s = getSkinValueNoParams(Value)
  
  If Path <> "" And CheckFilename(GetFilePart(Path)) = #True
    
    If SkinPath <> ""
      SkinLastCurrentDir = GetCurrentDirectory()
      SetCurrentDirectory(SkinPath)
    EndIf
    
    Path2.s = skin()\name+"\"+GetFilePart(Path)
    ;Debug "Path2: "+Path2
    
    ; process any parameters
    Dim param.SkinValueParam(1)
    If getSkinValueParams(Value, param()) = #True
      For n = 1 To ArraySize(param())-1
        ;Debug param(n)\name+" "+param(n)\var
        
        name.s = LCase(param(n)\name)
        var.s = LCase(param(n)\var)
        
        Select name
          Case "width"
            width = Val(var)
          Case "height"
            height = Val(var)
        EndSelect
        
      Next
    EndIf
    
    *oldResData = skin()\component()\state()\property()\resData
    oldResType = skin()\component()\state()\property()\resType
    
    *file = LoadImage_(GetModuleHandle_(0), Path, #IMAGE_ICON, width, height, #LR_LOADFROMFILE)
    If *file = 0
      *file = LoadImage_(GetModuleHandle_(0), Path2, #IMAGE_ICON, width, height, #LR_LOADFROMFILE)
      If *file = 0
        If GetPathPart(Path) = "" And FileSize(skin()\name+".sknz") > 0
          
          pack = OpenPack(0, skin()\name+".sknz")
          If pack <> 0
            
            If ExaminePack(0)
              
              While NextPackEntry(0)
                
                name.s = PackEntryName(0)
                If name = Path
                  size = PackEntrySize(0)
                  *mem = AllocateMemory(size)
                  If *mem <> #Null
                    If UncompressPackMemory(0, *mem, size, name)
                      f = CreateFile(#PB_Any, GetTemporaryDirectory()+Path)
                      WriteData(f, *mem, size)
                      CloseFile(f)
                      *file = LoadImage_(GetModuleHandle_(0), GetTemporaryDirectory()+Path, #IMAGE_ICON, width, height, #LR_LOADFROMFILE)
                      DeleteFile(GetTemporaryDirectory()+Path)
                    EndIf
                    FreeMemory(*mem)
                  EndIf
                  Break
                EndIf
                
              Wend
              
            EndIf
            
            ClosePack(0)
          EndIf
        EndIf
      EndIf
    EndIf
    If *file <> 0
      Debug GetFilePart(Path)+" icon loaded!"
      skin()\component()\state()\property()\resType = #SKIN_RES_ICON
      skin()\component()\state()\property()\resData = *file
      skin()\component()\state()\property()\resDataSize = 0
      loaded = #True
    Else
      Debug "not icon"
      *file = LoadImage(#PB_Any, Path)
      If *file = 0
        *file = LoadImage(#PB_Any, Path2)
        If *file = 0
          If GetPathPart(Path) = "" And FileSize(skin()\name+".sknz") > 0
            pack = OpenPack(0, skin()\name+".sknz")
            If pack <> 0
              
              If ExaminePack(0)
              
                While NextPackEntry(0)
                  
                  name.s = PackEntryName(0)
                  If name = Path
                    size = PackEntrySize(0)
                    *mem = AllocateMemory(size)
                    If *mem <> #Null
                      If UncompressPackMemory(0, *mem, size, name)
                        *file = CatchImage(#PB_Any, *mem, size)
                      EndIf
                      FreeMemory(*mem)
                    EndIf
                    Break
                  EndIf
                  
                Wend
                
              EndIf
              
              ClosePack(0)
            EndIf
          EndIf
        EndIf
      EndIf
      If *file <> 0
        Debug GetFilePart(Path)+" image loaded!"
        skin()\component()\state()\property()\resType = #SKIN_RES_IMAGE
        skin()\component()\state()\property()\resData = *file
        skin()\component()\state()\property()\resDataSize = 0
        loaded = #True
      Else
        Debug "not image"
        Debug GetFilePart(Path)+" loading as data"
        size = FileSize(Path)
        If size > 0
          file = ReadFile(#PB_Any, Path)
          If file = 0
            file = ReadFile(#PB_Any, Path2)
          EndIf
          If file <> 0
            *mem = AllocateMemory(size)
            If *mem <> 0
              size = ReadData(file, *mem, size)
              skin()\component()\state()\property()\resType = #SKIN_RES_DATA
              skin()\component()\state()\property()\resData = *mem
              skin()\component()\state()\property()\resDataSize = size
              loaded = #True
            EndIf
            CloseFile(file)
          EndIf
        EndIf
        
        If *file = 0
          If GetPathPart(Path) = "" And FileSize(skin()\name+".sknz") > 0
            pack = OpenPack(0, skin()\name+".sknz")
            If pack <> 0
              
              If ExaminePack(0)
              
                While NextPackEntry(0)
                  
                  name.s = PackEntryName(0)
                  If name = Path
                    size = PackEntrySize(0)
                    *mem = AllocateMemory(size)
                    If *mem <> #Null
                      If UncompressPackMemory(0, *mem, size, name)
                        *file = AllocateMemory(size)
                        CopyMemory(*mem, *file, size)
                        skin()\component()\state()\property()\resType = #SKIN_RES_DATA
                        skin()\component()\state()\property()\resData = *file
                        skin()\component()\state()\property()\resDataSize = size
                        loaded = #True
                      EndIf
                      FreeMemory(*mem)
                    EndIf
                    Break
                  EndIf
                  
                Wend
                
              EndIf
              
              ClosePack(0)
            EndIf
          EndIf
        EndIf
        
      EndIf
    EndIf
    
    ; free old resource if any
    If loaded = #True And *oldResData <> 0
      Select oldResType
        Case #SKIN_RES_ICON
          ;DestroyIcon_(*oldResData)
        Case #SKIN_RES_IMAGE
          ;FreeImage(*oldResData)
        Case #SKIN_RES_DATA
          ;FreeMemory(*oldResData)
      EndSelect
    EndIf
    
    If SkinPath <> ""
      SetCurrentDirectory(SkinLastCurrentDir)
    EndIf
    
  EndIf
  
  ProcedureReturn loaded
  
EndProcedure

Procedure SetDefaultGlobalSkinColourTheme(colour.l)
  
  If OSVersion() >= #PB_OS_Windows_Vista
    DefaultGlobalSkinColourTheme = "blue"
    ProcedureReturn
  EndIf
  
  r = Red(colour)
  g = Green(colour)
  b = Blue(colour)
  
  ;debuglog("colors: "+Str(r)+" "+Str(g)+" "+Str(b))
  
  ; 3 different colour highlight styles depending on theme colour
  ; colour is more silver/grey
  If r >= 200 And g >= 200 And b >= 200
    
    DefaultGlobalSkinColourTheme = "silver"
    
  ; colour is more blue
  ElseIf r < 200 And g < 200 And b >= 200
    
    DefaultGlobalSkinColourTheme = "blue"

  ; colour is more green
  ElseIf r >= 200 And g >= 200 And b < 200
    
    DefaultGlobalSkinColourTheme = "olive"
    
  ; any other colour combination, default to clasic grey
  Else
    
    DefaultGlobalSkinColourTheme = "grey"
    
  EndIf

EndProcedure

ProcedureDLL.s GetDefaultGlobalSkinColourTheme() ; Gets the default detected global colour theme name
  
  macro_protectCommand()
  
  ReturnString$ = DefaultGlobalSkinColourTheme
    
  ProcedureReturn ReturnString$
    
EndProcedure

; structure used for passing to window/child enumeration skin update procedures
Structure UPDATESKINSTRUCT
  processID.i
  skin.i
  redrawHwnd.i
EndStructure

; broadcasts #WM_UPDATESKIN message to all current process's top level windows's children
Procedure EnumChildUpdateSkin(hwnd, lParam)
  
  *uskin.UPDATESKINSTRUCT = lParam
  
  If *uskin\redrawHwnd <> 0 And GetWindowLongPtr_(hwnd, #GWL_STYLE) & #WS_VISIBLE
    If GetParent_(hwnd) = *uskin\redrawHwnd
      AddElement(skinHwndRedraw())
      skinHwndRedraw() = hwnd
      SendMessage_(hwnd, #WM_SETREDRAW, #False, 0)
    EndIf
    *proc = GetWindowLongPtr_(hwnd, #GWL_WNDPROC)
    CallWindowProc_(*proc, hwnd, #WM_UPDATESKIN, 0, *uskin\skin)
  Else
    ;PostMessage_(hwnd, #WM_UPDATESKIN, 0, *uskin\skin)
    *proc = GetWindowLongPtr_(hwnd, #GWL_WNDPROC)
    CallWindowProc_(*proc, hwnd, #WM_UPDATESKIN, 0, *uskin\skin)
  EndIf
  
  ProcedureReturn #True
EndProcedure
Procedure EnumWindowsUpdateSkin(hwnd, lParam)
  
  *uskin.UPDATESKINSTRUCT = lParam
  
  GetWindowThreadProcessId_(hwnd, @processID)
  If processID = *uskin\processID
    
    ClearList(skinHwndRedraw())
    If GetWindowLongPtr_(hwnd, #GWL_STYLE) & #WS_VISIBLE
      *uskin\redrawHwnd = hwnd
    Else
      *uskin\redrawHwnd = 0
    EndIf
    EnumChildWindows_(hwnd, @EnumChildUpdateSkin(), lParam)
    
    ForEach skinHwndRedraw()
      SendMessage_(skinHwndRedraw(), #WM_SETREDRAW, #True, 0)
      RedrawWindow_(skinHwndRedraw(), 0, 0, #RDW_UPDATENOW|#RDW_ERASENOW|#RDW_INVALIDATE|#RDW_ALLCHILDREN)
    Next
    
  EndIf
  
  ProcedureReturn #True
EndProcedure


Procedure delayedUpdateSkins(hwnd, uMsg, idEvent, dwTime)
  
  uskin.UPDATESKINSTRUCT
  uskin\processID = GetCurrentProcessId_()
  uskin\skin = idEvent
  
  debuglog("delayed updating skin: "+Str(idEvent))
  
  ; broadcast update skin message to all current process's top level windows's children
  EnumWindows_(@EnumWindowsUpdateSkin(), @uskin)
  
  KillTimer_(hwnd, idEvent)
  
EndProcedure

