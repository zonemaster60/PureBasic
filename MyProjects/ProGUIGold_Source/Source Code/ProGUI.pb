;--=========
;- initProGUI
;--=========
ProcedureDLL ProGUI_Init()
  
  Global NewMap previousMutexLine.s()
  Global NewList lsicon.listiconsubicons()
  Global NewList backbrush.backbrushes()
  Global NewList txtcontrol.txtcontrols()
  Global NewList panelexpage.panelexpages()
  Global NewList panelex.panelexs()
  Global NewList rebarBand.rebarbands()
  Global NewList rebarGadget.rebarGadgets()
  Global NewList toolbarEx.toolbarExs()
  Global NewList toolbarExButton.toolbarExButtons()
  Global NewList toolbartip.toolbarTooltips()
  Global NewList itemex.itemexs()
  Global NewList menuex.menuexs()
  Global NewList popupUserData.popupUserDatas()
  Global NewList menuScrollHotKey.menuScrollHotKeys()
  Global NewList menuCallback.menuCallbacks()
  Global NewList buttonx.buttonexs()
  Global NewList splitterx.splitterexs()
  Global NewList xbar.ExplorerBars()
  Global NewList Gradient.gradients()
  Global NewList cmdbar.CommandBars()
  Global NewList drpShadow.dropShadows() ; used for keeping track of a drop shadow's hdc and bitmap data
  Global NewList shadow.shadows() ; used for keeping tack of active menu drop shadows
  Global NewList titleShadow.shadows(); used for keeping track of menu title drop shadows
  Global NewList skin.skins()
  Global NewList skinHwndRedraw() ; keeps track of top level child windows that have had the #WM_UPDATESKIN message sent and need redrawing
  Global NewMap colour()  ; map of colour names to rgb value
  Global NewList border.borders()
  Global NewMap borderHandleCount() ; used to check how many copies of the handle there are, if handlecount = 1 then can free resources 
  Global NewMap img.imgs() ; used for image memory management, stores hash of HBITMAP or HICON
  Global NewMap imgp() ; used for image memory management, stores hash of file path to image
  Global NewMap trackWin.trackWindows(10000); used for keeping track of windows in ProGUI, e.g. PanelExPage autoscroll
  Global NewMap hotkeyTable.hotkeytables() ; used for tracking keyboard shortcuts/accelerators associated with each window
  
  ; mutexes
  Global trialMutex = CreateMutex() ; trial thread mutex
  Global trackWinMutex = CreateMutex() ; used to make sure there are no thread collisions in track window code
  Global txtcontrolLinksMutex = CreateMutex() ; used to make sure no thread collisions while updating txtcontol links
  Global menuMutex = CreateMutex() ; used to make sure no thread collisions when handling menuex lists
  Global toolbarMutex = CreateMutex() ; used to make sure no thread collisions when handling toolbarex lists
  Global panelMutex = CreateMutex() ; used to make sure no thread collisions when handling panelex/panelexpage lists
  Global hotkeyMutex = CreateMutex() ; used to make sure no thread collision when handling window accelerator
  Global animationMutex = CreateMutex() ; used to make sure no thread collisions when handling animation
  
  ; animation thread
  Global animationThreadID ; handle of the thread
  Global animationThreadHwnd ; hwnd of the thread
  
  ; set up UI colours
  Global UIColourMode ; used for storing current UI colour mode
  Global Dim UIWhidbeyColours.UIColours(#MaxUIComponents)
  Global Dim UIOffice2003Colours.UIColours(#MaxUIComponents)
  Global Dim UIOffice2007Colours.UIColours(#MaxUIComponents)
  Global Dim brushHandle.brushHandles(#MaxUIComponents)
  setDefaultUIColours()
  
  ; image codecs
  UsePNGImageDecoder()
  UseJPEGImageDecoder()
  
  ; packer compression
  ;UseBriefLZPacker()
  UseZipPacker()
  
  DataSection
    nullicon:
    IncludeBinary "null.ico"
    toolstripDropdownGlyph:
    IncludeBinary "toolstripDropdownGlyph.ico"
    dropdownGlyph:
    IncludeBinary "dropdownGlyph.ico"
    tickicon:
    IncludeBinary "tick.ico"
    bulleticon:
    IncludeBinary "bullet.ico"
    arrowicon:
    Data.b 135, 140, 46, 98, 2, 54, 78, 239, 82, 38, 57, 181, 56
  EndDataSection
  
  Global nullicon
  nullicon = ImageID(CatchImage(#PB_Any, ?nullicon))
  Global toolstripDropdownGlyph
  toolstripDropdownGlyph = ImageList_Create_(7, 17, #ILC_MASK | #ILC_COLOR32, 0, 0)
  error = ImageList_ReplaceIcon_(toolstripDropdownGlyph, -1, ImageID(CatchImage(#PB_Any, ?toolstripDropdownGlyph)))
  Global dropdownGlyph
  dropdownGlyph = ImageList_Create_(5, 3, #ILC_MASK | #ILC_COLOR32, 0, 0)
  error = ImageList_ReplaceIcon_(dropdownGlyph, -1, ImageID(CatchImage(#PB_Any, ?dropdownGlyph)))
  Global tickicon
  tickicon = ImageList_Create_(7, 7, #ILC_MASK | #ILC_COLOR32, 0, 0)
  error = ImageList_ReplaceIcon_(tickicon, -1, ImageID(CatchImage(#PB_Any, ?tickicon)))
  Global bulleticon
  bulleticon = ImageList_Create_(7, 7, #ILC_MASK | #ILC_COLOR32, 0, 0)
  error = ImageList_ReplaceIcon_(bulleticon, -1, ImageID(CatchImage(#PB_Any, ?bulleticon)))
  
  Global seed.l = 259173849
  
  ;- load mouse pointers
  Global normalMousePointer = LoadCursor_(0, #IDC_ARROW)
  Global verticalResizeMousePointer = LoadCursor_(0, #IDC_SIZENS)
  Global verticalDragMousePointer = LoadCursor_(0, #IDC_SIZENS)
  Global linkMousePointer = LoadCursor_(0, #IDC_HAND)
  Global dragMousePointer = LoadCursor_(0, #IDC_SIZEALL)
  Global hResizeMousePointer = LoadCursor_(0, #IDC_SIZEWE)
  
  Global rebarResizableMousepointer
  Global mousePointerHook
  Global rebarMouseMoveHook
  Global rebarVerticalResizeDrag
  rebarVerticalResizeDrag = -1
  Global lastRebarVertResizePos
  
  Global rebarGadgetInsert
  rebarGadgetInsert = -2  ; de-activate rebaraddgadget insert mode
  
  Global seed3.l = 478734210
  
  Global lastResizeRect.RECT
  Global resizeRECT.RECT
  Global resizing
  Global resizeMaximized
  Global LargestDesktopWidth  ; used for storing the largest desktop width on the system, for rebar UI Style formating
  
  currentMenuEx = -1
  currentMenuTitleEX = -1
  currentRebarGadget = -1
  currentToolbarEX = -1
  
  Global seed2.l = 924751372
  
  menuItemOver = -1
  menuOriginItem = -1
  menuHotItemNext = -1
  menuExItemIconWidth = 16
  menuExItemIconHeight = 16
  
  trialCounter = (200+800)*18
  
  ; set DefualtFont
  Global DefaultFont
  metrics.NONCLIENTMETRICS
  metrics\cbSize = SizeOf(NONCLIENTMETRICS)
  SystemParametersInfo_(#SPI_GETNONCLIENTMETRICS, SizeOf(NONCLIENTMETRICS), @metrics, 0)
  DefaultFont = CreateFontIndirect_(metrics\lfMenuFont)
  
  ; get system menu drop shadow status
  SystemParametersInfo_(#SPI_GETDROPSHADOW, 0, @systemDropShadowsEnabled, 0)
  
  ; display ProGUI version
  Global Version.f = #Version
  CompilerIf #DEBUGENABLED <> 0
    debuglog(#AppName+" Version: "+StrF(Version,2))
  CompilerEndIf
  
  ; get os version
  Global osVersion = OSVersion()
  CompilerIf #DEBUGENABLED <> 0
    debuglog("Operating System Version: "+Str(osVersion))
  CompilerEndIf
  
  ; get Comctl32.dll version
  Global Comctl32MajorVersion
  Global Comctl32MinorVersion
  Global Comctl32BuildNumber
  
  lib = OpenLibrary(#PB_Any,"Comctl32.dll")
  If lib <> 0
    dllinfo.DLLVERSIONINFO
    dllinfo\cbSize = SizeOf(DLLVERSIONINFO)
    CallFunction(lib,"DllGetVersion",@dllinfo)
    Comctl32MajorVersion = dllinfo\dwMajorVersion
    Comctl32MinorVersion = dllinfo\dwMinorVersion
    Comctl32BuildNumber = dllinfo\dwBuildNumber
    CompilerIf #DEBUGENABLED <> 0
      debuglog("Comctl32.dll Version: "+Str(Comctl32MajorVersion)+"."+Str(Comctl32MinorVersion)+"."+Str(Comctl32BuildNumber))
    CompilerEndIf
    CloseLibrary(lib)
  EndIf
  
  Gdi32 = OpenLibrary(#PB_Any, "Gdi32.dll") 
  If Gdi32
    Global GdiAlphaBlend_.GdiAlphaBlend_ = GetFunction(Gdi32, "GdiAlphaBlend")
    Debuglog("GdiAlphaBlend: "+Str(GdiAlphaBlend_))
    Global GdiGradientFill_.GdiGradientFill_ = GetFunction(Gdi32, "GdiGradientFill")
    Debuglog("GdiGradientFill: "+Str(GdiGradientFill_))
  Else 
    MessageRequester("Error!","Can't open Gdi32.dll",#MB_ICONERROR)
  EndIf
  
  InitXPtheme()
  InitDwmapi()
  
  
  CompilerIf #DISABLEPROTECTION = 0
    macro_loadHash()
    macro_verifyHash()
  CompilerEndIf
  
  
EndProcedure

Procedure KillProcess_ProGUI(pid)
  phandle = OpenProcess_ (#PROCESS_TERMINATE, #False, pid)
  If phandle <> #Null
    If TerminateProcess_ (phandle, 1)
      Result = #True
    EndIf
    CloseHandle_ (phandle)
  EndIf
  ProcedureReturn Result
EndProcedure 

; makes sure process terminates after period of time even if trial timeout window is disabled
Procedure monitorTrialTimeoutWindow(*dummy)
  
  Repeat
    RandomSeed(ElapsedMilliseconds())
    Delay(20000+Random(300000))  ; wait minimum of 20 secs plus random amount of seconds upto 5 minutes
    KillProcess_ProGUI(GetCurrentProcessId_())
    macro_verifyKeys()
    HaltProGUI = #True
  ForEver
  
EndProcedure

Global HaltProGUI
Procedure trialThread(*dummy)
  
  CompilerIf #DEBUGENABLED = -1
    debuglog("trial thread: started.")
  CompilerEndIf
  
  Repeat
    
    Delay(10)
    
    LockMutex(trialMutex)
    
    If trialCounter > 0
      trialCounter = trialCounter - 1
    Else
      If trialThreadStop = #False
        HaltProGUI = #True
        CreateThread(@monitorTrialTimeoutWindow(), 0)
        UnlockMutex(trialMutex)
        MessageRequester("ProGUI Trial timeout", "Your trial time has run out for this session!", #PB_MessageRequester_Ok)
        KillProcess_ProGUI(GetCurrentProcessId_())
        macro_verifyKeys()
        Repeat
          Delay(100)
        ForEver
      EndIf
    EndIf
    
    If trialThreadStop = #True
      UnlockMutex(trialMutex)
      Break
    EndIf
    UnlockMutex(trialMutex)
    
  ForEver
  
  CompilerIf #DEBUGENABLED = -1
    debuglog("trial thread: stopped.")
  CompilerEndIf
  
  LockMutex(trialMutex)
  trialThreadStopped = #True
  UnlockMutex(trialMutex)
  
  ProcedureReturn 1337
  
EndProcedure

;- StartProGUI
ProcedureDLL StartProGUI(user.s, k1.l, k2.l, k3.l, k4.l, k5.l, k6.l, k7.l)
  Static startProGUICalled
  
  If startProGUICalled = #False
    
    CompilerIf #DISABLEPROTECTION = 0
      CompilerIf #LIBRARY = 0
        macro_verifyHash()
        If *MD5mem <> 0
          FreeMemory(*MD5mem)
        EndIf
      CompilerEndIf
    CompilerEndIf
  
    If regk1 = 0
      reguser = user
      regk1 = k1
      regk2 = k2
      regk3 = k3
      regk4 = k4
      regk5 = k5
      regk6 = k6
      regk7 = k7
      
      CompilerIf #DISABLEPROTECTION = 0
        trialThreadID = ThreadID(CreateThread(@trialThread(), 0))
        Repeat
          GetExitCodeThread_(trialThreadID, @ExitCode)
          If ExitCode <> #STATUS_PENDING
            CompilerIf #DEBUGENABLED = -1
              debuglog("waiting for trial thread...")
            CompilerEndIf
            Delay(100)
          EndIf
        Until ExitCode = #STATUS_PENDING
        macro_verifyKeys()
      CompilerEndIf
    EndIf
    
    ; create hook to intercept creation of new windows for keeping track of windows
    ; i.e. handling windows dropped inside panelEx page with autoscroll turned on
    If WindowHook = 0
      CompilerIf #DEBUGENABLED = -1
        debuglog("creating window hook...")
      CompilerEndIf
      threadId = GetCurrentThreadId_()
      WindowHook = SetWindowsHookEx_(#WH_CALLWNDPROC, @CallWndProcHook(), 0, threadId)
      CompilerIf #DEBUGENABLED = -1
        debuglog("window hook created.")
      CompilerEndIf
    EndIf
    
    CompilerIf #DEBUGENABLED = -1
      debuglog("initialising GDI+...")
    CompilerEndIf
    InitGDIPlus()
    CompilerIf #DEBUGENABLED = -1
      debuglog("GDI+ initialised.")
    CompilerEndIf
    
    startProGUICalled = #True
    
    ; start animation thread
    CompilerIf #DEBUGENABLED = -1
      debuglog("creating animation thread...")
    CompilerEndIf
    animationThreadID = ThreadID(CreateThread(@animationThread(), 0))
    CompilerIf #DEBUGENABLED = -1
      debuglog("animation thread created.")
    CompilerEndIf
    
  EndIf
  
EndProcedure

; used for enumerating and closing down windows on detach process
Procedure EnumWindowsProc(hwnd, lParam)
  
  GetWindowThreadProcessId_(hwnd, @processID)
  If processID = lParam
    DestroyWindow_(hwnd)
  EndIf
  ;debuglog("destroy")
  
  ProcedureReturn #True
EndProcedure

; used for enumerating and hiding windows on detach process
Procedure EnumHideWindowsProc(hwnd, lParam)
  
  GetWindowThreadProcessId_(hwnd, @processID)
  If processID = lParam
    ShowWindow_(hwnd, #SW_HIDE)
  EndIf
  
  ProcedureReturn #True
EndProcedure

ProcedureDLL ProGUI_End()
  
  ; get rid of animation thread
  If animationThreadID <> 0
    For n = 0 To 100
      LockMutex(animationMutex)
      If animationThreadHwnd <> 0
        PostMessage_(animationThreadHwnd, #WM_CLOSE, 0, 0)
      EndIf
      If animationThreadHwnd = 0
        TerminateThread_(animationThreadID, 1337)
        animationThreadHwnd + 1
      EndIf
      UnlockMutex(animationMutex)
      GetExitCodeThread_(animationThreadID, @ExitCode)
      If ExitCode = 1337 Or ExitCode <> #STATUS_PENDING
        CompilerIf #DEBUGENABLED = -1
          debuglog("animation thread terminated.")
        CompilerEndIf
        Break
      EndIf
      CompilerIf #DEBUGENABLED = -1
        debuglog("waiting for animation thread..."+Str(n))
      CompilerEndIf
      Delay(10)
    Next
    CompilerIf #DEBUGENABLED = -1
      debuglog("continue free up...")
    CompilerEndIf
  EndIf
  
  ; get rid of trialthread
  If trialThreadID <> 0
    LockMutex(trialMutex)
    trialThreadStop = #True
    trialCounter = 0
    UnlockMutex(trialMutex)
    For n = 0 To 100
      LockMutex(trialMutex)
      If trialThreadStopped = #True
        TerminateThread_(trialThreadID, 1337)
        trialThreadStopped + 1
      EndIf
      UnlockMutex(trialMutex)
      GetExitCodeThread_(trialThreadID, @ExitCode)
      If ExitCode = 1337 Or ExitCode <> #STATUS_PENDING
        CompilerIf #DEBUGENABLED = -1
          debuglog("trial thread terminated.")
        CompilerEndIf
        Break
      EndIf
      CompilerIf #DEBUGENABLED = -1
        debuglog("waiting for trial thread..."+Str(n))
      CompilerEndIf
      Delay(10)
    Next
  EndIf
  
  ; hide client windows left open before the dll is detached
  CompilerIf #DEBUGENABLED = 0
    EnumWindows_(@EnumHideWindowsProc(), GetCurrentProcessId_())
  CompilerEndIf
  
  FreeRebar(-1)
  debuglog("freed rebars")
  FreeToolBarEx(-1)
  debuglog("freed toolbars")
  FreeButtonEx(-1)
  debuglog("freed buttons")
  FreeMenuEx(-1)
  debuglog("freed menus")
  FreeTextControlEx(-1)
  debuglog("freed textcontrols")
  FreeSplitterEx(-1)
  debuglog("freed splitterexs")
  FreePanelEx(-1)
  debuglog("freed panels")
  
  If WindowHook <> 0
    UnhookWindowsHookEx_(WindowHook)
  EndIf
  
  If KeyboardHook <> 0
    UnhookWindowsHookEx_(KeyboardHook)
  EndIf
  
  If HotKeyHook <> 0
    UnhookWindowsHookEx_(HotKeyHook)
  EndIf
  
  ForEach menuCallback()
    If menuCallback()\oldCallback <> 0
      If IsWindow_(menuCallback()\WindowID)
        SetWindowLongPtr_(menuCallback()\WindowID, #GWLP_WNDPROC, menuCallback()\oldCallback)
      EndIf
    EndIf
  Next
  
  ForEach trackWin()
    If IsWindow_(trackWin()\hwnd)
      SetWindowLongPtr_(Val(MapKey(trackWin())), #GWLP_WNDPROC, trackWin()\callbackProc)
    EndIf
  Next
  
  ; make sure there are no client windows left open before the dll is detached
  EnumWindows_(@EnumWindowsProc(), GetCurrentProcessId_())
  
  ExitXPtheme()
  ExitGDIPlus()
  ExitDwmapi()
  
  CompilerIf #DEBUGENABLED <> 0
    debuglog("bye")
    ;Delay(5000)
  CompilerEndIf
  
EndProcedure

CompilerIf #LIBRARY = 0
  ProcedureDLL AttachProcess(Instance)
  
    ProGUI_Instance = Instance
    ProGUI_Init()
  
  EndProcedure
CompilerEndIf

;- DetachProcess
CompilerIf #LIBRARY = 0
  ProcedureDLL DetachProcess(Instance)
    ProGUI_End()

EndProcedure

ProcedureDLL AttachThread(Instance)
EndProcedure

ProcedureDLL DetachThread(Instance)
EndProcedure
CompilerEndIf
;-

;- init panelex themes/borders/masks
Procedure initPanelexThemes()
  Static createdPanelExThemes
  
  If createdPanelExThemes = #False And ThemesEnabled = #True
    
    ;/ initialize panelex default theme background border masks
    themeButtonBorderImage = CreateImage(#PB_Any, 100, 100, 32)
    ; system button normal state border background mask
    hdc = StartDrawing(ImageOutput(themeButtonBorderImage))
    DrawingMode(#PB_2DDrawing_AllChannels)
    Box(0, 0, 100, 100, RGBA(255, 255, 255, 0))
    rc.RECT
    rc\right = 100
    rc\bottom = 100
    If ThemesEnabled = #True
      CallFunctionFast(*DrawThemeBackground, hThemeButton, hdc, 1, 0, @rc, 0)
    EndIf
    StopDrawing()
    Global themeButtonBorder = createBorder()
    setBorder(themeButtonBorder, ImageID(themeButtonBorderImage), -2, 0, 0)
    FreeImage(themeButtonBorderImage)
    
    ; system button hot state border background mask
    themeButtonBorderHotImage = CreateImage(#PB_Any, 100, 100, 32)
    hdc = StartDrawing(ImageOutput(themeButtonBorderHotImage))
    DrawingMode(#PB_2DDrawing_AllChannels)
    Box(0, 0, 100, 100, RGBA(255, 255, 255, 0))
    rc.RECT
    rc\right = 100
    rc\bottom = 100
    If ThemesEnabled = #True
      CallFunctionFast(*DrawThemeBackground, hThemeButton, hdc, 1, 2, @rc, 0)
    EndIf
    StopDrawing()
    Global themeButtonHotBorder = createBorder()
    setBorder(themeButtonHotBorder, ImageID(themeButtonBorderHotImage), -2, 0, 0)
    FreeImage(themeButtonBorderHotImage)
    
    ; system button pressed state border background mask
    themeButtonBorderPressedImage = CreateImage(#PB_Any, 100, 100, 32)
    hdc = StartDrawing(ImageOutput(themeButtonBorderPressedImage))
    DrawingMode(#PB_2DDrawing_AllChannels)
    Box(0, 0, 100, 100, RGBA(255, 255, 255, 0))
    rc.RECT
    rc\right = 100
    rc\bottom = 100
    If ThemesEnabled = #True
      CallFunctionFast(*DrawThemeBackground, hThemeButton, hdc, 1, 3, @rc, 0)
    EndIf
    StopDrawing()
    Global themeButtonPressedBorder = createBorder()
    setBorder(themeButtonPressedBorder, ImageID(themeButtonBorderPressedImage), -2, 0, 0)
    FreeImage(themeButtonBorderPressedImage)
    
    ; system button disabled state border background mask
    themeButtonBorderDisabledImage = CreateImage(#PB_Any, 100, 100, 32)
    hdc = StartDrawing(ImageOutput(themeButtonBorderDisabledImage))
    DrawingMode(#PB_2DDrawing_AllChannels)
    Box(0, 0, 100, 100, RGBA(255, 255, 255, 0))
    rc.RECT
    rc\right = 100
    rc\bottom = 100
    If ThemesEnabled = #True
      CallFunctionFast(*DrawThemeBackground, hThemeButton, hdc, 1, 1, @rc, 0)
    EndIf
    StopDrawing()
    Global themeButtonDisabledBorder = createBorder()
    setBorder(themeButtonDisabledBorder, ImageID(themeButtonBorderDisabledImage), -2, 0, 0)
    FreeImage(themeButtonBorderDisabledImage)
    
    ; system tab theme border background mask
    themeTabBorderImage = CreateImage(#PB_Any, 100, 100, 32)
    hdc = StartDrawing(ImageOutput(themeTabBorderImage))
    DrawingMode(#PB_2DDrawing_AllChannels)
    Box(0, 0, 100, 100, RGBA(255, 255, 255, 0))
    rc.RECT
    rc\right = 100
    rc\bottom = 100
    If ThemesEnabled = #True
      CallFunctionFast(*DrawThemeBackground, hThemeTab, hdc, 9, 0, @rc, 0)
    EndIf
    StopDrawing()
    Global themeTabBorder = createBorder()
    rc\left = 1
    rc\top = 1
    rc\right - 3
    rc\bottom - 2
    setBorder(themeTabBorder, ImageID(themeTabBorderImage), 0, rc, 0)
    FreeImage(themeTabBorderImage)
    
    createdPanelExThemes = #True
  EndIf
  
EndProcedure

; converts all white pixels to be transparent alpha and full alpha otherwise
Procedure filterWhiteToAlpha(x, y, s, t)
  r = Red(s)
  g = Green(s)
  b = Blue(s)
  If r = 255 And g = 255 And b = 255
    alpha = 0
  Else
    alpha = 255
  EndIf
  ProcedureReturn RGBA(r, g, b, alpha)
EndProcedure
Macro addAlphaToXpTheme(image)
  ; hack to add an alpha channel on XP theme
  If ThemesEnabled And OSVersion <= #PB_OS_Windows_XP
    timage = CreateImage(#PB_Any, w, h, 32)
    StartDrawing(ImageOutput(timage))
    DrawingMode(#PB_2DDrawing_CustomFilter)
    CustomFilterCallback(@filterWhiteToAlpha())
    DrawImage(ImageID(image), 0, 0)
    StopDrawing()
    FreeImage(image)
    image = timage
  EndIf
EndMacro

;--===================
;- init/create default skins
;--===================
Procedure initDefaultSkin(name.s)
  Static loadedBinaries
  
  If loadedBinaries = #False
    
    DataSection
    
      ; explorer bar office 2007 blue skin images
      xbar_office2007_blue_border:
      IncludeBinary "ExplorerBar_Office2007_blue_border.png"
      xbar_office2007_blue_hborder:
      IncludeBinary "ExplorerBar_Office2007_blue_hborder.png"
      xbar_office2007_blue_glyph_down:
      IncludeBinary "ExplorerBar_Office2007_blue_glyph_down.png"
      xbar_office2007_blue_glyph_up:
      IncludeBinary "ExplorerBar_Office2007_blue_glyph_up.png"
      ; explorer bar office 2007 silver skin images
      xbar_office2007_silver_border:
      IncludeBinary "ExplorerBar_Office2007_silver_border.png"
      xbar_office2007_silver_hborder:
      IncludeBinary "ExplorerBar_Office2007_silver_hborder.png"
      xbar_office2007_silver_glyph_down:
      IncludeBinary "ExplorerBar_Office2007_silver_glyph_down.png"
      xbar_office2007_silver_glyph_up:
      IncludeBinary "ExplorerBar_Office2007_silver_glyph_up.png"
      ; explorer bar office 2007 black skin images
      xbar_office2007_black_border:
      IncludeBinary "ExplorerBar_Office2007_black_border.png"
      xbar_office2007_black_hborder:
      IncludeBinary "ExplorerBar_Office2007_black_hborder.png"
      xbar_office2007_black_glyph_down:
      IncludeBinary "ExplorerBar_Office2007_black_glyph_down.png"
      xbar_office2007_black_glyph_up:
      IncludeBinary "ExplorerBar_Office2007_black_glyph_up.png"
      
    EndDataSection
    
    ; explorer bar office 2007 blue skin images
    Global xbar_office2007_blue_border = CatchImage(#PB_Any, ?xbar_office2007_blue_border)
    Global xbar_office2007_blue_hborder = CatchImage(#PB_Any, ?xbar_office2007_blue_hborder)
    Global xbar_office2007_blue_glyph_down = CatchImage(#PB_Any, ?xbar_office2007_blue_glyph_down)
    Global xbar_office2007_blue_glyph_up = CatchImage(#PB_Any, ?xbar_office2007_blue_glyph_up)
    ; explorer bar office 2007 silver skin images
    Global xbar_office2007_silver_border = CatchImage(#PB_Any, ?xbar_office2007_silver_border)
    Global xbar_office2007_silver_hborder = CatchImage(#PB_Any, ?xbar_office2007_silver_hborder)
    Global xbar_office2007_silver_glyph_down = CatchImage(#PB_Any, ?xbar_office2007_silver_glyph_down)
    Global xbar_office2007_silver_glyph_up = CatchImage(#PB_Any, ?xbar_office2007_silver_glyph_up)
    ; explorer bar office 2007 black skin images
    Global xbar_office2007_black_border = CatchImage(#PB_Any, ?xbar_office2007_black_border)
    Global xbar_office2007_black_hborder = CatchImage(#PB_Any, ?xbar_office2007_black_hborder)
    Global xbar_office2007_black_glyph_down = CatchImage(#PB_Any, ?xbar_office2007_black_glyph_down)
    Global xbar_office2007_black_glyph_up = CatchImage(#PB_Any, ?xbar_office2007_black_glyph_up)
    
    loadedBinaries = #True
    
  EndIf
  
  name = LCase(name)
  
  If GetSkinHandle(name) = 0
    
    SkinAutoUpdateRepress = #True
    
    Select name
        
      ;- **** image button
      Case "imagebuttonskin"  
        
        ; create image button skin
        Global imageButtonSkin = CreateSkin("imageButtonSkin")
        ; normal
        SetSkinProperty(imageButtonSkin, "imagebuttonex", "normal", "background", "-1;")
        SetSkinProperty(imageButtonSkin, "imagebuttonex", "normal", "image position", "x: 50%; y: 50%;")
        ; hot
        SetSkinProperty(imageButtonSkin, "imagebuttonex", "hot", "background", "-1;")
        SetSkinProperty(imageButtonSkin, "imagebuttonex", "hot", "image position", "x: 50%; y: 50%;")
        ; pressed
        SetSkinProperty(imageButtonSkin, "imagebuttonex", "pressed", "background", "-1;")
        SetSkinProperty(imageButtonSkin, "imagebuttonex", "pressed", "image position", "x: 50%; y: 50%;")
        ; disabled
        SetSkinProperty(imageButtonSkin, "imagebuttonex", "disabled", "background", "-1;")
        SetSkinProperty(imageButtonSkin, "imagebuttonex", "disabled", "image position", "x: 50%; y: 50%;")
        
      ;- **** button
      Case "sysbuttonskin"
        
        ; create system button skin
        Global sysButtonSkin = CreateSkin("sysButtonSkin")
        ; normal
        SetSkinProperty(sysButtonSkin, "buttonex", "normal", "background", "8;")
        SetSkinProperty(sysButtonSkin, "buttonex", "normal", "image position", "x: 50%; y: 50%;")
        SetSkinProperty(sysButtonSkin, "buttonex", "normal", "image padding", "top: 2; left: 6; bottom: 2; right: 4;")
        SetSkinProperty(sysButtonSkin, "buttonex", "normal", "text position", "x: 50%; y: 50%;")
        SetSkinProperty(sysButtonSkin, "buttonex", "normal", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; hot
        SetSkinProperty(sysButtonSkin, "buttonex", "hot", "background", "9;")
        SetSkinProperty(sysButtonSkin, "buttonex", "hot", "image position", "x: 50%; y: 50%;")
        SetSkinProperty(sysButtonSkin, "buttonex", "hot", "image padding", "top: 2; left: 6; bottom: 2; right: 4;")
        SetSkinProperty(sysButtonSkin, "buttonex", "hot", "text position", "x: 50%; y: 50%;")
        SetSkinProperty(sysButtonSkin, "buttonex", "hot", "text padding", "top: 2; left: 2; bottom: 2; right: 6;")
        ; pressed
        SetSkinProperty(sysButtonSkin, "buttonex", "pressed", "background", "10;")
