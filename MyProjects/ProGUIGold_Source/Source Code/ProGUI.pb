  ;/ Whidbey style colours
  ; silver
  UIWhidbeyColours(#menuTitleTextColor)\Silver = RGB(0,0,0)
  UIWhidbeyColours(#menuTitleHotTextColor)\Silver = RGB(0,0,0)
  UIWhidbeyColours(#menuTitleHeldTextColor)\Silver = RGB(0,0,0)
  UIWhidbeyColours(#menuTitleInactiveTextColor)\Silver = RGB(172,168,153)
  UIWhidbeyColours(#menuTextColor)\Silver = RGB(0,0,0)
  UIWhidbeyColours(#disabledColor)\Silver = RGB(197,195,184)
  UIWhidbeyColours(#menuHotColor)\Silver = RGB(232,232,236) ; 0
  UIWhidbeyColours(#menuHotBorder)\Silver = RGB(178,180,191) ; 1
  UIWhidbeyColours(#menuBarColor)\Silver = RGB(229,228,231) ; 2
  UIWhidbeyColours(#menuHeldBorder)\Silver = RGB(113,111,100) ; 3
  UIWhidbeyColours(#separatorBar)\Silver = RGB(189,186,196) ; 4
  UIWhidbeyColours(#background)\Silver = RGB(251,251,251)
  UIWhidbeyColours(#menuCheckboxBackground)\Silver = RGB(235,234,237)
  UIWhidbeyColours(#menuCheckboxSelectedBackground)\Silver = RGB(212,212,218)
  UIWhidbeyColours(#menuCheckboxDisabledBackground)\Silver = RGB(241,241,242)
  UIWhidbeyColours(#menuCheckboxDisabledBorder)\Silver = RGB(157,157,161)
  UIWhidbeyColours(#menuCheckboxBorder)\Silver = UIWhidbeyColours(#menuHotBorder)\Silver
  UIWhidbeyColours(#menuCheckboxSelectedBorder)\Silver = RGB(153,155,164)
  UIWhidbeyColours(#menuDropShadow)\Silver = MakeColor(50,0,0,0)
  UIWhidbeyColours(#menuHeldColor)\Silver = UIWhidbeyColours(#menuBarColor)\Silver
  UIWhidbeyColours(#selectedColor)\Silver = UIWhidbeyColours(#menuHotColor)\Silver
  UIWhidbeyColours(#selectedBorder)\Silver = UIWhidbeyColours(#menuHotBorder)\Silver
  UIWhidbeyColours(#selectedTextColor)\Silver = RGB(0,0,0)
