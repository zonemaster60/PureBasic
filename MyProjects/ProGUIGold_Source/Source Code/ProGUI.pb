;- Border/Mask Structures
Structure BorderPart
  dat.i ; *img or *rgn
  datPremultiplied.i ; used with autostretch for keeping premultiplied copy of image GDI alphablit
  width.l
  height.l
EndStructure
Structure BorderImage
  
  crc32.i ; used to check whether this image has changed and redraw parts if so
  rc.RECT
  
  ; border image parts
  topLeft.BorderPart
  topRight.BorderPart
  bottomLeft.BorderPart
  bottomRight.BorderPart
  top.BorderPart
  left.BorderPart
  right.BorderPart
  bottom.BorderPart
  
EndStructure
Structure BorderMasks
  
  crc32.i ; used to check whether this image has changed and redraw parts if so
  rc.RECT
  maskrgn.i
  maskwidth.i
  maskheight.i
  
  ; border mask parts
  topLeft.BorderPart
  topRight.BorderPart
  bottomLeft.BorderPart
  bottomRight.BorderPart
  top.BorderPart
  left.BorderPart
  right.BorderPart
  bottom.BorderPart
  
EndStructure
Structure Borders
  
  thisimage.s
  thismask.s
  Map image.BorderImage()
  Map mask.BorderMasks()
  *srcHandle ; used if this is a copy
  
  autoStretchSides.RECT ; if side of rect not equal zero then auto stretch that image part instead of repeating
  
EndStructure

; used for auto border and auto mask (image processing)
Structure side
  c.i   ; current pixel colour brightness
  lc.i  ; last lowest pixel colour brightness
  a.i   ; current pixel alpha
  la.i  ; last pixel alpha (highest/lowest)
  x.i   ; current pixel x pos
  y.i   ; current pixel y pos
  lx.i  ; last pixel x pos
  ly.i  ; last pixel y pos
EndStructure

;- Skin Structures
Enumeration 1
  #SKIN_RES_ICON ; private
  #SKIN_RES_IMAGE ; private
  #SKIN_RES_DATA ; private
EndEnumeration

#SKIN_SAVE_PACKAGE = $1

Structure skinProperties
  name.s
  value.s
  resType.i
  resData.i
  resDataSize.i
EndStructure

Structure skinStates
  name.s
  List property.skinProperties()
EndStructure

Structure skinComponents
  name.s
  List state.skinStates()
EndStructure

Structure skins
  name.s
  author.s
  date.s
  version.s
  url.s
  List component.skinComponents()
  autoUpdate.b ; if set to true, SetSkinProperty will automatically update all controls currently using this skin
EndStructure

; directory where skins/resources will be automatically looked for
Global SkinPath.s
; stores the current directory path, used to restore after any Skin file routines used
Global SkinLastCurrentDir.s
; stores the user set global skin colour theme name
Global GlobalSkinColourTheme.s
; stores the default system detected colour theme name
Global DefaultGlobalSkinColourTheme.s

; makes sure init of default skins and skin loading doesn't update every call to SetSkinProperty
Global SkinAutoUpdateRepress = #False

; WM_Message that tells the control to update its skin
; lparam contains handle of the skin
#WM_UPDATESKIN = 40099 ; #WM_APP+7331


;- MenuEx Structures
Structure menuexs
  id.l
  WindowID.i
  toolbarID.i
  popupid.i
  purepopupid.i
  buttonID.l
  singleMenu.b  ; does this menu have multiple button titles, 0 = yes, -1 = no
  dropdownMenuex.i
  greyed.b ; is this menu item greyed due to loosing window focus, -1 = yes, 0 = no
  active.b ; is the menu currently active i.e popup displayed, -1 yep, 0 nope
  style.l ; style the menu is drawn in
  measuredWidth.l ; stores the calculated width of the popupmenu
  measuredHeight.l;
  root.b  ; flags whether this is currently a root menu
  
  ; cached window contents
  hdc.i
  Buffer.i
  bufferWidth.l
  bufferHeight.l
EndStructure


Structure itemexs
  menuex.i
  popupid.i
  text.s
  pos.l
  normal.b    ;}
  hot.b       ; > flags for stating whether images used
  disabled.b  ;}
  defDisabledStyle.l ; stores disabled icon visual style, used for flaging redraw of icon when changed
  ImageList.i
  imageHeight.l
  imageWidth.l
  checkIcon.b   ; flags whether to use the items associated images when in checkbox/radiocheck state
  radiocheck.b  ; used for identifying item as belonging to a radiocheck group
  groupNo.l     ; used for storing the radiocheck group that this item belongs to
  scroll.l      ; used for flaging whether this item is a special scroll button
EndStructure


Structure popupUserDatas  ; used in subclassing popupmenus
  menuExPtr.i
  originalStyle.l   ; used for storing a copy of the menuex()\style to be restored on destroy
  lastWindowXpos.l
  submenu.i
  parentPopupUserData.i
  WindowID.i
  WindowPosChangingTimes.l  ; used for keeping track of the number of times a menu has received WM_WINDOWPOSCHANGING msg
  
  bottomShadowHandle.i  ; used for re-drawing bottom shadows of submenu/s and parent when same bottom ypos/height
  bottomShadowHidden.i  ; stores a handle to the parents hidden shadow
  bottomShadowFlags.i   ;
  bottomShadowX.l       ;
  bottomShadowY.l       ;
  bottomShadowWidth.l   ;
  bottomShadowTmp.i     ;
  leftBottomShadowX.l
  leftBottomShadowY.l
  leftBottomShadowWidth.l
  leftBottomShadowHandle.i
  
  lastMenuYPos.l        ; used for storing parent item's y pos for skipping separator bars
EndStructure


Structure menuScrollHotKeys
  hotkey.s
  id.l
EndStructure

;- Keyboard HotKey Structures
Global HotKeyHook
Structure hotkeys
  key.i
  fvirt.i
  cmd.w
EndStructure
Structure hotkeytables
  List k.hotkeys()
EndStructure

;- ToolBarEx Structures
Structure toolbarExButtons
  
  id.l
  toolbarID.i
  toolbarExHandle.i ; handle to the button's ToolBarEx hwnd
  toolbarEx.i ; pointer to the button's toolbarEx structure
  normalImage.i
  hotImage.i
  disabledImage.i
  defDisabledImage.b ; flagged if no custom disabled image specified and default disabled image should be rendered
  defDisabledStyle.l ; stores disabled icon visual style, used for flaging redraw of icon when changed
  text.s ; stores text for button with escapecode formating intact
  separator.l ; used to flag whether this button is a separator
  gadget.i  ; used to flag (if nonezero) whether this button contains a gadget, if so contains handle to gadget hwnd
  gadgetStyled.b ; used to flag whether the gadget should be styled with the toolbarEx's UIStyle
  gadgetStyledState.l ; used to flag certain drawing states for styled gadgets
  gadgetPad.RECT  ; stores the padding around a gadget
  
EndStructure

; toolbarExButton gadget styled state flag constants
#TOOLBAREXGADGET_HOVER = $1 ; private
#TOOLBAREXGADGET_DROPDOWN = $2 ; private
#TOOLBAREXGADGET_FOCUS = $4 ; private
  
Structure toolbarExs
  
  id.l
  Handle.i
  WindowID.i
  style.l
  normalImageList.i
  hotImageList.i
