        ; selected hot
        SetSkinProperty(sysToggleButtonSkin, "togglebuttonex", "selected hot", "background", "9;")
        SetSkinProperty(sysToggleButtonSkin, "togglebuttonex", "selected hot", "image position", "x: 50%; y: 50%;")
