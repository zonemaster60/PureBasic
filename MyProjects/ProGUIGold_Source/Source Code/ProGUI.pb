      ;- **** splitter sys 1
      Case "syssplitterskin"
        
        ; create system splitter skin
        Global sysSplitterSkin = CreateSkin("sysSplitterSkin")
        ; horizontal
        ; normal
        SetSkinProperty(sysSplitterSkin, "splitterex", "normal", "gripper size", "width: 5;")
        SetSkinProperty(sysSplitterSkin, "splitterex", "normal", "gripper background", "-1;")
        SetSkinProperty(sysSplitterSkin, "splitterex", "normal", "background", "-1;")
        ; hot
        SetSkinProperty(sysSplitterSkin, "splitterex", "hot", "gripper background", "-1;")
        ; pressed
        SetSkinProperty(sysSplitterSkin, "splitterex", "pressed", "gripper background", "-1;")
        
        ; vertical
        ; normal
        SetSkinProperty(sysSplitterSkin, "splitterex", "normal vertical", "gripper size", "height: 5;")
        SetSkinProperty(sysSplitterSkin, "splitterex", "normal vertical", "gripper background", "-1;")
        SetSkinProperty(sysSplitterSkin, "splitterex", "normal vertical", "background", "-1;")
        ; hot
        SetSkinProperty(sysSplitterSkin, "splitterex", "hot vertical", "gripper background", "-1;")
        ; pressed
        SetSkinProperty(sysSplitterSkin, "splitterex", "pressed vertical", "gripper background", "-1;")
        
      ;- **** splitter sys 2
      Case "syssplitter2skin"
        
        ;/ initialize splitterex default theme images
        width = 98
        height = 98
        x = 1
        y = 1
        Global themeSplitterBorderImage1 = CreateImage(#PB_Any, 100, 100, 32)
        ; system button normal state border background mask
        hdc = StartDrawing(ImageOutput(themeSplitterBorderImage1))
        DrawingMode(#PB_2DDrawing_AllChannels)
        
        Box(0, 0, 100, 100, RGBA(255, 255, 255, 0))
        
        col = GetSysColor_(#COLOR_BTNHIGHLIGHT)
        col = RGBA(Red(col), Green(col), Blue(col), 255)
        Box(x, y, width-1, 1, col)
        Box(x, y+1, 1, height-2, col)
        col = GetSysColor_(#COLOR_3DDKSHADOW)
        col = RGBA(Red(col), Green(col), Blue(col), 255)
        Box(x, height, width, 1, col)
        Box(width, y, 1, height-1, col)
        col = GetSysColor_(#COLOR_BTNSHADOW)
        
        StopDrawing()
        
        ; create system splitter skin 2
        Global sysSplitter2Skin = CreateSkin("sysSplitter2Skin")
        ; horizontal
        ; normal
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal", "gripper size", "width: 5;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal", "first padding", "right: 1;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal", "second padding", "left: 1;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal", "background", "-1;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal", "gripper background", "COLOR_BTNFACE;")
        SetSkinPropertyData(sysSplitter2Skin, "splitterex", "normal", "gripper border image", ImageID(themeSplitterBorderImage1))
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal", "gripper border mask", "-1;")
        ; hot
        SetSkinProperty(sysSplitter2Skin, "splitterex", "hot", "background", "-1;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "hot", "gripper background", "COLOR_BTNFACE;")
        SetSkinPropertyData(sysSplitter2Skin, "splitterex", "hot", "gripper border image", ImageID(themeSplitterBorderImage1))
        SetSkinProperty(sysSplitter2Skin, "splitterex", "hot", "gripper border mask", "-1;")
        ; pressed
        SetSkinProperty(sysSplitter2Skin, "splitterex", "pressed", "background", "-1;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "pressed", "gripper background", "COLOR_BTNFACE;")
        SetSkinPropertyData(sysSplitter2Skin, "splitterex", "pressed", "gripper border image", ImageID(themeSplitterBorderImage1))
        SetSkinProperty(sysSplitter2Skin, "splitterex", "pressed", "gripper border mask", "-1;")
        
        ; vertical
        ; normal
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal vertical", "gripper size", "height: 5;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal vertical", "first padding", "bottom: 1;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal vertical", "second padding", "top: 1;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal vertical", "background", "-1;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal vertical", "gripper background", "COLOR_BTNFACE;")
        SetSkinPropertyData(sysSplitter2Skin, "splitterex", "normal vertical", "gripper border image", ImageID(themeSplitterBorderImage1))
        SetSkinProperty(sysSplitter2Skin, "splitterex", "normal vertical", "gripper border mask", "-1;")
        ; hot
        SetSkinProperty(sysSplitter2Skin, "splitterex", "hot vertical", "background", "-1;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "hot vertical", "gripper background", "COLOR_BTNFACE;")
        SetSkinPropertyData(sysSplitter2Skin, "splitterex", "hot vertical", "gripper border image", ImageID(themeSplitterBorderImage1))
        SetSkinProperty(sysSplitter2Skin, "splitterex", "hot vertical", "gripper border mask", "-1;")
        ; pressed
        SetSkinProperty(sysSplitter2Skin, "splitterex", "pressed vertical", "background", "-1;")
        SetSkinProperty(sysSplitter2Skin, "splitterex", "pressed vertical", "gripper background", "COLOR_BTNFACE;")
        SetSkinPropertyData(sysSplitter2Skin, "splitterex", "pressed vertical", "gripper border image", ImageID(themeSplitterBorderImage1))
        SetSkinProperty(sysSplitter2Skin, "splitterex", "pressed vertical", "gripper border mask", "-1;")
        
      ;- **** splitter office2007
      Case "office2007splitterskin"
        
        Global BlueSplitterOffice2007BorderImage = CreateImage(#PB_Any, 100, 100, 32)
        ; render blue office2007 style splitterex gripper image border
        StartDrawing(ImageOutput(BlueSplitterOffice2007BorderImage))
          DrawingMode(#PB_2DDrawing_AllChannels)
          Box(0, 0, 100, 100, RGBA(101, 147, 207, 255))
          Box(1, 1, 98, 1, RGBA(255,255,255,255))
          Box(1, 2, 98, 97, RGBA(0, 0, 0, 0))
        StopDrawing()
        
        Global BlueVerticalSplitterOffice2007GripperImage = CreateImage(#PB_Any, 19, 3, 32)
        ; render blue office2007 style vertical splitterex gripper image
        StartDrawing(ImageOutput(BlueVerticalSplitterOffice2007GripperImage))
          DrawingMode(#PB_2DDrawing_AllChannels)
          Box(0, 0, 19, 3, RGBA(0, 0, 0, 0))
          x = 0 : y = 0
          For n = 0 To 4
            Box(x, y, 2, 2, RGBA(101, 147, 207, 255))
            Box(x+1, y+1, 2, 2, RGBA(249, 249, 251, 255))
            Box(x+1, y+1, 1, 1, RGBA(173, 209, 255, 255))
            x = x + 4
          Next
        StopDrawing()
          
        Global BlueSplitterOffice2007GripperImage = CreateImage(#PB_Any, 3, 19, 32)
        ; render blue office2007 style vertical splitterex gripper image
        StartDrawing(ImageOutput(BlueSplitterOffice2007GripperImage))
          DrawingMode(#PB_2DDrawing_AllChannels)
          Box(0, 0, 3, 19, RGBA(0, 0, 0, 0))
          x = 0 : y = 0
          For n = 0 To 4
            Box(x, y, 2, 2, RGBA(101, 147, 207, 255))
            Box(x+1, y+1, 2, 2, RGBA(249, 249, 251, 255))
            Box(x+1, y+1, 1, 1, RGBA(173, 209, 255, 255))
            y = y + 4
          Next
        StopDrawing()  
          
        Global BlackSplitterOffice2007BorderImage = CreateImage(#PB_Any, 100, 100, 32)
        ; render black office2007 style splitterex gripper image border
        StartDrawing(ImageOutput(BlackSplitterOffice2007BorderImage))
          DrawingMode(#PB_2DDrawing_AllChannels)
          Box(0, 0, 100, 100, RGBA(76, 83, 92, 255))
          Box(1, 1, 98, 1, RGBA(255,255,255,255))
          Box(1, 2, 98, 97, RGBA(0, 0, 0, 0))
        StopDrawing()
        
        Global BlackVerticalSplitterOffice2007GripperImage = CreateImage(#PB_Any, 19, 3, 32)
        ; render black office2007 style vertical splitterex gripper image
        StartDrawing(ImageOutput(BlackVerticalSplitterOffice2007GripperImage))
          DrawingMode(#PB_2DDrawing_AllChannels)
          Box(0, 0, 19, 3, RGBA(0, 0, 0, 0))
          x = 0 : y = 0
          For n = 0 To 4
            Box(x, y, 2, 2, RGBA(124, 124, 124, 255))
            Box(x+1, y+1, 2, 2, RGBA(249, 249, 251, 255))
            Box(x+1, y+1, 1, 1, RGBA(204, 204, 204, 255))
            x = x + 4
          Next
        StopDrawing()  
        
        Global BlackSplitterOffice2007GripperImage = CreateImage(#PB_Any, 3, 19, 32)
        ; render black office2007 style vertical splitterex gripper image
        StartDrawing(ImageOutput(BlackSplitterOffice2007GripperImage))
          DrawingMode(#PB_2DDrawing_AllChannels)
          Box(0, 0, 3, 19, RGBA(0, 0, 0, 0))
          x = 0 : y = 0
          For n = 0 To 4
            Box(x, y, 2, 2, RGBA(124, 124, 124, 255))
            Box(x+1, y+1, 2, 2, RGBA(249, 249, 251, 255))
            Box(x+1, y+1, 1, 1, RGBA(204, 204, 204, 255))
            y = y + 4
          Next
        StopDrawing()  
      
        Global SilverSplitterOffice2007BorderImage = CreateImage(#PB_Any, 100, 100, 32)
        ; render black office2007 style splitterex gripper image border
        StartDrawing(ImageOutput(SilverSplitterOffice2007BorderImage))
          DrawingMode(#PB_2DDrawing_AllChannels)
          Box(0, 0, 100, 100, RGBA(111, 112, 116, 255))
          Box(1, 1, 98, 1, RGBA(255,255,255,255))
          Box(1, 2, 98, 97, RGBA(0, 0, 0, 0))
        StopDrawing()
          
        Global SilverVerticalSplitterOffice2007GripperImage = CreateImage(#PB_Any, 19, 3, 32)
        ; render black office2007 style vertical splitterex gripper image
        StartDrawing(ImageOutput(SilverVerticalSplitterOffice2007GripperImage))
          DrawingMode(#PB_2DDrawing_AllChannels)
          Box(0, 0, 19, 3, RGBA(0, 0, 0, 0))
          x = 0 : y = 0
          For n = 0 To 4
            Box(x, y, 2, 2, RGBA(124, 124, 124, 255))
            Box(x+1, y+1, 2, 2, RGBA(249, 249, 251, 255))
            Box(x+1, y+1, 1, 1, RGBA(204, 204, 204, 255))
            x = x + 4
          Next
        StopDrawing()  
        
        Global SilverSplitterOffice2007GripperImage = CreateImage(#PB_Any, 3, 19, 32)
        ; render black office2007 style vertical splitterex gripper image
        StartDrawing(ImageOutput(SilverSplitterOffice2007GripperImage))
          DrawingMode(#PB_2DDrawing_AllChannels)
          Box(0, 0, 3, 19, RGBA(0, 0, 0, 0))
          x = 0 : y = 0
          For n = 0 To 4
            Box(x, y, 2, 2, RGBA(124, 124, 124, 255))
            Box(x+1, y+1, 2, 2, RGBA(249, 249, 251, 255))
            Box(x+1, y+1, 1, 1, RGBA(204, 204, 204, 255))
            y = y + 4
          Next
        StopDrawing()  
        
        ; create system splitter skin Office 2007
        Global office2007SplitterSkin = CreateSkin("office2007SplitterSkin")
        ; vertical
        ; normal
        SetSkinProperty(office2007SplitterSkin, "splitterex", "normal vertical", "gripper size", "width: 100; height: 9;")
