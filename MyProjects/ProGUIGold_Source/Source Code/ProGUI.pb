Procedure InitDwmapi()
  
  Dwmapi = OpenLibrary(#PB_Any, "dwmapi.dll")
  If Dwmapi <> 0
    
    *DwmIsCompositionEnabled = GetFunction(Dwmapi, "DwmIsCompositionEnabled")
    *DwmEnableComposition = GetFunction(Dwmapi, "DwmEnableComposition")
    *DwmSetWindowAttribute = GetFunction(Dwmapi, "DwmSetWindowAttribute")
    *DwmFlush = GetFunction(Dwmapi, "DwmFlush")
    *DwmSetPresentParameters = GetFunction(Dwmapi, "DwmSetPresentParameters")
    
    CallFunctionFast(*DwmIsCompositionEnabled, @CompositionEnabled)
    
  EndIf
  
EndProcedure

Procedure ExitDwmapi()
  If Dwmapi <> 0
    CloseLibrary(Dwmapi)
  EndIf
EndProcedure

Prototype pOpenThemeData(hwnd.i, pszClassList.p-unicode)
Procedure InitXPtheme()

  If XPthemeActive = 0
    XPthemeActive = OpenLibrary(#PB_Any, "UxTheme.dll")
    If XPthemeActive <> 0
      
      *OpenThemeData.pOpenThemeData = GetFunction(XPthemeActive, "OpenThemeData")
      *IsThemeBackgroundPartiallyTransparent = GetFunction(XPthemeActive, "IsThemeBackgroundPartiallyTransparent")
      *DrawThemeBackground = GetFunction(XPthemeActive, "DrawThemeBackground")
      *DrawThemeBackgroundEx = GetFunction(XPthemeActive, "DrawThemeBackgroundEx")
      *DrawThemeParentBackground = GetFunction(XPthemeActive, "DrawThemeParentBackground")
      *DrawThemeParentBackgroundEx = GetFunction(XPthemeActive, "DrawThemeParentBackgroundEx")
      *DrawThemeEdge = GetFunction(XPthemeActive, "DrawThemeEdge")
      *CloseThemeData = GetFunction(XPthemeActive, "CloseThemeData")
      *GetThemeSysColorBrush = GetFunction(XPthemeActive, "GetThemeSysColorBrush")
      *GetThemeSysColor = GetFunction(XPthemeActive, "GetThemeSysColor")
      *GetThemeColor = GetFunction(XPthemeActive, "GetThemeColor")
      *GetThemeRect = GetFunction(XPthemeActive, "GetThemeRect")
      *GetThemeFont = GetFunction(XPthemeActive, "GetThemeFont")
      
      *SetWindowTheme = GetFunction(XPthemeActive, "SetWindowTheme")
      
      *tmem = AllocateMemory(255)
      CallFunction(XPthemeActive, "GetCurrentThemeName", *tmem, 100, 0, 0, 0, 0)
      name.s = PeekS(*tmem, -1, #PB_Unicode)
      FreeMemory(*tmem)
      name = RemoveString(name, " ")
      If name <> ""
        ThemesEnabled = #True
      EndIf
      
      Window = GetForegroundWindow_()

      hTheme = *OpenThemeData(Window, "scrollbar")
      If hTheme <> 0
        XPthemeColour = CallFunctionFast(*GetThemeSysColor, hTheme, 2)
        SetDefaultGlobalSkinColourTheme(XPthemeColour)
        ;Debug "R: "+Str(Red(XPthemeColour))+" G: "+Str(Green(XPthemeColour))+" B: "+Str(Blue(XPthemeColour))
      EndIf
      
      hThemeExplorerbar = *OpenThemeData(Window, "explorerbar")
      hThemeRebar = *OpenThemeData(Window, "rebar")
      hThemeTab = *OpenThemeData(Window, "tab")
      hThemeToolbar = *OpenThemeData(Window, "toolbar")
      hThemeMenu = *OpenThemeData(Window, "menu")
      hThemeButton = *OpenThemeData(Window, "button")
      
    EndIf
  EndIf

  ProcedureReturn XPthemeActive
EndProcedure

Procedure ExitXPtheme()
  If XPthemeActive <> 0
    If hTheme <> 0
      CallFunctionFast(*CloseThemeData, hTheme)
      CallFunctionFast(*CloseThemeData, hThemeExplorerbar)
      CallFunctionFast(*CloseThemeData, hThemeRebar)
      CallFunctionFast(*CloseThemeData, hThemeTab)
      CallFunctionFast(*CloseThemeData, hThemeToolbar)
      CallFunctionFast(*CloseThemeData, hThemeMenu)
      CallFunctionFast(*CloseThemeData, hThemeButton)
    EndIf
    CloseLibrary(XPthemeActive)
  EndIf
EndProcedure


Procedure InitGDIPlus()
  
  If *gdiplusToken = 0
    GDIPlusHandle = OpenLibrary(#PB_Any,"GDIPlus.DLL")
    If GDIPlusHandle
      
      CompilerIf #DEBUGENABLED = -1
        debuglog("GDI+ Library opened ok.")
      CompilerEndIf
      gdpsi.GdiplusStartupInput
      gdpsi\GdiplusVersion = 1
      gdpsi\DebugEventCallback = 0
      gdpsi\SuppressBackgroundThread = #True
      gdpsi\SuppressExternalCodecs = 0
      CompilerIf #DEBUGENABLED = -1
        debuglog("starting GDI+...")
      CompilerEndIf
      CallFunction(GDIPlusHandle, "GdiplusStartup", @*gdiplusToken, @gdpsi, @gdpso)
      CallFunctionFast(gdpso\NotificationHook, @*gdiplusHookToken)
      CompilerIf #DEBUGENABLED = -1
        debuglog("GDI+ started ok: token: "+Str(*gdiplusToken)+" "+Str(*gdiplusHookToken))
        debuglog("hook: "+Str(gdpso\NotificationHook)+" "+Str(gdpso\NotificationUnHook))
      CompilerEndIf
      
      *GdipCreateFromHDC = GetFunction(GDIPlusHandle,"GdipCreateFromHDC")
      *GdipCreateFromHWND = GetFunction(GDIPlusHandle,"GdipCreateFromHWND")
      *GdipCreateLineBrushI = GetFunction(GDIPlusHandle,"GdipCreateLineBrushI")
      *GdipCreateSolidFill = GetFunction(GDIPlusHandle,"GdipCreateSolidFill")
      *GdipFillRectangleI = GetFunction(GDIPlusHandle,"GdipFillRectangleI")
      *GdipFillEllipseI = GetFunction(GDIPlusHandle,"GdipFillEllipseI")
      *GdipDeleteGraphics = GetFunction(GDIPlusHandle,"GdipDeleteGraphics")
      *GdipDeleteBrush = GetFunction(GDIPlusHandle,"GdipDeleteBrush")
      *GdipCreatePathGradientI = GetFunction(GDIPlusHandle,"GdipCreatePathGradientI")
      *GdipSetPathGradientCenterColor = GetFunction(GDIPlusHandle,"GdipSetPathGradientCenterColor")
      *GdipSetPathGradientCenterPointI = GetFunction(GDIPlusHandle,"GdipSetPathGradientCenterPointI")
      *GdipDrawLine = GetFunction(GDIPlusHandle,"GdipDrawLineI")
      *GdipCreatePen1 = GetFunction(GDIPlusHandle,"GdipCreatePen1")
      *GdipDeletePen = GetFunction(GDIPlusHandle,"GdipDeletePen")
      *GdipDrawImage = GetFunction(GDIPlusHandle,"GdipDrawImage")
      *GdipDrawImageI = GetFunction(GDIPlusHandle,"GdipDrawImageI")
      *GdipDrawImageRectI = GetFunction(GDIPlusHandle,"GdipDrawImageRectI")
      *GdipDrawImageRectRect = GetFunction(GDIPlusHandle,"GdipDrawImageRectRect")
      *GdipDrawImageRectRectI = GetFunction(GDIPlusHandle,"GdipDrawImageRectRectI")
      *GdipCreateImageAttributes = GetFunction(GDIPlusHandle,"GdipCreateImageAttributes")
      *GdipSetImageAttributesColorMatrix = GetFunction(GDIPlusHandle,"GdipSetImageAttributesColorMatrix")
      *GdipDisposeImageAttributes = GetFunction(GDIPlusHandle,"GdipDisposeImageAttributes")
      *GdipDisposeImage = GetFunction(GDIPlusHandle,"GdipDisposeImage")
      *GdipCreateBitmapFromHBITMAP = GetFunction(GDIPlusHandle, "GdipCreateBitmapFromHBITMAP")
      *GdipCreateBitmapFromScan0 = GetFunction(GDIPlusHandle, "GdipCreateBitmapFromScan0")
      *GdipCreateBitmapFromGraphics = GetFunction(GDIPlusHandle, "GdipCreateBitmapFromGraphics")
      *GdipCreateBitmapFromGdiDib = GetFunction(GDIPlusHandle, "GdipCreateBitmapFromGdiDib")
      *GdipBitmapSetPixel = GetFunction(GDIPlusHandle, "GdipBitmapSetPixel")
      *GdipBitmapLockBits = GetFunction(GDIPlusHandle, "GdipBitmapLockBits")
      *GdipBitmapUnLockBits = GetFunction(GDIPlusHandle, "GdipBitmapUnlockBits")
      *GdipImageRotateFlip = GetFunction(GDIPlusHandle, "GdipImageRotateFlip")
      *GdipSetCompositingMode = GetFunction(GDIPlusHandle, "GdipSetCompositingMode")
      *GdipSetCompositingQuality = GetFunction(GDIPlusHandle, "GdipSetCompositingQuality")
      *GdipSetPixelOffsetMode = GetFunction(GDIPlusHandle, "GdipSetPixelOffsetMode")
      *GdipSetSmoothingMode = GetFunction(GDIPlusHandle, "GdipSetSmoothingMode")
      *GdipSetLinePresetBlend = GetFunction(GDIPlusHandle, "GdipSetLinePresetBlend")
      *GdipCreatePath = GetFunction(GDIPlusHandle, "GdipCreatePath")
      *GdipCreatePathGradientFromPath = GetFunction(GDIPlusHandle, "GdipCreatePathGradientFromPath")
      *GdipAddPathEllipseI = GetFunction(GDIPlusHandle, "GdipAddPathEllipseI")
      *GdipDeletePath = GetFunction(GDIPlusHandle, "GdipDeletePath")
      *GdipSetPathGradientCenterPoint = GetFunction(GDIPlusHandle, "GdipSetPathGradientCenterPoint")
      
      RetVal = *gdiplusToken
    Else
      RetVal = 0
    EndIf
  Else
    RetVal = *gdiplusToken
  EndIf
  
  ProcedureReturn RetVal
EndProcedure

Procedure ExitGDIPlus()
  
  If GDIPlusHandle <> 0
    CallFunctionFast(gdpso\NotificationUnHook, *gdiplusHookToken)
    CallFunction(GDIPlusHandle, "GdiplusShutdown", *gdiplusToken)
    CloseLibrary(GDIPlusHandle)
  EndIf
  
EndProcedure
;-

Procedure measureMenuItemHeight(hdc.i, MenuItemEx.i)
  
  *thisItemEx = @itemex()
  ChangeCurrentElement(itemex(), MenuItemEx)
  oldFont = SelectObject_(hdc, currentMenuEXFont)
  
  If itemex()\scroll < 0 ; special scroll item button
  
    If itemex()\scroll <> -3 ; not filler
      height = menuScrollButtonHeight
    Else
      height = menuScrollFillerHeight
    EndIf
    
  ElseIf itemex()\text = "" ; separator
    
    ; get associated menuex
    ForEach menuex()
      If menuex()\popupid = itemex()\popupid
        Break
      EndIf
    Next
    
    If menuex()\style < 5
      height = 7
    Else
      height = 2
    EndIf
    
  Else
    
    rec.RECT
    rec\left = 0
    rec\right = 0
    rec\top = 0
    rec\bottom = 0
    renderText(hdc, itemex()\text, rec, 0, #DT_CALCRECT)
    
    height = rec\bottom+(#MENUEXITEMPADY*2)+(#MENUITEMIMAGEPADY*2)
    
    If height < itemex()\imageHeight+(#MENUEXITEMPADY*2)+(#MENUITEMIMAGEPADY*2)
      height = itemex()\imageHeight+(#MENUEXITEMPADY*2)+(#MENUITEMIMAGEPADX*2)
    EndIf
    
    height = height + 3
    
  EndIf
  
  SelectObject_(hdc, oldFont)
  
  ChangeCurrentElement(itemex(), *thisItemEx)
  
  ProcedureReturn height
  
EndProcedure

Procedure measureMenuWidth(MenuItemEx.i)
  
  hdc = CreateCompatibleDC_(0)
  oldFont = SelectObject_(hdc, currentMenuEXFont)
  
  ChangeCurrentElement(itemex(), MenuItemEx)
  
  p = FindString(itemex()\text, #ShortcutCode, 1)
  If p > 0
    txt.s = Mid(itemex()\text, 1, p-1)
    shortcut.s = Mid(itemex()\text, p+1)
    renderText(hdc, txt, @rec.RECT, currentMenuEXFont, #DT_CALCRECT)
    renderText(hdc, shortcut, @rc.RECT, currentMenuEXFont, #DT_CALCRECT)
    width = rec\right+rc\right
  Else 
    renderText(hdc, itemex()\text, @rec.RECT, currentMenuEXFont, #DT_CALCRECT)
    width = rec\right
  EndIf
    
  GetObject_(currentMenuEXFont, SizeOf(LOGFONT), @fontnfo.LOGFONT)
  fheight = fontnfo\lfHeight
  fheight = fontnfo\lfHeight: If fheight<0: fheight = -fheight: EndIf
  fheight*72.0/GetScreenDPI()
  padding = calcSidebarPadding(fheight)
  
  If fheight <= 9
    padding = padding - 2
  EndIf
  
  width = width + (itemex()\imageWidth*2)+padding+GetSystemMetrics_(#SM_CXMENUCHECK)
  
  SelectObject_(hdc, oldFont)
  DeleteDC_(hdc)
  
  ProcedureReturn width
  
EndProcedure


Procedure setDefaultUIColours()
  
  macro_protectCommand()
  
  ;/ set up colour name to value hash table
  colour("aliceblue") = $f0f8ff
  colour("antiquewhite") = $faebd7
  colour("aqua") = $00ffff
  colour("aquamarine") = $7fffd4
  colour("azure") = $f0ffff
  colour("beige") = $f5f5dc
  colour("bisque") = $ffe4c4
  colour("black") = $000000
  colour("blanchedalmond") = $ffebcd
  colour("blue") = $0000ff
  colour("blueviolet") = $8a2be2
  colour("brown") = $a52a2a
  colour("burlywood") = $deb887
  colour("cadetblue") = $5f9ea0
  colour("chartreuse") = $7fff00
  colour("chocolate") = $d2691e
  colour("coral") = $ff7f50
  colour("cornflowerblue") = $6495ed
  colour("cornsilk") = $fff8dc
  colour("crimson") = $dc143c
  colour("cyan") = $00ffff
  colour("darkblue") = $00008b
  colour("darkcyan") = $008b8b
  colour("darkgoldenrod") = $b8860b
