Enumeration ; Unit
    #UnitWorld       ;private, 0 -- World coordinate (non-physical unit)
    #UnitDisplay     ;private, 1 -- Variable -- For PageTransform only
    #UnitPixel       ;private, 2 -- Each unit is one device pixel.
    #UnitPoint       ;private, 3 -- Each unit is a printer's point, or 1/72 inch.
    #UnitInch        ;private, 4 -- Each unit is 1 inch.
    #UnitDocument    ;private, 5 -- Each unit is 1/300 inch.
    #UnitMillimeter  ;private, 6 -- Each unit is 1 millimeter.
EndEnumeration

